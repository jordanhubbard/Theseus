spec: uuid_extra1156
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.uuid1/uuid3/uuid4/uuid5 __module__ and __class__.__name__, uuid.UUID.__name__/__qualname__/__module__ and __init__ method attrs, uuid.NAMESPACE_DNS/URL/OID/X500 __class__.__name__/__qualname__/__module__, uuid.SafeUUID __name__/__qualname__/__module__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1156.generator_module_and_class_name:
  description: "uuid.uuid1, uuid3, uuid4, uuid5 __module__ and __class__.__name__ identity"
  kind: python_call_eq
  category: generator_module_classname
  id_prefix: uu1156gm
  columns: [id, function, args, expected]
  rows:
    - [uu1156gm001, uuid.uuid1.__module__.__eq__,                               ["uuid"],              true]
    - [uu1156gm002, uuid.uuid3.__module__.__eq__,                               ["uuid"],              true]
    - [uu1156gm003, uuid.uuid4.__module__.__eq__,                               ["uuid"],              true]
    - [uu1156gm004, uuid.uuid5.__module__.__eq__,                               ["uuid"],              true]
    - [uu1156gm005, uuid.uuid1.__class__.__name__.__eq__,                       ["function"],          true]
    - [uu1156gm006, uuid.uuid3.__class__.__name__.__eq__,                       ["function"],          true]
    - [uu1156gm007, uuid.uuid4.__class__.__name__.__eq__,                       ["function"],          true]
    - [uu1156gm008, uuid.uuid5.__class__.__name__.__eq__,                       ["function"],          true]
    - [uu1156gm009, uuid.uuid1.__module__.__class__.__name__.__eq__,            ["str"],               true]
    - [uu1156gm010, uuid.uuid4.__module__.__class__.__name__.__eq__,            ["str"],               true]

table uuid_extra1156.uuid_class_name_qualname_module_and_init:
  description: "uuid.UUID __name__/__qualname__/__module__ and __init__/__str__/__repr__ method attrs"
  kind: python_call_eq
  category: uuid_class_name_qualname_module_init
  id_prefix: uu1156ui
  columns: [id, function, args, expected]
  rows:
    - [uu1156ui001, uuid.UUID.__name__.__eq__,                                  ["UUID"],              true]
    - [uu1156ui002, uuid.UUID.__qualname__.__eq__,                              ["UUID"],              true]
    - [uu1156ui003, uuid.UUID.__module__.__eq__,                                ["uuid"],              true]
    - [uu1156ui004, uuid.UUID.__module__.__class__.__name__.__eq__,             ["str"],               true]
    - [uu1156ui005, uuid.UUID.__init__.__qualname__.__eq__,                     ["UUID.__init__"],     true]
    - [uu1156ui006, uuid.UUID.__init__.__class__.__name__.__eq__,               ["function"],          true]
    - [uu1156ui007, uuid.UUID.__init__.__module__.__eq__,                       ["uuid"],              true]
    - [uu1156ui008, uuid.UUID.__str__.__qualname__.__eq__,                      ["UUID.__str__"],      true]
    - [uu1156ui009, uuid.UUID.__repr__.__qualname__.__eq__,                     ["UUID.__repr__"],     true]
    - [uu1156ui010, uuid.UUID.__repr__.__class__.__name__.__eq__,               ["function"],          true]

table uuid_extra1156.namespace_constants_and_safeuuid:
  description: "uuid.NAMESPACE_DNS/URL/OID/X500 class attrs and uuid.SafeUUID __name__/__qualname__/__module__"
  kind: python_call_eq
  category: namespace_constants_safeuuid
  id_prefix: uu1156ns
  columns: [id, function, args, expected]
  rows:
    - [uu1156ns001, uuid.NAMESPACE_DNS.__class__.__name__.__eq__,               ["UUID"],              true]
    - [uu1156ns002, uuid.NAMESPACE_DNS.__class__.__qualname__.__eq__,           ["UUID"],              true]
    - [uu1156ns003, uuid.NAMESPACE_DNS.__class__.__module__.__eq__,             ["uuid"],              true]
    - [uu1156ns004, uuid.NAMESPACE_URL.__class__.__name__.__eq__,               ["UUID"],              true]
    - [uu1156ns005, uuid.NAMESPACE_OID.__class__.__name__.__eq__,               ["UUID"],              true]
    - [uu1156ns006, uuid.NAMESPACE_X500.__class__.__name__.__eq__,              ["UUID"],              true]
    - [uu1156ns007, uuid.NAMESPACE_URL.__class__.__module__.__eq__,             ["uuid"],              true]
    - [uu1156ns008, uuid.NAMESPACE_OID.__class__.__module__.__eq__,             ["uuid"],              true]
    - [uu1156ns009, uuid.SafeUUID.__name__.__eq__,                              ["SafeUUID"],          true]
    - [uu1156ns010, uuid.SafeUUID.__qualname__.__eq__,                          ["SafeUUID"],          true]
    - [uu1156ns011, uuid.SafeUUID.__module__.__eq__,                            ["uuid"],              true]
    - [uu1156ns012, uuid.NAMESPACE_DNS.__class__.__name__.__class__.__name__.__eq__, ["str"],          true]
