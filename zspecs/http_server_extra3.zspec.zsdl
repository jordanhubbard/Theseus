spec: http_server_extra3
version: ">=3.9"
backend: python_module(http.server)

docs: https://docs.python.org/3/library/http.server.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.server.html — Python http.server module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/server.py"
  notes:
    - "This spec extends http_server.zspec.zsdl, http_server_handlers.zspec.zsdl, http_server_extra.zspec.zsdl, and http_server_extra2.zspec.zsdl."
    - "http_server.zspec.zsdl covers: class_names table (HTTPServer/ThreadingHTTPServer/Base/Simple/CGIHTTPRequestHandler), BaseHTTPRequestHandler string constants (server_version/protocol_version/default_request_version/error_content_type), extensions_map type."
    - "http_server_handlers.zspec.zsdl covers: modules table (Base/Simple/CGI/HTTPServer), hierarchy (Simple→Base, CGI→Simple, HTTP→TCPServer), error_message_format type/nonempty, SimpleHTTP server_version prefix, cgi_directories type/contents (/cgi-bin, /htbin)."
    - "http_server_extra.zspec.zsdl covers: BaseHTTPRequestHandler base (StreamRequestHandler), ThreadingHTTPServer module/bases[0]/[1], handler string attr types, HTTPServer/CGIHTTPRequestHandler __qualname__, SimpleHTTPRequestHandler.index_pages type/contains index.html, BaseHTTPRequestHandler.responses type/contains 200."
    - "http_server_extra2.zspec.zsdl covers: ThreadingHTTPServer/BaseHTTPRequestHandler/SimpleHTTPRequestHandler __qualname__, DEFAULT_ERROR_MESSAGE type, DEFAULT_ERROR_CONTENT_TYPE type/value, BaseHTTPRequestHandler rbufsize/wbufsize/disable_nagle_algorithm, responses contains 404/500, index_pages len/contains index.htm, SimpleHTTPRequestHandler.server_version exact value."
    - "Focus: new axes not present in any prior http.server spec."
    - "BaseHTTPRequestHandler.responses contains 301 and 302 — redirect codes; prior specs check 200/404/500 but not redirect codes."
    - "CGIHTTPRequestHandler.cgi_directories.__len__() == 2 — exactly two default directories; prior specs verify type and contents but not length."
    - "SimpleHTTPRequestHandler.extensions_map contains '.html' and '' (empty string for binary/octet-stream) — content-type mapping; prior specs only check that extensions_map is a dict."
    - "DEFAULT_ERROR_MESSAGE.__len__() > 0 — the error HTML template is non-empty; prior specs check type but not length."
    - "BaseHTTPRequestHandler.server_version.__class__.__name__ == 'str' — redundant type check covered in extra; this spec adds __len__ > 0 checks on server_version and protocol_version strings."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseHTTPRequestHandler.responses — redirect status codes not yet checked
# http_server_extra covers type and 200 presence.
# http_server_extra2 covers 404 and 500 presence.
# 301 (Moved Permanently) and 302 (Found) are new.
# ---------------------------------------------------------------------------

invariant http_server_extra3.responses.contains_301:
  description: "301 in BaseHTTPRequestHandler.responses — Moved Permanently must be present"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.responses.__contains__
  args: [301]
  expected: true

invariant http_server_extra3.responses.contains_302:
  description: "302 in BaseHTTPRequestHandler.responses — Found must be present"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.responses.__contains__
  args: [302]
  expected: true

# ---------------------------------------------------------------------------
# CGIHTTPRequestHandler.cgi_directories — length check
# http_server_handlers covers type (list) and contains '/cgi-bin' and '/htbin'.
# The exact count (2) has not been verified in any prior spec.
# ---------------------------------------------------------------------------

invariant http_server_extra3.CGIHTTPRequestHandler.cgi_directories_len:
  description: "len(CGIHTTPRequestHandler.cgi_directories) == 2 — exactly two default CGI directories"
  category: constants
  kind: python_call_eq
  function: CGIHTTPRequestHandler.cgi_directories.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# SimpleHTTPRequestHandler.extensions_map — content-type mapping checks
# http_server.zspec.zsdl verifies extensions_map is a dict.
# The presence of specific extension keys has not been checked in any prior spec.
# '.html' -> 'text/html' and '' -> 'application/octet-stream' are standard entries.
# ---------------------------------------------------------------------------

invariant http_server_extra3.extensions_map.contains_html:
  description: "'.html' in SimpleHTTPRequestHandler.extensions_map — HTML extension must be present"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.extensions_map.__contains__
  args: [".html"]
  expected: true

invariant http_server_extra3.extensions_map.contains_empty_key:
  description: "'' in SimpleHTTPRequestHandler.extensions_map — empty-string key for unknown types"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.extensions_map.__contains__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_ERROR_MESSAGE — non-empty length check
# http_server_extra2 verifies type is str.
# The length (non-zero) has not been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant http_server_extra3.DEFAULT_ERROR_MESSAGE.nonempty:
  description: "len(DEFAULT_ERROR_MESSAGE) > 0 — error HTML template must be non-empty"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ERROR_MESSAGE.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# BaseHTTPRequestHandler string constant non-empty length checks
# http_server.zspec.zsdl verifies exact values; http_server_extra verifies str type.
# __len__ > 0 as a separate dimension is new.
# ---------------------------------------------------------------------------

table http_server_extra3.handler_string_nonempty:
  kind: python_call_eq
  category: constants
  id_prefix: nonempty

  columns: [id, function, args, expected]
  rows:
    - [server_version,          BaseHTTPRequestHandler.server_version.__len__,          [], 14]
    - [protocol_version,        BaseHTTPRequestHandler.protocol_version.__len__,        [], 8 ]
    - [default_request_version, BaseHTTPRequestHandler.default_request_version.__len__, [], 8 ]

# ---------------------------------------------------------------------------
# SimpleHTTPRequestHandler extensions_map value — HTML content-type value
# Prior specs check only the presence of keys; the mapped value for .html
# has not been verified.
# ---------------------------------------------------------------------------

invariant http_server_extra3.extensions_map.html_value:
  description: "SimpleHTTPRequestHandler.extensions_map['.html'] == 'text/html'"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.extensions_map.__getitem__
  args: [".html"]
  expected: "text/html"
