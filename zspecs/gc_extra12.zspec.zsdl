spec: gc_extra12
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra11.zspec.zsdl."
    - "gc_extra11 covers __qualname__ for collect/get_count/get_threshold/get_objects."
    - "gc_extra5 covers __name__ for is_finalized/freeze/unfreeze/get_freeze_count via __module__ table."
    - "gc_extra4 covers __name__ for enable/disable/isenabled/collect/get_count/get_threshold/set_threshold/get_objects/get_referrers/get_referents via table."
    - "NOT yet covered: __qualname__ for is_finalized/freeze/unfreeze/get_freeze_count/get_referrers/get_referents/set_threshold/is_tracked."
    - "NOT yet covered: gc.get_threshold()[0] default value (700) as a standalone invariant."
    - "NOT yet covered: gc.get_freeze_count().__class__.__name__ == 'int' via __eq__ chain."
    - "NOT yet covered: gc.is_finalized.__name__.__eq__('is_finalized') standalone invariant."
    - "NOT yet covered: gc.freeze.__name__.__eq__('freeze') standalone invariant."
    - "NOT yet covered: gc.unfreeze.__name__.__eq__('unfreeze') standalone invariant."
    - "NOT yet covered: gc.get_freeze_count.__name__.__eq__('get_freeze_count') standalone invariant."
    - "For C builtin functions, __qualname__ == __name__."
    - "gc.get_threshold()[0] == 700 — CPython default generation-0 threshold."
    - "gc.get_freeze_count() returns an int — number of objects in the frozen generation."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ — remaining gc functions not in gc_extra11
#
# gc_extra11 covers __qualname__ for collect/get_count/get_threshold/get_objects.
# This spec adds __qualname__ for the remaining public gc functions:
# is_finalized, freeze, unfreeze, get_freeze_count, get_referrers, get_referents,
# set_threshold, is_tracked. For C builtin functions, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table gc_extra12.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [is_finalized,    is_finalized.__qualname__.__eq__,    ["is_finalized"],    true]
    - [freeze,          freeze.__qualname__.__eq__,          ["freeze"],          true]
    - [unfreeze,        unfreeze.__qualname__.__eq__,        ["unfreeze"],        true]
    - [get_freeze_count, get_freeze_count.__qualname__.__eq__, ["get_freeze_count"], true]
    - [get_referrers,   get_referrers.__qualname__.__eq__,   ["get_referrers"],   true]
    - [get_referents,   get_referents.__qualname__.__eq__,   ["get_referents"],   true]
    - [set_threshold,   set_threshold.__qualname__.__eq__,   ["set_threshold"],   true]
    - [is_tracked,      is_tracked.__qualname__.__eq__,      ["is_tracked"],      true]

# ---------------------------------------------------------------------------
# Function __name__ — extra12-namespace anchors for remaining functions
#
# gc_extra4 covers __name__ for 10 functions via a table. gc_extra5 covers
# is_finalized/freeze/unfreeze/get_freeze_count __module__. No prior spec
# covers __name__.__eq__() as standalone boolean invariants for these four.
# ---------------------------------------------------------------------------

invariant gc_extra12.is_finalized.name:
  description: "gc.is_finalized.__name__.__eq__('is_finalized') == True — C builtin function name"
  category: function_names
  kind: python_call_eq
  function: is_finalized.__name__.__eq__
  args: ["is_finalized"]
  expected: true

invariant gc_extra12.freeze.name:
  description: "gc.freeze.__name__.__eq__('freeze') == True — C builtin function name"
  category: function_names
  kind: python_call_eq
  function: freeze.__name__.__eq__
  args: ["freeze"]
  expected: true

invariant gc_extra12.unfreeze.name:
  description: "gc.unfreeze.__name__.__eq__('unfreeze') == True — C builtin function name"
  category: function_names
  kind: python_call_eq
  function: unfreeze.__name__.__eq__
  args: ["unfreeze"]
  expected: true

invariant gc_extra12.get_freeze_count.name:
  description: "gc.get_freeze_count.__name__.__eq__('get_freeze_count') == True — C builtin function name"
  category: function_names
  kind: python_call_eq
  function: get_freeze_count.__name__.__eq__
  args: ["get_freeze_count"]
  expected: true

# ---------------------------------------------------------------------------
# get_threshold — generation-0 default value
#
# gc_extra8 covers get_threshold()[1] == 10 (gen-1 default).
# gc_extra9 covers get_threshold()[2] == 10 (gen-2 default).
# No prior spec covers get_threshold()[0] == 700 (gen-0 default).
# The documented CPython default for generation 0 is 700.
# ---------------------------------------------------------------------------

invariant gc_extra12.get_threshold.gen0_default:
  description: "gc.get_threshold()[0] == 700 — CPython default generation-0 threshold is 700"
  category: threshold
  kind: python_call_eq
  function: get_threshold().__getitem__(0).__eq__
  args: [700]
  expected: true

# ---------------------------------------------------------------------------
# get_freeze_count — return type is int
#
# gc_extra and gc_extra7 cover get_freeze_count().__class__.__name__ == 'int'
# via invariant block method chain. No prior spec checks this via the dotted
# function chain syntax used in extra8/extra9 (collect/get_objects patterns).
# This asserts it as a standalone named invariant in the extra12 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra12.get_freeze_count.returns_int:
  description: "gc.get_freeze_count().__class__.__name__ == 'int' — returns frozen object count as int"
  category: get_freeze_count
  kind: python_call_eq
  function: get_freeze_count().__class__.__name__.__eq__
  args: ["int"]
  expected: true
