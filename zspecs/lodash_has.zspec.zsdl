spec: lodash_has
version: ">=4.0.0"
backend: node(lodash.has)

docs: https://lodash.com/docs/#has

provenance:
  derived_from:
    - "lodash.has README — https://www.npmjs.com/package/lodash.has"
    - "Test vectors verified with lodash.has@4.5.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.has exports the _.has function directly as module.exports."
    - "has(object, path) checks if path is a direct property of object."
    - "Supports nested dot-path notation."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_has.has:
  kind: node_module_call_eq
  function: ~
  category: has
  id_prefix: lhas

  columns: [id, args, expected]
  rows:
    - [present,    [{"a": 1, "b": 2}, "a"],       true]
    - [absent,     [{"a": 1}, "b"],                false]
    - [nested,     [{"a": {"b": 1}}, "a.b"],       true]
    - [nested_no,  [{"a": {"b": 1}}, "a.c"],       false]
