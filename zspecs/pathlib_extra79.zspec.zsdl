spec: pathlib_extra79
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra78."
    - "Prior specs covered: PurePath/PurePosixPath/PureWindowsPath/Path/PosixPath/WindowsPath __name__/__module__/__qualname__; Path instance attributes; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes; PurePath __dict__ membership; __bases__ and MRO lengths."
    - "pathlib_extra78 covers PurePath __dict__ membership (joinpath, __new__, parser, with_segments); PurePath/PurePosixPath/PureWindowsPath/Path __bases__[0].__name__ and __mro__.__len__()."
    - "This spec covers: Path.__dict__ content — what methods are directly defined on Path; Path.__dict__.__class__.__name__; Path.__dict__.__contains__ for open/read_text/write_text/iterdir/mkdir/exists/unlink; PurePath.__dict__.__contains__ for __str__ and joinpath."
    - "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' — Path class dict is a mappingproxy."
    - "pathlib.Path.__dict__.__contains__('open') == True — Path directly defines open."
    - "pathlib.Path.__dict__.__contains__('read_text') == True — Path directly defines read_text."
    - "pathlib.Path.__dict__.__contains__('write_text') == True — Path directly defines write_text."
    - "pathlib.Path.__dict__.__contains__('iterdir') == True — Path directly defines iterdir."
    - "pathlib.Path.__dict__.__contains__('mkdir') == True — Path directly defines mkdir."
    - "pathlib.Path.__dict__.__contains__('exists') == True — Path directly defines exists."
    - "pathlib.Path.__dict__.__contains__('unlink') == True — Path directly defines unlink."
    - "pathlib.PurePath.__dict__.__class__.__name__ == 'mappingproxy' — PurePath class dict is a mappingproxy."
    - "pathlib.PurePath.__dict__.__contains__('__str__') == True — PurePath defines __str__."
    - "pathlib.PurePath.__dict__.__contains__('joinpath') == True — PurePath defines joinpath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.__dict__ class check
# Path is a pure Python class in pathlib; its __dict__ is a mappingproxy.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra79.Path_dict_class:
  description: "Path.__dict__ is a mappingproxy"
  kind: python_call_eq
  category: class_dict
  id_prefix: pathlibmore79

  columns: [id, function, args, expected]
  rows:
    - [path_dict_class, Path.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# Path.__dict__ membership for IO methods
# Path directly defines open, read_text, write_text. These are in its own
# __dict__, not inherited from PurePath. Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra79.Path_dict_io_methods:
  description: "Path.__dict__ contains open, read_text, write_text"
  kind: python_call_eq
  category: class_dict
  id_prefix: pathlibmore79

  columns: [id, function, args, expected]
  rows:
    - [has_open,       "Path.__dict__.__contains__", ["open"],       true]
    - [has_read_text,  "Path.__dict__.__contains__", ["read_text"],  true]
    - [has_write_text, "Path.__dict__.__contains__", ["write_text"], true]

# ---------------------------------------------------------------------------
# Path.__dict__ membership for filesystem operation methods
# iterdir, mkdir, exists, unlink are defined directly on Path.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra79.Path_dict_fs_methods:
  description: "Path.__dict__ contains iterdir, mkdir, exists, unlink"
  kind: python_call_eq
  category: class_dict
  id_prefix: pathlibmore79

  columns: [id, function, args, expected]
  rows:
    - [has_iterdir, "Path.__dict__.__contains__", ["iterdir"], true]
    - [has_mkdir,   "Path.__dict__.__contains__", ["mkdir"],   true]
    - [has_exists,  "Path.__dict__.__contains__", ["exists"],  true]
    - [has_unlink,  "Path.__dict__.__contains__", ["unlink"],  true]

# ---------------------------------------------------------------------------
# PurePath.__dict__ class check and membership for __str__ and joinpath
# PurePath is the pure-path base; it defines __str__ and joinpath in its
# own __dict__. Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra79.PurePath_dict_extra:
  description: "PurePath.__dict__ class check and __str__/joinpath membership"
  kind: python_call_eq
  category: class_dict
  id_prefix: pathlibmore79

  columns: [id, function, args, expected]
  rows:
    - [purepath_dict_class,  PurePath.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [purepath_has_str,     "PurePath.__dict__.__contains__",            ["__str__"],      true]
    - [purepath_has_joinpath,"PurePath.__dict__.__contains__",            ["joinpath"],     true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra79.Path_dict.mappingproxy:
  description: "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: Path.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant pathlib_extra79.Path_dict.has_open:
  description: "pathlib.Path.__dict__.__contains__('open') == True"
  category: class_dict
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["open"]
  expected: true

invariant pathlib_extra79.Path_dict.has_read_text:
  description: "pathlib.Path.__dict__.__contains__('read_text') == True"
  category: class_dict
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["read_text"]
  expected: true

invariant pathlib_extra79.PurePath_dict.has_str:
  description: "pathlib.PurePath.__dict__.__contains__('__str__') == True"
  category: class_dict
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["__str__"]
  expected: true

invariant pathlib_extra79.PurePath_dict.has_joinpath:
  description: "pathlib.PurePath.__dict__.__contains__('joinpath') == True"
  category: class_dict
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["joinpath"]
  expected: true
