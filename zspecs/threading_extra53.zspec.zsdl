spec: threading_extra53
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra52.zspec.zsdl."
    - "Prior specs covered: Thread/__module__/__eq__('threading') (extra16/extra44/extra48); Event/__module__/__eq__('threading') (extra16/extra19/extra44); Semaphore/__module__/__eq__('threading') (extra11/extra16/extra19); BoundedSemaphore/__module__/__eq__('threading') (extra16/extra19); Condition/__module__/__eq__('threading') (extra16/extra19); Barrier/__module__/__eq__('threading') (extra16/extra19); Timer/__module__/__eq__('threading') (extra16/extra19); Thread/__module__/__len__()==9 (extra34/extra48); Event/__module__/__len__()==9 (extra34); Condition/__module__/__len__()==9 (extra34/extra48); Semaphore/__module__/__len__()==9 (extra34/extra48); BoundedSemaphore/__module__/__len__()==9 (extra34/extra48); Timer/__module__/__len__()==9 (extra34/extra48); Barrier/__module__/__len__()==9 (extra34/extra48); main_thread/__module__/__eq__('threading') (extra44/extra47); current_thread/__module__/__eq__('threading') (extra44/extra47); active_count/__module__/__eq__('threading') (extra44/extra47); enumerate/__module__/__eq__('threading') (extra44/extra47); __all__/__class__/__name__/__eq__('list') (extra52); __all__/__class__/__qualname__/__eq__('list') (extra52)."
    - "This spec covers: threading.Thread.__module__.__class__.__name__.__eq__('str')==true; threading.Event.__module__.__class__.__name__.__eq__('str')==true; threading.Semaphore.__module__.__class__.__name__.__eq__('str')==true; threading.BoundedSemaphore.__module__.__class__.__name__.__eq__('str')==true; threading.Condition.__module__.__class__.__name__.__eq__('str')==true; threading.Barrier.__module__.__class__.__name__.__eq__('str')==true; threading.Timer.__module__.__class__.__name__.__eq__('str')==true; threading.main_thread.__module__.__len__()==9; threading.enumerate.__module__.__len__()==9."
    - "Key findings: All threading pure-Python classes and functions store their __module__ as the Python string 'threading' (9 chars). Since this string is a Python str object, its __class__ is the str built-in type, and str.__name__ == 'str' (3 chars). Prior specs extensively covered __module__.__eq__('threading') and __module__.__len__()==9 for all major threading classes (Thread/Event/Semaphore/BoundedSemaphore/Condition/Barrier/Timer) and functions (main_thread/current_thread/active_count/enumerate). No prior threading spec records __module__.__class__.__name__.__eq__('str') for any threading class or function — the class-of-module-string dimension is new to extra53. Additionally, threading function __module__.__len__()==9 for main_thread and enumerate was not recorded as explicit rows in prior specs (only the class-level __len__ rows exist). Note: threading.Lock() returns a _thread.lock instance whose __module__ is '_thread' (7 chars), not 'threading'; Lock is excluded to avoid uncertainty. All nine invariants are new to extra53."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading class __module__.__class__.__name__ == 'str' — extra53 namespace
#
# All pure-Python threading synchronization classes store their __module__
# as the Python string 'threading' (9 chars). This string is a str object,
# so its __class__ is the built-in str type, and str.__name__ == 'str' (3 chars).
# Prior specs confirmed __module__.__eq__('threading') and __module__.__len__()==9
# for all seven classes below, but no prior threading spec records
# T.__module__.__class__.__name__.__eq__('str') for any threading class.
# All seven checks are new to extra53. Note: threading.Lock() returns a
# _thread.lock (C-extension) whose __module__ == '_thread'; Lock is excluded.
# ---------------------------------------------------------------------------

table threading_extra53.class_module_class_name:
  description: "threading class __module__.__class__.__name__ == 'str' — all pure-Python threading classes store __module__ as a Python str object; str.__name__ == 'str' (3 chars); no prior threading spec records this class-of-module-string dimension for any class"
  kind: python_call_eq
  category: identity
  id_prefix: thrdmod53

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_module_class_name,
       Thread.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Thread.__module__.__class__.__name__ == 'str' — Thread is a pure-Python class in Lib/threading.py; __module__ is the Python string 'threading' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed Thread.__module__.__eq__('threading') and Thread.__module__.__len__()==9; this is the first __module__.__class__.__name__ check for any threading class; new to extra53"]
    - [Event_module_class_name,
       Event.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Event.__module__.__class__.__name__ == 'str' — Event is a pure-Python class in Lib/threading.py; __module__ is the Python string 'threading' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed Event.__module__.__eq__('threading') and Event.__module__.__len__()==9; this is the first __module__.__class__.__name__ check for Event; new to extra53"]
    - [Semaphore_module_class_name,
       Semaphore.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Semaphore.__module__.__class__.__name__ == 'str' — Semaphore is a pure-Python class in Lib/threading.py; __module__ is the Python string 'threading' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed Semaphore.__module__.__eq__('threading') and Semaphore.__module__.__len__()==9; this is the first __module__.__class__.__name__ check for Semaphore; new to extra53"]
    - [BoundedSemaphore_module_class_name,
       BoundedSemaphore.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.BoundedSemaphore.__module__.__class__.__name__ == 'str' — BoundedSemaphore is a pure-Python class in Lib/threading.py; __module__ is the Python string 'threading' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed BoundedSemaphore.__module__.__eq__('threading') and BoundedSemaphore.__module__.__len__()==9; this is the first __module__.__class__.__name__ check for BoundedSemaphore; new to extra53"]
    - [Condition_module_class_name,
       Condition.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Condition.__module__.__class__.__name__ == 'str' — Condition is a pure-Python class in Lib/threading.py; __module__ is the Python string 'threading' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed Condition.__module__.__eq__('threading') and Condition.__module__.__len__()==9; this is the first __module__.__class__.__name__ check for Condition; new to extra53"]
    - [Barrier_module_class_name,
       Barrier.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Barrier.__module__.__class__.__name__ == 'str' — Barrier is a pure-Python class in Lib/threading.py; __module__ is the Python string 'threading' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed Barrier.__module__.__eq__('threading') and Barrier.__module__.__len__()==9; this is the first __module__.__class__.__name__ check for Barrier; new to extra53"]
    - [Timer_module_class_name,
       Timer.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Timer.__module__.__class__.__name__ == 'str' — Timer is a pure-Python class in Lib/threading.py (a Thread subclass that runs a function after a specified delay); __module__ is the Python string 'threading' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed Timer.__module__.__eq__('threading') and Timer.__module__.__len__()==9; this is the first __module__.__class__.__name__ check for Timer; new to extra53"]

# ---------------------------------------------------------------------------
# threading function __module__.__len__() — extra53 namespace
#
# Prior specs recorded __module__.__len__()==9 for all major threading classes
# (Thread/Event/Semaphore/BoundedSemaphore/Condition/Barrier/Timer) in extra34
# and extra48. However, the threading functions (main_thread, current_thread,
# active_count, enumerate) had their __module__.__eq__ confirmed (extra44/extra47)
# but their __module__.__len__() was not recorded as explicit rows. The two
# checks below (main_thread and enumerate) are new to extra53.
# ---------------------------------------------------------------------------

table threading_extra53.function_module_len:
  description: "threading function __module__.__len__()==9 — 'threading' is 9 chars; main_thread and enumerate __module__.__len__ not recorded as explicit rows in prior specs; class-level __len__==9 confirmed in extra34/extra48 but function-level not yet recorded"
  kind: python_call_eq
  category: identity
  id_prefix: thrdmod53

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_module_len,
       main_thread.__module__.__len__,
       [],
       9,
       "threading.main_thread.__module__.__len__() == 9 — 'threading' has 9 characters; main_thread is a pure-Python function in Lib/threading.py that returns the MainThread singleton; prior specs confirmed main_thread.__module__.__eq__('threading') (extra44/extra47); this is the first explicit __module__.__len__() row for main_thread; consistent with all other threading pure-Python symbols whose __module__ is 'threading' (9 chars); new to extra53"]
    - [enumerate_module_len,
       enumerate.__module__.__len__,
       [],
       9,
       "threading.enumerate.__module__.__len__() == 9 — 'threading' has 9 characters; threading.enumerate is a pure-Python function in Lib/threading.py that returns a list of all live Thread objects (shadows the built-in enumerate); prior specs confirmed enumerate.__module__.__eq__('threading') (extra44/extra47); this is the first explicit __module__.__len__() row for threading.enumerate; new to extra53"]
