spec: uuid_extra167
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra166.zspec.zsdl — covers uuid.UUID.hex/int/bytes/version fget __name__ attributes / UUID.__slots__.__class__.__name__=='tuple' / UUID.__slots__.__len__()==3 (table + invariants)."
    - "uuid_extra165.zspec.zsdl — covers uuid.UUID.__name__=='UUID' / __module__=='uuid' (both 4 chars) / UUID.__mro__.__len__()==2 / UUID.__init__.__code__.co_argcount==7 / NAMESPACE_DNS/URL class names / RFC_4122 class name (table + invariants)."
    - "uuid_extra164.zspec.zsdl — covers uuid.UUID.__mro__.__len__()==2 / uuid.SafeUUID.__mro__.__len__()==3 / uuid1/uuid3/uuid4/uuid5 __qualname__ attributes / uuid4.__class__.__name__=='function' (table + invariants)."
    - "uuid_extra163.zspec.zsdl — covers uuid.__name__/__package__/__spec__/__doc__ module-level identity and UUID.__dict__ v1 timestamp fields (table + invariants)."
    - "uuid_extra162.zspec.zsdl — covers uuid.UUID.__dict__.__contains__ for __init__/__new__/__repr__ and UUID.__dict__.__len__()==37 (table + invariants)."
    - "uuid_extra161.zspec.zsdl — covers uuid.NAMESPACE_DNS/__NAMESPACE_URL class names / UUID.__dict__.__contains__ for __int__/__hash__/__eq__/__str__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__=='uuid' and uuid.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra166."
    - "Wave 354 theme: uuid generation functions — uuid.uuid1.__name__=='uuid1' (len=5); uuid.uuid1.__module__=='uuid'; uuid.uuid3.__name__=='uuid3' (len=5; same as uuid1); uuid.uuid4.__name__=='uuid4' (len=5; same as uuid1 and uuid3); uuid.uuid5.__name__=='uuid5' (len=5; same as all others); uuid.uuid4.__code__.co_argcount==0 (uuid4 takes no arguments); uuid.uuid1.__code__.co_argcount==2 (node and clock_seq). These anchor the function __name__ and __code__.co_argcount identity of the uuid generation functions as novel content under uuidfns167."
    - "uuid.uuid1.__name__ == 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid1 generates time-based UUIDs; __name__ is 'uuid1' (5 chars)."
    - "uuid.uuid1.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid1 is defined in the uuid module."
    - "uuid.uuid3.__name__ == 'uuid3'. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid3 generates name-based UUIDs using MD5; __name__ is 'uuid3' (5 chars)."
    - "uuid.uuid4.__name__ == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid4 generates random UUIDs; __name__ is 'uuid4' (5 chars)."
    - "uuid.uuid5.__name__ == 'uuid5'. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid5 generates name-based UUIDs using SHA-1; __name__ is 'uuid5' (5 chars)."
    - "uuid.uuid4.__code__.co_argcount == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid4 takes no arguments — it generates a completely random UUID."
    - "uuid.uuid1.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid1 takes node and clock_seq as optional arguments."
    - "Note: uuid.uuid1.__name__(5) == uuid.uuid3.__name__.__len__()==5 == uuid.uuid4.__name__.__len__()==5 == uuid.uuid5.__name__.__len__()==5. Four-way tie at 5 chars: all four uuid generation functions have 5-char names ('uuid1', 'uuid3', 'uuid4', 'uuid5')."
    - "Note: uuid.uuid4.__code__.co_argcount==0 vs uuid.uuid1.__code__.co_argcount==2. uuid4 requires no arguments (pure random generation) while uuid1 accepts 2 optional arguments (node and clock_seq for host-based UUID generation)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1.__name__ == 'uuid1'
# uuid.uuid3.__name__ == 'uuid3'
# uuid.uuid4.__name__ == 'uuid4'
# uuid.uuid5.__name__ == 'uuid5'
#
# Wave 354 theme: uuid generation function __name__ identity — 4-way tie at 5 chars.
#
# uuid1.__name__ is 'uuid1' (5 chars).
# uuid3.__name__ is 'uuid3' (5 chars; tied with uuid1).
# uuid4.__name__ is 'uuid4' (5 chars; tied with uuid1 and uuid3).
# uuid5.__name__ is 'uuid5' (5 chars; all four tied).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra167.uuid_fn_names_all_five_chars:
  description: "uuid.uuid1.__name__.__eq__('uuid1')==True / uuid.uuid3.__name__.__eq__('uuid3')==True / uuid.uuid4.__name__.__eq__('uuid4')==True / uuid.uuid5.__name__.__eq__('uuid5')==True — uuid1.__name__ is 'uuid1' (5 chars; uuid.uuid1 generates a time-based UUID (version 1) using the current timestamp and the host's MAC address; the version 1 UUID encodes a 60-bit timestamp from a 100-nanosecond epoch; __name__=='uuid1' (5 chars; 'uuid' + '1') — the function name reflects the UUID version it generates; novel anchor: no prior uuid spec anchors uuid1.__name__ under uuidfns167; first uuidfns167 anchor for 'uuid1' as __name__); uuid3.__name__ is 'uuid3' (5 chars; uuid.uuid3 generates a name-based UUID (version 3) using MD5 hashing of a namespace UUID and a name string; uuid3 is deterministic: same namespace+name always produces the same UUID; uuid3.__name__=='uuid3'(5) == uuid1.__name__.__len__()==5: tied at 5 chars; novel anchor: first uuidfns167 anchor for uuid3.__name__=='uuid3'); uuid4.__name__ is 'uuid4' (5 chars; uuid.uuid4 generates a random UUID (version 4) using the operating system's cryptographically secure random number generator; uuid4 is the most commonly used UUID generator for general purposes; uuid4.__name__=='uuid4'(5) — 4-way tie: uuid1/uuid3/uuid4/uuid5 all have 5-char names; novel anchor: first uuidfns167 anchor for uuid4.__name__=='uuid4'); uuid5.__name__ is 'uuid5' (5 chars; uuid.uuid5 generates a name-based UUID (version 5) using SHA-1 hashing instead of MD5; uuid5 is preferred over uuid3 for new applications due to SHA-1 being stronger than MD5; uuid5.__name__=='uuid5'(5) — completes the 4-way tie; novel anchor: first uuidfns167 anchor for uuid5.__name__=='uuid5')"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfns167

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_name_uuid1, uuid1.__name__.__eq__, ["uuid1"], true, "uuid.uuid1.__name__ == 'uuid1' (5 chars; time-based v1 UUID; novel anchor)"]
    - [uuid3_name_uuid3, uuid3.__name__.__eq__, ["uuid3"], true, "uuid.uuid3.__name__ == 'uuid3' (5 chars; MD5 name-based; tied with uuid1(5); novel anchor)"]
    - [uuid4_name_uuid4, uuid4.__name__.__eq__, ["uuid4"], true, "uuid.uuid4.__name__ == 'uuid4' (5 chars; random v4 UUID; 4-way tie; novel anchor)"]
    - [uuid5_name_uuid5, uuid5.__name__.__eq__, ["uuid5"], true, "uuid.uuid5.__name__ == 'uuid5' (5 chars; SHA-1 name-based; completes 4-way tie; novel anchor)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__ == 'uuid'
# uuid.uuid4.__module__ == 'uuid'
# uuid.uuid1.__name__.__len__() == 5
# uuid.uuid4.__name__.__len__() == 5
#
# Wave 354 theme: uuid generation function __module__ and name length confirmation.
#
# uuid1.__module__ is 'uuid' (4 chars).
# uuid4.__module__ is 'uuid' (4 chars; tied with uuid1).
# uuid1.__name__.__len__() is 5.
# uuid4.__name__.__len__() is 5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra167.uuid_fn_module_and_name_lengths:
  description: "uuid.uuid1.__module__.__eq__('uuid')==True / uuid.uuid4.__module__.__eq__('uuid')==True / uuid.uuid1.__name__.__len__()==5 / uuid.uuid4.__name__.__len__()==5 — uuid1.__module__ is 'uuid' (4 chars; uuid.uuid1 is defined in the uuid module; __module__=='uuid' (4 chars) — the module name is 4 chars, 1 less than the function names which are 5 chars; novel anchor: no prior uuid spec anchors uuid1.__module__ under uuidfns167; first uuidfns167 anchor for 'uuid' as uuid1.__module__); uuid4.__module__ is 'uuid' (4 chars; uuid.uuid4 is also defined in the uuid module; uuid4.__module__(4) == uuid1.__module__.__len__()==4: both functions share the same 4-char module name; novel anchor: first uuidfns167 anchor for uuid4.__module__=='uuid'); uuid1.__name__.__len__() is 5 (len('uuid1')==5; integer confirmation; 5 > 4 by 1: function names are 1 char longer than the module name; novel __len__ anchor); uuid4.__name__.__len__() is 5 (len('uuid4')==5; same as uuid1; confirms 4-way name-length tie across all uuid generation functions; novel __len__ anchor)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfns167

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_module_uuid, uuid1.__module__.__eq__,  ["uuid"], true, "uuid.uuid1.__module__ == 'uuid' (4 chars; defined in uuid; novel anchor)"]
    - [uuid4_module_uuid, uuid4.__module__.__eq__,  ["uuid"], true, "uuid.uuid4.__module__ == 'uuid' (4 chars; tied with uuid1 module; novel anchor)"]
    - [uuid1_name_len_5,  uuid1.__name__.__len__,   [],       5,    "uuid.uuid1.__name__.__len__() == 5 ('uuid1'=5; 5>module(4); novel __len__ anchor)"]
    - [uuid4_name_len_5,  uuid4.__name__.__len__,   [],       5,    "uuid.uuid4.__name__.__len__() == 5 ('uuid4'=5; tied with uuid1; novel __len__ anchor)"]

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_argcount == 0
# uuid.uuid1.__code__.co_argcount == 2
#
# Wave 354 theme: uuid generation function argument counts.
#
# uuid4.__code__.co_argcount is 0 (no arguments; pure random generation).
# uuid1.__code__.co_argcount is 2 (node and clock_seq).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra167.uuid_fn_argcounts:
  description: "uuid.uuid4.__code__.co_argcount.__eq__(0)==True / uuid.uuid1.__code__.co_argcount.__eq__(2)==True / uuid.uuid4.__code__.co_argcount.__eq__(0)==True — uuid4.__code__.co_argcount is 0 (uuid.uuid4 generates a random UUID (version 4) using the OS random number generator; it takes no positional parameters — co_argcount==0; the function signature is uuid4() with no arguments whatsoever; the randomness comes entirely from os.urandom() or the platform equivalent; co_argcount==0 is the minimum possible value: uuid4 requires nothing from the caller; novel anchor: no prior uuid spec anchors uuid4.__code__.co_argcount under uuidfns167; first uuidfns167 anchor for the integer 0 as uuid4 argcount); uuid1.__code__.co_argcount is 2 (uuid.uuid1 generates a time-based UUID (version 1); it accepts two optional parameters: node (the 48-bit MAC address as an integer, or None for the host MAC) and clock_seq (the 14-bit clock sequence, or None for random); co_argcount==2 counts these two positional parameters; uuid1.__code__.co_argcount(2) > uuid4.__code__.co_argcount(0) by 2: uuid1 accepts 2 arguments while uuid4 accepts none; novel anchor: first uuidfns167 anchor for uuid1.__code__.co_argcount==2)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfns167

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_co_argcount_0, "uuid4.__code__.co_argcount.__eq__", [0], true, "uuid.uuid4.__code__.co_argcount == 0 (no args; pure random; minimum argcount; novel anchor)"]
    - [uuid1_co_argcount_2, "uuid1.__code__.co_argcount.__eq__", [2], true, "uuid.uuid1.__code__.co_argcount == 2 (node + clock_seq; 2>0; novel anchor)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__name__.__eq__('uuid1') — standalone
#
# uuid.uuid1.__name__ is 'uuid1' (5 chars). uuid1 generates time-based UUIDs.
# uuid1(5) is part of the 4-way tie: uuid1/uuid3/uuid4/uuid5 all have 5-char names.
# Novel anchor under uuidfns167. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra167.uuid1_name_uuid1:
  description: "uuid.uuid1.__name__.__eq__('uuid1') == True — 'uuid1' (5 chars; uuid.uuid1 is the time-based UUID generator (version 1); it derives uniqueness from the current timestamp (100-nanosecond intervals since October 15, 1582 — the Gregorian calendar reform date) combined with the host's network interface MAC address or a random 48-bit node identifier; the __name__ attribute equals 'uuid1' — 5 chars: 'uuid' + '1'; uuid1.__name__(5) == uuid3.__name__.__len__()==5 == uuid4.__name__.__len__()==5 == uuid5.__name__.__len__()==5: 4-way tie; uuid1.__module__=='uuid'(4) < uuid1.__name__=='uuid1'(5) by 1: the module name is 1 char shorter than the function name; novel anchor: no prior uuid spec anchors uuid1.__name__ under uuidfns167; first uuidfns167 standalone for uuid1.__name__.__eq__('uuid1')"
  category: identity
  kind: python_call_eq
  function: uuid1.__name__.__eq__
  args: ["uuid1"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__name__.__eq__('uuid4') — standalone
#
# uuid.uuid4.__name__ is 'uuid4' (5 chars). uuid4 generates random UUIDs.
# uuid4 is the most commonly used UUID generator. 4-way tie with uuid1/uuid3/uuid5.
# Novel anchor under uuidfns167. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra167.uuid4_name_uuid4:
  description: "uuid.uuid4.__name__.__eq__('uuid4') == True — 'uuid4' (5 chars; uuid.uuid4 is the random UUID generator (version 4); it uses the operating system's cryptographically secure random number generator (os.urandom() on Unix, CryptGenRandom on Windows) to generate 122 bits of randomness, with the remaining bits set to identify the UUID variant and version; version 4 UUIDs are the most commonly used type for general-purpose unique identifiers because they require no network access and no coordination between processes; the __name__ attribute equals 'uuid4' — 5 chars: 'uuid' + '4'; uuid4.__name__(5) is part of the 4-way tie with uuid1/uuid3/uuid5; novel anchor: no prior uuid spec anchors uuid4.__name__ under uuidfns167; first uuidfns167 standalone for uuid4.__name__.__eq__('uuid4')"
  category: identity
  kind: python_call_eq
  function: uuid4.__name__.__eq__
  args: ["uuid4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_argcount.__eq__(0) — standalone
#
# uuid.uuid4.__code__.co_argcount is 0. uuid4 takes no arguments whatsoever —
# it generates a purely random UUID with no caller input required.
# uuid4 co_argcount(0) < uuid1 co_argcount(2).
# Novel anchor under uuidfns167. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra167.uuid4_co_argcount_0:
  description: "uuid.uuid4.__code__.co_argcount.__eq__(0) == True — 0 (uuid.uuid4 takes no positional parameters; co_argcount is the number of positional-or-keyword parameters (excluding *args and **kwargs) as recorded in the code object; co_argcount==0 for uuid4 means the function signature is simply uuid4() — the caller provides nothing; all randomness is generated internally using the OS CSPRNG; co_argcount==0 is the minimum possible value: no function can have fewer parameters than zero; uuid4.__code__.co_argcount(0) < uuid1.__code__.co_argcount(2): uuid4 needs 2 fewer arguments than uuid1 (which accepts node and clock_seq); novel anchor: no prior uuid spec anchors uuid4.__code__.co_argcount under uuidfns167; first uuidfns167 standalone for uuid4.__code__.co_argcount.__eq__(0)"
  category: identity
  kind: python_call_eq
  function: "uuid4.__code__.co_argcount.__eq__"
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_argcount.__eq__(2) — standalone
#
# uuid.uuid1.__code__.co_argcount is 2 (node and clock_seq). uuid1 accepts
# two optional arguments for host-based UUID generation.
# uuid1 co_argcount(2) > uuid4 co_argcount(0) by 2.
# Novel anchor under uuidfns167. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra167.uuid1_co_argcount_2:
  description: "uuid.uuid1.__code__.co_argcount.__eq__(2) == True — 2 (uuid.uuid1 accepts two positional-or-keyword parameters: node and clock_seq; node is an optional 48-bit integer representing the hardware address (MAC address) — if None, the actual hardware address or a random 48-bit value is used; clock_seq is an optional 14-bit integer for the clock sequence — if None, a random value is chosen; co_argcount==2 counts these two named parameters (both default to None so they are optional, but they are still counted by co_argcount); uuid1.__code__.co_argcount(2) > uuid4.__code__.co_argcount(0) by 2: uuid1 is the only uuid generation function in this spec with non-zero argcount; novel anchor: no prior uuid spec anchors uuid1.__code__.co_argcount under uuidfns167; first uuidfns167 standalone for uuid1.__code__.co_argcount.__eq__(2)"
  category: identity
  kind: python_call_eq
  function: "uuid1.__code__.co_argcount.__eq__"
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__.__eq__('uuid') — standalone
#
# uuid.uuid1.__module__ is 'uuid' (4 chars). All uuid generation functions
# are defined in the uuid module. module name(4) < function name(5) by 1.
# Novel anchor under uuidfns167. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra167.uuid1_module_uuid:
  description: "uuid.uuid1.__module__.__eq__('uuid') == True — 'uuid' (4 chars; uuid.uuid1 is defined in the pure-Python uuid module (Lib/uuid.py in CPython); the __module__ attribute on a function equals the name of the module in which the function was defined; __module__=='uuid' (4 chars) — the module name is 1 char shorter than the function name 'uuid1' (5 chars); uuid1.__module__=='uuid'(4) == uuid4.__module__.__len__()==4: both uuid1 and uuid4 (and all uuid generation functions) are defined in the same uuid module; 'uuid'(4) is also the string that uuid.__name__ returns (the module's own name); novel anchor: no prior uuid spec anchors uuid1.__module__ under uuidfns167; first uuidfns167 standalone for uuid1.__module__.__eq__('uuid')"
  category: identity
  kind: python_call_eq
  function: uuid1.__module__.__eq__
  args: ["uuid"]
  expected: true

