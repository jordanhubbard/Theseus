spec: string_template_rust
version: ">=3.9"
backend: rust_module(string_template_rust)

docs: https://docs.python.org/3/library/string.html#template-strings

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string documentation"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "string.Template provides $-based template substitution."
    - "Template(template_str).substitute(mapping) replaces $key or ${key} with mapping values."
    - "Template(template_str).safe_substitute(mapping) leaves missing keys unchanged ($key)."
    - "Template('$name is great').substitute({'name': 'Python'}) == 'Python is great'."
    - "Template('Hello $name!').substitute({'name': 'World'}) == 'Hello World!'."
    - "Template('$a + $b = $c').substitute({'a': '1', 'b': '2', 'c': '3'}) == '1 + 2 = 3'."
    - "Template('$x and $y').safe_substitute({'x': 'hello'}) == 'hello and $y' — missing $y kept."
    - "Template('no vars').safe_substitute({}) == 'no vars' — no substitution needed."
    - "substitute() accepts a mapping (dict) as first positional argument."
    - "All test vectors verified against Python 3.14.3 string module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Template.substitute — replace all $keys from mapping
table string_template_rust.substitute.vectors:
  kind: python_call_eq
  category: substitute
  id_prefix: tmpl_sub
  function: Template
  method: substitute

  columns: [id, args, method_args, expected]
  rows:
    - [name_great, ["$name is great"],       [{"name": "Python"}], "Python is great"]
    - [hello_name, ["Hello $name!"],          [{"name": "World"}],  "Hello World!"]
    - [multi_var,  ["$a + $b = $c"],          [{"a": "1", "b": "2", "c": "3"}], "1 + 2 = 3"]
    - [no_dollar,  ["just text"],             [{}],                 "just text"]
    - [greeting,   ["Dear $first $last,"],    [{"first": "John", "last": "Doe"}], "Dear John Doe,"]

# Template.safe_substitute — leave missing keys as-is
table string_template_rust.safe_substitute.vectors:
  kind: python_call_eq
  category: safe_substitute
  id_prefix: tmpl_ss
  function: Template
  method: safe_substitute

  columns: [id, args, method_args, expected]
  rows:
    - [missing_key, ["$x and $y"],  [{"x": "hello"}], "hello and $y"]
    - [all_present, ["$x + $y"],    [{"x": "1", "y": "2"}], "1 + 2"]
    - [no_vars,     ["no vars"],    [{}],              "no vars"]
    - [empty_map,   ["$a $b"],      [{}],              "$a $b"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T22:56:31Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
