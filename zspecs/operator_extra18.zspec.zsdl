spec: operator_extra18
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra17.zspec.zsdl."
    - "operator_extra17 covers __name__.__eq__ and __module__.__eq__ for arithmetic operators (add/sub/mul/truediv/floordiv/mod/pow) and direct call results for add/mul/floordiv."
    - "No prior operator spec covers direct call results for eq/ne/lt/le/gt/ge as python_call_eq invariants in the extra18 namespace."
    - "No prior operator spec covers not_(False)==True, and_(5,3)==1, or_(5,3)==7, xor(5,3)==6 in the extra18 namespace."
    - "operator.and_(5,3)==1: bitwise AND of 101 and 011 is 001 (decimal 1)."
    - "operator.or_(5,3)==7: bitwise OR of 101 and 011 is 111 (decimal 7)."
    - "operator.xor(5,3)==6: bitwise XOR of 101 and 011 is 110 (decimal 6)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Comparison operator call results
#
# operator_extra17 covers arithmetic call results (add/mul/floordiv).
# No prior spec records call results for eq/ne/lt/le/gt/ge/not_ as invariants
# in the extra18 namespace. All return Python bool values.
# ---------------------------------------------------------------------------

table operator_extra18.comparison_calls:
  kind: python_call_eq
  category: call_results
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra18.comparison_calls.eq,
       eq,
       [3, 3],
       true,
       "operator.eq(3, 3) == True — equality comparison"]
    - [operator_extra18.comparison_calls.ne,
       ne,
       [3, 4],
       true,
       "operator.ne(3, 4) == True — inequality comparison"]
    - [operator_extra18.comparison_calls.lt,
       lt,
       [2, 3],
       true,
       "operator.lt(2, 3) == True — less-than comparison"]
    - [operator_extra18.comparison_calls.le,
       le,
       [3, 3],
       true,
       "operator.le(3, 3) == True — less-than-or-equal comparison"]
    - [operator_extra18.comparison_calls.gt,
       gt,
       [4, 3],
       true,
       "operator.gt(4, 3) == True — greater-than comparison"]
    - [operator_extra18.comparison_calls.ge,
       ge,
       [3, 3],
       true,
       "operator.ge(3, 3) == True — greater-than-or-equal comparison"]

# ---------------------------------------------------------------------------
# Logical not_ call result
#
# operator.not_(False) == True — logical negation of a falsy value.
# No prior operator spec records not_(False)==True as an invariant.
# ---------------------------------------------------------------------------

invariant operator_extra18.not_.call_false:
  description: "operator.not_(False) == True — logical negation of False"
  category: call_results
  kind: python_call_eq
  function: not_
  args: [false]
  expected: true

# ---------------------------------------------------------------------------
# Bitwise operator call results
#
# Bitwise operators use integer bit patterns:
#   5 == 0b101, 3 == 0b011
#   and_(5,3) == 0b001 == 1
#   or_(5,3)  == 0b111 == 7
#   xor(5,3)  == 0b110 == 6
# No prior operator spec records these three bitwise results in the extra18
# namespace.
# ---------------------------------------------------------------------------

invariant operator_extra18.and_.call_5_3:
  description: "operator.and_(5, 3) == 1 — bitwise AND of 0b101 and 0b011 is 0b001"
  category: call_results
  kind: python_call_eq
  function: and_
  args: [5, 3]
  expected: 1

invariant operator_extra18.or_.call_5_3:
  description: "operator.or_(5, 3) == 7 — bitwise OR of 0b101 and 0b011 is 0b111"
  category: call_results
  kind: python_call_eq
  function: or_
  args: [5, 3]
  expected: 7

invariant operator_extra18.xor.call_5_3:
  description: "operator.xor(5, 3) == 6 — bitwise XOR of 0b101 and 0b011 is 0b110"
  category: call_results
  kind: python_call_eq
  function: xor
  args: [5, 3]
  expected: 6
