spec: path_browserify
version: ">=1.0.1"
backend: node(path-browserify)

docs: https://www.npmjs.com/package/path-browserify

provenance:
  derived_from:
    - "path-browserify README — https://www.npmjs.com/package/path-browserify"
    - "Test vectors verified with path-browserify via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "path-browserify source"
  notes:
    - "path-browserify is an npm package. Install: npm install path-browserify"
    - "Provides POSIX path utilities: join, extname, basename, dirname."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a path string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table path_browserify.join:
  kind: node_module_call_eq
  function: join
  category: path
  id_prefix: pathbjoin

  columns: [id, args, expected]
  rows:
    - [three_parts, ["a", "b", "c"],        "a/b/c"]
    - [with_slash,  ["/usr", "local/bin"],   "/usr/local/bin"]

table path_browserify.extname:
  kind: node_module_call_eq
  function: extname
  category: path
  id_prefix: pathbext

  columns: [id, args, expected]
  rows:
    - [txt,  ["file.txt"],  ".txt"]
    - [js,   ["index.js"],  ".js"]
    - [none, ["Makefile"],  ""]

table path_browserify.basename:
  kind: node_module_call_eq
  function: basename
  category: path
  id_prefix: pathbbase

  columns: [id, args, expected]
  rows:
    - [full_path, ["/usr/local/bin/node"], "node"]
    - [with_ext,  ["file.txt"],            "file.txt"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:38:27Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
