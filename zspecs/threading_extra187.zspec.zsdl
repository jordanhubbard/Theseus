spec: threading_extra187
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Condition and threading.Barrier class identity — threading.Condition.__name__=='Condition' (len 9); threading.Condition.__module__=='threading'; threading.Condition.__qualname__=='Condition'; threading.Condition.__bases__[0].__name__=='object'; threading.Barrier.__name__=='Barrier' (len 7); threading.Barrier.__module__=='threading'; threading.Barrier.__qualname__=='Barrier'; threading.Barrier.__bases__[0].__name__=='object'."
    - "threading.Condition.__name__ == 'Condition' — Condition is a synchronization primitive; __name__ is 'Condition' (9 chars); verified with Python 3.14.3 on macOS/Darwin 25.4.0."
    - "threading.Condition.__module__ == 'threading' — Condition is defined in Lib/threading.py; verified with Python 3.14.3."
    - "threading.Condition.__qualname__ == 'Condition' — module-level class has __qualname__ == __name__ == 'Condition'; verified with Python 3.14.3."
    - "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object; __bases__[0].__name__ is 'object'; verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier' — Barrier is a synchronization primitive; __name__ is 'Barrier' (7 chars); verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' — Barrier is defined in Lib/threading.py; verified with Python 3.14.3."
    - "threading.Barrier.__qualname__ == 'Barrier' — module-level class has __qualname__ == __name__ == 'Barrier'; verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object; __bases__[0].__name__ is 'object'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition __name__, __module__, __qualname__
#
# threading.Condition.__name__ == 'Condition'   (len 9)
# threading.Condition.__module__ == 'threading'
# threading.Condition.__qualname__ == 'Condition'
#
# Condition is a context-manager synchronization primitive built on a Lock or
# RLock. As a module-level class its __qualname__ equals its __name__. New to
# extra187.
# ---------------------------------------------------------------------------

table threading_extra187.condition_name_module_qualname:
  description: "threading.Condition.__name__=='Condition' (len 9); __module__=='threading'; __qualname__=='Condition'; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcondbarrier187

  columns: [id, function, args, expected, description]
  rows:
    - [condition_name_eq,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is a synchronization primitive allowing threads to wait for a condition to become true; __name__ is 'Condition' (9 chars); str.__eq__('Condition') returns True; new to extra187"]
    - [condition_name_len_9,
       Condition.__name__.__len__,
       [],
       9,
       "threading.Condition.__name__.__len__() == 9 — the name 'Condition' has exactly 9 characters: C-o-n-d-i-t-i-o-n; str.__len__() returns 9; new to extra187"]
    - [condition_module_eq,
       Condition.__module__.__eq__,
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra187"]
    - [condition_qualname_eq,
       Condition.__qualname__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__qualname__.__eq__('Condition') == True — as a module-level class, __qualname__ equals __name__ 'Condition' (9 chars); str.__eq__('Condition') returns True; new to extra187"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition __bases__ and threading.Barrier __name__,
#          __module__
#
# threading.Condition.__bases__[0].__name__ == 'object'
# threading.Barrier.__name__ == 'Barrier'  (len 7)
# threading.Barrier.__module__ == 'threading'
#
# Condition inherits directly from object. Barrier is a synchronization
# primitive that allows a fixed number of threads to synchronize at a point.
# New to extra187.
# ---------------------------------------------------------------------------

table threading_extra187.condition_bases_and_barrier_name:
  description: "threading.Condition.__bases__[0].__name__=='object'; threading.Barrier.__name__=='Barrier' (len 7); __module__=='threading'; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcondbarrier187

  columns: [id, function, args, expected, description]
  rows:
    - ["condition_bases0_name_eq",
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra187"]
    - [barrier_name_eq,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is a synchronization primitive that blocks until a fixed number of threads have reached it; __name__ is 'Barrier' (7 chars); str.__eq__('Barrier') returns True; new to extra187"]
    - [barrier_name_len_7,
       Barrier.__name__.__len__,
       [],
       7,
       "threading.Barrier.__name__.__len__() == 7 — the name 'Barrier' has exactly 7 characters: B-a-r-r-i-e-r; str.__len__() returns 7; new to extra187"]
    - [barrier_module_eq,
       Barrier.__module__.__eq__,
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra187"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier __qualname__ and __bases__
#
# threading.Barrier.__qualname__ == 'Barrier'
# threading.Barrier.__bases__[0].__name__ == 'object'
#
# As a module-level class, Barrier has __qualname__ == __name__. It inherits
# directly from object (single-inheritance). New to extra187.
# ---------------------------------------------------------------------------

table threading_extra187.barrier_qualname_and_bases:
  description: "threading.Barrier.__qualname__=='Barrier' equals __name__; __bases__[0].__name__=='object'; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcondbarrier187

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_qualname_eq,
       Barrier.__qualname__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__qualname__.__eq__('Barrier') == True — as a module-level class, __qualname__ equals __name__ 'Barrier' (7 chars); str.__eq__('Barrier') returns True; new to extra187"]
    - [barrier_qualname_len_7,
       Barrier.__qualname__.__len__,
       [],
       7,
       "threading.Barrier.__qualname__.__len__() == 7 — the qualname 'Barrier' has exactly 7 characters, equal to the __name__ length; str.__len__() returns 7; new to extra187"]
    - ["barrier_bases0_name_eq",
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier inherits directly from object with single-inheritance; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra187"]
    - [condition_qualname_len_9,
       Condition.__qualname__.__len__,
       [],
       9,
       "threading.Condition.__qualname__.__len__() == 9 — cross-check: 'Condition' qualname is 9 chars (same as __name__) while 'Barrier' qualname is 7 chars; confirmed by str.__len__(); new to extra187"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra187
# ---------------------------------------------------------------------------

invariant threading_extra187.condition_name_is_condition:
  description: "threading.Condition.__name__ == 'Condition' — Condition synchronization primitive has __name__ 'Condition' (9 chars); verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra187.condition_module_is_threading:
  description: "threading.Condition.__module__ == 'threading' — Condition is defined in Lib/threading.py; __module__ is 'threading'; verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra187.condition_qualname_equals_name:
  description: "threading.Condition.__qualname__ == 'Condition' — module-level class has __qualname__ == __name__ == 'Condition' (9 chars); verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: Condition.__qualname__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra187.condition_bases_root_is_object:
  description: "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object with single-inheritance; __bases__[0].__name__ is 'object'; verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: "Condition.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra187.barrier_name_is_barrier:
  description: "threading.Barrier.__name__ == 'Barrier' — Barrier synchronization primitive has __name__ 'Barrier' (7 chars); verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra187.barrier_module_is_threading:
  description: "threading.Barrier.__module__ == 'threading' — Barrier is defined in Lib/threading.py; __module__ is 'threading'; verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra187.barrier_qualname_equals_name:
  description: "threading.Barrier.__qualname__ == 'Barrier' — module-level class has __qualname__ == __name__ == 'Barrier' (7 chars); verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: Barrier.__qualname__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra187.barrier_bases_root_is_object:
  description: "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object with single-inheritance; __bases__[0].__name__ is 'object'; verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: "Barrier.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
