spec: re_extra184
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "re.IGNORECASE.__class__.__name__=='RegexFlag'; MULTILINE.__class__.__name__=='RegexFlag'; DOTALL.__class__.__name__=='RegexFlag'; VERBOSE.__class__.__name__=='RegexFlag'."
    - "re.RegexFlag.__name__=='RegexFlag' (len=9); __module__=='re'; __bases__[0].__name__=='IntFlag'."
    - "Integer values (verified Python 3.14.3 macOS): re.IGNORECASE==2, re.MULTILINE==8, re.DOTALL==16, re.VERBOSE==64."
    - "re.IGNORECASE.__eq__(2)==True — IGNORECASE (alias re.I) has integer value 2 as an IntFlag member."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re flag constants class identity
# IGNORECASE, MULTILINE, DOTALL, VERBOSE are all RegexFlag instances
# ---------------------------------------------------------------------------

table re_extra184.flag_constant_class_identity:
  description: "re flag constants class identity: IGNORECASE, MULTILINE, DOTALL, VERBOSE all have __class__.__name__=='RegexFlag'; all are IntFlag enum members"
  kind: python_call_eq
  category: identity
  id_prefix: reregexflag184

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_cls,  IGNORECASE.__class__.__name__.__eq__,  ["RegexFlag"],  true,  "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IGNORECASE is a RegexFlag IntFlag member; confirmed Python 3.14.3 macOS"]
    - [multiline_cls,   MULTILINE.__class__.__name__.__eq__,   ["RegexFlag"],  true,  "re.MULTILINE.__class__.__name__ == 'RegexFlag' — MULTILINE is a RegexFlag IntFlag member; confirmed Python 3.14.3 macOS"]
    - [dotall_cls,      DOTALL.__class__.__name__.__eq__,      ["RegexFlag"],  true,  "re.DOTALL.__class__.__name__ == 'RegexFlag' — DOTALL is a RegexFlag IntFlag member; confirmed Python 3.14.3 macOS"]
    - [verbose_cls,     VERBOSE.__class__.__name__.__eq__,     ["RegexFlag"],  true,  "re.VERBOSE.__class__.__name__ == 'RegexFlag' — VERBOSE is a RegexFlag IntFlag member; confirmed Python 3.14.3 macOS"]
    - [ignorecase_ne,   IGNORECASE.__class__.__name__.__eq__,  ["IntFlag"],    false, "re.IGNORECASE.__class__.__name__.__eq__('IntFlag') == False — class is 'RegexFlag', not its base 'IntFlag'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.RegexFlag class identity
# __name__=='RegexFlag' (len=9); __module__=='re'; __bases__[0].__name__=='IntFlag'
# ---------------------------------------------------------------------------

table re_extra184.regexflag_class_identity:
  description: "re.RegexFlag class identity: __name__=='RegexFlag' (len=9); __module__=='re'; __bases__[0].__name__=='IntFlag'; RegexFlag is an IntFlag subclass"
  kind: python_call_eq
  category: identity
  id_prefix: reregexflag184

  columns: [id, function, args, expected, description]
  rows:
    - [rflag_name,       RegexFlag.__name__.__eq__,               ["RegexFlag"],  true,  "re.RegexFlag.__name__ == 'RegexFlag' — the flag enum class name; len('RegexFlag')==9; confirmed Python 3.14.3 macOS"]
    - [rflag_name_len,   RegexFlag.__name__.__len__,              [],             9,     "re.RegexFlag.__name__.__len__() == 9 — 'RegexFlag': R(1)e(2)g(3)e(4)x(5)F(6)l(7)a(8)g(9); confirmed Python 3.14.3 macOS"]
    - [rflag_module,     RegexFlag.__module__.__eq__,             ["re"],         true,  "re.RegexFlag.__module__ == 're' — RegexFlag belongs to the re module; confirmed Python 3.14.3 macOS"]
    - [rflag_base,       "RegexFlag.__bases__[0].__name__.__eq__",  ["IntFlag"],    true,  "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag subclasses IntFlag from the enum module; confirmed Python 3.14.3 macOS"]
    - [rflag_ne_intflag, RegexFlag.__name__.__eq__,               ["IntFlag"],    false, "re.RegexFlag.__name__.__eq__('IntFlag') == False — the class is 'RegexFlag', not 'IntFlag'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re flag integer values
# IGNORECASE==2, MULTILINE==8, DOTALL==16, VERBOSE==64
# ---------------------------------------------------------------------------

table re_extra184.flag_integer_values:
  description: "re flag integer values (verified Python 3.14.3 macOS): IGNORECASE==2, MULTILINE==8, DOTALL==16, VERBOSE==64; these are powers of 2 (bitmask flags)"
  kind: python_call_eq
  category: identity
  id_prefix: reregexflag184

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_val,  IGNORECASE.__eq__,  [2],   true,  "re.IGNORECASE.__eq__(2) == True — IGNORECASE (alias re.I) has integer value 2; confirmed Python 3.14.3 macOS"]
    - [multiline_val,   MULTILINE.__eq__,   [8],   true,  "re.MULTILINE.__eq__(8) == True — MULTILINE (alias re.M) has integer value 8; confirmed Python 3.14.3 macOS"]
    - [dotall_val,      DOTALL.__eq__,      [16],  true,  "re.DOTALL.__eq__(16) == True — DOTALL (alias re.S) has integer value 16; confirmed Python 3.14.3 macOS"]
    - [verbose_val,     VERBOSE.__eq__,     [64],  true,  "re.VERBOSE.__eq__(64) == True — VERBOSE (alias re.X) has integer value 64; confirmed Python 3.14.3 macOS"]
    - [ignorecase_ne,   IGNORECASE.__eq__,  [8],   false, "re.IGNORECASE.__eq__(8) == False — IGNORECASE is 2, not 8 (which is MULTILINE); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra184.ignorecase_class_is_regexflag:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IGNORECASE is a RegexFlag IntFlag member; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra184.multiline_class_is_regexflag:
  description: "re.MULTILINE.__class__.__name__ == 'RegexFlag' — MULTILINE is a RegexFlag IntFlag member; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: MULTILINE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra184.dotall_class_is_regexflag:
  description: "re.DOTALL.__class__.__name__ == 'RegexFlag' — DOTALL is a RegexFlag IntFlag member; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DOTALL.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra184.verbose_class_is_regexflag:
  description: "re.VERBOSE.__class__.__name__ == 'RegexFlag' — VERBOSE is a RegexFlag IntFlag member; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: VERBOSE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra184.regexflag_name_is_regexflag:
  description: "re.RegexFlag.__name__ == 'RegexFlag' — the flag enum class name; len('RegexFlag')==9: R(1)e(2)g(3)e(4)x(5)F(6)l(7)a(8)g(9); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra184.regexflag_name_len_is_9:
  description: "re.RegexFlag.__name__.__len__() == 9 — 'RegexFlag' has 9 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: RegexFlag.__name__.__len__
  args: []
  expected: 9

invariant re_extra184.regexflag_module_is_re:
  description: "re.RegexFlag.__module__ == 're' — RegexFlag belongs to the re module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra184.regexflag_base_is_intflag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag subclasses IntFlag from the enum module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra184.ignorecase_eq_2:
  description: "re.IGNORECASE.__eq__(2) == True — IGNORECASE (alias re.I) has integer value 2 as a bitmask flag; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IGNORECASE.__eq__
  args: [2]
  expected: true
