spec: pathlib_extra183
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers: pathlib.Path component properties — name, suffix, suffixes, stem, parent, parents, parts, root — all implemented as Python property objects with a fget function."
    - "pathlib.Path properties use Python-level property() so each has a .fget attribute; .fget.__name__ matches the property name itself."
    - "Name length groupings: name==stem==root (4); parts (5); suffix==parent (6); parents (7); suffixes (8)."
    - "pathlib.Path.name.fget.__name__ == 'name' (len=4); stem (4) and root (4) tie with name — a 3-way tie at length 4."
    - "pathlib.Path.suffix.fget.__name__ == 'suffix' (len=6); parent (6) ties with suffix — a 2-way tie at length 6."
    - "pathlib.Path.suffixes.fget.__name__ == 'suffixes' (len=8) — the longest among the eight properties covered."
    - "pathlib.Path.parts.fget.__name__ == 'parts' (len=5) — uniquely length 5 among the eight properties."
    - "pathlib.Path.parents.fget.__name__ == 'parents' (len=7) — uniquely length 7 among the eight properties."
    - "Length ordering: name==stem==root (4) < parts (5) < suffix==parent (6) < parents (7) < suffixes (8)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path single-component properties (name, stem, root)
# All have fget.__name__ length == 4 — a 3-way tie
# ---------------------------------------------------------------------------

table pathlib_extra183.single_component_props:
  description: "pathlib.Path single-component properties with len==4: name.fget.__name__=='name'; stem.fget.__name__=='stem'; root.fget.__name__=='root'; name==stem==root all have length 4 — a 3-way tie"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibbprops183

  columns: [id, function, args, expected, description]
  rows:
    - [name_fget_name,      Path.name.fget.__name__.__eq__,      ["name"], true, "pathlib.Path.name.fget.__name__ == 'name' — the name property returns the final path component (e.g. 'file.txt' from '/dir/file.txt'); Path.name is a Python property so .fget is the getter function whose __name__ is 'name'; len=4; confirmed Python 3.14.3 macOS"]
    - [name_fget_name_len,  Path.name.fget.__name__.__len__,     [],       4,    "pathlib.Path.name.fget.__name__.__len__() == 4 — 'name' has 4 characters: n(1)a(2)m(3)e(4); name (4) == stem (4) == root (4): a 3-way tie at length 4 among single-component properties; confirmed Python 3.14.3 macOS"]
    - [stem_fget_name,      Path.stem.fget.__name__.__eq__,      ["stem"], true, "pathlib.Path.stem.fget.__name__ == 'stem' — the stem property returns the final component without suffix (e.g. 'file' from 'file.txt'); 'stem' has 4 characters: s(1)t(2)e(3)m(4); stem (4) == name (4) == root (4): a 3-way tie at length 4; confirmed Python 3.14.3 macOS"]
    - [stem_fget_name_len,  Path.stem.fget.__name__.__len__,     [],       4,    "pathlib.Path.stem.fget.__name__.__len__() == 4 — 'stem' has 4 characters; stem (4) == name (4) == root (4): all three single-component properties share fget name length 4; confirmed Python 3.14.3 macOS"]
    - [root_fget_name,      Path.root.fget.__name__.__eq__,      ["root"], true, "pathlib.Path.root.fget.__name__ == 'root' — the root property returns the root of the path (e.g. '/' on POSIX); 'root' has 4 characters: r(1)o(2)o(3)t(4); root (4) == name (4) == stem (4): a 3-way tie at length 4; confirmed Python 3.14.3 macOS"]
    - [root_fget_name_len,  Path.root.fget.__name__.__len__,     [],       4,    "pathlib.Path.root.fget.__name__.__len__() == 4 — 'root' has 4 characters; name==stem==root all have fget name length 4; the length ordering starts: name==stem==root (4) < parts (5) < suffix==parent (6) < parents (7) < suffixes (8); confirmed Python 3.14.3 macOS"]
    - [name_prop_class,     Path.name.__class__.__name__.__eq__, ["property"], true, "pathlib.Path.name.__class__.__name__ == 'property' — Path.name is a pure Python property object, not a C descriptor; it has .fget, .fset, .fdel attributes; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path suffix-related and parts properties
# parts (5); suffix==parent (6); suffixes (8)
# ---------------------------------------------------------------------------

table pathlib_extra183.suffix_and_parts_props:
  description: "pathlib.Path suffix and parts properties: parts.fget.__name__=='parts' (len=5); suffix.fget.__name__=='suffix' (len=6); suffixes.fget.__name__=='suffixes' (len=8); parts (5) < suffix (6) < suffixes (8)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibbprops183

  columns: [id, function, args, expected, description]
  rows:
    - [parts_fget_name,      Path.parts.fget.__name__.__eq__,      ["parts"],    true, "pathlib.Path.parts.fget.__name__ == 'parts' — the parts property returns a tuple of the path's components (e.g. ('/', 'usr', 'bin') for '/usr/bin'); 'parts' has 5 characters: p(1)a(2)r(3)t(4)s(5); parts (5) is uniquely length 5 among the eight properties covered; confirmed Python 3.14.3 macOS"]
    - [parts_fget_name_len,  Path.parts.fget.__name__.__len__,     [],           5,    "pathlib.Path.parts.fget.__name__.__len__() == 5 — 'parts' has 5 characters; name==stem==root (4) < parts (5) < suffix==parent (6): parts is in the middle of the length ordering; confirmed Python 3.14.3 macOS"]
    - [suffix_fget_name,     Path.suffix.fget.__name__.__eq__,     ["suffix"],   true, "pathlib.Path.suffix.fget.__name__ == 'suffix' — the suffix property returns the file extension including the dot (e.g. '.txt'); 'suffix' has 6 characters: s(1)u(2)f(3)f(4)i(5)x(6); suffix (6) == parent (6): a 2-way tie at length 6; confirmed Python 3.14.3 macOS"]
    - [suffix_fget_name_len, Path.suffix.fget.__name__.__len__,    [],           6,    "pathlib.Path.suffix.fget.__name__.__len__() == 6 — 'suffix' has 6 characters; suffix (6) == parent (6): both share length 6; parts (5) < suffix==parent (6) < parents (7); confirmed Python 3.14.3 macOS"]
    - [suffixes_fget_name,   Path.suffixes.fget.__name__.__eq__,   ["suffixes"], true, "pathlib.Path.suffixes.fget.__name__ == 'suffixes' — the suffixes property returns a list of all suffixes (e.g. ['.tar', '.gz']); 'suffixes' has 8 characters: s(1)u(2)f(3)f(4)i(5)x(6)e(7)s(8); suffixes (8) is the longest fget name among the eight properties covered; confirmed Python 3.14.3 macOS"]
    - [suffixes_fget_name_len, Path.suffixes.fget.__name__.__len__, [],          8,    "pathlib.Path.suffixes.fget.__name__.__len__() == 8 — 'suffixes' has 8 characters; parents (7) < suffixes (8): suffixes is the longest property name; suffix (6) < suffixes (8): the plural form is 2 characters longer; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.Path parent/parents properties and property class identity
# parent (6); parents (7) — a strict 1-character difference
# ---------------------------------------------------------------------------

table pathlib_extra183.parent_props:
  description: "pathlib.Path parent and parents properties: parent.fget.__name__=='parent' (len=6); parents.fget.__name__=='parents' (len=7); parent (6) < parents (7); all Path properties are Python property objects"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibbprops183

  columns: [id, function, args, expected, description]
  rows:
    - [parent_fget_name,      Path.parent.fget.__name__.__eq__,      ["parent"],  true, "pathlib.Path.parent.fget.__name__ == 'parent' — the parent property returns the logical parent of the path (e.g. Path('/usr/bin').parent == Path('/usr')); 'parent' has 6 characters: p(1)a(2)r(3)e(4)n(5)t(6); parent (6) == suffix (6): a 2-way tie at length 6; confirmed Python 3.14.3 macOS"]
    - [parent_fget_name_len,  Path.parent.fget.__name__.__len__,     [],          6,    "pathlib.Path.parent.fget.__name__.__len__() == 6 — 'parent' has 6 characters; parent (6) == suffix (6): both share length 6; parts (5) < parent==suffix (6) < parents (7): parent is between parts and parents in the length ordering; confirmed Python 3.14.3 macOS"]
    - [parents_fget_name,     Path.parents.fget.__name__.__eq__,     ["parents"], true, "pathlib.Path.parents.fget.__name__ == 'parents' — the parents property returns an immutable sequence of the path's logical ancestors; 'parents' has 7 characters: p(1)a(2)r(3)e(4)n(5)t(6)s(7); parents (7) is uniquely length 7 among the eight properties covered; confirmed Python 3.14.3 macOS"]
    - [parents_fget_name_len, Path.parents.fget.__name__.__len__,    [],          7,    "pathlib.Path.parents.fget.__name__.__len__() == 7 — 'parents' has 7 characters; parent (6) < parents (7) < suffixes (8): parents is between its singular form and suffixes in the length ordering; the 's' suffix adds exactly 1 character; confirmed Python 3.14.3 macOS"]
    - [suffix_prop_class,     Path.suffix.__class__.__name__.__eq__, ["property"], true, "pathlib.Path.suffix.__class__.__name__ == 'property' — Path.suffix is a Python property object; all eight Path component properties (name, suffix, suffixes, stem, parent, parents, parts, root) are property instances with a .fget function; confirmed Python 3.14.3 macOS"]
    - [parents_prop_class,    Path.parents.__class__.__name__.__eq__, ["property"], true, "pathlib.Path.parents.__class__.__name__ == 'property' — Path.parents is a Python property object; .fget is the getter function whose __name__ == 'parents'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra183.name_fget_name_is_name:
  description: "pathlib.Path.name.fget.__name__ == 'name' — the name property fget is a Python function named 'name'; len=4; name (4) == stem (4) == root (4): a 3-way tie at length 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.name.fget.__name__.__eq__
  args: ["name"]
  expected: true

invariant pathlib_extra183.stem_fget_name_len_is_4:
  description: "pathlib.Path.stem.fget.__name__.__len__() == 4 — 'stem' has 4 characters; stem (4) == name (4) == root (4): a 3-way tie at length 4 among single-component Path properties; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.stem.fget.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra183.suffix_fget_name_is_suffix:
  description: "pathlib.Path.suffix.fget.__name__ == 'suffix' — the suffix property fget is named 'suffix'; len=6; suffix (6) == parent (6): a 2-way tie at length 6; parts (5) < suffix (6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.suffix.fget.__name__.__eq__
  args: ["suffix"]
  expected: true

invariant pathlib_extra183.suffixes_fget_name_len_is_8:
  description: "pathlib.Path.suffixes.fget.__name__.__len__() == 8 — 'suffixes' has 8 characters; suffixes (8) is the longest fget name among the eight Path component properties covered; parents (7) < suffixes (8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.suffixes.fget.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra183.parents_fget_name_len_is_7:
  description: "pathlib.Path.parents.fget.__name__.__len__() == 7 — 'parents' has 7 characters; parents (7) is uniquely length 7 among the eight properties; parent (6) < parents (7) < suffixes (8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.parents.fget.__name__.__len__
  args: []
  expected: 7

invariant pathlib_extra183.parts_fget_name_len_is_5:
  description: "pathlib.Path.parts.fget.__name__.__len__() == 5 — 'parts' has 5 characters; parts (5) is uniquely length 5 among the eight Path component properties; name==stem==root (4) < parts (5) < suffix==parent (6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.parts.fget.__name__.__len__
  args: []
  expected: 5

invariant pathlib_extra183.root_fget_name_is_root:
  description: "pathlib.Path.root.fget.__name__ == 'root' — the root property fget is named 'root'; len=4; root (4) == name (4) == stem (4): a 3-way tie at length 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.root.fget.__name__.__eq__
  args: ["root"]
  expected: true

invariant pathlib_extra183.parent_prop_is_property:
  description: "pathlib.Path.parent.__class__.__name__ == 'property' — Path.parent is a Python property object; all Path component properties (name, suffix, suffixes, stem, parent, parents, parts, root) are Python property instances with a .fget getter function; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.parent.__class__.__name__.__eq__
  args: ["property"]
  expected: true
