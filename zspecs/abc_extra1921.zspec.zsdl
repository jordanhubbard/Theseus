    - ["ab1921032", "abc.ABCMeta.__dict__.__contains__", ["__init_subclass__"], false]

table abc_extra1921.abcmeta_dict_protocol:
  description: "abc.ABCMeta __dict__ key-presence checks for well-known metaclass members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1921

  columns: [id, function, args, expected]
  rows:
    - ["ab1921041", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"], true]
    - ["ab1921042", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true]
    - ["ab1921043", "abc.ABCMeta.__dict__.__contains__", ["__new__"], true]
    - ["ab1921044", "abc.ABCMeta.__dict__.__contains__", ["register"], true]
    - ["ab1921045", "abc.ABCMeta.__dict__.__contains__", ["_dump_registry"], true]
    - ["ab1921046", "abc.ABCMeta.__dict__.__contains__", ["_abc_registry_clear"], true]
    - ["ab1921047", "abc.ABCMeta.__dict__.__contains__", ["_abc_caches_clear"], true]

table abc_extra1921.abc_dict_protocol:
  description: "abc.ABC __dict__ key-presence checks for well-known class members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1921

  columns: [id, function, args, expected]
  rows:
    - ["ab1921051", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["ab1921052", "abc.ABC.__dict__.__contains__", ["__slots__"], true]
    - ["ab1921053", "abc.ABC.__dict__.__contains__", ["_abc_impl"], true]
    - ["ab1921054", "abc.ABC.__dict__.__contains__", ["__doc__"], true]
    - ["ab1921055", "abc.ABC.__dict__.__contains__", ["__module__"], true]
    - ["ab1921056", "abc.ABC.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ab1921057", "abc.ABC.__dict__.__contains__", ["__init_subclass__"], false]
    - ["ab1921058", "abc.ABC.__dict__.__contains__", ["__init__"], false]
    - ["ab1921059", "abc.ABC.__dict__.__contains__", ["__new__"], false]
    - ["ab1921060", "abc.ABCMeta.__dict__.__contains__", ["__slots__"], false]
    - ["ab1921061", "abc.ABCMeta.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ab1921062", "abc.ABCMeta.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ab1921063", "abc.ABCMeta.__dict__.__contains__", ["__init_subclass__"], false]
    - ["ab1921064", "abc.ABCMeta.__dict__.__contains__", ["__doc__"], true]
    - ["ab1921065", "abc.ABCMeta.__dict__.__contains__", ["__module__"], true]
