spec: abc_extra1921
version: ">=3.9"
backend: python_module(abc)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "abc.ABC defines __slots__ in its own __dict__ (value: empty tuple), and also defines __abstractmethods__ (value: frozenset()) and _abc_impl."
    - "abc.ABCMeta does NOT define __slots__ or __abstractmethods__ in its own __dict__."
    - "abc.ABCMeta defines __instancecheck__ and __subclasscheck__ in its own __dict__, but NOT __subclasshook__ (which lives in object.__dict__)."
    - "abc.abstractmethod is a plain function (decorator), not a class; its __dict__ is empty and none of the protocol keys are present."
    - "Neither abc.ABC, abc.ABCMeta, nor abc.abstractmethod define __init_subclass__ in their own __dict__."
    - "abc.ABCMeta.__dict__ also contains: __new__, register, _dump_registry, _abc_registry_clear, _abc_caches_clear."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table abc_extra1921.slots_protocol:
  description: "abc types __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1921

  columns: [id, function, args, expected]
  rows:
    - ["ab1921001", "abc.ABC.__dict__.__contains__", ["__slots__"], true]
    - ["ab1921002", "abc.ABCMeta.__dict__.__contains__", ["__slots__"], false]

