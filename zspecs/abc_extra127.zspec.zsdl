spec: abc_extra127
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 254 theme — abc.ABC and ABCMeta __doc__ string class names and lengths. NEW in extra127: abc.ABC.__doc__.__class__.__name__=='str'; abc.ABC.__doc__.__len__()==78; abc.ABCMeta.__doc__.__class__.__name__=='str'; abc.ABCMeta.__doc__.__len__()==576; abc.abstractmethod.__doc__.__class__.__name__=='str'; abc.abstractmethod.__doc__.__len__()==537; abc.get_cache_token.__doc__.__class__.__name__=='str'; abc.get_cache_token.__doc__.__len__()==230. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__doc__.__len__() == 78. abc.ABC.__doc__ is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (78 chars). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__doc__.__len__() == 576. ABCMeta's docstring is the longest among the four abc objects measured here (576 > abstractmethod=537 > get_cache_token=230 > ABC=78). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__doc__.__len__() == 537. abstractmethod's docstring is the second longest (537 chars). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token.__doc__.__len__() == 230. get_cache_token's docstring is the shortest of the ABCMeta/abstractmethod/get_cache_token group (but longer than ABC's 78). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC and abc.ABCMeta __doc__ string class names and lengths — extra127
#
# Wave 254 theme: abc.ABC and ABCMeta __doc__ string class names and lengths.
#
# abc.ABC.__doc__.__class__.__name__    == 'str'
# abc.ABC.__doc__.__len__()             == 78
# abc.ABCMeta.__doc__.__class__.__name__ == 'str'
# abc.ABCMeta.__doc__.__len__()          == 576  (longest)
# ---------------------------------------------------------------------------

table abc_extra127.abc_ABC_ABCMeta_doc_identity:
  description: "abc.ABC and abc.ABCMeta __doc__ string class name and length checks in abcdoc127 namespace — wave 254 theme: abc doc strings are plain str objects; abc.ABC.__doc__.__class__.__name__.__eq__('str')==True (ABC's docstring is a plain Python str); abc.ABC.__doc__.__len__()==78 (ABC's docstring is 78 chars: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'); abc.ABCMeta.__doc__.__class__.__name__.__eq__('str')==True (ABCMeta's docstring is also a plain str); abc.ABCMeta.__doc__.__len__()==576 (ABCMeta's docstring is the longest of the four abc objects measured here — 576 chars describing the metaclass for defining ABCs, virtual subclasses, and the issubclass() interaction); the ratio ABCMeta/ABC doc length is 576/78 = ~7.4x; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdoc127

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_cls,    abc.ABC.__doc__.__class__.__name__.__eq__,      ["str"],  true, "abc.ABC.__doc__.__class__.__name__ == 'str' (plain Python str); verified with Python 3.14.3"]
    - [abc_doc_len,    abc.ABC.__doc__.__len__,                        [],       78,   "abc.ABC.__doc__.__len__() == 78 ('Helper class that...inheritance.\\n'); verified with Python 3.14.3"]
    - [meta_doc_cls,   abc.ABCMeta.__doc__.__class__.__name__.__eq__,  ["str"],  true, "abc.ABCMeta.__doc__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [meta_doc_len,   abc.ABCMeta.__doc__.__len__,                   [],       576,  "abc.ABCMeta.__doc__.__len__() == 576 (longest abc docstring; describes metaclass for ABCs); verified with Python 3.14.3"]
    - [abc_doc_ne,     abc.ABC.__doc__.__eq__,                         ["abc"],  false, "abc.ABC.__doc__.__eq__('abc') == False (the ABC docstring is not 'abc'); verified with Python 3.14.3"]
    - [meta_doc_gt,    abc.ABCMeta.__doc__.__len__,                   [],       576,  "abc.ABCMeta.__doc__.__len__() == 576 (ABCMeta docstring is 576 chars, longer than ABC at 78); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod and abc.get_cache_token __doc__ lengths — extra127
#
# abc.abstractmethod.__doc__.__class__.__name__  == 'str'
# abc.abstractmethod.__doc__.__len__()           == 537
# abc.get_cache_token.__doc__.__class__.__name__ == 'str'
# abc.get_cache_token.__doc__.__len__()          == 230
# ---------------------------------------------------------------------------

table abc_extra127.abc_abstractmethod_get_cache_token_doc:
  description: "abc.abstractmethod and abc.get_cache_token __doc__ string class name and length checks in abcdoc127 namespace — wave 254 theme: abstractmethod and get_cache_token docstrings; abc.abstractmethod.__doc__.__class__.__name__.__eq__('str')==True (abstractmethod docstring is a plain str); abc.abstractmethod.__doc__.__len__()==537 (second longest: describes the @abstractmethod decorator, requirements for ABCMeta, usage example with class C; 537 chars); abc.get_cache_token.__doc__.__class__.__name__.__eq__('str')==True; abc.get_cache_token.__doc__.__len__()==230 (third longest: 230 chars describing the cache token mechanism for virtual subclasses); doc length ranking: ABCMeta=576 > abstractmethod=537 > get_cache_token=230 > ABC=78; all four __doc__ values are non-None str instances; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdoc127a

  columns: [id, function, args, expected, description]
  rows:
    - [absm_doc_cls,  abc.abstractmethod.__doc__.__class__.__name__.__eq__,  ["str"],  true, "abc.abstractmethod.__doc__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [absm_doc_len,  abc.abstractmethod.__doc__.__len__,                   [],       537,  "abc.abstractmethod.__doc__.__len__() == 537 (second longest abc docstring); verified with Python 3.14.3"]
    - [gct_doc_cls,   abc.get_cache_token.__doc__.__class__.__name__.__eq__, ["str"],  true, "abc.get_cache_token.__doc__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [gct_doc_len,   abc.get_cache_token.__doc__.__len__,                  [],       230,  "abc.get_cache_token.__doc__.__len__() == 230 (third longest; describes cache token mechanism); verified with Python 3.14.3"]
    - [absm_lt_meta,  abc.abstractmethod.__doc__.__len__,                   [],       537,  "abc.abstractmethod.__doc__.__len__() == 537 < 576 (ABCMeta doc is longer); verified with Python 3.14.3"]
    - [gct_gt_abc,    abc.get_cache_token.__doc__.__len__,                  [],       230,  "abc.get_cache_token.__doc__.__len__() == 230 > 78 (ABC doc is shorter); verified with Python 3.14.3"]
    - [absm_ne_gct,   abc.abstractmethod.__doc__.__len__,                   [],       537,  "abc.abstractmethod.__doc__.__len__() == 537, different from get_cache_token (230); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc __doc__ string class names cross-check table — extra127
#
# All four __doc__ attributes have class name 'str'
# Length ordering: ABCMeta(576) > abstractmethod(537) > get_cache_token(230) > ABC(78)
# ---------------------------------------------------------------------------

table abc_extra127.abc_doc_class_names_crosscheck:
  description: "Cross-check that all four abc __doc__ attributes have class name 'str' and unique lengths in abcdoc127 namespace — wave 254 theme: abc docstring class uniformity; all four major abc exports have non-None docstrings of class 'str' (Python plain string); ABC.__doc__.__len__()==78 (shortest: concise helper class description); ABCMeta.__doc__.__len__()==576 (longest: full metaclass spec including virtual subclasses); abstractmethod.__doc__.__len__()==537 (second: full decorator description with usage example); get_cache_token.__doc__.__len__()==230 (third: describes opaque token object for cache invalidation); all four are plain 'str' with no special encoding or subclassing; doc lengths are all unique (78, 230, 537, 576 — no ties); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdoc127b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_str,       abc.ABC.__doc__.__class__.__name__.__eq__,            ["str"], true, "abc.ABC.__doc__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [meta_str,      abc.ABCMeta.__doc__.__class__.__name__.__eq__,        ["str"], true, "abc.ABCMeta.__doc__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [absm_str,      abc.abstractmethod.__doc__.__class__.__name__.__eq__, ["str"], true, "abc.abstractmethod.__doc__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [gct_str,       abc.get_cache_token.__doc__.__class__.__name__.__eq__, ["str"], true, "abc.get_cache_token.__doc__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [abc78,         abc.ABC.__doc__.__len__,                              [],      78,   "abc.ABC.__doc__.__len__() == 78 (shortest; 'Helper class...' 78 chars); verified with Python 3.14.3"]
    - [meta576,       abc.ABCMeta.__doc__.__len__,                         [],      576,  "abc.ABCMeta.__doc__.__len__() == 576 (longest; 576 chars); verified with Python 3.14.3"]
    - [absm537,       abc.abstractmethod.__doc__.__len__,                  [],      537,  "abc.abstractmethod.__doc__.__len__() == 537 (second longest; 537 chars); verified with Python 3.14.3"]
    - [gct230,        abc.get_cache_token.__doc__.__len__,                 [],      230,  "abc.get_cache_token.__doc__.__len__() == 230 (third; 230 chars); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra127
# ---------------------------------------------------------------------------

invariant abc_extra127.ABC_doc_len_78:
  description: "abc.ABC.__doc__.__len__() == 78 — abc.ABC.__doc__ is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (78 chars); this is the shortest docstring among the four abc objects measured: ABC=78, get_cache_token=230, abstractmethod=537, ABCMeta=576; ABC.__doc__.__class__.__name__ is 'str' (plain Python string); abc.ABC is a simple helper class that uses ABCMeta as its metaclass, providing a convenient base for user-defined abstract base classes; abc.ABC was added in Python 3.4 as an alternative to directly using ABCMeta as a metaclass; NEW in extra127: first standalone ABC.__doc__ length invariant in abcdoc127 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__len__
  args: []
  expected: 78

invariant abc_extra127.ABCMeta_doc_len_576:
  description: "abc.ABCMeta.__doc__.__len__() == 576 — abc.ABCMeta.__doc__ is the longest abc docstring at 576 chars; it describes the metaclass for defining ABCs: direct subclassing, virtual subclasses (registered via register()), and the issubclass() interaction; ABCMeta.__doc__ is longer than abstractmethod.__doc__ (537 chars) by 39 chars; ABCMeta.__doc__.__class__.__name__ is 'str'; ABCMeta is a metaclass (inherits from type), and its __doc__ explains the virtual subclass mechanism in detail; the length ranking is ABCMeta=576 > abstractmethod=537 > get_cache_token=230 > ABC=78; NEW in extra127: first standalone ABCMeta.__doc__ length invariant in abcdoc127 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__doc__.__len__
  args: []
  expected: 576

invariant abc_extra127.abstractmethod_doc_len_537:
  description: "abc.abstractmethod.__doc__.__len__() == 537 — abc.abstractmethod.__doc__ is 537 chars (second longest among the four abc objects); the docstring covers: what abstractmethod is, that it requires ABCMeta or a subclass as metaclass, that all abstract methods must be overridden, that abstract methods can be called via super(), and includes a Usage code example with class C(metaclass=ABCMeta); abc.abstractmethod.__doc__.__class__.__name__ is 'str'; abstractmethod is a function decorator (not a class) defined in Lib/abc.py; length comparison: ABCMeta=576 (longer by 39) > abstractmethod=537 > get_cache_token=230 > ABC=78; NEW in extra127: first standalone abstractmethod.__doc__ length invariant in abcdoc127 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__doc__.__len__
  args: []
  expected: 537

invariant abc_extra127.get_cache_token_doc_len_230:
  description: "abc.get_cache_token.__doc__.__len__() == 230 — abc.get_cache_token.__doc__ is 230 chars (third longest among the four; starts with 'Returns the current ABC cache token.'); it describes the opaque cache token object that identifies the current version of the ABC cache for virtual subclasses; the token changes with every call to register() on any ABC; abc.get_cache_token.__doc__.__class__.__name__ is 'str'; get_cache_token is implemented in the C extension _abc module (not pure Python); length comparison: ABCMeta=576 > abstractmethod=537 > get_cache_token=230 > ABC=78; NEW in extra127: first standalone get_cache_token.__doc__ length invariant in abcdoc127 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__doc__.__len__
  args: []
  expected: 230

invariant abc_extra127.all_abc_docs_are_str:
  description: "abc.ABC.__doc__.__class__.__name__.__eq__('str') returns True — all four major abc exports (ABC, ABCMeta, abstractmethod, get_cache_token) have non-None __doc__ strings of class 'str'; no NoneType, no bytes, no special subclass — all are plain Python str objects; the docstrings span a range of lengths: ABC=78 (shortest), get_cache_token=230, abstractmethod=537, ABCMeta=576 (longest); all four doc lengths are unique (no ties); abc.ABC.__doc__.__class__.__name__.__len__() is 3 (len of 'str'); compared to the abc module itself: abc.__doc__ is also a str; NEW in extra127: first standalone ABC.__doc__ class name str invariant in abcdoc127 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

