spec: concurrent_futures_extra283
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — wait constants and exception hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are plain str constants"
    - "concurrent.futures.Error.__bases__[0].__name__ == 'Exception'"
    - "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra283.wait_constants:
  description: "Wait constant values and class names for FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED"
  kind: python_call_eq
  category: identity
  id_prefix: cf283c

  columns: [id, function, args, expected, description]
  rows:
    - [cf283c001, concurrent.futures.FIRST_COMPLETED.__eq__, ["FIRST_COMPLETED"], true, "FIRST_COMPLETED value is 'FIRST_COMPLETED'"]
    - [cf283c002, concurrent.futures.FIRST_EXCEPTION.__eq__, ["FIRST_EXCEPTION"], true, "FIRST_EXCEPTION value is 'FIRST_EXCEPTION'"]
    - [cf283c003, concurrent.futures.ALL_COMPLETED.__eq__, ["ALL_COMPLETED"], true, "ALL_COMPLETED value is 'ALL_COMPLETED'"]
    - [cf283c004, concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__, ["str"], true, "FIRST_COMPLETED is a str instance"]
    - [cf283c005, concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__, ["str"], true, "FIRST_EXCEPTION is a str instance"]

table concurrent_futures_extra283.exception_identity:
  description: "Exception class identity for Error, BrokenExecutor, BrokenThreadPool, BrokenProcessPool"
  kind: python_call_eq
  category: identity
  id_prefix: cf283e

  columns: [id, function, args, expected, description]
  rows:
    - [cf283e001, concurrent.futures.Error.__name__.__eq__, ["Error"], true, "Error class name is 'Error'"]
    - [cf283e002, concurrent.futures.BrokenExecutor.__name__.__eq__, ["BrokenExecutor"], true, "BrokenExecutor class name is 'BrokenExecutor'"]
    - [cf283e003, concurrent.futures.thread.BrokenThreadPool.__name__.__eq__, ["BrokenThreadPool"], true, "BrokenThreadPool class name is 'BrokenThreadPool'"]
    - [cf283e004, concurrent.futures.process.BrokenProcessPool.__name__.__eq__, ["BrokenProcessPool"], true, "BrokenProcessPool class name is 'BrokenProcessPool'"]
    - [cf283e005, concurrent.futures.Error.__module__.__eq__, ["concurrent.futures._base"], true, "Error module is concurrent.futures._base"]

invariant concurrent_futures_extra283.all_completed_is_str:
  description: "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra283.error_base_is_exception:
  description: "concurrent.futures.Error.__bases__[0].__name__ == 'Exception'"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant concurrent_futures_extra283.brokenexecutor_module:
  description: "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.BrokenExecutor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra283.brokenexecutor_base_is_runtimeerror:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

invariant concurrent_futures_extra283.brokenpoolthread_base_is_brokenexecutor:
  description: "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__"
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra283.first_completed_eq:
  description: "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true
