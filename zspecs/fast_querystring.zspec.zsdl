spec: fast_querystring
version: ">=1.0.0"
backend: node(fast-querystring)

docs: https://github.com/anonrig/fast-querystring#readme

provenance:
  derived_from:
    - "fast-querystring README — https://github.com/anonrig/fast-querystring#readme"
    - "Node.js querystring API — https://nodejs.org/api/querystring.html"
    - "Test vectors verified with fast-querystring via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "fast-querystring source"
  notes:
    - "Faster querystring parser/serializer — drop-in for Node's querystring module."
    - "Install: npm install fast-querystring"
    - "v1 CJS; named exports parse / stringify."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string/object input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant fast_querystring.parse_simple:
  description: "parse('a=1&b=2') is {a:'1', b:'2'} (values are strings)"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["a=1&b=2"]
  chain: []
  expected: {a: "1", b: "2"}

invariant fast_querystring.parse_url_encoded:
  description: "parse decodes %20 to space"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["msg=hello%20world"]
  chain:
    - {get: msg}
  expected: "hello world"

invariant fast_querystring.parse_empty_string:
  description: "parse('') is {}"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: [""]
  chain: []
  expected: {}

invariant fast_querystring.stringify_simple:
  description: "stringify({a:1,b:2}) is 'a=1&b=2'"
  category: stringify
  kind: node_chain_eq
  entry: named
  function: stringify
  entry_args: [{a: 1, b: 2}]
  chain: []
  expected: "a=1&b=2"

invariant fast_querystring.stringify_url_encodes_space:
  description: "stringify({msg:'hello world'}) is 'msg=hello%20world'"
  category: stringify
  kind: node_chain_eq
  entry: named
  function: stringify
  entry_args: [{msg: "hello world"}]
  chain: []
  expected: "msg=hello%20world"

invariant fast_querystring.stringify_empty:
  description: "stringify({}) is ''"
  category: stringify
  kind: node_chain_eq
  entry: named
  function: stringify
  entry_args: [{}]
  chain: []
  expected: ""

invariant fast_querystring.parse_repeats:
  description: "parse('a=1&a=2') yields array for repeated key"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["a=1&a=2"]
  chain:
    - {get: a}
  expected: ["1", "2"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:55:07Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
