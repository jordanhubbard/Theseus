spec: re_extra1396
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module error (PatternError), Pattern, Match documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method checks for re module classes."
    - "re.Pattern and re.Match are C extension types from the _sre module; both have '__class_getitem__' in their own __dict__ as a 'builtin_function_or_method'; this enables generic alias syntax (e.g. re.Pattern[str])."
    - "re.error is a pure-Python exception class and does NOT have '__class_getitem__' in its own __dict__."
    - "None of the re module classes (error, Pattern, Match) have '__init_subclass__' in their own __dict__; all inherit __init_subclass__ from object; the inherited __init_subclass__.__class__.__name__ is 'builtin_function_or_method'; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "re.Pattern.__class_getitem__.__class__.__name__ == 'builtin_function_or_method'; re.Match.__class_getitem__.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1396.pattern_match_class_getitem_type:
  description: "re.Pattern and re.Match __class_getitem__ type check — wave 540 theme: both C extension types from _sre define __class_getitem__ in their own __dict__ as a 'builtin_function_or_method'; this enables PEP 585 generic alias usage (e.g. re.Pattern[str]); re.error does not have __class_getitem__; verified with Python 3.12"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: re1396cg
  columns: [id, function, args, expected, description]
  rows:
    - [re1396cg001, re.Pattern.__class_getitem__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true,  "re.Pattern.__class_getitem__.__class__.__name__ == 'builtin_function_or_method' (C extension type defines __class_getitem__ for generic alias support); verified with Python 3.12"]
    - [re1396cg002, re.Match.__class_getitem__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true,  "re.Match.__class_getitem__.__class__.__name__ == 'builtin_function_or_method' (C extension type defines __class_getitem__ for generic alias support); verified with Python 3.12"]
    - [re1396cg003, re.Pattern.__dict__.__contains__,                        ["__class_getitem__"],           true,  "re.Pattern.__dict__.__contains__('__class_getitem__') == True (Pattern defines __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [re1396cg004, re.Match.__dict__.__contains__,                          ["__class_getitem__"],           true,  "re.Match.__dict__.__contains__('__class_getitem__') == True (Match defines __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [re1396cg005, re.error.__dict__.__contains__,                          ["__class_getitem__"],           false, "re.error.__dict__.__contains__('__class_getitem__') == False (exception class does not define __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [re1396cg006, re.Pattern.__class_getitem__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true,  "re.Pattern.__class_getitem__.__class__.__name__ == 'builtin_function_or_method' (cross-check anchor: Pattern consistently builtin_function_or_method); verified with Python 3.12"]
    - [re1396cg007, re.Match.__class_getitem__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true,  "re.Match.__class_getitem__.__class__.__name__ == 'builtin_function_or_method' (cross-check: Match consistently builtin_function_or_method); verified with Python 3.12"]
    - [re1396cg008, re.Pattern.__dict__.__contains__,                        ["__class_getitem__"],           true,  "re.Pattern.__dict__.__contains__('__class_getitem__') == True (cross-check: Pattern's __class_getitem__ in own dict confirmed); verified with Python 3.12"]

table re_extra1396.error_no_class_getitem:
  description: "re.error __dict__ lacks __class_getitem__ contrasted with Pattern and Match — wave 540 theme: re.error is a pure-Python exception class and does not define __class_getitem__ in its own __dict__; this contrasts sharply with re.Pattern and re.Match which are C extension types that do define it; verified with Python 3.12"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: re1396er
  columns: [id, function, args, expected, description]
  rows:
    - [re1396er001, re.error.__dict__.__contains__,    ["__class_getitem__"], false, "re.error.__dict__.__contains__('__class_getitem__') == False (pure-Python exception class does not define __class_getitem__); verified with Python 3.12"]
    - [re1396er002, re.Pattern.__dict__.__contains__,  ["__class_getitem__"], true,  "re.Pattern.__dict__.__contains__('__class_getitem__') == True (contrast: C extension type Pattern does define __class_getitem__); verified with Python 3.12"]
    - [re1396er003, re.Match.__dict__.__contains__,    ["__class_getitem__"], true,  "re.Match.__dict__.__contains__('__class_getitem__') == True (contrast: C extension type Match does define __class_getitem__); verified with Python 3.12"]
    - [re1396er004, re.error.__dict__.__contains__,    ["__class_getitem__"], false, "re.error.__dict__.__contains__('__class_getitem__') == False (cross-check anchor: exception class consistently absent); verified with Python 3.12"]
    - [re1396er005, re.error.__dict__.__contains__,    ["__class_getitem__"], false, "re.error.__dict__.__contains__('__class_getitem__') == False (cross-check: exception class absent while C types present); verified with Python 3.12"]
    - [re1396er006, re.Pattern.__dict__.__contains__,  ["__class_getitem__"], true,  "re.Pattern.__dict__.__contains__('__class_getitem__') == True (cross-check: Pattern present in contrast to error); verified with Python 3.12"]
    - [re1396er007, re.Match.__dict__.__contains__,    ["__class_getitem__"], true,  "re.Match.__dict__.__contains__('__class_getitem__') == True (cross-check: Match present in contrast to error); verified with Python 3.12"]

table re_extra1396.all_classes_init_subclass_not_in_dict:
  description: "All re module classes __dict__ lacks __init_subclass__ and type check — wave 540 theme: none of re.error, re.Pattern, or re.Match have '__init_subclass__' in their own __dict__; all inherit it from object; the inherited __init_subclass__.__class__.__name__ is 'builtin_function_or_method' for all three; verified with Python 3.12"
  kind: python_call_eq
  category: init_subclass_checks
  id_prefix: re1396is
  columns: [id, function, args, expected, description]
  rows:
    - [re1396is001, re.error.__dict__.__contains__,                         ["__init_subclass__"],           false, "re.error.__dict__.__contains__('__init_subclass__') == False (exception class inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [re1396is002, re.Pattern.__dict__.__contains__,                       ["__init_subclass__"],           false, "re.Pattern.__dict__.__contains__('__init_subclass__') == False (C extension type inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [re1396is003, re.Match.__dict__.__contains__,                         ["__init_subclass__"],           false, "re.Match.__dict__.__contains__('__init_subclass__') == False (C extension type inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [re1396is004, re.error.__init_subclass__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true,  "re.error.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [re1396is005, re.Pattern.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true,  "re.Pattern.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [re1396is006, re.Match.__init_subclass__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true,  "re.Match.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [re1396is007, re.error.__dict__.__contains__,                         ["__init_subclass__"],           false, "re.error.__dict__.__contains__('__init_subclass__') == False (cross-check: all three re classes uniformly lack __init_subclass__ in own dict 1/3); verified with Python 3.12"]
    - [re1396is008, re.Pattern.__dict__.__contains__,                       ["__init_subclass__"],           false, "re.Pattern.__dict__.__contains__('__init_subclass__') == False (cross-check: all three re classes uniformly lack __init_subclass__ in own dict 2/3); verified with Python 3.12"]
    - [re1396is009, re.Match.__dict__.__contains__,                         ["__init_subclass__"],           false, "re.Match.__dict__.__contains__('__init_subclass__') == False (cross-check: all three re classes uniformly lack __init_subclass__ in own dict 3/3); verified with Python 3.12"]
