spec: io_extra194
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.open.__name__ == 'open' (len=4); io.open is the built-in open function re-exported by the io module."
    - "io.open.__module__ == '_io' — the actual implementation lives in the C extension _io, not in Lib/io.py."
    - "io.open.__qualname__ == 'open' (same as __name__ for top-level builtins)."
    - "io.open.__class__.__name__ == 'builtin_function_or_method' — C builtin, confirmed Python 3.14.3 macOS."
    - "io.open_code.__name__ == 'open_code' (len=9); opens a file for reading in a way the interpreter can trust."
    - "io.open_code.__module__ == '_io' — also implemented in the C extension."
    - "io.open_code.__qualname__ == 'open_code' (top-level builtin, __qualname__ == __name__)."
    - "io.open_code.__class__.__name__ == 'builtin_function_or_method' — C builtin, confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.open identity — __name__, __module__, __qualname__
# ---------------------------------------------------------------------------

table io_extra194.open_func_identity:
  description: "io.open function identity: __name__=='open'(4), __module__=='_io'(C extension), __qualname__=='open'"
  kind: python_call_eq
  category: identity
  id_prefix: ioopenfunc194

  columns: [id, function, args, expected, description]
  rows:
    - [open_name_eq,     io.open.__name__.__eq__,     ["open"], true, "io.open.__name__ == 'open'; confirmed Python 3.14.3 macOS"]
    - [open_name_len,    io.open.__name__.__len__,     [],       4,    "io.open.__name__.__len__() == 4 — o(1)p(2)e(3)n(4); confirmed Python 3.14.3 macOS"]
    - [open_module_eq,   io.open.__module__.__eq__,   ["_io"],  true, "io.open.__module__ == '_io' — C extension, not Lib/io.py; confirmed Python 3.14.3 macOS"]
    - [open_qualname_eq, io.open.__qualname__.__eq__,  ["open"], true, "io.open.__qualname__ == 'open'; confirmed Python 3.14.3 macOS"]
    - [open_class_eq,    io.open.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "io.open.__class__.__name__ == 'builtin_function_or_method'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.open_code identity — __name__, __module__, __qualname__
# ---------------------------------------------------------------------------

table io_extra194.open_code_func_identity:
  description: "io.open_code function identity: __name__=='open_code'(9), __module__=='_io', __qualname__=='open_code'"
  kind: python_call_eq
  category: identity
  id_prefix: ioopenfunc194

  columns: [id, function, args, expected, description]
  rows:
    - [ocode_name_eq,     io.open_code.__name__.__eq__,     ["open_code"], true, "io.open_code.__name__ == 'open_code'; confirmed Python 3.14.3 macOS"]
    - [ocode_name_len,    io.open_code.__name__.__len__,     [],            9,    "io.open_code.__name__.__len__() == 9 — o(1)p(2)e(3)n(4)_(5)c(6)o(7)d(8)e(9); confirmed Python 3.14.3 macOS"]
    - [ocode_module_eq,   io.open_code.__module__.__eq__,   ["_io"],       true, "io.open_code.__module__ == '_io' — C extension; confirmed Python 3.14.3 macOS"]
    - [ocode_qualname_eq, io.open_code.__qualname__.__eq__,  ["open_code"], true, "io.open_code.__qualname__ == 'open_code'; confirmed Python 3.14.3 macOS"]
    - [ocode_class_eq,    io.open_code.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "io.open_code.__class__.__name__ == 'builtin_function_or_method'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.open vs io.open_code — name length contrast
# open (4) vs open_code (9)
# ---------------------------------------------------------------------------

table io_extra194.open_vs_open_code_len:
  description: "io.open __name__ length 4 vs io.open_code __name__ length 9: open_code is 5 characters longer"
  kind: python_call_eq
  category: identity
  id_prefix: ioopenfunc194

  columns: [id, function, args, expected, description]
  rows:
    - [open_len_4,      io.open.__name__.__len__,      [], 4, "io.open.__name__ length == 4; confirmed Python 3.14.3 macOS"]
    - [ocode_len_9,     io.open_code.__name__.__len__, [], 9, "io.open_code.__name__ length == 9; confirmed Python 3.14.3 macOS"]
    - [open_mod_len,    io.open.__module__.__len__,    [], 3, "io.open.__module__ '_io' length == 3; confirmed Python 3.14.3 macOS"]
    - [ocode_mod_len,   io.open_code.__module__.__len__, [], 3, "io.open_code.__module__ '_io' length == 3; confirmed Python 3.14.3 macOS"]
    - [open_qual_len,   io.open.__qualname__.__len__, [], 4, "io.open.__qualname__ 'open' length == 4; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra194.open_name_eq:
  description: "io.open.__name__ == 'open' — io.open is the built-in open function; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io_extra194.open_name_len_4:
  description: "io.open.__name__.__len__() == 4 — 'open' has 4 characters: o(1)p(2)e(3)n(4); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open.__name__.__len__
  args: []
  expected: 4

invariant io_extra194.open_module_is_cext:
  description: "io.open.__module__ == '_io' — implementation lives in the C extension _io, not Lib/io.py; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra194.open_qualname_eq:
  description: "io.open.__qualname__ == 'open' — top-level builtin, qualname equals name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant io_extra194.open_class_is_builtin:
  description: "io.open.__class__.__name__ == 'builtin_function_or_method' — io.open is a C builtin; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant io_extra194.open_code_name_eq:
  description: "io.open_code.__name__ == 'open_code' — opens a file for reading in a way the interpreter trusts; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open_code.__name__.__eq__
  args: ["open_code"]
  expected: true

invariant io_extra194.open_code_name_len_9:
  description: "io.open_code.__name__.__len__() == 9 — 'open_code' has 9 characters: o(1)p(2)e(3)n(4)_(5)c(6)o(7)d(8)e(9); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open_code.__name__.__len__
  args: []
  expected: 9

invariant io_extra194.open_code_module_is_cext:
  description: "io.open_code.__module__ == '_io' — also implemented in the C extension; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open_code.__module__.__eq__
  args: ["_io"]
  expected: true

