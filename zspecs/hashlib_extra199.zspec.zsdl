spec: hashlib_extra199
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "hashlib.md5.__name__ == 'openssl_md5' (len=11) — OpenSSL-backed md5 constructor on macOS/Darwin."
    - "hashlib.sha1.__name__ == 'openssl_sha1' (len=12) — OpenSSL-backed SHA-1 constructor on macOS/Darwin."
    - "hashlib.sha224.__name__ == 'openssl_sha224' (len=14) — OpenSSL-backed; length 14 matches sha256, sha384, sha512."
    - "hashlib.sha384.__name__ == 'openssl_sha384' (len=14) — OpenSSL-backed SHA-384 constructor on macOS/Darwin."
    - "hashlib.sha512.__name__ == 'openssl_sha512' (len=14) — OpenSSL-backed SHA-512 constructor on macOS/Darwin."
    - "Name length ordering: md5 (11) < sha1 (12) < sha224 == sha256 == sha384 == sha512 (14)."
    - "hashlib.sha224.__name__ != hashlib.sha256.__name__ even though both have len=14 ('openssl_sha224' vs 'openssl_sha256')."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH constructor __name__ lengths — md5, sha1, sha224
# md5=11, sha1=12, sha224=14; strict ascending order
# ---------------------------------------------------------------------------

table hashlibhashalg199.short_names:
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlibhashalg199

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_len,    md5.__name__.__len__,    [], 11, "len(hashlib.md5.__name__) == 11 ('openssl_md5' has 11 characters)"]
    - [sha1_name_len,   sha1.__name__.__len__,   [], 12, "len(hashlib.sha1.__name__) == 12 ('openssl_sha1' has 12 characters)"]
    - [sha224_name_len, sha224.__name__.__len__, [], 14, "len(hashlib.sha224.__name__) == 14 ('openssl_sha224' has 14 characters)"]

# ---------------------------------------------------------------------------
# HASH constructor __name__ lengths — sha256, sha384, sha512
# All three share len=14 on macOS/Darwin with OpenSSL backend
# ---------------------------------------------------------------------------

table hashlibhashalg199.sha256_family:
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlibhashalg199

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_len, sha256.__name__.__len__, [], 14, "len(hashlib.sha256.__name__) == 14 ('openssl_sha256' has 14 characters)"]
    - [sha384_name_len, sha384.__name__.__len__, [], 14, "len(hashlib.sha384.__name__) == 14 ('openssl_sha384' has 14 characters)"]
    - [sha512_name_len, sha512.__name__.__len__, [], 14, "len(hashlib.sha512.__name__) == 14 ('openssl_sha512' has 14 characters)"]

# ---------------------------------------------------------------------------
# HASH constructor __name__ values — sha224, sha384, sha512
# Verify actual string values; all distinct despite identical lengths
# ---------------------------------------------------------------------------

table hashlibhashalg199.name_values:
  kind: python_call_eq
  category: name_values
  id_prefix: hashlibhashalg199

  columns: [id, function, args, expected, description]
  rows:
    - [sha224_name_eq, sha224.__name__.__eq__, ["openssl_sha224"], true, "hashlib.sha224.__name__ == 'openssl_sha224' (OpenSSL-backed SHA-224 constructor name)"]
    - [sha384_name_eq, sha384.__name__.__eq__, ["openssl_sha384"], true, "hashlib.sha384.__name__ == 'openssl_sha384' (OpenSSL-backed SHA-384 constructor name)"]
    - [sha512_name_eq, sha512.__name__.__eq__, ["openssl_sha512"], true, "hashlib.sha512.__name__ == 'openssl_sha512' (OpenSSL-backed SHA-512 constructor name)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlibhashalg199.md5.name_len:
  description: "len(hashlib.md5.__name__) == 11 ('openssl_md5' has 11 characters — shortest among the six covered algorithms)"
  category: name_lengths
  kind: python_call_eq
  function: md5.__name__.__len__
  args: []
  expected: 11

invariant hashlibhashalg199.sha1.name_len:
  description: "len(hashlib.sha1.__name__) == 12 ('openssl_sha1' has 12 characters — one more than md5)"
  category: name_lengths
  kind: python_call_eq
  function: sha1.__name__.__len__
  args: []
  expected: 12

invariant hashlibhashalg199.sha224.name_len:
  description: "len(hashlib.sha224.__name__) == 14 ('openssl_sha224' has 14 characters)"
  category: name_lengths
  kind: python_call_eq
  function: sha224.__name__.__len__
  args: []
  expected: 14

invariant hashlibhashalg199.sha256.name_len:
  description: "len(hashlib.sha256.__name__) == 14 ('openssl_sha256' has 14 characters)"
  category: name_lengths
  kind: python_call_eq
  function: sha256.__name__.__len__
  args: []
  expected: 14

invariant hashlibhashalg199.sha384.name_len:
  description: "len(hashlib.sha384.__name__) == 14 ('openssl_sha384' has 14 characters)"
  category: name_lengths
  kind: python_call_eq
  function: sha384.__name__.__len__
  args: []
  expected: 14

invariant hashlibhashalg199.sha512.name_len:
  description: "len(hashlib.sha512.__name__) == 14 ('openssl_sha512' has 14 characters)"
  category: name_lengths
  kind: python_call_eq
  function: sha512.__name__.__len__
  args: []
  expected: 14

invariant hashlibhashalg199.sha224.name_value:
  description: "hashlib.sha224.__name__ == 'openssl_sha224' (OpenSSL-backed SHA-224 constructor on macOS/Darwin)"
  category: name_values
  kind: python_call_eq
  function: sha224.__name__.__eq__
  args: ["openssl_sha224"]
  expected: true

invariant hashlibhashalg199.sha384.name_value:
  description: "hashlib.sha384.__name__ == 'openssl_sha384' (OpenSSL-backed SHA-384 constructor on macOS/Darwin)"
  category: name_values
  kind: python_call_eq
  function: sha384.__name__.__eq__
  args: ["openssl_sha384"]
  expected: true

