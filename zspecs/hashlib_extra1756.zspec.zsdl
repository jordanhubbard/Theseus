spec: hashlib_extra1756
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "hashlib.md5: C extension type — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "hashlib.sha256: C extension type — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "hashlib.sha512: C extension type — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "hashlib.sha3_256: C extension type — no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "Complementary checks: hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'; hashlib.algorithms_guaranteed.__contains__('sha256') == True; hashlib.algorithms_guaranteed.__contains__('sha512') == True."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for hashlib types
#
# Wave 564 theme: which hashlib types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# hashlib.md5: C extension type — a hash constructor, not a numeric type;
#   no arithmetic operators defined in __dict__.
# hashlib.sha256: C extension type — a hash constructor; not numeric; no
#   arithmetic operators in __dict__.
# hashlib.sha512: C extension type — a hash constructor; not numeric; no
#   arithmetic operators in __dict__.
# hashlib.sha3_256: C extension type — an OpenSSL-backed hash constructor;
#   not numeric; no arithmetic operators in __dict__.
# ---------------------------------------------------------------------------

table hashlib_extra1756.arithmetic_operators:
  description: "hashlib types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1756

  columns: [id, function, args, expected]
  rows:
    - ["hl1756001", "hashlib.md5.__dict__.__contains__", ["__add__"], false]
    - ["hl1756002", "hashlib.md5.__dict__.__contains__", ["__sub__"], false]
    - ["hl1756003", "hashlib.md5.__dict__.__contains__", ["__mul__"], false]
    - ["hl1756004", "hashlib.md5.__dict__.__contains__", ["__truediv__"], false]
    - ["hl1756005", "hashlib.md5.__dict__.__contains__", ["__floordiv__"], false]
    - ["hl1756006", "hashlib.md5.__dict__.__contains__", ["__pow__"], false]
    - ["hl1756007", "hashlib.md5.__dict__.__contains__", ["__neg__"], false]
    - ["hl1756008", "hashlib.md5.__dict__.__contains__", ["__pos__"], false]
    - ["hl1756009", "hashlib.sha256.__dict__.__contains__", ["__add__"], false]
    - ["hl1756010", "hashlib.sha256.__dict__.__contains__", ["__sub__"], false]
    - ["hl1756011", "hashlib.sha256.__dict__.__contains__", ["__mul__"], false]
    - ["hl1756012", "hashlib.sha256.__dict__.__contains__", ["__neg__"], false]
    - ["hl1756013", "hashlib.sha512.__dict__.__contains__", ["__add__"], false]
    - ["hl1756014", "hashlib.sha512.__dict__.__contains__", ["__truediv__"], false]
    - ["hl1756015", "hashlib.sha512.__dict__.__contains__", ["__pow__"], false]
    - ["hl1756016", "hashlib.sha3_256.__dict__.__contains__", ["__add__"], false]
    - ["hl1756017", "hashlib.sha3_256.__dict__.__contains__", ["__sub__"], false]
    - ["hl1756018", "hashlib.sha3_256.__dict__.__contains__", ["__neg__"], false]

# ---------------------------------------------------------------------------
# Table 2: complementary module-level attribute checks for hashlib
#
# Unique checks not covered in earlier waves:
# - hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'
# - hashlib.algorithms_guaranteed.__contains__('sha256') == True
# - hashlib.algorithms_guaranteed.__contains__('sha512') == True
# - hashlib.algorithms_guaranteed.__contains__('md5') == True
# - hashlib.algorithms_guaranteed.__contains__('sha3_256') == True
# - hashlib.algorithms_available.__contains__.__class__.__name__ == 'builtin_function_or_method'
# These checks confirm module-level structure and type identity, contrasting
# with the class __dict__ checks above.
# ---------------------------------------------------------------------------

table hashlib_extra1756.module_level_attributes:
  description: "hashlib module-level attribute class name and membership checks — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1756

  columns: [id, function, args, expected]
  rows:
    - ["hl1756019", "hashlib.pbkdf2_hmac.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["hl1756020", "hashlib.algorithms_guaranteed.__contains__", ["sha256"], true]
    - ["hl1756021", "hashlib.algorithms_guaranteed.__contains__", ["sha512"], true]
    - ["hl1756022", "hashlib.algorithms_guaranteed.__contains__", ["md5"], true]
    - ["hl1756023", "hashlib.algorithms_guaranteed.__contains__", ["sha3_256"], true]
    - ["hl1756024", "hashlib.algorithms_available.__contains__.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["hl1756025", "hashlib.sha3_256.__dict__.__contains__", ["__floordiv__"], false]
