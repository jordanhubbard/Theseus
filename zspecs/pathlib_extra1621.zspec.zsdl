spec: pathlib_extra1621
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "pathlib classes use __slots__ extensively; when __slots__ is defined without including '__weakref__', no __weakref__ descriptor is added to the class dict"
    - "pathlib.PurePath defines __slots__ with 8 private cache slots; none include '__weakref__'"
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath define __slots__ = () — empty tuple, no __weakref__"
    - "pathlib.Path defines __slots__ = ('_info',) — only _info slot, no __weakref__"
    - "pathlib.PosixPath and pathlib.WindowsPath define __slots__ = () — empty tuple, no __weakref__"
    - "Consequence: pathlib path objects cannot be weakly referenced via the weakref module"
    - "Cross-check: '__weakref__' not in pathlib.PurePath.__slots__ and '__weakref__' not in pathlib.Path.__slots__"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: PurePath hierarchy — __weakref__ absent from all class dicts
# ---------------------------------------------------------------------------

table pathlib_extra1621.purepath_no_weakref:
  description: "pathlib.PurePath, PurePosixPath, PureWindowsPath all use __slots__ without including __weakref__ — none expose __weakref__ in their own class dict, so instances cannot be weakly referenced"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1621pp

  columns: [id, function, args, expected]
  rows:
    - ["pl1621pp001", pathlib.PurePath.__dict__.__contains__,         ["__weakref__"], false]
    - ["pl1621pp002", pathlib.PurePosixPath.__dict__.__contains__,    ["__weakref__"], false]
    - ["pl1621pp003", pathlib.PureWindowsPath.__dict__.__contains__,   ["__weakref__"], false]
    - ["pl1621pp004", pathlib.PurePath.__dict__.__contains__,         ["__slots__"],   true]
    - ["pl1621pp005", pathlib.PurePosixPath.__dict__.__contains__,    ["__slots__"],   true]
    - ["pl1621pp006", pathlib.PureWindowsPath.__dict__.__contains__,   ["__slots__"],   true]
    - ["pl1621pp007", pathlib.PurePath.__dict__.__contains__,         ["__dict__"],    false]
    - ["pl1621pp008", pathlib.PurePosixPath.__dict__.__contains__,    ["__dict__"],    false]
    - ["pl1621pp009", pathlib.PureWindowsPath.__dict__.__contains__,   ["__dict__"],    false]
    - ["pl1621pp010", pathlib.PurePath.__slots__.__contains__,        ["__weakref__"], false]
    - ["pl1621pp011", pathlib.PurePosixPath.__slots__.__contains__,   ["__weakref__"], false]
    - ["pl1621pp012", pathlib.PureWindowsPath.__slots__.__contains__,  ["__weakref__"], false]
    - ["pl1621pp013", pathlib.PurePath.__slots__.__contains__,        ["_raw_paths"],  true]
    - ["pl1621pp014", pathlib.PurePath.__slots__.__contains__,        ["_drv"],        true]
    - ["pl1621pp015", pathlib.PurePath.__slots__.__contains__,        ["_root"],       true]
    - ["pl1621pp016", pathlib.PurePath.__slots__.__contains__,        ["_hash"],       true]
    - ["pl1621pp017", pathlib.PurePath.__dict__.__contains__,         ["_raw_paths"],  true]
    - ["pl1621pp018", pathlib.PurePath.__dict__.__contains__,         ["_drv"],        true]
    - ["pl1621pp019", pathlib.PurePath.__dict__.__contains__,         ["_root"],       true]
    - ["pl1621pp020", pathlib.PurePath.__dict__.__contains__,         ["_hash"],       true]
    - ["pl1621pp021", pathlib.PurePath.__dict__.__contains__,         ["__module__"],  true]
    - ["pl1621pp022", pathlib.PurePosixPath.__dict__.__contains__,    ["__module__"],  true]
    - ["pl1621pp023", pathlib.PureWindowsPath.__dict__.__contains__,   ["__module__"],  true]
    - ["pl1621pp024", pathlib.PurePath.__dict__.__contains__,         ["__str__"],     true]
    - ["pl1621pp025", pathlib.PurePath.__dict__.__contains__,         ["__repr__"],    true]
    - ["pl1621pp026", pathlib.PurePath.__dict__.__contains__,         ["__eq__"],      true]
    - ["pl1621pp027", pathlib.PurePath.__dict__.__contains__,         ["__hash__"],    true]
    - ["pl1621pp028", pathlib.PurePath.__dict__.__contains__,         ["__fspath__"],  true]
    - ["pl1621pp029", pathlib.PurePosixPath.__dict__.__contains__,    ["_raw_paths"],  false]
    - ["pl1621pp030", pathlib.PureWindowsPath.__dict__.__contains__,   ["_raw_paths"],  false]

# ---------------------------------------------------------------------------
# Table 2: Path hierarchy — __weakref__ absent from all class dicts
# ---------------------------------------------------------------------------

table pathlib_extra1621.path_no_weakref:
  description: "pathlib.Path, PosixPath, WindowsPath all use __slots__ without including __weakref__ — none expose __weakref__ in their own class dict, so instances cannot be weakly referenced"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1621pa

  columns: [id, function, args, expected]
  rows:
    - ["pl1621pa001", pathlib.Path.__dict__.__contains__,      ["__weakref__"], false]
    - ["pl1621pa002", pathlib.PosixPath.__dict__.__contains__,  ["__weakref__"], false]
    - ["pl1621pa003", pathlib.WindowsPath.__dict__.__contains__, ["__weakref__"], false]
    - ["pl1621pa004", pathlib.Path.__dict__.__contains__,      ["__slots__"],   true]
    - ["pl1621pa005", pathlib.PosixPath.__dict__.__contains__,  ["__slots__"],   true]
    - ["pl1621pa006", pathlib.WindowsPath.__dict__.__contains__, ["__slots__"],   true]
    - ["pl1621pa007", pathlib.Path.__dict__.__contains__,      ["__dict__"],    false]
    - ["pl1621pa008", pathlib.PosixPath.__dict__.__contains__,  ["__dict__"],    false]
    - ["pl1621pa009", pathlib.WindowsPath.__dict__.__contains__, ["__dict__"],    false]
    - ["pl1621pa010", pathlib.Path.__slots__.__contains__,     ["__weakref__"], false]
    - ["pl1621pa011", pathlib.PosixPath.__slots__.__contains__,  ["__weakref__"], false]
    - ["pl1621pa012", pathlib.WindowsPath.__slots__.__contains__, ["__weakref__"], false]
    - ["pl1621pa013", pathlib.Path.__slots__.__contains__,     ["_info"],       true]
    - ["pl1621pa014", pathlib.Path.__slots__.__contains__,     ["__weakref__"], false]
    - ["pl1621pa015", pathlib.Path.__dict__.__contains__,      ["_info"],       true]
    - ["pl1621pa016", pathlib.PosixPath.__dict__.__contains__,  ["_info"],       false]
    - ["pl1621pa017", pathlib.WindowsPath.__dict__.__contains__, ["_info"],       false]
    - ["pl1621pa018", pathlib.Path.__dict__.__contains__,      ["__module__"],  true]
    - ["pl1621pa019", pathlib.PosixPath.__dict__.__contains__,  ["__module__"],  true]
    - ["pl1621pa020", pathlib.WindowsPath.__dict__.__contains__, ["__module__"],  true]
    - ["pl1621pa021", pathlib.Path.__dict__.__contains__,      ["open"],        true]
    - ["pl1621pa022", pathlib.Path.__dict__.__contains__,      ["stat"],        true]
    - ["pl1621pa023", pathlib.Path.__dict__.__contains__,      ["exists"],      true]
    - ["pl1621pa024", pathlib.Path.__dict__.__contains__,      ["is_file"],     true]
    - ["pl1621pa025", pathlib.Path.__dict__.__contains__,      ["is_dir"],      true]
    - ["pl1621pa026", pathlib.Path.__dict__.__contains__,      ["mkdir"],       true]
    - ["pl1621pa027", pathlib.Path.__dict__.__contains__,      ["__new__"],     true]
    - ["pl1621pa028", pathlib.PosixPath.__dict__.__contains__,  ["open"],        false]
    - ["pl1621pa029", pathlib.PosixPath.__dict__.__contains__,  ["__new__"],     false]
    - ["pl1621pa030", pathlib.Path.__dict__.__contains__,      ["iterdir"],     true]
