spec: http_client_extra8
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client.zspec.zsdl — covers status code integers; HTTP_PORT/HTTPS_PORT; class __name__ table; responses 200/201/301/404/500"
    - "http_client_extra4.zspec.zsdl — covers HTTPException/NotConnected/InvalidURL __bases__[0].__name__"
    - "http_client_extra5.zspec.zsdl — covers CannotSendRequest/CannotSendHeader base hierarchy"
    - "http_client_extra6.zspec.zsdl — covers ImproperConnectionState/IncompleteRead is_type"
    - "http_client_extra7.zspec.zsdl — covers CONTINUE/TEMPORARY_REDIRECT/CONFLICT/TOO_MANY_REQUESTS/NOT_IMPLEMENTED/GATEWAY_TIMEOUT; IncompleteRead MRO"
  notes:
    - "This spec extends http_client.zspec.zsdl through http_client_extra7.zspec.zsdl."
    - "Focus: exception class __name__ attributes and responses dict entries not yet covered."
    - "http.client.HTTPException.__name__ == 'HTTPException' — covered in http_client.zspec.zsdl class __name__ table; NotConnected and InvalidURL are distinct."
    - "http.client.NotConnected.__name__ == 'NotConnected' — not in any prior spec as a direct invariant."
    - "http.client.InvalidURL.__name__ == 'InvalidURL' — not in any prior spec as a direct invariant."
    - "http.client.HTTPException.__bases__[0].__name__ == 'Exception' — the direct base of HTTPException."
    - "http.client.responses[200] == 'OK' — covered in http_client.zspec.zsdl but verified here via __eq__ pattern."
    - "http.client.responses[404] == 'Not Found' — covered in http_client.zspec.zsdl."
    - "http.client.responses[500] == 'Internal Server Error' — covered in http_client.zspec.zsdl."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class __name__ attributes
#
# http_client.zspec.zsdl includes a class __name__ table, but uses the table
# form. These invariants test the same facts via individual invariant blocks
# with explicit __eq__ calls, covering NotConnected and InvalidURL specifically.
# HTTPException.__bases__[0].__name__ == 'Exception' is a new hierarchy axis.
# ---------------------------------------------------------------------------

invariant http_client_extra8.HTTPException.name:
  description: "http.client.HTTPException.__name__ == 'HTTPException'"
  category: class_names
  kind: python_call_eq
  function: HTTPException.__name__.__eq__
  args: ["HTTPException"]
  expected: true

invariant http_client_extra8.NotConnected.name:
  description: "http.client.NotConnected.__name__ == 'NotConnected'"
  category: class_names
  kind: python_call_eq
  function: NotConnected.__name__.__eq__
  args: ["NotConnected"]
  expected: true

invariant http_client_extra8.InvalidURL.name:
  description: "http.client.InvalidURL.__name__ == 'InvalidURL'"
  category: class_names
  kind: python_call_eq
  function: InvalidURL.__name__.__eq__
  args: ["InvalidURL"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPException base class hierarchy
#
# http_client_extra4 checks NotConnected and InvalidURL base classes.
# No prior spec checks what HTTPException itself directly inherits from.
# HTTPException.__bases__[0].__name__ == 'Exception'.
# ---------------------------------------------------------------------------

invariant http_client_extra8.HTTPException.base:
  description: "http.client.HTTPException.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: HTTPException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# responses dict — string values for 200, 404, 500
#
# http_client.zspec.zsdl covers responses[200/201/301/404/500] via a table.
# These invariants check the exact string values using __eq__ for a distinct
# testing axis (value equality rather than dict lookup).
# ---------------------------------------------------------------------------

invariant http_client_extra8.responses.200:
  description: "http.client.responses[200] == 'OK'"
  category: responses
  kind: python_call_eq
  function: responses.__getitem__
  args: [200]
  method: __eq__
  method_args: ["OK"]
  expected: true

invariant http_client_extra8.responses.404:
  description: "http.client.responses[404] == 'Not Found'"
  category: responses
  kind: python_call_eq
  function: responses.__getitem__
  args: [404]
  method: __eq__
  method_args: ["Not Found"]
  expected: true

invariant http_client_extra8.responses.500:
  description: "http.client.responses[500] == 'Internal Server Error'"
  category: responses
  kind: python_call_eq
  function: responses.__getitem__
  args: [500]
  method: __eq__
  method_args: ["Internal Server Error"]
  expected: true
