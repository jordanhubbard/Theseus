spec: color_name
version: ">=2.0.0"
backend: node(color-name)

docs: https://github.com/colorjs/color-name#readme

provenance:
  derived_from:
    - "color-name README — https://github.com/colorjs/color-name#readme"
    - "CSS Color Module Level 4 — https://www.w3.org/TR/css-color-4/"
    - "Test vectors verified with color-name via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "color-name source"
  notes:
    - "Static lookup table mapping CSS color names to RGB triplets [r,g,b]."
    - "Install: npm install color-name"
    - "v2 is ESM with a CJS shim; the lookup table is exposed as default."
    - "Uses property reads via dotted paths: 'default.red' → [255, 0, 0]."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Static lookup; missing names produce undefined."
  stderr: "null"
  stickiness: "N/A — pure data."
  codes: {}

# Lookup CSS named color -> [R, G, B]
table color_name.lookup:
  kind: node_property_eq
  category: lookup
  entry: bare
  id_prefix: name

  columns: [id, property, expected]
  rows:
    - [red,            default.red,            [255, 0, 0]]
    - [green,          default.green,          [0, 128, 0]]
    - [blue,           default.blue,           [0, 0, 255]]
    - [white,          default.white,          [255, 255, 255]]
    - [black,          default.black,          [0, 0, 0]]
    - [yellow,         default.yellow,         [255, 255, 0]]
    - [cyan,           default.cyan,           [0, 255, 255]]
    - [magenta,        default.magenta,        [255, 0, 255]]
    - [orange,         default.orange,         [255, 165, 0]]
    - [purple,         default.purple,         [128, 0, 128]]
    - [rebeccapurple,  default.rebeccapurple,  [102, 51, 153]]
    - [transparent_lookup_returns_undefined,
                       default.notArealColor,  ~]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:28:00Z
  iterations: 1
  pass_count: 12
  fail_count: 0
  total_invariants: 12
  notes: Synthesis succeeded in 1 iteration(s). 12 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
