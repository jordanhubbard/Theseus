spec: hashlib_extra261
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2module.c"
  notes:
    - "hashlib.sha3_256 is a builtin_function_or_method (not a type) on CPython with OpenSSL; its __name__ is 'openssl_sha3_256'."
    - "hashlib.blake2b and hashlib.blake2s are types (classes); their __class__.__name__ is 'type'."
    - "hashlib.blake2b.__module__ == '_blake2' and hashlib.blake2s.__module__ == '_blake2'."
    - "hashlib.pbkdf2_hmac is a builtin_function_or_method in _hashlib; __name__ == 'pbkdf2_hmac'."
    - "hashlib.scrypt is a builtin_function_or_method in _hashlib; __module__ == '_hashlib'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha3_256 function identity
# ---------------------------------------------------------------------------

invariant hashlib_extra261.sha3_256.name:
  description: "hashlib.sha3_256.__name__ == 'openssl_sha3_256' (CPython OpenSSL backend)"
  category: identity
  kind: python_call_eq
  function: sha3_256.__name__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

invariant hashlib_extra261.sha3_256.qualname:
  description: "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256'"
  category: identity
  kind: python_call_eq
  function: sha3_256.__qualname__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

invariant hashlib_extra261.sha3_256.module:
  description: "hashlib.sha3_256.__module__ == '_hashlib'"
  category: identity
  kind: python_call_eq
  function: sha3_256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra261.sha3_256.class_name:
  description: "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: sha3_256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# blake2b function identity
# ---------------------------------------------------------------------------

invariant hashlib_extra261.blake2b.name:
  description: "hashlib.blake2b.__name__ == 'blake2b'"
  category: identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

invariant hashlib_extra261.blake2b.qualname:
  description: "hashlib.blake2b.__qualname__ == 'blake2b'"
  category: identity
  kind: python_call_eq
  function: blake2b.__qualname__.__eq__
  args: ["blake2b"]
  expected: true

invariant hashlib_extra261.blake2b.module:
  description: "hashlib.blake2b.__module__ == '_blake2'"
  category: identity
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

invariant hashlib_extra261.blake2b.class_name:
  description: "hashlib.blake2b.__class__.__name__ == 'type' (blake2b is a class)"
  category: identity
  kind: python_call_eq
  function: blake2b.__class__.__name__.__eq__
  args: ["type"]
  expected: true

