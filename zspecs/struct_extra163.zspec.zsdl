# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.pack.__class__.__name__ is 'builtin_function_or_method' (25 chars). struct.pack is
# a C builtin function from the _struct extension. struct_extra162 anchors this as a table
# row under structfn162; this spec provides a dedicated standalone under structdict163.
# 'builtin_function_or_method' (25 chars) is the type name for all C-implemented callables
# that appear as module-level functions or unbound methods in C extension types.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra163.pack_class_builtin_function_or_method:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — 'builtin_function_or_method' (25 chars = 'builtin_'=8 + 'function_or_method'=17); struct.pack is a C function from _struct.c exposed as a module-level function; pack.__module__=='_struct'(7 chars); struct_extra162 anchors this as a table row under structfn162; this standalone provides a dedicated anchor under structdict163; 'builtin_function_or_method'(25) >> 'function'(8) (regular Python function type) by 17 chars; first structdict163 standalone for pack.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.unpack.__class__.__name__ is 'builtin_function_or_method' (25 chars). struct.unpack
# is the module-level inverse of struct.pack. Both pack and unpack are C builtins from _struct.c
# and share the same type (builtin_function_or_method). struct.unpack(fmt, buffer) returns a
# tuple of Python values. 'builtin_function_or_method' (25 chars) == pack.__class__.__name__
# (25 chars) — both module-level struct functions share the same type name length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra163.unpack_class_builtin_function_or_method:
  description: "struct.unpack.__class__.__name__.__eq__('builtin_function_or_method') == True — 'builtin_function_or_method' (25 chars; same type as struct.pack; both are C builtins from _struct.c; unpack.__module__=='_struct'(7); unpack.__name__=='unpack'(6 chars); pack.__class__.__name__.__len__()==unpack.__class__.__name__.__len__()==25; first structdict163 standalone for unpack.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: unpack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('pack') — standalone
#
# struct.Struct.__dict__.__contains__('pack') is True. 'pack' is one of the 16 keys in
# struct.Struct's mappingproxy __dict__. Struct.pack is a method_descriptor (the instance
# method version of pack, as opposed to the module-level struct.pack which is a
# builtin_function_or_method). Struct(fmt).pack(*values) packs values using the pre-compiled
# format string. struct_extra160 anchors Struct.__dict__ membership using 'in' syntax; this
# spec anchors using __contains__ method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra163.Struct_dict_contains_pack:
  description: "struct.Struct.__dict__.__contains__('pack') == True — 'pack' is one of the 16 keys in Struct.__dict__ (mappingproxy); Struct.pack is the instance method (method_descriptor) for packing values using the pre-compiled format; Struct(fmt).pack(*values) is equivalent to struct.pack(fmt, *values) but faster because the format is pre-compiled; struct_extra160 anchors via 'in' syntax; this spec anchors via __contains__ method; Struct.__dict__.__len__()==16; first structdict163 standalone for Struct.__dict__.__contains__('pack')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('unpack') — standalone
#
# struct.Struct.__dict__.__contains__('unpack') is True. 'unpack' is one of the 16 keys in
# struct.Struct's mappingproxy __dict__. Struct.unpack is the instance method for unpacking
# bytes into a tuple of Python values using the pre-compiled format string.
# Struct(fmt).unpack(buffer) returns a tuple. struct_extra160 anchors this membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra163.Struct_dict_contains_unpack:
  description: "struct.Struct.__dict__.__contains__('unpack') == True — 'unpack' is one of the 16 keys in Struct.__dict__; Struct.unpack is the instance method for unpacking bytes to a tuple using pre-compiled format; Struct(fmt).unpack(buffer) returns tuple; struct_extra160 anchors via 'in' syntax; Struct.__dict__.__len__()==16; 'unpack'(6 chars) > 'pack'(4 chars) by 2; first structdict163 standalone for Struct.__dict__.__contains__('unpack')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('size') — standalone
#
# struct.Struct.__dict__.__contains__('size') is True. 'size' is one of the 16 keys in
# struct.Struct's mappingproxy. Struct.size is a getset_descriptor (read-only property)
# that returns the number of bytes in the packed structure. This is equivalent to calling
# struct.calcsize(fmt) but uses the pre-compiled format. Struct(fmt).size returns an integer.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra163.Struct_dict_contains_size:
  description: "struct.Struct.__dict__.__contains__('size') == True — 'size' is one of the 16 keys in Struct.__dict__; Struct.size is a read-only getset_descriptor returning the number of bytes required to pack/unpack according to the format string; equivalent to struct.calcsize(fmt); struct_extra160 anchors via 'in' syntax; Struct.__dict__.__len__()==16; 'size'(4 chars) == 'pack'(4 chars) in length; first structdict163 standalone for Struct.__dict__.__contains__('size')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["size"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('format') — standalone
#
# struct.Struct.__dict__.__contains__('format') is True. 'format' is one of the 16 keys in
# struct.Struct's mappingproxy. Struct.format is a getset_descriptor (read-only property)
# that returns the format string used to create the Struct instance. 'format' (6 chars) is
# useful for inspecting an existing Struct object's format string.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra163.Struct_dict_contains_format:
  description: "struct.Struct.__dict__.__contains__('format') == True — 'format' is one of the 16 keys in Struct.__dict__; Struct.format is a read-only getset_descriptor returning the format string of the Struct instance; struct_extra160 anchors via 'in' syntax; Struct.__dict__.__len__()==16; 'format'(6 chars) == 'unpack'(6 chars) in length; first structdict163 standalone for Struct.__dict__.__contains__('format')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["format"]
  expected: true

# ---------------------------------------------------------------------------
