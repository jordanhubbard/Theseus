    - [dict_has_iter_unpack,  "Struct.__dict__.__contains__", ["iter_unpack"],  true, "struct.Struct.__dict__.__contains__('iter_unpack') == True ('iter_unpack' 11 chars; iterator unpack; added Python 3.4; struct_extra160 anchors)"]
