invariant struct_extra163.Struct_dict_len_16:
  description: "struct.Struct.__dict__.__len__() == 16 — 16 keys in Struct.__dict__ (mappingproxy): 9 dunder methods (__delattr__/__doc__/__getattribute__/__init__/__module__/__new__/__repr__/__setattr__/__sizeof__) + 7 non-dunder (format/iter_unpack/pack/pack_into/size/unpack/unpack_from) = 16 total; struct_extra160 anchors as table row; this standalone provides a dedicated anchor under structdict163; 16 is the exact count verified on Python 3.14.3 macOS/Darwin 25.4.0; first structdict163 standalone for Struct.__dict__.__len__()==16"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__len__
