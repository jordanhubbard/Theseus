spec: struct_extra163
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra162.zspec.zsdl — covers struct.pack/__unpack/__pack_into/__unpack_from/__iter_unpack/__calcsize .__name__/__module__ (module-level function identity); pack.__class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "struct_extra161.zspec.zsdl — covers struct.error/__Struct class identity (__name__/__module__/__bases__) and lengths (table + invariants)."
    - "struct_extra160.zspec.zsdl — covers struct.Struct.__dict__ membership (pack/unpack/pack_into/unpack_from/iter_unpack/size/format) and meta-attributes (__len__()==16/__class__.__name__=='mappingproxy') (table + invariants)."
    - "struct_extra159.zspec.zsdl — covers struct.__spec__ attributes (table + invariants)."
    - "struct_extra158.zspec.zsdl — covers struct.Struct.__new__/__str__ qualnames; struct.error class identity (table + invariants)."
    - "struct_extra157.zspec.zsdl — covers struct.Struct.__repr__/__sizeof__ qualnames / Struct.__name__/__module__ (table + invariants)."
    - "struct_extra154.zspec.zsdl — covers struct.Struct.pack/__unpack/__pack_into qualnames (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra162."
    - "Wave 349 theme: struct.pack/__unpack class names and struct.Struct.__dict__ key membership and size. struct_extra162 anchors pack.__class__.__name__=='builtin_function_or_method' as a table row; this spec anchors pack.__class__.__name__ and unpack.__class__.__name__ as standalones, and struct.Struct.__dict__.__contains__('pack'/'unpack'/'size'/'format')==True and __len__()==16 as novel table+standalone content. struct_extra160 anchors Struct.__dict__ membership (pack/unpack/pack_into/unpack_from/iter_unpack/size/format/__len__()==16/__class__.__name__=='mappingproxy') as table rows; this spec covers the same values through the __contains__ method syntax as the primary novel anchor."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('size') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('format') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__len__() == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__dict__ contains exactly 16 keys: __delattr__, __doc__, __getattribute__, __init__, __module__, __new__, __repr__, __setattr__, __sizeof__, format, iter_unpack, pack, pack_into, size, unpack, unpack_from. struct_extra160 anchors __len__()==16 as a table row; this spec anchors it via __len__() as a standalone and the __contains__ checks as novel table content."
    - "Note: struct.pack.__class__.__name__ == 'builtin_function_or_method' (25 chars). struct_extra162 anchors this as a table row under structfn162; this spec anchors it as a standalone under structdict163. struct.unpack.__class__.__name__ is also 'builtin_function_or_method' (25 chars) — both pack and unpack are C builtin functions from _struct.c."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.unpack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.Struct.__dict__.__contains__('pack')
# struct.Struct.__dict__.__contains__('unpack')
#
# Wave 349 theme: pack/unpack class names and Struct dict membership for pack/unpack.
#
# pack.__class__.__name__ == 'builtin_function_or_method' (25 chars; C builtin).
# unpack.__class__.__name__ == 'builtin_function_or_method' (25 chars; same type).
# Struct.__dict__.__contains__('pack') == True (pack is in the Struct namespace).
# Struct.__dict__.__contains__('unpack') == True (unpack is in the Struct namespace).
# struct_extra162 anchors pack.__class__.__name__ as a table row under structfn162;
# this spec anchors pack and unpack class names + Struct dict membership as the primary
# novel table under structdict163. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra163.pack_unpack_class_and_dict_membership:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method')==True / unpack.__class__.__name__.__eq__('builtin_function_or_method')==True / Struct.__dict__.__contains__('pack')==True / Struct.__dict__.__contains__('unpack')==True — pack.__class__.__name__ is 'builtin_function_or_method' (25 chars; struct.pack is a C builtin function from the _struct extension; 'builtin_function_or_method' is the type for C-implemented functions exposed in Python; struct_extra162 anchors this as a table row under structfn162; this spec provides a fresh anchor under structdict163 combining class name with dict membership); unpack.__class__.__name__ is 'builtin_function_or_method' (25 chars; same type as pack; both pack and unpack are C builtins; 'builtin_function_or_method'(25 chars) is one of the longer Python type names — 25 chars = 'builtin_'=8 + 'function_or_method'=17); Struct.__dict__.__contains__('pack') is True ('pack' is a key in struct.Struct.__dict__; Struct.__dict__ has 16 keys total including pack/unpack/pack_into/unpack_from/iter_unpack/size/format and 9 dunder attributes; struct_extra160 anchors dict membership via Python 'in' syntax; this spec uses __contains__ method syntax); Struct.__dict__.__contains__('unpack') is True ('unpack' is a key in struct.Struct.__dict__; first structdict163 anchor for pack/unpack class names and dict membership)"
  kind: python_call_eq
  category: identity
  id_prefix: structdict163

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class_builtin,    "pack.__class__.__name__.__eq__",          ["builtin_function_or_method"], true, "struct.pack.__class__.__name__ == 'builtin_function_or_method' (25 chars; C builtin from _struct.c; struct_extra162 anchors as row; confirmed here under structdict163)"]
    - [unpack_class_builtin,  "unpack.__class__.__name__.__eq__",        ["builtin_function_or_method"], true, "struct.unpack.__class__.__name__ == 'builtin_function_or_method' (25 chars; same type as pack; both module-level struct functions are C builtins)"]
    - [dict_has_pack,         "Struct.__dict__.__contains__",            ["pack"],   true, "struct.Struct.__dict__.__contains__('pack') == True ('pack' is in Struct.__dict__; Struct.__dict__ has 16 keys total; struct_extra160 anchors membership)"]
    - [dict_has_unpack,       "Struct.__dict__.__contains__",            ["unpack"], true, "struct.Struct.__dict__.__contains__('unpack') == True ('unpack' is in Struct.__dict__; struct_extra160 anchors; confirmed via __contains__ method here)"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('size')
# struct.Struct.__dict__.__contains__('format')
# struct.Struct.__dict__.__len__()==16
# struct.pack.__class__.__name__.__len__()==25
#
# Wave 349 theme: Struct dict contains 'size' and 'format', and its total length.
#
# Struct.__dict__.__contains__('size') == True (size is a getset_descriptor).
# Struct.__dict__.__contains__('format') == True (format is a getset_descriptor).
# Struct.__dict__.__len__() == 16 (total keys in Struct's mappingproxy).
# pack.__class__.__name__.__len__() == 25 ('builtin_function_or_method' = 25 chars).
# struct_extra160 anchors dict membership and __len__()==16 as table rows;
# this spec provides a new anchor combining size/format membership and len as a table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
