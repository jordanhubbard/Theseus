table struct_extra163.dict_size_format_and_len:
  description: "struct.Struct.__dict__.__contains__('size')==True / Struct.__dict__.__contains__('format')==True / Struct.__dict__.__len__()==16 / pack.__class__.__name__.__len__()==25 — Struct.__dict__.__contains__('size') is True ('size' is a key in struct.Struct.__dict__; it is a getset_descriptor that returns the number of bytes required to pack/unpack according to the Struct's format string; Struct.size is a read-only attribute; struct_extra160 anchors this membership; confirmed via __contains__ method); Struct.__dict__.__contains__('format') is True ('format' is a key in struct.Struct.__dict__; it is a getset_descriptor that returns the format string used to create the Struct instance; Struct.format is a read-only attribute; struct_extra160 anchors; confirmed via __contains__); Struct.__dict__.__len__() is 16 (the struct.Struct mappingproxy has exactly 16 entries: __delattr__/__doc__/__getattribute__/__init__/__module__/__new__/__repr__/__setattr__/__sizeof__/format/iter_unpack/pack/pack_into/size/unpack/unpack_from; 9 dunder methods + 7 non-dunder attributes = 16 total; struct_extra160 anchors __len__()==16 as a table row; confirmed); pack.__class__.__name__.__len__() is 25 ('builtin_function_or_method' = 25 chars; struct_extra162 anchors __len__()==4/11 for pack/unpack_from __name__; this spec anchors the type name length 25; first structdict163 anchor for size/format membership and dict len)"
  kind: python_call_eq
  category: identity
  id_prefix: structdict163

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_size,       "Struct.__dict__.__contains__", ["size"],   true, "struct.Struct.__dict__.__contains__('size') == True ('size' is a read-only getset_descriptor in Struct.__dict__; returns bytes required by format string; struct_extra160 anchors)"]
    - [dict_has_format,     "Struct.__dict__.__contains__", ["format"], true, "struct.Struct.__dict__.__contains__('format') == True ('format' is a read-only getset_descriptor in Struct.__dict__; returns format string; struct_extra160 anchors)"]
    - [dict_len_16,         "Struct.__dict__.__len__",      [],          16,  "struct.Struct.__dict__.__len__() is 16 (16 keys: 9 dunder methods + 7 non-dunder: format/iter_unpack/pack/pack_into/size/unpack/unpack_from; struct_extra160 anchors)"]
    - [pack_cls_name_len_25, "pack.__class__.__name__.__len__", [],      25,  "struct.pack.__class__.__name__.__len__() is 25 ('builtin_function_or_method' = 25 chars; longest type name in this spec; struct_extra162 anchors as table row)"]

