table struct_extra163.pack_unpack_class_name_and_module_lengths:
  description: "struct.pack.__class__.__name__.__len__()==25 / unpack.__class__.__name__.__len__()==25 / pack.__module__.__len__()==7 / Struct.__dict__.__len__()==16 — pack.__class__.__name__.__len__() is 25 ('builtin_function_or_method' = 25 chars; longest type name string among struct objects in this spec; 25 = 'builtin_'=8 + 'function_or_method'=17; 25 chars is significantly longer than the function names themselves: pack=4, unpack=6); unpack.__class__.__name__.__len__() is 25 ('builtin_function_or_method' = 25 chars; same type as pack; pack.__class__==unpack.__class__: both are builtin_function_or_method from _struct.c; both share __class__.__name__.__len__()==25); pack.__module__.__len__() is 7 ('_struct' = '_'=1 + 'struct'=6 = 7 chars; the private C extension module name; leading underscore marks private; struct_extra162 anchors pack.__module__=='_struct' as a standalone; '_struct'(7) > 'struct'(6) by 1 char; all six module-level struct functions share __module__='_struct'(7 chars)); Struct.__dict__.__len__() is 16 (confirmed; 16 total keys; first structdict163 anchor for unpack.__class__.__name__.__len__()==25 alongside pack class name lengths)"
