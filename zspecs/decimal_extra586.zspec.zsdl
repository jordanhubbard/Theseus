spec: decimal_extra586
version: ">=3.9"
backend: python_module(decimal)
docs: "Behavioral spec covering decimal.Decimal class method __qualname__ identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module Decimal class reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All Decimal methods should report __qualname__ in the canonical Decimal.method form"
  created_at: "2026-04-12T00:00:00Z"

table de586qn:
  description: "decimal.Decimal method __qualname__ identity checks"
  columns: [id, function, args, expected]
  rows:
    - [de586qn01, decimal.Decimal.from_float.__qualname__.__eq__, ["Decimal.from_float"], true]
    - [de586qn02, decimal.Decimal.as_tuple.__qualname__.__eq__, ["Decimal.as_tuple"], true]
    - [de586qn03, decimal.Decimal.as_integer_ratio.__qualname__.__eq__, ["Decimal.as_integer_ratio"], true]
    - [de586qn04, decimal.Decimal.sqrt.__qualname__.__eq__, ["Decimal.sqrt"], true]
    - [de586qn05, decimal.Decimal.exp.__qualname__.__eq__, ["Decimal.exp"], true]
    - [de586qn06, decimal.Decimal.ln.__qualname__.__eq__, ["Decimal.ln"], true]
    - [de586qn07, decimal.Decimal.log10.__qualname__.__eq__, ["Decimal.log10"], true]
    - [de586qn08, decimal.Decimal.quantize.__qualname__.__eq__, ["Decimal.quantize"], true]
    - [de586qn09, decimal.Decimal.to_integral.__qualname__.__eq__, ["Decimal.to_integral"], true]
    - [de586qn10, decimal.Decimal.to_integral_value.__qualname__.__eq__, ["Decimal.to_integral_value"], true]
    - [de586qn11, decimal.Decimal.is_nan.__qualname__.__eq__, ["Decimal.is_nan"], true]
    - [de586qn12, decimal.Decimal.is_infinite.__qualname__.__eq__, ["Decimal.is_infinite"], true]
    - [de586qn13, decimal.Decimal.is_zero.__qualname__.__eq__, ["Decimal.is_zero"], true]

table de586md:
  description: "decimal.Decimal class __module__ identity check"
  columns: [id, function, args, expected]
  rows:
    - [de586md01, decimal.Decimal.__module__.__eq__, ["decimal"], true]
