spec: itertools_extra278
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.tee is a C-level builtin_function_or_method: __module__ == 'itertools', __class__.__name__ == 'builtin_function_or_method'."
    - "tee.__name__ == 'tee' (3 chars); tee.__qualname__ == 'tee'; tee.__module__ == 'itertools'."
    - "itertools.chain is a C-level type: __class__.__name__ == 'type'; chain.from_iterable is a builtin_function_or_method."
    - "chain.from_iterable.__module__ is None — the classmethod does not carry a module attribute."
    - "itertools.combinations is a C-level type; combinations.__doc__ is not None."
    - "itertools.__doc__ is not None — the itertools module ships with a module-level docstring."
    - "itertools.__name__ == 'itertools' (9 chars)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.tee — builtin identity
#
# tee is a C-level builtin_function_or_method.
# __name__ == 'tee' (3 chars); __qualname__ == 'tee'; __module__ == 'itertools'.
# ---------------------------------------------------------------------------

table itertools_extra278.tee_identity:
  description: "itertools.tee builtin identity — __name__, __module__, __qualname__, __class__.__name__; name length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex278te

  columns: [id, function, args, expected, description]
  rows:
    - [te_name_eq,  tee.__name__.__eq__,            ["tee"],       true, "itertools.tee.__name__ == 'tee'; verified with Python 3.14.3"]
    - [te_name_len, tee.__name__.__len__,             [],           3,    "itertools.tee.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [te_mod_eq,   tee.__module__.__eq__,            ["itertools"], true, "itertools.tee.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [te_qn_eq,    tee.__qualname__.__eq__,          ["tee"],       true, "itertools.tee.__qualname__ == 'tee'; verified with Python 3.14.3"]
    - [te_cls_eq,   tee.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "itertools.tee.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools.combinations — type identity and doc presence
#
# combinations is a C-level type: __class__.__name__ == 'type'.
# combinations.__name__ == 'combinations' (12 chars); __module__ == 'itertools'.
# combinations.__doc__ is not None; itertools.__doc__ is not None.
# ---------------------------------------------------------------------------

table itertools_extra278.combinations_module_doc:
  description: "itertools.combinations type identity and doc presence; itertools module doc presence; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex278cm

  columns: [id, function, args, expected, description]
  rows:
    - [co_name_eq,  combinations.__name__.__eq__,           ["combinations"], true,  "itertools.combinations.__name__ == 'combinations'; verified with Python 3.14.3"]
    - [co_name_len, combinations.__name__.__len__,           [],              12,    "itertools.combinations.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [co_mod_eq,   combinations.__module__.__eq__,          ["itertools"],   true,  "itertools.combinations.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [co_cls_eq,   combinations.__class__.__name__.__eq__,  ["type"],        true,  "itertools.combinations.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [co_doc_none, combinations.__doc__.__eq__,             [null],          false, "itertools.combinations.__doc__ is not None — combinations ships with a docstring; verified with Python 3.14.3"]
    - [it_doc_none, __doc__.__eq__,                          [null],          false, "itertools.__doc__ is not None — itertools module has a module-level docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra278
# ---------------------------------------------------------------------------

invariant itertools_extra278.tee_is_builtin:
  description: "itertools.tee.__class__.__name__ == 'builtin_function_or_method' — tee is a C builtin, not a pure-Python function"
  category: identity
  kind: python_call_eq
  function: tee.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra278.tee_module_is_itertools:
  description: "itertools.tee.__module__ == 'itertools' — tee is registered in the itertools C extension module"
  category: identity
  kind: python_call_eq
  function: tee.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra278.tee_name_length_is_3:
  description: "itertools.tee.__name__.__len__() == 3 — 'tee' has 3 characters (one of the shortest names in itertools)"
  category: identity
  kind: python_call_eq
  function: tee.__name__.__len__
  args: []
  expected: 3

invariant itertools_extra278.combinations_is_type:
  description: "itertools.combinations.__class__.__name__ == 'type' — combinations is a C-level type, not a function"
  category: identity
  kind: python_call_eq
  function: combinations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra278.combinations_doc_is_not_none:
  description: "itertools.combinations.__doc__.__eq__(None) == False — combinations ships with a non-None docstring"
  category: behavior
  kind: python_call_eq
  function: combinations.__doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra278.itertools_doc_is_not_none:
  description: "itertools.__doc__.__eq__(None) == False — the itertools module ships with a module-level docstring"
  category: behavior
  kind: python_call_eq
  function: __doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra278.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — the classmethod qualname encodes the owning class"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra278.combinations_name_length_is_12:
  description: "itertools.combinations.__name__.__len__() == 12 — 'combinations' has 12 characters"
  category: identity
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12
