spec: multiprocessing_extra1471
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue — Queue documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "multiprocessing_extra.zspec.zsdl — covers class name and module checks"
    - "multiprocessing_extra1456.zspec.zsdl — covers __contains__ and __iter__ dict membership checks"
    - "CPython source: Lib/multiprocessing/process.py, Lib/multiprocessing/pool.py, Lib/multiprocessing/queues.py"
  notes:
    - "Wave 545 (_extra1471): focuses on __len__ and __getitem__ method presence and type checks for multiprocessing classes."
    - "multiprocessing.Process does not define '__len__' in its own __dict__ — Process manages a subprocess lifecycle, not a collection. Verified Python 3.14.4."
    - "multiprocessing.Process does not define '__getitem__' in its own __dict__ — Process state is accessed via .exitcode, .pid, etc., not subscript. Verified Python 3.14.4."
    - "multiprocessing.pool.Pool does not define '__len__' in its own __dict__ — Pool manages worker processes; tasks submitted via apply/map, not index. Verified Python 3.14.4."
    - "multiprocessing.pool.Pool does not define '__getitem__' in its own __dict__ — Pool API uses apply/map/imap; no subscript access. Verified Python 3.14.4."
    - "multiprocessing.queues.Queue does not define '__len__' in its own __dict__ — Queue is a FIFO IPC channel; items retrieved via get(). Verified Python 3.14.4."
    - "multiprocessing.queues.Queue does not define '__getitem__' in its own __dict__ — Queue items not accessible by index. Verified Python 3.14.4."
    - "multiprocessing.queues.SimpleQueue does not define '__len__' or '__getitem__' in its own __dict__ — SimpleQueue is a simpler IPC FIFO; no sized or subscript protocol. Verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing class __len__ dict absence
#
# Wave 545 theme: '__len__' not in own __dict__ for multiprocessing classes.
# Process, pool.Pool, queues.Queue, and queues.SimpleQueue are all IPC or
# process lifecycle abstractions — none define __len__ in their own class
# __dict__ because they are not sized containers.
# ---------------------------------------------------------------------------

table multiprocessing_extra1471.len_dict_membership:
  description: "multiprocessing classes: '__len__' not in own __dict__ for Process, pool.Pool, queues.Queue, queues.SimpleQueue; wave 545; new to extra1471"
  kind: python_call_eq
  category: len_dict_membership
  id_prefix: mp1471ld

  columns: [id, function, args, expected, description]
  rows:
    - [mp1471ld001,
       "Process.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.Process.__dict__.__contains__('__len__') == False — Process manages a subprocess lifecycle via start/join/terminate; is not a sized collection; no __len__ in own class __dict__; new to extra1471"]
    - [mp1471ld002,
       "pool.Pool.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.pool.Pool.__dict__.__contains__('__len__') == False — Pool manages worker processes for parallel task execution; is not a sized container; no __len__ in own class __dict__; new to extra1471"]
    - [mp1471ld003,
       "queues.Queue.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.queues.Queue.__dict__.__contains__('__len__') == False — Queue is a FIFO inter-process communication channel; items retrieved via get(); no __len__ in own class __dict__; new to extra1471"]
    - [mp1471ld004,
       "queues.SimpleQueue.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.queues.SimpleQueue.__dict__.__contains__('__len__') == False — SimpleQueue is a simplified IPC FIFO; no sized protocol defined in own class __dict__; new to extra1471"]
    - [mp1471ld005,
       "Process.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.Process.__dict__.__contains__('__len__') == False — cross-check: Process exposes .pid, .exitcode, .name attributes but not a sized-container interface; new to extra1471"]
    - [mp1471ld006,
       "pool.Pool.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.pool.Pool.__dict__.__contains__('__len__') == False — cross-check: Pool API (apply, map, imap, starmap) is task-submission oriented, not sized-container oriented; new to extra1471"]
    - [mp1471ld007,
       "queues.Queue.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.queues.Queue.__dict__.__contains__('__len__') == False — cross-check: Queue size may be queried via qsize() on some platforms, but __len__ is not defined in own __dict__; new to extra1471"]
    - [mp1471ld008,
       "queues.SimpleQueue.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.queues.SimpleQueue.__dict__.__contains__('__len__') == False — cross-check: SimpleQueue exposes only get/put/empty; no sized-container protocol; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing class __getitem__ dict absence
#
# Wave 545 theme: '__getitem__' not in own __dict__ for multiprocessing
# classes. None of the multiprocessing classes support subscript-based item
# access; they use method-based APIs (get/put, apply/map, start/join).
# ---------------------------------------------------------------------------

table multiprocessing_extra1471.getitem_dict_membership:
  description: "multiprocessing classes: '__getitem__' not in own __dict__ for Process, pool.Pool, queues.Queue, queues.SimpleQueue; wave 545; new to extra1471"
  kind: python_call_eq
  category: getitem_dict_membership
  id_prefix: mp1471gi

  columns: [id, function, args, expected, description]
  rows:
    - [mp1471gi001,
       "Process.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.Process.__dict__.__contains__('__getitem__') == False — Process state accessed via .pid/.exitcode/.name attributes; subscript access not defined; no __getitem__ in own class __dict__; new to extra1471"]
    - [mp1471gi002,
       "pool.Pool.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.pool.Pool.__dict__.__contains__('__getitem__') == False — Pool results retrieved via AsyncResult.get() or map return values; no subscript access; no __getitem__ in own class __dict__; new to extra1471"]
    - [mp1471gi003,
       "queues.Queue.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.queues.Queue.__dict__.__contains__('__getitem__') == False — Queue items retrieved via queue.get(); FIFO discipline; subscript access not applicable; no __getitem__ in own class __dict__; new to extra1471"]
    - [mp1471gi004,
       "queues.SimpleQueue.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.queues.SimpleQueue.__dict__.__contains__('__getitem__') == False — SimpleQueue exposes only get/put/empty; subscript access not defined; no __getitem__ in own class __dict__; new to extra1471"]
    - [mp1471gi005,
       "Process.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.Process.__dict__.__contains__('__getitem__') == False — cross-check: Process is not a mapping or sequence type; subscript protocol entirely absent; new to extra1471"]
    - [mp1471gi006,
       "pool.Pool.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.pool.Pool.__dict__.__contains__('__getitem__') == False — cross-check: Pool is a process-pool manager; subscript protocol entirely absent; new to extra1471"]
    - [mp1471gi007,
       "queues.Queue.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.queues.Queue.__dict__.__contains__('__getitem__') == False — cross-check: multiprocessing Queue is a FIFO IPC channel; subscript protocol entirely absent; new to extra1471"]
    - [mp1471gi008,
       "queues.SimpleQueue.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.queues.SimpleQueue.__dict__.__contains__('__getitem__') == False — cross-check: SimpleQueue is a minimal IPC FIFO; subscript protocol entirely absent; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing cross-protocol absence — __len__ and __getitem__
#
# Wave 545 theme: confirm that both halves of the sequence protocol are absent
# from multiprocessing classes, verifying the complete absence of sized-
# container and subscript-access semantics from all four target classes.
# ---------------------------------------------------------------------------

table multiprocessing_extra1471.sequence_protocol_absence:
  description: "multiprocessing classes: both '__len__' and '__getitem__' absent from own __dict__; cross-check for Process, Pool, Queue, SimpleQueue; wave 545; new to extra1471"
  kind: python_call_eq
  category: sequence_protocol_absence
  id_prefix: mp1471sp

  columns: [id, function, args, expected, description]
  rows:
    - [mp1471sp001,
       "Process.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.Process.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from Process; new to extra1471"]
    - [mp1471sp002,
       "Process.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.Process.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from Process; new to extra1471"]
    - [mp1471sp003,
       "pool.Pool.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.pool.Pool.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from Pool; new to extra1471"]
    - [mp1471sp004,
       "pool.Pool.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.pool.Pool.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from Pool; new to extra1471"]
    - [mp1471sp005,
       "queues.Queue.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.queues.Queue.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from queues.Queue; new to extra1471"]
    - [mp1471sp006,
       "queues.Queue.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.queues.Queue.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from queues.Queue; new to extra1471"]
    - [mp1471sp007,
       "queues.SimpleQueue.__dict__.__contains__",
       ["__len__"],
       false,
       "multiprocessing.queues.SimpleQueue.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from SimpleQueue; new to extra1471"]
    - [mp1471sp008,
       "queues.SimpleQueue.__dict__.__contains__",
       ["__getitem__"],
       false,
       "multiprocessing.queues.SimpleQueue.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from SimpleQueue; new to extra1471"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1471
# ---------------------------------------------------------------------------

invariant multiprocessing_extra1471.Process_len_not_in_dict:
  description: "'__len__' not in multiprocessing.Process.__dict__ — Process does not define the sized protocol; wave 545; new to extra1471"
  kind: python_call_eq
  function: Process.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant multiprocessing_extra1471.Process_getitem_not_in_dict:
  description: "'__getitem__' not in multiprocessing.Process.__dict__ — Process does not define subscript access; wave 545; new to extra1471"
  kind: python_call_eq
  function: Process.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant multiprocessing_extra1471.Pool_len_not_in_dict:
  description: "'__len__' not in multiprocessing.pool.Pool.__dict__ — Pool does not define the sized protocol; wave 545; new to extra1471"
  kind: python_call_eq
  function: pool.Pool.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant multiprocessing_extra1471.Queue_getitem_not_in_dict:
  description: "'__getitem__' not in multiprocessing.queues.Queue.__dict__ — queues.Queue does not define subscript access; wave 545; new to extra1471"
  kind: python_call_eq
  function: queues.Queue.__dict__.__contains__
  args: ["__getitem__"]
  expected: false
