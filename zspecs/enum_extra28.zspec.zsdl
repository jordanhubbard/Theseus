spec: enum_extra28
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra27.zspec.zsdl."
    - "Focus: EnumMeta.__qualname__ (which equals 'EnumType' in Python 3.11+), member/nonmember qualnames and modules, combined __module__ table for Flag/auto/member/nonmember, and EnumMeta.__bases__[0].__name__ in the extra28 namespace."
    - "enum_extra27 covers Enum._generate_next_value_/__qualname__ and Enum._missing_/__qualname__ method qualnames, and combined class qualnames for IntEnum/IntFlag/Flag/StrEnum/auto/unique/EnumType."
    - "enum_extra26 covers Enum.__str__/__repr__/__new__ method qualnames and EnumMeta method qualnames."
    - "enum_extra21 covers a combined __qualname__ table for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique and EnumMeta.__qualname__ standalone."
    - "No prior enum spec records EnumMeta.__qualname__ == 'EnumType' (the surprising fact that EnumMeta's own __qualname__ is 'EnumType') as a focused invariant in the extra28 namespace."
    - "No prior enum spec records member.__qualname__ or nonmember.__qualname__ in any invariant or table."
    - "No prior enum spec records a combined __module__ table for Flag/auto/member/nonmember in the extra28 namespace."
    - "No prior enum spec records EnumMeta.__bases__[0].__name__ == 'type' in any invariant or table."
    - "In Python 3.11+, enum.EnumMeta and enum.EnumType are the same object (EnumMeta is EnumType is True); both have __qualname__ == 'EnumType'."
    - "member and nonmember were added in Python 3.11; spec version is set to >=3.11."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# enum.EnumMeta.__qualname__ == 'EnumType' — standalone invariant
#
# In Python 3.11+, EnumMeta was renamed to EnumType; both names refer to the
# same object. EnumMeta.__qualname__ == 'EnumType' (not 'EnumMeta').
# enum_extra21 records EnumMeta.__qualname__ as a standalone invariant in the
# extra21 namespace. No prior enum spec has EnumMeta.__qualname__ == 'EnumType'
# as a focused invariant in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra28.EnumMeta.qualname:
  description: "enum.EnumMeta.__qualname__ == 'EnumType' — EnumMeta was renamed to EnumType in Python 3.11+"
  category: class_qualnames
  kind: python_call_eq
  function: EnumMeta.__qualname__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# len(enum.EnumMeta.__qualname__) == 8 — standalone invariant
#
# len('EnumType') == 8.
# No prior enum spec records this length in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra28.EnumMeta.qualname_len:
  description: "len(enum.EnumMeta.__qualname__) == 8 — len('EnumType') == 8"
  category: class_qualname_lengths
  kind: python_call_eq
  function: EnumMeta.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# enum.member and nonmember __qualname__ values — combined table
#
# member and nonmember are descriptor classes added in Python 3.11 for
# fine-grained control of enum member creation.
# No prior enum spec records member.__qualname__ or nonmember.__qualname__
# in any invariant or table.
# ---------------------------------------------------------------------------

table enum_extra28.member_qualnames:
  description: "__qualname__.__eq__ for enum.member and nonmember — Python 3.11+"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [member,    member.__qualname__.__eq__,    ["member"],    true]
    - [nonmember, nonmember.__qualname__.__eq__, ["nonmember"], true]

# ---------------------------------------------------------------------------
# enum.member and nonmember __qualname__.__len__() — combined table
#
# Verifies the string length of each descriptor class __qualname__:
#   member -> 6, nonmember -> 9
# No prior enum spec collects these two qualname lengths together.
# ---------------------------------------------------------------------------

table enum_extra28.member_qualname_lens:
  description: "__qualname__.__len__() for enum.member and nonmember — Python 3.11+"
  kind: python_call_eq
  category: class_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [member,    member.__qualname__.__len__,    [], 6]
    - [nonmember, nonmember.__qualname__.__len__, [], 9]

# ---------------------------------------------------------------------------
# enum class __module__ values — combined table
#
# Flag, auto, member, and nonmember all have __module__ == 'enum'.
# No prior enum spec has all four together in a combined __module__ table
# in the extra28 namespace.
# ---------------------------------------------------------------------------

table enum_extra28.class_modules:
  description: "__module__.__eq__ for enum.Flag, auto, member, nonmember — Python 3.11+"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Flag,      Flag.__module__.__eq__,      ["enum"], true]
    - [auto,      auto.__module__.__eq__,      ["enum"], true]
    - [member,    member.__module__.__eq__,    ["enum"], true]
    - [nonmember, nonmember.__module__.__eq__, ["enum"], true]

# ---------------------------------------------------------------------------
# enum class __module__.__len__() — combined table
#
# All four __module__ strings equal 'enum' which has length 4.
# No prior enum spec collects these four module name lengths together
# in a single table in the extra28 namespace.
# ---------------------------------------------------------------------------

table enum_extra28.class_module_lens:
  description: "__module__.__len__() for enum.Flag, auto, member, nonmember — Python 3.11+"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [Flag,      Flag.__module__.__len__,      [], 4]
    - [auto,      auto.__module__.__len__,      [], 4]
    - [member,    member.__module__.__len__,    [], 4]
    - [nonmember, nonmember.__module__.__len__, [], 4]

# ---------------------------------------------------------------------------
# enum.EnumMeta.__bases__[0].__name__ == 'type' — standalone invariant
#
# EnumMeta (aka EnumType) inherits from the built-in 'type' metaclass.
# No prior enum spec records EnumMeta.__bases__[0].__name__ in any invariant.
# ---------------------------------------------------------------------------

invariant enum_extra28.EnumMeta.base_name:
  description: "enum.EnumMeta.__bases__[0].__name__ == 'type' — EnumMeta inherits from built-in type"
  category: class_attrs
  kind: python_call_eq
  function: "EnumMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true
