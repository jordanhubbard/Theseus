spec: itertools_extra58
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra57.zspec.zsdl."
    - "Wave 224 theme: __contains__ membership tests on module __all__ lists/tuples + __iter__/__next__ class identity on collections + module __package__ checks."
    - "itertools does NOT have a module-level __all__ attribute (hasattr(itertools, '__all__') is False, confirmed in extra57). itertools is a C-extension module; its public API is determined by the C module initialization, not by __all__. Therefore wave 224's __contains__ theme applies to itertools only through __package__ checks and docstring type checks — not through __all__.__contains__ tests."
    - "itertools.__package__ == '' (empty string) — C-extension stdlib modules have __package__ == '' for the same reason as pure-Python stdlib modules: top-level modules not inside a package hierarchy have __package__ equal to the empty string. Verified: itertools.__package__.__eq__('') == True and itertools.__package__.__eq__('itertools') == False. No prior itertools spec records __package__.__eq__('') or __package__.__class__.__name__.__eq__('str') as table rows."
    - "itertools C-extension type docstrings: groupby.__doc__.__len__()==323; chain.__doc__.__len__()==190; count.__doc__.__len__()==205. All three are str objects. No prior itertools spec has table rows checking __doc__.__len__() for these types."
    - "This spec covers: itertools.__package__.__eq__('')==true; itertools.__package__.__class__.__name__.__eq__('str')==true; itertools.groupby.__doc__.__class__.__name__.__eq__('str')==true; itertools.chain.__doc__.__class__.__name__.__eq__('str')==true; itertools.count.__doc__.__class__.__name__.__eq__('str')==true; itertools.groupby.__doc__.__len__()==323; itertools.chain.__doc__.__len__()==190; itertools.count.__doc__.__len__()==205."
    - "Key findings: itertools.__package__ is '' (empty string) — same as functools, inspect, threading; all top-level stdlib modules share this pattern. itertools is a C-extension module (Modules/itertoolsmodule.c) but __package__ behavior is the same as for pure-Python stdlib modules. The docstrings for groupby (323 chars), chain (190 chars), and count (205 chars) are all str objects. These are the C-extension type docstrings embedded in the module's C source. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.__package__ identity — extra58
#
# Wave 224 theme: module __package__ checks.
#
# itertools.__package__ == '' (empty string). Despite being a C-extension module
# (Modules/itertoolsmodule.c), itertools follows the same __package__ convention
# as pure-Python top-level stdlib modules: __package__ is '' because itertools
# is not inside any package hierarchy.
#
# Note: __package__ == '' is the correct value for itertools (not 'itertools'
# and not None). The import system sets __package__ to '' for top-level modules.
# For C-extension modules this is determined at import time by importlib's
# C-extension loader, which sets __package__ = '' for top-level extension modules.
#
# __package__ is a Python str, confirmed by __class__.__name__.__eq__('str')==true.
#
# No prior itertools spec records __package__.__eq__('') or
# __package__.__class__.__name__.__eq__('str') as table rows. Both are new
# to extra58.
# ---------------------------------------------------------------------------

table itertools_extra58.package_identity:
  description: "itertools.__package__.__eq__('')==true and __package__.__class__.__name__.__eq__('str')==true — C-extension stdlib module __package__ is empty string (not module name); __package__ is a str; no prior itertools spec has table rows for __package__; new to extra58"
  kind: python_call_eq
  category: string_value
  id_prefix: itertpkg58

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq_empty_string,
       __package__.__eq__,
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools.__package__ is '' (the empty string); itertools is a C-extension module in Modules/itertoolsmodule.c but its __package__ follows the same convention as pure-Python top-level stdlib modules: a top-level module not inside any package hierarchy has __package__ == '' rather than the module name; the import system (importlib's C-extension loader) sets __package__ = '' for top-level extension modules; verified: itertools.__package__.__eq__('itertools') returns False; no prior itertools spec records __package__.__eq__('') as a table row; new to extra58"]
    - [package_class_name_eq_str,
       __package__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__package__.__class__.__name__.__eq__('str') == True — itertools.__package__ is a Python str object (the empty string ''); the str built-in type has __class__.__name__ == 'str' (3 chars); regardless of the empty value, __package__ is always typed as str for stdlib modules (both C-extension and pure-Python); no prior itertools spec records __package__.__class__.__name__.__eq__('str') as a table row; new to extra58"]

# ---------------------------------------------------------------------------
# itertools C-type docstring type checks — extra58
#
# Wave 224 theme: companion to __package__ checks; docstring type identity
# for C-extension itertools types.
#
# The three C-extension types — groupby, chain, count — each have a __doc__
# attribute that is a Python str object. The docstrings are embedded in the
# C source (Modules/itertoolsmodule.c) and exposed as Python str objects at
# module import time.
#
# No prior itertools spec has table rows checking __doc__.__class__.__name__.__eq__('str')
# for any of these types. These checks establish that the docstrings are proper
# Python str objects (not None, bytes, or some other type).
# ---------------------------------------------------------------------------

table itertools_extra58.c_type_doc_class_name:
  description: "itertools groupby/chain/count.__doc__.__class__.__name__.__eq__('str')==true — C-extension type docstrings are Python str objects; no prior itertools spec has table rows checking __doc__.__class__.__name__.__eq__('str') for these types; new to extra58"
  kind: python_call_eq
  category: class_identity
  id_prefix: itertpkg58

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_doc_class_name_eq_str,
       groupby.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — groupby is a C-extension type in Modules/itertoolsmodule.c; its __doc__ attribute is a Python str object containing the type's docstring (323 characters); the C source embeds docstrings as C string literals which Python exposes as str objects at import time; the str type has __class__.__name__ == 'str' (3 chars); no prior itertools spec has a table row checking groupby.__doc__.__class__.__name__.__eq__('str'); new to extra58"]
    - [chain_doc_class_name_eq_str,
       chain.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — chain is a C-extension type in Modules/itertoolsmodule.c; its __doc__ is a Python str object (190 characters) documenting the chain type that makes an iterator that returns elements from the first iterable until exhausted, then from the next iterable, and so on; no prior itertools spec has a table row checking chain.__doc__.__class__.__name__.__eq__('str'); new to extra58"]
    - [count_doc_class_name_eq_str,
       count.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — count is a C-extension type in Modules/itertoolsmodule.c; its __doc__ is a Python str object (205 characters) documenting the count type that makes an iterator returning evenly spaced values starting with number start; no prior itertools spec has a table row checking count.__doc__.__class__.__name__.__eq__('str'); new to extra58"]

# ---------------------------------------------------------------------------
# itertools C-type docstring lengths — extra58
#
# Wave 224 theme: docstring length as companion to type identity checks.
#
# groupby.__doc__.__len__()==323, chain.__doc__.__len__()==190,
# count.__doc__.__len__()==205. All verified with Python 3.14.3.
#
# No prior itertools spec records __doc__.__len__() for groupby, chain, or
# count as table rows. All three are new to extra58.
# ---------------------------------------------------------------------------

table itertools_extra58.c_type_doc_lengths:
  description: "itertools groupby.__doc__.__len__()==323, chain.__doc__.__len__()==190, count.__doc__.__len__()==205 — C-extension type docstring character lengths; no prior itertools spec has table rows checking __doc__.__len__() for these types; new to extra58"
  kind: python_call_eq
  category: length
  id_prefix: itertpkg58

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_doc_len_eq_323,
       groupby.__doc__.__len__,
       [],
       323,
       "itertools.groupby.__doc__.__len__() == 323 — groupby's C-extension docstring is exactly 323 characters in Python 3.14; groupby groups consecutive elements of an iterable that share the same key value; the docstring describes the groupby(iterable, key=None) signature and behavior; no prior itertools spec records groupby.__doc__.__len__()==323 as a table row; new to extra58"]
    - [chain_doc_len_eq_190,
       chain.__doc__.__len__,
       [],
       190,
       "itertools.chain.__doc__.__len__() == 190 — chain's C-extension docstring is exactly 190 characters in Python 3.14; chain makes an iterator that returns elements from the first iterable until exhausted then proceeds to the next iterable; no prior itertools spec records chain.__doc__.__len__()==190 as a table row; new to extra58"]
    - [count_doc_len_eq_205,
       count.__doc__.__len__,
       [],
       205,
       "itertools.count.__doc__.__len__() == 205 — count's C-extension docstring is exactly 205 characters in Python 3.14; count makes an iterator returning evenly spaced values starting with number start; supports non-integer step for floating-point counting; no prior itertools spec records count.__doc__.__len__()==205 as a table row; new to extra58"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra58
# ---------------------------------------------------------------------------

invariant itertools_extra58.package_is_empty_string:
  description: "itertools.__package__.__eq__('') == True — C-extension stdlib module has __package__ == '' (empty string, not module name); same pattern as pure-Python top-level stdlib modules; wave 224 __package__ check; new to extra58"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra58.package_is_str:
  description: "itertools.__package__.__class__.__name__.__eq__('str') == True — __package__ is a Python str object; holds for both C-extension and pure-Python top-level stdlib modules; new to extra58"
  kind: python_call_eq
  function: __package__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra58.groupby_doc_is_str:
  description: "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — C-extension type docstring is a Python str; verified length 323 chars; new to extra58"
  kind: python_call_eq
  function: groupby.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
