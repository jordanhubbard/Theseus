spec: struct_extra214
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct('!H').pack(1) == b'\\x00\\x01' — big-endian unsigned short 1."
    - "struct.Struct('!H').pack(255) == b'\\x00\\xff' — big-endian unsigned short 255."
    - "struct.Struct('!I').pack(0) == b'\\x00\\x00\\x00\\x00' — big-endian unsigned int 0."
    - "struct.Struct('!I').pack(1) == b'\\x00\\x00\\x00\\x01' — big-endian unsigned int 1."
    - "struct.Struct.__name__ == 'Struct'; struct.Struct.__module__ == '_struct'."
    - "struct.pack.__name__ == 'pack'; struct.unpack.__name__ == 'unpack' (already covered in struct_extra213)."
    - "struct.calcsize('!B') == 1; struct.calcsize('!H') == 2; struct.calcsize('!I') == 4; struct.calcsize('!L') == 4."
    - "struct.Struct('!H').pack.__name__ == 'pack'."
    - "struct.error.__name__ == 'error'; struct.error.__bases__[0].__name__ == 'Exception'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct pack results — big-endian network order
#
# struct.Struct('!H').pack(1)   == b'\x00\x01'
# struct.Struct('!H').pack(255) == b'\x00\xff'
# struct.Struct('!I').pack(0)   == b'\x00\x00\x00\x00'
# struct.Struct('!I').pack(1)   == b'\x00\x00\x00\x01'
# ---------------------------------------------------------------------------

invariant struct_extra214.pack_H_1:
  description: "struct.Struct('!H').pack(1) == b'\\x00\\x01' — big-endian unsigned short 1 encodes as two bytes: high byte 0x00, low byte 0x01; network byte order (!) is big-endian; verified with Python 3.14.3"
  category: pack_values
  kind: python_call_eq
  function: "struct.Struct('!H').pack"
  args: [1]
  expected: !hex 0001

invariant struct_extra214.pack_H_255:
  description: "struct.Struct('!H').pack(255) == b'\\x00\\xff' — big-endian unsigned short 255 (0x00FF) encodes as 0x00 0xFF; high byte is 0 since 255 < 256; verified with Python 3.14.3"
  category: pack_values
  kind: python_call_eq
  function: "struct.Struct('!H').pack"
  args: [255]
  expected: !hex 00ff

invariant struct_extra214.pack_I_0:
  description: "struct.Struct('!I').pack(0) == b'\\x00\\x00\\x00\\x00' — big-endian unsigned int 0 encodes as four zero bytes; the all-zeros encoding is the minimum representable value; verified with Python 3.14.3"
  category: pack_values
  kind: python_call_eq
  function: "struct.Struct('!I').pack"
  args: [0]
  expected: !hex 00000000

invariant struct_extra214.pack_I_1:
  description: "struct.Struct('!I').pack(1) == b'\\x00\\x00\\x00\\x01' — big-endian unsigned int 1 encodes as three zero bytes followed by 0x01; smallest non-zero 32-bit big-endian value; verified with Python 3.14.3"
  category: pack_values
  kind: python_call_eq
  function: "struct.Struct('!I').pack"
  args: [1]
  expected: !hex 00000001

# ---------------------------------------------------------------------------
# struct.calcsize — network byte order format sizes
#
# struct.calcsize('!B') == 1
# struct.calcsize('!H') == 2
# struct.calcsize('!I') == 4
# struct.calcsize('!L') == 4
# ---------------------------------------------------------------------------

table struct_extra214.calcsize_network_formats:
  description: "struct.calcsize with network byte order (!) prefix in structeq214 namespace — wave 214 theme: !B=1 (unsigned char) / !H=2 (unsigned short) / !I=4 (unsigned int) / !L=4 (unsigned long); network byte order (!) uses standard sizes, eliminating platform alignment; !I and !L are both 4 bytes on all platforms with the ! prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: calcsize
  id_prefix: structeq214

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_nB, struct.calcsize, ["!B"], 1, "struct.calcsize('!B') == 1 — network byte order unsigned char is 1 byte"]
    - [calcsize_nH, struct.calcsize, ["!H"], 2, "struct.calcsize('!H') == 2 — network byte order unsigned short is 2 bytes"]
    - [calcsize_nI, struct.calcsize, ["!I"], 4, "struct.calcsize('!I') == 4 — network byte order unsigned int is 4 bytes"]
    - [calcsize_nL, struct.calcsize, ["!L"], 4, "struct.calcsize('!L') == 4 — network byte order unsigned long is 4 bytes (standard size with ! prefix)"]

# ---------------------------------------------------------------------------
# struct.Struct instance pack method __name__
#
# struct.Struct('!H').pack.__name__ == 'pack'
# ---------------------------------------------------------------------------

invariant struct_extra214.struct_pack_method_name:
  description: "struct.Struct('!H').pack.__name__ == 'pack' — the bound pack method of a Struct instance reports 'pack' as its __name__; consistent with all other bound method name conventions; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "struct.Struct('!H').pack.__name__.__eq__"
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error exception class hierarchy
#
# struct.error.__name__            == 'error'
# struct.error.__bases__[0].__name__ == 'Exception'
# ---------------------------------------------------------------------------

table struct_extra214.error_class_hierarchy:
  description: "struct.error exception class identity and base class checks in structeq214a namespace — wave 214 theme: error.__name__ == 'error' (flat simple name); error.__bases__[0].__name__ == 'Exception' (direct subclass of Exception); struct.error inherits directly from Exception, not from OSError or ValueError; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: structeq214a

  columns: [id, function, args, expected, description]
  rows:
    - [error_name,      "struct.error.__name__.__eq__",              ["error"],     true, "struct.error.__name__ == 'error' — the struct exception class simple name is 'error'"]
    - [error_base_name, "struct.error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits directly from Exception"]
