spec: bignumber_js
version: ">=9.0.0"
backend: node(bignumber.js)

docs: https://www.npmjs.com/package/bignumber.js

provenance:
  derived_from:
    - "bignumber.js README — https://www.npmjs.com/package/bignumber.js"
    - "Test vectors verified with bignumber.js via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "bignumber.js source"
  notes:
    - "bignumber.js is an npm package. Install: npm install bignumber.js"
    - "BigNumber(val) constructs a BigNumber; callable without new."
    - "Provides toString(), toNumber(), isInteger(), toFixed() methods."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns precise numeric value or boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table bignumber_js.toString:
  kind: node_factory_call_eq
  factory: ~
  method: toString
  category: format
  id_prefix: bnstr

  columns: [id, factory_args, expected]
  rows:
    - [pi,    ["3.14"],                   "3.14"]
    - [large, ["1234567890"],                   "1234567890"]

table bignumber_js.toNumber:
  kind: node_factory_call_eq
  factory: ~
  method: toNumber
  category: convert
  id_prefix: bnnum

  columns: [id, factory_args, expected]
  rows:
    - [pi,  ["3.14"], 3.14]
    - [neg, ["-5"],   -5]

table bignumber_js.isInteger:
  kind: node_factory_call_eq
  factory: ~
  method: isInteger
  category: predicate
  id_prefix: bnint

  columns: [id, factory_args, expected]
  rows:
    - [integer,   ["5"],   true]
    - [not_int,   ["5.5"], false]
