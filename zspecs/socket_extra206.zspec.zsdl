spec: socket_extra206
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec covers __code__ attributes of Python-level socket module functions: create_connection, getfqdn, create_server."
    - "socket.create_connection.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a plain Python int; verified with Python 3.14.3."
    - "socket.getfqdn.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a plain Python int; verified with Python 3.14.3."
    - "socket.create_server.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a plain Python int; verified with Python 3.14.3."
    - "socket.create_connection.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is a plain Python int; verified with Python 3.14.3."
    - "socket.create_connection.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the path to socket.py as a str; verified with Python 3.14.3."
    - "socket.create_connection.__code__.co_argcount == 3 — create_connection takes 3 positional parameters; verified with Python 3.14.3."
    - "socket.getfqdn.__code__.co_argcount == 1 — getfqdn takes 1 positional parameter; verified with Python 3.14.3."
    - "socket.create_server.__code__.co_argcount == 1 — create_server takes 1 positional parameter; verified with Python 3.14.3."
    - "socket.create_connection.__code__.__class__.__name__ == 'code' — the __code__ object is of type 'code'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.create_connection.__code__ attribute class names
#
# create_connection is a Python-level function; its __code__ exposes
# co_flags (int), co_stacksize (int), co_filename (str), co_argcount (int).
# ---------------------------------------------------------------------------

table socket_extra206.create_connection_code_attr_types:
  description: "socket.create_connection.__code__ co_flags/co_stacksize/co_filename/__class__.__name__ checks; new to extra206"
  kind: python_call_eq
  category: code_attrs
  id_prefix: socketcoflags206

  columns: [id, function, args, expected, description]
  rows:
    - [cc_co_flags_class_eq,
       create_connection.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.create_connection.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is a plain Python int on create_connection's code object; verified with Python 3.14.3; new to extra206"]
    - [cc_co_stacksize_class_eq,
       create_connection.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.create_connection.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is a plain Python int on create_connection's code object; verified with Python 3.14.3; new to extra206"]
    - [cc_co_filename_class_eq,
       create_connection.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "socket.create_connection.__code__.co_filename.__class__.__name__.__eq__('str') == True — co_filename is the path to socket.py as a str; verified with Python 3.14.3; new to extra206"]
    - [cc_code_class_eq,
       create_connection.__code__.__class__.__name__.__eq__,
       ["code"],
       true,
       "socket.create_connection.__code__.__class__.__name__.__eq__('code') == True — the __code__ object of create_connection is of type 'code'; verified with Python 3.14.3; new to extra206"]

# ---------------------------------------------------------------------------
# Table 2: socket.getfqdn and socket.create_server __code__ attribute class names
#
# Both are Python-level functions; co_flags, co_stacksize are plain ints.
# ---------------------------------------------------------------------------

table socket_extra206.getfqdn_and_create_server_code_attrs:
  description: "socket.getfqdn and socket.create_server __code__.co_flags/co_stacksize class names; new to extra206"
  kind: python_call_eq
  category: code_attrs
  id_prefix: socketcoflags206

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_co_flags_class_eq,
       getfqdn.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.getfqdn.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is a plain Python int on getfqdn's code object; verified with Python 3.14.3; new to extra206"]
    - [getfqdn_co_stacksize_class_eq,
       getfqdn.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.getfqdn.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is a plain Python int on getfqdn's code object; verified with Python 3.14.3; new to extra206"]
    - [cs_co_flags_class_eq,
       create_server.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.create_server.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is a plain Python int on create_server's code object; verified with Python 3.14.3; new to extra206"]
    - [cs_co_stacksize_class_eq,
       create_server.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.create_server.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is a plain Python int on create_server's code object; verified with Python 3.14.3; new to extra206"]

# ---------------------------------------------------------------------------
# Table 3: co_argcount values and co_name class names
#
# create_connection: co_argcount == 3
# getfqdn: co_argcount == 1
# create_server: co_argcount == 1
# co_name is str for all.
# ---------------------------------------------------------------------------

table socket_extra206.code_argcount_and_name_types:
  description: "socket create_connection/getfqdn/create_server __code__.co_argcount values and co_name class names; new to extra206"
  kind: python_call_eq
  category: code_attrs
  id_prefix: socketcoflags206

  columns: [id, function, args, expected, description]
  rows:
    - [cc_co_argcount_eq_3,
       create_connection.__code__.co_argcount.__eq__,
       [3],
       true,
       "socket.create_connection.__code__.co_argcount.__eq__(3) == True — create_connection takes exactly 3 positional parameters (address, timeout, source_address); verified with Python 3.14.3; new to extra206"]
    - [getfqdn_co_argcount_eq_1,
       getfqdn.__code__.co_argcount.__eq__,
       [1],
       true,
       "socket.getfqdn.__code__.co_argcount.__eq__(1) == True — getfqdn takes exactly 1 positional parameter (name); verified with Python 3.14.3; new to extra206"]
    - [cs_co_argcount_eq_1,
       create_server.__code__.co_argcount.__eq__,
       [1],
       true,
       "socket.create_server.__code__.co_argcount.__eq__(1) == True — create_server takes exactly 1 positional parameter (address); verified with Python 3.14.3; new to extra206"]
    - [cc_co_name_class_eq,
       create_connection.__code__.co_name.__class__.__name__.__eq__,
       ["str"],
       true,
       "socket.create_connection.__code__.co_name.__class__.__name__.__eq__('str') == True — co_name is a str on the code object; verified with Python 3.14.3; new to extra206"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra206
# ---------------------------------------------------------------------------

invariant socket_extra206.create_connection_co_flags_is_int:
  description: "socket.create_connection.__code__.co_flags.__class__.__name__ == 'int' — co_flags on create_connection's code object is a plain Python int; verified with Python 3.14.3; new to extra206"
  category: code_attrs
  kind: python_call_eq
  function: create_connection.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra206.getfqdn_co_flags_is_int:
  description: "socket.getfqdn.__code__.co_flags.__class__.__name__ == 'int' — co_flags on getfqdn's code object is a plain Python int; verified with Python 3.14.3; new to extra206"
  category: code_attrs
  kind: python_call_eq
  function: getfqdn.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra206.create_server_co_flags_is_int:
  description: "socket.create_server.__code__.co_flags.__class__.__name__ == 'int' — co_flags on create_server's code object is a plain Python int; verified with Python 3.14.3; new to extra206"
  category: code_attrs
  kind: python_call_eq
  function: create_server.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra206.create_connection_co_stacksize_is_int:
  description: "socket.create_connection.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize on create_connection's code object is a plain Python int; verified with Python 3.14.3; new to extra206"
  category: code_attrs
  kind: python_call_eq
  function: create_connection.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra206.create_connection_co_filename_is_str:
  description: "socket.create_connection.__code__.co_filename.__class__.__name__ == 'str' — co_filename on create_connection's code object is a str holding the path to socket.py; verified with Python 3.14.3; new to extra206"
  category: code_attrs
  kind: python_call_eq
  function: create_connection.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant socket_extra206.create_connection_code_is_code_type:
  description: "socket.create_connection.__code__.__class__.__name__ == 'code' — the __code__ attribute of create_connection is a code object of type 'code'; verified with Python 3.14.3; new to extra206"
  category: code_attrs
