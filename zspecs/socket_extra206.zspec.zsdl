invariant socket_extra206.create_connection_co_argcount_is_3:
  description: "socket.create_connection.__code__.co_argcount == 3 — create_connection accepts exactly 3 positional arguments (address, timeout, source_address); co_argcount is an int equal to 3; verified with Python 3.14.3; new to extra206"
  category: code_attrs
  kind: python_call_eq
  function: create_connection.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant socket_extra206.getfqdn_co_argcount_is_1:
  description: "socket.getfqdn.__code__.co_argcount == 1 — getfqdn accepts exactly 1 positional argument (name); co_argcount is an int equal to 1; verified with Python 3.14.3; new to extra206"
  category: code_attrs
