spec: hashlib_extra59
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra58.zspec.zsdl — covers blake2b/blake2s __repr__.__class__.__name__/__hash__.__class__.__name__.__eq__('wrapper_descriptor'); hashlib.__spec__.name.__eq__('hashlib') and __spec__.name.__len__()==7."
    - "hashlib_extra57.zspec.zsdl — covers blake2b/blake2s __init__.__class__.__name__/__module__.__eq__('wrapper_descriptor'/'builtins'); md5/sha1/sha3_256/blake2s __class__.__module__.__eq__('builtins')."
    - "hashlib_extra55.zspec.zsdl — covers algorithms_guaranteed.__contains__ for sha224/sha384/blake2b/blake2s/sha3_256/sha3_512; hashlib.__name__.__eq__('hashlib') and __name__.__len__()==7."
    - "hashlib_extra34.zspec.zsdl — covers hashlib.__all__.__class__.__name__.__eq__('tuple') and __all__.__len__()==19 and __all__.__class__.__name__.__len__()==5; new.__class__.__name__.__len__()==8; algorithms_available.__len__()==19."
    - "hashlib_extra11.zspec.zsdl — covers blake2b/__name__/__module__/__qualname__.__eq__ string values."
    - "hashlib_extra40.zspec.zsdl — covers blake2b/__init__/__qualname__.__eq__ and related dunder descriptors."
  notes:
    - "This spec extends hashlib through hashlib_extra58; it does NOT duplicate invariants present in those files."
    - "Wave 223 theme: module __all__ content + __eq__.__class__.__name__ checks."
    - "Coverage gap 1: hashlib_extra34 covers hashlib.__all__.__class__.__name__.__eq__('tuple') and hashlib.__all__.__len__()==19. No prior hashlib spec checks hashlib.__all__.__contains__ for specific member names. hashlib.__all__ is a tuple containing 19 names; __contains__ confirms that specific algorithm names are present in the public API declaration. These are independent from algorithms_guaranteed (covered by hashlib_extra55): __all__.__contains__ checks the module's declared public namespace, whereas algorithms_guaranteed checks runtime availability. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('md5') == True. 'md5' is in hashlib.__all__ (the tuple of public names). hashlib_extra55 checks algorithms_guaranteed.__contains__ for blake2b/blake2s/sha224 etc., but NOT __all__.__contains__ for any name. hashlib_extra34 checks __all__.__len__() and __class__.__name__ but NOT __all__.__contains__. No prior hashlib spec checks __all__.__contains__ for any specific name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('blake2b') == True. 'blake2b' is in hashlib.__all__. Independent regression vector: if blake2b were removed from the public API, __all__.__contains__('blake2b') would return False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('file_digest') == True. 'file_digest' was added in Python 3.11; its presence in __all__ confirms the API surface includes it. No prior hashlib spec checks __all__.__contains__('file_digest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('pbkdf2_hmac') == True. 'pbkdf2_hmac' is in hashlib.__all__. hashlib_extra34 checks pbkdf2_hmac.__qualname__ and __module__ lengths, but NOT whether 'pbkdf2_hmac' is in __all__. No prior hashlib spec checks __all__.__contains__('pbkdf2_hmac'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior hashlib spec checks blake2b.__eq__.__class__.__name__ or blake2s.__eq__.__class__.__name__. hashlib_extra58 checks blake2b/__repr__/__class__.__name__ and __hash__.__class__.__name__ (both 'wrapper_descriptor'). hashlib_extra57 checks __init__.__class__.__name__.__eq__('wrapper_descriptor'). But no prior spec checks __eq__.__class__.__name__ for blake2b or blake2s. blake2b and blake2s are C extension types; they do not define __eq__ themselves, so __eq__ is inherited from object as a wrapper_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__eq__.__class__.__name__ == 'wrapper_descriptor'. blake2b is a C extension type; __eq__ is inherited from object as a slot wrapper (wrapper_descriptor) for the tp_richcompare slot. No prior hashlib spec checks blake2b.__eq__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__eq__.__class__.__name__ == 'wrapper_descriptor'. Same inherited __eq__ pattern as blake2b; both are C extension types. No prior hashlib spec checks blake2s.__eq__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior hashlib spec checks blake2b.__subclasshook__.__class__.__name__ or blake2s.__subclasshook__.__class__.__name__. blake2b and blake2s are C extension types; __subclasshook__ is inherited from object as a classmethod wrapping a builtin_function_or_method. Accessing __subclasshook__ on the type yields the underlying builtin_function_or_method. hashlib_extra58 covers __repr__/__hash__ but NOT __subclasshook__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. __subclasshook__ is inherited from object as a builtin classmethod; accessing it on the type yields a builtin_function_or_method. No prior hashlib spec checks blake2b.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Same pattern as blake2b. No prior hashlib spec checks blake2s.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__ for specific public names
#
# hashlib_extra34 covers hashlib.__all__.__class__.__name__.__eq__('tuple')
# and __all__.__len__()==19 — the type and length of the __all__ tuple.
# hashlib_extra55 covers algorithms_guaranteed.__contains__ for specific names.
# No prior hashlib spec checks __all__.__contains__ for any specific name.
# hashlib.__all__ is a tuple of 19 public names; __contains__ confirms
# membership in the declared public API namespace, independently of runtime
# availability (which algorithms_guaranteed tracks).
# ---------------------------------------------------------------------------

table hashlib_extra59.all_contains:
  description: "hashlib.__all__.__contains__('md5'/'blake2b'/'file_digest'/'pbkdf2_hmac') — confirms specific names in the public API tuple; hashlib_extra34 covers __all__.__class__.__name__/__len__ but NOT __contains__; hashlib_extra55 covers algorithms_guaranteed.__contains__ (runtime availability axis) but NOT __all__.__contains__ (declared namespace axis); no prior hashlib spec checks __all__.__contains__ for any name"
  kind: python_call_eq
  category: module_structure
  id_prefix: hashlibAll59

  columns: [id, function, args, expected]
  rows:
    - [all_contains_md5,        __all__.__contains__, ["md5"],        true]
    - [all_contains_blake2b,    __all__.__contains__, ["blake2b"],    true]
    - [all_contains_file_digest, __all__.__contains__, ["file_digest"], true]
    - [all_contains_pbkdf2_hmac, __all__.__contains__, ["pbkdf2_hmac"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b and blake2s __eq__.__class__.__name__.__eq__('wrapper_descriptor')
#
# hashlib_extra58 checks blake2b/blake2s __repr__.__class__.__name__ and
# __hash__.__class__.__name__ (both 'wrapper_descriptor'). hashlib_extra57
# checks __init__.__class__.__name__.__eq__('wrapper_descriptor'). But no
# prior hashlib spec checks __eq__.__class__.__name__ for blake2b or blake2s.
# blake2b and blake2s are C extension types; they do not define __eq__, so
# __eq__ is inherited from object as a wrapper_descriptor (C slot wrapper
# for the tp_richcompare slot implementing equality).
# ---------------------------------------------------------------------------

table hashlib_extra59.blake_eq_class_name:
  description: "hashlib.blake2b/__eq__/__class__/__name__.__eq__('wrapper_descriptor') and blake2s same — C extension types inherit __eq__ from object as a wrapper_descriptor (C slot wrapper for tp_richcompare); hashlib_extra58 covers __repr__/__hash__.__class__.__name__ for blake2b/blake2s but NOT __eq__; no prior hashlib spec checks __eq__.__class__.__name__ for blake2b or blake2s"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibAll59

  columns: [id, function, args, expected]
  rows:
    - [blake2b_eq_class_name_eq, blake2b.__eq__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [blake2s_eq_class_name_eq, blake2s.__eq__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b and blake2s __subclasshook__.__class__.__name__
#
# __subclasshook__ is inherited from object as a classmethod; accessing it
# on a C extension type yields a builtin_function_or_method. No prior hashlib
# spec checks __subclasshook__.__class__.__name__ for blake2b or blake2s.
# hashlib_extra58 covers __repr__ and __hash__ class names; hashlib_extra57
# covers __init__.__class__.__name__; but __subclasshook__ is unchecked.
# ---------------------------------------------------------------------------

table hashlib_extra59.blake_subclasshook_class_name:
  description: "hashlib.blake2b/__subclasshook__/__class__/__name__.__eq__('builtin_function_or_method') and blake2s same — __subclasshook__ inherited from object as a classmethod wrapper; accessing on the type yields builtin_function_or_method; no prior hashlib spec checks __subclasshook__.__class__.__name__ for blake2b or blake2s"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibAll59

  columns: [id, function, args, expected]
  rows:
    - [blake2b_subclasshook_class_name_eq, blake2b.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [blake2s_subclasshook_class_name_eq, blake2s.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('new') — the 'new' factory function
#
# 'new' is the primary factory function in hashlib; its presence in __all__
# confirms the public API includes the generic constructor. hashlib_extra34
# covers new.__class__.__name__.__len__()==8 (the class name of the new
# function object), but NOT whether 'new' is in __all__. No prior hashlib
# spec checks __all__.__contains__('new').
# ---------------------------------------------------------------------------

invariant hashlib_extra59.all_contains_new:
  description: "hashlib.__all__.__contains__('new') == True — 'new' factory function is in the public API tuple; hashlib_extra34 covers new.__class__.__name__.__len__() but NOT __all__.__contains__('new'); hashlib_extra55 covers algorithms_guaranteed but NOT __all__ membership; no prior hashlib spec checks __all__.__contains__('new')"
  category: module_structure
  kind: python_call_eq
  function: __all__.__contains__
  args: ["new"]
  expected: true
