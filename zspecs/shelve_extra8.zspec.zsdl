spec: shelve_extra8
version: ">=3.0"
backend: python_module(shelve)

docs: https://docs.python.org/3/library/shelve.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shelve.html — Python shelve module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shelve.py"
  notes:
    - "This spec extends shelve.zspec.zsdl through shelve_extra7.zspec.zsdl with new, non-duplicate invariants."
    - "shelve_extra7 covers: Shelf.__mro__[0..2] table; BsdDbShelf.__mro__[0..1] table; Shelf.update/__name__; Shelf.setdefault/__name__."
    - "shelve_extra6 covers: Shelf.__mro__.__len__ >= 4; BsdDbShelf.__bases__.__len__ == 1; open.__doc__.__class__.__name__; Shelf.get.__name__."
    - "shelve_extra5 covers: Shelf method names (keys, values, items, sync, close); Shelf.__dict__.__class__.__name__."
    - "shelve_extra4 covers: __qualname__ for open, Shelf, BsdDbShelf, DbfilenameShelf."
    - "shelve_extra3 covers: BsdDbShelf/__module__; DbfilenameShelf/__module__; Shelf/__bases__/__len__; class metatype table; BsdDbShelf/__bases__[0]/__name__."
    - "No prior spec covers: DbfilenameShelf.__mro__[0].__name__ == 'DbfilenameShelf' — MRO index 0 for DbfilenameShelf."
    - "No prior spec covers: DbfilenameShelf.__mro__[1].__name__ == 'Shelf' — MRO index 1 for DbfilenameShelf."
    - "No prior spec covers: DbfilenameShelf.__mro__[2].__name__ == 'MutableMapping' — MRO index 2 for DbfilenameShelf."
    - "No prior spec covers: Shelf.__mro__[3].__name__ == 'Collection' — MRO index 3 (extra7 covers 0, 1, 2 only)."
    - "No prior spec covers: Shelf.pop.__name__ == 'pop' — inherited MutableMapping pop method."
    - "No prior spec covers: Shelf.__contains__.__name__ == '__contains__' — membership test method."
    - "No prior spec covers: Shelf.__getitem__.__name__ == '__getitem__' — item access method."
    - "No prior spec covers: Shelf.__setitem__.__name__ == '__setitem__' — item assignment method."
    - "No prior spec covers: Shelf.__delitem__.__name__ == '__delitem__' — item deletion method."
    - "shelve_extra5 covers keys/values/items/sync/close; extra6 covers get; extra7 covers update/setdefault; extra8 covers pop/__contains__/__getitem__/__setitem__/__delitem__."
    - "shelve.DbfilenameShelf.__mro__: [DbfilenameShelf, Shelf, MutableMapping, Mapping, Collection, ...] — verified at runtime."
    - "shelve.Shelf.__mro__[3].__name__ == 'Collection' — fourth entry in the Shelf MRO chain."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DbfilenameShelf.__mro__ index checks — depth 0, 1, and 2
#
# shelve_extra7 covers Shelf.__mro__[0..2] and BsdDbShelf.__mro__[0..1].
# No prior spec checks any DbfilenameShelf.__mro__[N].
# DbfilenameShelf.__mro__: [DbfilenameShelf, Shelf, MutableMapping, ...]
# ---------------------------------------------------------------------------

table shelve_extra8.DbfilenameShelf_mro_indices:
  description: "DbfilenameShelf.__mro__ depth checks: index 0=DbfilenameShelf, 1=Shelf, 2=MutableMapping"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: dmro8

  columns: [id, function, args, method, expected]
  rows:
    - [idx0, DbfilenameShelf.__mro__.__getitem__, [0], __name__, "DbfilenameShelf"]
    - [idx1, DbfilenameShelf.__mro__.__getitem__, [1], __name__, "Shelf"]
    - [idx2, DbfilenameShelf.__mro__.__getitem__, [2], __name__, "MutableMapping"]

# ---------------------------------------------------------------------------
# Shelf.__mro__[3].__name__ — Collection
#
# shelve_extra7 covers Shelf.__mro__[0], [1], [2] (Shelf, MutableMapping,
# Mapping). Index 3 is Collection. No prior spec checks this depth.
# ---------------------------------------------------------------------------

invariant shelve_extra8.Shelf.mro_idx3:
  description: "shelve.Shelf.__mro__[3].__name__ == 'Collection' — MRO depth 3"
  category: class_hierarchy
  kind: python_call_eq
  function: Shelf.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "Collection"

# ---------------------------------------------------------------------------
# Shelf dunder item-access method names
#
# shelve_extra5 covers keys/values/items/sync/close; extra6 covers get;
# extra7 covers update/setdefault. The four item-access dunders
# (__getitem__, __setitem__, __delitem__, __contains__) and pop() have not
# appeared in any prior shelve spec.
# ---------------------------------------------------------------------------

invariant shelve_extra8.Shelf.getitem_name:
  description: "shelve.Shelf.__getitem__.__name__ == '__getitem__' — item access method"
  category: method_names
  kind: python_call_eq
  function: Shelf.__getitem__.__name__.__eq__
  args: ["__getitem__"]
  expected: true

invariant shelve_extra8.Shelf.setitem_name:
  description: "shelve.Shelf.__setitem__.__name__ == '__setitem__' — item assignment method"
  category: method_names
  kind: python_call_eq
  function: Shelf.__setitem__.__name__.__eq__
  args: ["__setitem__"]
  expected: true

invariant shelve_extra8.Shelf.delitem_name:
  description: "shelve.Shelf.__delitem__.__name__ == '__delitem__' — item deletion method"
  category: method_names
  kind: python_call_eq
  function: Shelf.__delitem__.__name__.__eq__
  args: ["__delitem__"]
  expected: true

invariant shelve_extra8.Shelf.contains_name:
  description: "shelve.Shelf.__contains__.__name__ == '__contains__' — membership test method"
  category: method_names
  kind: python_call_eq
  function: Shelf.__contains__.__name__.__eq__
  args: ["__contains__"]
  expected: true

invariant shelve_extra8.Shelf.pop_name:
  description: "shelve.Shelf.pop.__name__ == 'pop' — inherited MutableMapping pop method"
  category: method_names
  kind: python_call_eq
  function: Shelf.pop.__name__.__eq__
  args: ["pop"]
  expected: true
