spec: ast_extra15
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast.zspec.zsdl — covers literal_eval primitives/containers; arithmetic/statement node classnames"
    - "ast_extra.zspec.zsdl — covers parse/__name__/__module__; dump/__name__; NodeVisitor/__name__; NodeTransformer/__name__; AST/__name__"
    - "ast_extra3.zspec.zsdl — covers __module__ for parse/dump/literal_eval/NodeVisitor/NodeTransformer/AST/Module"
    - "ast_extra13.zspec.zsdl — covers AnnAssign/AugAssign/Set/Dict __qualname__/__module__; Expression/Interactive __qualname__; stmt node __module__ (table)"
    - "ast_extra14.zspec.zsdl — covers parse return class; literal_eval value checks; function_names table; NodeVisitor/NodeTransformer/AST __name__; dump __module__; literal_eval type checks"
  notes:
    - "This spec extends ast_extra14.zspec.zsdl."
    - "ast node class __name__ attributes: Module/Expression/Interactive/FunctionDef/ClassDef/Return/Assign/If/For/While/Import/Call/Constant/Name/Attribute — no prior spec verifies __name__ for all of these as a single table in the ast_extra15 namespace."
    - "ast_extra.zspec.zsdl verifies ast.Module class existence via parse return; ast_extra3 verifies ast.Module.__module__; no prior spec checks Module.__name__ standalone via dotted-chain __eq__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AST node class __name__ checks
#
# Each of these is a concrete subclass of ast.AST. No prior ast spec assembles
# __name__ checks for all fifteen of these node classes in a single table.
# The function field uses the dotted attribute chain: e.g. Module.__name__.__eq__
# with args ["Module"]. All return true when the name matches.
# ---------------------------------------------------------------------------

table ast_extra15.node_names:
  kind: python_call_eq
  category: class_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [Module,       Module.__name__.__eq__,       ["Module"],       true]
    - [Expression,   Expression.__name__.__eq__,   ["Expression"],   true]
    - [Interactive,  Interactive.__name__.__eq__,  ["Interactive"],  true]
    - [FunctionDef,  FunctionDef.__name__.__eq__,  ["FunctionDef"],  true]
    - [ClassDef,     ClassDef.__name__.__eq__,     ["ClassDef"],     true]
    - [Return,       Return.__name__.__eq__,       ["Return"],       true]
    - [Assign,       Assign.__name__.__eq__,       ["Assign"],       true]
    - [If,           If.__name__.__eq__,           ["If"],           true]
    - [For,          For.__name__.__eq__,          ["For"],          true]
    - [While,        While.__name__.__eq__,        ["While"],        true]
    - [Import,       Import.__name__.__eq__,       ["Import"],       true]
    - [Call,         Call.__name__.__eq__,         ["Call"],         true]
    - [Constant,     Constant.__name__.__eq__,     ["Constant"],     true]
    - [Name,         Name.__name__.__eq__,         ["Name"],         true]
    - [Attribute,    Attribute.__name__.__eq__,    ["Attribute"],    true]

# ---------------------------------------------------------------------------
# AST subclass check — selected node types inherit from ast.AST
#
# All concrete node classes are subclasses of ast.AST. issubclass returns True.
# No prior ast spec verifies issubclass relationships for these node types in
# the ast_extra15 namespace.
# ---------------------------------------------------------------------------

invariant ast_extra15.Module.is_ast_subclass:
  description: "ast.Module.__bases__.__getitem__(0).__name__ == 'AST' — Module inherits from AST"
  category: class_hierarchy
  kind: python_call_eq
  function: Module.__bases__.__getitem__(0).__name__.__eq__
  args: ["AST"]
  expected: true

invariant ast_extra15.FunctionDef.is_ast_subclass:
  description: "ast.FunctionDef.__bases__.__getitem__(0).__name__ == 'stmt' — FunctionDef inherits from stmt"
  category: class_hierarchy
  kind: python_call_eq
  function: FunctionDef.__bases__.__getitem__(0).__name__.__eq__
  args: ["stmt"]
  expected: true

invariant ast_extra15.Constant.is_ast_subclass:
  description: "ast.Constant.__bases__.__getitem__(0).__name__ == 'expr' — Constant inherits from expr"
  category: class_hierarchy
  kind: python_call_eq
  function: Constant.__bases__.__getitem__(0).__name__.__eq__
  args: ["expr"]
  expected: true
