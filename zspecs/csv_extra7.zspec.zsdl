spec: csv_extra7
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and prior extras."
    - "csv_extra5 covers reader.__qualname__, writer.__qualname__, DictReader.__qualname__, DictWriter.__qualname__."
    - "csv_extra4 covers reader.__module__ and writer.__module__ via the _csv module."
    - "Focus here: csv.reader.__name__, csv.writer.__name__, csv.DictReader.__name__, csv.DictWriter.__name__, csv.reader.__module__ (== '_csv'), csv.DictReader.__module__ (== 'csv'), csv.DictWriter.__module__ (== 'csv'), csv.DictReader.__qualname__ (already in extra5, not duplicated)."
    - "csv.reader.__name__ == 'reader' — the C builtin type name as seen from the csv namespace."
    - "csv.writer.__name__ == 'writer' — similarly implemented in _csv.c."
    - "csv.reader.__module__ == '_csv' — reader is defined in the C extension _csv."
    - "csv.writer.__module__ == '_csv' — writer is defined in the C extension _csv."
    - "csv.DictReader.__name__ == 'DictReader' — pure-Python class defined in Lib/csv.py."
    - "csv.DictWriter.__name__ == 'DictWriter' — pure-Python class defined in Lib/csv.py."
    - "csv.DictReader.__module__ == 'csv' — defined in Lib/csv.py, not in _csv."
    - "csv.DictWriter.__module__ == 'csv' — defined in Lib/csv.py, not in _csv."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks for reader and writer (C-extension types)
# csv_extra5 checks __qualname__; this spec checks __name__ which is a
# distinct attribute on the type objects (for C types __name__ != __qualname__
# is possible when nested, but for top-level types they are equal strings).
# ---------------------------------------------------------------------------

table csv_extra7.c_type_names:
  kind: python_call_eq
  category: type_names
  id_prefix: tname

  columns: [id, function, args, expected]
  rows:
    - [reader, reader.__name__.__eq__, ["reader"], true]
    - [writer, writer.__name__.__eq__, ["writer"], true]

# ---------------------------------------------------------------------------
# __name__ checks for DictReader and DictWriter (pure-Python classes)
# csv_extra5 checks __qualname__; this spec checks __name__.
# ---------------------------------------------------------------------------

table csv_extra7.dict_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [DictReader, DictReader.__name__.__eq__, ["DictReader"], true]
    - [DictWriter, DictWriter.__name__.__eq__, ["DictWriter"], true]

# ---------------------------------------------------------------------------
# __module__ checks — reader and writer live in _csv (C extension)
# ---------------------------------------------------------------------------

invariant csv_extra7.reader.module:
  description: "csv.reader.__module__ == '_csv' — reader is implemented in the _csv C extension"
  category: modules
  kind: python_call_eq
  function: reader.__module__.__eq__
  args: ["_csv"]
  expected: true

invariant csv_extra7.writer.module:
  description: "csv.writer.__module__ == '_csv' — writer is implemented in the _csv C extension"
  category: modules
  kind: python_call_eq
  function: writer.__module__.__eq__
  args: ["_csv"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks — DictReader and DictWriter live in csv (pure Python)
# ---------------------------------------------------------------------------

invariant csv_extra7.DictReader.module:
  description: "csv.DictReader.__module__ == 'csv' — DictReader is defined in Lib/csv.py"
  category: modules
  kind: python_call_eq
  function: DictReader.__module__.__eq__
  args: ["csv"]
  expected: true

invariant csv_extra7.DictWriter.module:
  description: "csv.DictWriter.__module__ == 'csv' — DictWriter is defined in Lib/csv.py"
  category: modules
  kind: python_call_eq
  function: DictWriter.__module__.__eq__
  args: ["csv"]
  expected: true
