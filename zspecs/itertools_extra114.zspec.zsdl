spec: itertools_extra114
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra113.zspec.zsdl."
    - "This spec covers: itertools iterator type __qualname__ attributes for islice, groupby, compress, count, product, permutations, combinations; qualname == name for all top-level C-extension types; qualname lengths; wave 265."
    - "itertools.islice.__qualname__ == 'islice' (len 6). Verified with Python 3.14.3."
    - "itertools.groupby.__qualname__ == 'groupby' (len 7). Verified with Python 3.14.3."
    - "itertools.compress.__qualname__ == 'compress' (len 8). Verified with Python 3.14.3."
    - "itertools.count.__qualname__ == 'count' (len 5). Verified with Python 3.14.3."
    - "itertools.product.__qualname__ == 'product' (len 7). Verified with Python 3.14.3."
    - "itertools.permutations.__qualname__ == 'permutations' (len 12). Verified with Python 3.14.3."
    - "itertools.combinations.__qualname__ == 'combinations' (len 12). Verified with Python 3.14.3."
    - "All itertools iterator types: __qualname__ == __name__ (top-level C-extension types have no enclosing scope). Verified with Python 3.14.3."
    - "itertools.chain.__qualname__ == 'chain' (len 5). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools iterator type __qualname__ string values
#
# Wave 265 theme: All itertools iterator types are C-extension types defined
# in Modules/itertoolsmodule.c. Because they are all defined at module scope
# (not nested inside another class), their __qualname__ equals their __name__
# exactly. islice.__qualname__ == 'islice' (6), groupby.__qualname__ == 'groupby'
# (7), compress.__qualname__ == 'compress' (8), count.__qualname__ == 'count'
# (5), product.__qualname__ == 'product' (7), permutations.__qualname__ ==
# 'permutations' (12), combinations.__qualname__ == 'combinations' (12).
# permutations and combinations share the same qualname length of 12.
#
# itertools.islice.__qualname__ == 'islice'
# itertools.groupby.__qualname__ == 'groupby'
# itertools.compress.__qualname__ == 'compress'
# itertools.count.__qualname__ == 'count'
# itertools.product.__qualname__ == 'product'
#
# New to extra114.
# ---------------------------------------------------------------------------

table itertools_extra114.iterator_type_qualnames:
  description: "itertools iterator __qualname__: islice='islice'(6), groupby='groupby'(7), compress='compress'(8), count='count'(5), product='product'(7); all C-extension top-level types; wave 265; new to extra114"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsitq114

  columns: [id, function, args, expected, description]
  rows:
    - [islice_qualname,
       "islice.__qualname__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — islice is a C-extension type at module scope; __qualname__ equals __name__; str.__eq__('islice') returns True; new to extra114"]
    - [islice_qualname_len,
       "islice.__qualname__.__len__",
       [],
       6,
       "itertools.islice.__qualname__.__len__() == 6 — 'islice' has 6 characters: i-s-l-i-c-e; str.__len__() returns 6; new to extra114"]
    - [groupby_qualname,
       "groupby.__qualname__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__qualname__.__eq__('groupby') == True — groupby is a C-extension type at module scope; __qualname__ equals __name__; str.__eq__('groupby') returns True; new to extra114"]
    - [groupby_qualname_len,
       "groupby.__qualname__.__len__",
       [],
       7,
       "itertools.groupby.__qualname__.__len__() == 7 — 'groupby' has 7 characters: g-r-o-u-p-b-y; str.__len__() returns 7; new to extra114"]
    - [compress_qualname,
       "compress.__qualname__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__qualname__.__eq__('compress') == True — compress is a C-extension type at module scope; __qualname__ equals __name__; str.__eq__('compress') returns True; new to extra114"]
    - [compress_qualname_len,
       "compress.__qualname__.__len__",
       [],
       8,
       "itertools.compress.__qualname__.__len__() == 8 — 'compress' has 8 characters: c-o-m-p-r-e-s-s; str.__len__() returns 8; new to extra114"]
    - [count_qualname,
       "count.__qualname__.__eq__",
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a C-extension type at module scope; __qualname__ equals __name__; str.__eq__('count') returns True; new to extra114"]
    - [count_qualname_len,
       "count.__qualname__.__len__",
       [],
       5,
       "itertools.count.__qualname__.__len__() == 5 — 'count' has 5 characters: c-o-u-n-t; same length as 'chain'; str.__len__() returns 5; new to extra114"]
    - [product_qualname,
       "product.__qualname__.__eq__",
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — product is a C-extension type at module scope; __qualname__ equals __name__; str.__eq__('product') returns True; new to extra114"]
    - [product_qualname_len,
       "product.__qualname__.__len__",
       [],
       7,
       "itertools.product.__qualname__.__len__() == 7 — 'product' has 7 characters: p-r-o-d-u-c-t; same length as 'groupby'; str.__len__() returns 7; new to extra114"]

# ---------------------------------------------------------------------------
# Table 2: itertools permutations and combinations __qualname__
#
# Wave 265 theme: itertools.permutations and itertools.combinations are both
# C-extension types with __qualname__ matching __name__. Both have the same
# qualname length of 12. itertools.combinations_with_replacement has a much
# longer qualname of 28 characters. The shared length of 12 between
# permutations and combinations is a notable structural property. chain has
# qualname len 5, the shortest alongside count and cycle.
#
# itertools.permutations.__qualname__ == 'permutations'   (len 12)
# itertools.combinations.__qualname__ == 'combinations'   (len 12)
# len(permutations.__qualname__) == len(combinations.__qualname__)
# itertools.chain.__qualname__ == 'chain'                 (len 5)
#
# New to extra114.
# ---------------------------------------------------------------------------

table itertools_extra114.permutations_combinations_qualnames:
  description: "itertools permutations/combinations __qualname__: both='permutations'/'combinations' each len 12; chain='chain'(5); permutations and combinations share qualname length; wave 265; new to extra114"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolspcq114

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_qualname,
       "permutations.__qualname__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations is a C-extension type at module scope; __qualname__ equals __name__; str.__eq__('permutations') returns True; new to extra114"]
    - [permutations_qualname_len,
       "permutations.__qualname__.__len__",
       [],
       12,
       "itertools.permutations.__qualname__.__len__() == 12 — 'permutations' has 12 characters: p-e-r-m-u-t-a-t-i-o-n-s; same length as combinations; str.__len__() returns 12; new to extra114"]
    - [combinations_qualname,
       "combinations.__qualname__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations is a C-extension type at module scope; __qualname__ equals __name__; str.__eq__('combinations') returns True; new to extra114"]
    - [combinations_qualname_len,
       "combinations.__qualname__.__len__",
       [],
       12,
       "itertools.combinations.__qualname__.__len__() == 12 — 'combinations' has 12 characters: c-o-m-b-i-n-a-t-i-o-n-s; same length as permutations; str.__len__() returns 12; new to extra114"]
    - [chain_qualname,
       "chain.__qualname__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is a C-extension type at module scope; __qualname__ equals __name__; str.__eq__('chain') returns True; new to extra114"]
    - [chain_qualname_len,
       "chain.__qualname__.__len__",
       [],
       5,
       "itertools.chain.__qualname__.__len__() == 5 — 'chain' has 5 characters: c-h-a-i-n; shortest qualname among itertools types along with count and cycle; str.__len__() returns 5; new to extra114"]

# ---------------------------------------------------------------------------
# Table 3: itertools iterator type __qualname__ == __name__ identity
#
# Wave 265 theme: For all C-extension types defined at module scope, __qualname__
# and __name__ are identical strings. This is because there is no enclosing
# class scope to prefix. The equality check using __eq__ returns True for
# islice, groupby, compress, count, and product. This distinguishes top-level
# C-extension types from nested classes (which would show 'Outer.Inner').
#
# islice.__qualname__.__eq__(islice.__name__) == True
# groupby.__qualname__.__eq__(groupby.__name__) == True
# compress.__qualname__.__eq__(compress.__name__) == True
# count.__qualname__.__eq__(count.__name__) == True
# product.__qualname__.__eq__(product.__name__) == True
#
# New to extra114.
# ---------------------------------------------------------------------------

table itertools_extra114.qualname_equals_name:
  description: "itertools iterator types: __qualname__ == __name__ for islice, groupby, compress, count, product — all top-level C-extension types with no enclosing scope; wave 265; new to extra114"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsqen114

  columns: [id, function, args, expected, description]
  rows:
    - [islice_qualname_eq_name,
       "islice.__qualname__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — __qualname__ equals __name__ for top-level C-extension types; 'islice' is the bare name; str.__eq__('islice') returns True; new to extra114"]
    - [groupby_qualname_eq_name,
       "groupby.__qualname__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__qualname__.__eq__('groupby') == True — __qualname__ equals __name__ for top-level C-extension types; 'groupby' is the bare name; str.__eq__('groupby') returns True; new to extra114"]
    - [compress_qualname_eq_name,
       "compress.__qualname__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__qualname__.__eq__('compress') == True — __qualname__ equals __name__ for top-level C-extension types; 'compress' is the bare name; str.__eq__('compress') returns True; new to extra114"]
    - [count_qualname_eq_name,
       "count.__qualname__.__eq__",
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — __qualname__ equals __name__ for top-level C-extension types; 'count' is the bare name; str.__eq__('count') returns True; new to extra114"]
    - [product_qualname_eq_name,
       "product.__qualname__.__eq__",
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — __qualname__ equals __name__ for top-level C-extension types; 'product' is the bare name; str.__eq__('product') returns True; new to extra114"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra114
# ---------------------------------------------------------------------------

invariant itertools_extra114.islice_qualname:
  description: "itertools.islice.__qualname__ == 'islice' — top-level C-extension type; qualname equals name; len 6; wave 265; new to extra114"
  kind: python_call_eq
  function: islice.__qualname__.__eq__
  args: ["islice"]
  expected: true

invariant itertools_extra114.groupby_qualname_len:
  description: "len(itertools.groupby.__qualname__) == 7 — 'groupby' is 7 characters; same length as 'product'; wave 265; new to extra114"
  kind: python_call_eq
  function: groupby.__qualname__.__len__
  args: []
  expected: 7

invariant itertools_extra114.permutations_qualname_len:
  description: "len(itertools.permutations.__qualname__) == 12 — 'permutations' is 12 characters; same length as 'combinations'; wave 265; new to extra114"
  kind: python_call_eq
  function: permutations.__qualname__.__len__
  args: []
  expected: 12

invariant itertools_extra114.combinations_qualname_len:
  description: "len(itertools.combinations.__qualname__) == 12 — 'combinations' is 12 characters; same length as 'permutations'; wave 265; new to extra114"
  kind: python_call_eq
  function: combinations.__qualname__.__len__
  args: []
  expected: 12

invariant itertools_extra114.compress_qualname_len:
  description: "len(itertools.compress.__qualname__) == 8 — 'compress' is 8 characters; unique length among the itertools types surveyed; wave 265; new to extra114"
  kind: python_call_eq
  function: compress.__qualname__.__len__
  args: []
  expected: 8
