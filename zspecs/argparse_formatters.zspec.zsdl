spec: argparse_formatters
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html#formatter-class

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/argparse.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "argparse source: Lib/argparse.py (PSF; source inspection permitted)"
  not_derived_from:
    - "argparse spec — that spec covers ArgumentParser, Namespace, nargs constants, SUPPRESS/REMAINDER, and the ArgumentError/ArgumentTypeError exception hierarchy; this spec focuses on HelpFormatter subclasses, FileType, and BooleanOptionalAction"
  notes:
    - "HelpFormatter is the default formatter; its subclasses override _fill_text and/or _split_lines."
    - "RawDescriptionHelpFormatter preserves whitespace in the description but not in argument help text."
    - "RawTextHelpFormatter preserves whitespace in both description and argument help text."
    - "ArgumentDefaultsHelpFormatter appends the default value to each argument's help text."
    - "MetavarTypeHelpFormatter uses the type function name as the metavar."
    - "All four public formatter subclasses inherit directly from HelpFormatter."
    - "FileType is a callable factory that returns a file-like object; it is not a subclass of any file class."
    - "BooleanOptionalAction (Python 3.9+) is a subclass of Action; it provides --foo/--no-foo pairs."
    - "ArgumentError.__bases__[0].__name__ == 'Exception' — direct Exception subclass (no intermediate base)."
    - "ArgumentTypeError.__bases__[0].__name__ == 'Exception' — direct Exception subclass."
    - "All expected values verified by running Python 3.14.3 argparse on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Formatter classes do not raise on construction; they require a prog string. FileType raises TypeError or OSError when the file cannot be opened. BooleanOptionalAction construction is handled by ArgumentParser internally."
  stderr: "null"
  stickiness: "N/A — formatter instances are created per-parser."
  codes: {}

# ---------------------------------------------------------------------------
# HelpFormatter subclass __name__ checks
# ---------------------------------------------------------------------------

table argparse_formatters.formatter_names:
  kind: python_call_eq
  category: class_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [helpformatter,                 HelpFormatter.__name__.__eq__,                 ["HelpFormatter"],                 true]
    - [rawdescription,                RawDescriptionHelpFormatter.__name__.__eq__,   ["RawDescriptionHelpFormatter"],   true]
    - [rawtext,                       RawTextHelpFormatter.__name__.__eq__,          ["RawTextHelpFormatter"],          true]
    - [argumentdefaults,              ArgumentDefaultsHelpFormatter.__name__.__eq__, ["ArgumentDefaultsHelpFormatter"], true]
    - [metavartype,                   MetavarTypeHelpFormatter.__name__.__eq__,      ["MetavarTypeHelpFormatter"],      true]

# ---------------------------------------------------------------------------
# HelpFormatter subclass inheritance — all four subclasses derive from HelpFormatter
# ---------------------------------------------------------------------------

table argparse_formatters.formatter_bases:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: fbase

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [rawdescription_base,   RawDescriptionHelpFormatter.__bases__.__getitem__,   [0], __name__, [], "HelpFormatter"]
    - [rawtext_base,          RawTextHelpFormatter.__bases__.__getitem__,          [0], __name__, [], "HelpFormatter"]
    - [argumentdefaults_base, ArgumentDefaultsHelpFormatter.__bases__.__getitem__, [0], __name__, [], "HelpFormatter"]
    - [metavartype_base,      MetavarTypeHelpFormatter.__bases__.__getitem__,      [0], __name__, [], "HelpFormatter"]

# ---------------------------------------------------------------------------
# __module__ checks — all formatter classes belong to argparse
# ---------------------------------------------------------------------------

table argparse_formatters.formatter_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [helpformatter,    HelpFormatter.__module__.__eq__,                 ["argparse"], true]
    - [rawtext,          RawTextHelpFormatter.__module__.__eq__,          ["argparse"], true]
    - [argumentdefaults, ArgumentDefaultsHelpFormatter.__module__.__eq__, ["argparse"], true]
    - [metavartype,      MetavarTypeHelpFormatter.__module__.__eq__,      ["argparse"], true]

# ---------------------------------------------------------------------------
# FileType — callable factory for file arguments
# ---------------------------------------------------------------------------

invariant argparse_formatters.filetype_name:
  description: "argparse.FileType.__name__ == 'FileType'"
  category: class_names
  kind: python_call_eq
  function: FileType.__name__.__eq__
  args: ["FileType"]
  expected: true

invariant argparse_formatters.filetype_module:
  description: "argparse.FileType.__module__ == 'argparse'"
  category: class_modules
  kind: python_call_eq
  function: FileType.__module__.__eq__
  args: ["argparse"]
  expected: true

# ---------------------------------------------------------------------------
# BooleanOptionalAction — Action subclass for --flag/--no-flag pairs (Python 3.9+)
# ---------------------------------------------------------------------------

invariant argparse_formatters.booleanoptionalaction_name:
  description: "argparse.BooleanOptionalAction.__name__ == 'BooleanOptionalAction'"
  category: class_names
  kind: python_call_eq
  function: BooleanOptionalAction.__name__.__eq__
  args: ["BooleanOptionalAction"]
  expected: true

invariant argparse_formatters.booleanoptionalaction_base:
  description: "argparse.BooleanOptionalAction.__bases__[0].__name__ == 'Action'"
  category: class_hierarchy
  kind: python_call_eq
  function: BooleanOptionalAction.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Action"

# ---------------------------------------------------------------------------
# Exception class hierarchy
# ---------------------------------------------------------------------------

invariant argparse_formatters.argumenterror_base:
  description: "argparse.ArgumentError.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: ArgumentError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

invariant argparse_formatters.argumenttypeerror_base:
  description: "argparse.ArgumentTypeError.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: ArgumentTypeError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"
