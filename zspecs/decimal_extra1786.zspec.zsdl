spec: decimal_extra1786
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers Decimal str/predicates/as_tuple/class name/getcontext/error cases"
    - "decimal_extra.zspec.zsdl — covers Decimal predicates/eng_string, Context/BasicContext/ExtendedContext names, ROUND_* constants"
    - "decimal_extra1771.zspec.zsdl — covers async protocol, Context dict methods, absent numeric protocols, ROUND_* types"
  notes:
    - "Wave 566, theme: __class_getitem__ and __init_subclass__ class creation hooks."
    - "Decimal and Context are C extension types; neither defines __class_getitem__ — Decimal[...] has no semantic meaning."
    - "decimal exception classes (DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow) also do NOT define __class_getitem__."
    - "None of the decimal types define __init_subclass__ in their own __dict__."
    - "Complementary rows: Decimal defines __add__, __sub__, __mul__, __truediv__, __neg__, sqrt, ln, log10, exp, quantize directly."
    - "Context defines add, subtract, multiply, divide, sqrt, power, create_decimal directly in its own __dict__."
    - "All expected values verified by running Python 3.14 decimal module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Wave 566 theme: __class_getitem__ — absent from all decimal types
# Decimal and Context are C types; Decimal[...] is not valid syntax
# ---------------------------------------------------------------------------

table decimal_extra1786.class_getitem:
  description: "__class_getitem__ absent from all decimal type __dict__ — C types and exception classes do not define it"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: dc1786

  columns: [id, function, args, expected]
  rows:
    - ["dc1786001", decimal.Decimal.__dict__.__contains__,          ["__class_getitem__"], false]
    - ["dc1786002", decimal.Context.__dict__.__contains__,          ["__class_getitem__"], false]
    - ["dc1786003", decimal.DecimalException.__dict__.__contains__, ["__class_getitem__"], false]
    - ["dc1786004", decimal.InvalidOperation.__dict__.__contains__, ["__class_getitem__"], false]
    - ["dc1786005", decimal.DivisionByZero.__dict__.__contains__,   ["__class_getitem__"], false]
    - ["dc1786006", decimal.Overflow.__dict__.__contains__,         ["__class_getitem__"], false]
    - ["dc1786007", decimal.Underflow.__dict__.__contains__,        ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Wave 566 theme: __init_subclass__ — absent from all decimal types
# ---------------------------------------------------------------------------

table decimal_extra1786.init_subclass:
  description: "__init_subclass__ absent from all decimal type __dict__ — not overridden in Decimal, Context, or exceptions"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: dc1786

  columns: [id, function, args, expected]
  rows:
    - ["dc1786008",  decimal.Decimal.__dict__.__contains__,          ["__init_subclass__"], false]
    - ["dc1786009",  decimal.Context.__dict__.__contains__,          ["__init_subclass__"], false]
    - ["dc1786010",  decimal.DecimalException.__dict__.__contains__, ["__init_subclass__"], false]
    - ["dc1786011",  decimal.InvalidOperation.__dict__.__contains__, ["__init_subclass__"], false]
    - ["dc1786012",  decimal.DivisionByZero.__dict__.__contains__,   ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Complementary: Decimal defines arithmetic dunder methods directly in its __dict__
# __add__, __sub__, __mul__, __truediv__, __neg__, sqrt, ln, log10, exp, quantize
# ---------------------------------------------------------------------------

table decimal_extra1786.decimal_arithmetic_dict:
  description: "Decimal defines arithmetic operators and math methods directly in its own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: dc1786

  columns: [id, function, args, expected]
  rows:
    - ["dc1786013", decimal.Decimal.__dict__.__contains__, ["__add__"],      true]
    - ["dc1786014", decimal.Decimal.__dict__.__contains__, ["__sub__"],      true]
    - ["dc1786015", decimal.Decimal.__dict__.__contains__, ["__mul__"],      true]
    - ["dc1786016", decimal.Decimal.__dict__.__contains__, ["__truediv__"],  true]
    - ["dc1786017", decimal.Decimal.__dict__.__contains__, ["__neg__"],      true]
    - ["dc1786018", decimal.Decimal.__dict__.__contains__, ["sqrt"],         true]
    - ["dc1786019", decimal.Decimal.__dict__.__contains__, ["ln"],           true]
    - ["dc1786020", decimal.Decimal.__dict__.__contains__, ["quantize"],     true]

# ---------------------------------------------------------------------------
# Complementary: Context defines arithmetic operation methods in its own __dict__
# add, subtract, multiply, divide, sqrt, power, create_decimal
# ---------------------------------------------------------------------------

table decimal_extra1786.context_arithmetic_dict:
  description: "Context defines add, subtract, multiply, divide, sqrt, power, create_decimal in its own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: dc1786

  columns: [id, function, args, expected]
  rows:
    - ["dc1786021", decimal.Context.__dict__.__contains__, ["add"],            true]
    - ["dc1786022", decimal.Context.__dict__.__contains__, ["subtract"],       true]
    - ["dc1786023", decimal.Context.__dict__.__contains__, ["multiply"],       true]
    - ["dc1786024", decimal.Context.__dict__.__contains__, ["divide"],         true]
    - ["dc1786025", decimal.Context.__dict__.__contains__, ["sqrt"],           true]
