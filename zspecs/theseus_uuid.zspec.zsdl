spec: theseus_uuid
version: ">=3.9"
backend: python_cleanroom(theseus_uuid)
blocks: uuid

docs: https://www.rfc-editor.org/rfc/rfc4122

provenance:
  derived_from:
    - "https://www.rfc-editor.org/rfc/rfc4122 — UUID RFC"
  notes:
    - "Clean-room UUID v4 generator. Do NOT import uuid or any random library beyond os.urandom."
    - "UUID v4 is randomly generated: 128 bits with version=4 and variant=RFC4122 bits set."
    - "Format: xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx where y is 8, 9, a, or b."
    - "uuid4() returns a UUID string matching the pattern above."
    - "uuid_nil() returns '00000000-0000-0000-0000-000000000000'."
    - "Export: uuid4() -> str, uuid_nil() -> str."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_uuid.uuid4_format:
  description: "uuid4() returns a string matching UUID v4 format"
  category: format
  kind: python_call_eq
  function: uuid4_is_valid_format
  args: []
  expected: true

invariant theseus_uuid.uuid4_version:
  description: "uuid4() has version digit '4'"
  category: format
  kind: python_call_eq
  function: uuid4_has_version4
  args: []
  expected: true

invariant theseus_uuid.uuid_nil:
  description: "uuid_nil() returns all-zeros UUID"
  category: nil
  kind: python_call_eq
  function: uuid_nil
  args: []
  expected: "00000000-0000-0000-0000-000000000000"
