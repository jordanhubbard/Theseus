spec: theseus_difflib
version: ">=3.9"
backend: python_cleanroom(theseus_difflib)
blocks: difflib

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html"
  notes:
    - "Clean-room diff/similarity utilities. Do NOT import difflib."
    - "SequenceMatcher ratio: similarity ratio between two strings (0.0 to 1.0)."
    - "get_close_matches(word, possibilities, n=3, cutoff=0.6) returns best matches."
    - "unified_diff(a, b) returns lines of unified diff format."
    - "difflib_ratio_identical(): ratio of 'hello' vs 'hello' == 1.0."
    - "difflib_close_matches(): get_close_matches('appel', ['ape', 'apple', 'peach']) includes 'apple'."
    - "difflib_ratio_different(): ratio of 'abc' vs 'xyz' < 0.5."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_difflib.ratio_identical:
  description: "SequenceMatcher ratio of identical strings == 1.0"
  category: ratio
  kind: python_call_eq
  function: difflib_ratio_identical
  args: []
  expected: 1.0

invariant theseus_difflib.close_matches:
  description: "get_close_matches('appel', ['ape','apple','peach']) includes 'apple'"
  category: close_matches
  kind: python_call_eq
  function: difflib_close_matches_has_apple
  args: []
  expected: true

invariant theseus_difflib.ratio_different:
  description: "ratio of 'abc' vs 'xyz' < 0.5"
  category: ratio
  kind: python_call_eq
  function: difflib_ratio_different_lt_half
  args: []
  expected: true
