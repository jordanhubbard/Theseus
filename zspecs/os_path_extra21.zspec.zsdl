spec: os_path_extra21
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py, Lib/genericpath.py"
    - "os_path_extra6.zspec.zsdl — covers __qualname__ for join/split/basename/dirname/normpath/abspath/exists/isfile/isdir/isabs."
    - "os_path_extra8.zspec.zsdl — covers expanduser __qualname__."
    - "os_path_extra16.zspec.zsdl — covers __qualname__ for join/split/exists/isfile/isdir/basename/dirname; __module__ for join/split/exists/isfile/isdir/basename/dirname/sameopenfile/samestat/getsize/getatime/getmtime/getctime."
    - "os_path_extra18.zspec.zsdl — covers splitext and normpath __qualname__ and __module__."
    - "os_path_extra19.zspec.zsdl — covers ismount.__qualname__; __module__ for realpath/sameopenfile/samestat/getsize/getatime/getmtime/getctime/lexists/islink/ismount."
    - "os_path_extra20.zspec.zsdl — covers __qualname__/__module__/__len__ for relpath/expandvars/commonpath/commonprefix/samefile/isabs."
  notes:
    - "This spec extends os_path_extra20.zspec.zsdl."
    - "Focus: __qualname__ for getsize/getatime/getmtime/getctime (not covered in any prior spec); lexists.__qualname__; os.path module-level __name__ attribute identity."
    - "os.path.getsize.__qualname__ == 'getsize' — top-level function in genericpath; qualname equals simple name. Verified."
    - "os.path.getatime.__qualname__ == 'getatime' — top-level function in genericpath. Verified."
    - "os.path.getmtime.__qualname__ == 'getmtime' — top-level function in genericpath. Verified."
    - "os.path.getctime.__qualname__ == 'getctime' — top-level function in genericpath. Verified."
    - "os.path.lexists.__qualname__ == 'lexists' — extra19 covers lexists.__module__ but no prior spec covers lexists.__qualname__ as a standalone. Verified."
    - "os.path.getsize.__module__ == 'genericpath' — covered in extra16 for the module axis; __qualname__ axis is novel."
    - "os.path.getatime.__module__ == 'genericpath' — same situation. Verified."
    - "os.path.getmtime.__module__ == 'genericpath' — same situation. Verified."
    - "os.path.getctime.__module__ == 'genericpath' — same situation. Verified."
    - "os.path.__name__ == 'posixpath' — on POSIX, os.path is the posixpath module; its __name__ attribute reflects that. No prior os.path spec covers this module-level attribute."
    - "os.path.__name__.__class__.__name__ == 'str' — module __name__ is a plain string. Novel axis."
    - "os.path.__name__.__len__() == 9 — len('posixpath') == 9. Novel length axis."
    - "os.path.__file__.__class__.__name__ == 'str' — the module __file__ attribute is a str. Novel type-check axis."
    - "len('getsize') == 7, len('getatime') == 8, len('getmtime') == 8, len('getctime') == 8, len('lexists') == 7. All verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ for os.path getsize/getatime/getmtime/getctime/lexists
#
# os_path_extra16 covers __qualname__ for join/split/exists/isfile/isdir/basename/dirname.
# os_path_extra18 covers __qualname__ for splitext/normpath.
# os_path_extra19 covers __qualname__ for ismount.
# os_path_extra20 covers __qualname__ for relpath/expandvars/commonpath/commonprefix/samefile/isabs.
# No prior spec covers __qualname__ for getsize, getatime, getmtime, getctime, or lexists.
# All five are top-level functions — qualname equals the simple function name.
# Verified: getsize='getsize', getatime='getatime', getmtime='getmtime',
#   getctime='getctime', lexists='lexists'.
# ---------------------------------------------------------------------------

table os_path_extra21.stat_function_qualnames:
  description: "__qualname__ for os.path getsize/getatime/getmtime/getctime/lexists — top-level functions in genericpath"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqn21

  columns: [id, function, args, expected]
  rows:
    - [getsize,  getsize.__qualname__.__eq__,  ["getsize"],  true]
    - [getatime, getatime.__qualname__.__eq__, ["getatime"], true]
    - [getmtime, getmtime.__qualname__.__eq__, ["getmtime"], true]
    - [getctime, getctime.__qualname__.__eq__, ["getctime"], true]
    - [lexists,  lexists.__qualname__.__eq__,  ["lexists"],  true]

# ---------------------------------------------------------------------------
# Table: __qualname__ string lengths for getsize/getatime/getmtime/getctime/lexists
#
# No prior os.path spec covers __qualname__.__len__() for any of these functions.
# Length checks provide an independent cross-validation axis.
# Verified: getsize=7, getatime=8, getmtime=8, getctime=8, lexists=7.
# ---------------------------------------------------------------------------

table os_path_extra21.stat_function_qualname_lengths:
  description: "__qualname__.__len__() for os.path getsize/getatime/getmtime/getctime/lexists"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqlen21

  columns: [id, function, args, expected]
  rows:
    - [getsize,  getsize.__qualname__.__len__,  [], 7]
    - [getatime, getatime.__qualname__.__len__, [], 8]
    - [getmtime, getmtime.__qualname__.__len__, [], 8]
    - [getctime, getctime.__qualname__.__len__, [], 8]
    - [lexists,  lexists.__qualname__.__len__,  [], 7]

# ---------------------------------------------------------------------------
# Table: os.path module-level __name__ attribute — value, class, and length
#
# On POSIX, os.path is the posixpath module. Its module-level __name__ is
# 'posixpath' (not 'os.path'). No prior os.path spec covers this module-level
# attribute (as opposed to function __module__ attributes).
# Verified: __name__='posixpath', __class__.__name__='str', __len__()==9.
# ---------------------------------------------------------------------------

table os_path_extra21.module_name_attr:
  description: "os.path module __name__ attribute — value 'posixpath', class 'str', length 9"
  kind: python_call_eq
  category: module_identity
  id_prefix: mna21

  columns: [id, function, args, expected]
  rows:
    - [name_value, __name__.__eq__,                    ["posixpath"], true]
    - [name_class, __name__.__class__.__name__.__eq__,  ["str"],       true]
    - [name_len,   __name__.__len__,                    [],            9]

# ---------------------------------------------------------------------------
# Standalone: os.path.getsize.__qualname__ == 'getsize'
#
# getsize is a top-level function in genericpath.py shared across platforms.
# No prior spec covers getsize.__qualname__ (extra16 covers getsize.__module__,
# extra19 also covers getsize.__module__ from a different namespace).
# Verified: os.path.getsize.__qualname__ == 'getsize'.
# ---------------------------------------------------------------------------

invariant os_path_extra21.getsize.qualname:
  description: "os.path.getsize.__qualname__ == 'getsize' — top-level function in genericpath; qualname equals simple name"
  category: function_identity
  kind: python_call_eq
  function: getsize.__qualname__.__eq__
  args: ["getsize"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: os.path.lexists.__qualname__ == 'lexists'
#
# lexists checks path existence without following symlinks. extra19 covers
# lexists.__module__ == 'genericpath' but no prior spec covers
# lexists.__qualname__ as a standalone invariant.
# Verified: os.path.lexists.__qualname__ == 'lexists'.
# ---------------------------------------------------------------------------

invariant os_path_extra21.lexists.qualname:
  description: "os.path.lexists.__qualname__ == 'lexists' — checks existence without following symlinks; extra19 covers module but not qualname"
  category: function_identity
  kind: python_call_eq
  function: lexists.__qualname__.__eq__
  args: ["lexists"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: os.path.__file__.__class__.__name__ == 'str'
#
# The module-level __file__ attribute contains the filesystem path to the
# posixpath.py source file. As with all Python module __file__ attributes,
# this is a plain str object. No prior os.path spec checks this attribute.
# Verified: os.path.__file__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant os_path_extra21.module.file_is_str:
  description: "os.path.__file__.__class__.__name__ == 'str' — module file path attribute is a Python string"
  category: module_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
