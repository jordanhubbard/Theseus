spec: multiprocessing_extra2551
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/reduction.py"
  notes:
    - "Theme: __reduce__, __reduce_ex__, and __getnewargs__ dict-presence — checking whether multiprocessing classes define their own pickling/serialization protocol in their class __dict__."
    - "multiprocessing.Process: despite spawning new processes (which uses pickling of the target callable and its args), the Process object itself does not define __reduce__, __reduce_ex__, or __getnewargs__ in its class __dict__. Process uses ForkingPickler/reduction module for inter-process object transfer — not class-level pickling dunders. Verified with Python 3.14."
    - "multiprocessing.queues.Queue is a process-safe FIFO backed by a pipe and a feeder thread; the queue handle is shared via multiprocessing.reduction (FD passing), not via __reduce__/__reduce_ex__ in the class __dict__. Verified with Python 3.14."
    - "multiprocessing.queues.SimpleQueue is a lightweight unbuffered queue using a Pipe directly; like Queue it relies on reduction for handle sharing, not class-level pickling protocol dunders. Verified with Python 3.14."
    - "multiprocessing.queues.JoinableQueue extends Queue with a task completion semaphore; it inherits Queue's reduction-based sharing approach and defines no __reduce__, __reduce_ex__, or __getnewargs__ in its own class __dict__. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from multiprocessing.Process __dict__.
# Process spawns OS subprocesses and internally uses ForkingPickler to transfer
# the target callable and arguments — but the Process class itself defines no
# __reduce__, __reduce_ex__, or __getnewargs__ in its own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2551.process_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from multiprocessing.Process __dict__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: mp2551

  columns: [id, function, args, expected]
  rows:
    - ["mp2551-001", multiprocessing.Process.__dict__.__contains__, ["__reduce__"],     false]
    - ["mp2551-002", multiprocessing.Process.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["mp2551-003", multiprocessing.Process.__dict__.__contains__, ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.queues.Queue — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from multiprocessing.queues.Queue __dict__.
# Queue is shared across processes by transferring OS-level file descriptors via
# the multiprocessing.reduction module (ForkingPickler). The Queue class itself
# defines no __reduce__, __reduce_ex__, or __getnewargs__ in its class __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2551.queue_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from multiprocessing.queues.Queue __dict__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: mp2551

  columns: [id, function, args, expected]
  rows:
    - ["mp2551-004", multiprocessing.queues.Queue.__dict__.__contains__, ["__reduce__"],     false]
    - ["mp2551-005", multiprocessing.queues.Queue.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["mp2551-006", multiprocessing.queues.Queue.__dict__.__contains__, ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.queues.SimpleQueue — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from multiprocessing.queues.SimpleQueue __dict__.
# SimpleQueue wraps a raw Pipe connection; cross-process sharing uses reduction
# (FD passing), not class-level pickling protocol dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2551.simple_queue_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from multiprocessing.queues.SimpleQueue __dict__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: mp2551

  columns: [id, function, args, expected]
  rows:
    - ["mp2551-007", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__reduce__"],     false]
    - ["mp2551-008", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["mp2551-009", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 4: multiprocessing.queues.JoinableQueue — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from multiprocessing.queues.JoinableQueue __dict__.
# JoinableQueue extends Queue with task_done() and join() for completion tracking;
# it inherits queue sharing via reduction and defines no pickling dunders itself.
# ---------------------------------------------------------------------------

table multiprocessing_extra2551.joinable_queue_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from multiprocessing.queues.JoinableQueue __dict__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: mp2551

  columns: [id, function, args, expected]
  rows:
    - ["mp2551-010", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__reduce__"],     false]
    - ["mp2551-011", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["mp2551-012", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 5: cross-class parity — __reduce__ absent from Process and all Queue variants
#
# Symmetric cross-check: Process and all three Queue variants all lack __reduce__
# in their own class __dict__. Cross-process communication in multiprocessing uses
# reduction (ForkingPickler) for file descriptor passing, not class-level
# __reduce__ overrides on the IPC primitive classes themselves.
# ---------------------------------------------------------------------------

table multiprocessing_extra2551.cross_class_reduce_parity:
  description: "__reduce__ absent from Process and all Queue variants; cross-process sharing uses reduction, not class __reduce__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: mp2551

  columns: [id, function, args, expected]
  rows:
    - ["mp2551-013", multiprocessing.Process.__dict__.__contains__,              ["__reduce__"], false]
    - ["mp2551-014", multiprocessing.queues.Queue.__dict__.__contains__,         ["__reduce__"], false]
    - ["mp2551-015", multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__reduce__"], false]
    - ["mp2551-016", multiprocessing.queues.JoinableQueue.__dict__.__contains__,  ["__reduce__"], false]

# ---------------------------------------------------------------------------
# Table 6: cross-class parity — __getnewargs__ absent from Process and all Queue variants
#
# __getnewargs__ provides positional arguments to __new__ during unpickling.
# None of the multiprocessing IPC primitives defines this method because they
# are not reconstructed via __new__ + __getnewargs__ during pickling.
# ---------------------------------------------------------------------------

table multiprocessing_extra2551.cross_class_getnewargs_parity:
  description: "__getnewargs__ absent from Process and all Queue variants; no class uses __new__-based pickling reconstruction; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: mp2551

  columns: [id, function, args, expected]
  rows:
    - ["mp2551-017", multiprocessing.Process.__dict__.__contains__,              ["__getnewargs__"], false]
    - ["mp2551-018", multiprocessing.queues.Queue.__dict__.__contains__,         ["__getnewargs__"], false]
    - ["mp2551-019", multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__getnewargs__"], false]
    - ["mp2551-020", multiprocessing.queues.JoinableQueue.__dict__.__contains__,  ["__getnewargs__"], false]
