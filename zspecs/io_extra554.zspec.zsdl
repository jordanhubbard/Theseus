spec: io_extra554
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io.TextIOWrapper method and property identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks that TextIOWrapper exposes expected method names and property descriptors"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra554.textiowrapper_method_names:
  description: "io.TextIOWrapper method __name__ identity — read, write, seek and related methods"
  kind: python_call_eq
  category: method_names
  id_prefix: io554mn

  columns: [id, function, args, expected]
  rows:
    - [io554mn001, io.TextIOWrapper.read.__name__.__eq__,        ["read"],        true]
    - [io554mn002, io.TextIOWrapper.readline.__name__.__eq__,    ["readline"],    true]
    - [io554mn003, io.TextIOWrapper.write.__name__.__eq__,       ["write"],       true]
    - [io554mn004, io.TextIOWrapper.flush.__name__.__eq__,       ["flush"],       true]
    - [io554mn005, io.TextIOWrapper.close.__name__.__eq__,       ["close"],       true]
    - [io554mn006, io.TextIOWrapper.seek.__name__.__eq__,        ["seek"],        true]
    - [io554mn007, io.TextIOWrapper.tell.__name__.__eq__,        ["tell"],        true]
    - [io554mn008, io.TextIOWrapper.readable.__name__.__eq__,    ["readable"],    true]
    - [io554mn009, io.TextIOWrapper.writable.__name__.__eq__,    ["writable"],    true]
    - [io554mn010, io.TextIOWrapper.seekable.__name__.__eq__,    ["seekable"],    true]
    - [io554mn011, io.TextIOWrapper.detach.__name__.__eq__,      ["detach"],      true]
    - [io554mn012, io.TextIOWrapper.reconfigure.__name__.__eq__, ["reconfigure"], true]

table io_extra554.textiowrapper_property_kinds:
  description: "io.TextIOWrapper property descriptor identity — name, mode, encoding are properties"
  kind: python_call_eq
  category: property_identity
  id_prefix: io554pk

  columns: [id, function, args, expected]
  rows:
    - [io554pk001, io.TextIOWrapper.name.__class__.__name__.__eq__,     ["property"], true]
    - [io554pk002, io.TextIOWrapper.mode.__class__.__name__.__eq__,     ["property"], true]
    - [io554pk003, io.TextIOWrapper.encoding.__class__.__name__.__eq__, ["property"], true]
