spec: struct_extra1621
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "struct.Struct is a C extension type from _struct; its class __dict__ does NOT contain '__weakref__'"
    - "struct.error is a pure Python exception class without __slots__; its class __dict__ DOES contain '__weakref__' as a getset_descriptor"
    - "struct.error inherits from Exception; issubclass(struct.error, Exception) is True"
    - "struct.error.__name__ == 'error'; struct.error.__module__ == 'struct'"
    - "struct.calcsize returns the size in bytes for native-order format strings: B=1, H=2, I=4, Q=8, f=4, d=8, s=1, p=1, ?=1, x=1"
    - "The 'L' format (unsigned long) is platform-dependent (4 on 32-bit, 8 on 64-bit) and is not tested here"
    - "All calcsize values below use native byte order (no prefix) and are verified on 64-bit macOS/Darwin"
    - "struct.Struct.__dict__ does NOT contain '__dict__' or '__weakref__'; it is a C type with no Python-level slot support in the type dict"
  created_at: "2026-04-12"
error_model: python_exceptions

table struct_extra1621.struct_no_weakref:
  description: "struct.Struct is a C extension type; its class __dict__ does NOT contain '__weakref__', '__dict__', or '__slots__'"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1621nw

  columns: [id, function, args, expected]
  rows:
    - ["st1621nw001", "struct.Struct.__dict__.__contains__", ["__weakref__"],         false]
    - ["st1621nw002", "struct.Struct.__dict__.__contains__", ["__slots__"],           false]
    - ["st1621nw003", "struct.Struct.__dict__.__contains__", ["__dict__"],            false]
    - ["st1621nw004", "struct.Struct.__dict__.__contains__", ["format"],              true]
    - ["st1621nw005", "struct.Struct.__dict__.__contains__", ["size"],                true]
    - ["st1621nw006", "struct.Struct.__dict__.__contains__", ["pack"],                true]
    - ["st1621nw007", "struct.Struct.__dict__.__contains__", ["unpack"],              true]
    - ["st1621nw008", "struct.Struct.__dict__.__contains__", ["pack_into"],           true]
    - ["st1621nw009", "struct.Struct.__dict__.__contains__", ["unpack_from"],         true]
    - ["st1621nw010", "struct.Struct.__dict__.__contains__", ["iter_unpack"],         true]
    - ["st1621nw011", "struct.Struct.__dict__.__contains__", ["__doc__"],             true]
    - ["st1621nw012", "struct.Struct.__dict__.__contains__", ["__module__"],          true]
    - ["st1621nw013", "struct.Struct.__dict__.__contains__", ["__new__"],             true]
    - ["st1621nw014", "struct.Struct.__dict__.__contains__", ["__init__"],            true]
    - ["st1621nw015", "struct.Struct.__dict__.__contains__", ["__repr__"],            true]
    - ["st1621nw016", "struct.Struct.__name__.__eq__",       ["Struct"],              true]
    - ["st1621nw017", "struct.Struct.__module__.__eq__",     ["_struct"],             true]
    - ["st1621nw018", "struct.Struct.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["st1621nw019", "struct.Struct.__class__.__name__.__eq__",          ["type"],   true]
    - ["st1621nw020", "struct.Struct.__dict__.__contains__", ["__sizeof__"],          true]
    - ["st1621nw021", "struct.Struct.__dict__.__contains__", ["__delattr__"],         true]
    - ["st1621nw022", "struct.Struct.__dict__.__contains__", ["__setattr__"],         true]
    - ["st1621nw023", "struct.Struct.__dict__.__contains__", ["__getattribute__"],    true]
    - ["st1621nw024", "struct.Struct.__dict__.__contains__", ["__reduce__"],          false]
    - ["st1621nw025", "struct.Struct.__dict__.__contains__", ["__iter__"],            false]

table struct_extra1621.struct_error_weakref:
  description: "struct.error is a pure Python exception class without __slots__; its __dict__ DOES contain '__weakref__' as a getset_descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1621ew

  columns: [id, function, args, expected]
  rows:
    - ["st1621ew001", "struct.error.__dict__.__contains__",                    ["__weakref__"],  true]
    - ["st1621ew002", "struct.error.__dict__.__contains__",                    ["__slots__"],    false]
    - ["st1621ew003", "struct.error.__dict__.__contains__",                    ["__dict__"],     false]
    - ["st1621ew004", "struct.error.__dict__.__contains__",                    ["__doc__"],      true]
    - ["st1621ew005", "struct.error.__dict__.__contains__",                    ["__module__"],   true]
    - ["st1621ew006", "type(struct.error.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["st1621ew007", "type(struct.error.__dict__['__doc__']).__name__.__eq__",     ["NoneType"], true]
    - ["st1621ew008", "type(struct.error.__dict__['__module__']).__name__.__eq__",  ["str"],      true]
    - ["st1621ew009", "issubclass(struct.error, Exception).__eq__",            [true],           true]
    - ["st1621ew010", "issubclass(struct.error, OSError).__eq__",              [false],          true]
    - ["st1621ew011", "struct.error.__name__.__eq__",                          ["error"],        true]
    - ["st1621ew012", "struct.error.__module__.__eq__",                        ["struct"],       true]
    - ["st1621ew013", "struct.error.__bases__.__len__",                        [],               1]
    - ["st1621ew014", "struct.error.__class__.__name__.__eq__",                ["type"],         true]
    - ["st1621ew015", "struct.error.__dict__.__class__.__name__.__eq__",       ["mappingproxy"], true]
    - ["st1621ew016", "struct.error.__dict__.__contains__",                    ["args"],         false]
    - ["st1621ew017", "struct.error.__dict__.__contains__",                    ["__init__"],     false]
    - ["st1621ew018", "struct.error.__dict__.__contains__",                    ["__new__"],      false]
    - ["st1621ew019", "struct.error.__dict__.__contains__",                    ["__str__"],      false]
    - ["st1621ew020", "struct.error.__dict__.__contains__",                    ["__repr__"],     false]
    - ["st1621ew021", "struct.error.__dict__.__contains__",                    ["__reduce__"],   false]
    - ["st1621ew022", "struct.error.__dict__.__contains__",                    ["message"],      false]
    - ["st1621ew023", "struct.error.__dict__.__contains__",                    ["errno"],        false]
    - ["st1621ew024", "struct.error.__dict__.__contains__",                    ["strerror"],     false]
    - ["st1621ew025", "struct.error.__bases__.__contains__",                   [Exception],      true]

table struct_extra1621.calcsize_constants:
  description: "struct.calcsize returns the native-order byte size for standard format characters; platform-independent values on 64-bit systems"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1621cs

  columns: [id, function, args, expected]
  rows:
    - ["st1621cs001", "struct.calcsize.__eq__",               [struct.calcsize],  true]
    - ["st1621cs002", "type(struct.calcsize).__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st1621cs003", "struct.calcsize",                      ["B"],              1]
    - ["st1621cs004", "struct.calcsize",                      ["H"],              2]
    - ["st1621cs005", "struct.calcsize",                      ["I"],              4]
    - ["st1621cs006", "struct.calcsize",                      ["Q"],              8]
    - ["st1621cs007", "struct.calcsize",                      ["f"],              4]
    - ["st1621cs008", "struct.calcsize",                      ["d"],              8]
    - ["st1621cs009", "struct.calcsize",                      ["s"],              1]
    - ["st1621cs010", "struct.calcsize",                      ["p"],              1]
    - ["st1621cs011", "struct.calcsize",                      ["?"],              1]
    - ["st1621cs012", "struct.calcsize",                      ["x"],              1]
    - ["st1621cs013", "struct.calcsize",                      [">H"],             2]
    - ["st1621cs014", "struct.calcsize",                      [">I"],             4]
    - ["st1621cs015", "struct.calcsize",                      [">Q"],             8]
    - ["st1621cs016", "struct.calcsize",                      ["!H"],             2]
    - ["st1621cs017", "struct.calcsize",                      ["!I"],             4]
    - ["st1621cs018", "struct.calcsize",                      ["!Q"],             8]
    - ["st1621cs019", "struct.calcsize",                      [">BHI"],           7]
    - ["st1621cs020", "struct.calcsize",                      ["4s"],             4]
    - ["st1621cs021", "struct.calcsize",                      [">f"],             4]
    - ["st1621cs022", "struct.calcsize",                      [">d"],             8]
    - ["st1621cs023", "struct.calcsize.__name__.__eq__",      ["calcsize"],       true]
    - ["st1621cs024", "struct.Struct.__dict__.__contains__",  ["__weakref__"],    false]
    - ["st1621cs025", "struct.error.__dict__.__contains__",   ["__weakref__"],    true]
