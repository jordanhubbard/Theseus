spec: re_extra856
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "re module CPython documentation"
    - "Python standard library re.RegexFlag enum"
  not_derived_from:
    - "any third-party regex library"
  notes:
    - "Covers class name identity of re module flag constants"
    - "All flag constants are instances of re.RegexFlag (IntFlag enum)"
  created_at: "2026-04-12"

table re_extra856.flag_classnames:
  description: "re module flag constants class names"
  kind: python_call_eq
  category: identity
  id_prefix: re856xx
  columns: [id, function, args, expected]
  rows:
    - [re856xx001, re.IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx002, re.MULTILINE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx003, re.DOTALL.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx004, re.VERBOSE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx005, re.ASCII.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx006, re.UNICODE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx007, re.LOCALE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx008, re.I.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx009, re.M.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx010, re.S.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx011, re.X.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re856xx012, re.A.__class__.__name__.__eq__, ["RegexFlag"], true]
