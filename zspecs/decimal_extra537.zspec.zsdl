spec: decimal_extra537
version: ">=3.9"
backend: python_module(decimal)
docs: "Behavioral specs for decimal.Decimal arithmetic and comparison method name identity"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table decimal_extra537.method_name_identity:
  description: "Verify __name__ for decimal.Decimal arithmetic and comparison dunder methods"
  kind: python_call_eq
  category: identity
  id_prefix: mn
  columns: [id, function, args, expected]
  rows:
    - [mn001, decimal.Decimal.__add__.__name__.__eq__, ["__add__"], true]
    - [mn002, decimal.Decimal.__sub__.__name__.__eq__, ["__sub__"], true]
    - [mn003, decimal.Decimal.__mul__.__name__.__eq__, ["__mul__"], true]
    - [mn004, decimal.Decimal.__truediv__.__name__.__eq__, ["__truediv__"], true]
    - [mn005, decimal.Decimal.__floordiv__.__name__.__eq__, ["__floordiv__"], true]
    - [mn006, decimal.Decimal.__mod__.__name__.__eq__, ["__mod__"], true]
    - [mn007, decimal.Decimal.__pow__.__name__.__eq__, ["__pow__"], true]
    - [mn008, decimal.Decimal.__neg__.__name__.__eq__, ["__neg__"], true]
    - [mn009, decimal.Decimal.__pos__.__name__.__eq__, ["__pos__"], true]
    - [mn010, decimal.Decimal.__abs__.__name__.__eq__, ["__abs__"], true]
    - [mn011, decimal.Decimal.__eq__.__name__.__eq__, ["__eq__"], true]
    - [mn012, decimal.Decimal.__lt__.__name__.__eq__, ["__lt__"], true]
    - [mn013, decimal.Decimal.__le__.__name__.__eq__, ["__le__"], true]
    - [mn014, decimal.Decimal.__gt__.__name__.__eq__, ["__gt__"], true]
    - [mn015, decimal.Decimal.__ge__.__name__.__eq__, ["__ge__"], true]
