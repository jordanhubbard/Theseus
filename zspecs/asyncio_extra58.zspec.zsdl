spec: asyncio_extra58
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queue documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio task and future documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec extends asyncio_extra57.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51 — recorded as 'list'; actual value in Python 3.14.3 is 'tuple'), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ (extra/extra2/extra5), Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), BoundedSemaphore/__bases__[0].__qualname__=='Semaphore' (extra53), Condition/__bases__[0].__qualname__=='object' (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') for Queue/Lock/Event/Semaphore/Condition (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), class __weakref__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), Queue/Lock/Event/Semaphore __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), Queue/Lock/Event __subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') (extra57)."
    - "This spec covers (asynciopkg58 namespace): asyncio.__all__.__contains__ membership for key members Queue/Lock/Event/Semaphore/gather/sleep/Task/Future — each returns True because asyncio is a package that re-exports all these names in its __all__ tuple (95 items). asyncio.__package__.__eq__('asyncio') — asyncio is a package (directory with __init__.py at Lib/asyncio/__init__.py); __package__ == 'asyncio'; __len__() == 7. Queue.__doc__.__class__.__name__.__eq__('str') and Lock.__doc__.__class__.__name__.__eq__('str') — Queue and Lock are pure-Python asyncio classes with docstrings; __doc__ is a plain Python str; __class__.__name__ == 'str'. No prior asyncio spec has captured __all__.__contains__ membership checks or __package__.__eq__ as string equality."
    - "asyncio.__all__.__contains__('Queue') returns True. asyncio.__all__ is a tuple of 95 exported names. 'Queue' is one of the exported names; __contains__('Queue') returns True. No prior asyncio spec captured __all__.__contains__ membership checks. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__all__.__contains__('Lock') returns True. 'Lock' is an exported asyncio synchronization primitive in __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__all__.__contains__('Event') returns True. 'Event' is an exported asyncio synchronization primitive in __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__all__.__contains__('Semaphore') returns True. 'Semaphore' is an exported asyncio synchronization primitive in __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__all__.__contains__('gather') returns True. 'gather' is an exported asyncio coroutine utility in __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__all__.__contains__('sleep') returns True. 'sleep' is an exported asyncio coroutine utility in __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__all__.__contains__('Task') returns True. 'Task' is an exported asyncio task class in __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__all__.__contains__('Future') returns True. 'Future' is an exported asyncio future class in __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__package__ == 'asyncio'. asyncio is a package (directory Lib/asyncio/ with __init__.py). For packages, __package__ equals the package name string, which is 'asyncio'. __eq__('asyncio') returns True. __len__() == 7. No prior asyncio spec captured __package__.__eq__ as a string equality check (only __package__ identity mentioned in prior notes). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__doc__.__class__.__name__ == 'str'. Queue is a pure-Python class in Lib/asyncio/queues.py. It has a docstring (non-None); the docstring is a plain Python str object; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True. No prior asyncio spec captured __doc__.__class__.__name__ as a string equality check at this dimension. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__doc__.__class__.__name__ == 'str'. Lock is a pure-Python class in Lib/asyncio/locks.py. It has a docstring; __doc__ is a plain Python str; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.__all__.__contains__ membership checks — extra58
#
# asyncio.__all__ is a tuple of 95 exported names in Python 3.14.3.
# The following key members are all present in __all__:
#   Queue, Lock, Event, Semaphore, gather, sleep, Task, Future
#
# __contains__(name) returns True for each of these members.
# No prior asyncio spec has captured __all__.__contains__ membership checks.
# Extra58 introduces this dimension in the asynciopkg58 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra58.all_contains_members:
  description: "asyncio.__all__.__contains__ membership checks in asynciopkg58 namespace — asyncio.__all__ is a tuple of 95 exported names; Queue/Lock/Event/Semaphore/gather/sleep/Task/Future are all present; __contains__(name) returns True for each; first __all__.__contains__ membership checks in any asyncio spec"
  kind: python_call_eq
  category: membership
  id_prefix: asynciopkg58contains

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     __all__.__contains__, ["Queue"],     true, "asyncio.__all__.__contains__('Queue') == True — 'Queue' is in asyncio.__all__ (95-item tuple); Queue is the FIFO async queue class exported from Lib/asyncio/queues.py; first __all__.__contains__ membership check in any asyncio spec"]
    - [Lock,      __all__.__contains__, ["Lock"],      true, "asyncio.__all__.__contains__('Lock') == True — 'Lock' is in asyncio.__all__; Lock is the asyncio mutex synchronization primitive exported from Lib/asyncio/locks.py"]
    - [Event,     __all__.__contains__, ["Event"],     true, "asyncio.__all__.__contains__('Event') == True — 'Event' is in asyncio.__all__; Event is the asyncio event synchronization primitive exported from Lib/asyncio/locks.py"]
    - [Semaphore, __all__.__contains__, ["Semaphore"], true, "asyncio.__all__.__contains__('Semaphore') == True — 'Semaphore' is in asyncio.__all__; Semaphore is the asyncio counting semaphore exported from Lib/asyncio/locks.py"]
    - [gather,    __all__.__contains__, ["gather"],    true, "asyncio.__all__.__contains__('gather') == True — 'gather' is in asyncio.__all__; gather is the asyncio coroutine aggregation utility exported from Lib/asyncio/tasks.py"]
    - [sleep,     __all__.__contains__, ["sleep"],     true, "asyncio.__all__.__contains__('sleep') == True — 'sleep' is in asyncio.__all__; sleep is the asyncio coroutine delay utility exported from Lib/asyncio/tasks.py"]
    - [Task,      __all__.__contains__, ["Task"],      true, "asyncio.__all__.__contains__('Task') == True — 'Task' is in asyncio.__all__; Task is the asyncio coroutine wrapper class exported from Lib/asyncio/tasks.py"]
    - [Future,    __all__.__contains__, ["Future"],    true, "asyncio.__all__.__contains__('Future') == True — 'Future' is in asyncio.__all__; Future is the asyncio future result holder class exported from Lib/asyncio/futures.py"]

# ---------------------------------------------------------------------------
# asyncio.__package__ identity check — extra58
#
# asyncio is a package (directory Lib/asyncio/ with __init__.py).
# For packages, Python sets __package__ equal to the package name string.
# asyncio.__package__ == 'asyncio'
# __eq__('asyncio') returns True; __len__() == 7.
#
# No prior asyncio spec has captured __package__.__eq__ as a string equality
# check in table form. Extra58 introduces this in the asynciopkg58 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra58.package_identity:
  description: "asyncio.__package__ identity in asynciopkg58 namespace — asyncio is a package (Lib/asyncio/__init__.py); __package__ == 'asyncio'; __eq__('asyncio') returns True; __len__() == 7; first __package__.__eq__ table in any asyncio spec"
  kind: python_call_eq
  category: package_identity
  id_prefix: asynciopkg58pkgid

  columns: [id, function, args, expected, description]
  rows:
    - [pkg_eq,  __package__.__eq__,  ["asyncio"], true, "asyncio.__package__.__eq__('asyncio') == True — asyncio is a package directory (Lib/asyncio/) with __init__.py; for packages __package__ equals the package name string 'asyncio'; first __package__ string equality check in any asyncio spec"]
    - [pkg_len, __package__.__len__, [],          7,    "asyncio.__package__.__len__() == 7 — 'asyncio' has 7 characters (a-s-y-n-c-i-o); cross-check of the package name string length"]

# ---------------------------------------------------------------------------
# asyncio Queue/Lock __doc__.__class__.__name__ — extra58
#
# Queue (Lib/asyncio/queues.py) and Lock (Lib/asyncio/locks.py) are
# pure-Python asyncio classes that both define docstrings.
# The docstring (__doc__) is a plain Python str object.
# str is a built-in type; __class__.__name__ == 'str'.
#
# Queue.__doc__.__class__.__name__.__eq__('str') returns True.
# Lock.__doc__.__class__.__name__.__eq__('str')  returns True.
#
# No prior asyncio spec has captured __doc__.__class__.__name__ as a
# string equality check at this dimension in the asynciopkg58 namespace.
# Extra58 introduces this in the asynciopkg58 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra58.doc_class_name_eq:
  description: "asyncio Queue/Lock __doc__.__class__.__name__ in asynciopkg58 namespace — Queue and Lock are pure-Python classes with docstrings; __doc__ is a plain Python str; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True; novel docstring class check in asynciopkg58 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciopkg58docname

  columns: [id, function, args, expected, description]
  rows:
    - [Queue, Queue.__doc__.__class__.__name__.__eq__, ["str"], true, "asyncio.Queue.__doc__.__class__.__name__ == 'str' — Queue (Lib/asyncio/queues.py) defines a docstring; the docstring is a plain Python str object; str is a built-in type; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True"]
    - [Lock,  Lock.__doc__.__class__.__name__.__eq__,  ["str"], true, "asyncio.Lock.__doc__.__class__.__name__ == 'str' — Lock (Lib/asyncio/locks.py) defines a docstring; the docstring is a plain Python str object; str is a built-in type; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra58
# ---------------------------------------------------------------------------

invariant asyncio_extra58.all_contains_Queue:
  description: "asyncio.__all__.__contains__('Queue') returns True — 'Queue' is in asyncio.__all__ (95-item tuple); Queue is the FIFO async queue class; first __all__.__contains__ membership check in any asyncio spec"
  category: membership
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Queue"]
  expected: true

invariant asyncio_extra58.all_contains_gather:
  description: "asyncio.__all__.__contains__('gather') returns True — 'gather' is in asyncio.__all__; gather is the asyncio coroutine aggregation utility; novel __all__.__contains__ membership check for gather"
  category: membership
  kind: python_call_eq
  function: __all__.__contains__
  args: ["gather"]
  expected: true

invariant asyncio_extra58.all_contains_Task:
  description: "asyncio.__all__.__contains__('Task') returns True — 'Task' is in asyncio.__all__; Task is the asyncio coroutine wrapper class; novel __all__.__contains__ membership check for Task"
  category: membership
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Task"]
  expected: true

invariant asyncio_extra58.package_eq:
  description: "asyncio.__package__.__eq__('asyncio') returns True — asyncio is a package (Lib/asyncio/__init__.py); __package__ == 'asyncio'; first __package__ string equality invariant in any asyncio spec"
  category: package_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra58.Queue_doc_class_name_eq:
  description: "asyncio.Queue.__doc__.__class__.__name__.__eq__('str') returns True — Queue defines a docstring which is a plain Python str; str is a built-in type; __class__.__name__ == 'str'; novel docstring type check for Queue in asynciopkg58 namespace"
  category: class_names
  kind: python_call_eq
  function: Queue.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant asyncio_extra58.Lock_doc_class_name_eq:
  description: "asyncio.Lock.__doc__.__class__.__name__.__eq__('str') returns True — Lock defines a docstring which is a plain Python str; str is a built-in type; __class__.__name__ == 'str'; novel docstring type check for Lock in asynciopkg58 namespace"
  category: class_names
  kind: python_call_eq
  function: Lock.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
