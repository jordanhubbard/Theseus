spec: asyncio_extra37
version: ">=3.11"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-runner.html — asyncio Runner"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/timeouts.py"
  notes:
    - "This spec extends asyncio_extra36.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__() (C extension), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__() == 95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), create_task/run_coroutine_threadsafe __qualname__.__len__(), Queue.__mro__.__len__()==3, BoundedSemaphore.__mro__.__len__()==5, Queue method __qualname__.__len__() tables, wait_for/shield/sleep module/name lengths, timeout class identity, TaskGroup class identity, Task/Future MRO depths and base name lengths, PriorityQueue/LifoQueue/Lock/Semaphore/Condition/Event MRO depths and base name lengths, Queue/Lock/Event method __name__.__len__() tables, Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__() tables, Runner/__name__+__module__+__qualname__ (string equality, extra3/extra6/extra8), TaskGroup/__name__.__len__()==9, TaskGroup/__qualname__.__len__()==9, TaskGroup/__module__.__len__()==18, timeout/__name__.__len__()==7, timeout_at not yet covered as __len__()."
    - "This spec covers: Runner.__name__.__len__()==6; Runner.run.__name__.__len__()==3; Runner.close.__name__.__len__()==5; Runner.get_loop.__name__.__len__()==8; Runner.run.__qualname__.__len__()==10 ('Runner.run'); Runner.close.__qualname__.__len__()==12 ('Runner.close'); Runner.get_loop.__qualname__.__len__()==15 ('Runner.get_loop'); timeout_at.__name__.__len__()==10 ('timeout_at'); timeout_at.__qualname__.__len__()==10 ('timeout_at'); create_task.__name__.__len__()==11 ('create_task'); ensure_future.__name__.__len__()==13 ('ensure_future')."
    - "Runner is a Python 3.11+ context manager class for running async code. Its three main methods are run(), close(), and get_loop(). The short __name__ values are 'run' (3), 'close' (5), and 'get_loop' (8). The __qualname__ values carry the 'Runner.' prefix: 'Runner.run' (10), 'Runner.close' (12), 'Runner.get_loop' (15)."
    - "Runner.__name__.__len__() == 6 — 'Runner' itself is 6 characters. Prior specs (extra3, extra6) covered __name__.__eq__ and __qualname__.__eq__ as string equality checks, but NOT __name__.__len__() as an integer."
    - "timeout_at is a module-level function in asyncio (Python 3.11+) that creates an absolute-deadline Timeout context manager. Its __name__ == 'timeout_at' (10 chars), which equals timeout.__name__.__len__() + 3 (timeout is 7 chars). Both __name__ and __qualname__ equal 'timeout_at' (top-level function, so they match)."
    - "create_task.__name__ == 'create_task' (11 chars); ensure_future.__name__ == 'ensure_future' (13 chars). Prior specs covered create_task/__qualname__.__len__() but not __name__.__len__(). ensure_future was not measured by __name__.__len__() in any prior spec."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Runner method __name__.__len__() — extra37 namespace
#
# Runner (Python 3.11+) defines three key methods:
#   Runner.run.__name__      == 'run'      (3 chars)
#   Runner.close.__name__    == 'close'    (5 chars)
#   Runner.get_loop.__name__ == 'get_loop' (8 chars)
# These short __name__ values do not carry the 'Runner.' prefix; they reflect
# the bare method identifier as defined. Prior specs captured Runner's
# __name__, __module__, and __qualname__ as string equality (extra3, extra6,
# extra8), but no prior spec has measured Runner method __name__.__len__() as
# integer invariants.
# ---------------------------------------------------------------------------

table asyncio_extra37.runner_method_name_lengths:
  description: "asyncio.Runner method __name__.__len__() in extra37 namespace — short names without class prefix"
  kind: python_call_eq
  category: method_names
  id_prefix: runnermethodnamelen37

  columns: [id, function, args, expected, description]
  rows:
    - [run,      Runner.run.__name__.__len__,      [], 3,  "'run' is 3 characters — shortest Runner method name"]
    - [close,    Runner.close.__name__.__len__,    [], 5,  "'close' is 5 characters"]
    - [get_loop, Runner.get_loop.__name__.__len__,  [], 8,  "'get_loop' is 8 characters — longest Runner method short name"]

# ---------------------------------------------------------------------------
# asyncio Runner method __qualname__.__len__() — extra37 namespace
#
# Runner method __qualname__ values carry the 'Runner.' prefix (7 chars):
#   Runner.run.__qualname__      == 'Runner.run'      (10 chars)
#   Runner.close.__qualname__    == 'Runner.close'    (12 chars)
#   Runner.get_loop.__qualname__ == 'Runner.get_loop' (15 chars)
# These are novel integer measurements. The pattern is 'Runner.' (7) + name:
#   7 + 3 = 10 for run; 7 + 5 = 12 for close; 7 + 8 = 15 for get_loop.
# No prior asyncio spec has captured these __qualname__.__len__() values.
# ---------------------------------------------------------------------------

table asyncio_extra37.runner_method_qualname_lengths:
  description: "asyncio.Runner method __qualname__.__len__() in extra37 namespace — qualified names with 'Runner.' prefix"
  kind: python_call_eq
  category: method_names
  id_prefix: runnermethodqnamelen37

  columns: [id, function, args, expected, description]
  rows:
    - [run,      Runner.run.__qualname__.__len__,      [], 10, "'Runner.run' is 10 characters: 'Runner.' (7) + 'run' (3)"]
    - [close,    Runner.close.__qualname__.__len__,    [], 12, "'Runner.close' is 12 characters: 'Runner.' (7) + 'close' (5)"]
    - [get_loop, Runner.get_loop.__qualname__.__len__,  [], 15, "'Runner.get_loop' is 15 characters: 'Runner.' (7) + 'get_loop' (8)"]

# ---------------------------------------------------------------------------
# asyncio top-level function __name__.__len__() — extra37 namespace
#
# Several asyncio top-level functions have not had their __name__.__len__()
# measured as integer invariants in prior specs:
#   timeout_at.__name__    == 'timeout_at'    (10 chars)
#   create_task.__name__   == 'create_task'   (11 chars)
#   ensure_future.__name__ == 'ensure_future' (13 chars)
# timeout_at is 3 chars longer than timeout (7), reflecting the '_at' suffix.
# create_task and ensure_future are both longer than timeout_at; ensure_future
# is the longest at 13 chars.
# timeout_at.__qualname__ == 'timeout_at' (10 chars) — matches __name__ since
# it is a top-level function (no class prefix).
# ---------------------------------------------------------------------------

table asyncio_extra37.toplevel_function_name_lengths:
  description: "asyncio top-level function __name__.__len__() in extra37 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: asyncfuncnamelen37

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_at,    timeout_at.__name__.__len__,    [], 10, "'timeout_at' is 10 characters — 3 more than 'timeout' (7)"]
    - [create_task,   create_task.__name__.__len__,   [], 11, "'create_task' is 11 characters"]
    - [ensure_future, ensure_future.__name__.__len__, [], 13, "'ensure_future' is 13 characters — the longest in this table"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra37
# ---------------------------------------------------------------------------

invariant asyncio_extra37.Runner_name_len:
  description: "asyncio.Runner.__name__.__len__() == 6 — 'Runner' has 6 characters; prior specs verified __name__=='Runner' as a string but not __len__() as an integer"
  category: class_names
  kind: python_call_eq
  function: Runner.__name__.__len__
  args: []
  expected: 6

invariant asyncio_extra37.Runner_get_loop_qualname_len:
  description: "asyncio.Runner.get_loop.__qualname__.__len__() == 15 — 'Runner.get_loop' has 15 characters; the longest Runner method qualname in this spec"
  category: method_names
  kind: python_call_eq
  function: Runner.get_loop.__qualname__.__len__
  args: []
  expected: 15

invariant asyncio_extra37.timeout_at_name_len:
  description: "asyncio.timeout_at.__name__.__len__() == 10 — 'timeout_at' has 10 characters; 3 more than 'timeout' (7) due to the '_at' suffix"
  category: function_names
  kind: python_call_eq
  function: timeout_at.__name__.__len__
  args: []
  expected: 10

invariant asyncio_extra37.ensure_future_name_len:
  description: "asyncio.ensure_future.__name__.__len__() == 13 — 'ensure_future' has 13 characters; longer than create_task (11) by 2 characters"
  category: function_names
  kind: python_call_eq
  function: ensure_future.__name__.__len__
  args: []
  expected: 13
