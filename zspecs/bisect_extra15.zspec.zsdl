spec: bisect_extra15
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl through bisect_extra14.zspec.zsdl."
    - "Prior specs cover: __name__/__module__/__qualname__ for all 6 callables; behavioral vectors."
    - "bisect_extra14 covers __name__ for all 6 callables and bisect_left/bisect_right behavioral vectors."
    - "No prior spec covers __module__ for all 6 bisect callables in a unified table."
    - "No prior spec covers __qualname__ for bisect/insort alias functions standalone."
    - "bisect.bisect.__module__ == '_bisect' — C extension module, bisect is an alias for bisect_right."
    - "bisect.bisect_left.__module__ == '_bisect' — C extension module."
    - "bisect.bisect_right.__module__ == '_bisect' — C extension module."
    - "bisect.insort.__module__ == '_bisect' — C extension module, insort is an alias for insort_right."
    - "bisect.insort_left.__module__ == '_bisect' — C extension module."
    - "bisect.insort_right.__module__ == '_bisect' — C extension module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# bisect alias function __qualname__ standalone invariants
#
# bisect_extra14 covers __name__ for all 6 callables. No prior spec covers
# __qualname__ for bisect or insort (the aliases) as standalone invariants.
# For C builtins, __qualname__ == __name__, so bisect.__qualname__ ==
# 'bisect_right' and insort.__qualname__ == 'insort_right'.
# ---------------------------------------------------------------------------

invariant bisect_extra15.bisect.qualname:
  description: "bisect.bisect.__qualname__ == 'bisect_right' — alias qualname matches aliased function"
  category: function_identity
  kind: python_call_eq
  function: bisect.__qualname__.__eq__
  args: ["bisect_right"]
  expected: true

invariant bisect_extra15.insort.qualname:
  description: "bisect.insort.__qualname__ == 'insort_right' — alias qualname matches aliased function"
  category: function_identity
  kind: python_call_eq
  function: insort.__qualname__.__eq__
  args: ["insort_right"]
  expected: true

invariant bisect_extra15.bisect_left.qualname:
  description: "bisect.bisect_left.__qualname__ == 'bisect_left' — qualname equals name for C builtin"
  category: function_identity
  kind: python_call_eq
  function: bisect_left.__qualname__.__eq__
  args: ["bisect_left"]
  expected: true

invariant bisect_extra15.insort_left.qualname:
  description: "bisect.insort_left.__qualname__ == 'insort_left' — qualname equals name for C builtin"
  category: function_identity
  kind: python_call_eq
  function: insort_left.__qualname__.__eq__
  args: ["insort_left"]
  expected: true

# ---------------------------------------------------------------------------
# bisect function __module__ table — all 6 callables
#
# All 6 bisect callables are implemented in the _bisect C extension.
# Their __module__ is '_bisect' (not 'bisect'). No prior spec covers __module__
# for all 6 in a unified table.
# ---------------------------------------------------------------------------

table bisect_extra15.function_modules:
  description: "__module__ == '_bisect' for all 6 bisect callables — C extension origin"
  kind: python_call_eq
  category: function_metadata
  id_prefix: bmod

  columns: [id, function, args, expected]
  rows:
    - [bisect,       bisect.__module__.__eq__,       ["_bisect"], true]
    - [bisect_left,  bisect_left.__module__.__eq__,  ["_bisect"], true]
    - [bisect_right, bisect_right.__module__.__eq__, ["_bisect"], true]
    - [insort,       insort.__module__.__eq__,       ["_bisect"], true]
    - [insort_left,  insort_left.__module__.__eq__,  ["_bisect"], true]
    - [insort_right, insort_right.__module__.__eq__, ["_bisect"], true]
