spec: json_logic_js
version: ">=2.0.0"
backend: node(json-logic-js)

docs: https://jsonlogic.com

provenance:
  derived_from:
    - "JsonLogic docs — https://jsonlogic.com"
    - "Test vectors verified with json-logic-js via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "json-logic-js source"
  notes:
    - "Build complex rules and apply them to data — JSON-encoded DSL for portable logic across services."
    - "Install: npm install json-logic-js"
    - "v2 CJS; named exports apply / is_logic / truthy / get_operator / get_values / uses_data / add_operation / rm_operation / rule_like."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "apply() returns the rule's result; never throws on malformed rules (returns null)."
  stderr: "null"
  stickiness: "add_operation() / rm_operation() mutate global registry."
  codes: {}

invariant json_logic_js.equality_true:
  description: "apply({'==': [1, 1]}) is true"
  category: rules
  kind: node_chain_eq
  entry: named
  function: apply
  entry_args: [{"==": [1, 1]}]
  chain: []
  expected: true

invariant json_logic_js.inequality_false:
  description: "apply({'==': [1, 2]}) is false"
  category: rules
  kind: node_chain_eq
  entry: named
  function: apply
  entry_args: [{"==": [1, 2]}]
  chain: []
  expected: false

invariant json_logic_js.addition:
  description: "apply({'+': [1, 2]}) is 3"
  category: rules
  kind: node_chain_eq
  entry: named
  function: apply
  entry_args: [{"+": [1, 2]}]
  chain: []
  expected: 3

invariant json_logic_js.subtraction:
  description: "apply({'-': [10, 3]}) is 7"
  category: rules
  kind: node_chain_eq
  entry: named
  function: apply
  entry_args: [{"-": [10, 3]}]
  chain: []
  expected: 7

invariant json_logic_js.var_lookup:
  description: "apply({'var': 'a'}, {a: 5}) returns 5"
  category: rules
  kind: node_chain_eq
  entry: named
  function: apply
  entry_args: [{"var": "a"}, {a: 5}]
  chain: []
  expected: 5

invariant json_logic_js.if_true_branch:
  description: "apply({'if': [true, 'yes', 'no']}) is 'yes'"
  category: rules
  kind: node_chain_eq
  entry: named
  function: apply
  entry_args: [{"if": [true, "yes", "no"]}]
  chain: []
  expected: "yes"

invariant json_logic_js.if_false_branch:
  description: "apply({'if': [false, 'yes', 'no']}) is 'no'"
  category: rules
  kind: node_chain_eq
  entry: named
  function: apply
  entry_args: [{"if": [false, "yes", "no"]}]
  chain: []
  expected: "no"

invariant json_logic_js.is_logic_true:
  description: "is_logic({'==': [1,1]}) is true"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: is_logic
  entry_args: [{"==": [1, 1]}]
  chain: []
  expected: true

invariant json_logic_js.is_logic_false_for_array:
  description: "is_logic([1,2,3]) is false (arrays are not logic)"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: is_logic
  entry_args: [[1, 2, 3]]
  chain: []
  expected: false

invariant json_logic_js.is_logic_false_for_string:
  description: "is_logic('hi') is false"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: is_logic
  entry_args: ["hi"]
  chain: []
  expected: false

invariant json_logic_js.truthy_zero:
  description: "truthy(0) is false"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: truthy
  entry_args: [0]
  chain: []
  expected: false

invariant json_logic_js.truthy_string:
  description: "truthy('hi') is true"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: truthy
  entry_args: ["hi"]
  chain: []
  expected: true
