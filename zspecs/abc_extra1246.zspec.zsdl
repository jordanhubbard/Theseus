spec: abc_extra1246
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc __doc__ class checks for module, ABC, ABCMeta, abstractmethod, get_cache_token, update_abstractmethods"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that abc module and all public names ABC, ABCMeta, abstractmethod, get_cache_token, update_abstractmethods have str __doc__; also checks not NoneType; distinct from extra1231 (__dict__.__contains__ and qualnames), extra1201 (__bases__/__mro__ lengths), extra1216 (ABCMeta.__dict__ members)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1246.module_and_class_doc_is_str:
  description: "abc module __doc__ and public names ABC, ABCMeta, abstractmethod, get_cache_token, update_abstractmethods have str __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: ab1246ms
  columns: [id, function, args, expected]
  rows:
    - [ab1246ms001, abc.__doc__.__class__.__name__.__eq__,                     ["str"], true]
    - [ab1246ms002, abc.ABC.__doc__.__class__.__name__.__eq__,                 ["str"], true]
    - [ab1246ms003, abc.ABCMeta.__doc__.__class__.__name__.__eq__,             ["str"], true]
    - [ab1246ms004, abc.abstractmethod.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [ab1246ms005, abc.get_cache_token.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [ab1246ms006, abc.update_abstractmethods.__doc__.__class__.__name__.__eq__, ["str"], true]

table abc_extra1246.doc_class_not_nonetype:
  description: "abc module and all public name __doc__ class names are NOT NoneType"
  kind: python_call_eq
  category: doc_class
  id_prefix: ab1246nn
  columns: [id, function, args, expected]
  rows:
    - [ab1246nn001, abc.__doc__.__class__.__name__.__eq__,                     ["NoneType"], false]
    - [ab1246nn002, abc.ABC.__doc__.__class__.__name__.__eq__,                 ["NoneType"], false]
    - [ab1246nn003, abc.ABCMeta.__doc__.__class__.__name__.__eq__,             ["NoneType"], false]
    - [ab1246nn004, abc.abstractmethod.__doc__.__class__.__name__.__eq__,      ["NoneType"], false]
    - [ab1246nn005, abc.get_cache_token.__doc__.__class__.__name__.__eq__,     ["NoneType"], false]
    - [ab1246nn006, abc.update_abstractmethods.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [ab1246nn007, abc.__doc__.__class__.__name__.__eq__,                     ["int"],   false]
    - [ab1246nn008, abc.ABC.__doc__.__class__.__name__.__eq__,                 ["int"],   false]
    - [ab1246nn009, abc.ABCMeta.__doc__.__class__.__name__.__eq__,             ["int"],   false]
    - [ab1246nn010, abc.abstractmethod.__doc__.__class__.__name__.__eq__,      ["int"],   false]

table abc_extra1246.abcmeta_doc_class_cross_checks:
  description: "abc.ABCMeta.__doc__ class name is str and cross-check against float, list, dict; also abc.ABC and abc.abstractmethod cross-checks"
  kind: python_call_eq
  category: doc_class
  id_prefix: ab1246xc
  columns: [id, function, args, expected]
  rows:
    - [ab1246xc001, abc.ABCMeta.__doc__.__class__.__name__.__eq__,             ["str"],   true]
    - [ab1246xc002, abc.ABCMeta.__doc__.__class__.__name__.__eq__,             ["float"], false]
    - [ab1246xc003, abc.ABCMeta.__doc__.__class__.__name__.__eq__,             ["list"],  false]
    - [ab1246xc004, abc.ABCMeta.__doc__.__class__.__name__.__eq__,             ["dict"],  false]
    - [ab1246xc005, abc.ABC.__doc__.__class__.__name__.__eq__,                 ["float"], false]
    - [ab1246xc006, abc.ABC.__doc__.__class__.__name__.__eq__,                 ["list"],  false]
    - [ab1246xc007, abc.abstractmethod.__doc__.__class__.__name__.__eq__,      ["float"], false]
    - [ab1246xc008, abc.abstractmethod.__doc__.__class__.__name__.__eq__,      ["list"],  false]
    - [ab1246xc009, abc.get_cache_token.__doc__.__class__.__name__.__eq__,     ["float"], false]
    - [ab1246xc010, abc.update_abstractmethods.__doc__.__class__.__name__.__eq__, ["float"], false]
