spec: functools_extra97
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra96

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra96.zspec.zsdl."
    - "This spec covers: functools object __class__.__name__ identity — which functools exports are C extension types, Python classes, C builtins, or Python functions (Wave 252)."
    - "functools.partial.__class__.__name__ == 'type' — partial is a C extension type in _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.partialmethod.__class__.__name__ == 'type' — partialmethod is a Python class defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cached_property.__class__.__name__ == 'type' — cached_property is a Python class defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C function in _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C function in _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.wraps.__class__.__name__ == 'function' — wraps is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a pure-Python decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a pure-Python decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: C extension types (partial)
#
# Wave 252 theme: functools exports implemented as C extension types.
#
# functools.partial.__class__.__name__.__eq__('type') == True
#
# partial is defined in Modules/_functoolsmodule.c as a PyTypeObject.
# Its __class__ is <class 'type'> so __class__.__name__ == 'type'.
# Prior spec extra96 checked __code__ attributes; this spec (extra97) checks __class__.__name__. New to extra97.
# ---------------------------------------------------------------------------

table functools_extra97.c_extension_types:
  description: "functools.partial __class__.__name__ == 'type'; C extension type in _functoolsmodule.c; wave 252; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsobjclass97

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_name_eq_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is implemented as a C extension type (PyTypeObject) in Modules/_functoolsmodule.c; its metaclass is <class 'type'> so __class__.__name__ is 'type'; str.__eq__('type') returns True; prior spec extra96 checked __code__ attributes; this spec (extra97) checks __class__.__name__; new to extra97"]

# ---------------------------------------------------------------------------
# Table 2: Python classes (partialmethod, cached_property)
#
# Wave 252 theme: functools exports implemented as Python classes.
#
# functools.partialmethod.__class__.__name__.__eq__('type')    == True
# functools.cached_property.__class__.__name__.__eq__('type') == True
#
# Both partialmethod and cached_property are defined in Lib/functools.py using class statements.
# Their metaclass is <class 'type'> so __class__.__name__ == 'type'. New to extra97.
# ---------------------------------------------------------------------------

table functools_extra97.python_classes:
  description: "functools.partialmethod and cached_property __class__.__name__ == 'type'; Python classes in Lib/functools.py; wave 252; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsobjclass97

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_class_name_eq_type,
       "partialmethod.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — partialmethod is a pure-Python class defined in Lib/functools.py using a class statement; its metaclass is <class 'type'>, not a custom metaclass, so __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra97"]
    - [cached_property_class_name_eq_type,
       "cached_property.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a pure-Python class defined in Lib/functools.py using a class statement; its metaclass is <class 'type'>, so __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Table 3: C builtins (reduce, cmp_to_key)
#
# Wave 252 theme: functools exports implemented as C builtin functions.
#
# functools.reduce.__class__.__name__.__eq__('builtin_function_or_method')    == True
# functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True
#
# reduce and cmp_to_key are implemented in C in Modules/_functoolsmodule.c.
# They are exposed as PyCFunction objects whose type is builtin_function_or_method. New to extra97.
# ---------------------------------------------------------------------------

table functools_extra97.c_builtins:
  description: "functools.reduce and cmp_to_key __class__.__name__ == 'builtin_function_or_method'; C functions in _functoolsmodule.c; wave 252; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsobjclass97

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_eq_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is implemented as a PyCFunction in Modules/_functoolsmodule.c; PyCFunction objects have type builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra97"]
    - [cmp_to_key_class_name_eq_builtin,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is implemented as a PyCFunction in Modules/_functoolsmodule.c; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Table 4: Python functions (lru_cache, update_wrapper, wraps, total_ordering, singledispatch)
#
# Wave 252 theme: functools exports implemented as pure-Python functions.
#
# functools.lru_cache.__class__.__name__.__eq__('function')       == True
# functools.update_wrapper.__class__.__name__.__eq__('function')  == True
# functools.wraps.__class__.__name__.__eq__('function')           == True
# functools.total_ordering.__class__.__name__.__eq__('function')  == True
# functools.singledispatch.__class__.__name__.__eq__('function')  == True
#
# All are defined with def statements in Lib/functools.py.
# Their __class__ is <class 'function'> so __class__.__name__ == 'function'. New to extra97.
# ---------------------------------------------------------------------------

table functools_extra97.python_functions:
  description: "lru_cache/update_wrapper/wraps/total_ordering/singledispatch __class__.__name__ == 'function'; pure-Python functions in Lib/functools.py; wave 252; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsobjclass97

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_class_name_eq_function,
       "lru_cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a pure-Python function defined in Lib/functools.py; its __class__ is <class 'function'> so __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [update_wrapper_class_name_eq_function,
       "update_wrapper.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__.__eq__('function') == True — update_wrapper is a pure-Python function defined in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [wraps_class_name_eq_function,
       "wraps.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is a pure-Python convenience decorator defined in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [total_ordering_class_name_eq_function,
       "total_ordering.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a pure-Python class decorator defined in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [singledispatch_class_name_eq_function,
       "singledispatch.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a pure-Python generic function decorator defined in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra97
# ---------------------------------------------------------------------------

invariant functools_extra97.partial_class_name:
  description: "functools.partial.__class__.__name__ == 'type' — partial is implemented as a C extension type in _functoolsmodule.c; wave 252; new to extra97"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra97.reduce_class_name:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C PyCFunction in _functoolsmodule.c; wave 252; new to extra97"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra97.lru_cache_class_name:
  description: "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a pure-Python function in Lib/functools.py; wave 252; new to extra97"
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra97.singledispatch_class_name:
  description: "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a pure-Python decorator in Lib/functools.py; wave 252; new to extra97"
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra97.cmp_to_key_class_name:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C PyCFunction in _functoolsmodule.c; wave 252; new to extra97"
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
