spec: aggregate_error
version: ">=4.0.0"
backend: node(aggregate-error)

docs: https://github.com/sindresorhus/aggregate-error#readme

provenance:
  derived_from:
    - "aggregate-error README — https://github.com/sindresorhus/aggregate-error#readme"
    - "ECMAScript AggregateError proposal"
    - "Test vectors verified with aggregate-error via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "aggregate-error source"
  notes:
    - "Combines multiple Error/string instances into one error whose .message lists each child error and stack."
    - "Install: npm install aggregate-error"
    - "v4 ESM with CJS shim; constructor exposed under .default."
    - ".name is 'AggregateError'; .message contains the full multi-line concatenation; we test .name and properties that are stable."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Constructor; never throws on iterable input."
  stderr: "null"
  stickiness: "Each invariant constructs a fresh AggregateError."
  codes: {}

# Construction with strings
invariant aggregate_error.name_is_AggregateError:
  description: "AggregateError instance has .name === 'AggregateError'"
  category: identity
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [["error 1", "error 2"]]
  chain:
    - {get: name}
  expected: "AggregateError"

invariant aggregate_error.is_error_instance:
  description: "AggregateError instances are Error instances"
  category: identity
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [["error 1"]]
  chain:
    - {get: constructor}
    - {get: name}
  expected: "AggregateError"

# Message starts with newline + indented child
invariant aggregate_error.message_contains_first_error:
  description: ".message contains the first child error's message"
  category: message
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [["error 1", "error 2"]]
  chain:
    - {get: message}
    - {method: includes, args: ["error 1"]}
  expected: true

invariant aggregate_error.message_contains_second_error:
  description: ".message contains the second child error's message"
  category: message
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [["error 1", "error 2"]]
  chain:
    - {get: message}
    - {method: includes, args: ["error 2"]}
  expected: true

# Array of single error
invariant aggregate_error.single_error_message_includes_it:
  description: "Single-error case still includes the message text"
  category: message
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [["lonely error"]]
  chain:
    - {get: message}
    - {method: includes, args: ["lonely error"]}
  expected: true

invariant aggregate_error.single_error_name_is_AggregateError:
  description: "Single-input case still gets .name 'AggregateError'"
  category: identity
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [["one"]]
  chain:
    - {get: name}
  expected: "AggregateError"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:31:14Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
