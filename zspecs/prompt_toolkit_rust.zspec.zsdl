spec: prompt_toolkit_rust
version: ">=3.9"
backend: rust_module(prompt_toolkit_rust)

docs: https://python-prompt-toolkit.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://python-prompt-toolkit.readthedocs.io/en/stable/ — prompt_toolkit docs"
  not_derived_from:
    - "prompt_toolkit source: prompt_toolkit/__init__.py"
  notes:
    - "prompt_toolkit provides interactive command line interface building."
    - "from prompt_toolkit import PromptSession; PromptSession is available."
    - "prompt_toolkit.__version__ is a non-empty string."
    - "prompt_toolkit.formatted_text.HTML is available."
    - "prompt_toolkit.shortcuts.PromptSession.__name__ == 'PromptSession'."
    - "Expose ptk_version_nonempty() -> bool: len(prompt_toolkit.__version__) > 0."
    - "Expose ptk_has_html() -> bool: hasattr(prompt_toolkit.formatted_text, 'HTML')."
    - "Expose ptk_session_name() -> str: prompt_toolkit.shortcuts.PromptSession.__name__."
    - "All test vectors verified against prompt_toolkit 3.0.50."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# ptk_version_nonempty — version non-empty
invariant prompt_toolkit_rust.version.nonempty:
  description: "prompt_toolkit.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: ptk_version_nonempty
  args: []
  expected: true

# ptk_has_html — HTML class present
invariant prompt_toolkit_rust.formatted.has_html:
  description: "prompt_toolkit.formatted_text.HTML is available"
  category: formatted
  kind: python_call_eq
  function: ptk_has_html
  args: []
  expected: true

# ptk_session_name — PromptSession class name
invariant prompt_toolkit_rust.session.class_name:
  description: "PromptSession.__name__ == 'PromptSession'"
  category: session
  kind: python_call_eq
  function: ptk_session_name
  args: []
  expected: "PromptSession"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:58:05Z
