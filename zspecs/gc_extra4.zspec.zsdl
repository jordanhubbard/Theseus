spec: gc_extra4
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends prior gc specs."
    - "Focus: __name__ attributes for gc functions; gc constants and settings."
    - "gc.enable.__name__ == 'enable'."
    - "gc.disable.__name__ == 'disable'."
    - "gc.isenabled().__class__.__name__ == 'bool'."
    - "gc.collect.__name__ == 'collect'."
    - "gc.get_count.__name__ == 'get_count'."
    - "gc.get_threshold.__name__ == 'get_threshold'."
    - "gc.set_threshold.__name__ == 'set_threshold'."
    - "gc.get_objects.__name__ == 'get_objects'."
    - "gc.get_threshold() returns a tuple of 3 ints."
    - "gc.get_count() returns a tuple of 3 ints."
    - "gc.DEBUG_LEAK == gc.DEBUG_COLLECTABLE | gc.DEBUG_UNCOLLECTABLE | gc.DEBUG_SAVEALL."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table gc_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [enable,        enable.__name__.__eq__,        ["enable"],        true]
    - [disable,       disable.__name__.__eq__,       ["disable"],       true]
    - [isenabled,     isenabled.__name__.__eq__,     ["isenabled"],     true]
    - [collect,       collect.__name__.__eq__,       ["collect"],       true]
    - [get_count,     get_count.__name__.__eq__,     ["get_count"],     true]
    - [get_threshold, get_threshold.__name__.__eq__, ["get_threshold"], true]
    - [set_threshold, set_threshold.__name__.__eq__, ["set_threshold"], true]
    - [get_objects,   get_objects.__name__.__eq__,   ["get_objects"],   true]
    - [get_referrers, get_referrers.__name__.__eq__, ["get_referrers"], true]
    - [get_referents, get_referents.__name__.__eq__, ["get_referents"], true]

table gc_extra4.debug_constants:
  kind: python_call_eq
  category: constants
  id_prefix: debug

  columns: [id, function, args, expected]
  rows:
    - [DEBUG_STATS,       DEBUG_STATS.__eq__,       [1],  true]
    - [DEBUG_COLLECTABLE, DEBUG_COLLECTABLE.__eq__, [2],  true]
    - [DEBUG_UNCOLLECTABLE, DEBUG_UNCOLLECTABLE.__eq__, [4], true]
    - [DEBUG_SAVEALL,     DEBUG_SAVEALL.__eq__,     [32], true]

invariant gc_extra4.isenabled.returns_bool:
  description: "gc.isenabled().__class__.__name__ == 'bool'"
  category: isenabled
  kind: python_call_eq
  function: isenabled
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bool"]
  expected: true

invariant gc_extra4.get_threshold.returns_tuple:
  description: "gc.get_threshold().__class__.__name__ == 'tuple'"
  category: get_threshold
  kind: python_call_eq
  function: get_threshold
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["tuple"]
  expected: true

invariant gc_extra4.get_threshold.length_three:
  description: "len(gc.get_threshold()) == 3"
  category: get_threshold
  kind: python_call_eq
  function: get_threshold
  args: []
  method: __len__
  method_args: []
  expected: 3

invariant gc_extra4.get_count.returns_tuple:
  description: "gc.get_count().__class__.__name__ == 'tuple'"
  category: get_count
  kind: python_call_eq
  function: get_count
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["tuple"]
  expected: true

invariant gc_extra4.get_count.length_three:
  description: "len(gc.get_count()) == 3"
  category: get_count
  kind: python_call_eq
  function: get_count
  args: []
  method: __len__
  method_args: []
  expected: 3

invariant gc_extra4.collect.returns_int:
  description: "gc.collect().__class__.__name__ == 'int'"
  category: collect
  kind: python_call_eq
  function: collect
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true
