spec: multiprocessing_extra946
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes:
    - "Checks __module__ attribute for core multiprocessing public API functions"
    - "cpu_count, current_process, active_children are top-level module functions"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra946.process_query_modules:
  description: "multiprocessing process query functions __module__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp946pq
  columns: [id, function, args, expected]
  rows:
    - [mp946pq001, multiprocessing.cpu_count.__module__.__eq__,       ["multiprocessing"], true]
    - [mp946pq002, multiprocessing.current_process.__module__.__eq__, ["multiprocessing"], true]
    - [mp946pq003, multiprocessing.active_children.__module__.__eq__, ["multiprocessing"], true]
    - [mp946pq004, multiprocessing.freeze_support.__module__.__eq__,  ["multiprocessing"], true]
    - [mp946pq005, multiprocessing.cpu_count.__qualname__.__eq__,     ["cpu_count"],       true]
    - [mp946pq006, multiprocessing.current_process.__qualname__.__eq__, ["current_process"], true]

table multiprocessing_extra946.start_method_modules:
  description: "multiprocessing start method functions __module__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp946sm
  columns: [id, function, args, expected]
  rows:
    - [mp946sm001, multiprocessing.set_start_method.__module__.__eq__, ["multiprocessing"], true]
    - [mp946sm002, multiprocessing.get_start_method.__module__.__eq__, ["multiprocessing"], true]
    - [mp946sm003, multiprocessing.get_context.__module__.__eq__,      ["multiprocessing"], true]
    - [mp946sm004, multiprocessing.set_start_method.__qualname__.__eq__, ["set_start_method"], true]
    - [mp946sm005, multiprocessing.get_start_method.__qualname__.__eq__, ["get_start_method"], true]
    - [mp946sm006, multiprocessing.get_context.__qualname__.__eq__,    ["get_context"],     true]

table multiprocessing_extra946.function_class_identity:
  description: "multiprocessing function __class__.__name__ and freeze_support qualname"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp946fc
  columns: [id, function, args, expected]
  rows:
    - [mp946fc001, multiprocessing.cpu_count.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [mp946fc002, multiprocessing.active_children.__class__.__name__.__eq__, ["function"], true]
    - [mp946fc003, multiprocessing.freeze_support.__class__.__name__.__eq__,  ["function"], true]
    - [mp946fc004, multiprocessing.freeze_support.__qualname__.__eq__,        ["freeze_support"], true]
    - [mp946fc005, multiprocessing.active_children.__qualname__.__eq__,       ["active_children"], true]
    - [mp946fc006, multiprocessing.set_start_method.__class__.__name__.__eq__, ["function"], true]
    - [mp946fc007, multiprocessing.get_context.__class__.__name__.__eq__,     ["function"], true]
