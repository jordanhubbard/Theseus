spec: subprocess_extra12
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "This spec extends subprocess.zspec.zsdl and prior extras through subprocess_extra11.zspec.zsdl."
    - "subprocess_extra11 covers: CompletedProcess.__bases__[0].__name__=='object'; CompletedProcess.__mro__[0]/__name__; CompletedProcess.__mro__[1]/__name__; SubprocessError.__bases__[0].__name__=='Exception'; CalledProcessError/__mro__[0]/__name__; TimeoutExpired/__mro__[0]/__name__."
    - "subprocess_extra10 covers: Popen.__mro__[1].__name__=='object'; CalledProcessError/__mro__[4]=='object'; TimeoutExpired/__mro__[4]=='object'; Popen method __module__; Popen.__class__.__name__=='type'; sentinel arithmetic (__mul__, __floordiv__)."
    - "subprocess_extra9 covers: Popen method __qualname__ (communicate/wait/poll/kill/terminate); CalledProcessError/TimeoutExpired/SubprocessError __mro__[3]; PIPE/STDOUT/DEVNULL __neg__(); CompletedProcess.__module__; function __class__.__name__."
    - "subprocess_extra6 covers: __qualname__ for CalledProcessError/TimeoutExpired/SubprocessError/run/call/check_call/check_output/Popen/CompletedProcess."
    - "subprocess_extra3 covers: CompletedProcess/__name__; CalledProcessError/__name__; TimeoutExpired/__name__; SubprocessError/__name__."
    - "No prior spec covers CompletedProcess.check_returncode.__qualname__ == 'CompletedProcess.check_returncode'."
    - "No prior spec covers CompletedProcess.check_returncode.__name__ == 'check_returncode'."
    - "No prior spec covers CompletedProcess.check_returncode.__module__ == 'subprocess'."
    - "No prior spec covers Popen.__enter__.__qualname__ == 'Popen.__enter__' or Popen.__exit__.__qualname__ == 'Popen.__exit__'."
    - "No prior spec covers Popen.__enter__.__module__ or Popen.__exit__.__module__ == 'subprocess'."
    - "No prior spec covers PIPE.__index__() == -1, STDOUT.__index__() == -2, DEVNULL.__index__() == -3."
    - "No prior spec covers PIPE.__pow__(3) == -1 ((-1)**3 == -1), STDOUT.__pow__(3) == -8, DEVNULL.__pow__(3) == -27."
    - "CompletedProcess.check_returncode is the only public instance method on CompletedProcess."
    - "Popen.__enter__/__exit__ implement the context manager protocol, defined in subprocess.py."
    - "PIPE.__index__() returns the integer value for use in C extensions and index operations."
    - "PIPE.__pow__(3) == -1 because (-1)**3 == -1; STDOUT.__pow__(3) == (-2)**3 == -8; DEVNULL.__pow__(3) == (-3)**3 == -27."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CompletedProcess.check_returncode — __qualname__, __name__, __module__
#
# subprocess_extra6 checks CompletedProcess.__qualname__ (the class qualname).
# subprocess_extra9 checks CompletedProcess.__module__ (the class module).
# No prior spec covers the check_returncode method attributes.
# check_returncode is the only public instance method defined on CompletedProcess.
# ---------------------------------------------------------------------------

invariant subprocess_extra12.CompletedProcess.check_returncode_qualname:
  description: "subprocess.CompletedProcess.check_returncode.__qualname__ == 'CompletedProcess.check_returncode'"
  category: method_qualnames
  kind: python_call_eq
  function: CompletedProcess.check_returncode.__qualname__.__eq__
  args: ["CompletedProcess.check_returncode"]
  expected: true

invariant subprocess_extra12.CompletedProcess.check_returncode_name:
  description: "subprocess.CompletedProcess.check_returncode.__name__ == 'check_returncode'"
  category: method_names
  kind: python_call_eq
  function: CompletedProcess.check_returncode.__name__.__eq__
  args: ["check_returncode"]
  expected: true

invariant subprocess_extra12.CompletedProcess.check_returncode_module:
  description: "subprocess.CompletedProcess.check_returncode.__module__ == 'subprocess' — defined in subprocess.py"
  category: method_modules
  kind: python_call_eq
  function: CompletedProcess.check_returncode.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# Popen.__enter__ and Popen.__exit__ — context manager methods
#
# subprocess_extra9 checks communicate/wait/poll/kill/terminate __qualname__.
# subprocess_extra10 checks send_signal.__qualname__ and Popen method __module__.
# No prior spec checks __enter__ or __exit__ qualnames or modules.
# Popen implements the context manager protocol; both methods are in subprocess.py.
# ---------------------------------------------------------------------------

table subprocess_extra12.Popen_context_manager_qualnames:
  description: "Popen.__enter__ and Popen.__exit__ qualnames include the class prefix"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: cmqname

  columns: [id, function, args, expected]
  rows:
    - [enter, Popen.__enter__.__qualname__.__eq__, ["Popen.__enter__"], true]
    - [exit,  Popen.__exit__.__qualname__.__eq__,  ["Popen.__exit__"],  true]

table subprocess_extra12.Popen_context_manager_modules:
  description: "Popen.__enter__ and Popen.__exit__ have __module__ == 'subprocess'"
  kind: python_call_eq
  category: method_modules
  id_prefix: cmmod

  columns: [id, function, args, expected]
  rows:
    - [enter, Popen.__enter__.__module__.__eq__, ["subprocess"], true]
    - [exit,  Popen.__exit__.__module__.__eq__,  ["subprocess"], true]

# ---------------------------------------------------------------------------
# PIPE, STDOUT, DEVNULL — __index__() method
#
# subprocess_extra8 covers __abs__(); subprocess_extra9 covers __neg__();
# subprocess_extra10 covers __mul__(-1) and __floordiv__(3).
# No prior spec covers __index__(), which returns the raw integer for use in
# C extensions and buffer/index operations.
# PIPE.__index__() == -1, STDOUT.__index__() == -2, DEVNULL.__index__() == -3.
# ---------------------------------------------------------------------------

table subprocess_extra12.sentinel_index:
  description: "PIPE/STDOUT/DEVNULL __index__() returns their raw integer values"
  kind: python_call_eq
  category: constants
  id_prefix: idx

  columns: [id, function, args, expected]
  rows:
    - [PIPE,    PIPE.__index__,    [], -1]
    - [STDOUT,  STDOUT.__index__,  [], -2]
    - [DEVNULL, DEVNULL.__index__, [], -3]

# ---------------------------------------------------------------------------
# PIPE, STDOUT, DEVNULL — __pow__(3) cube values
#
# subprocess_extra10 covers PIPE.__mul__(-1) == 1 and DEVNULL.__floordiv__(3) == -1.
# No prior spec covers __pow__(3):
#   PIPE.__pow__(3) == (-1)**3 == -1
#   STDOUT.__pow__(3) == (-2)**3 == -8
#   DEVNULL.__pow__(3) == (-3)**3 == -27
# ---------------------------------------------------------------------------

table subprocess_extra12.sentinel_pow3:
  description: "PIPE/STDOUT/DEVNULL cubed via __pow__(3): -1, -8, -27"
  kind: python_call_eq
  category: constants
  id_prefix: pow3

  columns: [id, function, args, expected]
  rows:
    - [PIPE,    PIPE.__pow__,    [3], -1]
    - [STDOUT,  STDOUT.__pow__,  [3], -8]
    - [DEVNULL, DEVNULL.__pow__, [3], -27]
