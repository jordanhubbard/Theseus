# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__qualname__.__eq__('Struct') — standalone
#
# struct.Struct.pack.__objclass__.__qualname__ is 'Struct'. For a top-level class
# (not nested inside another class), __qualname__ equals __name__. The Struct class
# is a top-level C extension type, so its __qualname__ is simply 'Struct' (6 chars),
# identical to its __name__. This contrasts with nested classes where __qualname__
# would have a 'Outer.Inner' format. extra93 anchors Struct.__qualname__.__eq__
# ('Struct') directly; no prior struct spec anchors pack.__objclass__.__qualname__
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

