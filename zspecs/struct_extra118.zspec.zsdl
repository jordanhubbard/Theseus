  description: "Struct.pack.__objclass__.__name__.__eq__('Struct')==True / Struct.unpack.__objclass__.__name__.__eq__('Struct')==True / Struct.pack.__objclass__.__module__.__eq__('_struct')==True / Struct.pack.__objclass__.__qualname__.__eq__('Struct')==True / Struct.pack_into.__objclass__.__name__.__eq__('Struct')==True — all Struct methods share the same __objclass__ (the Struct class from _struct); __objclass__.__module__ confirms C extension origin; __qualname__ equals __name__ for top-level type; extra93 anchors Struct __module__ and __qualname__ directly but NOT via __objclass__ path; no prior spec anchors __objclass__ for any Struct method; first structobj118 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structobj118

  columns: [id, function, args, expected, description]
  rows:
    - [pack_objclass_name,     "Struct.pack.__objclass__.__name__.__eq__",     ["Struct"],  true, "Struct.pack.__objclass__.__name__ is 'Struct' (6 chars; __objclass__ identifies the defining class; no prior spec anchors __objclass__ path for pack)"]
    - [unpack_objclass_name,   "Struct.unpack.__objclass__.__name__.__eq__",   ["Struct"],  true, "Struct.unpack.__objclass__.__name__ is 'Struct' (same __objclass__ as pack; all five methods share the same defining class; no prior spec anchors __objclass__ for unpack)"]
    - [pack_objclass_module,   "Struct.pack.__objclass__.__module__.__eq__",   ["_struct"], true, "Struct.pack.__objclass__.__module__ is '_struct' (7 chars; confirms Struct class is from the _struct C extension; no prior spec anchors __objclass__.__module__ for pack)"]
    - [pack_objclass_qualname, "Struct.pack.__objclass__.__qualname__.__eq__", ["Struct"],  true, "Struct.pack.__objclass__.__qualname__ is 'Struct' (qualname equals name for top-level type; no nested class prefix; no prior spec anchors __objclass__.__qualname__ for pack)"]
    - [pack_into_objclass,     "Struct.pack_into.__objclass__.__name__.__eq__",["Struct"],  true, "Struct.pack_into.__objclass__.__name__ is 'Struct' (cross-check confirming all Struct methods share the same __objclass__; no prior spec anchors __objclass__ for pack_into)"]

