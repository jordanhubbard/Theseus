spec: struct_extra118
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra117.zspec.zsdl — covers Struct.__hash__/__eq__ qualnames and bare names / Struct.__doc__.__class__.__module__.__eq__('builtins') (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__() (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__() (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__ (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra117; it does NOT duplicate invariants present in those files."
    - "Wave 284 theme: Struct method __objclass__ identity — pack/unpack/pack_into/unpack_from/iter_unpack __objclass__.__name__.__eq__('Struct') / __objclass__.__module__.__eq__('_struct') / __objclass__.__qualname__.__eq__('Struct') / pack and unpack_from __class__.__name__.__len__()==17."
    - "struct.Struct.pack.__objclass__.__name__ == 'Struct'. All five Struct methods share the same __objclass__ (the Struct class itself). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__objclass__.__module__ == '_struct'. The __objclass__ is the Struct class from the _struct C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__objclass__.__qualname__ == 'Struct'. The qualname equals the name for this top-level C extension type (no nested class prefix). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__class__.__name__.__len__() == 17. len('method_descriptor')==17. The Struct methods are method_descriptor objects. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The __objclass__ attribute of a method_descriptor identifies the class that defines the method. For all five Struct methods (pack, unpack, pack_into, unpack_from, iter_unpack), __objclass__ is the Struct class itself, with __name__=='Struct' (6 chars), __qualname__=='Struct' (6 chars), and __module__=='_struct' (7 chars). The __objclass__.__module__=='_struct' confirms the C extension origin. len('method_descriptor')==17 chars — the same length as 'getset_descriptor' (a coincidence across different C descriptor types). All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.unpack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.pack.__objclass__.__module__.__eq__('_struct')
# struct.Struct.pack.__objclass__.__qualname__.__eq__('Struct')
# struct.Struct.pack_into.__objclass__.__name__.__eq__('Struct')
#
# Wave 284 theme: Struct method __objclass__ name, module, and qualname.
#
# The __objclass__ attribute of a method_descriptor is the class that defines the method.
# For all five Struct methods, __objclass__ is the Struct class from the _struct C
# extension. Struct.__name__ is 'Struct' (6 chars), __qualname__ is 'Struct' (6 chars
# — same as __name__ for a top-level type), and __module__ is '_struct' (7 chars).
# extra93 anchors Struct.__module__.__eq__('_struct') and Struct.__qualname__.__eq__
# ('Struct'); no prior struct spec anchors the __objclass__ attribute path for any
# Struct method under structobj118. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

