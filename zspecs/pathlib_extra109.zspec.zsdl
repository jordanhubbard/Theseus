spec: pathlib_extra109
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra99

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra99.zspec.zsdl."
    - "This spec covers: pathlib class __qualname__ values and lengths for all public pathlib classes."
    - "pathlib.PurePath.__qualname__ = 'PurePath' (length 8)."
    - "pathlib.PurePosixPath.__qualname__ = 'PurePosixPath' (length 13)."
    - "pathlib.PureWindowsPath.__qualname__ = 'PureWindowsPath' (length 15)."
    - "pathlib.Path.__qualname__ = 'Path' (length 4)."
    - "pathlib.PosixPath.__qualname__ = 'PosixPath' (length 9)."
    - "pathlib.WindowsPath.__qualname__ = 'WindowsPath' (length 11)."
    - "For all pathlib classes defined at module level, __qualname__ == __name__ (no nested class scoping)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath, PurePosixPath, PureWindowsPath __qualname__ values
# PurePath.__qualname__ = 'PurePath' (length 8).
# PurePosixPath.__qualname__ = 'PurePosixPath' (length 13).
# PureWindowsPath.__qualname__ = 'PureWindowsPath' (length 15).
# ---------------------------------------------------------------------------

table pathlib_extra109.pure_path_qualnames:
  description: "pathlib pure path class __qualname__ values: PurePath='PurePath'(8), PurePosixPath='PurePosixPath'(13), PureWindowsPath='PureWindowsPath'(15)"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibqualname109

  columns: [id, function, args, expected, description]
  rows:
    - [pp_qname_eq,    PurePath.__qualname__.__eq__,         ["PurePath"],        true,  "pathlib.PurePath.__qualname__ == 'PurePath'"]
    - [pp_qname_len,   PurePath.__qualname__.__len__,        [],                  8,     "pathlib.PurePath.__qualname__.__len__() == 8 ('PurePath' has 8 characters)"]
    - [ppp_qname_eq,   PurePosixPath.__qualname__.__eq__,    ["PurePosixPath"],   true,  "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath'"]
    - [ppp_qname_len,  PurePosixPath.__qualname__.__len__,   [],                 13,     "pathlib.PurePosixPath.__qualname__.__len__() == 13 ('PurePosixPath' has 13 characters)"]
    - [pwp_qname_eq,   PureWindowsPath.__qualname__.__eq__,  ["PureWindowsPath"], true,  "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath'"]
    - [pwp_qname_len,  PureWindowsPath.__qualname__.__len__, [],                 15,     "pathlib.PureWindowsPath.__qualname__.__len__() == 15 ('PureWindowsPath' has 15 characters)"]
    - [pp_qname_not,   PurePath.__qualname__.__eq__,         ["pathlib.PurePath"],false,  "pathlib.PurePath.__qualname__ != 'pathlib.PurePath' (no module prefix in __qualname__)"]

# ---------------------------------------------------------------------------
# pathlib.Path, PosixPath, WindowsPath __qualname__ values
# Path.__qualname__ = 'Path' (length 4).
# PosixPath.__qualname__ = 'PosixPath' (length 9).
# WindowsPath.__qualname__ = 'WindowsPath' (length 11).
# ---------------------------------------------------------------------------

table pathlib_extra109.concrete_path_qualnames:
  description: "pathlib concrete path class __qualname__ values: Path='Path'(4), PosixPath='PosixPath'(9), WindowsPath='WindowsPath'(11)"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibqualname109

  columns: [id, function, args, expected, description]
  rows:
    - [path_qname_eq,    Path.__qualname__.__eq__,         ["Path"],        true,  "pathlib.Path.__qualname__ == 'Path'"]
    - [path_qname_len,   Path.__qualname__.__len__,        [],              4,     "pathlib.Path.__qualname__.__len__() == 4 ('Path' has 4 characters)"]
    - [posixp_qname_eq,  PosixPath.__qualname__.__eq__,    ["PosixPath"],   true,  "pathlib.PosixPath.__qualname__ == 'PosixPath'"]
    - [posixp_qname_len, PosixPath.__qualname__.__len__,   [],              9,     "pathlib.PosixPath.__qualname__.__len__() == 9 ('PosixPath' has 9 characters)"]
    - [winp_qname_eq,    WindowsPath.__qualname__.__eq__,  ["WindowsPath"], true,  "pathlib.WindowsPath.__qualname__ == 'WindowsPath'"]
    - [winp_qname_len,   WindowsPath.__qualname__.__len__, [],             11,     "pathlib.WindowsPath.__qualname__.__len__() == 11 ('WindowsPath' has 11 characters)"]
    - [path_qname_not,   Path.__qualname__.__eq__,         ["PurePath"],   false,  "pathlib.Path.__qualname__ != 'PurePath' (Path and PurePath are distinct classes)"]
    - [posixp_not_win,   PosixPath.__qualname__.__eq__,    ["WindowsPath"],false,  "pathlib.PosixPath.__qualname__ != 'WindowsPath' (PosixPath and WindowsPath are distinct classes)"]
    - [pwp_longer_ppp,   PureWindowsPath.__qualname__.__len__,[], 15,            "pathlib.PureWindowsPath.__qualname__.__len__() == 15 (longer than PurePosixPath at 13)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra109.PurePath.qualname_is_PurePath:
  description: "pathlib.PurePath.__qualname__ == 'PurePath' (for module-level classes, __qualname__ equals the bare class name with no enclosing scope prefix)"
  category: class_names
  kind: python_call_eq
  function: PurePath.__qualname__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra109.PurePath.qualname_len_8:
  description: "pathlib.PurePath.__qualname__.__len__() == 8 ('PurePath' has 8 characters: P-u-r-e-P-a-t-h)"
  category: class_names
  kind: python_call_eq
  function: PurePath.__qualname__.__len__
  args: []
  expected: 8

invariant pathlib_extra109.Path.qualname_len_4:
  description: "pathlib.Path.__qualname__.__len__() == 4 ('Path' has 4 characters, making it the shortest __qualname__ among public pathlib classes)"
  category: class_names
  kind: python_call_eq
  function: Path.__qualname__.__len__
  args: []
  expected: 4

invariant pathlib_extra109.PureWindowsPath.qualname_len_15:
  description: "pathlib.PureWindowsPath.__qualname__.__len__() == 15 ('PureWindowsPath' has 15 characters, making it the longest __qualname__ among public pathlib classes)"
  category: class_names
  kind: python_call_eq
  function: PureWindowsPath.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra109.WindowsPath.qualname_is_WindowsPath:
  description: "pathlib.WindowsPath.__qualname__ == 'WindowsPath' (class attributes including __qualname__ are accessible on all platforms even though instantiation raises NotImplementedError on non-Windows)"
  category: class_names
  kind: python_call_eq
  function: WindowsPath.__qualname__.__eq__
  args: ["WindowsPath"]
  expected: true

