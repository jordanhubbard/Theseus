spec: fnmatch_extra_rust
version: ">=3.9"
backend: rust_module(fnmatch_extra_rust)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — fnmatch stdlib"
  notes:
    - "fnmatch provides Unix filename pattern matching."
    - "fnmatch.fnmatch('hello.py', '*.py') is True."
    - "fnmatch.fnmatch('hello.txt', '*.py') is False."
    - "fnmatch.filter(['a.py','b.txt','c.py'], '*.py') == ['a.py','c.py']."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant fnmatch_extra_rust.match_py:
  description: "fnmatch.fnmatch('hello.py', '*.py') is True"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch_extra_match_py
  args: []
  expected: true

invariant fnmatch_extra_rust.no_match_txt:
  description: "fnmatch.fnmatch('hello.txt', '*.py') is False"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch_extra_no_match_txt
  args: []
  expected: false

invariant fnmatch_extra_rust.filter_py_files:
  description: "fnmatch.filter(['a.py','b.txt','c.py'], '*.py') == ['a.py','c.py']"
  category: filter
  kind: python_call_eq
  function: fnmatch_extra_filter_py_files
  args: []
  expected: ["a.py", "c.py"]

