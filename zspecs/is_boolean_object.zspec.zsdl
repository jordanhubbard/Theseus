spec: is_boolean_object
version: ">=1.2.2"
backend: node(is-boolean-object)

docs: https://www.npmjs.com/package/is-boolean-object

provenance:
  derived_from:
    - "is-boolean-object README — https://www.npmjs.com/package/is-boolean-object"
    - "Test vectors verified with is-boolean-object via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-boolean-object source"
  notes:
    - "is-boolean-object is an npm package. Install: npm install is-boolean-object"
    - "Returns true for boolean primitives and Boolean objects."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_boolean_object.isBoolean:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: isboolobj

  columns: [id, args, expected]
  rows:
    - [prim_true,  [true],  true]
    - [prim_false, [false], true]
    - [number_1,   [1],     false]
    - [string,     ["foo"], false]
