spec: socket_extra1156
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.error/timeout/herror/gaierror __name__/__qualname__/__module__, socket.socket __name__/__qualname__/__module__/__class__.__name__ and __init__/__repr__ attrs, socket.herror/gaierror __weakref__ class attrs, socket.SOCK_DGRAM/AF_INET6 SocketKind/AddressFamily class attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1156.exception_class_name_qualname_module:
  description: "socket.error, timeout, herror, gaierror __name__/__qualname__/__module__ identity"
  kind: python_call_eq
  category: exception_class_name_qualname_module
  id_prefix: sk1156ex
  columns: [id, function, args, expected]
  rows:
    - [sk1156ex001, socket.error.__name__.__eq__,                               ["OSError"],           true]
    - [sk1156ex002, socket.error.__qualname__.__eq__,                           ["OSError"],           true]
    - [sk1156ex003, socket.error.__module__.__eq__,                             ["builtins"],          true]
    - [sk1156ex004, socket.timeout.__name__.__eq__,                             ["TimeoutError"],      true]
    - [sk1156ex005, socket.timeout.__qualname__.__eq__,                         ["TimeoutError"],      true]
    - [sk1156ex006, socket.timeout.__module__.__eq__,                           ["builtins"],          true]
    - [sk1156ex007, socket.herror.__name__.__eq__,                              ["herror"],            true]
    - [sk1156ex008, socket.herror.__qualname__.__eq__,                          ["herror"],            true]
    - [sk1156ex009, socket.herror.__module__.__eq__,                            ["socket"],            true]
    - [sk1156ex010, socket.gaierror.__name__.__eq__,                            ["gaierror"],          true]
    - [sk1156ex011, socket.gaierror.__qualname__.__eq__,                        ["gaierror"],          true]
    - [sk1156ex012, socket.gaierror.__module__.__eq__,                          ["socket"],            true]
    - [sk1156ex013, socket.herror.__module__.__class__.__name__.__eq__,         ["str"],               true]
    - [sk1156ex014, socket.gaierror.__module__.__class__.__name__.__eq__,       ["str"],               true]

table socket_extra1156.socket_class_identity_and_init_repr:
  description: "socket.socket __name__/__qualname__/__module__/__class__.__name__ and __init__/__repr__ attrs"
  kind: python_call_eq
  category: socket_class_identity_init_repr
  id_prefix: sk1156si
  columns: [id, function, args, expected]
  rows:
    - [sk1156si001, socket.socket.__name__.__eq__,                              ["socket"],                 true]
    - [sk1156si002, socket.socket.__qualname__.__eq__,                          ["socket"],                 true]
    - [sk1156si003, socket.socket.__module__.__eq__,                            ["socket"],                 true]
    - [sk1156si004, socket.socket.__class__.__name__.__eq__,                    ["type"],                   true]
    - [sk1156si005, socket.socket.__module__.__class__.__name__.__eq__,         ["str"],                    true]
    - [sk1156si006, socket.socket.__init__.__qualname__.__eq__,                 ["socket.__init__"],        true]
    - [sk1156si007, socket.socket.__init__.__class__.__name__.__eq__,           ["function"],               true]
    - [sk1156si008, socket.socket.__repr__.__qualname__.__eq__,                 ["socket.__repr__"],        true]
    - [sk1156si009, socket.socket.__repr__.__class__.__name__.__eq__,           ["function"],               true]

table socket_extra1156.herror_gaierror_weakref_and_enum_subclasses:
  description: "socket.herror/gaierror __weakref__ class attrs and SOCK_DGRAM/AF_INET6 enum subclass attrs"
  kind: python_call_eq
  category: herror_gaierror_weakref_enum_subclasses
  id_prefix: sk1156we
  columns: [id, function, args, expected]
  rows:
    - [sk1156we001, socket.herror.__weakref__.__class__.__name__.__eq__,        ["getset_descriptor"],  true]
    - [sk1156we002, socket.herror.__weakref__.__class__.__qualname__.__eq__,    ["getset_descriptor"],  true]
    - [sk1156we003, socket.herror.__weakref__.__class__.__module__.__eq__,      ["builtins"],           true]
    - [sk1156we004, socket.herror.__weakref__.__qualname__.__eq__,              ["herror.__weakref__"], true]
    - [sk1156we005, socket.gaierror.__weakref__.__class__.__name__.__eq__,      ["getset_descriptor"],  true]
    - [sk1156we006, socket.gaierror.__weakref__.__qualname__.__eq__,            ["gaierror.__weakref__"], true]
    - [sk1156we007, socket.SOCK_DGRAM.__class__.__name__.__eq__,                ["SocketKind"],         true]
    - [sk1156we008, socket.SOCK_DGRAM.__class__.__qualname__.__eq__,            ["SocketKind"],         true]
    - [sk1156we009, socket.SOCK_DGRAM.__class__.__module__.__eq__,              ["socket"],             true]
    - [sk1156we010, socket.AF_INET6.__class__.__name__.__eq__,                  ["AddressFamily"],      true]
    - [sk1156we011, socket.AF_INET6.__class__.__qualname__.__eq__,              ["AddressFamily"],      true]
    - [sk1156we012, socket.AF_INET6.__class__.__module__.__eq__,                ["socket"],             true]
