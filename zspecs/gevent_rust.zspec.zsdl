spec: gevent_rust
version: ">=3.9"
backend: rust_module(gevent_rust)

docs: https://www.gevent.org/api/

provenance:
  derived_from:
    - "https://www.gevent.org/api/ — gevent documentation"
  not_derived_from:
    - "gevent source: gevent/__init__.py"
  notes:
    - "gevent is a coroutine-based Python networking library."
    - "gevent.spawn is available."
    - "gevent.sleep is available."
    - "gevent.__version__ is a non-empty string."
    - "gevent.Greenlet is available."
    - "Expose gevent_has_spawn() -> bool: hasattr(gevent, 'spawn')."
    - "Expose gevent_has_greenlet() -> bool: hasattr(gevent, 'Greenlet')."
    - "Expose gevent_version_nonempty() -> bool: len(gevent.__version__) > 0."
    - "All test vectors verified against gevent 25.4.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# gevent_has_spawn — spawn present
invariant gevent_rust.module.has_spawn:
  description: "gevent.spawn is available"
  category: module
  kind: python_call_eq
  function: gevent_has_spawn
  args: []
  expected: true

# gevent_has_greenlet — Greenlet present
invariant gevent_rust.module.has_greenlet:
  description: "gevent.Greenlet is available"
  category: module
  kind: python_call_eq
  function: gevent_has_greenlet
  args: []
  expected: true

# gevent_version_nonempty — version non-empty
invariant gevent_rust.version.nonempty:
  description: "gevent.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: gevent_version_nonempty
  args: []
  expected: true

