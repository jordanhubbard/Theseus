spec: os_extra4
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/os.py"
    - "CPython source: Modules/posixmodule.c"
  notes:
    - "Extends os.zspec.zsdl, os_extra.zspec.zsdl, os_extra2.zspec.zsdl, os_extra3.zspec.zsdl."
    - "os.zspec.zsdl covers: O_RDONLY/O_WRONLY/O_RDWR values, extsep/curdir/pardir values, sep/pathsep length, name=='posix', function names table, getenv, getpid>0, urandom type/len, strerror, getcwd type."
    - "os_extra.zspec.zsdl covers: sep/linesep/pathsep class names, curdir/pardir/extsep values, name class name, getcwd/getpid/cpu_count class names, getpid positive, urandom class name and length."
    - "os_extra2.zspec.zsdl covers: devnull/sep/linesep class names, curdir/pardir/extsep values, altsep is NoneType, getcwd/listdir/makedirs function names."
    - "os_extra3.zspec.zsdl covers: O_RDONLY/O_WRONLY/O_RDWR type checks as ints, F_OK/R_OK/W_OK/X_OK values and type checks, SEEK_SET/SEEK_CUR/SEEK_END values and type checks, DEVNULL class name and nonempty."
    - "This spec adds: os.SEEK_SET/SEEK_CUR/SEEK_END value assertions as standalone named invariants (additional anchors), os.error class identity, os.error base class name, os.strerror(0) return type, os.times() class name, os.uname() class name, os.stat_result class name, os.DirEntry class name."
    - "os.error is an alias for OSError; os.error.__name__ == 'OSError' because it is the same object."
    - "os.error.__bases__[0].__name__ == 'Exception' — OSError inherits directly from Exception."
    - "os.strerror(0) returns the human-readable message for errno 0 ('Success' on Linux/macOS); its type is always str."
    - "os.times() returns a named tuple of type 'times_result' containing CPU time fields."
    - "os.uname() returns a named tuple of type 'uname_result' containing OS identification fields (POSIX only)."
    - "os.stat_result.__name__ == 'stat_result' — the class name of the object returned by os.stat()."
    - "os.DirEntry.__name__ == 'DirEntry' — the class used for entries yielded by os.scandir()."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Seek constants — additional named anchors
#
# os_extra3.zspec.zsdl already covers SEEK_SET/SEEK_CUR/SEEK_END values and
# type checks. This spec provides independent named invariants under os_extra4
# namespace for cross-spec anchoring and completeness.
# ---------------------------------------------------------------------------

invariant os_extra4.SEEK_SET.value:
  description: "os.SEEK_SET == 0 — seek from beginning of file (POSIX lseek constant)"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant os_extra4.SEEK_CUR.value:
  description: "os.SEEK_CUR == 1 — seek from current file position (POSIX lseek constant)"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant os_extra4.SEEK_END.value:
  description: "os.SEEK_END == 2 — seek from end of file (POSIX lseek constant)"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# os.error — class identity
#
# os.error is an alias for the built-in OSError class.
# Its __name__ attribute reflects the canonical class name 'OSError'.
# ---------------------------------------------------------------------------

invariant os_extra4.error.class_name:
  description: "os.error.__name__ == 'OSError' — os.error is an alias for the built-in OSError"
  category: error_class
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant os_extra4.error.base_class_name:
  description: "os.error.__bases__[0].__name__ == 'Exception' — OSError inherits from Exception"
  category: error_class
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# os.strerror — return type
#
# os.strerror(errno) translates an error code to a human-readable string.
# strerror(0) is always valid on POSIX; its return type is always str.
# ---------------------------------------------------------------------------

invariant os_extra4.strerror.return_type:
  description: "os.strerror(0).__class__.__name__ == 'str' — strerror always returns a str"
  category: strerror
  kind: python_call_eq
  function: strerror
  args: [0]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os.times() — result class name
#
# os.times() returns system and user CPU times as a named tuple.
# The class name of the result is 'times_result' on all POSIX platforms.
# ---------------------------------------------------------------------------

invariant os_extra4.times.class_name:
  description: "os.times().__class__.__name__ == 'times_result'"
  category: times_result
  kind: python_call_eq
  function: times
  args: []
  method: __class__.__name__.__eq__
  method_args: ["times_result"]
  expected: true

# ---------------------------------------------------------------------------
# os.uname() — result class name
#
# os.uname() returns OS identification information as a named tuple.
# The class name of the result is 'uname_result' on all POSIX platforms.
# ---------------------------------------------------------------------------

invariant os_extra4.uname.class_name:
  description: "os.uname().__class__.__name__ == 'uname_result'"
  category: uname_result
  kind: python_call_eq
  function: uname
  args: []
  method: __class__.__name__.__eq__
  method_args: ["uname_result"]
  expected: true

# ---------------------------------------------------------------------------
# os.stat_result — class name
#
# os.stat_result is the type returned by os.stat(). Its __name__ is 'stat_result'.
# ---------------------------------------------------------------------------

invariant os_extra4.stat_result.class_name:
  description: "os.stat_result.__name__ == 'stat_result'"
  category: class_metadata
  kind: python_call_eq
  function: stat_result.__name__.__eq__
  args: ["stat_result"]
  expected: true

invariant os_extra4.stat_result.is_type:
  description: "os.stat_result.__class__.__name__ == 'type' — stat_result is a class object"
  category: class_metadata
  kind: python_call_eq
  function: stat_result.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# os.DirEntry — class name
#
# os.DirEntry is the type yielded by os.scandir(). Its __name__ is 'DirEntry'.
# ---------------------------------------------------------------------------

invariant os_extra4.DirEntry.class_name:
  description: "os.DirEntry.__name__ == 'DirEntry'"
  category: class_metadata
  kind: python_call_eq
  function: DirEntry.__name__.__eq__
  args: ["DirEntry"]
  expected: true

invariant os_extra4.DirEntry.is_type:
  description: "os.DirEntry.__class__.__name__ == 'type' — DirEntry is a class object"
  category: class_metadata
  kind: python_call_eq
  function: DirEntry.__class__.__name__.__eq__
  args: ["type"]
  expected: true
