spec: configparser_extra4
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
    - "configparser.zspec.zsdl — covers __name__ for all public classes and exceptions, DEFAULTSECT value, ConfigParser/RawConfigParser initial state, MRO checks"
    - "configparser_extra.zspec.zsdl — covers ConfigParser/__name__/__module__, RawConfigParser/__name__, Error/__name__, NoSectionError/__name__/__base__, NoOptionError/__name__/__base__, DuplicateSectionError/__name__, InterpolationError/__name__, ConfigParser().sections()==[], DEFAULTSECT=='DEFAULT'"
    - "configparser_extra2.zspec.zsdl — covers __module__ for RawConfigParser/BasicInterpolation/ExtendedInterpolation/Error/NoSectionError/NoOptionError/DuplicateSectionError/ParsingError/MissingSectionHeaderError, exception hierarchy bases, ConfigParser method names, is_type checks, DEFAULTSECT class name"
    - "configparser_extra3.zspec.zsdl — covers __name__ for ConfigParser/RawConfigParser in table, exception __name__ table, DEFAULTSECT value, MAX_INTERPOLATION_DEPTH value, Error base, NoSectionError base, ConfigParser instance class, ConfigParser __module__, RawConfigParser base"
  notes:
    - "This spec adds __qualname__ vectors for all major configparser classes and exceptions."
    - "configparser.ConfigParser.__qualname__ == 'ConfigParser' — top-level class, qualname matches name."
    - "configparser.RawConfigParser.__qualname__ == 'RawConfigParser'."
    - "configparser.SafeConfigParser.__qualname__ == 'SafeConfigParser' — deprecated alias in Python 3.9; removed in Python 3.12."
    - "configparser.BasicInterpolation.__qualname__ == 'BasicInterpolation'."
    - "configparser.ExtendedInterpolation.__qualname__ == 'ExtendedInterpolation'."
    - "configparser.NoSectionError.__qualname__ == 'NoSectionError'."
    - "configparser.NoOptionError.__qualname__ == 'NoOptionError'."
    - "configparser.DuplicateSectionError.__qualname__ == 'DuplicateSectionError'."
    - "configparser.MissingSectionHeaderError.__qualname__ == 'MissingSectionHeaderError'."
    - "configparser.ParsingError.__qualname__ == 'ParsingError'."
    - "configparser.Error.__qualname__ == 'Error'."
    - "All __qualname__ values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — main classes
# Top-level classes have __qualname__ == __name__ (no nesting).
# ---------------------------------------------------------------------------

table configparser_extra4.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [ConfigParser,         ConfigParser.__qualname__.__eq__,         ["ConfigParser"],         true]
    - [RawConfigParser,      RawConfigParser.__qualname__.__eq__,      ["RawConfigParser"],      true]
    - [BasicInterpolation,   BasicInterpolation.__qualname__.__eq__,   ["BasicInterpolation"],   true]
    - [ExtendedInterpolation, ExtendedInterpolation.__qualname__.__eq__, ["ExtendedInterpolation"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — exception classes
# ---------------------------------------------------------------------------

table configparser_extra4.exception_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: excqname

  columns: [id, function, args, expected]
  rows:
    - [Error,                     Error.__qualname__.__eq__,                     ["Error"],                     true]
    - [NoSectionError,            NoSectionError.__qualname__.__eq__,            ["NoSectionError"],            true]
    - [NoOptionError,             NoOptionError.__qualname__.__eq__,             ["NoOptionError"],             true]
    - [DuplicateSectionError,     DuplicateSectionError.__qualname__.__eq__,     ["DuplicateSectionError"],     true]
    - [MissingSectionHeaderError, MissingSectionHeaderError.__qualname__.__eq__, ["MissingSectionHeaderError"], true]
    - [ParsingError,              ParsingError.__qualname__.__eq__,              ["ParsingError"],              true]

# ---------------------------------------------------------------------------
# SafeConfigParser — deprecated alias present in Python 3.9
# (version guard: this attribute was removed in Python 3.12)
# ---------------------------------------------------------------------------

invariant configparser_extra4.SafeConfigParser.qualname:
  description: "configparser.SafeConfigParser.__qualname__ == 'SafeConfigParser' — deprecated alias in Python 3.9"
  category: qualnames
  version: ">=3.9,<3.12"
  kind: python_call_eq
  function: SafeConfigParser.__qualname__.__eq__
  args: ["SafeConfigParser"]
  expected: true

# ---------------------------------------------------------------------------
# InterpolationError __qualname__ — covers the intermediate error class
# not in any prior spec's qualname table
# ---------------------------------------------------------------------------

invariant configparser_extra4.InterpolationError.qualname:
  description: "configparser.InterpolationError.__qualname__ == 'InterpolationError'"
  category: qualnames
  kind: python_call_eq
  function: InterpolationError.__qualname__.__eq__
  args: ["InterpolationError"]
  expected: true

# ---------------------------------------------------------------------------
# DuplicateOptionError __qualname__
# ---------------------------------------------------------------------------

invariant configparser_extra4.DuplicateOptionError.qualname:
  description: "configparser.DuplicateOptionError.__qualname__ == 'DuplicateOptionError'"
  category: qualnames
  kind: python_call_eq
  function: DuplicateOptionError.__qualname__.__eq__
  args: ["DuplicateOptionError"]
  expected: true

# ---------------------------------------------------------------------------
# Confirm __qualname__ == __name__ for ConfigParser (top-level class invariant)
# ---------------------------------------------------------------------------

invariant configparser_extra4.ConfigParser.qualname_eq_name:
  description: "configparser.ConfigParser.__qualname__ == configparser.ConfigParser.__name__ — top-level class"
  category: qualnames
  kind: python_call_eq
  function: ConfigParser.__qualname__.__eq__
  args: ["ConfigParser"]
  expected: true
