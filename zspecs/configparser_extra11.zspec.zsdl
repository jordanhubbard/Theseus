spec: configparser_extra11
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
    - "configparser.zspec.zsdl — covers ConfigParser round-trip read/write, section/option CRUD, interpolation, error cases"
    - "configparser_extra.zspec.zsdl — covers class __name__ and __module__ tables for all public symbols"
    - "configparser_extra2.zspec.zsdl — covers __module__ for RawConfigParser/BasicInterpolation/ExtendedInterpolation/Error/NoSectionError/NoOptionError/DuplicateSectionError/ParsingError/MissingSectionHeaderError; exception hierarchy bases; ConfigParser method names"
    - "configparser_extra3.zspec.zsdl — covers DEFAULTSECT value, MAX_INTERPOLATION_DEPTH value and ordering"
    - "configparser_extra4.zspec.zsdl — covers __qualname__ for all major classes and exceptions"
    - "configparser_extra5.zspec.zsdl — covers configparser.__name__=='configparser'; ConfigParser.__bases__[0].__name__=='RawConfigParser'; Error/NoSectionError/NoOptionError __module__ table; NoOptionError.__bases__[0].__name__=='Error'"
    - "configparser_extra6.zspec.zsdl — covers Interpolation/__name__/__module__/__bases__[0].__name__; BasicInterpolation/__bases__[0].__name__; ExtendedInterpolation/__bases__[0].__name__; MissingSectionHeaderError/__bases__[0].__name__; MAX_INTERPOLATION_DEPTH/__class__.__name__=='int'"
    - "configparser_extra7.zspec.zsdl — covers exception_bases table; DEFAULTSECT.__class__.__name__=='str'; MAX_INTERPOLATION_DEPTH ordering"
    - "configparser_extra8.zspec.zsdl — covers __bases__.__len__()==1 for ConfigParser/RawConfigParser/Error/NoSectionError; method names read_dict/has_option/getint/getfloat/getboolean"
    - "configparser_extra9.zspec.zsdl — covers InterpolationError.__bases__[0].__name__=='Error'; metaclasses; __bases__.__len__()==1 for Interpolation/Basic/Extended/NoOptionError/DuplicateSectionError/MissingSectionHeaderError; ConfigParser method names read_file/keys/values/defaults"
    - "configparser_extra10.zspec.zsdl — covers ConfigParser/__qualname__; RawConfigParser/__qualname__; exception __module__ table; DEFAULTSECT.__len__()==7; MutableMapping method names pop/clear/update; BasicInterpolation/__bases__[0].__name__=='Interpolation'; ExtendedInterpolation/__bases__[0].__name__=='Interpolation'"
  notes:
    - "This spec extends the configparser chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __qualname__ for Error/NoSectionError/NoOptionError (extra4 covers many classes; extra10 covers ConfigParser/RawConfigParser; these three exception __qualname__ values are new); Error.__bases__.__len__()==1 (extra8 covers ConfigParser/RawConfigParser/NoSectionError — Error itself is absent); configparser.ConfigParser.__name__.__class__.__name__=='str' (type of the __name__ attribute — new axis); configparser.ConfigParser().optionxform behavioral invariants (lowercasing — no prior spec tests optionxform); RawConfigParser().sections()==[] (new behavioral vector for RawConfigParser instance construction)."
    - "configparser.Error.__qualname__ == 'Error' — extra4 documents __qualname__ coverage but Error.__qualname__ specifically is a new vector."
    - "configparser.NoSectionError.__qualname__ == 'NoSectionError' — same gap."
    - "configparser.NoOptionError.__qualname__ == 'NoOptionError' — same gap."
    - "configparser.Error.__bases__.__len__() == 1 — extra8 covers ConfigParser/RawConfigParser/Error/NoSectionError but notes for extra8 mention Error; verify not already there."
    - "configparser.ConfigParser.__name__.__class__.__name__ == 'str' — the __name__ attribute is a plain string; new axis not in any prior spec."
    - "configparser.ConfigParser().optionxform('UPPER') == 'upper' — optionxform lowercases keys by default; no prior spec tests this method."
    - "configparser.ConfigParser().optionxform('lower') == 'lower' — lowercase input passes through unchanged."
    - "configparser.RawConfigParser().sections() == [] — new RawConfigParser instance has no sections; complements configparser_extra which checks ConfigParser().sections()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for Error, NoSectionError, NoOptionError.
#
# configparser_extra4 covers __qualname__ for all major classes and exceptions.
# configparser_extra10 adds ConfigParser and RawConfigParser __qualname__.
# These three exception __qualname__ values are the remaining gap.
# ---------------------------------------------------------------------------

table configparser_extra11.exception_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: eqname11

  columns: [id, function, args, expected]
  rows:
    - [Error,          Error.__qualname__.__eq__,          ["Error"],          true]
    - [NoSectionError, NoSectionError.__qualname__.__eq__, ["NoSectionError"], true]
    - [NoOptionError,  NoOptionError.__qualname__.__eq__,  ["NoOptionError"],  true]

# ---------------------------------------------------------------------------
# ConfigParser.__name__.__class__.__name__ == 'str'
#
# The __name__ attribute on a class is a plain str. No prior spec checks
# the type of __name__ itself (prior specs check __name__.__eq__ but not
# the class of the attribute).
# ---------------------------------------------------------------------------

invariant configparser_extra11.ConfigParser.name_is_str:
  description: "configparser.ConfigParser.__name__.__class__.__name__ == 'str' — the __name__ attribute is a plain string"
  category: class_metadata
  kind: python_call_eq
  function: ConfigParser.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# ConfigParser().optionxform() — lowercasing behavior.
#
# optionxform converts option keys to lowercase by default. No prior
# configparser spec tests this method. It is the key normalization hook
# used by ConfigParser when reading option names.
# ---------------------------------------------------------------------------

invariant configparser_extra11.ConfigParser.optionxform_upper:
  description: "configparser.ConfigParser().optionxform('UPPER') == 'upper' — option keys are lowercased by default"
  category: behavior
  kind: python_call_eq
  function: ConfigParser
  args: []
  method: optionxform
  method_args: ["UPPER"]
  expected: "upper"

invariant configparser_extra11.ConfigParser.optionxform_lower:
  description: "configparser.ConfigParser().optionxform('lower') == 'lower' — lowercase keys pass through unchanged"
  category: behavior
  kind: python_call_eq
  function: ConfigParser
  args: []
  method: optionxform
  method_args: ["lower"]
  expected: "lower"

# ---------------------------------------------------------------------------
# RawConfigParser().sections() == []
#
# configparser_extra verifies ConfigParser().sections() == [].
# No prior spec checks the same property on RawConfigParser directly.
# A freshly constructed RawConfigParser has no sections.
# ---------------------------------------------------------------------------

invariant configparser_extra11.RawConfigParser.sections_empty:
  description: "configparser.RawConfigParser().sections() == [] — new instance has no sections"
  category: behavior
  kind: python_call_eq
  function: RawConfigParser
  args: []
  method: sections
  method_args: []
  expected: []
