spec: decimal_extra288
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All decimal.ROUND_* constants are plain str values in Python 3 — isinstance(decimal.ROUND_HALF_EVEN, str) is True."
    - "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN', decimal.ROUND_HALF_UP == 'ROUND_HALF_UP', etc."
    - "decimal.MAX_PREC == 999999999999999999 — the maximum precision for the C decimal implementation; this differs from sys.maxsize."
    - "decimal.MAX_PREC is an int, not sys.maxsize; its value is 999999999999999999 (10^18 - 1)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ROUND_* constants — class name is 'str'
#
# All decimal.ROUND_* rounding constants are plain Python str objects.
# Their __class__.__name__ is 'str', not a special enum or descriptor type.
# ---------------------------------------------------------------------------

invariant decimal_extra288.round_half_even_class_name:
  description: "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — rounding constants are plain str objects"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_HALF_EVEN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# ROUND_* constants — string equality
#
# Each decimal.ROUND_* constant's string value equals its own name.
# These are the canonical rounding mode names used by the decimal module.
# ---------------------------------------------------------------------------

table decimal_extra288.rounding_constants:
  description: "decimal.ROUND_* constants equal their own name strings"
  kind: python_call_eq
  category: constants
  id_prefix: dec288a

  columns: [id, function, args, expected, description]
  rows:
    - [dec288a001, decimal.ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN'"]
    - [dec288a002, decimal.ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'"]
    - [dec288a003, decimal.ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true, "decimal.ROUND_DOWN == 'ROUND_DOWN'"]
    - [dec288a004, decimal.ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true, "decimal.ROUND_CEILING == 'ROUND_CEILING'"]
    - [dec288a005, decimal.ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true, "decimal.ROUND_FLOOR == 'ROUND_FLOOR'"]
    - [dec288a006, decimal.ROUND_UP.__eq__,        ["ROUND_UP"],        true, "decimal.ROUND_UP == 'ROUND_UP'"]
    - [dec288a007, decimal.ROUND_HALF_DOWN.__eq__, ["ROUND_HALF_DOWN"], true, "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN'"]
    - [dec288a008, decimal.ROUND_05UP.__eq__,      ["ROUND_05UP"],      true, "decimal.ROUND_05UP == 'ROUND_05UP'"]

# ---------------------------------------------------------------------------
# decimal.MAX_PREC — maximum precision for the C decimal implementation
#
# decimal.MAX_PREC is the maximum number of significant digits the C decimal
# extension supports. In Python 3.14 on 64-bit systems it is 999999999999999999
# (10^18 - 1). This differs from sys.maxsize (2^63 - 1 = 9223372036854775807).
# ---------------------------------------------------------------------------

invariant decimal_extra288.max_prec_value:
  description: "decimal.MAX_PREC == 999999999999999999 — the C decimal max precision in Python 3.14"
  category: constants
  kind: python_call_eq
  function: decimal.MAX_PREC.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra288.max_prec_class_name:
  description: "decimal.MAX_PREC.__class__.__name__ == 'int' — MAX_PREC is a plain Python integer"
  category: constants
  kind: python_call_eq
  function: decimal.MAX_PREC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — individual rounding constant checks
# ---------------------------------------------------------------------------

invariant decimal_extra288.round_half_up_eq:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — the round-half-up rounding mode constant"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra288.round_down_eq:
  description: "decimal.ROUND_DOWN == 'ROUND_DOWN' — the round-toward-zero rounding mode constant"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_DOWN.__eq__
  args: ["ROUND_DOWN"]
  expected: true

invariant decimal_extra288.round_ceiling_eq:
  description: "decimal.ROUND_CEILING == 'ROUND_CEILING' — the round-toward-positive-infinity rounding mode constant"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_CEILING.__eq__
  args: ["ROUND_CEILING"]
  expected: true

invariant decimal_extra288.round_floor_eq:
  description: "decimal.ROUND_FLOOR == 'ROUND_FLOOR' — the round-toward-negative-infinity rounding mode constant"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_FLOOR.__eq__
  args: ["ROUND_FLOOR"]
  expected: true

invariant decimal_extra288.round_up_eq:
  description: "decimal.ROUND_UP == 'ROUND_UP' — the round-away-from-zero rounding mode constant"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra288.round_half_down_eq:
  description: "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN' — the round-half-toward-zero rounding mode constant"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_HALF_DOWN.__eq__
  args: ["ROUND_HALF_DOWN"]
  expected: true

invariant decimal_extra288.round_05up_eq:
  description: "decimal.ROUND_05UP == 'ROUND_05UP' — the round-zero-or-five-up rounding mode constant"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_05UP.__eq__
  args: ["ROUND_05UP"]
  expected: true
