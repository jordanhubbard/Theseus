spec: inspect_extra1156
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.__package__.__class__.__name__, inspect.__loader__.__class__.__name__, inspect.__all__.__class__.__name__, inspect.Parameter/__module__, inspect.Signature/__module__, inspect.BoundArguments/__module__, inspect.FullArgSpec/__module__, inspect.FrameInfo/__module__ — not covered in _extra1126/_extra1141"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1156.package_loader_all_class_names:
  description: "inspect.__package__, __loader__, and __all__ class name identity"
  kind: python_call_eq
  category: package_loader_all_class_names
  id_prefix: ip1156pl
  columns: [id, function, args, expected]
  rows:
    - [ip1156pl001, inspect.__package__.__class__.__name__.__eq__,                  ["str"],                          true]
    - [ip1156pl002, inspect.__package__.__eq__,                                      ["inspect"],                      true]
    - [ip1156pl003, inspect.__loader__.__class__.__name__.__eq__,                    ["SourceFileLoader"],              true]
    - [ip1156pl004, inspect.__all__.__class__.__name__.__eq__,                       ["list"],                         true]
    - [ip1156pl005, inspect.__all__.__contains__,                                    ["signature"],                    true]
    - [ip1156pl006, inspect.__all__.__contains__,                                    ["Parameter"],                    true]
    - [ip1156pl007, inspect.__all__.__contains__,                                    ["isfunction"],                   true]
    - [ip1156pl008, inspect.__all__.__contains__,                                    ["getmembers"],                   true]

table inspect_extra1156.parameter_signature_bound_arguments_modules:
  description: "inspect.Parameter, Signature, and BoundArguments __module__ identity"
  kind: python_call_eq
  category: parameter_signature_bound_arguments_modules
  id_prefix: ip1156ps
  columns: [id, function, args, expected]
  rows:
    - [ip1156ps001, inspect.Parameter.__module__.__eq__,                             ["inspect"],                      true]
    - [ip1156ps002, inspect.Parameter.__qualname__.__eq__,                           ["Parameter"],                    true]
    - [ip1156ps003, inspect.Parameter.__class__.__name__.__eq__,                     ["type"],                         true]
    - [ip1156ps004, inspect.Parameter.__doc__.__class__.__name__.__eq__,             ["str"],                          true]
    - [ip1156ps005, inspect.Signature.__module__.__eq__,                             ["inspect"],                      true]
    - [ip1156ps006, inspect.Signature.__qualname__.__eq__,                           ["Signature"],                    true]
    - [ip1156ps007, inspect.Signature.__class__.__name__.__eq__,                     ["type"],                         true]
    - [ip1156ps008, inspect.BoundArguments.__module__.__eq__,                        ["inspect"],                      true]

table inspect_extra1156.fullargspec_frameinfo_modules:
  description: "inspect.FullArgSpec and FrameInfo __module__ and class identity"
  kind: python_call_eq
  category: fullargspec_frameinfo_modules
  id_prefix: ip1156ff
  columns: [id, function, args, expected]
  rows:
    - [ip1156ff001, inspect.FullArgSpec.__module__.__eq__,                           ["inspect"],                      true]
    - [ip1156ff002, inspect.FullArgSpec.__qualname__.__eq__,                         ["FullArgSpec"],                   true]
    - [ip1156ff003, inspect.FullArgSpec.__class__.__name__.__eq__,                   ["type"],                         true]
    - [ip1156ff004, inspect.FrameInfo.__module__.__eq__,                             ["inspect"],                      true]
    - [ip1156ff005, inspect.FrameInfo.__qualname__.__eq__,                           ["FrameInfo"],                    true]
    - [ip1156ff006, inspect.FrameInfo.__class__.__name__.__eq__,                     ["type"],                         true]
    - [ip1156ff007, inspect.BoundArguments.__qualname__.__eq__,                      ["BoundArguments"],                true]
    - [ip1156ff008, inspect.BoundArguments.__class__.__name__.__eq__,                ["type"],                         true]
