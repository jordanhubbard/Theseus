spec: color_convert
version: ">=3.0.0"
backend: node(color-convert)
esm: true

docs: https://github.com/Qix-/color-convert#readme

provenance:
  derived_from:
    - "color-convert README — https://github.com/Qix-/color-convert#readme"
    - "Test vectors verified with color-convert via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "color-convert source"
  notes:
    - "Convert between color models — rgb / hex / hsl / hsv / hwb / cmyk / xyz / lab / lch / oklab / oklch / keyword."
    - "Install: npm install color-convert"
    - "v3 ESM only; default export is an object {space: {targetSpace: convertFn}}."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on numeric input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant color_convert.rgb_to_hex_red:
  description: "rgb.hex(255,0,0) is 'FF0000'"
  category: rgb
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.rgb"}
    - {method: hex, args: [255, 0, 0]}
  expected: "FF0000"

invariant color_convert.hex_to_rgb_red:
  description: "hex.rgb('FF0000') is [255, 0, 0]"
  category: hex
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.hex"}
    - {method: rgb, args: ["FF0000"]}
  expected: [255, 0, 0]

invariant color_convert.rgb_to_hsl_red:
  description: "rgb.hsl(255,0,0) is [0, 100, 50]"
  category: rgb
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.rgb"}
    - {method: hsl, args: [255, 0, 0]}
  expected: [0, 100, 50]

invariant color_convert.hsl_to_rgb_red:
  description: "hsl.rgb(0, 100, 50) is [255, 0, 0]"
  category: hsl
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.hsl"}
    - {method: rgb, args: [0, 100, 50]}
  expected: [255, 0, 0]

invariant color_convert.rgb_to_keyword:
  description: "rgb.keyword(255,0,0) is 'red'"
  category: rgb
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.rgb"}
    - {method: keyword, args: [255, 0, 0]}
  expected: "red"

invariant color_convert.keyword_to_rgb:
  description: "keyword.rgb('red') is [255, 0, 0]"
  category: keyword
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.keyword"}
    - {method: rgb, args: ["red"]}
  expected: [255, 0, 0]

invariant color_convert.has_rgb_namespace:
  description: "Default export has 'rgb' namespace (object of converters)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.rgb"}
    - {get: "constructor.name"}
  expected: "Object"

invariant color_convert.has_hsl_namespace:
  description: "Default export has 'hsl' namespace (object of converters)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.hsl"}
    - {get: "constructor.name"}
  expected: "Object"

invariant color_convert.rgb_to_cmyk_red:
  description: "rgb.cmyk(255,0,0) is [0, 100, 100, 0]"
  category: rgb
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.rgb"}
    - {method: cmyk, args: [255, 0, 0]}
  expected: [0, 100, 100, 0]
