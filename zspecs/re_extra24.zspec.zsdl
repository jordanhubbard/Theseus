spec: re_extra24
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra23.zspec.zsdl."
    - "re_extra23 covers: Pattern/Match/error __mro__.__len__(); Pattern __mro__[0]/__mro__[1] names; error __mro__[1]/__mro__[2] names; table of function __module__ attributes."
    - "re_extra22 covers: Pattern.__name__; Pattern.__module__; Match.__name__; Match.__module__; table of function __name__ attributes."
    - "re_extra9 covers: error.__qualname__ == 'PatternError' (3.12+); Pattern.__qualname__ == 'Pattern'; Match.__qualname__ == 'Match'."
    - "re_extra8 covers: compile/match/search/fullmatch/sub/split/findall/finditer __qualname__ table; error.__qualname__ == 'error' (pre-3.12 alias)."
    - "re_extra10 covers: purge/escape/subn __qualname__ table."
    - "NOT yet covered (now covered here): re.Pattern.__qualname__.__len__() == 7 — length of the 'Pattern' qualname string."
    - "NOT yet covered (now covered here): re.Match.__qualname__.__len__() == 5 — length of the 'Match' qualname string."
    - "NOT yet covered (now covered here): re.error.__qualname__.__len__() == 12 — length of 'PatternError' (12 chars, Python 3.12+)."
    - "NOT yet covered (now covered here): table of function __qualname__ string lengths — compile(7), match(5), search(6), findall(7), sub(3), split(5)."
    - "re.Pattern.__qualname__.__len__() == 7 verified at runtime ('Pattern' has 7 chars)."
    - "re.Match.__qualname__.__len__() == 5 verified at runtime ('Match' has 5 chars)."
    - "re.error.__qualname__.__len__() == 12 verified at runtime ('PatternError' has 12 chars on Python 3.12+)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern — __qualname__ string length
#
# re_extra9 covers Pattern.__qualname__ == 'Pattern' as a standalone invariant.
# No prior spec verifies Pattern.__qualname__.__len__(). The string 'Pattern'
# has 7 characters.
# Verified at runtime: __len__() == 7.
# ---------------------------------------------------------------------------

invariant re_extra24.Pattern.qualname_len:
  description: "re.Pattern.__qualname__.__len__() == 7 — 'Pattern' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# re.Match — __qualname__ string length
#
# re_extra9 covers Match.__qualname__ == 'Match'. No prior spec verifies
# Match.__qualname__.__len__(). The string 'Match' has 5 characters.
# Verified at runtime: __len__() == 5.
# ---------------------------------------------------------------------------

invariant re_extra24.Match.qualname_len:
  description: "re.Match.__qualname__.__len__() == 5 — 'Match' has 5 characters"
  category: class_identity
  kind: python_call_eq
  function: Match.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# re.error — __qualname__ string length
#
# re_extra9 covers error.__qualname__ == 'PatternError' (Python 3.12+).
# No prior spec verifies error.__qualname__.__len__(). The string 'PatternError'
# has 12 characters.
# Verified at runtime: __len__() == 12.
# ---------------------------------------------------------------------------

invariant re_extra24.error.qualname_len:
  description: "re.error.__qualname__.__len__() == 12 — 'PatternError' has 12 characters (Python 3.12+)"
  category: class_identity
  kind: python_call_eq
  function: error.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Table: re function __qualname__ string lengths
#
# re_extra8 covers function __qualname__ equality checks. No prior spec
# verifies the character counts of function __qualname__ strings. For
# module-level functions, __qualname__ equals __name__, so the lengths
# reflect the name length: compile(7), match(5), search(6), findall(7),
# sub(3), split(5).
# Verified at runtime: all six values confirmed.
# ---------------------------------------------------------------------------

table re_extra24.function_qualname_lengths:
  description: "re module function __qualname__ string lengths — compile, match, search, findall, sub, split"
  kind: python_call_eq
  category: class_identity
  id_prefix: qnlen24

  columns: [id, function, args, expected]
  rows:
    - [compile_len, compile.__qualname__.__len__, [], 7]
    - [match_len,   match.__qualname__.__len__,   [], 5]
    - [search_len,  search.__qualname__.__len__,  [], 6]
    - [findall_len, findall.__qualname__.__len__, [], 7]
    - [sub_len,     sub.__qualname__.__len__,     [], 3]
    - [split_len,   split.__qualname__.__len__,   [], 5]
