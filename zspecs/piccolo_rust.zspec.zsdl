spec: piccolo_rust
version: ">=3.9"
backend: rust_module(piccolo_rust)

docs: https://piccolo-orm.com/

provenance:
  derived_from:
    - "https://piccolo-orm.com/ — Piccolo ORM"
  notes:
    - "Piccolo is a fast async ORM for Python."
    - "piccolo.table.Table is a class."
    - "piccolo.columns.Column is a class."
    - "piccolo.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant piccolo_rust.has_table:
  description: "piccolo.table.Table is a class"
  category: presence
  kind: python_call_eq
  function: piccolo_has_table
  args: []
  expected: true

invariant piccolo_rust.has_column:
  description: "piccolo.columns.Column is a class"
  category: presence
  kind: python_call_eq
  function: piccolo_has_column
  args: []
  expected: true

invariant piccolo_rust.version_nonempty:
  description: "piccolo.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: piccolo_version_nonempty
  args: []
  expected: true

