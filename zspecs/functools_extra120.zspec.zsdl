# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch __code__ co_varnames and co_name
#
# Wave 266 theme: functools.singledispatch is a pure-Python decorator defined
# in Lib/functools.py. Its code object's first varname (co_varnames[0]) is
# 'func' — the single positional parameter that receives the function to be
# dispatched. The co_name attribute matches the def-statement name exactly:
# 'singledispatch'. The __name__ attribute has length 14.
#
# functools.singledispatch.__code__.co_varnames[0] == 'func'
# functools.singledispatch.__code__.co_name == 'singledispatch'
# functools.singledispatch.__name__.__len__() == 14
# functools.singledispatch.__code__.co_argcount == 1
#
# New to extra120. Previously covered: __name__, __qualname__, __module__,
# __qualname__.__len__, co_argcount (in earlier specs).
# ---------------------------------------------------------------------------

