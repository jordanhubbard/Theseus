spec: dataclasses_extra30
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra29.zspec.zsdl."
    - "Prior specs covered: dataclass/fields/asdict/astuple/make_dataclass/replace/is_dataclass __name__, Field/__name__/__module__/__qualname__, FrozenInstanceError/__name__/__module__/__bases__[0].__name__, MISSING.__class__.__name__, KW_ONLY, dataclasses.__all__ type/length, field/__name__, Field.__bases__[0].__name__=='object', various __qualname__ checks."
    - "This spec covers: dataclasses.dataclass.__module__, dataclasses.fields.__module__, dataclasses.asdict.__module__, dataclasses.astuple.__module__, dataclasses.make_dataclass.__module__, dataclasses.replace.__module__, dataclasses.is_dataclass.__module__, dataclasses.dataclass.__module__.__len__(), dataclasses.Field.__module__.__len__(), dataclasses.dataclass.__qualname__, dataclasses.fields.__qualname__, dataclasses.asdict.__qualname__."
    - "All seven module-level functions have __module__ == 'dataclasses' (len 11)."
    - "Field.__module__ == 'dataclasses' (len 11)."
    - "dataclass.__qualname__ == 'dataclass'; fields.__qualname__ == 'fields'; asdict.__qualname__ == 'asdict'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dataclasses module-level function __module__ values — combined table
#
# All seven module-level functions in dataclasses have __module__ == 'dataclasses'.
# No prior dataclasses spec collects all seven together in a single combined
# __module__.__eq__ table in the extra30 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra30.function_modules:
  description: "__module__.__eq__ for dataclasses module-level functions — all 'dataclasses'"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__module__.__eq__,      ["dataclasses"], true]
    - [fields,         fields.__module__.__eq__,         ["dataclasses"], true]
    - [asdict,         asdict.__module__.__eq__,         ["dataclasses"], true]
    - [astuple,        astuple.__module__.__eq__,        ["dataclasses"], true]
    - [make_dataclass, make_dataclass.__module__.__eq__, ["dataclasses"], true]
    - [replace,        replace.__module__.__eq__,        ["dataclasses"], true]
    - [is_dataclass,   is_dataclass.__module__.__eq__,   ["dataclasses"], true]

# ---------------------------------------------------------------------------
# dataclasses.__module__ string lengths — combined table
#
# dataclasses.dataclass.__module__ == 'dataclasses' (len 11).
# dataclasses.Field.__module__ == 'dataclasses' (len 11).
# No prior dataclasses spec records these two module string lengths together
# in a combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra30.module_string_lens:
  description: "__module__.__len__() for dataclasses.dataclass and Field — both 11"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [dataclass, dataclass.__module__.__len__, [], 11]
    - [Field,     Field.__module__.__len__,     [], 11]

# ---------------------------------------------------------------------------
# dataclasses.dataclass, fields, asdict __qualname__ — standalone invariants
#
# These three module-level functions have __qualname__ equal to their short
# identifier. No prior dataclasses spec records dataclass.__qualname__,
# fields.__qualname__, or asdict.__qualname__ in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra30.dataclass.qualname:
  description: "dataclasses.dataclass.__qualname__ == 'dataclass' — module-level function"
  category: function_attrs
  kind: python_call_eq
  function: dataclass.__qualname__.__eq__
  args: ["dataclass"]
  expected: true

invariant dataclasses_extra30.fields.qualname:
  description: "dataclasses.fields.__qualname__ == 'fields' — module-level function"
  category: function_attrs
  kind: python_call_eq
  function: fields.__qualname__.__eq__
  args: ["fields"]
  expected: true

invariant dataclasses_extra30.asdict.qualname:
  description: "dataclasses.asdict.__qualname__ == 'asdict' — module-level function"
  category: function_attrs
  kind: python_call_eq
  function: asdict.__qualname__.__eq__
  args: ["asdict"]
  expected: true
