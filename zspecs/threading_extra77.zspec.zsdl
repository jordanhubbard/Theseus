spec: threading_extra77
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra76.zspec.zsdl."
    - "This spec covers: threading Thread class __dict__ content (Wave 242)."
    - "Thread.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of Thread is a mappingproxy. Verified with Python 3.14.3."
    - "Thread.__dict__.__contains__('start') == True — Thread.start is defined. Verified with Python 3.14.3."
    - "Thread.__dict__.__contains__('run') == True — Thread.run is defined. Verified with Python 3.14.3."
    - "Thread.__dict__.__contains__('join') == True — Thread.join is defined. Verified with Python 3.14.3."
    - "Thread.__dict__.__contains__('is_alive') == True — Thread.is_alive is defined. Verified with Python 3.14.3."
    - "Thread.__dict__.__contains__('daemon') == True — daemon is a property on Thread. Verified with Python 3.14.3."
    - "Thread.__dict__.__contains__('name') == True — name is a property on Thread. Verified with Python 3.14.3."
    - "Thread.__dict__.__contains__('ident') == True — ident is a property on Thread. Verified with Python 3.14.3."
    - "Condition.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of Condition is a mappingproxy. Verified with Python 3.14.3."
    - "Condition.__dict__.__contains__('wait') == True — Condition.wait is defined. Verified with Python 3.14.3."
    - "Condition.__dict__.__contains__('notify') == True — Condition.notify is defined. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread __dict__ class name — extra77
#
# Wave 242 theme: Thread.__dict__ is a mappingproxy.
#
# threading.Thread.__dict__.__class__.__name__ == 'mappingproxy'
#
# No prior threading spec checks Thread.__dict__.__class__.__name__ via thrdmore77. New to extra77.
# ---------------------------------------------------------------------------

table threading_extra77.Thread_dict_class_name:
  description: "Thread.__dict__.__class__.__name__=='mappingproxy'; wave 242 Thread __dict__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore77

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_dict_class_name_eq_mappingproxy,
       Thread.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Thread is a pure-Python class defined in Lib/threading.py that represents a thread of control; its class namespace is exposed as a read-only mappingproxy; __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior threading spec checks Thread.__dict__.__class__.__name__ via thrdmore77; new to extra77"]

# ---------------------------------------------------------------------------
# Thread __dict__ core lifecycle methods — extra77
#
# Wave 242 theme: Thread.__dict__ contains start/run/join/is_alive.
#
# threading.Thread.__dict__.__contains__('start')    == True
# threading.Thread.__dict__.__contains__('run')      == True
# threading.Thread.__dict__.__contains__('join')     == True
# threading.Thread.__dict__.__contains__('is_alive') == True
#
# No prior threading spec checks Thread.__dict__ lifecycle method keys via thrdmore77. New to extra77.
# ---------------------------------------------------------------------------

table threading_extra77.Thread_dict_lifecycle_methods:
  description: "Thread.__dict__.__contains__('start')==True, 'run'==True, 'join'==True, 'is_alive'==True; wave 242 Thread __dict__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore77

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_dict_contains_start,
       Thread.__dict__.__contains__,
       ["start"],
       true,
       "threading.Thread.__dict__.__contains__('start') == True — Thread.start(self) is defined in the Thread class body in Lib/threading.py; it starts the thread's activity by invoking the run() method in a new OS thread; mappingproxy.__contains__('start') returns True; no prior threading spec checks Thread.__dict__.__contains__('start') via thrdmore77; new to extra77"]
    - [Thread_dict_contains_run,
       Thread.__dict__.__contains__,
       ["run"],
       true,
       "threading.Thread.__dict__.__contains__('run') == True — Thread.run(self) is defined in the Thread class body in Lib/threading.py; it is the method representing the thread's activity which subclasses may override; mappingproxy.__contains__('run') returns True; no prior threading spec checks Thread.__dict__.__contains__('run') via thrdmore77; new to extra77"]
    - [Thread_dict_contains_join,
       Thread.__dict__.__contains__,
       ["join"],
       true,
       "threading.Thread.__dict__.__contains__('join') == True — Thread.join(self, timeout=None) is defined in the Thread class body in Lib/threading.py; it waits until the thread terminates; mappingproxy.__contains__('join') returns True; no prior threading spec checks Thread.__dict__.__contains__('join') via thrdmore77; new to extra77"]
    - [Thread_dict_contains_is_alive,
       Thread.__dict__.__contains__,
       ["is_alive"],
       true,
       "threading.Thread.__dict__.__contains__('is_alive') == True — Thread.is_alive(self) is defined in the Thread class body in Lib/threading.py; it returns True if the thread is still running; mappingproxy.__contains__('is_alive') returns True; no prior threading spec checks Thread.__dict__.__contains__('is_alive') via thrdmore77; new to extra77"]

# ---------------------------------------------------------------------------
# Thread __dict__ properties — extra77
#
# Wave 242 theme: Thread.__dict__ contains daemon/name/ident.
#
# threading.Thread.__dict__.__contains__('daemon') == True
# threading.Thread.__dict__.__contains__('name')   == True
# threading.Thread.__dict__.__contains__('ident')  == True
#
# No prior threading spec checks Thread.__dict__ property keys via thrdmore77. New to extra77.
# ---------------------------------------------------------------------------

table threading_extra77.Thread_dict_properties:
  description: "Thread.__dict__.__contains__('daemon')==True, 'name'==True, 'ident'==True; wave 242 Thread __dict__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore77

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_dict_contains_daemon,
       Thread.__dict__.__contains__,
       ["daemon"],
       true,
       "threading.Thread.__dict__.__contains__('daemon') == True — Thread.daemon is a property defined in the Thread class body in Lib/threading.py; it is a boolean that indicates whether the thread is a daemon thread; mappingproxy.__contains__('daemon') returns True; no prior threading spec checks Thread.__dict__.__contains__('daemon') via thrdmore77; new to extra77"]
    - [Thread_dict_contains_name,
       Thread.__dict__.__contains__,
       ["name"],
       true,
       "threading.Thread.__dict__.__contains__('name') == True — Thread.name is a property defined in the Thread class body in Lib/threading.py; it is a string used for identification purposes only; mappingproxy.__contains__('name') returns True; no prior threading spec checks Thread.__dict__.__contains__('name') via thrdmore77; new to extra77"]
    - [Thread_dict_contains_ident,
       Thread.__dict__.__contains__,
       ["ident"],
       true,
       "threading.Thread.__dict__.__contains__('ident') == True — Thread.ident is a property defined in the Thread class body in Lib/threading.py; it returns the thread identifier (an integer) or None if the thread has not been started; mappingproxy.__contains__('ident') returns True; no prior threading spec checks Thread.__dict__.__contains__('ident') via thrdmore77; new to extra77"]

# ---------------------------------------------------------------------------
# Condition __dict__ class name and method presence — extra77
#
# Wave 242 theme: Condition.__dict__ is a mappingproxy; contains wait/notify.
#
# threading.Condition.__dict__.__class__.__name__     == 'mappingproxy'
# threading.Condition.__dict__.__contains__('wait')   == True
# threading.Condition.__dict__.__contains__('notify') == True
#
# No prior threading spec checks Condition.__dict__ attrs via thrdmore77. New to extra77.
# ---------------------------------------------------------------------------

table threading_extra77.Condition_dict_attrs:
  description: "Condition.__dict__.__class__.__name__=='mappingproxy', __contains__('wait')==True, __contains__('notify')==True; wave 242 Condition __dict__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore77

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_dict_class_name_eq_mappingproxy,
       Condition.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "threading.Condition.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Condition is a pure-Python class defined in Lib/threading.py that implements a condition variable; its class namespace is exposed as a read-only mappingproxy; __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior threading spec checks Condition.__dict__.__class__.__name__ via thrdmore77; new to extra77"]
    - [Condition_dict_contains_wait,
       Condition.__dict__.__contains__,
       ["wait"],
       true,
       "threading.Condition.__dict__.__contains__('wait') == True — Condition.wait(self, timeout=None) is defined in the Condition class body in Lib/threading.py; it waits until notified or until a timeout occurs; mappingproxy.__contains__('wait') returns True; no prior threading spec checks Condition.__dict__.__contains__('wait') via thrdmore77; new to extra77"]
    - [Condition_dict_contains_notify,
       Condition.__dict__.__contains__,
       ["notify"],
       true,
       "threading.Condition.__dict__.__contains__('notify') == True — Condition.notify(self, n=1) is defined in the Condition class body in Lib/threading.py; it wakes up one or more threads waiting on the condition; mappingproxy.__contains__('notify') returns True; no prior threading spec checks Condition.__dict__.__contains__('notify') via thrdmore77; new to extra77"]

