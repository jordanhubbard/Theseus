spec: types_extra28
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends types_extra27.zspec.zsdl."
    - "Prior specs covered: FunctionType/LambdaType/MethodType/GeneratorType/CodeType/ModuleType/__name__/__module__/__qualname__, SimpleNamespace/__name__/__module__/__qualname__, MappingProxyType/__name__, DynamicClassAttribute/__name__, GenericAlias/__name__, UnionType/__name__, various __bases__[0].__name__ checks, NoneType/EllipsisType/NotImplementedType, __module__.__len__() and __name__.__len__() for many types, __qualname__.__len__() for SimpleNamespace/__init__/__repr__/__eq__ and ModuleType/__init__/__repr__, __mro__.__len__() for MappingProxyType/NoneType/EllipsisType, NoneType.__module__.__len__() == 8, new_class.__qualname__.__len__() == 9."
    - "This spec covers: types.__all__.__len__() and .__class__.__name__.__len__(); __dict__.__class__.__name__.__len__() for SimpleNamespace/MappingProxyType/FunctionType/MethodType/ModuleType/GeneratorType/CoroutineType (all mappingproxy=12); __qualname__.__len__() for SimpleNamespace/MappingProxyType/NoneType/GeneratorType/CoroutineType/FunctionType/MethodType (C internal names differ from Python attribute names); __bases__[0].__name__.__len__() for SimpleNamespace/MappingProxyType."
    - "types.__all__.__len__() == 33 — verified on Python 3.12."
    - "All seven class __dict__ values in this spec are 'mappingproxy' (length 12) — consistent across C-level and Python-level types in the types module."
    - "types.MappingProxyType.__qualname__ == 'mappingproxy' (length 12) — the C-level internal name, not the Python attribute name 'MappingProxyType' (16)."
    - "types.GeneratorType.__qualname__ == 'generator' (length 9); types.CoroutineType.__qualname__ == 'coroutine' (length 9) — C internal names."
    - "types.FunctionType.__qualname__ == 'function' (length 8); types.MethodType.__qualname__ == 'method' (length 6) — C internal names."
    - "types.NoneType.__qualname__ == 'NoneType' (length 8) — unlike most C types, NoneType keeps 'NoneType' as its qualname."
    - "types.SimpleNamespace.__qualname__ == 'SimpleNamespace' (length 15) — Python class, so qualname matches the public attribute name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# types.__all__.__len__() and .__class__.__name__.__len__()
#
# types.__all__ is a list with 33 entries (Python 3.12). The list class name
# 'list' has length 4. No prior types spec records the total number of exports
# or the type of __all__.
# ---------------------------------------------------------------------------

table types_extra28.all_list_attrs:
  description: "types.__all__ length (33) and its class name length (4 — 'list')"
  kind: python_call_eq
  category: module_all_attrs
  id_prefix: all

  columns: [id, function, args, expected]
  rows:
    - [len,            __all__.__len__,                   [], 33]
    - [class_name_len, __all__.__class__.__name__.__len__, [], 4]

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for seven types-module classes
#
# Every class measured here — both C-implemented (FunctionType, MethodType,
# ModuleType, GeneratorType, CoroutineType, MappingProxyType) and Python-level
# (SimpleNamespace) — stores its class __dict__ as a mappingproxy (length 12).
# No prior types spec records __dict__.__class__.__name__.__len__() for any of
# these seven classes.
# ---------------------------------------------------------------------------

table types_extra28.class_dict_type_lens:
  description: "__dict__.__class__.__name__.__len__() for seven types-module classes — all are mappingproxy (12)"
  kind: python_call_eq
  category: dict_type_checks
  id_prefix: dict_class_name_len

  columns: [id, function, args, expected]
  rows:
    - [SimpleNamespace,   SimpleNamespace.__dict__.__class__.__name__.__len__,   [], 12]
    - [MappingProxyType,  MappingProxyType.__dict__.__class__.__name__.__len__,  [], 12]
    - [FunctionType,      FunctionType.__dict__.__class__.__name__.__len__,      [], 12]
    - [MethodType,        MethodType.__dict__.__class__.__name__.__len__,        [], 12]
    - [ModuleType,        ModuleType.__dict__.__class__.__name__.__len__,        [], 12]
    - [GeneratorType,     GeneratorType.__dict__.__class__.__name__.__len__,     [], 12]
    - [CoroutineType,     CoroutineType.__dict__.__class__.__name__.__len__,     [], 12]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for C-level types: MappingProxyType/GeneratorType/
# CoroutineType/FunctionType/MethodType and Python-level: SimpleNamespace/NoneType
#
# C-level types use their internal C name as __qualname__, which differs from
# the Python attribute name: 'mappingproxy' (12) vs 'MappingProxyType' (16);
# 'generator'/'coroutine' (9 each) vs 'GeneratorType'/'CoroutineType' (13/13);
# 'function' (8) vs 'FunctionType' (12); 'method' (6) vs 'MethodType' (10).
# SimpleNamespace is Python-level so its qualname 'SimpleNamespace' (15)
# matches the attribute name. NoneType keeps its public name 'NoneType' (8).
# No prior types spec records these __qualname__.__len__() values.
# ---------------------------------------------------------------------------

table types_extra28.class_qualname_lens:
  description: "__qualname__.__len__() for types-module classes — C internal names diverge from Python attribute names"
  kind: python_call_eq
  category: qualname_attr_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [SimpleNamespace,  SimpleNamespace.__qualname__.__len__,  [], 15]
    - [MappingProxyType, MappingProxyType.__qualname__.__len__, [], 12]
    - [NoneType,         NoneType.__qualname__.__len__,         [], 8]
    - [GeneratorType,    GeneratorType.__qualname__.__len__,    [], 9]
    - [CoroutineType,    CoroutineType.__qualname__.__len__,    [], 9]
    - [FunctionType,     FunctionType.__qualname__.__len__,     [], 8]
    - [MethodType,       MethodType.__qualname__.__len__,       [], 6]

# ---------------------------------------------------------------------------
# types.MappingProxyType.__qualname__.__len__() == 12 — standalone
#
# types.MappingProxyType.__qualname__ == 'mappingproxy' (length 12). The
# Python attribute name 'MappingProxyType' has 16 characters, but the C
# internal name 'mappingproxy' (12 chars) is what Python reports as the
# __qualname__. This is the same pattern seen in GeneratorType ('generator'),
# CoroutineType ('coroutine'), FunctionType ('function'), and MethodType
# ('method'). No prior types spec records this qualname length as a standalone.
# ---------------------------------------------------------------------------

invariant types_extra28.MappingProxyType.qualname_len:
  description: "types.MappingProxyType.__qualname__.__len__() == 12 — C internal name 'mappingproxy' has length 12; Python attribute name 'MappingProxyType' has length 16"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: MappingProxyType.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# types.SimpleNamespace.__bases__[0].__name__.__len__() == 6 — standalone
#
# types.SimpleNamespace.__bases__[0].__name__ == 'object' (length 6).
# SimpleNamespace is a Python-level class with object as its sole direct base.
# No prior types spec records __bases__[0].__name__.__len__() for SimpleNamespace
# as a standalone invariant.
# ---------------------------------------------------------------------------

invariant types_extra28.SimpleNamespace.bases0_name_len:
  description: "types.SimpleNamespace.__bases__[0].__name__.__len__() == 6 — SimpleNamespace's sole base class is 'object' (length 6)"
  category: base_class_names
  kind: python_call_eq
  function: "SimpleNamespace.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# types.FunctionType.__qualname__.__len__() == 8 — standalone
#
# types.FunctionType.__qualname__ == 'function' (length 8). The C internal
# name 'function' is 8 characters — 4 shorter than the Python attribute name
# 'FunctionType' (12). This illustrates the systematic pattern where C-level
# types expose shorter internal names as __qualname__ than the descriptive
# Python attribute names in the types module.
# ---------------------------------------------------------------------------

invariant types_extra28.FunctionType.qualname_len:
  description: "types.FunctionType.__qualname__.__len__() == 8 — C internal name 'function' has length 8; Python attribute name 'FunctionType' has length 12"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: FunctionType.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# types.__all__.__len__() == 33 — standalone
#
# types.__all__ contains 33 exported names in Python 3.12. This anchors the
# module's public API surface area and serves as a cross-module comparison
# point (vs. typing's 105 exports, weakref's 13, etc.).
# ---------------------------------------------------------------------------

invariant types_extra28.all_len:
  description: "types.__all__.__len__() == 33 — 33 public exports in Python 3.12"
  category: module_all_attrs
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 33
