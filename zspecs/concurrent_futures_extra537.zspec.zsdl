spec: concurrent_futures_extra537
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: "concurrent.futures Executor context manager methods and class identity checks"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table concurrent_futures_extra537.method_names:
  description: "concurrent.futures method __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cfname
  columns: [id, function, args, expected]
  rows:
    - [cfname001, concurrent.futures.Executor.__enter__.__name__.__eq__, ["__enter__"], true]
    - [cfname002, concurrent.futures.Executor.__exit__.__name__.__eq__, ["__exit__"], true]
    - [cfname003, concurrent.futures.Future.__repr__.__name__.__eq__, ["__repr__"], true]

table concurrent_futures_extra537.class_qualnames:
  description: "concurrent.futures class __qualname__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cfqual
  columns: [id, function, args, expected]
  rows:
    - [cfqual001, concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__, ["ThreadPoolExecutor"], true]
    - [cfqual002, concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true]
    - [cfqual003, concurrent.futures.Executor.__qualname__.__eq__, ["Executor"], true]
    - [cfqual004, concurrent.futures.Future.__qualname__.__eq__, ["Future"], true]
    - [cfqual005, concurrent.futures.BrokenExecutor.__qualname__.__eq__, ["BrokenExecutor"], true]
    - [cfqual006, concurrent.futures.wait.__qualname__.__eq__, ["wait"], true]
    - [cfqual007, concurrent.futures.as_completed.__qualname__.__eq__, ["as_completed"], true]
