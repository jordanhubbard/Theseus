spec: object_omit
version: ">=1.0.0"
backend: node(object-omit)

docs: https://www.npmjs.com/package/object-omit

provenance:
  derived_from:
    - "object-omit README — https://www.npmjs.com/package/object-omit"
    - "Test vectors verified with object-omit via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-omit source"
  notes:
    - "object-omit is an npm package. Install: npm install object-omit"
    - "Returns a copy of an object with specified keys removed."
    - "Second argument can be a string (single key) or array of strings."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_omit.omit:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: omit

  columns: [id, args, expected]
  rows:
    - [array_key,   [{"a": 1, "b": 2, "c": 3}, ["b"]],      {"a": 1, "c": 3}]
    - [string_key,  [{"a": 1, "b": 2}, "a"],                 {"b": 2}]
    - [two_keys,    [{"x": 1, "y": 2, "z": 3}, ["x", "z"]], {"y": 2}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:13:55Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
