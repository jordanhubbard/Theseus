spec: re3046
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (re3046): __enter__, __exit__, __aenter__ dict-presence for re types."
    - "re.Pattern, re.Match, and re.RegexFlag are regex engine types; none define __enter__ or __exit__ in their own __dict__."
    - "Compiled patterns are not context managers and do not define __enter__/__exit__ at the class level."
    - "None of the re types define __aenter__ in their own __dict__; async context manager support is absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# re types are regex engine objects, not context managers; none define
# __enter__ in their own __dict__; all false.
# ---------------------------------------------------------------------------

table re3046.enter:
  description: "re types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re3046
  columns: [id, function, args, expected]
  rows:
    - ["re3046001", operator.contains, [re.Pattern.__dict__,   __enter__], false]
    - ["re3046002", operator.contains, [re.Match.__dict__,     __enter__], false]
    - ["re3046003", operator.contains, [re.RegexFlag.__dict__, __enter__], false]
    - ["re3046004", operator.contains, [re.Pattern.__dict__,   __enter__], false]
    - ["re3046005", operator.contains, [re.Match.__dict__,     __enter__], false]
    - ["re3046006", operator.contains, [re.RegexFlag.__dict__, __enter__], false]

