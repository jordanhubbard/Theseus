spec: heapq_extra
version: ">=3.2"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "Python heapq documentation — https://docs.python.org/3/library/heapq.html"
    - "Test vectors verified by running Python 3.14.3 heapq module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec covers identity and behavioral invariants not present in heapq.zspec.zsdl."
    - "heappush and heappop are C-implemented; their __module__ == '_heapq'."
    - "merge is a Python-level generator function; its __name__ == 'merge'."
    - "nlargest and nsmallest return lists; nlargest is descending, nsmallest is ascending."
    - "heapreplace and heappushpop mutate lists in-place and are verified by __name__ only."
    - "All expected values verified by running Python 3.14.3 heapq module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name identity
# ---------------------------------------------------------------------------

invariant heapq_extra.heappush.name:
  description: "heappush.__name__ == 'heappush'"
  category: identity
  kind: python_call_eq
  function: heappush.__name__.__eq__
  args: ["heappush"]
  expected: true

invariant heapq_extra.heappush.module:
  description: "heappush.__module__ == '_heapq' — C implementation"
  category: identity
  kind: python_call_eq
  function: heappush.__module__.__eq__
  args: ["_heapq"]
  expected: true

invariant heapq_extra.heappop.name:
  description: "heappop.__name__ == 'heappop'"
  category: identity
  kind: python_call_eq
  function: heappop.__name__.__eq__
  args: ["heappop"]
  expected: true

invariant heapq_extra.heapify.name:
  description: "heapify.__name__ == 'heapify'"
  category: identity
  kind: python_call_eq
  function: heapify.__name__.__eq__
  args: ["heapify"]
  expected: true

invariant heapq_extra.heapreplace.name:
  description: "heapreplace.__name__ == 'heapreplace'"
  category: identity
  kind: python_call_eq
  function: heapreplace.__name__.__eq__
  args: ["heapreplace"]
  expected: true

invariant heapq_extra.heappushpop.name:
  description: "heappushpop.__name__ == 'heappushpop'"
  category: identity
  kind: python_call_eq
  function: heappushpop.__name__.__eq__
  args: ["heappushpop"]
  expected: true

invariant heapq_extra.merge.name:
  description: "merge.__name__ == 'merge'"
  category: identity
  kind: python_call_eq
  function: merge.__name__.__eq__
  args: ["merge"]
  expected: true

invariant heapq_extra.nlargest.name:
  description: "nlargest.__name__ == 'nlargest'"
  category: identity
  kind: python_call_eq
  function: nlargest.__name__.__eq__
  args: ["nlargest"]
  expected: true

invariant heapq_extra.nsmallest.name:
  description: "nsmallest.__name__ == 'nsmallest'"
  category: identity
  kind: python_call_eq
  function: nsmallest.__name__.__eq__
  args: ["nsmallest"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — nlargest and nsmallest on [1, 5, 3, 2, 4]
# ---------------------------------------------------------------------------

invariant heapq_extra.nlargest.top3:
  description: "nlargest(3, [1,5,3,2,4]) == [5, 4, 3] — three largest in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [3, [1, 5, 3, 2, 4]]
  expected: [5, 4, 3]

invariant heapq_extra.nsmallest.top3:
  description: "nsmallest(3, [1,5,3,2,4]) == [1, 2, 3] — three smallest in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [3, [1, 5, 3, 2, 4]]
  expected: [1, 2, 3]
