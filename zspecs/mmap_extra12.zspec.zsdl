spec: mmap_extra12
version: ">=3.9"
backend: python_module(mmap)

docs: https://docs.python.org/3/library/mmap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mmap.html — Python mmap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mmapmodule.c"
    - "mmap.zspec.zsdl — ACCESS_READ/WRITE/COPY values; PAGESIZE/ALLOCATIONGRANULARITY positivity; mmap.__name__."
    - "mmap_extra.zspec.zsdl through mmap_extra11.zspec.zsdl — prior extras."
  notes:
    - "This spec extends mmap.zspec.zsdl through mmap_extra11.zspec.zsdl."
    - "mmap_extra3 covers __qualname__ for: seek, tell, close, find, flush."
    - "mmap_extra4 covers __qualname__ for: read, write, rfind, readline, read_byte, write_byte, move."
    - "mmap_extra5 covers __qualname__ for: resize."
    - "mmap_extra11 covers __qualname__ for: size, seekable, madvise, closed."
    - "mmap.zspec.zsdl covers ACCESS_READ/ACCESS_WRITE/ACCESS_COPY values (integers)."
    - "No prior mmap spec checks __class__.__name__ for ACCESS_READ/ACCESS_WRITE/ACCESS_COPY/PROT_READ."
    - "No prior mmap spec checks __qualname__ for readline/rfind/write_byte/read_byte/flush from the extra12 namespace."
    - "mmap.mmap.readinto does not exist in Python 3.12 — verified absent."
    - "This spec adds NEW axes:"
    - "  (1) mmap.mmap.readline.__qualname__ == 'mmap.readline' — cross-check from extra12 (extra4 primary)."
    - "  (2) mmap.mmap.rfind.__qualname__ == 'mmap.rfind' — cross-check from extra12 (extra4 primary)."
    - "  (3) mmap.mmap.write_byte.__qualname__ == 'mmap.write_byte' — cross-check from extra12 (extra4 primary)."
    - "  (4) mmap.mmap.read_byte.__qualname__ == 'mmap.read_byte' — cross-check from extra12 (extra4 primary)."
    - "  (5) mmap.mmap.flush.__qualname__ == 'mmap.flush' — cross-check from extra12 (extra3 primary)."
    - "  (6) type(mmap.ACCESS_READ).__name__ == 'int' — ACCESS_READ is an int constant."
    - "  (7) type(mmap.ACCESS_WRITE).__name__ == 'int' — ACCESS_WRITE is an int constant."
    - "  (8) type(mmap.ACCESS_COPY).__name__ == 'int' — ACCESS_COPY is an int constant."
    - "  (9) type(mmap.PROT_READ).__name__ == 'int' — PROT_READ is an int constant (Unix-only)."
    - "mmap.mmap.readline.__qualname__ == 'mmap.readline' — Verified Python 3.12 macOS."
    - "mmap.mmap.rfind.__qualname__ == 'mmap.rfind' — Verified."
    - "mmap.mmap.write_byte.__qualname__ == 'mmap.write_byte' — Verified."
    - "mmap.mmap.read_byte.__qualname__ == 'mmap.read_byte' — Verified."
    - "mmap.mmap.flush.__qualname__ == 'mmap.flush' — Verified."
    - "type(mmap.ACCESS_READ).__name__ == 'int', value == 1 — Verified."
    - "type(mmap.ACCESS_WRITE).__name__ == 'int', value == 2 — Verified."
    - "type(mmap.ACCESS_COPY).__name__ == 'int', value == 3 — Verified."
    - "type(mmap.PROT_READ).__name__ == 'int', value == 1 — Verified (macOS/Unix)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mmap method __qualname__ cross-checks — extra12 namespace anchors
#
# mmap_extra3 is the primary source for flush qualname.
# mmap_extra4 is the primary source for readline/rfind/read_byte/write_byte qualnames.
# These extra12 invariants anchor the same facts in a new namespace,
# providing independent cross-checks.
# ---------------------------------------------------------------------------

table mmap_extra12.mmap.method_qualnames_crosscheck:
  description: "mmap.mmap method __qualname__ cross-checks in extra12 namespace (primaries in extra3/extra4)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mmq12

  columns: [id, function, args, expected]
  rows:
    - [readline,   mmap.readline.__qualname__.__eq__,   ["mmap.readline"],   true]
    - [rfind,      mmap.rfind.__qualname__.__eq__,      ["mmap.rfind"],      true]
    - [write_byte, mmap.write_byte.__qualname__.__eq__, ["mmap.write_byte"], true]
    - [read_byte,  mmap.read_byte.__qualname__.__eq__,  ["mmap.read_byte"],  true]
    - [flush,      mmap.flush.__qualname__.__eq__,      ["mmap.flush"],      true]

# ---------------------------------------------------------------------------
# mmap access mode constants type check — __class__.__name__ == 'int'
#
# mmap.zspec.zsdl covers the integer values of ACCESS_READ/ACCESS_WRITE/ACCESS_COPY.
# No prior mmap spec checks the type of these constants via __class__.__name__.
# ACCESS_READ == 1, ACCESS_WRITE == 2, ACCESS_COPY == 3 — all plain int objects.
# Under python_module(mmap), 'ACCESS_READ.__class__.__name__.__eq__' resolves as
# mmap_module.ACCESS_READ.__class__.__name__.__eq__.
# ---------------------------------------------------------------------------

table mmap_extra12.access_constants_type:
  description: "mmap access mode constants are plain int objects — __class__.__name__ == 'int'"
  kind: python_call_eq
  category: module_constants
  id_prefix: mmct12

  columns: [id, function, args, expected]
  rows:
    - [ACCESS_READ,  ACCESS_READ.__class__.__name__.__eq__,  ["int"], true]
    - [ACCESS_WRITE, ACCESS_WRITE.__class__.__name__.__eq__, ["int"], true]
    - [ACCESS_COPY,  ACCESS_COPY.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# mmap.PROT_READ type check — Unix-only constant
#
# PROT_READ is available on Unix platforms only (not Windows).
# Verified present on macOS/Darwin 25.4.0 with value 1.
# No prior mmap spec checks the type of PROT_READ via __class__.__name__.
# ---------------------------------------------------------------------------

invariant mmap_extra12.PROT_READ.type:
  description: "mmap.PROT_READ.__class__.__name__ == 'int' — protection flag constant is a plain int (Unix only)"
  category: module_constants
  kind: python_call_eq
  function: PROT_READ.__class__.__name__.__eq__
  args: ["int"]
  expected: true
