spec: cgi_extra4
version: ">=3.9,<3.13"
backend: python_module(cgi)

docs: https://docs.python.org/3/library/cgi.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cgi.html — Python cgi module documentation"
    - "Test vectors verified with Python 3.12.9 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cgi.py"
  notes:
    - "The cgi module was deprecated in Python 3.11 and removed in Python 3.13."
    - "This spec applies to Python >=3.9,<3.13 only."
    - "This spec extends cgi.zspec.zsdl, cgi_extra.zspec.zsdl, cgi_extra2.zspec.zsdl, and cgi_extra3.zspec.zsdl."
    - "cgi.zspec.zsdl covers __name__ for FieldStorage, MiniFieldStorage, parse, parse_header, escape; parse_header/escape behavioral invariants."
    - "cgi_extra.zspec.zsdl covers __module__ for FieldStorage/MiniFieldStorage; __name__ for print_exception."
    - "cgi_extra2.zspec.zsdl covers __name__ for parse_multipart, parse_qs, parse_qsl; __bases__ for FieldStorage/MiniFieldStorage; parse_header return-type checks."
    - "cgi_extra3.zspec.zsdl covers __qualname__ for FieldStorage, MiniFieldStorage, parse, parse_header."
    - "This spec adds: __qualname__ for parse_multipart, parse_qs, parse_qsl, print_exception; __module__ for parse, parse_header, parse_multipart, parse_qs, parse_qsl, print_exception; module __name__ check."
    - "All cgi module-level functions have __module__ == 'cgi' and __qualname__ == __name__."
    - "parse_qs and parse_qsl are re-exported from urllib.parse; their __module__ may differ — vectors reflect actual Python 3.12 behavior (both __module__ == 'urllib.parse')."
    - "All expected values verified with Python 3.12.9 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# module identity
# ---------------------------------------------------------------------------

invariant cgi_extra4.module.name:
  description: "cgi.__name__ == 'cgi'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["cgi"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks for remaining functions
# (cgi_extra3.zspec.zsdl covers parse and parse_header qualnames;
#  this spec covers parse_multipart, parse_qs, parse_qsl, print_exception)
# ---------------------------------------------------------------------------

table cgi_extra4.function_qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [parse_multipart,  parse_multipart.__qualname__.__eq__,   ["parse_multipart"],  true]
    - [print_exception,  print_exception.__qualname__.__eq__,   ["print_exception"],  true]

# ---------------------------------------------------------------------------
# __module__ checks for cgi-native functions
# (cgi_extra.zspec.zsdl covers __module__ for FieldStorage/MiniFieldStorage only)
# Functions defined directly in cgi have __module__ == 'cgi'
# ---------------------------------------------------------------------------

table cgi_extra4.function_modules:
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [parse,           parse.__module__.__eq__,           ["cgi"], true]
    - [parse_header,    parse_header.__module__.__eq__,    ["cgi"], true]
    - [parse_multipart, parse_multipart.__module__.__eq__, ["cgi"], true]
    - [print_exception, print_exception.__module__.__eq__, ["cgi"], true]

# ---------------------------------------------------------------------------
# parse_qs and parse_qsl — re-exported from urllib.parse
# These two are aliases; their __module__ is 'urllib.parse'
# ---------------------------------------------------------------------------

invariant cgi_extra4.parse_qs.module_is_urllib_parse:
  description: "cgi.parse_qs.__module__ == 'urllib.parse' — re-exported alias"
  category: functions
  kind: python_call_eq
  function: parse_qs.__module__.__eq__
  args: ["urllib.parse"]
  expected: true

invariant cgi_extra4.parse_qsl.module_is_urllib_parse:
  description: "cgi.parse_qsl.__module__ == 'urllib.parse' — re-exported alias"
  category: functions
  kind: python_call_eq
  function: parse_qsl.__module__.__eq__
  args: ["urllib.parse"]
  expected: true

# ---------------------------------------------------------------------------
# parse_qs and parse_qsl __qualname__ checks
# (qualname reflects the original definition site in urllib.parse)
# ---------------------------------------------------------------------------

invariant cgi_extra4.parse_qs.qualname:
  description: "cgi.parse_qs.__qualname__ == 'parse_qs'"
  category: functions
  kind: python_call_eq
  function: parse_qs.__qualname__.__eq__
  args: ["parse_qs"]
  expected: true

invariant cgi_extra4.parse_qsl.qualname:
  description: "cgi.parse_qsl.__qualname__ == 'parse_qsl'"
  category: functions
  kind: python_call_eq
  function: parse_qsl.__qualname__.__eq__
  args: ["parse_qsl"]
  expected: true
