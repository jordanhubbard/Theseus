spec: struct_extra85
version: ">=3.9"
extends: struct_extra84
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra84.zspec.zsdl — covers struct.Struct method __qualname__ string lengths / module-level function __qualname__ string lengths / Struct and error name string lengths (table + invariants)."
    - "struct_extra83.zspec.zsdl — covers module-level function __qualname__.__eq__ for pack/unpack/pack_into/unpack_from/iter_unpack/calcsize / Struct.__dict__.__contains__ for pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct_extra82.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ / Struct.__name__/__qualname__/__bases__[0].__name__/__mro__.__len__() (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra84; it does NOT duplicate invariants present in those files."
    - "Wave 255 theme: struct.Struct and struct.error type identity — __class__.__name__, docstring class names, and Struct method class names."
    - "struct.Struct.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__doc__ is None (NoneType) — struct.error has no docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__module__ == '_struct' (the C extension). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct/__class__/__name__.__eq__('type')
# struct.Struct/__doc__/__class__/__name__.__eq__('str')
# struct.Struct.pack/__class__/__name__.__eq__('method_descriptor')
# struct.Struct.unpack/__class__/__name__.__eq__('method_descriptor')
#
# Wave 255 theme: Struct class/doc identity and method class names (group 1).
#
# struct.Struct is a C type, so its __class__.__name__ is 'type'. It has a
# str docstring (__doc__.__class__.__name__ == 'str'). Its methods pack and
# unpack are C-level method_descriptors. No prior struct spec anchors these
# __class__.__name__.__eq__ calls under structtypeid85.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra85.struct_class_doc_identity:
  description: "struct.Struct/__class__.__name__.__eq__('type')==True / Struct/__doc__/__class__.__name__.__eq__('str')==True / Struct.pack/__class__.__name__.__eq__('method_descriptor')==True / Struct.unpack/__class__.__name__.__eq__('method_descriptor')==True — Struct is a C type whose __class__.__name__ is 'type'; it has a str docstring; pack and unpack are C method_descriptor objects; first structtypeid85 anchor for Struct class/doc identity and pack/unpack class names"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structtypeid85

  columns: [id, function, args, expected]
  rows:
    - [struct_class_is_type,     Struct.__class__.__name__.__eq__,          ["type"],              true]
    - [struct_doc_class_str,     Struct.__doc__.__class__.__name__.__eq__,  ["str"],               true]
    - [struct_pack_method_desc,  Struct.pack.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [struct_unpack_method_desc, Struct.unpack.__class__.__name__.__eq__,  ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.Struct.pack_into/__class__/__name__.__eq__('method_descriptor')
# struct.Struct.unpack_from/__class__.__name__.__eq__('method_descriptor')
# struct.Struct.iter_unpack/__class__.__name__.__eq__('method_descriptor')
# struct.Struct/__class__/__name__.__eq__('type') (cross-check)
#
# Wave 255 theme: Struct method class names (group 2).
#
# pack_into, unpack_from, and iter_unpack are all method_descriptor objects
# on struct.Struct, just like pack and unpack. The cross-check repeats Struct
# __class__.__name__ from group 1. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra85.struct_method_class_names:
  description: "struct.Struct.pack_into/__class__.__name__.__eq__('method_descriptor')==True / Struct.unpack_from/__class__.__name__.__eq__('method_descriptor')==True / Struct.iter_unpack/__class__.__name__.__eq__('method_descriptor')==True / Struct/__class__.__name__.__eq__('type')==True — pack_into/unpack_from/iter_unpack are all C method_descriptor objects on struct.Struct (same as pack/unpack); cross-check repeats Struct __class__.__name__=='type'; first structtypeid85 anchor for pack_into/unpack_from/iter_unpack method class names"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structtypeid85

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_into_method_desc,    Struct.pack_into.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [struct_unpack_from_method_desc,  Struct.unpack_from.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [struct_iter_unpack_method_desc,  Struct.iter_unpack.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [struct_class_is_type2,           Struct.__class__.__name__.__eq__,              ["type"],              true]

# ---------------------------------------------------------------------------
# struct.pack/__class__/__name__.__eq__('builtin_function_or_method')
# struct.unpack/__class__/__name__.__eq__('builtin_function_or_method')
# struct.calcsize/__class__.__name__.__eq__('builtin_function_or_method')
# struct.Struct.pack/__class__/__name__.__eq__('method_descriptor') (cross-check)
#
# Wave 255 theme: module-level function class names.
#
# Module-level functions pack, unpack, calcsize are builtin_function_or_method
# objects (not method_descriptor like the Struct instance methods). This table
# anchors all three alongside a cross-check for Struct.pack class name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra85.struct_module_func_class_names:
  description: "struct.pack/__class__.__name__.__eq__('builtin_function_or_method')==True / struct.unpack/__class__.__name__.__eq__('builtin_function_or_method')==True / struct.calcsize/__class__.__name__.__eq__('builtin_function_or_method')==True / Struct.pack/__class__.__name__.__eq__('method_descriptor')==True — module-level pack/unpack/calcsize are builtin_function_or_method (not method_descriptor); Struct.pack is method_descriptor; cross-check distinguishes the two class types; first structtypeid85 anchor for module function class names"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structtypeid85

  columns: [id, function, args, expected]
  rows:
    - [mod_pack_builtin,    pack.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [mod_unpack_builtin,  unpack.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [mod_calcsize_builtin, calcsize.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [struct_pack_method3, Struct.pack.__class__.__name__.__eq__, ["method_descriptor"],        true]

# ---------------------------------------------------------------------------
# struct.error/__class__/__name__.__eq__('type')
# struct.error/__module__.__eq__('struct')
# struct.error/__name__.__eq__('error')
# struct.error/__bases__[0]/__name__.__eq__('Exception')
#
# Wave 255 theme: struct.error type identity.
#
# struct.error is a Python exception class (type). Its __class__.__name__ is
# 'type', __module__ is 'struct', __name__ is 'error', and it inherits from
# Exception. Its __doc__ is None (not a str). This table anchors the identity
# facts about struct.error (excluding the None __doc__).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra85.struct_error_identity:
  description: "struct.error/__class__.__name__.__eq__('type')==True / error/__module__.__eq__('struct')==True / error/__name__.__eq__('error')==True / error/__bases__[0]/__name__.__eq__('Exception')==True — struct.error is a Python exception class inheriting from Exception; its __class__.__name__ is 'type', __module__ is 'struct', __name__ is 'error', __bases__[0] is Exception; __doc__ is None (no docstring); first structtypeid85 anchor for struct.error type identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structtypeid85

  columns: [id, function, args, expected]
  rows:
    - [error_class_is_type,     error.__class__.__name__.__eq__,        ["type"],      true]
    - [error_module_eq,         error.__module__.__eq__,                 ["struct"],    true]
    - [error_name_eq,           error.__name__.__eq__,                   ["error"],     true]
    - [error_bases_exception,   "error.__bases__[0].__name__.__eq__",    ["Exception"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__class__.__name__.__eq__('type') — standalone
#
# struct.Struct is a C type; its __class__.__name__ is 'type'. No prior struct
# spec anchors Struct.__class__.__name__.__eq__ under this id_prefix.
# First __class__.__name__.__eq__('type') standalone for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra85.struct_class_is_type:
  description: "struct.Struct.__class__.__name__.__eq__('type') == True — Struct is a C type (not a Python class); its __class__ is 'type'; no prior struct spec anchors Struct.__class__.__name__.__eq__ under structtypeid85; first standalone for Struct type identity"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.Struct has a str docstring. Its __doc__.__class__.__name__ is 'str'.
# No prior struct spec anchors Struct.__doc__.__class__.__name__.__eq__ as a call.
# First __doc__.__class__.__name__.__eq__ standalone for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra85.struct_doc_class_str:
  description: "struct.Struct.__doc__.__class__.__name__.__eq__('str') == True — Struct has a C-level str docstring describing its purpose and format string syntax; __doc__.__class__.__name__ is 'str'; first standalone for struct.Struct __doc__ class identity under structtypeid85"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.iter_unpack is a C method_descriptor. Its __class__.__name__
# is 'method_descriptor'. No prior struct spec anchors this __eq__ call.
# First __class__.__name__.__eq__ standalone for struct.Struct.iter_unpack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra85.struct_iter_unpack_method_desc:
  description: "struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor') == True — Struct.iter_unpack is a C-level method_descriptor (same as pack/unpack/pack_into/unpack_from); no prior struct spec anchors this __eq__ call; first standalone for struct.Struct.iter_unpack class identity under structtypeid85"
  category: class_attrs
  kind: python_call_eq
  function: Struct.iter_unpack.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__class__.__name__.__eq__('type') — standalone
#
# struct.error is a Python exception class; its __class__.__name__ is 'type'.
# No prior struct spec anchors error.__class__.__name__.__eq__ as a call.
# First __class__.__name__.__eq__ standalone for struct.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra85.struct_error_class_is_type:
  description: "struct.error.__class__.__name__.__eq__('type') == True — struct.error is a Python class (its metaclass is type); __class__.__name__ is 'type'; struct_extra84 anchors error.__name__.__len__() but not __class__.__name__.__eq__; first standalone for struct.error class identity under structtypeid85"
  category: class_attrs
  kind: python_call_eq
  function: error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error inherits from Exception. Its __bases__[0].__name__ is 'Exception'.
# No prior struct spec anchors error.__bases__[0].__name__.__eq__ as a call.
# First __bases__[0].__name__.__eq__ standalone for struct.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra85.struct_error_bases_exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error directly inherits from Exception (not from OSError or ValueError); its __bases__[0].__name__ is 'Exception'; first __bases__[0].__name__.__eq__ standalone for struct.error under structtypeid85"
  category: class_attrs
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
