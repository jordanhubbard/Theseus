  id_prefix: re554fn

  columns: [id, function, args, expected]
  rows:
    - [re554fn001, re.RegexFlag.IGNORECASE.name.__eq__, ["IGNORECASE"], true]
    - [re554fn002, re.RegexFlag.MULTILINE.name.__eq__,  ["MULTILINE"],  true]
    - [re554fn003, re.RegexFlag.DOTALL.name.__eq__,     ["DOTALL"],     true]
    - [re554fn004, re.RegexFlag.UNICODE.name.__eq__,    ["UNICODE"],    true]
    - [re554fn005, re.RegexFlag.VERBOSE.name.__eq__,    ["VERBOSE"],    true]
    - [re554fn006, re.RegexFlag.ASCII.name.__eq__,      ["ASCII"],      true]
