error_model: python_exceptions

table re_extra554.regexflag_class_identity:
  description: "re.RegexFlag member __class__.__name__ == 'RegexFlag' — ASCII, LOCALE, VERBOSE"
  kind: python_call_eq
  category: enum_class_identity
  id_prefix: re554ci

  columns: [id, function, args, expected]
  rows:
    - [re554ci001, re.RegexFlag.ASCII.__class__.__name__.__eq__,   ["RegexFlag"], true]
    - [re554ci002, re.RegexFlag.LOCALE.__class__.__name__.__eq__,  ["RegexFlag"], true]
    - [re554ci003, re.RegexFlag.VERBOSE.__class__.__name__.__eq__, ["RegexFlag"], true]

table re_extra554.regexflag_values:
  description: "re.RegexFlag member integer values — ASCII=256, LOCALE=4, VERBOSE=64"
  kind: python_call_eq
  category: enum_values
  id_prefix: re554fv

  columns: [id, function, args, expected]
  rows:
    - [re554fv001, re.RegexFlag.ASCII.value.__eq__,   [256], true]
    - [re554fv002, re.RegexFlag.LOCALE.value.__eq__,  [4],   true]
    - [re554fv003, re.RegexFlag.VERBOSE.value.__eq__, [64],  true]

table re_extra554.regexflag_names:
  description: "re.RegexFlag member .name strings — IGNORECASE, MULTILINE, DOTALL, UNICODE, VERBOSE, ASCII"
