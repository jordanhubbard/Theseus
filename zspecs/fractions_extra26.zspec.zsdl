spec: fractions_extra26
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra25.zspec.zsdl."
    - "Prior specs covered: __mro__.__len__() (6), __bases__[0].__name__ ('Rational'), __abstractmethods__.__len__() (0), operator __qualname__.__len__() for __add__/__mul__/__truediv__ (45) and __eq__/__lt__ (15), __hash__.__qualname__.__len__() (17)."
    - "This spec covers: fractions module-level attributes (__name__, __doc__.__class__.__name__, __all__) and their lengths; Fraction.__qualname__.__len__() (8); Fraction.__dict__.__class__.__name__.__len__() (12); Fraction.__new__.__qualname__.__len__() (16); Fraction.limit_denominator/__qualname__.__len__() (26); Fraction.from_float/__qualname__.__len__() (19); Fraction.from_decimal/__qualname__.__len__() (21); Fraction.numerator.fget.__qualname__.__len__() (18); Fraction.denominator.fget.__qualname__.__len__() (20)."
    - "fractions.__all__ == ['Fraction'] — length 1, class 'list'."
    - "Fraction.__init__.__qualname__ == 'object.__init__' (15 chars) — Fraction does not override __init__, inherits from object."
    - "Fraction.__new__.__qualname__ == 'Fraction.__new__' (16 chars) — Fraction defines __new__ for construction."
    - "Fraction.numerator and Fraction.denominator are property objects; their fget qualnames are 'Fraction.numerator' (18) and 'Fraction.denominator' (20)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# fractions module-level identity attributes
#
# fractions.__name__ == 'fractions' (9 chars). fractions.__doc__ is a str
# (class name len == 3). fractions.__all__ == ['Fraction'] — a list of
# length 1. No prior fractions spec records these module-level attributes.
# ---------------------------------------------------------------------------

invariant fractions_extra26.module.name_len:
  description: "len(fractions.__name__) == 9 — 'fractions' is 9 chars"
  category: module_identity
  kind: python_call_eq
  function: fractions.__name__.__len__
  args: []
  expected: 9

invariant fractions_extra26.module.doc_class_name_len:
  description: "len(fractions.__doc__.__class__.__name__) == 3 — docstring is a 'str'"
  category: module_identity
  kind: python_call_eq
  function: fractions.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant fractions_extra26.module.all_len:
  description: "len(fractions.__all__) == 1 — only 'Fraction' is exported"
  category: module_identity
  kind: python_call_eq
  function: fractions.__all__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Fraction class-level identity — __qualname__, __dict__ class
#
# Fraction.__qualname__ == 'Fraction' (8 chars) — a top-level class so no
# nesting prefix. Fraction.__dict__ is a mappingproxy (12 chars). No prior
# fractions spec records __qualname__.__len__() for the class itself, or
# __dict__.__class__.__name__.__len__().
# ---------------------------------------------------------------------------

invariant fractions_extra26.Fraction.qualname_len:
  description: "len(fractions.Fraction.__qualname__) == 8 — 'Fraction' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__qualname__.__len__
  args: []
  expected: 8

invariant fractions_extra26.Fraction.dict_class_name_len:
  description: "len(fractions.Fraction.__dict__.__class__.__name__) == 12 — Fraction.__dict__ is a 'mappingproxy'"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Fraction constructor qualnames: __new__ and __init__
#
# Fraction defines __new__ for object construction (qualname 'Fraction.__new__',
# 16 chars). It does NOT override __init__ — Fraction.__init__.__qualname__
# resolves to 'object.__init__' (15 chars), inherited from object. No prior
# fractions spec records either of these qualname lengths.
# ---------------------------------------------------------------------------

invariant fractions_extra26.Fraction.new_qualname_len:
  description: "len(fractions.Fraction.__new__.__qualname__) == 16 — 'Fraction.__new__' is 16 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Fraction.__new__.__qualname__.__len__
  args: []
  expected: 16

invariant fractions_extra26.Fraction.init_qualname_len:
  description: "len(fractions.Fraction.__init__.__qualname__) == 15 — inherits 'object.__init__' (15 chars)"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Fraction.__init__.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# Fraction classmethod and regular method __qualname__.__len__() table
#
# limit_denominator, from_float, from_decimal — all directly defined methods
# with qualnames 'Fraction.limit_denominator' (26), 'Fraction.from_float' (19),
# 'Fraction.from_decimal' (21). No prior fractions spec records these lengths.
# ---------------------------------------------------------------------------

table fractions_extra26.method_qualname_lens:
  description: "__qualname__.__len__() for Fraction instance and class methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: mqlen26

  columns: [id, function, args, expected, description]
  rows:
    - [limit_denominator,
       "Fraction.limit_denominator.__qualname__.__len__",
       [],
       26,
       "Fraction.limit_denominator.__qualname__ == 'Fraction.limit_denominator' (26 chars)"]
    - [from_float,
       "Fraction.from_float.__qualname__.__len__",
       [],
       19,
       "Fraction.from_float.__qualname__ == 'Fraction.from_float' (19 chars)"]
    - [from_decimal,
       "Fraction.from_decimal.__qualname__.__len__",
       [],
       21,
       "Fraction.from_decimal.__qualname__ == 'Fraction.from_decimal' (21 chars)"]

# ---------------------------------------------------------------------------
# Fraction property fget __qualname__.__len__() — numerator and denominator
#
# Fraction.numerator and Fraction.denominator are property objects. Their
# getter functions have qualnames 'Fraction.numerator' (18 chars) and
# 'Fraction.denominator' (20 chars). Accessed via .fget. No prior fractions
# spec records these lengths.
# ---------------------------------------------------------------------------

invariant fractions_extra26.Fraction.numerator_fget_qualname_len:
  description: "len(fractions.Fraction.numerator.fget.__qualname__) == 18 — 'Fraction.numerator' is 18 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Fraction.numerator.fget.__qualname__.__len__
  args: []
  expected: 18

invariant fractions_extra26.Fraction.denominator_fget_qualname_len:
  description: "len(fractions.Fraction.denominator.fget.__qualname__) == 20 — 'Fraction.denominator' is 20 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Fraction.denominator.fget.__qualname__.__len__
  args: []
  expected: 20
