spec: dataclasses_extra26
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra25.zspec.zsdl."
    - "Focus: __qualname__ values for top-level dataclasses module functions (dataclass, field, asdict, astuple, make_dataclass, replace, is_dataclass, fields) in the extra26 namespace."
    - "dataclasses_extra25 covers Field instance method qualnames (Field.__set_name__, Field.__repr__, Field.__init__) and sentinel type metadata."
    - "No prior dataclasses spec records the __qualname__ values for dataclass/field/asdict/astuple/make_dataclass/replace/is_dataclass/fields as a combined table in any namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dataclasses module-level function __qualname__ values — combined table
#
# All eight functions are defined at module level in dataclasses; each has
# __qualname__ equal to its own function name (simple, no class prefix).
# No prior dataclasses spec has all eight together in a combined __qualname__
# table in any spec namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra26.function_qualnames:
  description: "__qualname__.__eq__ for dataclasses module-level functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__qualname__.__eq__,      ["dataclass"],      true]
    - [field,          field.__qualname__.__eq__,          ["field"],          true]
    - [asdict,         asdict.__qualname__.__eq__,         ["asdict"],         true]
    - [astuple,        astuple.__qualname__.__eq__,        ["astuple"],        true]
    - [make_dataclass, make_dataclass.__qualname__.__eq__, ["make_dataclass"], true]
    - [replace,        replace.__qualname__.__eq__,        ["replace"],        true]
    - [is_dataclass,   is_dataclass.__qualname__.__eq__,   ["is_dataclass"],   true]
    - [fields,         fields.__qualname__.__eq__,         ["fields"],         true]

# ---------------------------------------------------------------------------
# dataclasses module-level function __qualname__.__len__() — combined table
#
# Verifies the string length of each function __qualname__:
#   dataclass -> 9, field -> 5, asdict -> 6, astuple -> 7,
#   make_dataclass -> 14, replace -> 7, is_dataclass -> 12, fields -> 6
# No prior dataclasses spec collects these eight qualname lengths together.
# ---------------------------------------------------------------------------

table dataclasses_extra26.function_qualname_lens:
  description: "__qualname__.__len__() for dataclasses module-level functions"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__qualname__.__len__,       [],  9]
    - [field,          field.__qualname__.__len__,           [],  5]
    - [asdict,         asdict.__qualname__.__len__,          [],  6]
    - [astuple,        astuple.__qualname__.__len__,         [],  7]
    - [make_dataclass, make_dataclass.__qualname__.__len__,  [], 14]
    - [replace,        replace.__qualname__.__len__,         [],  7]
    - [is_dataclass,   is_dataclass.__qualname__.__len__,    [], 12]
    - [fields,         fields.__qualname__.__len__,          [],  6]
