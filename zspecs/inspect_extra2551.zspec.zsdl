spec: inspect_extra2551
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2551 (_extra2551): __reduce__, __reduce_ex__, __getnewargs__ dict-presence checks."
    - "inspect.Parameter and inspect.Signature define __reduce__ (explicit pickling support)."
    - "inspect namedtuple types (FullArgSpec, ArgInfo, Arguments, Attribute, ClosureVars) define __getnewargs__ via namedtuple machinery but NOT __reduce__ or __reduce_ex__."
    - "inspect.BoundArguments and inspect.FrameInfo define none of the three pickling dunders."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __reduce__ dict-presence for inspect classes
#
# inspect.Parameter and inspect.Signature each define __reduce__ explicitly
# to support pickling of introspection objects.
# inspect.BoundArguments, inspect.FrameInfo define no __reduce__.
# Namedtuple-derived types (FullArgSpec, ArgInfo, etc.) also lack __reduce__
# in their own __dict__ — they rely on tuple's pickling path instead.
# ---------------------------------------------------------------------------

table inspect_extra2551.reduce_protocol:
  description: "inspect classes __reduce__ dict-presence checks — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2551

  columns: [id, function, args, expected]
  rows:
    - ["in2551001", "inspect.Parameter.__dict__.__contains__", ["__reduce__"], true]
    - ["in2551002", "inspect.Signature.__dict__.__contains__", ["__reduce__"], true]
    - ["in2551003", "inspect.BoundArguments.__dict__.__contains__", ["__reduce__"], false]
    - ["in2551004", "inspect.FrameInfo.__dict__.__contains__", ["__reduce__"], false]
    - ["in2551005", "inspect.FullArgSpec.__dict__.__contains__", ["__reduce__"], false]
    - ["in2551006", "inspect.ArgInfo.__dict__.__contains__", ["__reduce__"], false]
    - ["in2551007", "inspect.Arguments.__dict__.__contains__", ["__reduce__"], false]
    - ["in2551008", "inspect.Attribute.__dict__.__contains__", ["__reduce__"], false]
    - ["in2551009", "inspect.ClosureVars.__dict__.__contains__", ["__reduce__"], false]

# ---------------------------------------------------------------------------
# Table 2: __reduce_ex__ dict-presence for inspect classes
#
# No inspect class defines __reduce_ex__ in its own __dict__.
# __reduce_ex__ is inherited from object (or tuple for namedtuples).
# ---------------------------------------------------------------------------

table inspect_extra2551.reduce_ex_protocol:
  description: "inspect classes __reduce_ex__ dict-presence checks — all False — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2551

  columns: [id, function, args, expected]
  rows:
    - ["in2551010", "inspect.Parameter.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["in2551011", "inspect.Signature.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["in2551012", "inspect.BoundArguments.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["in2551013", "inspect.FrameInfo.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["in2551014", "inspect.FullArgSpec.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["in2551015", "inspect.ArgInfo.__dict__.__contains__", ["__reduce_ex__"], false]

# ---------------------------------------------------------------------------
# Table 3: __getnewargs__ dict-presence for inspect classes
#
# inspect namedtuple subclasses (FullArgSpec, ArgInfo, Arguments, Attribute,
# ClosureVars) each receive __getnewargs__ from the namedtuple factory.
# inspect.Parameter, inspect.Signature, inspect.BoundArguments, and
# inspect.FrameInfo do NOT define __getnewargs__.
# ---------------------------------------------------------------------------

table inspect_extra2551.getnewargs_protocol:
  description: "inspect classes __getnewargs__ dict-presence checks — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2551

  columns: [id, function, args, expected]
  rows:
    - ["in2551016", "inspect.FullArgSpec.__dict__.__contains__", ["__getnewargs__"], true]
    - ["in2551017", "inspect.ArgInfo.__dict__.__contains__", ["__getnewargs__"], true]
    - ["in2551018", "inspect.Arguments.__dict__.__contains__", ["__getnewargs__"], true]
    - ["in2551019", "inspect.Attribute.__dict__.__contains__", ["__getnewargs__"], true]
    - ["in2551020", "inspect.ClosureVars.__dict__.__contains__", ["__getnewargs__"], true]
    - ["in2551021", "inspect.Parameter.__dict__.__contains__", ["__getnewargs__"], false]
    - ["in2551022", "inspect.Signature.__dict__.__contains__", ["__getnewargs__"], false]
    - ["in2551023", "inspect.BoundArguments.__dict__.__contains__", ["__getnewargs__"], false]
    - ["in2551024", "inspect.FrameInfo.__dict__.__contains__", ["__getnewargs__"], false]
