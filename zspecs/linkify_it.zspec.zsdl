spec: linkify_it
version: ">=5.0.0"
backend: node(linkify-it)

docs: https://github.com/markdown-it/linkify-it#readme

provenance:
  derived_from:
    - "linkify-it README — https://github.com/markdown-it/linkify-it#readme"
    - "Test vectors verified with linkify-it via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "linkify-it source"
  notes:
    - "linkify-it detects URL/email patterns inside text — used by markdown-it's autolink feature."
    - "Install: npm install linkify-it"
    - "Module export IS the constructor; new Linkify().match(text) returns array of {schema, index, lastIndex, raw, text, url} or null."
    - ".test(text) is a fast boolean predicate."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure operations; .match returns null when nothing detected."
  stderr: "null"
  stickiness: "N/A — Linkify instance is reusable."
  codes: {}

# .test() — predicate
invariant linkify_it.test_url_detected:
  description: ".test() returns true for text containing a URL"
  category: test
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: test, args: ["Visit https://example.com today"]}
  expected: true

invariant linkify_it.test_email_detected:
  description: ".test() returns true for text containing an email"
  category: test
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: test, args: ["Contact alice@example.com"]}
  expected: true

invariant linkify_it.test_plain_text_false:
  description: ".test() returns false for plain text without URLs/emails"
  category: test
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: test, args: ["just plain text here"]}
  expected: false

# .match() — extracts URL details
invariant linkify_it.match_https_url:
  description: ".match() captures https URL"
  category: match
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: match, args: ["Visit https://example.com today"]}
    - {method: at, args: [0]}
    - {get: url}
  expected: "https://example.com"

invariant linkify_it.match_email:
  description: ".match() captures email and prepends mailto: scheme in the .url field"
  category: match
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: match, args: ["Contact alice@example.com"]}
    - {method: at, args: [0]}
    - {get: url}
  expected: "mailto:alice@example.com"

invariant linkify_it.match_returns_null_when_no_links:
  description: ".match() returns null for text without any URL/email"
  category: match
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: match, args: ["plain text"]}
  expected: ~

invariant linkify_it.match_index:
  description: "Match.index reports the byte offset of the URL in the source text"
  category: match
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: match, args: ["Visit https://example.com today"]}
    - {method: at, args: [0]}
    - {get: index}
  expected: 6

invariant linkify_it.match_returns_array_length_one:
  description: "Single-URL text yields a one-element match array"
  category: match
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: match, args: ["see https://a.com only"]}
    - {get: length}
  expected: 1

invariant linkify_it.match_two_urls:
  description: "Text with two URLs yields a two-element match array"
  category: match
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: match, args: ["one https://a.com and two https://b.com"]}
    - {get: length}
  expected: 2

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:15:56Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
