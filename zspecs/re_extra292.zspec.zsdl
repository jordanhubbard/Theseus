spec: re_extra292
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module __all__ membership for functions, classes, and flags"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "len(re.__all__) verified as 30 on CPython 3.12+"
    - "Flag short aliases (I, L, M, S, X, U, A) are present in re.__all__"
    - "RegexFlag enum class is present in re.__all__ since Python 3.6"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table re_extra292.all_core_functions:
  description: "re.__all__ membership for core function names"
  kind: python_call_eq
  category: identity
  id_prefix: rex292

  columns: [id, function, args, expected, description]
  rows:
    - [rex292_001, re.__all__.__contains__, ["compile"], true, "'compile' in re.__all__"]
    - [rex292_002, re.__all__.__contains__, ["match"], true, "'match' in re.__all__"]
    - [rex292_003, re.__all__.__contains__, ["fullmatch"], true, "'fullmatch' in re.__all__"]
    - [rex292_004, re.__all__.__contains__, ["search"], true, "'search' in re.__all__"]
    - [rex292_005, re.__all__.__contains__, ["sub"], true, "'sub' in re.__all__"]
    - [rex292_006, re.__all__.__contains__, ["subn"], true, "'subn' in re.__all__"]
    - [rex292_007, re.__all__.__contains__, ["split"], true, "'split' in re.__all__"]
    - [rex292_008, re.__all__.__contains__, ["findall"], true, "'findall' in re.__all__"]
    - [rex292_009, re.__all__.__contains__, ["finditer"], true, "'finditer' in re.__all__"]
    - [rex292_010, re.__all__.__contains__, ["purge"], true, "'purge' in re.__all__"]
    - [rex292_011, re.__all__.__contains__, ["escape"], true, "'escape' in re.__all__"]

table re_extra292.all_classes_and_flags:
  description: "re.__all__ membership for classes and flag aliases"
  kind: python_call_eq
  category: identity
  id_prefix: rex292f

  columns: [id, function, args, expected, description]
  rows:
    - [rex292f_001, re.__all__.__contains__, ["error"], true, "'error' in re.__all__"]
    - [rex292f_002, re.__all__.__contains__, ["Pattern"], true, "'Pattern' in re.__all__"]
    - [rex292f_003, re.__all__.__contains__, ["Match"], true, "'Match' in re.__all__"]
    - [rex292f_004, re.__all__.__contains__, ["RegexFlag"], true, "'RegexFlag' in re.__all__"]
    - [rex292f_005, re.__all__.__contains__, ["I"], true, "'I' (IGNORECASE short) in re.__all__"]
    - [rex292f_006, re.__all__.__contains__, ["L"], true, "'L' (LOCALE short) in re.__all__"]
    - [rex292f_007, re.__all__.__contains__, ["M"], true, "'M' (MULTILINE short) in re.__all__"]
    - [rex292f_008, re.__all__.__contains__, ["S"], true, "'S' (DOTALL short) in re.__all__"]
    - [rex292f_009, re.__all__.__contains__, ["X"], true, "'X' (VERBOSE short) in re.__all__"]
    - [rex292f_010, re.__all__.__contains__, ["U"], true, "'U' (UNICODE short) in re.__all__"]
    - [rex292f_011, re.__all__.__contains__, ["A"], true, "'A' (ASCII short) in re.__all__"]

invariant re_extra292.inv_all_len:
  description: "len(re.__all__) is 30"
  category: identity
  kind: python_call_eq
  function: re.__all__.__len__
  args: []
  expected: 30

invariant re_extra292.inv_ignorecase_in_all:
  description: "'IGNORECASE' in re.__all__"
  category: identity
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["IGNORECASE"]
  expected: true

invariant re_extra292.inv_multiline_in_all:
  description: "'MULTILINE' in re.__all__"
  category: identity
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["MULTILINE"]
  expected: true

invariant re_extra292.inv_dotall_in_all:
  description: "'DOTALL' in re.__all__"
  category: identity
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["DOTALL"]
  expected: true

invariant re_extra292.inv_verbose_in_all:
  description: "'VERBOSE' in re.__all__"
  category: identity
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["VERBOSE"]
  expected: true
