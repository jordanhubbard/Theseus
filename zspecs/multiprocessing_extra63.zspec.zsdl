spec: multiprocessing_extra63
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_varnames, co_filename, and co_flags documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra62.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__len__() tables, Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), Pool/__doc__/__class__/__module__=='builtins' (extra50), Pool/__class__.__name__=='type', Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins') (extra53), Process/__init__.__class__.__name__.__eq__('function') (extra53), Process/Pool __repr__.__class__.__name__ (extra54), Process __weakref__.__class__.__name__ (extra54), ProcessError/AuthenticationError exception __repr__.__class__.__name__ (extra54), mp.__all__.__class__.__name__.__eq__('list') (extra55), mp.__all__.__len__()==37 (extra55), Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra55), mp.__all__.__contains__ membership checks (extra56), mp.__package__.__eq__('multiprocessing') (extra56), Queue/Pool __doc__.__class__.__name__.__eq__('str') (extra56), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra57), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra58), Process method __qualname__ string equality for start/run/join/terminate/kill/is_alive/close/interrupt (extra59), Process.__init__/__annotations__/__globals__ class identity + current_process __annotations__ class identity and len (extra60), Process.__init__/__defaults__/__code__/__class__.__name__ checks, current_process/__defaults__/__code__/__class__.__name__ checks (extra61), Process.__init__/Process.start/current_process __code__.co_name equality and co_argcount values (extra62)."
    - "This spec covers (mpcode3_63 namespace): wave 231 theme — __code__.co_varnames, co_filename, co_flags attribute chains. NEW in extra63: Process.__init__.__code__.co_varnames.__class__.__name__=='tuple' — co_varnames is always a tuple; current_process.__code__.co_varnames.__class__.__name__=='tuple'; Process.__init__.__code__.co_varnames[0]=='self' — BaseProcess.__init__(self, group=None, ...) so first co_varnames entry is 'self'; Process.start.__code__.co_varnames[0]=='self' — Process.start(self) so first is 'self'; Process.__init__/Process.start/current_process co_filename.__contains__('.py')==True; Process.__init__/Process.start/current_process co_flags.__class__.__name__=='int'."
    - "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is a tuple of strings naming all local variables in definition order. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_varnames[0] == 'self'. BaseProcess.__init__ is defined as 'def __init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None)' — self is the first parameter so co_varnames[0]=='self'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__code__.co_varnames[0] == 'self'. Process.start(self) — self is the only parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_filename.__contains__('.py') == True. co_filename stores the absolute path to the pure-Python source file. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_flags.__class__.__name__ == 'int'. co_flags is a bitmask integer encoding code-object properties. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_varnames.__class__.__name__ checks — extra63
#
# Wave 231 theme: co_varnames type identity.
#
# co_varnames is always a tuple of strings on every code object.
# tuple.__class__.__name__ == 'tuple'.
# ---------------------------------------------------------------------------

table multiprocessing_extra63.co_varnames_class_name:
  description: "multiprocessing __code__.co_varnames.__class__.__name__.__eq__('tuple') checks in mpcode3_63 namespace — wave 231 theme: co_varnames type identity; co_varnames is always a tuple on all code objects; Process.__init__ and current_process have co_varnames.__class__.__name__=='tuple'; NEW in extra63: no prior mp spec has checked __code__.co_varnames.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode3_63

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_varnames_class,    Process.__init__.__code__.co_varnames.__class__.__name__.__eq__,    ["tuple"], true, "Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of strings naming all local variables in the code object; Process.__init__.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: first co_varnames.__class__.__name__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [current_process_co_varnames_class, current_process.__code__.co_varnames.__class__.__name__.__eq__,    ["tuple"], true, "current_process.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; current_process.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: first co_varnames.__class__.__name__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_varnames[0] first-argument checks — extra63
#
# Wave 231 theme: first entry in co_varnames.
#
# co_varnames lists arguments first, in definition order:
#   Process.__init__(self, group=None, ...) → co_varnames[0] == 'self'
#   Process.start(self) → co_varnames[0] == 'self'
#
# Table row function values containing '[' MUST be double-quoted in YAML.
# ---------------------------------------------------------------------------

table multiprocessing_extra63.co_varnames_first_arg:
  description: "multiprocessing __code__.co_varnames[0].__eq__ checks in mpcode3_63 namespace — wave 231 theme: first co_varnames entry; Process.__init__ co_varnames[0]=='self', Process.start co_varnames[0]=='self'; arguments appear in co_varnames in definition order; NEW in extra63: no prior mp spec has checked co_varnames[0].__eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode3_63a

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_varnames_first,  "Process.__init__.__code__.co_varnames[0].__eq__", ["self"], true, "Process.__init__.__code__.co_varnames[0] == 'self' — BaseProcess.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None); self is the first parameter; co_varnames lists arguments first in definition order; co_varnames[0] is 'self'; __eq__('self') returns True; NEW in extra63: first co_varnames[0] check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [process_start_co_varnames_first, "Process.start.__code__.co_varnames[0].__eq__",   ["self"], true, "Process.start.__code__.co_varnames[0] == 'self' — Process.start(self); self is the only parameter; co_varnames[0] is 'self'; __eq__('self') returns True; NEW in extra63: first co_varnames[0] check for Process.start in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_filename.__contains__('.py') checks — extra63
#
# Wave 231 theme: co_filename membership check.
#
# co_filename stores the absolute path to the .py source file. All
# multiprocessing process functions are implemented in pure Python, so
# co_filename always contains '.py'.
# ---------------------------------------------------------------------------

table multiprocessing_extra63.co_filename_contains_py:
  description: "multiprocessing __code__.co_filename.__contains__('.py') checks in mpcode3_63 namespace — wave 231 theme: co_filename membership; Process.__init__/Process.start/current_process all have co_filename containing '.py'; co_filename is the absolute path to the pure-Python source file; NEW in extra63: no prior mp spec has checked __code__.co_filename.__contains__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode3_63b

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_filename_py,    Process.__init__.__code__.co_filename.__contains__,    [".py"], true, "Process.__init__.__code__.co_filename.__contains__('.py') == True — co_filename stores the absolute path to the source .py file; multiprocessing.Process.__init__ (BaseProcess.__init__) is implemented in Lib/multiprocessing/process.py; the filename contains '.py'; NEW in extra63: first co_filename membership check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [process_start_co_filename_py,   Process.start.__code__.co_filename.__contains__,       [".py"], true, "Process.start.__code__.co_filename.__contains__('.py') == True — multiprocessing.Process.start is implemented in a pure-Python .py file (Lib/multiprocessing/process.py); the filename contains '.py'; NEW in extra63: first co_filename membership check for Process.start in any mp spec; verified with Python 3.14.3"]
    - [current_process_co_filename_py, current_process.__code__.co_filename.__contains__,     [".py"], true, "current_process.__code__.co_filename.__contains__('.py') == True — multiprocessing.current_process is implemented in Lib/multiprocessing/process.py; the filename contains '.py'; NEW in extra63: first co_filename membership check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_flags.__class__.__name__ checks — extra63
#
# Wave 231 theme: co_flags type identity.
#
# co_flags is a bitmask integer encoding properties of the code object
# (CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS, etc.).
# It is always a plain Python int. int.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table multiprocessing_extra63.co_flags_class_name:
  description: "multiprocessing __code__.co_flags.__class__.__name__.__eq__('int') checks in mpcode3_63 namespace — wave 231 theme: co_flags type identity; co_flags is a bitmask int encoding code-object properties; Process.__init__/Process.start/current_process all have co_flags.__class__.__name__=='int'; NEW in extra63: no prior mp spec has checked __code__.co_flags.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode3_63c

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_flags_class,    Process.__init__.__code__.co_flags.__class__.__name__.__eq__,    ["int"], true, "Process.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a bitmask integer encoding properties of the code object; Process.__init__.__code__.co_flags is an int; int.__class__.__name__ is 'int'; NEW in extra63: first co_flags.__class__.__name__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [process_start_co_flags_class,   Process.start.__code__.co_flags.__class__.__name__.__eq__,      ["int"], true, "Process.start.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always an int; Process.start.__code__.co_flags is an int; int.__class__.__name__ is 'int'; NEW in extra63: first co_flags.__class__.__name__ check for Process.start in any mp spec; verified with Python 3.14.3"]
    - [current_process_co_flags_class, current_process.__code__.co_flags.__class__.__name__.__eq__,    ["int"], true, "current_process.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always an int; current_process.__code__.co_flags is an int; int.__class__.__name__ is 'int'; NEW in extra63: first co_flags.__class__.__name__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra63
# ---------------------------------------------------------------------------

invariant multiprocessing_extra63.process_init_co_varnames_tuple:
  description: "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — co_varnames is a tuple of strings naming all local variables in the code object; Process.__init__.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: no prior mp spec has checked Process.__init__.__code__.co_varnames.__class__.__name__ via __eq__; wave 231 first co_varnames type identity invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant multiprocessing_extra63.process_init_co_varnames_self:
  description: "multiprocessing.Process.__init__.__code__.co_varnames[0].__eq__('self') returns True — BaseProcess.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None); self is the first parameter; co_varnames lists arguments first so co_varnames[0]=='self'; NEW in extra63: no prior mp spec has checked Process.__init__.__code__.co_varnames[0] via __eq__; wave 231 first co_varnames first-entry invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: "Process.__init__.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

invariant multiprocessing_extra63.process_start_co_varnames_self:
  description: "multiprocessing.Process.start.__code__.co_varnames[0].__eq__('self') returns True — Process.start(self); self is the only parameter; co_varnames[0]=='self'; __eq__('self') returns True; NEW in extra63: no prior mp spec has checked Process.start.__code__.co_varnames[0] via __eq__; wave 231 first co_varnames first-entry invariant for Process.start; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: "Process.start.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

invariant multiprocessing_extra63.process_init_co_filename_contains_py:
  description: "multiprocessing.Process.__init__.__code__.co_filename.__contains__('.py') returns True — co_filename stores the absolute path to the source .py file; Process.__init__ (BaseProcess.__init__) is implemented in Lib/multiprocessing/process.py; the filename contains '.py'; NEW in extra63: no prior mp spec has checked Process.__init__.__code__.co_filename.__contains__ via invariant; wave 231 first co_filename membership invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_filename.__contains__
  args: [".py"]
