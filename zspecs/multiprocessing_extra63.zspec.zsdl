invariant multiprocessing_extra63.process_init_co_flags_int:
  description: "multiprocessing.Process.__init__.__code__.co_flags.__class__.__name__.__eq__('int') returns True — co_flags is a bitmask integer encoding code-object properties (CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS, etc.); Process.__init__.__code__.co_flags is a plain Python int; int.__class__.__name__ is 'int'; NEW in extra63: no prior mp spec has checked Process.__init__.__code__.co_flags.__class__.__name__ via __eq__; wave 231 first co_flags type identity invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_flags.__class__.__name__.__eq__
