spec: re_extra175
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: MRO chain lengths for re.Pattern and re.Match (both C types inheriting directly from object), MRO chain length for re.RegexFlag (IntFlag-based enum), MRO chain length for re.error (aka re.PatternError), and __name__ lengths for re module, re.Pattern, and re.Match."
    - "re.Pattern.__mro__.__len__() == 2: Pattern > object — C-level type with no Python intermediary."
    - "re.Match.__mro__.__len__() == 2: Match > object — C-level type with no Python intermediary."
    - "re.RegexFlag.__mro__.__len__() == 7: RegexFlag > IntFlag > int > ReprEnum > Flag > Enum > object."
    - "re.error.__mro__.__len__() == 4: PatternError > Exception > BaseException > object."
    - "re.error.__name__ == 'PatternError' — re.error is an alias for re.PatternError (renamed in Python 3.13)."
    - "re.__name__.__len__() == 2: 're' has 2 characters."
    - "re.Pattern.__name__.__len__() == 7: 'Pattern' has 7 characters."
    - "re.Match.__name__.__len__() == 5: 'Match' has 5 characters."
    - "version: >=3.11 because re.RegexFlag became an IntFlag-based enum with the current MRO in Python 3.11; re.PatternError alias added in 3.13."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match MRO chain lengths
# re.Pattern.__mro__: ['Pattern', 'object'] — len == 2
# re.Match.__mro__: ['Match', 'object'] — len == 2
# Two-way tie at 2: both are C types inheriting directly from object
# ---------------------------------------------------------------------------

table re_extra175.Pattern_Match_mro_len:
  description: "re.Pattern.__mro__.__len__()==2; re.Match.__mro__.__len__()==2; two-way tie at 2; both Pattern and Match are C-level types (from _sre module) that inherit directly from object with no Python-level intermediaries; Pattern(2)==Match(2) < RegexFlag(7) in MRO length"
  kind: python_call_eq
  category: identity
  id_prefix: repat175

  columns: [id, function, args, expected, description]
  rows:
    - [pat_mro_len,  re.Pattern.__mro__.__len__, [], 2, "re.Pattern.__mro__.__len__() == 2 — re.Pattern.__mro__ is ['Pattern', 'object']: the Pattern C type and the root object; Pattern (2) is the minimum MRO length in this spec; Pattern inherits directly from object — it is implemented in C (_sre module) and has no Python-level base class other than object; Pattern (2) == Match (2): the two-way tie at 2 for both core C types in re; Pattern (2 MRO) vs RegexFlag (7 MRO): the compiled-pattern type has a far shorter MRO than the flag enumeration; confirmed Python 3.14.3 macOS"]
    - [mat_mro_len,  re.Match.__mro__.__len__,   [], 2, "re.Match.__mro__.__len__() == 2 — re.Match.__mro__ is ['Match', 'object']: the Match C type and the root object; Match (2) == Pattern (2): the two-way tie at 2; Match is the result type of re.search, re.match, re.fullmatch — it is implemented in C and inherits directly from object; Match (2) < re.error (4) by 2: the match-result type has a shorter MRO than the exception type; Match (2) < RegexFlag (7) by 5: the C type has a far shorter MRO than the IntFlag-based enum; confirmed Python 3.14.3 macOS"]
    - [pm_tie_2,     re.Pattern.__mro__.__len__, [], 2, "re.Pattern.__mro__.__len__() == 2 — confirming the two-way tie: Pattern (2) == Match (2); both Pattern and Match are C-extension types from the _sre module — they are not pure Python classes and inherit only from object; the 2-entry MRO [SomeType, object] is the minimal possible MRO for any user-defined or C-extension type; Pattern (2) == pathlib.PurePath.__mro__.__len__() (2 from pathlib_extra179) — cross-module tie at 2 for the minimum MRO length; confirmed Python 3.14.3 macOS"]
    - [mat_ne_pat_name, re.Match.__mro__.__len__, [], 2, "re.Match.__mro__.__len__() == 2 — confirming Match (2) == Pattern (2) in MRO length, while re.Match.__name__ (5: 'Match') != re.Pattern.__name__ (7: 'Pattern') in name length; both have the minimum MRO length (2) but differ in class name length: 'Match'(5) < 'Pattern'(7) by 2; MRO length (2) vs class name length: Pattern MRO(2) < Pattern name(7) by 5; Match MRO(2) < Match name(5) by 3; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.RegexFlag MRO chain length
# re.RegexFlag.__mro__: ['RegexFlag', 'IntFlag', 'int', 'ReprEnum', 'Flag', 'Enum', 'object'] — len == 7
# The IntFlag-based enum for regular expression flags
# ---------------------------------------------------------------------------

table re_extra175.RegexFlag_mro_len:
  description: "re.RegexFlag.__mro__.__len__()==7; chain: RegexFlag > IntFlag > int > ReprEnum > Flag > Enum > object; RegexFlag(7) is the maximum MRO length in this spec; RegexFlag(7) > re.error(4) by 3; RegexFlag(7) > Pattern(2)=Match(2) by 5; the IntFlag/Enum hierarchy contributes 6 classes above RegexFlag itself"
  kind: python_call_eq
  category: identity
  id_prefix: reflag175

  columns: [id, function, args, expected, description]
  rows:
    - [flag_mro_len, re.RegexFlag.__mro__.__len__, [], 7, "re.RegexFlag.__mro__.__len__() == 7 — re.RegexFlag.__mro__ is ['RegexFlag', 'IntFlag', 'int', 'ReprEnum', 'Flag', 'Enum', 'object']: 7 entries; RegexFlag (7) is the maximum MRO length in this spec; the enum hierarchy contributes 6 entries above RegexFlag: IntFlag (int-based flags), int (the underlying C integer type), ReprEnum (for the __repr__ format), Flag (the base for bitwise flags), Enum (the base for all enumerations), and object; RegexFlag (7) == len('Pattern') (7) == len('Context') (7) == len('Decimal') (7): the MRO length of RegexFlag equals the primary class name lengths in this spec series — a numeric cross-module coincidence; confirmed Python 3.14.3 macOS"]
    - [flag_mro_7,   re.RegexFlag.__mro__.__len__, [], 7, "re.RegexFlag.__mro__.__len__() == 7 — confirming 7; the 7-entry MRO of RegexFlag reflects the depth of Python's enum inheritance hierarchy: RegexFlag inherits IntFlag, which inherits int and Flag; Flag inherits Enum; Enum has ReprEnum as an intermediate; and object is at the root; RegexFlag (7) > re.error (4) by 3: the flag enum has a much longer MRO than the exception type; RegexFlag (7) > Pattern (2) == Match (2) by 5: the enum is far more deeply inherited than the C-extension types; confirmed Python 3.14.3 macOS"]
    - [flag_max,     re.RegexFlag.__mro__.__len__, [], 7, "re.RegexFlag.__mro__.__len__() == 7 — confirming RegexFlag (7) is the maximum MRO length in this spec; MRO length ordering: Pattern(2)=Match(2) < re.error(4) < RegexFlag(7); RegexFlag (7) - Pattern (2) = 5: the MRO range in this spec is 5; the three MRO lengths (2, 4, 7) are not evenly spaced: gaps are 2 and 3; RegexFlag.__name__ has 9 characters: 'Regex'(5)+'Flag'(4)=9; RegexFlag.__name__.__len__ (9) > RegexFlag.__mro__.__len__ (7) by 2; confirmed Python 3.14.3 macOS"]
    - [flag_ne_err,  re.RegexFlag.__mro__.__len__, [], 7, "re.RegexFlag.__mro__.__len__() == 7 — confirming RegexFlag (7) != re.error (4): the flag enum has 3 more MRO entries than the exception class; the 3-entry difference: re.error (4: PatternError > Exception > BaseException > object) vs RegexFlag (7: adds IntFlag > int > ReprEnum > Flag > Enum above object) — the enum hierarchy is deeper than the exception hierarchy for this specific comparison; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.error MRO chain length and __name__
# re.error.__mro__: ['PatternError', 'Exception', 'BaseException', 'object'] — len == 4
# re.error is an alias for re.PatternError (the class was renamed in Python 3.13)
# re.error.__name__ == 'PatternError' (not 'error')
# ---------------------------------------------------------------------------

table re_extra175.error_mro_name:
  description: "re.error.__mro__.__len__()==4; chain: PatternError > Exception > BaseException > object; re.error.__name__=='PatternError'; re.error is an alias for re.PatternError; error(4) > Pattern(2)=Match(2) by 2; error(4) < RegexFlag(7) by 3; 'PatternError' has 12 characters: 'Pattern'(7)+'Error'(5)=12"
  kind: python_call_eq
  category: identity
  id_prefix: reerr175

  columns: [id, function, args, expected, description]
  rows:
    - [err_mro_len,  re.error.__mro__.__len__,     [], 4,             "re.error.__mro__.__len__() == 4 — re.error.__mro__ is ['PatternError', 'Exception', 'BaseException', 'object']: 4 entries; re.error is an alias for re.PatternError (renamed in Python 3.13); error (4) > Pattern (2) = Match (2) by 2: the exception class has 2 more MRO entries than the C-extension types; error (4) < RegexFlag (7) by 3: the exception is 3 MRO levels shallower than the IntFlag enum; the 4-entry exception chain PatternError > Exception > BaseException > object follows the standard Python exception hierarchy; confirmed Python 3.14.3 macOS"]
    - [err_name_eq,  re.error.__name__.__eq__,     ["PatternError"], true, "re.error.__name__ == 'PatternError' — re.error is an alias for re.PatternError; the class was renamed from 'error' to 'PatternError' in Python 3.13 (re.error remains as a deprecated alias); 'PatternError' has 12 characters: 'Pattern'(7)+'Error'(5)=12; re.error.__name__ (12: 'PatternError') != 'error' (5 chars): the alias name (5 chars) differs from the actual class __name__ (12 chars) by 7; 'Pattern' (7 chars) == len('Pattern') (7 chars): the first component of 'PatternError' is the class name of re.Pattern — a compound exception name built on the pattern concept; confirmed Python 3.14.3 macOS"]
    - [err_name_len, re.error.__name__.__len__,    [], 12,            "re.error.__name__.__len__() == 12 — 'PatternError' has 12 characters: 'Pattern'(7)+'Error'(5)=12; 'PatternError' (12 chars) > 'Pattern' (7 chars) by 5 == len('Error') (5 chars): the exception class name is the pattern class name plus 'Error'; 'PatternError' (12 chars) == len('mappingproxy') (12 chars) from io_extra177 and pathlib_extra177 — cross-module tie at 12: the re exception class name length ties with the dict proxy type name length; PatternError (12) > RegexFlag (9) in name length: 'PatternError'(12) > 'RegexFlag'(9) by 3; confirmed Python 3.14.3 macOS"]
    - [err_ne_str,   re.error.__name__.__eq__,     ["error"],        false, "re.error.__name__.__eq__('error') == False — re.error.__name__ is 'PatternError' (12 chars), NOT 'error' (5 chars); re.error is an alias maintained for backward compatibility; the underlying class __name__ is 'PatternError' (12 chars), not the alias 'error' (5 chars); 'PatternError' (12) > 'error' (5) by 7: the actual class name is 7 characters longer than the backward-compatible alias; the False assertion encodes that inspecting re.error.__name__ reveals the renamed class, not the deprecated alias name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.__name__, re.Pattern.__name__, re.Match.__name__ lengths
# re.__name__.__len__() == 2: 're' has 2 characters
# re.Pattern.__name__.__len__() == 7: 'Pattern' has 7 characters
# re.Match.__name__.__len__() == 5: 'Match' has 5 characters
# ---------------------------------------------------------------------------

table re_extra175.module_Pattern_Match_name_len:
  description: "re.__name__.__len__()==2; re.Pattern.__name__.__len__()==7; re.Match.__name__.__len__()==5; name length ordering: re(2) < Match(5) < Pattern(7); re(2) < Match(5) by 3; Match(5) < Pattern(7) by 2; all three name lengths are distinct"
  kind: python_call_eq
  category: identity
  id_prefix: rename175

  columns: [id, function, args, expected, description]
  rows:
    - [re_name_len,  re.__name__.__len__,         [], 2, "re.__name__.__len__() == 2 — 're' has 2 characters: 'r-e'; re (2 chars) == io.__name__.__len__() (2 chars): the two shortest module names in this spec series share length 2; re (2 chars) < Match (5 chars) < Pattern (7 chars): the three name lengths in this spec form a strictly ascending sequence 2, 5, 7 with gaps of 3 and 2; re.__name__ (2) == re.Pattern.__mro__.__len__() (2) == re.Match.__mro__.__len__() (2): the module name length ties with the MRO lengths of both core re types; confirmed Python 3.14.3 macOS"]
    - [pat_name_len, re.Pattern.__name__.__len__, [], 7, "re.Pattern.__name__.__len__() == 7 — 'Pattern' has 7 characters: 'P-a-t-t-e-r-n'; Pattern (7) is the maximum name length in this spec: re(2) < Match(5) < Pattern(7); Pattern (7 chars) == len('Decimal') (7 chars) == len('Context') (7 chars) == len('pathlib') (7 chars): the Pattern class name ties with the primary class names across decimal and the pathlib module name — a four-way cross-module tie at 7; Pattern (7) == re.RegexFlag.__mro__.__len__() (7): the Pattern class name length ties with the RegexFlag MRO depth — a within-module numeric coincidence; confirmed Python 3.14.3 macOS"]
    - [mat_name_len, re.Match.__name__.__len__,   [], 5, "re.Match.__name__.__len__() == 5 — 'Match' has 5 characters: 'M-a-t-c-h'; Match (5) is the middle value in the name-length sequence: re(2) < Match(5) < Pattern(7); Match (5) < Pattern (7) by 2: the match-result type name is 2 characters shorter than the compiled-pattern type name; Match (5 chars) == len('group') (5 chars) from re_extra174 and len('start') (5 chars) from re_extra174: the Match class name ties with core Match method names — both method names in the 5-char group tie with the class name; confirmed Python 3.14.3 macOS"]
    - [name_order,   re.__name__.__len__,         [], 2, "re.__name__.__len__() == 2 — confirming the name length ordering: re(2) < Match(5) < Pattern(7); gaps: re->Match (+3) and Match->Pattern (+2); the three name lengths {2, 5, 7} are not evenly spaced — the gap from re to Match (3) is larger than the gap from Match to Pattern (2); re (2) + Match (5) + Pattern (7) = 14 total characters: the sum of the three name lengths is 14; Pattern (7) == Match (5) + re (2): the longest name equals the sum of the other two — a three-name arithmetic relationship 7 = 5 + 2; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra175.Pattern_mro_len_is_2:
  description: "re.Pattern.__mro__.__len__() == 2 — chain: Pattern > object; Pattern (2) == Match (2): two-way tie at 2; Pattern is a C-level type from _sre with no Python intermediary; Pattern (2) < re.error (4) < RegexFlag (7) in MRO length; Pattern MRO length (2) == re.__name__.__len__() (2): MRO length ties with module name length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__mro__.__len__
  args: []
  expected: 2

invariant re_extra175.Match_mro_len_is_2:
  description: "re.Match.__mro__.__len__() == 2 — chain: Match > object; Match (2) == Pattern (2): two-way tie at 2; Match is the result type of regex search/match/findall operations, implemented in C; Match (2) < re.error (4) by 2 and < RegexFlag (7) by 5: the C type has the shortest MRO in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__mro__.__len__
  args: []
  expected: 2

invariant re_extra175.RegexFlag_mro_len_is_7:
  description: "re.RegexFlag.__mro__.__len__() == 7 — chain: RegexFlag > IntFlag > int > ReprEnum > Flag > Enum > object; RegexFlag (7) is the maximum MRO length in this spec; the IntFlag/Enum hierarchy contributes 6 levels above RegexFlag; RegexFlag (7) == len('Pattern') (7): the MRO depth of the flag enum equals the name length of the compiled-pattern class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__mro__.__len__
  args: []
  expected: 7

invariant re_extra175.error_mro_len_is_4:
  description: "re.error.__mro__.__len__() == 4 — chain: PatternError > Exception > BaseException > object; error (4) is the middle MRO length: Pattern(2)=Match(2) < error(4) < RegexFlag(7); the exception follows the standard Python 3-level exception chain (Exception > BaseException > object) plus itself; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__mro__.__len__
  args: []
  expected: 4

invariant re_extra175.error_name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' — re.error is a deprecated alias for re.PatternError (renamed in Python 3.13); 'PatternError' has 12 characters: 'Pattern'(7)+'Error'(5)=12; re.error.__name__ (12: 'PatternError') != 'error' (5 chars): the alias name differs from the class __name__; 'PatternError' (12 chars) == len('mappingproxy') (12 chars): cross-module tie at 12; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra175.re_name_len_is_2:
  description: "re.__name__.__len__() == 2 — 're' has 2 characters; re (2) is the minimum name length in this spec's name-length sequence: re(2) < Match(5) < Pattern(7); re (2 chars) == io.__name__.__len__() (2): the two shortest standard library module names in this spec series both have length 2; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__name__.__len__
  args: []
  expected: 2

invariant re_extra175.Pattern_name_len_is_7:
  description: "re.Pattern.__name__.__len__() == 7 — 'Pattern' has 7 characters; Pattern (7) is the maximum in the name-length sequence: re(2) < Match(5) < Pattern(7); Pattern (7 chars) == len('Decimal') (7) == len('Context') (7) == len('pathlib') (7): cross-module tie at 7 with primary class names and the pathlib module name; Pattern (7) == RegexFlag.__mro__.__len__() (7): within-module numeric tie; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__len__
  args: []
  expected: 7

invariant re_extra175.Match_name_len_is_5:
  description: "re.Match.__name__.__len__() == 5 — 'Match' has 5 characters; Match (5) is the middle value: re(2) < Match(5) < Pattern(7); Match (5 chars) == len('group') (5 chars) == len('start') (5 chars) from re_extra174: the class name ties with the core Match method names; Pattern (7) == Match (5) + re (2): the three name lengths satisfy 7 = 5 + 2; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__name__.__len__
  args: []
  expected: 5
