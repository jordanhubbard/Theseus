spec: struct_extra418
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.__name__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__ == ''. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__name__ == '__sizeof__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct is loaded by a SourceFileLoader even though it wraps the _struct C extension, because the top-level struct module is a pure-Python wrapper. __loader__.__class__.__name__ == 'SourceFileLoader' confirms this. struct.Struct is implemented in C; its __sizeof__ method is a method_descriptor whose __qualname__ follows the 'ClassName.method' convention."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module identity attributes
#
# Wave 418 theme: struct module identity and loader type identity.
#
# struct is a top-level module that wraps the _struct C extension. Its
# __name__ is 'struct' and __package__ is '' (empty string). __spec__ is
# the importlib ModuleSpec. __loader__ is a SourceFileLoader because the
# top-level struct module is itself a pure-Python file that imports _struct.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra418.module_name:
  description: "struct.__name__.__eq__('struct') == True — the module's __name__ is the bare module name 'struct', standard Python module identity; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra418.module_package:
  description: "struct.__package__.__eq__('') == True — struct is a top-level module so __package__ is the empty string; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant struct_extra418.module_spec_class:
  description: "struct.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — importlib creates a ModuleSpec for every imported module; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant struct_extra418.module_loader_class:
  description: "struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — the struct module is loaded by a SourceFileLoader because the top-level struct.py is a pure-Python wrapper around the _struct C extension; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__ method identity
#
# struct.Struct is a C extension type. Its __sizeof__ method is a
# method_descriptor. Accessed on the class, __sizeof__.__name__ is the bare
# dunder name '__sizeof__' and __qualname__ is 'Struct.__sizeof__', following
# the standard CPython convention for C extension type methods.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra418.struct_sizeof_name:
  description: "struct.Struct.__sizeof__.__name__.__eq__('__sizeof__') == True — the C-level __sizeof__ method_descriptor's __name__ is the bare dunder name; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: Struct.__sizeof__.__name__.__eq__
  args: ["__sizeof__"]
  expected: true

invariant struct_extra418.struct_sizeof_qualname:
  description: "struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') == True — C extension type methods carry a qualname of the form 'TypeName.method_name'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: Struct.__sizeof__.__qualname__.__eq__
  args: ["Struct.__sizeof__"]
  expected: true
