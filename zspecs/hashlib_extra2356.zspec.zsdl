spec: hashlib_extra2356
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 604 (_extra2356): __init__ and __new__ implementation type classification."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.blake2b is a C extension type; blake2b.__init__.__class__.__name__ == 'wrapper_descriptor'."
    - "hashlib.blake2b.__new__.__class__.__name__ == 'builtin_function_or_method' (C-level allocation)."
    - "hashlib.blake2s is also a C extension type with identical __init__ and __new__ classification."
    - "hashlib.md5 is a module-level constructor function; its __class__.__name__ == 'builtin_function_or_method'."
    - "hashlib.new is a pure-Python factory function; its __class__.__name__ == 'function'."
    - "hashlib.sha1, sha224, sha256, sha384, sha512 are all builtin_function_or_method (C-backed constructors)."
    - "hashlib.sha3_256 is a builtin_function_or_method (C-backed SHA-3 constructor)."
    - "wrapper_descriptor is the class of __init__ for C extension types that define __init__ at the C level."
    - "builtin_function_or_method is the class of module-level C functions and __new__ for C types."
    - "Pure-Python functions have __class__.__name__ == 'function'."
  created_at: "2026-04-12"

table hashlib_extra2356.blake2b_init_type:
  description: "hashlib.blake2b is a C extension type — __init__ is a wrapper_descriptor, __new__ is builtin_function_or_method"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: hl2356
  columns: [id, function, args, expected]
  rows:
    - ["hl2356001", "hashlib.blake2b.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2356002", "hashlib.blake2b.__new__.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

table hashlib_extra2356.blake2s_init_type:
  description: "hashlib.blake2s is a C extension type — __init__ is a wrapper_descriptor, __new__ is builtin_function_or_method"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: hl2356
  columns: [id, function, args, expected]
  rows:
    - ["hl2356003", "hashlib.blake2s.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2356004", "hashlib.blake2s.__new__.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

table hashlib_extra2356.blake2_class_name:
  description: "hashlib.blake2b and blake2s are types — their own __class__.__name__ is 'type'"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: hl2356
  columns: [id, function, args, expected]
  rows:
    - ["hl2356005", "hashlib.blake2b.__class__.__name__.__eq__", ["type"], true]
    - ["hl2356006", "hashlib.blake2s.__class__.__name__.__eq__", ["type"], true]

table hashlib_extra2356.module_functions_class:
  description: "Module-level hashlib constructors are builtin_function_or_method; hashlib.new is a Python function"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: hl2356
  columns: [id, function, args, expected]
  rows:
    - ["hl2356007", "hashlib.md5.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["hl2356008", "hashlib.sha1.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["hl2356009", "hashlib.sha224.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["hl2356010", "hashlib.sha256.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["hl2356011", "hashlib.sha384.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["hl2356012", "hashlib.sha512.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["hl2356013", "hashlib.sha3_256.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["hl2356014", "hashlib.new.__class__.__name__.__eq__", ["function"], true]

table hashlib_extra2356.init_type_contrast:
  description: "Contrast: blake2b.__init__ is wrapper_descriptor (C type), hashlib.new is function (Python)"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: hl2356
  columns: [id, function, args, expected]
  rows:
    - ["hl2356015", "hashlib.blake2b.__init__.__class__.__name__.__eq__", ["function"], false]
    - ["hl2356016", "hashlib.blake2s.__init__.__class__.__name__.__eq__", ["function"], false]
    - ["hl2356017", "hashlib.new.__class__.__name__.__eq__", ["builtin_function_or_method"], false]
    - ["hl2356018", "hashlib.blake2b.__new__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["hl2356019", "hashlib.blake2s.__new__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["hl2356020", "hashlib.new.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
