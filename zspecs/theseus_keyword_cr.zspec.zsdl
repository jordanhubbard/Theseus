spec: theseus_keyword_cr
version: ">=3.9"
backend: python_cleanroom(theseus_keyword_cr)
blocks: keyword

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/keyword.html"
  notes:
    - "Clean-room Python keyword utilities. Do NOT import keyword."
    - "iskeyword(s): True if s is a Python keyword."
    - "issoftkeyword(s): True if s is a soft keyword (match, case, type)."
    - "kwlist: list of all Python keywords."
    - "keyword_iskeyword_if(): iskeyword('if') == True."
    - "keyword_iskeyword_foo(): iskeyword('foo') == False."
    - "keyword_kwlist_contains_for(): 'for' in kwlist."
    - "Export: iskeyword, issoftkeyword, kwlist."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_keyword_cr.iskeyword_if:
  description: "iskeyword('if') == True"
  category: iskeyword
  kind: python_call_eq
  function: keyword_iskeyword_if
  args: []
  expected: true

invariant theseus_keyword_cr.iskeyword_foo:
  description: "iskeyword('foo') == False"
  category: iskeyword
  kind: python_call_eq
  function: keyword_iskeyword_foo
  args: []
  expected: false

invariant theseus_keyword_cr.kwlist_contains_for:
  description: "'for' in kwlist"
  category: kwlist
  kind: python_call_eq
  function: keyword_kwlist_contains_for
  args: []
  expected: true
