# ===
# Table 4: Contrast — sync methods present in socket.socket and enum __dict__
# ===

table socket_extra2431.sync_methods_contrast:
  description: "socket.socket and enum types have sync infrastructure (__init__, __enter__, _value2member_map_) but NOT async protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2431

  columns: [id, function, args, expected]
  rows:
    - ["sk2431013", "socket.socket.__dict__.__contains__",        ["__init__"],           true]
    - ["sk2431014", "socket.socket.__dict__.__contains__",        ["__enter__"],          true]
    - ["sk2431015", "socket.socket.__dict__.__contains__",        ["__aiter__"],          false]
    - ["sk2431016", "socket.socket.__dict__.__contains__",        ["__anext__"],          false]
    - ["sk2431017", "socket.AddressFamily.__dict__.__contains__", ["_value2member_map_"], true]
    - ["sk2431018", "socket.AddressFamily.__dict__.__contains__", ["__aiter__"],          false]
    - ["sk2431019", "socket.MsgFlag.__dict__.__contains__",       ["_value2member_map_"], true]
    - ["sk2431020", "socket.MsgFlag.__dict__.__contains__",       ["__aiter__"],          false]
