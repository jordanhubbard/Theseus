spec: socket_extra2431
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra.zspec.zsdl — covers create_connection/create_server/setdefaulttimeout/htons/ntohs names; setdefaulttimeout; inet_ntoa; htons/ntohs/ntohl zero; htonl little-endian"
    - "socket_extra2.zspec.zsdl — covers AddressFamily/SocketKind enum class names; getfqdn/gethostname return type; socket.error alias; socket.timeout alias and base"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for socket classes."
    - "socket.socket is a synchronous blocking I/O class; it does not define __aiter__ or __anext__."
    - "socket.AddressFamily, socket.SocketKind, socket.MsgFlag, socket.AddressInfo are IntEnum/IntFlag enums."
    - "None of the socket enum types define __aiter__ or __anext__ in their class __dict__."
    - "socket.SocketIO is the file-like wrapper for socket objects used with makefile(); it is also purely synchronous."
    - "asyncio uses raw socket objects internally but socket.socket itself has no async protocol."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ===
# Table 1: __aiter__ and __anext__ absent from socket.socket __dict__
# ===

table socket_extra2431.aiter_in_dict_socket:
  description: "__aiter__ and __anext__ dict-presence for socket.socket — synchronous I/O class, no async protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2431

  columns: [id, function, args, expected]
  rows:
    - ["sk2431001", "socket.socket.__dict__.__contains__", ["__aiter__"], false]
    - ["sk2431002", "socket.socket.__dict__.__contains__", ["__anext__"], false]

