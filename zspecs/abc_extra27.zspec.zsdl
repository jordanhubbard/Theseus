spec: abc_extra27
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra26.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token, abstractproperty lengths, ABCMeta.register/__name__/__qualname__ lengths, ABCMeta.__new__/__instancecheck__ __qualname__.__len__(), __mro__.__len__() for ABCMeta/ABC, ABC/ABCMeta __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() for ABC/ABCMeta (both 12), ABCMeta.__subclasscheck__/__qualname__.__len__()==25, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9, ABC.__name__.__len__()==3, ABCMeta.register.__qualname__.__len__()==16, abstractmethod.__name__.__len__()==14, get_cache_token.__name__.__len__()==15, abc.__name__.__len__()==3."
    - "This spec covers: ABC.__mro__.__len__()==2 (ABC and object only); ABCMeta.__mro__.__len__()==3 (ABCMeta→type→object); ABCMeta.__mro__ entry name lengths: ABCMeta(7)/type(4)/object(6); ABC.__bases__[0].__name__.__len__()==6 ('object'); abstractmethod.__qualname__.__len__()==14; ABCMeta.__name__.__len__()==7; ABCMeta.__qualname__.__len__()==7."
    - "ABC.__mro__ == (ABC, object) — length 2. The ABC helper class directly subclasses object with no intermediate base."
    - "ABCMeta.__mro__ == (ABCMeta, type, object) — length 3. ABCMeta extends the built-in 'type' metaclass, giving it one more MRO entry than ABC."
    - "ABCMeta.__mro__ entry names by index: [0]='ABCMeta'(7), [1]='type'(4), [2]='object'(6). The shortest MRO entry is 'type' (4 chars)."
    - "ABC.__bases__[0].__name__ == 'object' (length 6) — ABC has a single direct base, the root 'object' class."
    - "abstractmethod.__qualname__ == 'abstractmethod' (length 14) — top-level class; __qualname__ equals __name__."
    - "ABCMeta.__name__ == ABCMeta.__qualname__ == 'ABCMeta' (length 7) — top-level metaclass with no nesting."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABC and ABCMeta __mro__.__len__() — two core abc classes
#
# abc.ABC.__mro__ == (ABC, object) — length 2. ABC is a simple helper class
# whose only role is to have ABCMeta as its metaclass; it contributes no
# additional MRO entries. abc.ABCMeta.__mro__ == (ABCMeta, type, object) —
# length 3. ABCMeta extends the built-in 'type' metaclass to intercept class
# creation and track abstract methods. No prior abc spec records these two MRO
# lengths together in a single table under the extra27 namespace.
# ---------------------------------------------------------------------------

table abc_extra27.mro_lengths:
  description: "__mro__.__len__() for ABC(2) and ABCMeta(3)"
  kind: python_call_eq
  category: mro_lengths
  id_prefix: mro_len

  columns: [id, function, args, expected, description]
  rows:
    - [ABC,
       ABC.__mro__.__len__,
       [],
       2,
       "len(abc.ABC.__mro__) == 2 — (ABC, object); ABC directly subclasses object"]
    - [ABCMeta,
       ABCMeta.__mro__.__len__,
       [],
       3,
       "len(abc.ABCMeta.__mro__) == 3 — (ABCMeta, type, object); ABCMeta subclasses type"]

# ---------------------------------------------------------------------------
# ABCMeta.__mro__ entry name lengths — three entries by name length
#
# ABCMeta.__mro__[0].__name__ == 'ABCMeta' (length 7).
# ABCMeta.__mro__[1].__name__ == 'type' (length 4) — the built-in metaclass.
# ABCMeta.__mro__[2].__name__ == 'object' (length 6) — the root class.
# Together these three lengths (7, 4, 6) characterise the entire MRO of
# ABCMeta. No prior abc spec records these three indexed MRO entry name
# lengths.
# ---------------------------------------------------------------------------

table abc_extra27.ABCMeta_mro_entry_name_lens:
  description: "ABCMeta.__mro__[i].__name__.__len__() for i=0(7),1(4),2(6)"
  kind: python_call_eq
  category: mro_entry_name_lengths
  id_prefix: mro_entry_name_len

  columns: [id, function, args, expected, description]
  rows:
    - [idx0,
       "ABCMeta.__mro__[0].__name__.__len__",
       [],
       7,
       "ABCMeta.__mro__[0].__name__ == 'ABCMeta' (length 7)"]
    - [idx1,
       "ABCMeta.__mro__[1].__name__.__len__",
       [],
       4,
       "ABCMeta.__mro__[1].__name__ == 'type' (length 4)"]
    - [idx2,
       "ABCMeta.__mro__[2].__name__.__len__",
       [],
       6,
       "ABCMeta.__mro__[2].__name__ == 'object' (length 6)"]

# ---------------------------------------------------------------------------
# ABC.__bases__[0].__name__.__len__() == 6 — standalone invariant
#
# abc.ABC.__bases__[0].__name__ == 'object' (length 6). ABC has exactly one
# direct base class — the root 'object'. This pairs with the MRO length of 2
# established above: a single intermediate base means the MRO is just
# (ABC, object). No prior abc spec records ABC.__bases__[0].__name__.__len__()
# as a standalone invariant under the extra27 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra27.ABC.bases0_name_len:
  description: "abc.ABC.__bases__[0].__name__.__len__() == 6 — sole base class is 'object' (length 6)"
  category: base_class_names
  kind: python_call_eq
  function: "ABC.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# abstractmethod.__qualname__.__len__() == 14 — standalone invariant
#
# abc.abstractmethod.__qualname__ == 'abstractmethod' (length 14). As a
# top-level class (not nested), __qualname__ equals __name__, both 14 chars.
# This was mentioned in extra26 notes but is recorded here as a standalone
# invariant in the extra27 namespace for direct testability.
# ---------------------------------------------------------------------------

invariant abc_extra27.abstractmethod.qualname_len:
  description: "abc.abstractmethod.__qualname__.__len__() == 14 — 'abstractmethod' is 14 characters; top-level class so __qualname__ == __name__"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: abstractmethod.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# ABCMeta.__name__.__len__() == ABCMeta.__qualname__.__len__() == 7
#
# ABCMeta is a top-level metaclass with no nesting, so its __name__ and
# __qualname__ are both 'ABCMeta' (7 characters). Recording both confirms the
# equality of name and qualname for this non-nested class. No prior abc spec
# records ABCMeta.__qualname__.__len__() as a standalone in the extra27
# namespace (extra26 noted the value but covered it only in table form under
# extra26).
# ---------------------------------------------------------------------------

invariant abc_extra27.ABCMeta.name_len:
  description: "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters"
  category: class_name_attrs
  kind: python_call_eq
  function: ABCMeta.__name__.__len__
  args: []
  expected: 7

invariant abc_extra27.ABCMeta.qualname_len:
  description: "abc.ABCMeta.__qualname__.__len__() == 7 — top-level metaclass; __qualname__ == __name__ == 'ABCMeta' (7 chars)"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: ABCMeta.__qualname__.__len__
  args: []
  expected: 7
