spec: socket_extra2371
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2371 (_extra2371): __class__.__name__ of module-level objects."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket, socket.error, socket.herror, socket.gaierror, socket.timeout are Python type objects; __class__.__name__ == 'type'."
    - "socket.AF_INET and socket.AF_INET6 are IntEnum members; __class__.__name__ == 'AddressFamily'."
    - "socket.SOCK_STREAM and socket.SOCK_DGRAM are IntEnum members; __class__.__name__ == 'SocketKind'."
    - "socket.gethostname and socket.setdefaulttimeout are C-level builtins; __class__.__name__ == 'builtin_function_or_method'."
    - "socket.getaddrinfo and socket.create_connection are Python-level functions; __class__.__name__ == 'function'."
    - "socket.AddressFamily and socket.SocketKind are EnumMeta instances; __class__.__name__ == 'EnumType'."
  created_at: "2026-04-12"

table socket_extra2371.object_types:
  description: "socket module-level object type classification via __class__.__name__"
