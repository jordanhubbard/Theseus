spec: itertools_extra245
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra244.zspec.zsdl — covers islice and compress class identity"
    - "itertools_extra243.zspec.zsdl — covers filterfalse and starmap class identity"
    - "itertools_extra242.zspec.zsdl — covers islice and takewhile class identity"
    - "itertools_extra.zspec.zsdl — covers combinations/permutations/product/compress/zip_longest names"
    - "itertools.zspec.zsdl — covers itertools class names and module identity"
  notes:
    - "This spec covers itertools.accumulate and itertools.pairwise class identity contracts."
    - "itertools.accumulate.__name__ == 'accumulate' (len=10) — accumulate is a C-level type in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.accumulate.__module__ == 'itertools' (len=9) — accumulate is exposed in the itertools namespace. Verified with Python 3.14.3."
    - "itertools.accumulate.__bases__[0].__name__ == 'object' — accumulate inherits directly from object. Verified with Python 3.14.3."
    - "itertools.accumulate.__class__.__name__ == 'type' — accumulate is a C extension type. Verified with Python 3.14.3."
    - "itertools.pairwise.__name__ == 'pairwise' (len=8) — pairwise is a C-level type in itertoolsmodule.c added in Python 3.10. Verified with Python 3.14.3."
    - "itertools.pairwise.__module__ == 'itertools' (len=9) — pairwise is exposed in the itertools namespace. Verified with Python 3.14.3."
    - "itertools.pairwise.__bases__[0].__name__ == 'object' — pairwise inherits directly from object. Verified with Python 3.14.3."
    - "itertools.pairwise.__class__.__name__ == 'type' — pairwise is a C extension type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.accumulate class identity contracts
#
# itertools.accumulate.__name__ == 'accumulate' (len=10)
# itertools.accumulate.__module__ == 'itertools' (len=9)
# itertools.accumulate.__qualname__ == 'accumulate'
# itertools.accumulate.__class__.__name__ == 'type'
# itertools.accumulate.__name__.__len__() == 10
#
# accumulate is a C-level type in itertoolsmodule.c. New to extra245.
# ---------------------------------------------------------------------------

table itertools_extra245.accum245_identity:
  description: "itertools.accumulate class identity: name, module, bases, class; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: accum245

  columns: [id, function, args, expected, description]
  rows:
    - [acc_name_eq,
       accumulate.__name__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — accumulate is a C-level type in itertoolsmodule.c; __name__ is 'accumulate' (len=10); new to extra245"]
    - [acc_name_len_10,
       accumulate.__name__.__len__,
       [],
       10,
       "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has exactly 10 characters; str.__len__() returns 10; new to extra245"]
    - [acc_module_eq,
       accumulate.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__eq__('itertools') == True — accumulate is exposed in the itertools namespace; __module__ is 'itertools' (len=9); new to extra245"]
    - [acc_module_len_9,
       accumulate.__module__.__len__,
       [],
       9,
       "itertools.accumulate.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra245"]
    - [acc_qualname_eq,
       accumulate.__qualname__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__.__eq__('accumulate') == True — accumulate is a top-level class; __qualname__ equals __name__; new to extra245"]

# ---------------------------------------------------------------------------
# Table 2: itertools.accumulate class type and content checks
#
# itertools.accumulate.__class__.__name__ == 'type'
# itertools.accumulate.__name__.__contains__('acc') == True
# itertools.accumulate.__module__.__contains__('itertools') == True
# itertools.accumulate.__qualname__.__len__() == 10
# itertools.accumulate.__class__.__module__ == 'builtins'
#
# New to extra245.
# ---------------------------------------------------------------------------

table itertools_extra245.accum245_class:
  description: "itertools.accumulate class type, name/module content checks; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: accum245c

  columns: [id, function, args, expected, description]
  rows:
    - [acc_class_is_type,
       accumulate.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.accumulate.__class__.__name__.__eq__('type') == True — accumulate is a C extension type; its metaclass is the built-in type; new to extra245"]
    - [acc_name_contains_acc,
       accumulate.__name__.__contains__,
       ["acc"],
       true,
       "itertools.accumulate.__name__.__contains__('acc') == True — 'accumulate' contains the prefix 'acc'; new to extra245"]
    - [acc_module_contains_itertools,
       accumulate.__module__.__contains__,
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__contains__('itertools') == True — 'itertools' contains the substring 'itertools'; new to extra245"]
    - [acc_qualname_len_10,
       accumulate.__qualname__.__len__,
       [],
       10,
       "itertools.accumulate.__qualname__.__len__() == 10 — 'accumulate' has exactly 10 characters; __qualname__ equals __name__; new to extra245"]
    - [acc_class_module_builtins,
       accumulate.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.accumulate.__class__.__module__.__eq__('builtins') == True — type is defined in the builtins module; new to extra245"]

# ---------------------------------------------------------------------------
# Table 3: itertools.pairwise class identity contracts
#
# itertools.pairwise.__name__ == 'pairwise' (len=8)
# itertools.pairwise.__module__ == 'itertools' (len=9)
# itertools.pairwise.__qualname__ == 'pairwise'
# itertools.pairwise.__class__.__name__ == 'type'
# itertools.pairwise.__name__.__len__() == 8
#
# pairwise was added in Python 3.10; it is a C-level type. New to extra245.
# ---------------------------------------------------------------------------

table itertools_extra245.pairwise245_identity:
  description: "itertools.pairwise class identity: name, module, bases, class; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: pairwise245

  columns: [id, function, args, expected, description]
  rows:
    - [pw_name_eq,
       pairwise.__name__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — pairwise is a C-level type added in Python 3.10; __name__ is 'pairwise' (len=8); new to extra245"]
    - [pw_name_len_8,
       pairwise.__name__.__len__,
       [],
       8,
       "itertools.pairwise.__name__.__len__() == 8 — 'pairwise' has exactly 8 characters; str.__len__() returns 8; new to extra245"]
    - [pw_module_eq,
       pairwise.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — pairwise is exposed in the itertools namespace; __module__ is 'itertools' (len=9); new to extra245"]
    - [pw_module_len_9,
       pairwise.__module__.__len__,
       [],
       9,
       "itertools.pairwise.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra245"]
    - [pw_qualname_eq,
       pairwise.__qualname__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__qualname__.__eq__('pairwise') == True — pairwise is a top-level class; __qualname__ equals __name__; new to extra245"]

# ---------------------------------------------------------------------------
# Table 4: itertools.pairwise class type and content checks
#
# itertools.pairwise.__class__.__name__ == 'type'
# itertools.pairwise.__name__.__contains__('pair') == True
# itertools.pairwise.__module__.__contains__('itertools') == True
# itertools.pairwise.__qualname__.__len__() == 8
# itertools.pairwise.__class__.__module__ == 'builtins'
#
# New to extra245.
# ---------------------------------------------------------------------------

table itertools_extra245.pairwise245_class:
  description: "itertools.pairwise class type, name/module content checks; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: pairwise245c

  columns: [id, function, args, expected, description]
  rows:
    - [pw_class_is_type,
       pairwise.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.pairwise.__class__.__name__.__eq__('type') == True — pairwise is a C extension type; its metaclass is the built-in type; new to extra245"]
    - [pw_name_contains_pair,
       pairwise.__name__.__contains__,
       ["pair"],
       true,
       "itertools.pairwise.__name__.__contains__('pair') == True — 'pairwise' contains the prefix 'pair'; new to extra245"]
    - [pw_module_contains_itertools,
       pairwise.__module__.__contains__,
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__contains__('itertools') == True — 'itertools' contains the substring 'itertools'; new to extra245"]
    - [pw_qualname_len_8,
       pairwise.__qualname__.__len__,
       [],
       8,
       "itertools.pairwise.__qualname__.__len__() == 8 — 'pairwise' has exactly 8 characters; __qualname__ equals __name__; new to extra245"]
    - [pw_class_module_builtins,
       pairwise.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.pairwise.__class__.__module__.__eq__('builtins') == True — type is defined in the builtins module; new to extra245"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra245
# ---------------------------------------------------------------------------

invariant itertools_extra245.acc_name_eq:
  description: "itertools.accumulate.__name__ == 'accumulate' (len=10); new to extra245"
  kind: python_call_eq
  function: accumulate.__name__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra245.acc_module_eq:
  description: "itertools.accumulate.__module__ == 'itertools' — C-level type in itertools namespace; new to extra245"
  kind: python_call_eq
  function: accumulate.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra245.acc_qualname_eq:
  description: "itertools.accumulate.__qualname__ == 'accumulate' — top-level class qualname; new to extra245"
  kind: python_call_eq
  function: accumulate.__qualname__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra245.acc_class_is_type:
  description: "itertools.accumulate.__class__.__name__ == 'type' — C extension type; new to extra245"
  kind: python_call_eq
  function: accumulate.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra245.acc_name_len_10:
  description: "itertools.accumulate.__name__.__len__() == 10; new to extra245"
  kind: python_call_eq
  function: accumulate.__name__.__len__
  args: []
  expected: 10

invariant itertools_extra245.pw_name_eq:
  description: "itertools.pairwise.__name__ == 'pairwise' (len=8) — added in Python 3.10; new to extra245"
  kind: python_call_eq
  function: pairwise.__name__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra245.pw_module_eq:
  description: "itertools.pairwise.__module__ == 'itertools' — C-level type in itertools namespace; new to extra245"
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra245.pw_qualname_eq:
  description: "itertools.pairwise.__qualname__ == 'pairwise' — top-level class qualname; new to extra245"
  kind: python_call_eq
  function: pairwise.__qualname__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra245.pw_class_is_type:
  description: "itertools.pairwise.__class__.__name__ == 'type' — C extension type; new to extra245"
  kind: python_call_eq
  function: pairwise.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra245.pw_name_len_8:
  description: "itertools.pairwise.__name__.__len__() == 8; new to extra245"
  kind: python_call_eq
  function: pairwise.__name__.__len__
  args: []
  expected: 8

invariant itertools_extra245.acc_name_contains_acc:
  description: "itertools.accumulate.__name__ contains 'acc'; new to extra245"
  kind: python_call_eq
  function: accumulate.__name__.__contains__
  args: ["acc"]
  expected: true

invariant itertools_extra245.pw_name_contains_pair:
  description: "itertools.pairwise.__name__ contains 'pair'; new to extra245"
  kind: python_call_eq
  function: pairwise.__name__.__contains__
  args: ["pair"]
  expected: true
