spec: functools_extra265
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS contents/length, WRAPPER_UPDATES, and callable types"
    - "functools_extra.zspec.zsdl — covers __name__/__module__ for reduce, partial, cached_property, cmp_to_key, total_ordering, singledispatch"
  notes:
    - "functools.wraps.__name__ == 'wraps' — Python function; __qualname__ matches __name__ (not nested)."
    - "functools.wraps.__module__ == 'functools'."
    - "functools.wraps.__class__.__name__ == 'function' — wraps is a Python-level function."
    - "functools.update_wrapper.__name__ == 'update_wrapper'; __qualname__ == 'update_wrapper'."
    - "functools.update_wrapper.__module__ == 'functools'; __class__.__name__ == 'function'."
    - "WRAPPER_ASSIGNMENTS is a 6-tuple on Python 3.14: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__."
    - "__module__, __name__, __qualname__, __doc__ all present in WRAPPER_ASSIGNMENTS on Python 3.14."
    - "All values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.wraps — decorator identity
#
# wraps is a Python function that serves as a decorator factory.
# Its __name__, __qualname__, __module__, and __class__.__name__ are verified.
# ---------------------------------------------------------------------------

invariant functools_extra265.wraps.name:
  description: "functools.wraps.__name__ == 'wraps'"
  category: identity
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra265.wraps.qualname:
  description: "functools.wraps.__qualname__ == 'wraps'"
  category: identity
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra265.wraps.module:
  description: "functools.wraps.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra265.wraps.class_name:
  description: "functools.wraps.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: wraps.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# functools.update_wrapper — function identity
#
# update_wrapper is a Python function that copies wrapper attributes.
# ---------------------------------------------------------------------------

invariant functools_extra265.update_wrapper.name:
  description: "functools.update_wrapper.__name__ == 'update_wrapper'"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra265.update_wrapper.qualname:
  description: "functools.update_wrapper.__qualname__ == 'update_wrapper'"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__qualname__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra265.update_wrapper.module:
  description: "functools.update_wrapper.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra265.update_wrapper.class_name:
  description: "functools.update_wrapper.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# functools.WRAPPER_ASSIGNMENTS — tuple contents and length
#
# On Python 3.14 this is a 6-tuple:
# ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__')
# ---------------------------------------------------------------------------

invariant functools_extra265.wrapper_assignments.length:
  description: "len(functools.WRAPPER_ASSIGNMENTS) == 6 on Python 3.14"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra265.wrapper_assignments.class_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra265.wrapper_assignments.contains_module:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__module__'"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools_extra265.wrapper_assignments.contains_name:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__name__'"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools_extra265.wrapper_assignments.contains_qualname:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__qualname__'"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__qualname__"]
  expected: true

invariant functools_extra265.wrapper_assignments.contains_doc:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__doc__'"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__doc__"]
  expected: true
