  rows:
    - ["dc2026007", "decimal.Decimal.__dict__.__contains__",          ["__floordiv__"],  true]
    - ["dc2026008", "decimal.Decimal.__dict__.__contains__",          ["__rfloordiv__"], true]
    - ["dc2026009", "decimal.Context.__dict__.__contains__",          ["__floordiv__"],  false]
    - ["dc2026010", "decimal.Context.__dict__.__contains__",          ["__rfloordiv__"], false]
    - ["dc2026011", "decimal.DecimalException.__dict__.__contains__", ["__floordiv__"],  false]
    - ["dc2026012", "decimal.DecimalException.__dict__.__contains__", ["__rfloordiv__"], false]

