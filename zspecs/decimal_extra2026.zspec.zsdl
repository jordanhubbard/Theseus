# ---------------------------------------------------------------------------
# In-place variants — all False (Decimal is immutable)
# __itruediv__, __ifloordiv__, __imod__ are not defined on any decimal type
# ---------------------------------------------------------------------------

table decimal_extra2026.inplace_protocol:
  description: "decimal types in-place division/modulo dict-presence — all False (Decimal is immutable)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2026

  columns: [id, function, args, expected]
  rows:
    - ["dc2026031", "decimal.Decimal.__dict__.__contains__",          ["__itruediv__"],  false]
    - ["dc2026032", "decimal.Decimal.__dict__.__contains__",          ["__ifloordiv__"], false]
    - ["dc2026033", "decimal.Decimal.__dict__.__contains__",          ["__imod__"],      false]
    - ["dc2026034", "decimal.Context.__dict__.__contains__",          ["__itruediv__"],  false]
    - ["dc2026035", "decimal.Context.__dict__.__contains__",          ["__ifloordiv__"], false]
    - ["dc2026036", "decimal.Context.__dict__.__contains__",          ["__imod__"],      false]
    - ["dc2026037", "decimal.DecimalException.__dict__.__contains__", ["__itruediv__"],  false]
    - ["dc2026038", "decimal.DecimalException.__dict__.__contains__", ["__ifloordiv__"], false]
    - ["dc2026039", "decimal.DecimalException.__dict__.__contains__", ["__imod__"],      false]
