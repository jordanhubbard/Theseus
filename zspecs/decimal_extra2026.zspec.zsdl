spec: decimal_extra2026
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __rtruediv__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__, __divmod__, __rdivmod__ dict-presence checks."
    - "decimal.Decimal is a full numeric type and defines all ten arithmetic operators in its own __dict__: __truediv__, __rtruediv__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__, __divmod__, __rdivmod__."
    - "decimal.Decimal is immutable; in-place variants (__itruediv__, __ifloordiv__, __imod__) are not defined in its __dict__."
    - "decimal.Context does not define division, modulo, exponentiation, or divmod operators in its own __dict__."
    - "decimal.DecimalException is an exception class; no arithmetic operators are defined in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __truediv__ / __rtruediv__ — true division dict-presence
# decimal.Decimal defines both; Context and DecimalException do not
# ---------------------------------------------------------------------------

table decimal_extra2026.truediv_protocol:
  description: "decimal types __truediv__/__rtruediv__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2026

  columns: [id, function, args, expected]
  rows:
    - ["dc2026001", "decimal.Decimal.__dict__.__contains__",          ["__truediv__"],  true]
    - ["dc2026002", "decimal.Decimal.__dict__.__contains__",          ["__rtruediv__"], true]
    - ["dc2026003", "decimal.Context.__dict__.__contains__",          ["__truediv__"],  false]
    - ["dc2026004", "decimal.Context.__dict__.__contains__",          ["__rtruediv__"], false]
    - ["dc2026005", "decimal.DecimalException.__dict__.__contains__", ["__truediv__"],  false]
    - ["dc2026006", "decimal.DecimalException.__dict__.__contains__", ["__rtruediv__"], false]

