spec: itertools_extra1321
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ output class checks for itertools C extension types."
    - "All itertools types are C extension types; __repr__ is always 'wrapper_descriptor'."
    - "itertools.count.__repr__.__qualname__ == 'count.__repr__' — count defines its own repr in C; others inherit from object."
    - "itertools.chain.__repr__.__qualname__ == 'object.__repr__' — chain does not define a custom repr; inherits object.__repr__."
    - "itertools.cycle.__repr__.__qualname__ == 'object.__repr__' — cycle does not define a custom repr."
    - "itertools.islice.__repr__.__qualname__ == 'object.__repr__' — islice does not define a custom repr."
    - "itertools.product.__repr__.__qualname__ == 'object.__repr__' — product does not define a custom repr."
    - "itertools.groupby.__repr__.__qualname__ == 'object.__repr__' — groupby does not define a custom repr."
    - "itertools.combinations.__repr__.__qualname__ == 'object.__repr__' — combinations does not define a custom repr."
    - "repr(itertools.chain).__class__.__name__ == 'str' — repr of any class object is a str."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra1321.chain_cycle_islice_repr_checks:
  description: "itertools.chain, cycle, islice __repr__ and __str__ class name and qualname; all are C extension types inheriting object.__repr__"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: it1321cc
  columns: [id, function, args, expected]
  rows:
    - [it1321cc001, itertools.chain.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [it1321cc002, itertools.chain.__repr__.__qualname__.__eq__,         ["object.__repr__"],     true]
    - [it1321cc003, itertools.chain.__str__.__class__.__name__.__eq__,    ["wrapper_descriptor"],  true]
    - [it1321cc004, itertools.cycle.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [it1321cc005, itertools.cycle.__repr__.__qualname__.__eq__,         ["object.__repr__"],     true]
    - [it1321cc006, itertools.islice.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"],  true]
    - [it1321cc007, itertools.islice.__repr__.__qualname__.__eq__,        ["object.__repr__"],     true]
    - [it1321cc008, repr(itertools.chain).__class__.__name__.__eq__,      ["str"],                 true]

table itertools_extra1321.count_repr_and_product_groupby_checks:
  description: "itertools.count __repr__ defines its own C-level repr; product and groupby inherit object.__repr__"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: it1321co
  columns: [id, function, args, expected]
  rows:
    - [it1321co001, itertools.count.__repr__.__class__.__name__.__eq__,    ["wrapper_descriptor"],  true]
    - [it1321co002, itertools.count.__repr__.__qualname__.__eq__,          ["count.__repr__"],      true]
    - [it1321co003, itertools.count.__str__.__class__.__name__.__eq__,     ["wrapper_descriptor"],  true]
    - [it1321co004, itertools.product.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"],  true]
    - [it1321co005, itertools.product.__repr__.__qualname__.__eq__,        ["object.__repr__"],     true]
    - [it1321co006, itertools.groupby.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"],  true]
    - [it1321co007, itertools.groupby.__repr__.__qualname__.__eq__,        ["object.__repr__"],     true]
    - [it1321co008, repr(itertools.count).__class__.__name__.__eq__,       ["str"],                 true]

table itertools_extra1321.combinations_permutations_repr_checks:
  description: "itertools.combinations and permutations __repr__ inherit from object; repr of class objects returns str"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: it1321cb
  columns: [id, function, args, expected]
  rows:
    - [it1321cb001, itertools.combinations.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [it1321cb002, itertools.combinations.__repr__.__qualname__.__eq__,         ["object.__repr__"],     true]
    - [it1321cb003, itertools.combinations.__str__.__class__.__name__.__eq__,    ["wrapper_descriptor"],  true]
    - [it1321cb004, itertools.permutations.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [it1321cb005, itertools.permutations.__repr__.__qualname__.__eq__,         ["object.__repr__"],     true]
    - [it1321cb006, itertools.permutations.__str__.__class__.__name__.__eq__,    ["wrapper_descriptor"],  true]
    - [it1321cb007, repr(itertools.combinations).__class__.__name__.__eq__,      ["str"],                 true]
    - [it1321cb008, repr(itertools.permutations).__class__.__name__.__eq__,      ["str"],                 true]
