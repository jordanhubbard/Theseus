spec: re3346
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (re3346): __neg__, __pos__, __abs__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __neg__, __pos__, __abs__ dict-presence (unary operators: -x, +x, abs(x))."
    - "No re class defines __neg__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; unary negation has no meaning for them. re.RegexFlag is an IntFlag enum; __neg__ is not present in re.RegexFlag.__dict__."
    - "No re class defines __pos__ in its own __dict__: re types are not numeric operands; unary plus is not defined on any re type. re.RegexFlag (IntFlag) does not define __pos__ in its own __dict__."
    - "No re class defines __abs__ in its own __dict__: abs() is not defined on any re type; re.Pattern and re.Match are not numeric, and re.RegexFlag (IntFlag) does not define __abs__ in its own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all unary arithmetic operators absent from re class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# No re class defines __neg__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but unary negation is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3346.neg:
  description: "re types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3346

  columns: [id, function, args, expected]
  rows:
    - ["re3346001", operator.contains, [re.Pattern.__dict__,   "__neg__"], false]
    - ["re3346002", operator.contains, [re.Match.__dict__,     "__neg__"], false]
    - ["re3346003", operator.contains, [re.RegexFlag.__dict__, "__neg__"], false]

# ---------------------------------------------------------------------------
