spec: datetime_extra_rust
version: ">=3.9"
backend: rust_module(datetime_extra_rust)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime documentation"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
  notes:
    - "Clean-room Rust reimplementation of Python datetime.fromisoformat, exposed via PyO3."
    - "fromisoformat(s) parses an ISO 8601 datetime string."
    - "fromisoformat('2026-04-19T12:30:45').year == 2026."
    - "fromisoformat('2026-04-19T12:30:45').month == 4."
    - "fromisoformat('2026-04-19T12:30:45').day == 19."
    - "fromisoformat('2026-04-19T12:30:45').hour == 12."
    - "fromisoformat('2026-04-19T12:30:45').minute == 30."
    - "fromisoformat('2026-04-19T12:30:45').second == 45."
    - "fromisoformat round-trip: fromisoformat(s).isoformat() == s."
    - "All test vectors verified against Python 3.14.3 datetime module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# fromisoformat — parse ISO 8601 datetime string
table datetime_extra_rust.fromisoformat.components:
  kind: python_call_eq
  category: fromisoformat
  id_prefix: dt_fiso

  columns: [id, function, args, method, expected]
  rows:
    - [year,   fromisoformat, ["2026-04-19T12:30:45"], year,   2026]
    - [month,  fromisoformat, ["2026-04-19T12:30:45"], month,  4]
    - [day,    fromisoformat, ["2026-04-19T12:30:45"], day,    19]
    - [hour,   fromisoformat, ["2026-04-19T12:30:45"], hour,   12]
    - [minute, fromisoformat, ["2026-04-19T12:30:45"], minute, 30]
    - [second, fromisoformat, ["2026-04-19T12:30:45"], second, 45]

# fromisoformat round-trip via isoformat()
invariant datetime_extra_rust.fromisoformat.roundtrip:
  description: "fromisoformat(s).isoformat() == s"
  category: fromisoformat
  kind: python_call_eq
  function: fromisoformat
  args: ["2026-04-19T12:30:45"]
  method: isoformat
  expected: "2026-04-19T12:30:45"

# date-only ISO format
table datetime_extra_rust.fromisoformat.date_only:
  kind: python_call_eq
  category: fromisoformat
  id_prefix: dt_date

  columns: [id, function, args, method, expected]
  rows:
    - [year,  fromisoformat, ["2000-01-01T00:00:00"], year,  2000]
    - [month, fromisoformat, ["2000-01-01T00:00:00"], month, 1]
    - [day,   fromisoformat, ["2000-01-01T00:00:00"], day,   1]

