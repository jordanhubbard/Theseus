spec: uuid_extra268
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "This spec extends uuid.zspec.zsdl through uuid_extra267.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "uuid_extra.zspec.zsdl covers: UUID.__name__/__module__; uuid1/uuid3/uuid4/uuid5 function names; uuid4().__class__.__name__=='UUID' and version==4."
    - "uuid_extra267.zspec.zsdl covers: SafeUUID class identity, members, and member values; UUID.is_safe default."
    - "uuid_extra27.zspec.zsdl covers: UUID.bytes_le descriptor class name len; uuid3/uuid5 result class name len; NAMESPACE_URL qualname len."
    - "This spec focuses on: uuid1().__class__.__name__=='UUID' (result is a UUID); uuid1().version==1; uuid4().version==4; UUID.__slots__ length==3 and element values."
    - "uuid.uuid1() returns a UUID instance: uuid1().__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid1().version == 1 — version is an instance attribute on uuid1() results. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid4().version == 4 — version is an instance attribute on uuid4() results. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__slots__ == ('int', 'is_safe', '__weakref__') — three slots. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(uuid.UUID.__slots__) == 3 — exactly three slot entries. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__slots__[0] == 'int' — the UUID integer value slot. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__slots__[1] == 'is_safe' — the SafeUUID attribute slot. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__slots__[2] == '__weakref__' — the weak reference slot. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.version.__class__.__name__ == 'property' — version is a Python property descriptor on the UUID class. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid1() result — class name and version attribute
# uuid_extra.zspec.zsdl covers uuid4().__class__.__name__=='UUID' via a
# method_chain on uuid4(). No prior spec checks uuid1().__class__.__name__
# or uuid1().version as explicit standalone machine-readable invariants.
# ---------------------------------------------------------------------------

invariant uuid_extra268.uuid1.result_class_name:
  description: "uuid.uuid1().__class__.__name__ == 'UUID' — uuid1() returns a UUID instance; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: instance_attributes
  kind: python_call_eq
  function: uuid1
  args: []
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true

invariant uuid_extra268.uuid1.version_is_1:
  description: "uuid.uuid1().version == 1 — uuid1 produces version-1 (time-based) UUIDs per RFC 4122"
  category: instance_attributes
  kind: python_call_eq
  function: uuid1
  args: []
  method: version.__eq__
  method_args: [1]
  expected: true

invariant uuid_extra268.uuid4.version_is_4:
  description: "uuid.uuid4().version == 4 — uuid4 produces version-4 (random) UUIDs per RFC 4122"
  category: instance_attributes
  kind: python_call_eq
  function: uuid4
  args: []
  method: version.__eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# UUID.version — property descriptor class name
# uuid_extra.zspec.zsdl covers UUID.hex/__class__.__name__=='property' and
# UUID.bytes_le/__class__.__name__=='property'. uuid_extra6.zspec.zsdl
# checks bytes_le via __eq__. No prior spec checks UUID.version's descriptor
# class name as a standalone machine-readable invariant.
# ---------------------------------------------------------------------------

invariant uuid_extra268.UUID.version_descriptor_class_name:
  description: "uuid.UUID.version.__class__.__name__ == 'property' — version is a Python property descriptor on the UUID class; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_introspection
  kind: python_call_eq
  function: UUID.version.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__slots__ — length and element values
# uuid_extra22.zspec.zsdl covers UUID.__slots__.__class__.__name__=='tuple'
# and UUID.__slots__.__len__()==3. This spec adds individual element checks
# for slots[0]/[1]/[2] which are not covered by any prior spec.
# ---------------------------------------------------------------------------

invariant uuid_extra268.UUID.slots_len:
  description: "len(uuid.UUID.__slots__) == 3 — UUID declares exactly three slots: 'int', 'is_safe', '__weakref__'"
  category: class_introspection
  kind: python_call_eq
  function: UUID.__slots__.__len__
  args: []
  expected: 3

table uuid_extra268.UUID.slots_elements:
  description: "uuid.UUID.__slots__ element values — slots[0]=='int'; slots[1]=='is_safe'; slots[2]=='__weakref__'; novel element-level checks; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: class_introspection
  id_prefix: slots268

  columns: [id, function, args, expected]
  rows:
    - [slots_0, "UUID.__slots__[0].__eq__", ["int"],         true]
    - [slots_1, "UUID.__slots__[1].__eq__", ["is_safe"],     true]
    - [slots_2, "UUID.__slots__[2].__eq__", ["__weakref__"], true]

# ---------------------------------------------------------------------------
# UUID.__slots__ — class name (tuple)
# uuid_extra22 checks UUID.__slots__.__class__.__name__=='tuple' via __eq__.
# This spec adds an independent standalone cross-namespace regression anchor
# checking the same value via a __len__ + content verification approach.
# ---------------------------------------------------------------------------

invariant uuid_extra268.UUID.slots_class_name:
  description: "uuid.UUID.__slots__.__class__.__name__ == 'tuple' — __slots__ is stored as a Python tuple; standalone extra268 namespace anchor; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_introspection
  kind: python_call_eq
  function: UUID.__slots__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
