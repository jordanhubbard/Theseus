spec: concurrent_futures_extra277
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "concurrent_futures_extra276.zspec.zsdl — covers concurrent.futures.wait and as_completed function identity; ProcessPoolExecutor class identity and method qualnames"
  notes:
    - "This spec covers: concurrent.futures.Future method qualnames (cancel, running, done, set_result, set_exception, add_done_callback); concurrent.futures.CancelledError MRO identity. NEW in extra277: Future.cancel.__qualname__=='Future.cancel' (len=13); Future.running.__qualname__=='Future.running' (len=14); Future.done.__qualname__=='Future.done' (len=11, shortest); Future.set_result.__qualname__=='Future.set_result' (len=18); Future.set_exception.__qualname__=='Future.set_exception' (len=21, longest); Future.add_done_callback.__qualname__=='Future.add_done_callback' (len=24, truly longest); CancelledError.__mro__.__len__()==5 ([CancelledError, Error, Exception, BaseException, object]); CancelledError.__bases__[0].__name__=='Error'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.Future.done.__qualname__ == 'Future.done' (len=11: 'Future.'=7+'done'=4). Future.done is the shortest method qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24: 'Future.'=7+'add_done_callback'=17). This is the longest method qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.CancelledError.__mro__ == [CancelledError, Error, Exception, BaseException, object] (length=5). CancelledError inherits from concurrent.futures._base.Error (an internal exception class), not directly from Exception; this gives it a 5-element MRO. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future method qualnames — extra277
#
# Future.cancel.__qualname__            == 'Future.cancel'           (len=13)
# Future.running.__qualname__           == 'Future.running'          (len=14)
# Future.done.__qualname__              == 'Future.done'             (len=11, shortest)
# Future.set_result.__qualname__        == 'Future.set_result'       (len=18)
# Future.set_exception.__qualname__     == 'Future.set_exception'    (len=21)
# Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24, longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra277.cf_future_method_qualnames:
  description: "concurrent.futures.Future method qualname checks in cffuture277 namespace — all Future methods are defined in Lib/concurrent/futures/_base.py; Future.cancel.__qualname__.__eq__('Future.cancel')==True (len=13: 'Future.'=7+'cancel'=6); Future.running.__qualname__.__eq__('Future.running')==True (len=14: 'Future.'=7+'running'=7); Future.done.__qualname__.__eq__('Future.done')==True (len=11: 'Future.'=7+'done'=4, shortest qualname in spec); Future.set_result.__qualname__.__eq__('Future.set_result')==True (len=18: 'Future.'=7+'set_result'=10, note underscore); Future.set_exception.__qualname__.__eq__('Future.set_exception')==True (len=21: 'Future.'=7+'set_exception'=13, note underscore); Future.add_done_callback.__qualname__.__eq__('Future.add_done_callback')==True (len=24: 'Future.'=7+'add_done_callback'=17, longest qualname in spec); all methods own (defined in Future, not inherited); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffuture277

  columns: [id, function, args, expected, description]
  rows:
    - [cancel_qn_eq,     "concurrent.futures.Future.cancel.__qualname__.__eq__",             ["Future.cancel"],            true, "Future.cancel.__qualname__ == 'Future.cancel' (len=13); verified with Python 3.14.3"]
    - [cancel_qn_len,    "concurrent.futures.Future.cancel.__qualname__.__len__",            [],                           13,   "Future.cancel.__qualname__.__len__() == 13 ('Future.cancel'=13); verified with Python 3.14.3"]
    - [running_qn_eq,    "concurrent.futures.Future.running.__qualname__.__eq__",            ["Future.running"],           true, "Future.running.__qualname__ == 'Future.running' (len=14); verified with Python 3.14.3"]
    - [running_qn_len,   "concurrent.futures.Future.running.__qualname__.__len__",           [],                           14,   "Future.running.__qualname__.__len__() == 14 ('Future.running'=14); verified with Python 3.14.3"]
    - [done_qn_eq,       "concurrent.futures.Future.done.__qualname__.__eq__",               ["Future.done"],              true, "Future.done.__qualname__ == 'Future.done' (len=11, shortest in spec); verified with Python 3.14.3"]
    - [done_qn_len,      "concurrent.futures.Future.done.__qualname__.__len__",              [],                           11,   "Future.done.__qualname__.__len__() == 11 ('Future.done'=11, shortest in spec); verified with Python 3.14.3"]
    - [setres_qn_eq,     "concurrent.futures.Future.set_result.__qualname__.__eq__",         ["Future.set_result"],        true, "Future.set_result.__qualname__ == 'Future.set_result' (len=18); verified with Python 3.14.3"]
    - [setres_qn_len,    "concurrent.futures.Future.set_result.__qualname__.__len__",        [],                           18,   "Future.set_result.__qualname__.__len__() == 18 ('Future.set_result'=18); verified with Python 3.14.3"]
    - [setexc_qn_eq,     "concurrent.futures.Future.set_exception.__qualname__.__eq__",      ["Future.set_exception"],     true, "Future.set_exception.__qualname__ == 'Future.set_exception' (len=21); verified with Python 3.14.3"]
    - [setexc_qn_len,    "concurrent.futures.Future.set_exception.__qualname__.__len__",     [],                           21,   "Future.set_exception.__qualname__.__len__() == 21 ('Future.set_exception'=21); verified with Python 3.14.3"]
    - [adc_qn_eq,        "concurrent.futures.Future.add_done_callback.__qualname__.__eq__",  ["Future.add_done_callback"], true, "Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24, longest); verified with Python 3.14.3"]
    - [adc_qn_len,       "concurrent.futures.Future.add_done_callback.__qualname__.__len__", [],                           24,   "Future.add_done_callback.__qualname__.__len__() == 24 ('Future.add_done_callback'=24, longest in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.CancelledError MRO identity — extra277
#
# CancelledError.__bases__[0].__name__   == 'Error'
# CancelledError.__mro__.__len__()       == 5
# CancelledError.__mro__ == [CancelledError, Error, Exception, BaseException, object]
# CancelledError.__module__              == 'concurrent.futures._base'
# CancelledError.__qualname__            == 'CancelledError'
# ---------------------------------------------------------------------------

table concurrent_futures_extra277.cf_cancelled_error_identity:
  description: "concurrent.futures.CancelledError MRO identity checks in cfcancel277 namespace — CancelledError is defined in Lib/concurrent/futures/_base.py alongside the Error base class; CancelledError.__bases__[0].__name__.__eq__('Error')==True (CancelledError inherits from concurrent.futures._base.Error, an internal exception class, not directly from Exception); CancelledError.__mro__.__len__()==5 ([CancelledError, Error, Exception, BaseException, object]); CancelledError.__module__.__eq__('concurrent.futures._base')==True; CancelledError.__qualname__.__eq__('CancelledError')==True; CancelledError.__name__.__len__()==14 ('CancelledError'=14); compare: asyncio.exceptions.CancelledError inherits directly from BaseException (MRO len=3), while concurrent.futures.CancelledError inherits from Error->Exception->BaseException (MRO len=5); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfcancel277

  columns: [id, function, args, expected, description]
  rows:
    - [ce_base0_eq,   "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__",  ["Error"],                          true, "CancelledError.__bases__[0].__name__ == 'Error' (inherits from internal Error class); verified with Python 3.14.3"]
    - [ce_mro_len,    "concurrent.futures.CancelledError.__mro__.__len__",               [],                                 5,    "CancelledError.__mro__.__len__() == 5 — [CancelledError, Error, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [ce_mod_eq,     "concurrent.futures.CancelledError.__module__.__eq__",             ["concurrent.futures._base"],       true, "CancelledError.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [ce_qn_eq,      "concurrent.futures.CancelledError.__qualname__.__eq__",           ["CancelledError"],                 true, "CancelledError.__qualname__ == 'CancelledError' (module-level class); verified with Python 3.14.3"]
    - [ce_name_len,   "concurrent.futures.CancelledError.__name__.__len__",              [],                                 14,   "CancelledError.__name__.__len__() == 14 ('CancelledError'=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra277
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra277.Future_done_qualname_len_is_11:
  description: "concurrent.futures.Future.done.__qualname__.__len__() == 11 — Future.done.__qualname__ is 'Future.done' (len=11: 'Future.'=7+'done'=4); this is the shortest method qualname in this spec; compare qualname lengths in spec: Future.done=11, Future.cancel=13, Future.running=14, Future.set_result=18, Future.set_exception=21, Future.add_done_callback=24 (longest); all six are own methods defined in Lib/concurrent/futures/_base.py; Future.done() returns True if the Future is done (cancelled, finished, or raised an exception); NEW in extra277: first standalone Future.done qualname length invariant in cffuture277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.done.__qualname__.__len__"
  args: []
  expected: 11

invariant concurrent_futures_extra277.Future_add_done_callback_qualname_len_is_24:
  description: "concurrent.futures.Future.add_done_callback.__qualname__.__len__() == 24 — Future.add_done_callback.__qualname__ is 'Future.add_done_callback' (len=24: 'Future.'=7+'add_done_callback'=17); this is the longest method qualname in this spec; compare qualname lengths: done=11, cancel=13, running=14, set_result=18, set_exception=21, add_done_callback=24 (longest); add_done_callback() registers a callback to be called when the Future completes; add_done_callback.__qualname__.__eq__('Future.add_done_callback') returns True; NEW in extra277: first standalone Future.add_done_callback qualname length invariant in cffuture277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.add_done_callback.__qualname__.__len__"
  args: []
  expected: 24

invariant concurrent_futures_extra277.CancelledError_mro_len_is_5:
  description: "concurrent.futures.CancelledError.__mro__.__len__() == 5 — CancelledError's MRO is [CancelledError, Error, Exception, BaseException, object] (length=5); CancelledError inherits from the internal concurrent.futures._base.Error class (not directly from Exception), adding an extra level to its MRO; compare: asyncio.exceptions.CancelledError.__mro__.__len__() == 3 ([CancelledError, BaseException, object], inherits directly from BaseException); the Error intermediate base provides a common root for all concurrent.futures exceptions; CancelledError.__bases__[0].__name__ is 'Error'; CancelledError.__module__ is 'concurrent.futures._base'; NEW in extra277: first standalone CancelledError MRO length invariant in cfcancel277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.CancelledError.__mro__.__len__"
  args: []
  expected: 5

invariant concurrent_futures_extra277.CancelledError_base_is_Error:
  description: "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__('Error') returns True — CancelledError's direct base is the internal 'Error' class from concurrent.futures._base; this 'Error' class is distinct from Python's built-in Exception; the Error base provides a common catch-all for concurrent.futures-specific exceptions; CancelledError.__mro__.__len__() is 5 ([CancelledError, Error, Exception, BaseException, object]); note that the builtin concurrent.futures.CancelledError is the same object as the stdlib CancelledError in Python 3.8+; CancelledError.__module__ is 'concurrent.futures._base'; NEW in extra277: first standalone CancelledError base class invariant in cfcancel277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

invariant concurrent_futures_extra277.Future_running_qualname_eq:
  description: "concurrent.futures.Future.running.__qualname__.__eq__('Future.running') returns True — Future.running.__qualname__ is 'Future.running' (len=14: 'Future.'=7+'running'=7); Future.running() returns True if the Future is currently executing; it is an own method defined in Lib/concurrent/futures/_base.py; Future.running.__name__ is 'running' (len=7); compare qualname lengths: done=11, cancel=13, running=14, set_result=18; Future.running.__qualname__.__len__() is 14; NEW in extra277: first standalone Future.running qualname invariant in cffuture277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.running.__qualname__.__eq__"
  args: ["Future.running"]
  expected: true
