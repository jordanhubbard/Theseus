spec: threading_extra2146
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2146 (_extra2146): numeric conversion protocol dict-presence checks — __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__ for threading types."
    - "Theme: numeric conversion protocol dict-presence — checking whether numeric dunder methods (math.trunc, math.floor, math.ceil, integer index protocol, complex conversion, truth testing, int conversion) are defined at the class level in __dict__ for threading synchronization types."
    - "threading.Thread, Event, Condition, Semaphore, BoundedSemaphore, Barrier are synchronization/lifecycle types. None define numeric conversion dunders."
    - "threading.Lock is actually the C-level type _thread.lock (accessible as threading.Lock, which is the class itself). Its __dict__ contains only lock-specific methods (acquire, release, locked, __enter__, __exit__). No numeric dunders."
    - "threading.RLock is a factory function (type 'function') in CPython — threading.RLock() returns a _thread.RLock or threading._RLock instance depending on the build. threading.RLock.__dict__ is a plain function dict (no numeric dunders)."
    - "threading._RLock is the pure-Python fallback RLock class (threading._PyRLock alias). Its __dict__ contains acquire, release, __enter__, __exit__, _is_owned. No numeric dunders."
    - "All seven target methods (__trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__) are absent from all threading class __dict__ objects."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: numeric conversion protocol dict-presence for threading.Thread,
#          threading.Event, threading.Condition
#
# Thread manages thread lifecycle. Event is a simple flag object. Condition
# wraps a lock with wait/notify semantics. None are numeric types.
# ---------------------------------------------------------------------------

table threading_extra2146.thread_event_condition_numeric_protocol:
  description: "threading.Thread, threading.Event, threading.Condition numeric conversion protocol dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2146

  columns: [id, function, args, expected]
  rows:
    - ["th2146001", "threading.Thread.__dict__.__contains__",    ["__trunc__"],   false]
    - ["th2146002", "threading.Thread.__dict__.__contains__",    ["__floor__"],   false]
    - ["th2146003", "threading.Thread.__dict__.__contains__",    ["__ceil__"],    false]
    - ["th2146004", "threading.Thread.__dict__.__contains__",    ["__index__"],   false]
    - ["th2146005", "threading.Thread.__dict__.__contains__",    ["__complex__"], false]
    - ["th2146006", "threading.Thread.__dict__.__contains__",    ["__bool__"],    false]
    - ["th2146007", "threading.Thread.__dict__.__contains__",    ["__int__"],     false]
    - ["th2146008", "threading.Event.__dict__.__contains__",     ["__trunc__"],   false]
    - ["th2146009", "threading.Event.__dict__.__contains__",     ["__floor__"],   false]
    - ["th2146010", "threading.Event.__dict__.__contains__",     ["__ceil__"],    false]
    - ["th2146011", "threading.Event.__dict__.__contains__",     ["__index__"],   false]
    - ["th2146012", "threading.Event.__dict__.__contains__",     ["__complex__"], false]
    - ["th2146013", "threading.Event.__dict__.__contains__",     ["__bool__"],    false]
    - ["th2146014", "threading.Event.__dict__.__contains__",     ["__int__"],     false]
    - ["th2146015", "threading.Condition.__dict__.__contains__", ["__trunc__"],   false]
    - ["th2146016", "threading.Condition.__dict__.__contains__", ["__floor__"],   false]
    - ["th2146017", "threading.Condition.__dict__.__contains__", ["__ceil__"],    false]
    - ["th2146018", "threading.Condition.__dict__.__contains__", ["__index__"],   false]
    - ["th2146019", "threading.Condition.__dict__.__contains__", ["__complex__"], false]
    - ["th2146020", "threading.Condition.__dict__.__contains__", ["__bool__"],    false]
    - ["th2146021", "threading.Condition.__dict__.__contains__", ["__int__"],     false]

