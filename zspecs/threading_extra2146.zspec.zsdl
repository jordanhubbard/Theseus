# ---------------------------------------------------------------------------
# Table 3: numeric conversion protocol dict-presence for threading.Lock
#          and threading._RLock
#
# threading.Lock is the C-level _thread.lock type (exposed directly as a
# class in the threading namespace). Its __dict__ holds only lock primitives.
# threading._RLock is the pure-Python reentrant lock class. Neither type
# defines any numeric conversion dunders.
# ---------------------------------------------------------------------------

table threading_extra2146.lock_rlock_numeric_protocol:
  description: "threading.Lock (C-level _thread.lock type) and threading._RLock numeric conversion protocol dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2146

  columns: [id, function, args, expected]
  rows:
    - ["th2146043", "threading.Lock.__dict__.__contains__",  ["__trunc__"],   false]
    - ["th2146044", "threading.Lock.__dict__.__contains__",  ["__floor__"],   false]
    - ["th2146045", "threading.Lock.__dict__.__contains__",  ["__ceil__"],    false]
    - ["th2146046", "threading.Lock.__dict__.__contains__",  ["__index__"],   false]
    - ["th2146047", "threading.Lock.__dict__.__contains__",  ["__complex__"], false]
    - ["th2146048", "threading.Lock.__dict__.__contains__",  ["__bool__"],    false]
    - ["th2146049", "threading.Lock.__dict__.__contains__",  ["__int__"],     false]
    - ["th2146050", "threading._RLock.__dict__.__contains__", ["__trunc__"],   false]
