spec: pathlib_extra2356
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra.zspec.zsdl — covers class names, instance creation, path components"
  notes:
    - "Wave 2356, theme: __init__ and __new__ implementation type classification."
    - "pathlib classes are pure Python; __init__ and __new__ are plain Python functions."
    - "pathlib.PurePath.__init__.__class__.__name__ == 'function' (verified Python 3.13, macOS)."
    - "pathlib.PurePath.__new__.__class__.__name__ == 'function' (verified Python 3.13, macOS)."
    - "pathlib.Path.__new__.__class__.__name__ == 'function' (verified Python 3.13, macOS)."
    - "pathlib.PosixPath.__new__.__class__.__name__ == 'function' (verified Python 3.13, macOS)."
    - "Contrast with C extension types (io, re.Pattern) where __init__ is 'wrapper_descriptor'."
    - "PurePosixPath, PureWindowsPath, PosixPath, WindowsPath all inherit from PurePath."
    - "pathlib uses __new__ for construction; __init__ is also defined as a Python function."
    - "All expected values verified by running Python 3.13 pathlib module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __init__.__class__.__name__ — all pathlib Python classes
# ---------------------------------------------------------------------------

table pathlib_extra2356.init_class_name:
  kind: python_call_eq
  category: impl_type
  id_prefix: pp2356

  columns: [id, function, args, expected]
  rows:
    - ["pp2356001", PurePath.__init__.__class__.__name__.__eq__,      ["function"], true]
    - ["pp2356002", PurePosixPath.__init__.__class__.__name__.__eq__, ["function"], true]
    - ["pp2356003", Path.__init__.__class__.__name__.__eq__,          ["function"], true]
    - ["pp2356004", PosixPath.__init__.__class__.__name__.__eq__,     ["function"], true]

# ---------------------------------------------------------------------------
# __new__.__class__.__name__ — all pathlib Python classes
# ---------------------------------------------------------------------------

table pathlib_extra2356.new_class_name:
  kind: python_call_eq
  category: impl_type
  id_prefix: pp2356

  columns: [id, function, args, expected]
  rows:
    - ["pp2356005", PurePath.__new__.__class__.__name__.__eq__,      ["function"], true]
    - ["pp2356006", PurePosixPath.__new__.__class__.__name__.__eq__, ["function"], true]
    - ["pp2356007", Path.__new__.__class__.__name__.__eq__,          ["function"], true]
    - ["pp2356008", PosixPath.__new__.__class__.__name__.__eq__,     ["function"], true]

# ---------------------------------------------------------------------------
# Contrast: __init__ is NOT wrapper_descriptor for any pathlib class
# ---------------------------------------------------------------------------

table pathlib_extra2356.init_not_wrapper_descriptor:
  kind: python_call_eq
  category: impl_type
  id_prefix: pp2356

  columns: [id, function, args, expected]
  rows:
    - ["pp2356009",  PurePath.__init__.__class__.__name__.__eq__,      ["wrapper_descriptor"], false]
    - ["pp2356010",  PurePosixPath.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], false]
    - ["pp2356011",  Path.__init__.__class__.__name__.__eq__,          ["wrapper_descriptor"], false]
    - ["pp2356012",  PosixPath.__init__.__class__.__name__.__eq__,     ["wrapper_descriptor"], false]

# ---------------------------------------------------------------------------
# Contrast: __new__ is NOT builtin_function_or_method for any pathlib class
# ---------------------------------------------------------------------------

table pathlib_extra2356.new_not_builtin:
  kind: python_call_eq
  category: impl_type
  id_prefix: pp2356

  columns: [id, function, args, expected]
  rows:
    - ["pp2356013", PurePath.__new__.__class__.__name__.__eq__,      ["builtin_function_or_method"], false]
    - ["pp2356014", PurePosixPath.__new__.__class__.__name__.__eq__, ["builtin_function_or_method"], false]
    - ["pp2356015", Path.__new__.__class__.__name__.__eq__,          ["builtin_function_or_method"], false]
    - ["pp2356016", PosixPath.__new__.__class__.__name__.__eq__,     ["builtin_function_or_method"], false]

# ---------------------------------------------------------------------------
# __init__ and __new__ are both Python functions (not slot_wrapper either)
# ---------------------------------------------------------------------------

table pathlib_extra2356.init_not_slot_wrapper:
  kind: python_call_eq
  category: impl_type
  id_prefix: pp2356

  columns: [id, function, args, expected]
  rows:
    - ["pp2356017", PurePath.__init__.__class__.__name__.__eq__, ["slot_wrapper"], false]
    - ["pp2356018", Path.__init__.__class__.__name__.__eq__,     ["slot_wrapper"], false]
    - ["pp2356019", PurePath.__new__.__class__.__name__.__eq__,  ["slot_wrapper"], false]
    - ["pp2356020", Path.__new__.__class__.__name__.__eq__,      ["slot_wrapper"], false]
