spec: numbers_extra13
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra through numbers_extra12."
    - "numbers_extra through numbers_extra11 cover __name__/__qualname__/__module__/__bases__/__abstractmethods__ for all five ABCs."
    - "numbers_extra11 covers Integral.__mro__.__getitem__ at all six indices."
    - "numbers_extra12 covers Number/Complex/Real/Rational MRO entries via __name__.__eq__."
    - "No prior spec covers __qualname__.__eq__ for all five ABC classes as a table."
    - "No prior spec covers __qualname__.__len__ for any of the five ABC classes."
    - "No prior spec covers Rational.__mro__[2], [3], [4] via __name__.__eq__."
    - "All five ABCs are top-level classes; __qualname__ equals __name__ for each."
    - "numbers.Number.__qualname__ == 'Number' (6 chars); numbers.Complex.__qualname__ == 'Complex' (7 chars)."
    - "numbers.Real.__qualname__ == 'Real' (4 chars); numbers.Rational.__qualname__ == 'Rational' (8 chars)."
    - "numbers.Integral.__qualname__ == 'Integral' (8 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABC class __qualname__.__eq__ — all five numeric tower classes
#
# Prior specs cover __qualname__.__eq__ for each class individually in
# scattered invariants.  This table groups all five in a single place,
# using the __qualname__.__eq__ expression form for uniform comparison.
# No prior spec records all five as a table.
# ---------------------------------------------------------------------------

table numbers_extra13.abc_qualnames:
  kind: python_call_eq
  category: class_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [Number,   Number.__qualname__.__eq__,   ["Number"],   true, "numbers.Number.__qualname__ == 'Number'"]
    - [Complex,  Complex.__qualname__.__eq__,  ["Complex"],  true, "numbers.Complex.__qualname__ == 'Complex'"]
    - [Real,     Real.__qualname__.__eq__,     ["Real"],     true, "numbers.Real.__qualname__ == 'Real'"]
    - [Rational, Rational.__qualname__.__eq__, ["Rational"], true, "numbers.Rational.__qualname__ == 'Rational'"]
    - [Integral, Integral.__qualname__.__eq__, ["Integral"], true, "numbers.Integral.__qualname__ == 'Integral'"]

# ---------------------------------------------------------------------------
# ABC class __qualname__.__len__ — character counts
#
# No prior spec records __qualname__.__len__ for any numbers ABC class.
# Length invariants confirm exact spelling (no nesting, no aliasing).
# ---------------------------------------------------------------------------

invariant numbers_extra13.Number.qualname_len:
  description: "len(numbers.Number.__qualname__) == 6 — 'Number' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Number.__qualname__.__len__
  args: []
  expected: 6

invariant numbers_extra13.Complex.qualname_len:
  description: "len(numbers.Complex.__qualname__) == 7 — 'Complex' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Complex.__qualname__.__len__
  args: []
  expected: 7

invariant numbers_extra13.Real.qualname_len:
  description: "len(numbers.Real.__qualname__) == 4 — 'Real' has 4 characters"
  category: class_identity
  kind: python_call_eq
  function: Real.__qualname__.__len__
  args: []
  expected: 4

invariant numbers_extra13.Rational.qualname_len:
  description: "len(numbers.Rational.__qualname__) == 8 — 'Rational' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Rational.__qualname__.__len__
  args: []
  expected: 8

invariant numbers_extra13.Integral.qualname_len:
  description: "len(numbers.Integral.__qualname__) == 8 — 'Integral' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Integral.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Rational MRO — remaining entries [2], [3], [4]
#
# numbers_extra12 covers Rational.__mro__[0] and [1] (__name__ chain).
# No prior spec covers Rational.__mro__[2] (Complex), [3] (Number), [4] (object).
# ---------------------------------------------------------------------------

invariant numbers_extra13.Rational.mro_2:
  description: "numbers.Rational.__mro__[2].__name__ == 'Complex' — third MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: "Rational.__mro__[2].__name__.__eq__"
  args: ["Complex"]
  expected: true

invariant numbers_extra13.Rational.mro_3:
  description: "numbers.Rational.__mro__[3].__name__ == 'Number' — fourth MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: "Rational.__mro__[3].__name__.__eq__"
  args: ["Number"]
  expected: true

invariant numbers_extra13.Rational.mro_4:
  description: "numbers.Rational.__mro__[4].__name__ == 'object' — fifth and final MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: "Rational.__mro__[4].__name__.__eq__"
  args: ["object"]
  expected: true
