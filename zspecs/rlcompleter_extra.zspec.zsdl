spec: rlcompleter_extra
version: ">=3.9"
backend: python_module(rlcompleter)

docs: https://docs.python.org/3/library/rlcompleter.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/rlcompleter.html — Python rlcompleter module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/rlcompleter.py"
  notes:
    - "Extends rlcompleter.zspec.zsdl with additional class, method, and inheritance invariants."
    - "rlcompleter.Completer is a pure-Python class; its __name__ and __module__ are well-defined."
    - "Completer inherits directly from object; __bases__ has exactly one entry."
    - "complete, global_matches, and attr_matches are the three public methods on Completer."
    - "Completer.__init__ accepts an optional namespace dict; omitting it defaults to the caller's globals."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Completer class — name and module affiliation
# ---------------------------------------------------------------------------

invariant rlcompleter_extra.Completer.name:
  description: "rlcompleter.Completer.__name__ == 'Completer'"
  category: classes
  kind: python_call_eq
  function: Completer.__name__.__eq__
  args: ["Completer"]
  expected: true

invariant rlcompleter_extra.Completer.module:
  description: "rlcompleter.Completer.__module__ == 'rlcompleter'"
  category: classes
  kind: python_call_eq
  function: Completer.__module__.__eq__
  args: ["rlcompleter"]
  expected: true

# ---------------------------------------------------------------------------
# Completer inheritance — base class is object
# ---------------------------------------------------------------------------

invariant rlcompleter_extra.Completer.base_is_object:
  description: "rlcompleter.Completer.__bases__[0].__name__ == 'object'"
  category: classes
  kind: python_call_eq
  function: Completer.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant rlcompleter_extra.Completer.bases_len:
  description: "len(rlcompleter.Completer.__bases__) == 1 — Completer has exactly one direct base"
  category: classes
  kind: python_call_eq
  function: Completer.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Method names on Completer
# ---------------------------------------------------------------------------

invariant rlcompleter_extra.Completer.complete.name:
  description: "rlcompleter.Completer.complete.__name__ == 'complete'"
  category: methods
  kind: python_call_eq
  function: Completer.complete.__name__.__eq__
  args: ["complete"]
  expected: true

invariant rlcompleter_extra.Completer.global_matches.name:
  description: "rlcompleter.Completer.global_matches.__name__ == 'global_matches'"
  category: methods
  kind: python_call_eq
  function: Completer.global_matches.__name__.__eq__
  args: ["global_matches"]
  expected: true

invariant rlcompleter_extra.Completer.attr_matches.name:
  description: "rlcompleter.Completer.attr_matches.__name__ == 'attr_matches'"
  category: methods
  kind: python_call_eq
  function: Completer.attr_matches.__name__.__eq__
  args: ["attr_matches"]
  expected: true

# ---------------------------------------------------------------------------
# Method types — all three public methods are plain functions
# ---------------------------------------------------------------------------

invariant rlcompleter_extra.Completer.complete.is_function:
  description: "type(rlcompleter.Completer.complete).__name__ == 'function'"
  category: methods
  kind: python_call_eq
  function: Completer.complete.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant rlcompleter_extra.Completer.global_matches.is_function:
  description: "type(rlcompleter.Completer.global_matches).__name__ == 'function'"
  category: methods
  kind: python_call_eq
  function: Completer.global_matches.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant rlcompleter_extra.Completer.attr_matches.is_function:
  description: "type(rlcompleter.Completer.attr_matches).__name__ == 'function'"
  category: methods
  kind: python_call_eq
  function: Completer.attr_matches.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Module identity — rlcompleter.__name__ is 'rlcompleter'
# ---------------------------------------------------------------------------

invariant rlcompleter_extra.module.name:
  description: "rlcompleter.__name__ == 'rlcompleter' — the module's own __name__ attribute"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["rlcompleter"]
  expected: true

# ---------------------------------------------------------------------------
# Completer.__init__ — present and is a function
# ---------------------------------------------------------------------------

invariant rlcompleter_extra.Completer.init.name:
  description: "rlcompleter.Completer.__init__.__name__ == '__init__'"
  category: methods
  kind: python_call_eq
  function: Completer.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true
