spec: uuid_extra2056
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "uuid.UUID defines __setattr__ in its own __dict__ (it overrides it to enforce immutability). All other sequence/mapping/attr-access dunders are absent."
    - "uuid.SafeUUID is an IntEnum subclass; none of the sequence/mapping/attr-access protocol methods appear in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2056.getitem_protocol:
  description: "uuid types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2056

  columns: [id, function, args, expected]
  rows:
    - ["uu2056001", "uuid.UUID.__dict__.__contains__",     ["__getitem__"], false]
    - ["uu2056002", "uuid.UUID.__dict__.__contains__",     ["__setitem__"], false]
    - ["uu2056003", "uuid.UUID.__dict__.__contains__",     ["__delitem__"], false]
    - ["uu2056004", "uuid.SafeUUID.__dict__.__contains__", ["__getitem__"], false]
    - ["uu2056005", "uuid.SafeUUID.__dict__.__contains__", ["__setitem__"], false]
    - ["uu2056006", "uuid.SafeUUID.__dict__.__contains__", ["__delitem__"], false]

