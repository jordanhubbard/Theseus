spec: functools_extra69
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra68.zspec.zsdl."
    - "Wave 230 theme: __code__ attribute deep chains — co_name, co_varnames class identity, co_argcount values, co_flags checks."
    - "wraps.__code__.co_name == 'wraps' — co_name is the qualified name of the Python function as a str. For wraps, it is the string 'wraps' (5 chars). Verified with Python 3.14.3."
    - "update_wrapper.__code__.co_name == 'update_wrapper' — co_name for update_wrapper is the string 'update_wrapper' (14 chars). Verified with Python 3.14.3."
    - "lru_cache.__code__.co_name == 'lru_cache' — co_name for lru_cache is the string 'lru_cache' (9 chars). Verified with Python 3.14.3."
    - "wraps.__code__.co_name.__class__.__name__ == 'str' — co_name is always a plain str object. str.__name__ == 'str' (3 chars). Verified with Python 3.14.3."
    - "wraps.__code__.co_argcount == 3 — co_argcount counts positional parameters (including those with defaults), excluding *args, **kwargs, and keyword-only parameters. wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) has 3 positional parameters: wrapped, assigned, updated. So co_argcount == 3. Verified with Python 3.14.3."
    - "update_wrapper.__code__.co_argcount == 4 — update_wrapper(wrapper, wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) has 4 positional parameters: wrapper, wrapped, assigned, updated. So co_argcount == 4. Verified with Python 3.14.3."
    - "lru_cache.__code__.co_argcount == 2 — lru_cache(maxsize=128, typed=False) has 2 positional parameters: maxsize, typed. So co_argcount == 2. Verified with Python 3.14.3."
    - "No prior functools spec checks co_name or co_argcount for any functools function. All checks in this spec are new to extra69."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools __code__.co_name checks — extra69
#
# Wave 230 theme: __code__.co_name deep chains.
#
# co_name is the name field of the code object (PyCodeObject.co_name).
# It is a str equal to the function's name as defined in its def statement.
#
# wraps.__code__.co_name == 'wraps'
# update_wrapper.__code__.co_name == 'update_wrapper'
# lru_cache.__code__.co_name == 'lru_cache'
#
# We verify via __eq__ which returns True when the names match.
#
# No prior functools spec checks co_name for any function. New to extra69.
# ---------------------------------------------------------------------------

table functools_extra69.co_name_eq:
  description: "functools function __code__.co_name.__eq__ — co_name matches the def-statement name; wave 230 co_name deep chains; new to extra69"
  kind: python_call_eq
  category: co_name
  id_prefix: functoolscode69

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_co_name_eq_wraps,
       wraps.__code__.co_name.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__code__.co_name.__eq__('wraps') == True — wraps is a pure-Python function (Lib/functools.py) defined with 'def wraps(...)'; the code object attribute co_name (PyCodeObject.co_name) stores the function's name as a plain str; for wraps it is the 5-character string 'wraps'; __eq__ on a str returns True when the argument equals the string; no prior functools spec checks co_name for wraps; new to extra69"]
    - [update_wrapper_code_co_name_eq_update_wrapper,
       update_wrapper.__code__.co_name.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True — update_wrapper is a pure-Python function (Lib/functools.py) defined with 'def update_wrapper(...)'; co_name for update_wrapper is the 14-character string 'update_wrapper'; __eq__ returns True; no prior functools spec checks co_name for update_wrapper; new to extra69"]
    - [lru_cache_code_co_name_eq_lru_cache,
       lru_cache.__code__.co_name.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — lru_cache is a pure-Python function (Lib/functools.py) defined with 'def lru_cache(...)'; co_name for lru_cache is the 9-character string 'lru_cache'; __eq__ returns True; no prior functools spec checks co_name for lru_cache; new to extra69"]

# ---------------------------------------------------------------------------
# wraps.__code__.co_name.__class__.__name__ — extra69
#
# Wave 230 theme: co_name is always a str.
#
# co_name is stored as a PyObject* in PyCodeObject.co_name; it is always an
# interned str in CPython. Therefore co_name.__class__ is the built-in str
# type, and str.__name__ == 'str'.
#
# Checking co_name.__class__.__name__.__eq__('str') confirms the type of the
# co_name attribute without depending on the exact function name string.
#
# No prior functools spec checks co_name.__class__.__name__. New to extra69.
# ---------------------------------------------------------------------------

table functools_extra69.co_name_class_name:
  description: "wraps.__code__.co_name.__class__.__name__.__eq__('str')==true — co_name is always a str object; wave 230 co_name deep chains; new to extra69"
  kind: python_call_eq
  category: co_name
  id_prefix: functoolscode69

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_co_name_class_name_eq_str,
       wraps.__code__.co_name.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.wraps.__code__.co_name.__class__.__name__.__eq__('str') == True — wraps is a pure-Python function (Lib/functools.py); its __code__ is a PyCodeObject; PyCodeObject.co_name is always an interned str object in CPython (it is stored as a PyObject* and created from the function name at compile time); therefore co_name.__class__ is the built-in str type and str.__name__ == 'str' (3 chars); __eq__ returns True; this chain verifies the type of co_name without depending on the name's content; no prior functools spec checks co_name.__class__.__name__; new to extra69"]

# ---------------------------------------------------------------------------
# functools __code__.co_argcount values — extra69
#
# Wave 230 theme: co_argcount counts positional parameters.
#
# co_argcount (PyCodeObject.co_argcount) counts the total number of positional
# parameters (including those with default values), but excludes *args,
# **kwargs, and keyword-only parameters (those after a bare *).
#
# wraps(wrapped, assigned=..., updated=...) — 3 positional params → co_argcount == 3
# update_wrapper(wrapper, wrapped, assigned=..., updated=...) — 4 → co_argcount == 4
# lru_cache(maxsize=128, typed=False) — 2 positional params → co_argcount == 2
#
# Verified with Python 3.14.3: wraps=3, update_wrapper=4, lru_cache=2.
#
# No prior functools spec checks co_argcount. New to extra69.
# ---------------------------------------------------------------------------

table functools_extra69.co_argcount_eq:
  description: "functools function __code__.co_argcount — positional parameter count; wave 230 co_argcount values; new to extra69"
  kind: python_call_eq
  category: co_argcount
  id_prefix: functoolscode69

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_co_argcount_eq_3,
       wraps.__code__.co_argcount.__eq__,
       [3],
       true,
       "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps is a pure-Python function (Lib/functools.py) with signature wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES); co_argcount counts positional parameters including those with defaults but excluding *args, **kwargs, and keyword-only parameters; here wrapped, assigned, and updated are all positional (none are keyword-only after a bare *), giving co_argcount == 3; verified with Python 3.14.3; no prior functools spec checks co_argcount for wraps; new to extra69"]
    - [update_wrapper_code_co_argcount_eq_4,
       update_wrapper.__code__.co_argcount.__eq__,
       [4],
       true,
       "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper is a pure-Python function (Lib/functools.py) with signature update_wrapper(wrapper, wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES); all 4 parameters (wrapper, wrapped, assigned, updated) are positional; co_argcount == 4; verified with Python 3.14.3; no prior functools spec checks co_argcount for update_wrapper; new to extra69"]
    - [lru_cache_code_co_argcount_eq_2,
       lru_cache.__code__.co_argcount.__eq__,
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache is a pure-Python function (Lib/functools.py) with signature lru_cache(maxsize=128, typed=False); both maxsize and typed are positional parameters (with defaults); co_argcount == 2; verified with Python 3.14.3; no prior functools spec checks co_argcount for lru_cache; new to extra69"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra69
# ---------------------------------------------------------------------------

invariant functools_extra69.wraps_co_name_eq_wraps:
  description: "functools.wraps.__code__.co_name.__eq__('wraps') == True — co_name is the function's def-statement name; wave 230 co_name deep chains; new to extra69"
  kind: python_call_eq
  function: wraps.__code__.co_name.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra69.lru_cache_co_name_eq_lru_cache:
  description: "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — co_name is the function's def-statement name; wave 230 co_name deep chains; new to extra69"
  kind: python_call_eq
  function: lru_cache.__code__.co_name.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra69.wraps_co_name_class_name_eq_str:
  description: "functools.wraps.__code__.co_name.__class__.__name__.__eq__('str') == True — co_name is always a str object; wave 230 co_name deep chains; new to extra69"
  kind: python_call_eq
  function: wraps.__code__.co_name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra69.wraps_co_argcount_eq_3:
  description: "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps has 3 positional parameters (wrapped, assigned, updated); wave 230 co_argcount values; new to extra69"
  kind: python_call_eq
  function: wraps.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant functools_extra69.update_wrapper_co_argcount_eq_4:
  description: "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper has 4 positional parameters (wrapper, wrapped, assigned, updated); wave 230 co_argcount values; new to extra69"
  kind: python_call_eq
  function: update_wrapper.__code__.co_argcount.__eq__
  args: [4]
  expected: true
