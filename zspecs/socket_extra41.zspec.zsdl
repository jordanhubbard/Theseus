spec: socket_extra41
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra40.zspec.zsdl — covers getdefaulttimeout.__qualname__.__eq__('getdefaulttimeout'); socket.socket fileno/close/setsockopt/getsockopt __name__.__eq__ string values."
    - "socket_extra39.zspec.zsdl — covers socket.socket connect/bind/accept/listen/send/recv __name__.__eq__ string values."
    - "socket_extra38.zspec.zsdl — covers socket.AF_INET==2, SOCK_STREAM==1, SOCK_DGRAM==2; getfqdn/__name__=='getfqdn'; getfqdn/__module__=='socket'."
    - "socket_extra37.zspec.zsdl — covers socket.socket recvfrom/sendto/makefile/connect_ex/recv_into/recvfrom_into __name__.__len__(); dup/get_inheritable/set_inheritable __name__.__len__() (length checks only, NOT string eq values)."
    - "socket_extra34.zspec.zsdl — covers socket.socket close/setblocking/getsockname/fileno/detach/shutdown/sendall __name__.__len__() (length checks only, NOT string eq values)."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3; setsockopt/getsockopt/__name__.__len__()==10; settimeout/getpeername __name__/__qualname__.__len__() (length checks only, NOT string eq values)."
    - "socket_extra11.zspec.zsdl — covers setdefaulttimeout/__module__.__eq__('_socket'); getdefaulttimeout/__module__.__eq__('_socket')."
    - "socket_extra7.zspec.zsdl — covers setdefaulttimeout/__name__.__eq__('setdefaulttimeout'); getdefaulttimeout/__name__.__eq__('getdefaulttimeout')."
  notes:
    - "This spec extends socket through socket_extra40; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: socket_extra39 covers connect/bind/accept/listen/send/recv __name__.__eq__; socket_extra40 covers fileno/close/setsockopt/getsockopt __name__.__eq__. But NO prior spec checks socket.socket.setblocking/__name__.__eq__('setblocking'), getpeername/__name__.__eq__('getpeername'), getsockname/__name__.__eq__('getsockname'), makefile/__name__.__eq__('makefile'), detach/__name__.__eq__('detach'), or dup/__name__.__eq__('dup') as string eq values. Prior specs cover these methods' __name__.__len__() (length checks) but NOT __name__.__eq__ (string eq values). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__name__ == 'setblocking'. extra34 covers __name__.__len__()==11 (length only). No prior spec checks __name__.__eq__('setblocking'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__name__ == 'getpeername'. extra29 covers __name__.__len__()==11 (length only). No prior spec checks __name__.__eq__('getpeername'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__name__ == 'getsockname'. extra34 covers __name__.__len__()==11 (length only). No prior spec checks __name__.__eq__('getsockname'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__name__ == 'makefile'. extra37 covers __name__.__len__()==8 (length only). No prior spec checks __name__.__eq__('makefile'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__name__ == 'detach'. extra34 covers __name__.__len__()==6 (length only). No prior spec checks __name__.__eq__('detach'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__name__ == 'dup'. extra37 covers __name__.__len__()==3 (length only). No prior spec checks __name__.__eq__('dup'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: socket_extra11 covers setdefaulttimeout/__module__.__eq__('_socket') and getdefaulttimeout/__module__.__eq__('_socket'). socket_extra38 covers getfqdn/__name__.__eq__ and getfqdn/__module__.__eq__('socket'). But NO prior spec checks socket.gethostname/__name__.__eq__('gethostname') or gethostname/__module__.__eq__('_socket'). socket_extra7 only covers setdefaulttimeout and getdefaulttimeout by name. gethostname is a distinct module-level C function. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostname.__name__ == 'gethostname'. C builtin function in _socket. No prior socket spec checks gethostname.__name__.__eq__ as a string value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == '_socket'. gethostname is implemented in the _socket C extension. No prior socket spec checks gethostname.__module__.__eq__('_socket'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Note: socket.socket.share does not exist on macOS/Linux; it is Windows-only. This spec skips share.__name__ as it is not universally available."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __name__ string eq values:
# setblocking, getpeername, getsockname, makefile, detach, dup
#
# socket_extra39 covers connect/bind/accept/listen/send/recv __name__.__eq__.
# socket_extra40 covers fileno/close/setsockopt/getsockopt __name__.__eq__.
# Prior specs (extra34, extra29, extra37) cover __name__.__len__() for these
# methods but NOT __name__.__eq__ as string values.
# ---------------------------------------------------------------------------

table socket_extra41.socket_method_name_eqs:
  description: "socket.socket setblocking/getpeername/getsockname/makefile/detach/dup __name__.__eq__ string values — novel: extra34 covers setblocking/getsockname/detach __name__.__len__(); extra29 covers getpeername __name__.__len__(); extra37 covers makefile/dup __name__.__len__(); no prior spec checks __name__.__eq__ for any of these methods"
  kind: python_call_eq
  category: function_names
  id_prefix: ssmne41

  columns: [id, function, args, expected]
  rows:
    - [setblocking_name_eq, "socket.setblocking.__name__.__eq__", ["setblocking"], true]
    - [getpeername_name_eq, "socket.getpeername.__name__.__eq__", ["getpeername"], true]
    - [getsockname_name_eq, "socket.getsockname.__name__.__eq__", ["getsockname"], true]
    - [makefile_name_eq,    "socket.makefile.__name__.__eq__",    ["makefile"],    true]
    - [detach_name_eq,      "socket.detach.__name__.__eq__",      ["detach"],      true]
    - [dup_name_eq,         "socket.dup.__name__.__eq__",         ["dup"],         true]

# ---------------------------------------------------------------------------
# socket.gethostname __name__ and __module__ string eq checks
#
# socket_extra7 covers setdefaulttimeout/__name__.__eq__ and getdefaulttimeout/__name__.__eq__.
# socket_extra38 covers getfqdn/__name__.__eq__ and getfqdn/__module__.__eq__.
# socket_extra11 covers setdefaulttimeout/__module__.__eq__('_socket') and
#   getdefaulttimeout/__module__.__eq__('_socket').
# No prior spec checks gethostname/__name__.__eq__('gethostname') or
# gethostname/__module__.__eq__('_socket').
# ---------------------------------------------------------------------------

table socket_extra41.gethostname_name_module_eq:
  description: "socket.gethostname.__name__.__eq__('gethostname') and __module__.__eq__('_socket') — novel: extra7 covers setdefaulttimeout/getdefaulttimeout __name__.__eq__; extra38 covers getfqdn __name__/__module__.__eq__; no prior spec checks gethostname __name__ or __module__ as string eq values"
  kind: python_call_eq
  category: function_names
  id_prefix: sghne41

  columns: [id, function, args, expected]
  rows:
    - [gethostname_name_eq,   gethostname.__name__.__eq__,   ["gethostname"], true]
    - [gethostname_module_eq, gethostname.__module__.__eq__,  ["_socket"],     true]
