spec: croniter_rust
version: ">=3.9"
backend: rust_module(croniter_rust)

docs: https://github.com/kiorky/croniter

provenance:
  derived_from:
    - "https://github.com/kiorky/croniter — croniter documentation"
  not_derived_from:
    - "croniter source: croniter/croniter.py"
  notes:
    - "croniter provides cron expression iteration for Python."
    - "croniter.croniter.is_valid('* * * * *') == True."
    - "croniter.croniter.is_valid('0 0 * * *') == True."
    - "croniter.croniter.is_valid('invalid') == False."
    - "croniter.croniter.is_valid('60 * * * *') == False."
    - "Expose croniter_is_valid(expr) -> bool: croniter.croniter.is_valid(expr)."
    - "All test vectors verified against croniter 5.0.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# croniter_is_valid — cron expression validation
table croniter_rust.validate.is_valid:
  kind: python_call_eq
  category: is_valid
  id_prefix: cron_v
  function: croniter_is_valid

  columns: [id, args, expected]
  rows:
    - [all_stars,   ["* * * * *"],    true]
    - [midnight,    ["0 0 * * *"],    true]
    - [hourly,      ["0 * * * *"],    true]
    - [invalid,     ["invalid"],      false]
    - [bad_minute,  ["60 * * * *"],   false]

