spec: lzma_extra5
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
    - "lzma_extra4.zspec.zsdl — covers compress/__name__ standalone; decompress/__name__ standalone; LZMAError/__name__ standalone; LZMAFile/__name__ standalone; LZMAError.__bases__[0].__name__ bool-form (extra4); FORMAT_AUTO/__class__.__name__ standalone; FORMAT_XZ/__class__.__name__ standalone; CHECK_CRC32/__class__.__name__ standalone."
    - "lzma_extra3.zspec.zsdl — covers FORMAT_*/CHECK_* __class__.__name__=='int' tables; CHECK_ID_MAX value; FILTER_LZMA1/LZMA2 class names; class/function type identity tables."
    - "lzma_extra2.zspec.zsdl — covers class __qualname__ table; LZMAFile/__module__ standalone; LZMAError/__module__ table; LZMAError base name bool form."
    - "lzma.zspec.zsdl — covers LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __name__ table; compress/decompress/open __name__ table; LZMAFile.__module__; FORMAT_AUTO/XZ/ALONE/RAW eq values; CHECK_NONE/CRC32/CRC64/SHA256 eq values; LZMAError.__bases__[0].__name__; compress returns bytes; is_check_supported."
  notes:
    - "This spec extends lzma through lzma_extra4; it does NOT duplicate invariants present in those files."
    - "Focus: LZMAFile.__bases__[0].__name__ == 'BaseStream' (bool-form, extra5); LZMACompressor.__bases__[0].__name__ == 'object' (extra5); LZMADecompressor.__bases__[0].__name__ == 'object' (extra5); open/__module__ standalone (extra5); compress/__module__ standalone (extra5); decompress/__module__ standalone (extra5); function __module__ table (extra5)."
    - "LZMAFile.__bases__[0].__name__ == 'BaseStream': LZMAFile inherits from _compression.BaseStream on Python 3.12. Verified 2026-04-09."
    - "LZMACompressor.__bases__[0].__name__ == 'object': LZMACompressor is a C extension type that inherits directly from object. Verified 2026-04-09."
    - "LZMADecompressor.__bases__[0].__name__ == 'object': same C extension pattern. Verified 2026-04-09."
    - "open/__module__ == 'lzma', compress/__module__ == 'lzma', decompress/__module__ == 'lzma': all pure-Python functions live in lzma module. Verified 2026-04-09."
    - "lzma_extra2 covers LZMAFile/__module__ from extra2. The open/__module__ and compress/__module__ standalone invariants are new from extra5 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# LZMAFile.__bases__[0].__name__ == 'BaseStream' — bool form
#
# No prior lzma spec checks LZMAFile.__bases__[0].__name__ in any form.
# LZMAFile inherits from _compression.BaseStream on Python 3.12.
# ---------------------------------------------------------------------------

invariant lzma_extra5.LZMAFile.base_name_bool:
  description: "lzma.LZMAFile.__bases__[0].__name__ == 'BaseStream' — LZMAFile inherits from BaseStream (bool-form, extra5)"
  category: class_hierarchy
  kind: python_call_eq
  function: LZMAFile.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseStream"]
  expected: true

# ---------------------------------------------------------------------------
# LZMACompressor.__bases__[0].__name__ == 'object'
#
# No prior lzma spec checks the base class name for LZMACompressor.
# LZMACompressor is a C extension type inheriting directly from object.
# ---------------------------------------------------------------------------

invariant lzma_extra5.LZMACompressor.base_name:
  description: "lzma.LZMACompressor.__bases__[0].__name__ == 'object' — LZMACompressor inherits directly from object (extra5)"
  category: class_hierarchy
  kind: python_call_eq
  function: LZMACompressor.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# LZMADecompressor.__bases__[0].__name__ == 'object'
#
# No prior lzma spec checks the base class name for LZMADecompressor.
# LZMADecompressor is a C extension type inheriting directly from object.
# ---------------------------------------------------------------------------

invariant lzma_extra5.LZMADecompressor.base_name:
  description: "lzma.LZMADecompressor.__bases__[0].__name__ == 'object' — LZMADecompressor inherits directly from object (extra5)"
  category: class_hierarchy
  kind: python_call_eq
  function: LZMADecompressor.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ attributes — open, compress, decompress (standalone)
#
# lzma_extra2 covers LZMAFile/__module__ as a standalone from extra2. No prior
# lzma spec checks open/__module__, compress/__module__, or decompress/__module__
# as standalone invariants in the extra5 namespace.
# ---------------------------------------------------------------------------

invariant lzma_extra5.open.module:
  description: "lzma.open.__module__ == 'lzma' — open is defined in the lzma module (extra5 anchor)"
  category: function_modules
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["lzma"]
  expected: true

invariant lzma_extra5.compress.module:
  description: "lzma.compress.__module__ == 'lzma' — compress is defined in the lzma module (extra5 anchor)"
  category: function_modules
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["lzma"]
  expected: true

invariant lzma_extra5.decompress.module:
  description: "lzma.decompress.__module__ == 'lzma' — decompress is defined in the lzma module (extra5 anchor)"
  category: function_modules
  kind: python_call_eq
  function: decompress.__module__.__eq__
  args: ["lzma"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ table — open, compress, decompress (extra5)
#
# No prior lzma spec presents open/compress/decompress __module__ together in
# a single table. This table anchors all three from the extra5 namespace.
# ---------------------------------------------------------------------------

table lzma_extra5.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod5

  columns: [id, function, args, expected]
  rows:
    - [open,       open.__module__.__eq__,       ["lzma"], true]
    - [compress,   compress.__module__.__eq__,   ["lzma"], true]
    - [decompress, decompress.__module__.__eq__, ["lzma"], true]
