spec: socket_extra2281
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count, dict size."
    - "Covers socket.socket, socket.error (OSError alias), socket.herror, socket.gaierror,"
    - "socket.timeout, socket.AddressFamily, and socket.SocketKind."
    - "socket.error is an alias for OSError (MRO depth 4: OSError -> Exception -> BaseException -> object)."
    - "socket.herror, socket.gaierror, socket.timeout all have MRO depth 5 (add one level above OSError)."
    - "socket.AddressFamily and socket.SocketKind extend IntEnum (MRO depth 6)."
    - "None of these classes carry __abstractmethods__; accessing it raises AttributeError."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2281.socket_mro:
