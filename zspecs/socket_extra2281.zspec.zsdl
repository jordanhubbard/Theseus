  kind: python_call_eq
  category: mro_depth
  id_prefix: sk2281

  columns: [id, function, args, expected]
  rows:
    - ["sk2281001", "socket.socket.__mro__.__len__", [], 3]
    - ["sk2281002", "socket.socket.__bases__.__len__", [], 1]
    - ["sk2281003", "socket.socket.__dict__.__len__", [], 28]

