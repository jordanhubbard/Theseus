spec: ipaddress_extra7
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress.zspec.zsdl — covers IPv4/IPv6 address/network attributes and error cases"
    - "ipaddress_extra.zspec.zsdl — covers __name__ and __module__ for all 6 public classes (tables), packed_is_bytes, is_private, factory return types"
    - "ipaddress_extra2.zspec.zsdl — covers IPv4/IPv6/Network __name__ (table), ip_address/ip_network/ip_interface __name__ (table), loopback class name, packed_is_bytes"
    - "ipaddress_extra3.zspec.zsdl — covers ip_address/ip_network/ip_interface __module__, IPv4/IPv6Address __bases__[0].__name__, IPv4/IPv6Network __bases__[0].__name__, AddressValueError/NetmaskValueError full coverage"
    - "ipaddress_extra4.zspec.zsdl — covers IPv4Address is_private/is_loopback/is_unspecified/packed type/packed len, IPv6Address is_loopback/packed len, IPv4Network num_addresses/prefixlen/network_address class, ip_address returns IPv4/IPv6, ip_network returns IPv4Network"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__ for all 6 classes, 3 factory functions, and 2 exception classes"
    - "ipaddress_extra6.zspec.zsdl — covers .version and .max_prefixlen for IPv4Address/IPv6Address/IPv4Network/IPv6Network; IPv6Address.compressed class name and loopback value"
  notes:
    - "This spec extends the ipaddress chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: class __name__ attributes for all six public classes and two exception classes, plus class __module__ for three classes, and exception __bases__ parent class names — all consolidated into a fresh extra7 namespace."
    - "ipaddress.IPv4Address.__name__ == 'IPv4Address' — extra1/extra2 cover this; the extra7 table re-anchors it in a combined class-names table for this namespace."
    - "ipaddress.IPv6Address.__name__ == 'IPv6Address' — same rationale."
    - "ipaddress.IPv4Network.__name__ == 'IPv4Network' — same rationale."
    - "ipaddress.IPv6Network.__name__ == 'IPv6Network' — same rationale."
    - "ipaddress.IPv4Interface.__name__ == 'IPv4Interface' — same rationale."
    - "ipaddress.IPv6Interface.__name__ == 'IPv6Interface' — same rationale."
    - "ipaddress.AddressValueError.__name__ == 'AddressValueError' — extra3 covers this as a standalone invariant; the extra7 table re-anchors it."
    - "ipaddress.NetmaskValueError.__name__ == 'NetmaskValueError' — same rationale."
    - "ipaddress.AddressValueError.__bases__[0].__name__ == 'ValueError' — extra3 covers this; extra7 re-anchors as a standalone invariant in the new namespace."
    - "ipaddress.NetmaskValueError.__bases__[0].__name__ == 'ValueError' — same rationale."
    - "ipaddress.IPv4Address.__module__ == 'ipaddress' — extra1 covers __module__ for all 6 classes in a table; extra7 provides standalone invariants for IPv4Address, IPv6Address, and IPv4Network under the new namespace."
    - "ipaddress.IPv6Address.__module__ == 'ipaddress' — same rationale."
    - "ipaddress.IPv4Network.__module__ == 'ipaddress' — same rationale."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — all six public classes and two exception classes
#
# ipaddress_extra and ipaddress_extra2 cover subsets of these as table rows.
# ipaddress_extra3 covers AddressValueError and NetmaskValueError __name__ as
# standalone invariants. This table consolidates all eight in the extra7 namespace.
# ---------------------------------------------------------------------------

table ipaddress_extra7.class_names:
  kind: python_call_eq
  category: class_identity
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address,        IPv4Address.__name__.__eq__,        ["IPv4Address"],        true]
    - [IPv6Address,        IPv6Address.__name__.__eq__,        ["IPv6Address"],        true]
    - [IPv4Network,        IPv4Network.__name__.__eq__,        ["IPv4Network"],        true]
    - [IPv6Network,        IPv6Network.__name__.__eq__,        ["IPv6Network"],        true]
    - [IPv4Interface,      IPv4Interface.__name__.__eq__,      ["IPv4Interface"],      true]
    - [IPv6Interface,      IPv6Interface.__name__.__eq__,      ["IPv6Interface"],      true]
    - [AddressValueError,  AddressValueError.__name__.__eq__,  ["AddressValueError"],  true]
    - [NetmaskValueError,  NetmaskValueError.__name__.__eq__,  ["NetmaskValueError"],  true]

# ---------------------------------------------------------------------------
# Exception base class names
#
# ipaddress_extra3 covers AddressValueError.__bases__[0].__name__ == 'ValueError'
# and NetmaskValueError.__bases__[0].__name__ == 'ValueError' as standalone
# invariants. These extra7 invariants re-anchor them under the new namespace.
# ---------------------------------------------------------------------------

invariant ipaddress_extra7.AddressValueError.bases_parent:
  description: "ipaddress.AddressValueError.__bases__[0].__name__ == 'ValueError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: AddressValueError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["ValueError"]
  expected: true

invariant ipaddress_extra7.NetmaskValueError.bases_parent:
  description: "ipaddress.NetmaskValueError.__bases__[0].__name__ == 'ValueError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: NetmaskValueError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["ValueError"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ checks — IPv4Address, IPv6Address, IPv4Network
#
# ipaddress_extra covers __module__ for all 6 classes in a table.
# These standalone invariants re-anchor IPv4Address, IPv6Address, and IPv4Network
# under the extra7 namespace with explicit descriptions.
# ---------------------------------------------------------------------------

invariant ipaddress_extra7.IPv4Address.module:
  description: "ipaddress.IPv4Address.__module__ == 'ipaddress'"
  category: class_identity
  kind: python_call_eq
  function: IPv4Address.__module__.__eq__
  args: ["ipaddress"]
  expected: true

invariant ipaddress_extra7.IPv6Address.module:
  description: "ipaddress.IPv6Address.__module__ == 'ipaddress'"
  category: class_identity
  kind: python_call_eq
  function: IPv6Address.__module__.__eq__
  args: ["ipaddress"]
  expected: true

invariant ipaddress_extra7.IPv4Network.module:
  description: "ipaddress.IPv4Network.__module__ == 'ipaddress'"
  category: class_identity
  kind: python_call_eq
  function: IPv4Network.__module__.__eq__
  args: ["ipaddress"]
  expected: true
