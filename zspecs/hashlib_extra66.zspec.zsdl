spec: hashlib_extra66
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra65.zspec.zsdl — covers new.__defaults__.__class__.__name__.__eq__('NoneType') / file_digest.__defaults__.__class__.__name__.__eq__('NoneType') / new.__code__.__class__.__name__.__eq__('code') / file_digest.__code__.__class__.__name__.__eq__('code') / blake2b.__doc__.__contains__('hash') (table + invariants)."
    - "hashlib_extra64.zspec.zsdl — covers hashlib.new and file_digest __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / new.__globals__.__class__.__name__.__eq__('dict') / new.__globals__.__contains__('new') / blake2b.__doc__.__contains__('BLAKE2b') (table + invariants)."
    - "hashlib_extra63.zspec.zsdl — covers blake2b/blake2s method descriptor __qualname__.__eq__ string values for update/digest/hexdigest/copy (blake2b) and update/digest/hexdigest (blake2s)."
    - "hashlib_extra62.zspec.zsdl — covers hashlib.__spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __spec__.has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "hashlib_extra61.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "hashlib_extra60.zspec.zsdl — covers hashlib.__all__.__contains__ for sha256/sha1/sha512/sha3_256 (table); blake2b/blake2s/md5/sha1 __doc__.__class__.__qualname__.__eq__('str'); __all__.__contains__('algorithms_guaranteed') (invariant)."
    - "hashlib_extra52.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __doc__.__class__.__name__.__eq__('str'); sha256/new/module __doc__.__class__.__qualname__.__eq__('str')."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra65; it does NOT duplicate invariants present in those files."
    - "Wave 230 theme: __code__ deep chains for Python functions + docstring content for C extension types."
    - "hashlib.new.__code__.co_name == '__hash_new' — hashlib.new is the public name for a pure Python function internally named __hash_new in Lib/hashlib.py. The code object's co_name reflects the internal name, not the attribute name 'new'. No prior hashlib spec checks new.__code__.co_name in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_name == 'file_digest' — the function's code object has co_name matching the function's own __name__ ('file_digest'). No prior hashlib spec checks file_digest.__code__.co_name in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_argcount == 1 — hashlib.new has signature new(name, *args, **kwargs). co_argcount counts only positional-or-keyword parameters (not *args or **kwargs), so co_argcount is 1 (just 'name'). No prior hashlib spec checks new.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_argcount == 2 — hashlib.file_digest has signature file_digest(fileobj, digest, /, *, _bufsize=262144). The two positional-only parameters 'fileobj' and 'digest' are counted by co_argcount; the keyword-only '_bufsize' is not. co_argcount is 2. No prior hashlib spec checks file_digest.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__doc__ == 'Return a new BLAKE2b hash object.' The short C extension type docstring does NOT contain 'size' or 'digest'. Words present: 'Return', 'new', 'BLAKE2b' (covered by hashlib_extra64), 'hash' (covered by hashlib_extra65), 'object'. This spec checks blake2b.__doc__.__contains__('object') and blake2s.__doc__.__contains__('object') — both docstrings end with 'hash object.'. No prior hashlib spec checks __contains__('object') for blake2b or blake2s. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __code__.co_name deep chain
#
# Wave 230 theme: __code__ deep chains for Python functions.
#
# hashlib.new is publicly named 'new' but internally the Python function in
# Lib/hashlib.py is defined as __hash_new (and then assigned to new). The
# code object's co_name captures the internal definition name: '__hash_new'.
# hashlib.file_digest is defined as 'file_digest' so co_name == 'file_digest'.
#
# No prior hashlib spec checks __code__.co_name for any hashlib function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra66.python_func_code_co_name:
  description: "hashlib.new.__code__.co_name.__eq__('__hash_new') and file_digest.__code__.co_name.__eq__('file_digest') — new is internally defined as __hash_new so co_name is '__hash_new' (not 'new'); file_digest co_name matches its definition name; no prior hashlib spec checks __code__.co_name for any hashlib function; first co_name anchor for hashlib"
  kind: python_call_eq
  category: code_objects
  id_prefix: hashlibcode2_66

  columns: [id, function, args, expected]
  rows:
    - [new_code_co_name_eq,         new.__code__.co_name.__eq__,         ["__hash_new"],   true]
    - [file_digest_code_co_name_eq, file_digest.__code__.co_name.__eq__, ["file_digest"],  true]

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __code__.co_argcount deep chain
#
# Wave 230 theme: __code__ deep chains for Python functions.
#
# hashlib.new(name, *args, **kwargs): co_argcount counts only
# positional-or-keyword parameters, which is 1 (just 'name'). *args and
# **kwargs are not counted.
#
# hashlib.file_digest(fileobj, digest, /, *, _bufsize=262144): the two
# positional-only params 'fileobj' and 'digest' ARE counted by co_argcount;
# keyword-only '_bufsize' is not. co_argcount == 2.
#
# No prior hashlib spec checks __code__.co_argcount for any hashlib function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra66.python_func_code_co_argcount:
  description: "hashlib.new.__code__.co_argcount==1 and file_digest.__code__.co_argcount==2 — new(name, *args, **kwargs) has 1 positional-or-keyword param; file_digest(fileobj, digest, /, *) has 2 positional-only params counted by co_argcount; no prior hashlib spec checks __code__.co_argcount for any hashlib function; first co_argcount anchor for hashlib"
  kind: python_call_eq
  category: code_objects
  id_prefix: hashlibcode2_66

  columns: [id, function, args, expected]
  rows:
    - [new_code_co_argcount_eq,         new.__code__.co_argcount.__eq__,         [1], true]
    - [file_digest_code_co_argcount_eq, file_digest.__code__.co_argcount.__eq__, [2], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b and blake2s __doc__ content check — 'object'
#
# Wave 230 theme: docstring content for C extension types.
#
# hashlib.blake2b.__doc__ == 'Return a new BLAKE2b hash object.'
# hashlib.blake2s.__doc__ == 'Return a new BLAKE2s hash object.'
# Both docstrings contain the word 'object' (as part of 'hash object.').
# hashlib_extra64 checks blake2b.__doc__.__contains__('BLAKE2b') (wave 228).
# hashlib_extra65 checks blake2b.__doc__.__contains__('hash') (wave 229).
# This spec checks 'object', a different keyword not yet covered in any prior
# hashlib spec for blake2b or blake2s. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table hashlib_extra66.blake2_doc_contains_object:
  description: "hashlib.blake2b.__doc__.__contains__('object') and blake2s.__doc__.__contains__('object') — C extension type docstrings are 'Return a new BLAKE2b hash object.' and 'Return a new BLAKE2s hash object.' respectively; 'object' appears as part of 'hash object.'; hashlib_extra64 checks __contains__('BLAKE2b'); hashlib_extra65 checks __contains__('hash'); no prior hashlib spec checks __contains__('object') for blake2b or blake2s"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibcode2_66

  columns: [id, function, args, expected]
  rows:
    - [blake2b_doc_contains_object, blake2b.__doc__.__contains__, ["object"], true]
    - [blake2s_doc_contains_object, blake2s.__doc__.__contains__, ["object"], true]

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_name.__eq__('__hash_new') — standalone
#
# hashlib.new is the public entry point for creating hash objects. It is
# implemented in Lib/hashlib.py as a function named __hash_new, then assigned
# to the module attribute 'new'. The code object's co_name captures the
# internal definition name, exposing the alias relationship. No prior hashlib
# spec checks new.__code__.co_name in any form. First co_name anchor for any
# hashlib function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra66.new_code_co_name_hash_new:
  description: "hashlib.new.__code__.co_name.__eq__('__hash_new') == True — hashlib.new is defined internally as __hash_new in Lib/hashlib.py and assigned to the 'new' attribute; co_name reflects the definition name '__hash_new', not the attribute name 'new'; no prior hashlib spec checks new.__code__.co_name; first co_name anchor for any hashlib function"
  category: code_objects
  kind: python_call_eq
  function: new.__code__.co_name.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__doc__.__contains__('object') — standalone
#
# hashlib.blake2b is a C extension type from Modules/_blake2/. Its docstring
# is 'Return a new BLAKE2b hash object.' — a one-sentence description. The
# word 'object' appears as the final noun ('hash object.'). hashlib_extra64
# checks __contains__('BLAKE2b') (wave 228) and hashlib_extra65 checks
# __contains__('hash') (wave 229). This invariant anchors the third distinct
# content keyword in blake2b's docstring that has not been checked before.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra66.blake2b_doc_contains_object:
  description: "hashlib.blake2b.__doc__.__contains__('object') == True — C extension type docstring is 'Return a new BLAKE2b hash object.'; 'object' appears as the final noun in 'hash object.'; hashlib_extra64 checks __contains__('BLAKE2b') (wave 228); hashlib_extra65 checks __contains__('hash') (wave 229); no prior hashlib spec checks blake2b.__doc__.__contains__('object'); third distinct content keyword anchor for blake2b docstring"
  category: docstrings
  kind: python_call_eq
  function: blake2b.__doc__.__contains__
  args: ["object"]
  expected: true
