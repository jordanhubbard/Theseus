spec: contextlib_extra21
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra20.zspec.zsdl."
    - "Prior specs cover: contextmanager/__name__/__qualname__/__module__/__class__.__name__; asynccontextmanager/__name__/__qualname__/__module__/__class__.__name__; suppress/__name__/__qualname__/__module__/__mro__/__bases__; redirect_stdout/__name__/__qualname__/__module__/__mro__/__bases__; redirect_stderr/__name__/__qualname__/__module__/__mro__/__bases__; redirect_stdout/__class__.__name__=='ABCMeta'; redirect_stderr/__class__.__name__=='ABCMeta'; ExitStack/AsyncExitStack/AbstractContextManager/AbstractAsyncContextManager/__class__.__name__=='ABCMeta'; nullcontext/__name__/__qualname__/__module__/__bases__/__mro__; closing/__name__/__qualname__/__module__/__bases__/__mro__/__class__.__name__; aclosing/__name__/__qualname__/__module__/__bases__/__mro__."
    - "This spec covers: suppress.__class__.__name__ == 'ABCMeta' (standalone invariant, not yet recorded); AbstractContextManager.__bases__[0].__name__ == 'ABC'; AbstractAsyncContextManager.__bases__[0].__name__ == 'ABC'; closing.__bases__[0].__name__ == 'AbstractContextManager' (standalone invariant form); aclosing.__bases__[0].__name__ == 'AbstractAsyncContextManager' (standalone invariant form)."
    - "contextlib.suppress.__class__.__name__ == 'ABCMeta' because suppress is registered with the ABC machinery."
    - "contextlib.AbstractContextManager and AbstractAsyncContextManager both inherit from ABC."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# suppress — __class__.__name__
#
# Prior specs record redirect_stdout.__class__.__name__ == 'ABCMeta' and
# redirect_stderr.__class__.__name__ == 'ABCMeta' via a table, but
# suppress.__class__.__name__ has never been recorded as a standalone
# invariant. suppress is an ABCMeta instance like the redirect classes.
# ---------------------------------------------------------------------------

invariant contextlib_extra21.suppress.class_name:
  description: "contextlib.suppress.__class__.__name__ == 'ABCMeta'"
  category: class_identity
  kind: python_call_eq
  function: suppress.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# AbstractContextManager and AbstractAsyncContextManager — base class
#
# Both ABC-based abstract base classes inherit from ABC. No prior contextlib
# spec records __bases__[0].__name__ for either class.
# ---------------------------------------------------------------------------

invariant contextlib_extra21.AbstractContextManager.base0_name:
  description: "contextlib.AbstractContextManager.__bases__[0].__name__ == 'ABC'"
  category: base_classes
  kind: python_call_eq
  function: AbstractContextManager.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["ABC"]
  expected: true

invariant contextlib_extra21.AbstractAsyncContextManager.base0_name:
  description: "contextlib.AbstractAsyncContextManager.__bases__[0].__name__ == 'ABC'"
  category: base_classes
  kind: python_call_eq
  function: AbstractAsyncContextManager.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["ABC"]
  expected: true

# ---------------------------------------------------------------------------
# closing and aclosing — base class (standalone invariant form)
#
# Prior specs record closing.__bases__.__getitem__ and aclosing.__bases__.__getitem__
# only via table rows. These standalone invariants provide the same data in
# a searchable, individually addressable form.
# ---------------------------------------------------------------------------

invariant contextlib_extra21.closing.base0_name:
  description: "contextlib.closing.__bases__[0].__name__ == 'AbstractContextManager'"
  category: base_classes
  kind: python_call_eq
  function: closing.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["AbstractContextManager"]
  expected: true

invariant contextlib_extra21.aclosing.base0_name:
  description: "contextlib.aclosing.__bases__[0].__name__ == 'AbstractAsyncContextManager'"
  category: base_classes
  kind: python_call_eq
  function: aclosing.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["AbstractAsyncContextManager"]
  expected: true
