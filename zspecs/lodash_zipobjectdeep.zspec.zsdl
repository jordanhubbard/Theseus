spec: lodash_zipobjectdeep
version: ">=4.0.0"
backend: node(lodash.zipobjectdeep)

docs: https://lodash.com/docs/#zipObjectDeep

provenance:
  derived_from:
    - "lodash.zipobjectdeep README — https://www.npmjs.com/package/lodash.zipobjectdeep"
    - "Test vectors verified with lodash.zipobjectdeep@4.4.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.zipobjectdeep exports the _.zipObjectDeep function directly as module.exports."
    - "zipObjectDeep(paths, values) creates a deeply nested object from path-value pairs."
    - "Dot and bracket notation in paths create nested structure."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns nested object from path-value pairs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_zipobjectdeep.zipobjectdeep:
  kind: node_module_call_eq
  function: ~
  category: zipobjectdeep
  id_prefix: lzod

  columns: [id, args, expected]
  rows:
    - [nested, [["a.b", "c"], [1, 2]],   {"a": {"b": 1}, "c": 2}]
    - [flat,   [["x", "y"], [10, 20]],   {"x": 10, "y": 20}]
