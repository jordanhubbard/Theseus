spec: hashlib_extra38
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra37.zspec.zsdl — covers blake2b/blake2s instance method __qualname__.__len__() for update/digest/hexdigest/copy."
    - "hashlib_extra36.zspec.zsdl — covers sha3_224/sha3_384 __name__.__len__()==16 and __module__.__len__()==8; shake_128/shake_256 __qualname__.__len__()==17."
    - "hashlib_extra33.zspec.zsdl — covers HASH method __qualname__.__len__(); sha3_512/shake_128/shake_256 __name__.__len__(); algorithms_guaranteed/__class__/__name__.__len__()==3."
    - "hashlib_extra32.zspec.zsdl — covers sha1/sha512/sha224/sha384/blake2b/blake2s/sha3_256 __module__.__len__(); blake2b/blake2s __name__.__len__()==7; sha3_256 __name__.__len__()==16."
    - "hashlib_extra31.zspec.zsdl — covers md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__()."
    - "hashlib_extra25.zspec.zsdl — covers algorithms_guaranteed/__len__()==14."
    - "hashlib_extra24.zspec.zsdl — covers __qualname__.__len__() for md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac."
    - "hashlib_extra19.zspec.zsdl — covers sha256/sha512/md5/sha1 hexdigest lengths (64/128/32/40) via new()."
  notes:
    - "This spec extends hashlib through hashlib_extra37; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__() (extra31); sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 __name__.__len__() (extra32/extra33/extra36); all __qualname__.__len__() for the above plus pbkdf2_hmac (extra24); hexdigest lengths for sha256/sha512/md5/sha1 via new() (extra19)."
    - "This spec covers: pbkdf2_hmac.__name__.__len__() (NOVEL — extra24 covers __qualname__.__len__()==11 for pbkdf2_hmac; extra20 and extra15 cover pbkdf2_hmac.__name__.__eq__ via __eq__; no prior spec checks pbkdf2_hmac.__name__.__len__() as a standalone __len__() call on __name__; the __len__() axis is distinct from both the __eq__ and __qualname__.__len__() axes); sha3_256 hexdigest length (NOVEL — extra19 covers sha256/sha512/md5/sha1 via new() but NOT sha3_256; sha3_256 produces 64 hex chars); sha3_224 hexdigest length (NOVEL — sha3_224 gives 56 hex chars; no prior spec checks any sha3_224 hexdigest length); sha3_384 hexdigest length (NOVEL — sha3_384 gives 96 hex chars; no prior spec checks any sha3_384 hexdigest length); blake2b hexdigest length (NOVEL — default digest_size==64 bytes gives 128 hex chars; no prior spec checks blake2b hexdigest length; extra19 covers only HASH-backed OpenSSL algorithms); blake2s hexdigest length (NOVEL — default digest_size==32 bytes gives 64 hex chars; no prior spec checks blake2s hexdigest length)."
    - "pbkdf2_hmac.__name__ == 'pbkdf2_hmac' (len 11). extra24 checks __qualname__.__len__()==11 for pbkdf2_hmac; extra20 and extra15 check __name__.__eq__('pbkdf2_hmac') via __eq__. No prior spec calls __name__.__len__() directly on pbkdf2_hmac. For C built-in functions __name__ and __qualname__ are the same string. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sha3_256 hexdigest len == 64. SHA3-256 produces a 256-bit (32-byte) digest; hex-encoding gives 64 chars. extra19 covers sha256/sha512/md5/sha1 via new() but not sha3_256. Expressed via sha3_256 constructor + method_chain. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sha3_224 hexdigest len == 56. SHA3-224 produces a 224-bit (28-byte) digest; hex-encoding gives 56 chars. No prior spec checks any sha3_224 hexdigest length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sha3_384 hexdigest len == 96. SHA3-384 produces a 384-bit (48-byte) digest; hex-encoding gives 96 chars. No prior spec checks any sha3_384 hexdigest length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "blake2b default hexdigest len == 128. Default digest_size for blake2b is 64 bytes; hex-encoding gives 128 chars. No prior spec checks blake2b hexdigest length (extra19 covers only OpenSSL-backed HASH algorithms). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "blake2s default hexdigest len == 64. Default digest_size for blake2s is 32 bytes; hex-encoding gives 64 chars. No prior spec checks blake2s hexdigest length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pbkdf2_hmac.__name__.__len__()
#
# extra24 covers pbkdf2_hmac.__qualname__.__len__()==11.
# extra20/extra15 cover pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') via __eq__.
# No prior spec calls __name__.__len__() on pbkdf2_hmac as a standalone __len__() check.
# For C-level built-in functions __name__ and __qualname__ are the same string
# 'pbkdf2_hmac', and __len__() on it returns 11.
# ---------------------------------------------------------------------------

invariant hashlib_extra38.pbkdf2_hmac.name_len:
  description: "hashlib.pbkdf2_hmac.__name__.__len__() == 11 — 'pbkdf2_hmac' has 11 characters; novel __name__.__len__() axis distinct from extra24 __qualname__.__len__ and extra20 __name__.__eq__"
  category: function_names
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# SHA-3 family hexdigest lengths
#
# extra19 covers sha256/sha512/md5/sha1 hexdigest lengths via new() with method_chain.
# No prior spec covers sha3_256, sha3_224, or sha3_384 hexdigest lengths.
# SHA-3 algorithms are FIPS 202; each variant has a fixed output width:
#   sha3_256 -> 256-bit -> 32 bytes -> 64 hex chars
#   sha3_224 -> 224-bit -> 28 bytes -> 56 hex chars
#   sha3_384 -> 384-bit -> 48 bytes -> 96 hex chars
# Expressed using the direct constructors (not new()) so the hash objects are
# created at the function level; hexdigest().__len__() accessed via method_chain.
# ---------------------------------------------------------------------------

invariant hashlib_extra38.sha3_256.hexdigest_len:
  description: "hashlib.sha3_256(b'').hexdigest().__len__() == 64 — SHA3-256 produces 64-char hex; novel: extra19 covers sha256 via new() but not sha3_256"
  category: hexdigest_lengths
  kind: python_call_eq
  function: sha3_256
  args: [!b64 ""]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [64]
  expected: true

invariant hashlib_extra38.sha3_224.hexdigest_len:
  description: "hashlib.sha3_224(b'').hexdigest().__len__() == 56 — SHA3-224 produces 56-char hex; novel: no prior spec checks any sha3_224 hexdigest length"
  category: hexdigest_lengths
  kind: python_call_eq
  function: sha3_224
  args: [!b64 ""]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [56]
  expected: true

invariant hashlib_extra38.sha3_384.hexdigest_len:
  description: "hashlib.sha3_384(b'').hexdigest().__len__() == 96 — SHA3-384 produces 96-char hex; novel: no prior spec checks any sha3_384 hexdigest length"
  category: hexdigest_lengths
  kind: python_call_eq
  function: sha3_384
  args: [!b64 ""]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [96]
  expected: true

# ---------------------------------------------------------------------------
# blake2b and blake2s default hexdigest lengths
#
# extra19 covers sha256/sha512/md5/sha1 hexdigest lengths (OpenSSL-backed HASH type).
# No prior spec checks hexdigest length for blake2b or blake2s (C extension type).
# Default digest_size for blake2b == 64 bytes -> hexdigest len == 128
# Default digest_size for blake2s == 32 bytes -> hexdigest len == 64
# Using method_chain pattern matching extra19 style.
# ---------------------------------------------------------------------------

invariant hashlib_extra38.blake2b.hexdigest_len:
  description: "hashlib.blake2b(b'').hexdigest().__len__() == 128 — default digest_size 64 bytes gives 128 hex chars; novel: no prior spec checks blake2b hexdigest length (extra19 covers HASH-backed only)"
  category: hexdigest_lengths
  kind: python_call_eq
  function: blake2b
  args: [!b64 ""]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [128]
  expected: true

invariant hashlib_extra38.blake2s.hexdigest_len:
  description: "hashlib.blake2s(b'').hexdigest().__len__() == 64 — default digest_size 32 bytes gives 64 hex chars; novel: no prior spec checks blake2s hexdigest length"
  category: hexdigest_lengths
  kind: python_call_eq
  function: blake2s
  args: [!b64 ""]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [64]
  expected: true
