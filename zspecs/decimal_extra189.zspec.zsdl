spec: decimal_extra189
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra188.zspec.zsdl."
    - "This spec covers decimal rounding constants identity: ROUND_UP, ROUND_DOWN, ROUND_HALF_UP, ROUND_HALF_DOWN class names and string lengths, plus ROUND_HALF_EVEN length."
    - "decimal.ROUND_UP.__class__.__name__ == 'str' (len=3); all rounding constants are plain Python strings, not enums; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_DOWN.__class__.__name__ == 'str' — same as ROUND_UP; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_UP.__class__.__name__ == 'str' — same as ROUND_UP; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_DOWN.__class__.__name__ == 'str' — same as ROUND_UP; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_UP.__len__() == 8 — 'ROUND_UP' has 8 characters; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_DOWN.__len__() == 10 — 'ROUND_DOWN' has 10 characters; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_UP.__len__() == 13 — 'ROUND_HALF_UP' has 13 characters; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_EVEN.__len__() == 15 — 'ROUND_HALF_EVEN' has 15 characters; confirmed Python 3.14.3 macOS."
    - "ROUND_HALF_DOWN.__len__() == 15 — same length as ROUND_HALF_EVEN; confirmed Python 3.14.3 macOS."
    - "Length ordering: ROUND_UP(8) < ROUND_DOWN(10) < ROUND_HALF_UP(13) < ROUND_HALF_DOWN(15)==ROUND_HALF_EVEN(15); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal rounding constants class name equality
# all are plain str, not enums
# ---------------------------------------------------------------------------

table decimal_extra189.rounding_class_names:
  description: "decimal rounding constants class names: ROUND_UP, ROUND_DOWN, ROUND_HALF_UP, ROUND_HALF_DOWN — all __class__.__name__ == 'str'"
  kind: python_call_eq
  category: identity
  id_prefix: decimalrounding189

  columns: [id, function, args, expected, description]
  rows:
    - [round_up_class_eq,        decimal.ROUND_UP.__class__.__name__.__eq__,        ["str"], true, "decimal.ROUND_UP.__class__.__name__ == 'str' (len=3); rounding constants are plain strings, not enums; confirmed Python 3.14.3 macOS"]
    - [round_down_class_eq,      decimal.ROUND_DOWN.__class__.__name__.__eq__,      ["str"], true, "decimal.ROUND_DOWN.__class__.__name__ == 'str'; same as ROUND_UP; confirmed Python 3.14.3 macOS"]
    - [round_half_up_class_eq,   decimal.ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true, "decimal.ROUND_HALF_UP.__class__.__name__ == 'str'; same as ROUND_UP; confirmed Python 3.14.3 macOS"]
    - [round_half_down_class_eq, decimal.ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"], true, "decimal.ROUND_HALF_DOWN.__class__.__name__ == 'str'; same as ROUND_UP; confirmed Python 3.14.3 macOS"]
    - [round_up_class_len,       decimal.ROUND_UP.__class__.__name__.__len__,       [], 3,   "decimal.ROUND_UP.__class__.__name__.__len__() == 3 — s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal rounding constants string lengths
# ROUND_UP(8) < ROUND_DOWN(10) < ROUND_HALF_UP(13) < ROUND_HALF_DOWN(15)==ROUND_HALF_EVEN(15)
# ---------------------------------------------------------------------------

table decimal_extra189.rounding_string_lengths:
  description: "decimal rounding constant string lengths: ROUND_UP=8, ROUND_DOWN=10, ROUND_HALF_UP=13, ROUND_HALF_DOWN=15, ROUND_HALF_EVEN=15"
  kind: python_call_eq
  category: identity
  id_prefix: decimalrounding189

  columns: [id, function, args, expected, description]
  rows:
    - [round_up_len,        decimal.ROUND_UP.__len__,        [], 8,  "decimal.ROUND_UP.__len__() == 8 — 'ROUND_UP' has 8 chars; shortest in spec; confirmed Python 3.14.3 macOS"]
    - [round_down_len,      decimal.ROUND_DOWN.__len__,      [], 10, "decimal.ROUND_DOWN.__len__() == 10 — 'ROUND_DOWN' has 10 chars; confirmed Python 3.14.3 macOS"]
    - [round_half_up_len,   decimal.ROUND_HALF_UP.__len__,   [], 13, "decimal.ROUND_HALF_UP.__len__() == 13 — 'ROUND_HALF_UP' has 13 chars; confirmed Python 3.14.3 macOS"]
    - [round_half_down_len, decimal.ROUND_HALF_DOWN.__len__,  [], 15, "decimal.ROUND_HALF_DOWN.__len__() == 15 — 'ROUND_HALF_DOWN' has 15 chars; same as ROUND_HALF_EVEN; confirmed Python 3.14.3 macOS"]
    - [round_half_even_len, decimal.ROUND_HALF_EVEN.__len__,  [], 15, "decimal.ROUND_HALF_EVEN.__len__() == 15 — 'ROUND_HALF_EVEN' has 15 chars; same length as ROUND_HALF_DOWN; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal rounding constants value equality
# verify the string content of each constant
# ---------------------------------------------------------------------------

table decimal_extra189.rounding_values:
  description: "decimal rounding constants value equality: ROUND_UP='ROUND_UP', ROUND_DOWN='ROUND_DOWN', ROUND_HALF_UP='ROUND_HALF_UP', ROUND_HALF_DOWN='ROUND_HALF_DOWN', ROUND_HALF_EVEN='ROUND_HALF_EVEN'"
  kind: python_call_eq
  category: identity
  id_prefix: decimalrounding189

  columns: [id, function, args, expected, description]
  rows:
    - [round_up_val_eq,        decimal.ROUND_UP.__eq__,        ["ROUND_UP"],        true, "decimal.ROUND_UP == 'ROUND_UP'; the constant value matches its name; confirmed Python 3.14.3 macOS"]
    - [round_down_val_eq,      decimal.ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true, "decimal.ROUND_DOWN == 'ROUND_DOWN'; confirmed Python 3.14.3 macOS"]
    - [round_half_up_val_eq,   decimal.ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'; confirmed Python 3.14.3 macOS"]
    - [round_half_down_val_eq, decimal.ROUND_HALF_DOWN.__eq__,  ["ROUND_HALF_DOWN"],  true, "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN'; confirmed Python 3.14.3 macOS"]
    - [round_half_even_val_eq, decimal.ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"],  true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN'; same string length as ROUND_HALF_DOWN (15); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra189.round_up_class_name_eq:
  description: "decimal.ROUND_UP.__class__.__name__ == 'str' — ROUND_UP is a plain Python string constant (len='str'=3); unlike the re.RegexFlag enum, decimal rounding constants are ordinary str objects; ROUND_UP rounds away from zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra189.round_down_class_name_eq:
  description: "decimal.ROUND_DOWN.__class__.__name__ == 'str' — ROUND_DOWN is a plain Python string constant; same class as ROUND_UP; ROUND_DOWN rounds toward zero (truncates); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_DOWN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra189.round_half_up_class_name_eq:
  description: "decimal.ROUND_HALF_UP.__class__.__name__ == 'str' — ROUND_HALF_UP is a plain Python string constant; same class as ROUND_UP; ROUND_HALF_UP rounds to nearest with ties going away from zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_HALF_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra189.round_half_down_class_name_eq:
  description: "decimal.ROUND_HALF_DOWN.__class__.__name__ == 'str' — ROUND_HALF_DOWN is a plain Python string constant; same class as ROUND_UP; ROUND_HALF_DOWN rounds to nearest with ties going toward zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_HALF_DOWN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra189.round_up_len:
  description: "decimal.ROUND_UP.__len__() == 8 — 'ROUND_UP' has 8 characters: R(1)O(2)U(3)N(4)D(5)_(6)U(7)P(8); this is the shortest rounding constant name in the spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_UP.__len__
  args: []
  expected: 8

invariant decimal_extra189.round_down_len:
  description: "decimal.ROUND_DOWN.__len__() == 10 — 'ROUND_DOWN' has 10 characters: R(1)O(2)U(3)N(4)D(5)_(6)D(7)O(8)W(9)N(10); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_DOWN.__len__
  args: []
  expected: 10

invariant decimal_extra189.round_half_up_len:
  description: "decimal.ROUND_HALF_UP.__len__() == 13 — 'ROUND_HALF_UP' has 13 characters: R(1)O(2)U(3)N(4)D(5)_(6)H(7)A(8)L(9)F(10)_(11)U(12)P(13); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_HALF_UP.__len__
  args: []
  expected: 13

invariant decimal_extra189.round_half_even_len:
  description: "decimal.ROUND_HALF_EVEN.__len__() == 15 — 'ROUND_HALF_EVEN' has 15 characters; same length as ROUND_HALF_DOWN (15); ROUND_HALF_EVEN (banker's rounding) rounds to nearest with ties going to the nearest even digit; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_HALF_EVEN.__len__
  args: []
  expected: 15

