spec: itertools_extra1066
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks groupby, zip_longest, takewhile, dropwhile, and starmap __qualname__ and __module__ class attributes; pairwise requires Python 3.10+"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1066.groupby_zip_longest_qualnames:
  description: "itertools.groupby and itertools.zip_longest class __qualname__ and __module__ checks"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: it1066gz
  columns: [id, function, args, expected]
  rows:
    - [it1066gz001, itertools.groupby.__qualname__.__eq__,              ["groupby"],          true]
    - [it1066gz002, itertools.groupby.__module__.__eq__,                ["itertools"],        true]
    - [it1066gz003, itertools.groupby.__class__.__name__.__eq__,        ["type"],             true]
    - [it1066gz004, itertools.groupby.__new__.__qualname__.__eq__,      ["groupby.__new__"],  true]
    - [it1066gz005, itertools.zip_longest.__qualname__.__eq__,          ["zip_longest"],      true]
    - [it1066gz006, itertools.zip_longest.__module__.__eq__,            ["itertools"],        true]
    - [it1066gz007, itertools.zip_longest.__class__.__name__.__eq__,    ["type"],             true]
    - [it1066gz008, itertools.zip_longest.__new__.__qualname__.__eq__,  ["zip_longest.__new__"], true]

