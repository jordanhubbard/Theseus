spec: pathlib_extra2251
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib.zspec.zsdl"
  notes:
    - "Wave 2251, theme: callable protocol and function-attribute dict-presence."
    - "Checks __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ in pathlib class __dict__s."
    - "pathlib.PurePath, PurePosixPath, PureWindowsPath are pure path types with no callable-protocol or function-attribute dunders."
    - "pathlib.Path is the concrete OS path type; also absent of callable-protocol dunders."
    - "Positive anchor rows verify real attribute membership (as_posix, joinpath, parts, exists, stat, etc.)."
  created_at: "2026-04-12"

table pathlib_extra2251.callable_protocol_purepath:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["pl2251001", pathlib.PurePath.__dict__.__contains__,       ["__call__"],       false]
    - ["pl2251002", pathlib.PurePath.__dict__.__contains__,       ["__code__"],       false]
    - ["pl2251003", pathlib.PurePath.__dict__.__contains__,       ["__globals__"],    false]
    - ["pl2251004", pathlib.PurePath.__dict__.__contains__,       ["__defaults__"],   false]
    - ["pl2251005", pathlib.PurePath.__dict__.__contains__,       ["__kwdefaults__"], false]
    - ["pl2251006", pathlib.PurePath.__dict__.__contains__,       ["__annotations__"],false]
    - ["pl2251007", pathlib.PurePath.__dict__.__contains__,       ["__builtins__"],   false]
    - ["pl2251008", pathlib.PurePosixPath.__dict__.__contains__,  ["__call__"],       false]
    - ["pl2251009", pathlib.PurePosixPath.__dict__.__contains__,  ["__code__"],       false]
    - ["pl2251010", pathlib.PurePosixPath.__dict__.__contains__,  ["__globals__"],    false]
    - ["pl2251011", pathlib.PurePosixPath.__dict__.__contains__,  ["__defaults__"],   false]
    - ["pl2251012", pathlib.PurePosixPath.__dict__.__contains__,  ["__kwdefaults__"], false]
    - ["pl2251013", pathlib.PurePosixPath.__dict__.__contains__,  ["__annotations__"],false]
    - ["pl2251014", pathlib.PurePosixPath.__dict__.__contains__,  ["__builtins__"],   false]
    - ["pl2251015", pathlib.PureWindowsPath.__dict__.__contains__,["__call__"],       false]
    - ["pl2251016", pathlib.PureWindowsPath.__dict__.__contains__,["__code__"],       false]
    - ["pl2251017", pathlib.PureWindowsPath.__dict__.__contains__,["__globals__"],    false]
    - ["pl2251018", pathlib.PureWindowsPath.__dict__.__contains__,["__defaults__"],   false]
    - ["pl2251019", pathlib.PureWindowsPath.__dict__.__contains__,["__kwdefaults__"], false]
    - ["pl2251020", pathlib.PureWindowsPath.__dict__.__contains__,["__annotations__"],false]
    - ["pl2251021", pathlib.PureWindowsPath.__dict__.__contains__,["__builtins__"],   false]

table pathlib_extra2251.callable_protocol_path:
