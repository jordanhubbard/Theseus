    - ["pl2251025", pathlib.Path.__dict__.__contains__,           ["__defaults__"],   false]
    - ["pl2251026", pathlib.Path.__dict__.__contains__,           ["__kwdefaults__"], false]
    - ["pl2251027", pathlib.Path.__dict__.__contains__,           ["__annotations__"],false]
    - ["pl2251028", pathlib.Path.__dict__.__contains__,           ["__builtins__"],   false]

