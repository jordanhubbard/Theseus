spec: enum_extra8
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends prior enum specs."
    - "Focus: Enum member attributes — name, value, __class__."
    - "All Enum members have a .name attribute that returns the member name as a string."
    - "All Enum members have a .value attribute that returns the associated value."
    - "The _member_names_ attribute on an Enum class returns a list of member name strings."
    - "The _member_map_ attribute returns a dict mapping names to members."
    - "Enum._generate_next_value_ is a classmethod."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

invariant enum_extra8.Enum._member_names_.class:
  description: "enum.Enum._member_names_.__class__.__name__ == 'list'"
  category: Enum_attributes
  kind: python_call_eq
  function: Enum._member_names_.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant enum_extra8.Enum._member_map_.class:
  description: "enum.Enum._member_map_.__class__.__name__ == 'dict'"
  category: Enum_attributes
  kind: python_call_eq
  function: Enum._member_map_.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant enum_extra8.IntEnum._member_names_.class:
  description: "enum.IntEnum._member_names_.__class__.__name__ == 'list'"
  category: IntEnum_attributes
  kind: python_call_eq
  function: IntEnum._member_names_.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant enum_extra8.Enum.mro_contains_object:
  description: "'object' in [c.__name__ for c in enum.Enum.__mro__]"
  category: hierarchy
  kind: python_call_eq
  function: Enum.__mro__.__len__
  args: []
  method: __ge__
  method_args: [2]
  expected: true

invariant enum_extra8.IntEnum.mro_contains_int:
  description: "enum.IntEnum.__mro__[1].__name__ == 'int'"
  category: hierarchy
  kind: python_call_eq
  function: IntEnum.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "int"

invariant enum_extra8.Flag.mro_length:
  description: "len(enum.Flag.__mro__) >= 3"
  category: hierarchy
  kind: python_call_eq
  function: Flag.__mro__.__len__
  args: []
  method: __ge__
  method_args: [3]
  expected: true

invariant enum_extra8.Enum.metaclass_is_type_subclass:
  description: "type(enum.Enum).__mro__[0].__name__ in ('EnumMeta', 'EnumType')"
  category: metaclass
  kind: python_call_eq
  function: Enum.__class__.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"

invariant enum_extra8.auto.instance_value:
  description: "enum.auto().__class__.__name__ == 'int'"
  category: auto
  kind: python_call_eq
  function: auto
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true

invariant enum_extra8.unique.qualname:
  description: "enum.unique.__qualname__ == 'unique'"
  category: unique
  kind: python_call_eq
  function: unique.__qualname__.__eq__
  args: ["unique"]
  expected: true

invariant enum_extra8.Enum.module:
  description: "enum.Enum.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: Enum.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra8.IntEnum.module:
  description: "enum.IntEnum.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: IntEnum.__module__.__eq__
  args: ["enum"]
  expected: true
