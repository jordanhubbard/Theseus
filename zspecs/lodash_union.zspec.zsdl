spec: lodash_union
version: ">=4.0.0"
backend: node(lodash.union)

docs: https://lodash.com/docs/#union

provenance:
  derived_from:
    - "lodash.union README — https://www.npmjs.com/package/lodash.union"
    - "Test vectors verified with lodash.union@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.union exports the _.union function directly as module.exports."
    - "union(...arrays) creates an array of unique values from all given arrays."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of unique values. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_union.union:
  kind: node_module_call_eq
  function: ~
  category: union
  id_prefix: lunion

  columns: [id, args, expected]
  rows:
    - [overlap,    [[1, 2], [2, 3]],      [1, 2, 3]]
    - [no_overlap, [[1, 2], [3, 4]],      [1, 2, 3, 4]]
    - [identical,  [[1, 2, 3], [1, 2]],   [1, 2, 3]]

