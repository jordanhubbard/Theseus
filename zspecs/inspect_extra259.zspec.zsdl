spec: inspect_extra259
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getsource, inspect.getsourcelines, inspect.getfile, inspect.getmodule, inspect.signature function identity — name, qualname, module, class."
    - "inspect.getsource.__name__ == 'getsource' — Python function name. Verified with Python 3.14.3."
    - "inspect.getsource.__qualname__ == 'getsource' — top-level function; qualname equals name. Verified with Python 3.14.3."
    - "inspect.getsource.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getsource.__class__.__name__ == 'function' — plain Python function. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__name__ == 'getsourcelines' — Python function name. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__qualname__ == 'getsourcelines' — top-level function; qualname equals name. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__class__.__name__ == 'function' — plain Python function. Verified with Python 3.14.3."
    - "inspect.getfile.__name__ == 'getfile' — Python function name. Verified with Python 3.14.3."
    - "inspect.getfile.__qualname__ == 'getfile' — top-level function; qualname equals name. Verified with Python 3.14.3."
    - "inspect.getfile.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getfile.__class__.__name__ == 'function' — plain Python function. Verified with Python 3.14.3."
    - "inspect.getmodule.__name__ == 'getmodule' — Python function name. Verified with Python 3.14.3."
    - "inspect.getmodule.__qualname__ == 'getmodule' — top-level function; qualname equals name. Verified with Python 3.14.3."
    - "inspect.getmodule.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getmodule.__class__.__name__ == 'function' — plain Python function. Verified with Python 3.14.3."
    - "inspect.signature.__name__ == 'signature' — Python function name. Verified with Python 3.14.3."
    - "inspect.signature.__qualname__ == 'signature' — top-level function; qualname equals name. Verified with Python 3.14.3."
    - "inspect.signature.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.signature.__class__.__name__ == 'function' — plain Python function. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getsource and inspect.getsourcelines function identity
#
# inspect.getsource.__name__              == 'getsource'
# inspect.getsource.__qualname__          == 'getsource'
# inspect.getsource.__module__            == 'inspect'
# inspect.getsource.__class__.__name__    == 'function'
# inspect.getsourcelines.__name__         == 'getsourcelines'
# inspect.getsourcelines.__qualname__     == 'getsourcelines'
#
# Both are plain Python functions in Lib/inspect.py. New to extra259.
# ---------------------------------------------------------------------------

table inspect_extra259.getsource_identity:
  description: "inspect.getsource and getsourcelines name, qualname, module, class contracts; plain Python functions; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: inpgs259

  columns: [id, function, args, expected, description]
  rows:
    - [getsource_name_eq,
       getsource.__name__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__name__.__eq__('getsource') == True — Python function name; new to extra259"]
    - [getsource_qualname_eq,
       getsource.__qualname__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__qualname__.__eq__('getsource') == True — top-level function; qualname equals name; new to extra259"]
    - [getsource_module_eq,
       getsource.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — defined in Lib/inspect.py; new to extra259"]
    - [getsource_class_name_eq,
       getsource.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getsource.__class__.__name__.__eq__('function') == True — plain Python function; new to extra259"]
    - [getsourcelines_name_eq,
       getsourcelines.__name__.__eq__,
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__name__.__eq__('getsourcelines') == True — Python function name; new to extra259"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getsourcelines qualname through inspect.getmodule identity
#
# inspect.getsourcelines.__qualname__  == 'getsourcelines'
# inspect.getfile.__name__             == 'getfile'
# inspect.getfile.__qualname__         == 'getfile'
# inspect.getmodule.__name__           == 'getmodule'
# inspect.getmodule.__qualname__       == 'getmodule'
#
# All are top-level functions in Lib/inspect.py. New to extra259.
# ---------------------------------------------------------------------------

table inspect_extra259.getfile_getmodule_identity:
  description: "inspect.getsourcelines qualname, getfile name/qualname, getmodule name/qualname contracts; plain Python functions; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: inpgfgm259

  columns: [id, function, args, expected, description]
  rows:
    - [getsourcelines_qualname_eq,
       getsourcelines.__qualname__.__eq__,
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__qualname__.__eq__('getsourcelines') == True — top-level function; qualname equals name; new to extra259"]
    - [getfile_name_eq,
       getfile.__name__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__name__.__eq__('getfile') == True — Python function name; new to extra259"]
    - [getfile_qualname_eq,
       getfile.__qualname__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__qualname__.__eq__('getfile') == True — top-level function; qualname equals name; new to extra259"]
    - [getmodule_name_eq,
       getmodule.__name__.__eq__,
       ["getmodule"],
       true,
       "inspect.getmodule.__name__.__eq__('getmodule') == True — Python function name; new to extra259"]
    - [getmodule_qualname_eq,
       getmodule.__qualname__.__eq__,
       ["getmodule"],
       true,
       "inspect.getmodule.__qualname__.__eq__('getmodule') == True — top-level function; qualname equals name; new to extra259"]

# ---------------------------------------------------------------------------
# Table 3: inspect.signature function identity contracts
#
# inspect.signature.__name__              == 'signature'
# inspect.signature.__qualname__          == 'signature'
# inspect.signature.__module__            == 'inspect'
# inspect.signature.__class__.__name__    == 'function'
# inspect.signature.__name__.__class__.__name__ == 'str'
#
# signature is a plain Python function in Lib/inspect.py. New to extra259.
# ---------------------------------------------------------------------------

table inspect_extra259.signature_identity:
  description: "inspect.signature name, qualname, module, class contracts; plain Python function; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: inpsig259

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq,
       signature.__name__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__name__.__eq__('signature') == True — Python function name; new to extra259"]
    - [signature_qualname_eq,
       signature.__qualname__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__qualname__.__eq__('signature') == True — top-level function; qualname equals name; new to extra259"]
    - [signature_module_eq,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — defined in Lib/inspect.py; new to extra259"]
    - [signature_class_name_eq,
       signature.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.signature.__class__.__name__.__eq__('function') == True — plain Python function; new to extra259"]
    - [signature_name_class_eq,
       signature.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.signature.__name__.__class__.__name__.__eq__('str') == True — __name__ is a str; new to extra259"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra259
# ---------------------------------------------------------------------------

invariant inspect_extra259.getsource.name_eq:
  description: "inspect.getsource.__name__ == 'getsource' — Python function name; new to extra259"
  category: identity
  kind: python_call_eq
  function: getsource.__name__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra259.getsource.qualname_eq:
  description: "inspect.getsource.__qualname__ == 'getsource' — top-level function; qualname equals name; new to extra259"
  category: identity
  kind: python_call_eq
  function: getsource.__qualname__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra259.getsource.module_eq:
  description: "inspect.getsource.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra259"
  category: identity
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra259.getsource.class_is_function:
  description: "inspect.getsource.__class__.__name__ == 'function' — plain Python function; new to extra259"
  category: identity
  kind: python_call_eq
  function: getsource.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra259.getsourcelines.name_eq:
  description: "inspect.getsourcelines.__name__ == 'getsourcelines' — Python function name; new to extra259"
  category: identity
  kind: python_call_eq
  function: getsourcelines.__name__.__eq__
  args: ["getsourcelines"]
  expected: true

invariant inspect_extra259.getsourcelines.qualname_eq:
  description: "inspect.getsourcelines.__qualname__ == 'getsourcelines' — top-level function; qualname equals name; new to extra259"
  category: identity
  kind: python_call_eq
  function: getsourcelines.__qualname__.__eq__
  args: ["getsourcelines"]
  expected: true

invariant inspect_extra259.getfile.name_eq:
  description: "inspect.getfile.__name__ == 'getfile' — Python function name; new to extra259"
  category: identity
  kind: python_call_eq
  function: getfile.__name__.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra259.getfile.qualname_eq:
  description: "inspect.getfile.__qualname__ == 'getfile' — top-level function; qualname equals name; new to extra259"
  category: identity
  kind: python_call_eq
  function: getfile.__qualname__.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra259.getmodule.name_eq:
  description: "inspect.getmodule.__name__ == 'getmodule' — Python function name; new to extra259"
  category: identity
  kind: python_call_eq
  function: getmodule.__name__.__eq__
  args: ["getmodule"]
  expected: true

invariant inspect_extra259.getmodule.qualname_eq:
  description: "inspect.getmodule.__qualname__ == 'getmodule' — top-level function; qualname equals name; new to extra259"
  category: identity
  kind: python_call_eq
  function: getmodule.__qualname__.__eq__
  args: ["getmodule"]
  expected: true

invariant inspect_extra259.signature.name_eq:
  description: "inspect.signature.__name__ == 'signature' — Python function name; new to extra259"
  category: identity
  kind: python_call_eq
  function: signature.__name__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra259.signature.module_eq:
  description: "inspect.signature.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra259"
  category: identity
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra259.signature.class_is_function:
  description: "inspect.signature.__class__.__name__ == 'function' — plain Python function; new to extra259"
  category: identity
  kind: python_call_eq
  function: signature.__class__.__name__.__eq__
  args: ["function"]
  expected: true
