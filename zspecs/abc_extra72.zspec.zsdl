spec: abc_extra72
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra71.zspec.zsdl."
    - "This spec covers: wave 243 theme — abc ABCMeta method code objects continued + abstractmethod/__update_abstractmethods code attributes. NEW in extra72: ABCMeta.register.__code__.co_varnames.__len__()==2; ABCMeta.__instancecheck__.__code__.co_name=='__instancecheck__'; ABCMeta.__subclasscheck__.__code__.co_name=='__subclasscheck__'; ABCMeta.__new__.__code__.co_name=='__new__'; abstractmethod.__code__.co_varnames.__len__()==1; abstractmethod.__code__.co_flags.__class__.__name__=='int'; update_abstractmethods.__code__.co_flags.__class__.__name__=='int'; ABCMeta.register.__code__.co_flags.__class__.__name__=='int'; abstractmethod.__code__.co_filename.__class__.__name__=='str'."
    - "abc.ABCMeta.register.__code__.co_varnames.__len__() == 2. register has two parameters: cls and subclass (co_argcount==2 from wave 237; co_varnames contains exactly those 2 entries). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__'. ABCMeta.__instancecheck__ is a Python method (not a C wrapper) in abc.py; co_name is '__instancecheck__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_name == '__subclasscheck__'. ABCMeta.__subclasscheck__ is a Python method in abc.py; co_name is '__subclasscheck__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__code__.co_name == '__new__'. ABCMeta.__new__ is a Python method in abc.py; co_name is '__new__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_varnames.__len__() == 1. abstractmethod has one parameter: funcobj; co_varnames contains exactly 1 entry. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_flags.__class__.__name__ == 'int'. co_flags is always an int in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_flags.__class__.__name__ == 'int'. co_flags is always an int in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_flags.__class__.__name__ == 'int'. co_flags is always an int in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_filename.__class__.__name__ == 'str'. co_filename is always a str in CPython (path to the source file). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

