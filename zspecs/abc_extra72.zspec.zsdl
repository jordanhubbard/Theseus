invariant abc_extra72.ABCMeta_register_varnames_len:
  description: "abc.ABCMeta.register.__code__.co_varnames.__len__() == 2 — register has two parameters (cls and subclass); co_varnames length is 2; NEW in extra72: first standalone co_varnames.__len__ invariant for ABCMeta.register in abcmore72 namespace; wave 243; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.register.__code__.co_varnames.__len__
  args: []
  expected: 2

invariant abc_extra72.ABCMeta_instancecheck_co_name:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_name.__eq__('__instancecheck__') returns True — ABCMeta.__instancecheck__ is a Python method in abc.py; co_name is '__instancecheck__'; NEW in extra72: first standalone co_name invariant for ABCMeta.__instancecheck__ in abcmore72 namespace; wave 243; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__code__.co_name.__eq__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra72.abstractmethod_varnames_len:
  description: "abc.abstractmethod.__code__.co_varnames.__len__() == 1 — abstractmethod has one parameter (funcobj); co_varnames length is 1; NEW in extra72: first standalone co_varnames.__len__ invariant for abstractmethod in abcmore72 namespace; wave 243; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_varnames.__len__
