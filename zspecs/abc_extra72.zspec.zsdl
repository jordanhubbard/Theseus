# ---------------------------------------------------------------------------

table abc_extra72.ABCMeta_register_varnames_and_instance_check:
  description: "abc ABCMeta.register co_varnames length and __instancecheck__/__subclasscheck__ co_name checks in abcmore72 namespace — wave 243 theme: ABCMeta method code objects; ABCMeta.register.__code__.co_varnames.__len__()==2 (register has two parameters: cls and subclass); ABCMeta.__instancecheck__.__code__.co_name=='__instancecheck__' (Python method in abc.py); ABCMeta.__subclasscheck__.__code__.co_name=='__subclasscheck__' (Python method in abc.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abcmore72

  columns: [id, function, args, expected, description]
  rows:
    - [register_varnames_len,       ABCMeta.register.__code__.co_varnames.__len__,              [], 2,    "ABCMeta.register.__code__.co_varnames.__len__() == 2 — register has two parameters: cls and subclass; co_varnames length is 2; verified with Python 3.14.3"]
    - [instancecheck_co_name,       ABCMeta.__instancecheck__.__code__.co_name.__eq__,          ["__instancecheck__"],  true, "ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__' — Python method in abc.py; co_name stores the function name; verified with Python 3.14.3"]
    - [subclasscheck_co_name,       ABCMeta.__subclasscheck__.__code__.co_name.__eq__,          ["__subclasscheck__"],  true, "ABCMeta.__subclasscheck__.__code__.co_name == '__subclasscheck__' — Python method in abc.py; co_name stores the function name; verified with Python 3.14.3"]

