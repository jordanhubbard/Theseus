spec: pickle_extra6
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl and prior extras."
    - "pickle_extra: Pickler.__name__, Unpickler.__name__, PickleError.__name__, PicklingError.__name__, UnpicklingError.__name__, PickleError.__bases__[0].__name__=='Exception'."
    - "pickle_extra2: Pickler.__module__=='pickle', Unpickler.__module__=='pickle', PickleError/__module__, PicklingError/__module__, UnpicklingError/__module__."
    - "pickle_extra4: Pickler.__qualname__, Unpickler.__qualname__, PickleError/__qualname__, PicklingError/__qualname__, UnpicklingError/__qualname__."
    - "pickle_extra5: class_qualnames table (Pickler/Unpickler/PickleError/PicklingError/UnpicklingError), function_qualnames table."
    - "Focus here: PickleBuffer.__name__ (cross-verify vs extra2), PickleBuffer.__qualname__ (extra4 has it — here we add PickleBuffer.__module__=='pickle' via __eq__), PicklingError.__bases__[0].__name__=='PickleError' (extra2 has it — new axis: PicklingError.__bases__[0].__module__=='builtins' or 'pickle'), dumps/loads round-trip for string (new vector), Pickler/__class__.__name__=='type' cross-check (extra2/3 have it)."
    - "New invariants: PickleBuffer.__qualname__ (extra4 has it as pickle_extra4.PickleBuffer.qualname; this spec adds it as a new id under pickle_extra6 — SKIP to avoid duplication)."
    - "Genuinely new axes: PickleError.__class__.__name__ (extra3 has it), so we focus on: dumps round-trip for float (new vector), dumps round-trip for empty dict, PickleBuffer.__bases__[0].__module__ (new), HIGHEST_PROTOCOL.__class__.__qualname__ == 'int', DEFAULT_PROTOCOL.__class__.__qualname__ == 'int'."
    - "pickle.HIGHEST_PROTOCOL.__class__.__qualname__ == 'int' — int is a top-level builtin, qualname equals name."
    - "pickle.DEFAULT_PROTOCOL.__class__.__qualname__ == 'int' — same reasoning."
    - "pickle.PickleBuffer.__bases__[0].__module__ == 'builtins' — object is defined in the builtins module."
    - "pickle.dumps(3.14).__class__.__name__ == 'bytes' — float round-trip type check."
    - "pickle.dumps({}).__class__.__name__ == 'bytes' — empty dict dumps to bytes."
    - "pickle.loads(pickle.dumps(3.14)) == 3.14 — float round-trip value check."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Protocol constant __class__.__qualname__ checks
# prior specs check __class__.__name__; __qualname__ is a distinct attribute.
# For built-in int, __qualname__ == __name__ == 'int'.
# ---------------------------------------------------------------------------

invariant pickle_extra6.HIGHEST_PROTOCOL.class_qualname:
  description: "pickle.HIGHEST_PROTOCOL.__class__.__qualname__ == 'int'"
  category: constants
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true

invariant pickle_extra6.DEFAULT_PROTOCOL.class_qualname:
  description: "pickle.DEFAULT_PROTOCOL.__class__.__qualname__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# PickleBuffer base module
# pickle_extra2 checks PickleBuffer.__bases__[0].__name__ == 'object'.
# This spec adds the __module__ check: object lives in 'builtins'.
# ---------------------------------------------------------------------------

invariant pickle_extra6.PickleBuffer.base_module:
  description: "pickle.PickleBuffer.__bases__[0].__module__ == 'builtins' — object is in builtins"
  category: class_hierarchy
  kind: python_call_eq
  function: PickleBuffer.__bases__.__getitem__
  args: [0]
  method: __module__
  expected: "builtins"

# ---------------------------------------------------------------------------
# dumps returns bytes for new value types not covered in prior specs
# pickle_extra3 covers int, list, None, False; this adds float and empty dict.
# ---------------------------------------------------------------------------

invariant pickle_extra6.dumps_float.returns_bytes:
  description: "pickle.dumps(3.14).__class__.__name__ == 'bytes' — float serializes to bytes"
  category: dumps_type
  kind: python_call_eq
  function: dumps
  args: [3.14]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant pickle_extra6.dumps_empty_dict.returns_bytes:
  description: "pickle.dumps({}).__class__.__name__ == 'bytes' — empty dict serializes to bytes"
  category: dumps_type
  kind: python_call_eq
  function: dumps
  args: [{}]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# loads(dumps(x)) round-trip for float
# Prior round-trip specs cover int, None, True, 'hello'; this adds float.
# ---------------------------------------------------------------------------

invariant pickle_extra6.roundtrip.float:
  description: "pickle.loads(pickle.dumps(3.14)) == 3.14 — float survives a pickle round-trip"
  category: roundtrip
  kind: python_call_eq
  function: dumps
  args: [3.14]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# PickleError.__qualname__ == 'PickleError' — confirm via __class__.__qualname__
# pickle_extra4 and extra5 check PickleError.__qualname__ directly as a string;
# this adds PickleError.__class__.__qualname__ == 'type' (distinct axis).
# ---------------------------------------------------------------------------

invariant pickle_extra6.PickleError.class_qualname:
  description: "pickle.PickleError.__class__.__qualname__ == 'type' — PickleError is a type"
  category: class_metadata
  kind: python_call_eq
  function: PickleError.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant pickle_extra6.Pickler.class_qualname:
  description: "pickle.Pickler.__class__.__qualname__ == 'type' — Pickler is a type"
  category: class_metadata
  kind: python_call_eq
  function: Pickler.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true
