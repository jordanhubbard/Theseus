    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers loop-management functions and task inspection helpers via __name__/__module__ attribute checks"
    - "All functions are top-level exports of the asyncio package"
  created_at: "2026-04-12T00:00:00Z"

invariant asyncio_extra554.get_event_loop_name:
