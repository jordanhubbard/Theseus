spec: sys_extra18
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra16.zspec.zsdl — covers byteorder=='little'; maxsize.__gt__(2147483648); platform.startswith('darwin')"
    - "sys_extra10.zspec.zsdl — covers maxunicode==1114111; maxsize>0; prefix/exec_prefix/executable __class__.__name__=='str'"
    - "sys_extra15.zspec.zsdl — covers version_info.major/minor/micro __class__.__name__=='int'; stdin/stdout/stderr __class__.__name__; api_version type"
    - "sys_extra9.zspec.zsdl — covers version_info.releaselevel.__class__.__name__=='str'; implementation.cache_tag class name"
  notes:
    - "This spec extends sys.zspec.zsdl and prior extras through sys_extra17.zspec.zsdl."
    - "sys.version is documented as always being a str; prior specs check version_info fields but no prior spec checks version.__class__.__name__=='str' directly as a standalone invariant in this namespace."
    - "sys.version_info.__class__.__name__ is 'version_info' — a named tuple subclass; no prior spec checks this name directly as a standalone invariant in this namespace."
    - "sys.version_info.__getitem__(0) returns the major version which is always an int — encoded here via __getitem__ (dotted chain) rather than subscript syntax."
    - "sys.platform.__class__.__name__=='str' — consistent with sys_extra10 but covered here as an independent invariant."
    - "sys.byteorder.__class__.__name__=='str' — byteorder is either 'little' or 'big'; type is always str."
    - "sys.maxsize.__class__.__name__=='int' — maxsize is a platform-dependent integer."
    - "sys.maxunicode.__class__.__name__=='int' — maxunicode is 1114111 on all modern Python builds."
    - "getrecursionlimit/setrecursionlimit/getrefcount/getsizeof/intern __name__ — function name attributes match the function's own name string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys.version — class name
#
# sys_extra9 and sys_extra16 cover various string properties of sys.version.
# This invariant checks version.__class__.__name__ == 'str' as a standalone
# type-identity assertion in the sys_extra18 namespace.
# ---------------------------------------------------------------------------

invariant sys_extra18.version.class_name:
  description: "sys.version.__class__.__name__ == 'str' — version is always a string"
  category: version
  kind: python_call_eq
  function: version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.version_info — class name
#
# sys_extra15 covers version_info field types. No prior spec checks
# version_info.__class__.__name__ == 'version_info' as a standalone invariant
# in this namespace.
# ---------------------------------------------------------------------------

invariant sys_extra18.version_info.class_name:
  description: "sys.version_info.__class__.__name__ == 'version_info' — named tuple type"
  category: version_info
  kind: python_call_eq
  function: version_info.__class__.__name__.__eq__
  args: ["version_info"]
  expected: true

# ---------------------------------------------------------------------------
# sys.version_info — major version is int (via __getitem__)
#
# sys_extra15 covers version_info.major.__class__.__name__ == 'int'.
# This invariant reaches the same element via __getitem__(0), exercising a
# different access path (dotted chain, no subscript syntax).
# ---------------------------------------------------------------------------

invariant sys_extra18.version_info.getitem0_class_name:
  description: "sys.version_info.__getitem__(0).__class__.__name__ == 'int' — major version is int"
  category: version_info
  kind: python_call_eq
  function: version_info.__getitem__
  args: [0]
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# sys.platform — class name
#
# sys_extra10 covers platform.__class__.__name__ == 'str' via a table row.
# This encodes the same fact as a standalone invariant in the sys_extra18 namespace.
# ---------------------------------------------------------------------------

invariant sys_extra18.platform.class_name:
  description: "sys.platform.__class__.__name__ == 'str' — platform is always a string"
  category: platform
  kind: python_call_eq
  function: platform.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.byteorder — class name
#
# sys_extra16 covers byteorder == 'little'. No prior spec checks
# byteorder.__class__.__name__ == 'str' as a standalone invariant.
# ---------------------------------------------------------------------------

invariant sys_extra18.byteorder.class_name:
  description: "sys.byteorder.__class__.__name__ == 'str' — byteorder is always a string"
  category: byteorder
  kind: python_call_eq
  function: byteorder.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.maxsize — class name
#
# sys_extra16 covers maxsize.__gt__(2147483648); sys_extra10 covers maxsize > 0.
# No prior spec checks maxsize.__class__.__name__ == 'int' directly.
# ---------------------------------------------------------------------------

invariant sys_extra18.maxsize.class_name:
  description: "sys.maxsize.__class__.__name__ == 'int' — maxsize is always an integer"
  category: maxsize
  kind: python_call_eq
  function: maxsize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# sys.maxunicode — class name
#
# sys_extra10 covers maxunicode == 1114111. No prior spec checks
# maxunicode.__class__.__name__ == 'int' as a standalone invariant.
# ---------------------------------------------------------------------------

invariant sys_extra18.maxunicode.class_name:
  description: "sys.maxunicode.__class__.__name__ == 'int' — maxunicode is always an integer"
  category: maxunicode
  kind: python_call_eq
  function: maxunicode.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# sys function __name__ attributes
#
# No prior spec covers the __name__ attributes of getrecursionlimit,
# setrecursionlimit, getrefcount, getsizeof, or intern as a table.
# Each function's __name__ attribute equals the function's own identifier.
# ---------------------------------------------------------------------------

table sys_extra18.function_names:
  description: "sys function __name__ attributes match their identifier names"
  kind: python_call_eq
  category: function_names

  columns: [id, function, args, expected]
  rows:
    - [getrecursionlimit, getrecursionlimit.__name__.__eq__, ["getrecursionlimit"], true]
    - [setrecursionlimit, setrecursionlimit.__name__.__eq__, ["setrecursionlimit"], true]
    - [getrefcount,       getrefcount.__name__.__eq__,       ["getrefcount"],       true]
    - [getsizeof,         getsizeof.__name__.__eq__,         ["getsizeof"],         true]
    - [intern,            intern.__name__.__eq__,            ["intern"],            true]
