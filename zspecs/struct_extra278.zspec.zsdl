spec: struct_extra278
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl through struct_extra277.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "struct_extra277.zspec.zsdl covers: signed vs unsigned overflow errors (pack('b', 128)/pack('B', 256) raise struct.error); valid boundary values pack('B', 255)==b'\\xff'/pack('b', -1)==b'\\xff'; unpack('B'/'b', b'\\xff'); Struct('>H') size/format/pack; '4s' format pack/unpack."
    - "This spec focuses on: struct.pack_into and unpack_from with bytearray — pack_into('!H', bytearray(2), 0, 256) mutates buffer to b'\\x01\\x00'; unpack_from('!H', b'\\x01\\x00') == (256,); unpack_from offset parameter; pack_into returns None; iter_unpack."
    - "struct.pack_into('!H', bytearray(2), 0, 256) leaves the buffer as b'\\x01\\x00'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack_from('!H', b'\\x01\\x00') == (256,). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack_from('!H', b'\\xab\\x01\\x00\\xcd', 1) == (256,) — offset=1 skips first byte. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack_into('!H', bytearray(2), 0, 256) returns None — pack_into mutates in place. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.iter_unpack('!H', b'\\x00\\x01\\x00\\x02\\x00\\x03') yields (1,), (2,), (3,). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!H') == 2 — network-order unsigned short is 2 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "struct.pack_into() writes directly into a writable buffer (bytearray) at the given offset and returns None. struct.unpack_from() reads from a buffer at an optional offset without consuming it. struct.error is raised on size mismatches."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; pack_into mutates its buffer argument."
  codes: {}

# ---------------------------------------------------------------------------
# struct.unpack_from — reading a big-endian unsigned short from bytes
# unpack_from('!H', b'\x01\x00') == (256,) — no offset, reads from start.
# unpack_from('!H', b'\xab\x01\x00\xcd', 1) == (256,) — offset=1 skips first byte.
# Both test that the caller controls the read position without slicing.
# ---------------------------------------------------------------------------

table struct_extra278.unpack_from_vectors:
  description: "struct.unpack_from('!H', ...) with and without offset; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: unpack_vector
  function: unpack_from
  id_prefix: ufv278

  columns: [id, args, expected, description]
  rows:
    - [no_offset,   ["!H", !hex 0100],         [256], "unpack_from('!H', b'\\x01\\x00') == (256,) — no offset, reads from byte 0"]
    - [offset_1,    ["!H", !hex ab0100cd, 1],   [256], "unpack_from('!H', b'\\xab\\x01\\x00\\xcd', offset=1) == (256,) — skip first byte"]
    - [offset_0_explicit, ["!H", !hex 0100, 0], [256], "unpack_from('!H', b'\\x01\\x00', offset=0) == (256,) — explicit offset=0"]

# ---------------------------------------------------------------------------
# struct.pack_into — writing a big-endian unsigned short into a bytearray
# pack_into('!H', buf, 0, 256) writes b'\x01\x00' into buf at offset 0.
# pack_into returns None — it mutates the buffer in place.
# The mutation can be verified by inspecting the buffer afterwards.
# ---------------------------------------------------------------------------

invariant struct_extra278.pack_into.returns_none:
  description: "struct.pack_into('!H', bytearray(2), 0, 256) returns None — pack_into mutates in place and has no return value; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: return_type
  kind: python_call_eq
  function: pack_into
  args: ["!H", {type: bytearray, length: 2}, 0, 256]
  expected: null

# ---------------------------------------------------------------------------
# struct.unpack_from — buffer too small raises struct.error
# unpack_from('!H', b'\x01') needs 2 bytes but the buffer is only 1 byte.
# struct.error is raised with a message about buffer size.
# ---------------------------------------------------------------------------

invariant struct_extra278.unpack_from.buffer_too_small_raises:
  description: "struct.unpack_from('!H', b'\\x01') raises struct.error — buffer is 1 byte but '!H' requires 2; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: error
  kind: python_call_raises
  function: unpack_from
  args: ["!H", !hex 01]
  raises: error

# ---------------------------------------------------------------------------
# struct.unpack_from — offset beyond buffer raises struct.error
# Specifying an offset that leaves fewer bytes than the format requires
# raises struct.error.
# ---------------------------------------------------------------------------

invariant struct_extra278.unpack_from.offset_overflow_raises:
  description: "struct.unpack_from('!H', b'\\x01\\x00', 1) raises struct.error — offset=1 leaves only 1 byte but '!H' needs 2; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: error
  kind: python_call_raises
  function: unpack_from
  args: ["!H", !hex 0100, 1]
  raises: error

# ---------------------------------------------------------------------------
# struct.calcsize — '!H' is 2 bytes
# calcsize returns the number of bytes packed/unpacked by a format string.
# For '!H' (network-order unsigned short) that is always 2.
# ---------------------------------------------------------------------------

invariant struct_extra278.calcsize.network_H:
  description: "struct.calcsize('!H') == 2 — network-order unsigned short is 2 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!H"]
  expected: 2

invariant struct_extra278.calcsize.network_I:
  description: "struct.calcsize('!I') == 4 — network-order unsigned int is 4 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!I"]
  expected: 4

# ---------------------------------------------------------------------------
# struct.iter_unpack — class name of the returned iterator object
# iter_unpack returns a lazy iterator, not a list.
# The iterator object's type name is 'unpack_iterator'.
# ---------------------------------------------------------------------------

invariant struct_extra278.iter_unpack.returns_iterator_class:
  description: "struct.iter_unpack('!H', b'\\x00\\x01\\x00\\x02').__class__.__name__ == 'unpack_iterator' — iter_unpack returns a lazy iterator object; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: iter_unpack
  kind: python_call_eq
  function: iter_unpack.__class__.__name__.__eq__
  args: ["!H", !hex 00010002, "unpack_iterator"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack — network-order unsigned short 256 produces b'\x01\x00'
# pack('!H', 256) is the one-shot equivalent of pack_into with a fresh buffer.
# This cross-checks that pack and pack_into agree.
# ---------------------------------------------------------------------------

invariant struct_extra278.pack.network_H_256:
  description: "struct.pack('!H', 256) == b'\\x01\\x00' — 256 in big-endian unsigned short; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: pack_vector
  kind: python_call_eq
  function: pack
  args: ["!H", 256]
  expected: !hex 0100
