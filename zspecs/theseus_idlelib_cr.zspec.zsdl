spec: theseus_idlelib_cr
version: ">=3.0"
backend: python_cleanroom(theseus_idlelib_cr)
blocks: idlelib

docs: https://docs.python.org/3/library/idle.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/idle.html"
  not_derived_from:
    - "CPython source: Lib/idlelib/__init__.py"
  notes:
    - "Clean-room idlelib namespace stub. Do NOT import idlelib."

error_model: python_exceptions

invariant theseus_idlelib_cr.idlelib2_package:
  description: "idlelib is importable as a namespace"
  category: behavior
  kind: python_call_eq
  function: idlelib2_package
  args: []
  expected: true

invariant theseus_idlelib_cr.idlelib2_name:
  description: "idlelib has correct __name__"
  category: behavior
  kind: python_call_eq
  function: idlelib2_name
  args: []
  expected: true

invariant theseus_idlelib_cr.idlelib2_path:
  description: "idlelib has __path__ (is a package)"
  category: behavior
  kind: python_call_eq
  function: idlelib2_path
  args: []
  expected: true
