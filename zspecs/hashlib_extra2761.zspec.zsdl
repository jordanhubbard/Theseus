spec: hashlib_extra2761
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra276.zspec.zsdl — covers SHA-512/SHA-224 empty-input hexdigest vectors and digest_size/block_size attributes."
    - "hashlib_extra275.zspec.zsdl — covers SHA-256/MD5/SHA-1 empty-input hexdigest vectors and HASH class identity."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "hashlib.HASH.__dict__.__contains__('__matmul__') == False — HASH (the OpenSSL-backed C type) does not define matrix multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__truediv__') == False — HASH does not define true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__iadd__') == False — HASH does not define in-place addition; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__matmul__') == False — blake2b does not define matrix multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__truediv__') == False — blake2b does not define true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__iadd__') == False — blake2b does not define in-place addition; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__matmul__') == False — blake2s does not define matrix multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__truediv__') == False — blake2s does not define true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__iadd__') == False — blake2s does not define in-place addition; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.HASH.__dict__ — __matmul__, __truediv__, __iadd__ absence
# HASH is the C type for OpenSSL-backed hash objects (sha256, md5, sha1, etc.).
# None of these arithmetic/matrix operators are defined on hash types.
# ---------------------------------------------------------------------------

table hashlib_extra2761.hash_dict_matmul_truediv_iadd:
  description: "hashlib.HASH.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — arithmetic/matrix operators are not defined on hash digest objects; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2761

  columns: [id, function, args, expected]
  rows:
    - ["hl2761-hash-matmul",  hashlib.HASH.__dict__.__contains__,  ["__matmul__"],  false]
    - ["hl2761-hash-truediv", hashlib.HASH.__dict__.__contains__,  ["__truediv__"], false]
    - ["hl2761-hash-iadd",    hashlib.HASH.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 2: hashlib.blake2b.__dict__ — __matmul__, __truediv__, __iadd__ absence
# blake2b is the C type for BLAKE2b hash objects.
# Like HASH, it defines no arithmetic or matrix operators.
# ---------------------------------------------------------------------------

table hashlib_extra2761.blake2b_dict_matmul_truediv_iadd:
  description: "hashlib.blake2b.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — the BLAKE2b hash type defines no arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2761

  columns: [id, function, args, expected]
  rows:
    - ["hl2761-b2b-matmul",  hashlib.blake2b.__dict__.__contains__,  ["__matmul__"],  false]
    - ["hl2761-b2b-truediv", hashlib.blake2b.__dict__.__contains__,  ["__truediv__"], false]
    - ["hl2761-b2b-iadd",    hashlib.blake2b.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 3: hashlib.blake2s.__dict__ — __matmul__, __truediv__, __iadd__ absence
# blake2s is the C type for BLAKE2s hash objects.
# Like HASH and blake2b, it defines no arithmetic or matrix operators.
# ---------------------------------------------------------------------------

table hashlib_extra2761.blake2s_dict_matmul_truediv_iadd:
  description: "hashlib.blake2s.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — the BLAKE2s hash type defines no arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2761

  columns: [id, function, args, expected]
  rows:
    - ["hl2761-b2s-matmul",  hashlib.blake2s.__dict__.__contains__,  ["__matmul__"],  false]
    - ["hl2761-b2s-truediv", hashlib.blake2s.__dict__.__contains__,  ["__truediv__"], false]
    - ["hl2761-b2s-iadd",    hashlib.blake2s.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — all three hash types absent for all three dunders
# Consolidates one row per (type, dunder) pair for easy cross-type comparison.
# ---------------------------------------------------------------------------

table hashlib_extra2761.all_types_all_dunders_absent:
  description: "HASH, blake2b, and blake2s all lack __matmul__, __truediv__, and __iadd__ in __dict__ — no hashlib hash type defines these arithmetic or matrix operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2761

  columns: [id, function, args, expected]
  rows:
    - ["hl2761-x-hash-matmul",  hashlib.HASH.__dict__.__contains__,    ["__matmul__"],  false]
    - ["hl2761-x-hash-truediv", hashlib.HASH.__dict__.__contains__,    ["__truediv__"], false]
    - ["hl2761-x-hash-iadd",    hashlib.HASH.__dict__.__contains__,    ["__iadd__"],    false]
    - ["hl2761-x-b2b-matmul",   hashlib.blake2b.__dict__.__contains__, ["__matmul__"],  false]
    - ["hl2761-x-b2b-truediv",  hashlib.blake2b.__dict__.__contains__, ["__truediv__"], false]
    - ["hl2761-x-b2b-iadd",     hashlib.blake2b.__dict__.__contains__, ["__iadd__"],    false]
    - ["hl2761-x-b2s-matmul",   hashlib.blake2s.__dict__.__contains__, ["__matmul__"],  false]
    - ["hl2761-x-b2s-truediv",  hashlib.blake2s.__dict__.__contains__, ["__truediv__"], false]
    - ["hl2761-x-b2s-iadd",     hashlib.blake2s.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra2761.hash_no_matmul:
  description: "hashlib.HASH.__dict__.__contains__('__matmul__') == False — HASH (OpenSSL-backed C type) does not define matrix multiplication; hash objects are cryptographic primitives, not numeric types; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant hashlib_extra2761.hash_no_truediv:
  description: "hashlib.HASH.__dict__.__contains__('__truediv__') == False — HASH does not define true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant hashlib_extra2761.hash_no_iadd:
  description: "hashlib.HASH.__dict__.__contains__('__iadd__') == False — HASH does not define in-place addition; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

