spec: arrify
version: ">=2.0.0"
backend: node(arrify)

docs: https://www.npmjs.com/package/arrify

provenance:
  derived_from:
    - "arrify README — https://www.npmjs.com/package/arrify"
    - "Test vectors verified with arrify@2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "arrify source"
  notes:
    - "arrify is an npm package. Install: npm install arrify@2"
    - "arrify v2 is CommonJS. v3+ is ESM-only."
    - "arrify(value) wraps non-array values in an array; passes arrays through; returns [] for null/undefined."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table arrify.arrify:
  kind: node_module_call_eq
  function: ~
  category: arrify
  id_prefix: arr

  columns: [id, args, expected]
  rows:
    - [string,  ["foo"],       ["foo"]]
    - [number,  [42],          [42]]
    - [bool,    [true],        [true]]
    - [array,   [["foo"]],     ["foo"]]
    - [null_v,  [null],        []]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:38:15Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
