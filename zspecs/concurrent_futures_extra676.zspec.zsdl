spec: concurrent_futures_extra676
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from: ["CPython source code"]
  notes: ["Covers concurrent.futures exception subclass and executor class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra676.broken_pool_identity:
  description: "Identity checks for BrokenThreadPool and BrokenProcessPool"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf676bp
  columns: [id, function, args, expected]
  rows:
    - [cf676bp001, concurrent.futures.BrokenThreadPool.__class__.__name__.__eq__, ["type"], true]
    - [cf676bp002, concurrent.futures.BrokenProcessPool.__class__.__name__.__eq__, ["type"], true]
    - [cf676bp003, concurrent.futures.BrokenThreadPool.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf676bp004, concurrent.futures.BrokenProcessPool.__doc__.__class__.__name__.__eq__, ["str"], true]

table concurrent_futures_extra676.exception_identity:
  description: "Identity checks for concurrent.futures exception classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf676ei
  columns: [id, function, args, expected]
  rows:
    - [cf676ei001, concurrent.futures.InvalidStateError.__class__.__name__.__eq__, ["type"], true]
    - [cf676ei002, concurrent.futures.InvalidStateError.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf676ei003, concurrent.futures.BrokenExecutor.__init__.__qualname__.__eq__, ["BrokenExecutor.__init__"], true]
    - [cf676ei004, concurrent.futures.CancelledError.__init__.__qualname__.__eq__, ["CancelledError.__init__"], true]
    - [cf676ei005, concurrent.futures.TimeoutError.__init__.__qualname__.__eq__, ["TimeoutError.__init__"], true]

table concurrent_futures_extra676.executor_identity:
  description: "Identity checks for Future, Executor, and ThreadPoolExecutor classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf676xi
  columns: [id, function, args, expected]
  rows:
    - [cf676xi001, concurrent.futures.Future.__class__.__name__.__eq__, ["type"], true]
    - [cf676xi002, concurrent.futures.Executor.__class__.__name__.__eq__, ["type"], true]
    - [cf676xi003, concurrent.futures.ThreadPoolExecutor.__class__.__name__.__eq__, ["type"], true]
