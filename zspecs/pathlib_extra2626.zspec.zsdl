spec: pathlib_extra2626
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2611.zspec.zsdl — covers __init_subclass__/__subclasshook__/__class_getitem__ dict-presence"
  notes:
    - "Wave 622 (pathlib_extra2626) theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "None of the pathlib classes define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "__length_hint__ is a protocol method for sized iterators; path objects are not iterators."
    - "__missing__ is a dict subclass hook; pathlib path objects are not dict subclasses."
    - "__reversed__ is an iterator protocol method; path objects do not support reverse iteration."
    - "pathlib.PosixPath is the concrete POSIX path class; it also lacks all three dunders in its own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2626.no_length_hint_in_pathlib_classes:
  description: "__length_hint__ is absent from all pathlib class __dict__s — path objects are not sized iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2626

  columns: [id, function, args, expected]
  rows:
    - ["pp2626001", "pathlib.PurePath.__dict__.__contains__",        ["__length_hint__"], false]
    - ["pp2626002", "pathlib.Path.__dict__.__contains__",            ["__length_hint__"], false]
    - ["pp2626003", "pathlib.PurePosixPath.__dict__.__contains__",   ["__length_hint__"], false]
    - ["pp2626004", "pathlib.PureWindowsPath.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2626.no_missing_in_pathlib_classes:
  description: "__missing__ is absent from all pathlib class __dict__s — path objects are not dict subclasses"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2626

  columns: [id, function, args, expected]
  rows:
    - ["pp2626005", "pathlib.PurePath.__dict__.__contains__",        ["__missing__"], false]
    - ["pp2626006", "pathlib.Path.__dict__.__contains__",            ["__missing__"], false]
    - ["pp2626007", "pathlib.PurePosixPath.__dict__.__contains__",   ["__missing__"], false]
    - ["pp2626008", "pathlib.PureWindowsPath.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2626.no_reversed_in_pathlib_classes:
  description: "__reversed__ is absent from all pathlib class __dict__s — path objects do not support reverse iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2626

  columns: [id, function, args, expected]
  rows:
    - ["pp2626009",  "pathlib.PurePath.__dict__.__contains__",        ["__reversed__"], false]
    - ["pp2626010", "pathlib.Path.__dict__.__contains__",            ["__reversed__"], false]
    - ["pp2626011", "pathlib.PurePosixPath.__dict__.__contains__",   ["__reversed__"], false]
    - ["pp2626012", "pathlib.PureWindowsPath.__dict__.__contains__", ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes HAVE path-manipulation methods but NOT container/iterator protocol methods
# Confirms that path objects are domain-specific types, not reversible containers or dicts
# ---------------------------------------------------------------------------

table pathlib_extra2626.pathlib_has_path_methods_not_container_hooks:
  description: "pathlib classes define __str__/parts/name/parent/stat/exists but NOT __length_hint__/__missing__/__reversed__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2626

  columns: [id, function, args, expected]
  rows:
    - ["pp2626013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],        true]
    - ["pp2626014", "pathlib.PurePath.__dict__.__contains__", ["parts"],          true]
    - ["pp2626015", "pathlib.PurePath.__dict__.__contains__", ["name"],           true]
    - ["pp2626016", "pathlib.PurePath.__dict__.__contains__", ["parent"],         true]
    - ["pp2626017", "pathlib.PurePath.__dict__.__contains__", ["__length_hint__"], false]
    - ["pp2626018", "pathlib.PurePath.__dict__.__contains__", ["__missing__"],    false]
    - ["pp2626019", "pathlib.PurePath.__dict__.__contains__", ["__reversed__"],   false]
    - ["pp2626020", "pathlib.Path.__dict__.__contains__",     ["stat"],           true]
    - ["pp2626021", "pathlib.Path.__dict__.__contains__",     ["exists"],         true]
    - ["pp2626022", "pathlib.Path.__dict__.__contains__",     ["open"],           true]
    - ["pp2626023", "pathlib.Path.__dict__.__contains__",     ["__length_hint__"], false]
    - ["pp2626024", "pathlib.Path.__dict__.__contains__",     ["__missing__"],    false]
    - ["pp2626025", "pathlib.Path.__dict__.__contains__",     ["__reversed__"],   false]
