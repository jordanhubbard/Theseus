spec: mailcap_extra2
version: ">=3.9,<3.13"
backend: python_module(mailcap)

docs: https://docs.python.org/3/library/mailcap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mailcap.html — Python mailcap documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/mailcap.py"
  notes:
    - "This spec extends mailcap.zspec.zsdl and mailcap_extra.zspec.zsdl."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __name__ — the mailcap module's own __name__ attribute
# ---------------------------------------------------------------------------

invariant mailcap_extra2.module.name:
  description: "mailcap.__name__ == 'mailcap'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["mailcap"]
  expected: true

# ---------------------------------------------------------------------------
# getcaps — __qualname__ (complements __name__ in prior specs)
# ---------------------------------------------------------------------------

invariant mailcap_extra2.getcaps.qualname:
  description: "mailcap.getcaps.__qualname__ == 'getcaps'"
  category: functions
  kind: python_call_eq
  function: getcaps.__qualname__.__eq__
  args: ["getcaps"]
  expected: true

# ---------------------------------------------------------------------------
# findmatch — __qualname__ (complements __name__ in prior specs)
# ---------------------------------------------------------------------------

invariant mailcap_extra2.findmatch.qualname:
  description: "mailcap.findmatch.__qualname__ == 'findmatch'"
  category: functions
  kind: python_call_eq
  function: findmatch.__qualname__.__eq__
  args: ["findmatch"]
  expected: true

# ---------------------------------------------------------------------------
# getcaps() return type — returns a dict
# (mailcap_extra.zspec.zsdl uses method chain; here we use a direct method call)
# ---------------------------------------------------------------------------

invariant mailcap_extra2.getcaps.returns_dict:
  description: "mailcap.getcaps() returns a dict"
  category: functions
  kind: python_call_eq
  function: getcaps
  args: []
  method: __class__.__name__.__eq__
  method_args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# getcaps — module affiliation confirmed via __module__ != 'builtins'
# ---------------------------------------------------------------------------

invariant mailcap_extra2.getcaps.module_not_builtins:
  description: "mailcap.getcaps.__module__ != 'builtins' — getcaps is not a builtin"
  category: functions
  kind: python_call_eq
  function: getcaps.__module__.__eq__
  args: ["builtins"]
  expected: false

# ---------------------------------------------------------------------------
# findmatch — module affiliation confirmed via __module__ != 'builtins'
# ---------------------------------------------------------------------------

invariant mailcap_extra2.findmatch.module_not_builtins:
  description: "mailcap.findmatch.__module__ != 'builtins' — findmatch is not a builtin"
  category: functions
  kind: python_call_eq
  function: findmatch.__module__.__eq__
  args: ["builtins"]
  expected: false
