spec: struct_extra2086
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 struct documentation — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl"
  notes:
    - "Wave extra2086, theme: __format__ string formatting protocol dict-presence; __bytes__ bytes conversion dict-presence; __fspath__ filesystem path protocol dict-presence; __buffer__/__release_buffer__ buffer protocol dict-presence."
    - "struct.Struct is a C extension type. Neither __format__, __bytes__, __fspath__, __buffer__, nor __release_buffer__ appear in struct.Struct.__dict__."
    - "struct.error is a plain Python exception subclassing Exception; it adds no special dunder methods beyond __doc__ and __module__."
    - "struct.Struct.__dict__ contains: __init__, __new__, __repr__, __setattr__, __delattr__, __getattribute__, __sizeof__, format, size, pack, pack_into, unpack, unpack_from, iter_unpack."
    - "struct.calcsize('>B') == 1, struct.calcsize('>H') == 2, struct.calcsize('>I') == 4, struct.calcsize('>Q') == 8."
    - "All expected values verified by running Python 3.12 struct on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __format__ string formatting protocol dict-presence
# ---------------------------------------------------------------------------

table struct_extra2086.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st2086001", "struct.Struct.__dict__.__contains__", ["__format__"], false]
    - ["st2086002", "struct.error.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# __bytes__ bytes conversion protocol dict-presence
# ---------------------------------------------------------------------------

table struct_extra2086.bytes_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st2086003", "struct.Struct.__dict__.__contains__", ["__bytes__"], false]
    - ["st2086004", "struct.error.__dict__.__contains__", ["__bytes__"], false]

# ---------------------------------------------------------------------------
# __fspath__ filesystem path protocol dict-presence
# ---------------------------------------------------------------------------

table struct_extra2086.fspath_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st2086005", "struct.Struct.__dict__.__contains__", ["__fspath__"], false]
    - ["st2086006", "struct.error.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# __buffer__ / __release_buffer__ buffer protocol dict-presence
# ---------------------------------------------------------------------------

table struct_extra2086.buffer_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st2086007", "struct.Struct.__dict__.__contains__", ["__buffer__"], false]
    - ["st2086008", "struct.Struct.__dict__.__contains__", ["__release_buffer__"], false]
    - ["st2086009", "struct.error.__dict__.__contains__", ["__buffer__"], false]
    - ["st2086010", "struct.error.__dict__.__contains__", ["__release_buffer__"], false]

# ---------------------------------------------------------------------------
# struct.Struct class __dict__ — explicitly defined attributes
# ---------------------------------------------------------------------------

table struct_extra2086.struct_class_dict:
  columns: [id, function, args, expected]
  rows:
    - ["st2086011", "struct.Struct.__dict__.__contains__", ["__init__"], true]
    - ["st2086012", "struct.Struct.__dict__.__contains__", ["__new__"], true]
    - ["st2086013", "struct.Struct.__dict__.__contains__", ["__repr__"], true]
    - ["st2086014", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]
    - ["st2086015", "struct.Struct.__dict__.__contains__", ["format"], true]
    - ["st2086016", "struct.Struct.__dict__.__contains__", ["size"], true]
    - ["st2086017", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st2086018", "struct.Struct.__dict__.__contains__", ["pack_into"], true]
    - ["st2086019", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st2086020", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2086021", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st2086022", "struct.Struct.__dict__.__contains__", ["__getattribute__"], true]
    - ["st2086023", "struct.Struct.__dict__.__contains__", ["__setattr__"], true]
    - ["st2086024", "struct.Struct.__dict__.__contains__", ["__delattr__"], true]

# ---------------------------------------------------------------------------
# struct.error class __dict__ — exception class attributes
# ---------------------------------------------------------------------------

table struct_extra2086.error_class_dict:
  columns: [id, function, args, expected]
  rows:
    - ["st2086025", "struct.error.__dict__.__contains__", ["__doc__"], true]
    - ["st2086026", "struct.error.__dict__.__contains__", ["__module__"], true]
    - ["st2086027", "struct.error.__dict__.__contains__", ["__init__"], false]
    - ["st2086028", "struct.error.__dict__.__contains__", ["__str__"], false]
