spec: inspect_extra2056
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments do not define sequence/mapping or attribute access protocol methods."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra2056.getitem_protocol:
  description: "inspect types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2056
  columns: [id, function, args, expected]
  rows:
    - ["in2056001", "inspect.Parameter.__dict__.__contains__",      ["__getitem__"], false]
    - ["in2056002", "inspect.Signature.__dict__.__contains__",      ["__getitem__"], false]
    - ["in2056003", "inspect.BoundArguments.__dict__.__contains__", ["__getitem__"], false]
    - ["in2056004", "inspect.Parameter.__dict__.__contains__",      ["__setitem__"], false]
    - ["in2056005", "inspect.Signature.__dict__.__contains__",      ["__setitem__"], false]
    - ["in2056006", "inspect.BoundArguments.__dict__.__contains__", ["__setitem__"], false]
    - ["in2056007", "inspect.Parameter.__dict__.__contains__",      ["__delitem__"], false]
    - ["in2056008", "inspect.Signature.__dict__.__contains__",      ["__delitem__"], false]
    - ["in2056009", "inspect.BoundArguments.__dict__.__contains__", ["__delitem__"], false]

