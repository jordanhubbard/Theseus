spec: io_extra114
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io_extra113.zspec.zsdl."
    - "This spec covers: io module constants (DEFAULT_BUFFER_SIZE, SEEK_SET, SEEK_CUR, SEEK_END), io.UnsupportedOperation class hierarchy, and io.open/io.open_code class names."
    - "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB); type is 'int'."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2; all are plain 'int' values."
    - "io.UnsupportedOperation.__bases__ == (OSError, ValueError); __bases__[0].__name__ == 'OSError'."
    - "io.UnsupportedOperation.__mro__ len == 6: (UnsupportedOperation, OSError, ValueError, Exception, BaseException, object)."
    - "io.UnsupportedOperation.__module__ == 'io'."
    - "io.open.__class__.__name__ == 'builtin_function_or_method' (C builtin, same as the built-in open)."
    - "io.open_code.__class__.__name__ == 'builtin_function_or_method' (C builtin; available since Python 3.8)."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' (plain Python int constant)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module seek constants and DEFAULT_BUFFER_SIZE
# SEEK_SET/SEEK_CUR/SEEK_END are plain int constants (0, 1, 2).
# DEFAULT_BUFFER_SIZE == 131072 (128 KiB), also a plain int.
# ---------------------------------------------------------------------------

table io_extra114.seek_constants:
  description: "io module seek and buffer constants: SEEK_SET=0, SEEK_CUR=1, SEEK_END=2, DEFAULT_BUFFER_SIZE=131072; all are plain int; type name == 'int'"
  kind: python_call_eq
  category: constants
  id_prefix: ioconst114a

  columns: [id, function, args, expected, description]
  rows:
    - [seek_set_val,   "SEEK_SET.__eq__",                       [0],      true,  "io.SEEK_SET == 0 (seek-from-start constant)"]
    - [seek_cur_val,   "SEEK_CUR.__eq__",                       [1],      true,  "io.SEEK_CUR == 1 (seek-from-current-position constant)"]
    - [seek_end_val,   "SEEK_END.__eq__",                       [2],      true,  "io.SEEK_END == 2 (seek-from-end constant)"]
    - [seek_set_type,  "SEEK_SET.__class__.__name__.__eq__",    ["int"],  true,  "type(io.SEEK_SET).__name__ == 'int' (plain Python int, not IntFlag or Enum)"]
    - [seek_cur_type,  "SEEK_CUR.__class__.__name__.__eq__",    ["int"],  true,  "type(io.SEEK_CUR).__name__ == 'int'"]
    - [seek_end_type,  "SEEK_END.__class__.__name__.__eq__",    ["int"],  true,  "type(io.SEEK_END).__name__ == 'int'"]
    - [buf_size_val,   "DEFAULT_BUFFER_SIZE.__eq__",            [131072], true,  "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; the default size for buffered I/O streams)"]
    - [buf_size_type,  "DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__", ["int"], true, "type(io.DEFAULT_BUFFER_SIZE).__name__ == 'int' (plain int constant)"]
    - [seek_set_ne_cur,"SEEK_SET.__eq__",                       [1],      false, "io.SEEK_SET != io.SEEK_CUR (0 != 1; the three seek modes are distinct integer values)"]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation class hierarchy
# UnsupportedOperation.__bases__ == (OSError, ValueError).
# MRO: UnsupportedOperation, OSError, ValueError, Exception, BaseException, object (len=6).
# __module__ == 'io'.
# ---------------------------------------------------------------------------

table io_extra114.UnsupportedOperation_hierarchy:
  description: "io.UnsupportedOperation class hierarchy: __bases__[0]='OSError', __bases__[1]='ValueError', __mro__ len=6, __module__='io', __name__='UnsupportedOperation'"
  kind: python_call_eq
  category: class_names
  id_prefix: ioconst114b

  columns: [id, function, args, expected, description]
  rows:
    - [unsup_name,       "UnsupportedOperation.__name__.__eq__",           ["UnsupportedOperation"], true, "io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"]
    - [unsup_base0,      "UnsupportedOperation.__bases__[0].__name__.__eq__", ["OSError"],        true,  "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' (primary base)"]
    - [unsup_base1,      "UnsupportedOperation.__bases__[1].__name__.__eq__", ["ValueError"],     true,  "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError' (secondary base; makes it catchable as a ValueError too)"]
    - [unsup_mro_len,    "UnsupportedOperation.__mro__.__len__",           [],                   6,     "io.UnsupportedOperation.__mro__.__len__() == 6 (UnsupportedOperation, OSError, ValueError, Exception, BaseException, object)"]
    - [unsup_module,     "UnsupportedOperation.__module__.__eq__",         ["io"],               true,  "io.UnsupportedOperation.__module__ == 'io' (defined in the pure-Python io module, not in _io C extension)"]
    - [unsup_name_len,   "UnsupportedOperation.__name__.__len__",          [],                   20,    "io.UnsupportedOperation.__name__.__len__() == 20 ('UnsupportedOperation' has 20 characters)"]
    - [unsup_mod_ne_io2, "UnsupportedOperation.__module__.__eq__",         ["_io"],              false, "io.UnsupportedOperation.__module__ != '_io' (the class is defined in the 'io' Python wrapper, not the '_io' C extension)"]

# ---------------------------------------------------------------------------
# io.open and io.open_code class names
# Both are C builtins: type name == 'builtin_function_or_method'.
# io.open is an alias for the built-in open function from _io.
# io.open_code is a security-oriented open for interpreter use (Python 3.8+).
# ---------------------------------------------------------------------------

table io_extra114.open_class_names:
  description: "io.open and io.open_code class names: both are 'builtin_function_or_method' (C extension builtins)"
  kind: python_call_eq
  category: class_names
  id_prefix: ioconst114c

  columns: [id, function, args, expected, description]
  rows:
    - [open_type,      "open.__class__.__name__.__eq__",      ["builtin_function_or_method"], true, "type(io.open).__name__ == 'builtin_function_or_method' (io.open is a C builtin alias for the built-in open)"]
    - [open_code_type, "open_code.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "type(io.open_code).__name__ == 'builtin_function_or_method' (io.open_code is a C builtin for security-audited file opening)"]
    - [open_not_func,  "open.__class__.__name__.__eq__",      ["function"],                  false, "type(io.open).__name__ != 'function' (io.open is a C builtin, not a Python-level function)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra114.SEEK_SET.value_zero:
  description: "io.SEEK_SET == 0 (seek-from-start; the value 0 means the offset is measured from the beginning of the file; SEEK_SET/SEEK_CUR/SEEK_END map to 0/1/2 matching POSIX SEEK_SET/SEEK_CUR/SEEK_END)"
  category: constants
  kind: python_call_eq
  function: "SEEK_SET.__eq__"
  args: [0]
  expected: true

invariant io_extra114.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; this is the default buffer size used by BufferedReader, BufferedWriter, and BufferedRandom when no explicit buffer_size argument is given)"
  category: constants
  kind: python_call_eq
  function: "DEFAULT_BUFFER_SIZE.__eq__"
  args: [131072]
  expected: true

invariant io_extra114.UnsupportedOperation.mro_len_6:
  description: "io.UnsupportedOperation.__mro__.__len__() == 6 (the MRO is UnsupportedOperation, OSError, ValueError, Exception, BaseException, object; the length of 6 reflects double-inheritance from OSError and ValueError, with their shared ancestors merged once)"
  category: class_names
  kind: python_call_eq
  function: "UnsupportedOperation.__mro__.__len__"
  args: []
  expected: 6

invariant io_extra114.UnsupportedOperation.module_is_io:
  description: "io.UnsupportedOperation.__module__ == 'io' (UnsupportedOperation is defined in the pure-Python 'io' wrapper module, not in the C extension '_io'; this contrasts with io.FileIO and io.BufferedReader whose __module__ == '_io')"
  category: class_names
  kind: python_call_eq
  function: "UnsupportedOperation.__module__.__eq__"
  args: ["io"]
  expected: true

invariant io_extra114.open.type_builtin:
  description: "type(io.open).__name__ == 'builtin_function_or_method' (io.open is an alias for the C-level _io.open; it is a builtin function, not a Python-level 'function' object; similarly io.open_code shares this type)"
  category: class_names
  kind: python_call_eq
  function: "open.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

