spec: csv_stringify
version: ">=6.0.0"
backend: node(csv-stringify/sync)

docs: https://csv.js.org/stringify/

provenance:
  derived_from:
    - "csv-stringify documentation — https://csv.js.org/stringify/"
    - "RFC 4180 (Common Format and MIME Type for CSV Files)"
    - "Test vectors verified with csv-stringify via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "csv-stringify source"
  notes:
    - "csv-stringify is the emitter half of the csv ecosystem (sibling to csv-parse)."
    - "Install: npm install csv-stringify"
    - "Spec uses the synchronous subpath: const {stringify} = require('csv-stringify/sync'); stringify(input, options) -> string"
    - "Default field separator is ','; default record separator is '\\n'; default quote behaviour is to quote only fields containing commas, quotes, or newlines."
    - "Output ends with a trailing record separator (\\n) when there is at least one record; empty input yields the empty string."
  rfcs:
    - "RFC 4180 — Common Format and MIME Type for Comma-Separated Values (CSV) Files — https://www.rfc-editor.org/rfc/rfc4180"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function — sync stringify returns a string; never throws on valid 2D array / array-of-objects input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table csv_stringify.array_input:
  kind: node_chain_eq
  category: array_input
  entry: named
  function: stringify
  id_prefix: arr

  columns: [id, entry_args, chain, expected]
  rows:
    - [two_rows,
       [[["a","b"],["1","2"]]],
       [],
       "a,b\n1,2\n"]

    - [single_row,
       [[["x","y","z"]]],
       [],
       "x,y,z\n"]

    - [empty_input,
       [[]],
       [],
       ""]

    - [quotes_field_containing_comma,
       [[["x,y","z"]]],
       [],
       "\"x,y\",z\n"]

    - [quotes_field_containing_newline,
       [[["a","b\nc"]]],
       [],
       "a,\"b\nc\"\n"]

    - [quotes_field_containing_doublequote,
       [[["he said \"hi\""]]],
       [],
       "\"he said \"\"hi\"\"\"\n"]

# ── object-input mode with {header: true} writes a header row first ────────

table csv_stringify.object_input_with_header:
  kind: node_chain_eq
  category: object_input
  entry: named
  function: stringify
  id_prefix: obj

  columns: [id, entry_args, chain, expected]
  rows:
    - [two_objects,
       [[{a: 1, b: 2}, {a: 3, b: 4}], {header: true}],
       [],
       "a,b\n1,2\n3,4\n"]

    - [single_object,
       [[{name: "Alice", age: 30}], {header: true}],
       [],
       "name,age\nAlice,30\n"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T16:42:07Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
