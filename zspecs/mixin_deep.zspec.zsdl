spec: mixin_deep
version: ">=2.0.1"
backend: node(mixin-deep)

docs: https://www.npmjs.com/package/mixin-deep

provenance:
  derived_from:
    - "mixin-deep README — https://www.npmjs.com/package/mixin-deep"
    - "Test vectors verified with mixin-deep via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "mixin-deep source"
  notes:
    - "mixin-deep is an npm package. Install: npm install mixin-deep"
    - "Deeply mixes properties of source objects into the first object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the mutated first object with all sources mixed in."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table mixin_deep.mixin:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: mixindeep

  columns: [id, args, expected]
  rows:
    - [shallow, [{"a": 1}, {"b": 2}],                    {"a": 1, "b": 2}]
    - [deep,    [{"a": {"x": 1}}, {"a": {"y": 2}}],      {"a": {"x": 1, "y": 2}}]
