spec: struct_extra143
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra142.zspec.zsdl — covers struct.__all__/__class__.__name__.__eq__('list') / __all__.__len__()==8 / __all__.__contains__('Struct'/'error'/'pack'/'calcsize') / __spec__.name.__eq__('struct') / __loader__.__class__.__name__.__eq__('SourceFileLoader') / Struct.__init__.__qualname__.__eq__('Struct.__init__') (table + invariants)."
    - "struct_extra141.zspec.zsdl — covers struct.Struct.__module__.__eq__('_struct') / Struct.__qualname__.__eq__('Struct') / Struct.__bases__[0].__name__.__eq__('object') / Struct.__mro__.__len__()==2 / Struct.__doc__.__len__()==40 / Struct.__dict__.__class__.__name__.__eq__('mappingproxy') / error.__qualname__.__eq__('error') (table + invariants)."
    - "struct_extra140.zspec.zsdl — covers struct.Struct.format/__class__.__name__.__eq__('getset_descriptor') / Struct.size/__class__.__name__.__eq__('getset_descriptor') / struct.__doc__.__len__()==1278 / struct.error/__doc__ is None (table + invariants)."
    - "struct_extra139.zspec.zsdl — covers struct module-level function __qualname__ string equality (all six) / __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra138.zspec.zsdl — covers Struct method __qualname__ string equality (pack/unpack/pack_into/unpack_from/iter_unpack) / error.__name__/__qualname__/__bases__[0].__name__ (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra142."
    - "Wave 318 theme: struct.Struct.__dict__ membership checks — Struct.__dict__.__contains__('pack')==True / __dict__.__contains__('unpack')==True / __dict__.__contains__('pack_into')==True / __dict__.__contains__('format')==True / __dict__.__contains__('size')==True / Struct.__dict__.__len__()==16 / struct.pack.__module__.__eq__('_struct') / struct.__package__.__eq__('')."
    - "struct.Struct.__dict__.__contains__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('format') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('size') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__len__() == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__dict__ has 16 entries (verified Python 3.14.3): pack, pack_into, unpack, unpack_from, iter_unpack (method_descriptor), format, size (getset_descriptor), __init__, __repr__, __delattr__, __getattribute__, __setattr__ (wrapper_descriptor), __sizeof__ (method_descriptor), __new__ (builtin_function_or_method), __doc__ (str), __module__ (str). This is the exact set of 16 direct class attributes."
    - "Note: struct.pack.__module__ == '_struct' (7 chars). Module-level functions like pack, unpack, calcsize, etc., are imported directly from the _struct C extension into the struct namespace, so their __module__ is '_struct' (with underscore). This is consistent with Struct.__module__ (also '_struct', anchored in extra141)."
    - "Note: struct.__package__ == '' (empty string). This is the standard __package__ value for top-level stdlib modules. It matches uuid.__package__/hashlib.__package__/socket.__package__ (all ''), confirming struct is a top-level module."
    - "Note: The 16 entries in Struct.__dict__ are a compact C extension class dict. Comparing to other class __dict__ sizes: struct.Struct (16) < socket.socket (28) << uuid.UUID (37). The smaller count reflects that Struct is a simpler C extension type with fewer methods and attributes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('pack')
# struct.Struct.__dict__.__contains__('unpack')
# struct.Struct.__dict__.__contains__('pack_into')
# struct.Struct.__dict__.__contains__('format')
#
# Wave 318 theme: struct.Struct class __dict__ contains method and descriptor names.
#
# pack, unpack, pack_into are method_descriptor objects present directly in the Struct
# class dict. format is a getset_descriptor present in the Struct class dict. extra140
# anchors Struct.format as a getset_descriptor; no prior struct spec anchors
# __dict__.__contains__ for pack/unpack/pack_into/format as a table under structdict143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra143.Struct_dict_contains_methods_and_format:
  description: "struct.Struct.__dict__.__contains__('pack')==True / __dict__.__contains__('unpack')==True / __dict__.__contains__('pack_into')==True / __dict__.__contains__('format')==True — pack/unpack/pack_into are method_descriptor (C-level); format is a getset_descriptor returning the format string; extra140 anchors format as getset_descriptor; first structdict143 anchor for Struct.__dict__.__contains__ method checks"
  kind: python_call_eq
  category: identity
  id_prefix: structdict143

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_pack,     Struct.__dict__.__contains__, ["pack"],     true, "struct.Struct.__dict__.__contains__('pack') == True (method_descriptor; packs values into bytes per format)"]
    - [dict_contains_unpack,   Struct.__dict__.__contains__, ["unpack"],   true, "struct.Struct.__dict__.__contains__('unpack') == True (method_descriptor; unpacks bytes to tuple)"]
    - [dict_contains_pack_into, Struct.__dict__.__contains__, ["pack_into"], true, "struct.Struct.__dict__.__contains__('pack_into') == True (method_descriptor; packs into an existing buffer)"]
    - [dict_contains_format,   Struct.__dict__.__contains__, ["format"],   true, "struct.Struct.__dict__.__contains__('format') == True (getset_descriptor returning the format string)"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('size')
# struct.Struct.__dict__.__contains__('iter_unpack')
# struct.Struct.__dict__.__len__()==16
# struct.pack.__module__.__eq__('_struct')
#
# Wave 318 theme: struct.Struct dict size descriptor, iter_unpack, dict length, and pack module.
#
# size is a getset_descriptor present in Struct.__dict__ (like format). iter_unpack is
# a method_descriptor. The total Struct.__dict__ length is 16. Module-level pack has
# __module__ == '_struct' since it is a C-level function imported from _struct.
# No prior struct spec anchors Struct.__dict__.__contains__('size'/'iter_unpack') or
# dict length or pack.__module__ as a table under structdict143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra143.Struct_dict_size_iterunpack_len_and_module:
  description: "struct.Struct.__dict__.__contains__('size')==True / __dict__.__contains__('iter_unpack')==True / Struct.__dict__.__len__()==16 / struct.pack.__module__.__eq__('_struct')==True — size is a getset_descriptor; iter_unpack is a method_descriptor; dict has 16 entries (compact C extension type; smaller than socket.socket=28 or uuid.UUID=37); pack.__module__ is '_struct' (C-level function); no prior struct spec anchors these under structdict143"
  kind: python_call_eq
  category: identity
  id_prefix: structdict143

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_size,      Struct.__dict__.__contains__, ["size"],         true, "struct.Struct.__dict__.__contains__('size') == True (getset_descriptor returning byte size for format string)"]
    - [dict_contains_iterunpack, Struct.__dict__.__contains__, ["iter_unpack"],  true, "struct.Struct.__dict__.__contains__('iter_unpack') == True (method_descriptor; yields tuples from a buffer)"]
    - [dict_len_16,             Struct.__dict__.__len__,      [],               16,   "struct.Struct.__dict__.__len__() is 16 (compact C extension class; struct(16) < socket.socket(28) << UUID(37))"]
    - [pack_module_struct,      pack.__module__.__eq__,       ["_struct"],      true, "struct.pack.__module__ == '_struct' (7 chars; C-level function imported from _struct C extension)"]

# ---------------------------------------------------------------------------
# struct.__package__.__eq__('')
# struct.Struct.__dict__.__contains__('unpack_from')
# struct.Struct.__dict__.__contains__('__repr__')
# struct.Struct.__name__.__eq__('Struct')
#
# Wave 318 theme: struct module package, additional Struct dict entries, and Struct name.
#
# struct.__package__ is '' (empty string) for a top-level module. Struct.__dict__ also
# contains unpack_from (a method_descriptor) and __repr__ (a wrapper_descriptor).
# Struct.__name__ is 'Struct' (6 chars) — the class name matching its qualname.
# No prior struct spec anchors these together as a table under structdict143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra143.package_and_additional_dict_entries:
  description: "struct.__package__.__eq__('')==True / Struct.__dict__.__contains__('unpack_from')==True / Struct.__dict__.__contains__('__repr__')==True / Struct.__name__.__eq__('Struct')==True — __package__ '' for top-level module; unpack_from is a method_descriptor; __repr__ is a wrapper_descriptor (C-level slot wrapper); Struct.__name__ 'Struct' (6 chars) matches __qualname__; no prior struct spec anchors these under structdict143"
  kind: python_call_eq
  category: identity
  id_prefix: structdict143

  columns: [id, function, args, expected, description]
  rows:
    - [pkg_empty,              __package__.__eq__,           [""],          true, "struct.__package__ == '' (empty string; standard for top-level stdlib modules)"]
    - [dict_contains_unpack_from, Struct.__dict__.__contains__, ["unpack_from"], true, "struct.Struct.__dict__.__contains__('unpack_from') == True (method_descriptor; unpacks from buffer at offset)"]
    - [dict_contains_repr,    Struct.__dict__.__contains__, ["__repr__"],  true, "struct.Struct.__dict__.__contains__('__repr__') == True (wrapper_descriptor; C-level slot wrapper)"]
    - [struct_name_eq,        Struct.__name__.__eq__,       ["Struct"],    true, "struct.Struct.__name__ == 'Struct' (6 chars; matches __qualname__; top-level C extension class name)"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('pack') — standalone
#
# struct.Struct.__dict__.__contains__('pack') is True. The 'pack' method is a
# method_descriptor in the Struct class dict. It packs the given values into a
# bytes object according to the Struct's format string. The pack method_descriptor
# is accessed as struct.Struct.__dict__['pack'] and is of type method_descriptor.
# extra138 anchors Struct.pack.__qualname__.__eq__('Struct.pack') (9 chars); no prior
# struct spec anchors Struct.__dict__.__contains__('pack') as a standalone under
# structdict143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra143.Struct_dict_contains_pack:
  description: "struct.Struct.__dict__.__contains__('pack') == True — 'pack' is a method_descriptor in the Struct class dict; packs values per the Struct format string; extra138 anchors Struct.pack qualname (9 chars); no prior struct spec anchors this as a standalone; first standalone under structdict143"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('format') — standalone
#
# struct.Struct.__dict__.__contains__('format') is True. The 'format' attribute is
# a getset_descriptor in the Struct class dict. It returns the format string used
# to create the Struct object. extra140 anchors Struct.format as a getset_descriptor
# with __class__.__name__ == 'getset_descriptor' (17 chars) and qualname 'Struct.format'
# (13 chars); no prior struct spec anchors Struct.__dict__.__contains__('format')
# as a standalone under structdict143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra143.Struct_dict_contains_format:
  description: "struct.Struct.__dict__.__contains__('format') == True — 'format' is a getset_descriptor in the Struct class dict; returns the format string; extra140 anchors class name 'getset_descriptor' (17 chars) and qualname 'Struct.format' (13 chars); no prior struct spec anchors this as a standalone; first standalone under structdict143"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["format"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__len__()==16 — standalone
#
# struct.Struct.__dict__.__len__() is 16. The 16 entries are: pack, pack_into, unpack,
# unpack_from, iter_unpack (5 method_descriptors), format, size (2 getset_descriptors),
# __init__, __repr__, __delattr__, __getattribute__, __setattr__ (4 wrapper_descriptors
# + 1 from the count above), __sizeof__ (method_descriptor), __new__ (builtin function),
# __doc__ (str), __module__ (str). Comparing class __dict__ sizes: struct.Struct (16) <
# socket.socket (28) << uuid.UUID (37). No prior struct spec anchors
# Struct.__dict__.__len__()==16 as a standalone under structdict143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra143.Struct_dict_len_16:
  description: "struct.Struct.__dict__.__len__() == 16 — 16 entries: 5 method_descriptors (pack/pack_into/unpack/unpack_from/iter_unpack) + 2 getset_descriptors (format/size) + 4 wrapper_descriptors + __sizeof__ + __new__ + __doc__ + __module__; class dict ordering: Struct(16) < socket.socket(28) << UUID(37); no prior struct spec anchors this as a standalone; first standalone under structdict143"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# struct.pack.__module__.__eq__('_struct') — standalone
#
# struct.pack.__module__ is '_struct' (7 chars). The module-level pack function
# is a builtin_function_or_method imported directly from the _struct C extension
# into the struct namespace, so it reports its __module__ as '_struct' (with
# underscore prefix). This is consistent with all other struct module-level functions
# (unpack, calcsize, pack_into, unpack_from, iter_unpack) which also have
# __module__ == '_struct'. Struct.__module__ (anchored in extra141) is also '_struct'
# (7 chars). No prior struct spec anchors pack.__module__.__eq__('_struct') as a
# standalone under structdict143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra143.pack_module_eq:
  description: "struct.pack.__module__.__eq__('_struct') == True — '_struct' (7 chars); C-level builtin_function_or_method imported from _struct; all struct module-level functions share __module__ == '_struct'; consistent with Struct.__module__ (extra141); no prior struct spec anchors this as a standalone; first standalone under structdict143"
  category: identity
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__package__.__eq__('') — standalone
#
# struct.__package__ is '' (empty string). This is the standard __package__ value
# for top-level stdlib modules not contained in a sub-package. All four stdlib modules
# covered by this spec series have empty-string __package__: hashlib, uuid, struct,
# and socket. The empty string distinguishes these top-level modules from sub-package
# modules such as email.utils (__package__ == 'email') or xml.etree.ElementTree
# (__package__ == 'xml.etree'). No prior struct spec anchors struct.__package__ == ''
# as a standalone under structdict143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra143.package_empty:
  description: "struct.__package__.__eq__('') == True — empty string; standard __package__ for top-level stdlib modules; matches hashlib/uuid/socket (all ''); contrasts with sub-packages that have non-empty __package__ (e.g. email.utils); no prior struct spec anchors this as a standalone; first standalone under structdict143"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
