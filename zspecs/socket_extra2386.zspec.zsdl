spec: socket_extra2386
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 606 (_extra2386): __str__ and __repr__ implementation type classification."
    - "socket.socket defines __repr__ in Python → 'function'; inherits __str__ from object → 'wrapper_descriptor'."
    - "socket.error (OSError alias) inherits both __repr__ and __str__ from BaseException → 'wrapper_descriptor'."
    - "socket.AddressFamily (IntEnum) defines __repr__ via enum machinery → 'function'; inherits __str__ → 'wrapper_descriptor'."
    - "socket.SocketKind (IntEnum) defines __repr__ via enum machinery → 'function'; inherits __str__ → 'wrapper_descriptor'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2386.socket_str_repr:
  description: "socket.socket __repr__ and __str__ implementation type via .__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk2386
  columns: [id, function, args, expected]
  rows:
    - ["sk2386001", "socket.socket.__repr__.__class__.__name__", [], "function"]
    - ["sk2386002", "socket.socket.__str__.__class__.__name__", [], "wrapper_descriptor"]

