  rows:
    - ["dc3016007", operator.contains, [decimal.Decimal.__dict__,          "__next__"], false]
    - ["dc3016008", operator.contains, [decimal.Context.__dict__,          "__next__"], false]
    - ["dc3016009", operator.contains, [decimal.Underflow.__dict__,        "__next__"], false]
    - ["dc3016010", operator.contains, [decimal.Inexact.__dict__,          "__next__"], false]
    - ["dc3016011", operator.contains, [decimal.Rounded.__dict__,          "__next__"], false]
    - ["dc3016012", operator.contains, [decimal.Subnormal.__dict__,        "__next__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — operator.contains(Cls.__dict__, '__reversed__')
#
# decimal types do not support reversed iteration; none define __reversed__; all false.
# ---------------------------------------------------------------------------

table dc3016.reversed:
  description: "decimal types __reversed__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc3016
  columns: [id, function, args, expected]
  rows:
    - ["dc3016013", operator.contains, [decimal.Decimal.__dict__,          "__reversed__"], false]
    - ["dc3016014", operator.contains, [decimal.Context.__dict__,          "__reversed__"], false]
    - ["dc3016015", operator.contains, [decimal.DecimalException.__dict__, "__reversed__"], false]
    - ["dc3016016", operator.contains, [decimal.FloatOperation.__dict__,   "__reversed__"], false]
    - ["dc3016017", operator.contains, [decimal.Clamped.__dict__,          "__reversed__"], false]
    - ["dc3016018", operator.contains, [decimal.Overflow.__dict__,         "__reversed__"], false]

# ---------------------------------------------------------------------------
