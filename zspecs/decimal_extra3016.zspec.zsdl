spec: dc3016
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module class hierarchy"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (dc3016): __iter__, __next__, __reversed__ dict-presence checks for decimal types."
    - "decimal.Decimal is an arbitrary-precision numeric type — not a sequence or iterator; no iterator protocol."
    - "decimal.Context holds rounding/precision configuration; it is not iterable."
    - "decimal.DecimalException and all its subclasses (InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation, Clamped) are exception types with no iterator slots."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# Decimal numeric and exception types do not define __iter__; all false.
# ---------------------------------------------------------------------------

table dc3016.iter:
  description: "decimal types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc3016
  columns: [id, function, args, expected]
  rows:
    - ["dc3016001", operator.contains, [decimal.Decimal.__dict__,          "__iter__"], false]
    - ["dc3016002", operator.contains, [decimal.Context.__dict__,          "__iter__"], false]
    - ["dc3016003", operator.contains, [decimal.DecimalException.__dict__, "__iter__"], false]
    - ["dc3016004", operator.contains, [decimal.InvalidOperation.__dict__, "__iter__"], false]
    - ["dc3016005", operator.contains, [decimal.DivisionByZero.__dict__,   "__iter__"], false]
    - ["dc3016006", operator.contains, [decimal.Overflow.__dict__,         "__iter__"], false]

# ---------------------------------------------------------------------------
# __next__ dict-presence — operator.contains(Cls.__dict__, '__next__')
#
# decimal types are not iterators; none define __next__; all false.
# ---------------------------------------------------------------------------

table dc3016.next:
  description: "decimal types __next__ dict-presence checks; wave 648"
  kind: python_call_eq
