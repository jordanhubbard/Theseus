table abc_extra207.qualname_lengths:
  description: "abc class and function __qualname__ lengths for all five in abcqualname207 namespace; new to abc_extra207"
  kind: python_call_eq
  category: qualnames
  id_prefix: abcqualname207

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_qualname_len,
       abstractmethod.__qualname__.__len__,
       [],
       14,
       "abc.abstractmethod.__qualname__.__len__() == 14 — 'abstractmethod' has 14 characters; new to abc_extra207; verified Python 3.14.3"]
    - [get_cache_token_qualname_len,
       get_cache_token.__qualname__.__len__,
