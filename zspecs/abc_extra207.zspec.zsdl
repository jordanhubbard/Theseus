spec: abc_extra207
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers __qualname__ attributes of abc classes and functions: ABCMeta, ABC, abstractmethod, update_abstractmethods, get_cache_token."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta' — top-level metaclass; qualname equals name. len == 7. Verified Python 3.14.3."
    - "abc.ABC.__qualname__ == 'ABC' — top-level helper class; qualname equals name. len == 3. Verified Python 3.14.3."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' — top-level decorator class; qualname equals name. len == 14. Verified Python 3.14.3."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' — top-level function; qualname equals name. len == 22. Verified Python 3.14.3."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' — top-level function; qualname equals name. len == 15. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc class __qualname__ equality — ABCMeta and ABC
#
# abc.ABCMeta.__qualname__ == 'ABCMeta' (len 7)
# abc.ABC.__qualname__ == 'ABC' (len 3)
# abc.abstractmethod.__qualname__ == 'abstractmethod' (len 14)
# abc.get_cache_token.__qualname__ == 'get_cache_token' (len 15)
#
# All are top-level definitions; qualname equals simple name.
# ---------------------------------------------------------------------------

table abc_extra207.class_qualnames:
  description: "abc.ABCMeta/ABC/abstractmethod/get_cache_token __qualname__ equality checks in abcqualname207 namespace — all top-level; qualname equals name; new to abc_extra207"
  kind: python_call_eq
  category: qualnames
  id_prefix: abcqualname207

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_qualname_eq,
       ABCMeta.__qualname__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__qualname__.__eq__('ABCMeta') == True — ABCMeta is a top-level metaclass; qualname equals name; new to abc_extra207; verified Python 3.14.3"]
    - [abc_qualname_eq,
       ABC.__qualname__.__eq__,
       ["ABC"],
       true,
       "abc.ABC.__qualname__.__eq__('ABC') == True — ABC is a top-level helper class with ABCMeta as its metaclass; qualname equals name; new to abc_extra207; verified Python 3.14.3"]
    - [abstractmethod_qualname_eq,
       abstractmethod.__qualname__.__eq__,
       ["abstractmethod"],
       true,
       "abc.abstractmethod.__qualname__.__eq__('abstractmethod') == True — abstractmethod is a top-level decorator class; qualname equals name; new to abc_extra207; verified Python 3.14.3"]
    - [get_cache_token_qualname_eq,
       get_cache_token.__qualname__.__eq__,
       ["get_cache_token"],
       true,
       "abc.get_cache_token.__qualname__.__eq__('get_cache_token') == True — get_cache_token is a top-level function returning the current ABC cache token; qualname equals name; new to abc_extra207; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: abc.update_abstractmethods __qualname__ equality and length
#
# abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' (len 22)
#
# update_abstractmethods has the longest qualname of the five abc objects (22).
# Table also captures lengths for ABCMeta (7) and ABC (3).
# ---------------------------------------------------------------------------

table abc_extra207.update_abstractmethods_qualname:
  description: "abc.update_abstractmethods __qualname__ equality and abc class/function qualname length checks in abcqualname207 namespace; new to abc_extra207"
  kind: python_call_eq
  category: qualnames
  id_prefix: abcqualname207

  columns: [id, function, args, expected, description]
  rows:
    - [update_abstractmethods_qualname_eq,
       update_abstractmethods.__qualname__.__eq__,
       ["update_abstractmethods"],
       true,
       "abc.update_abstractmethods.__qualname__.__eq__('update_abstractmethods') == True — update_abstractmethods is a top-level function added in Python 3.10; qualname equals name; new to abc_extra207; verified Python 3.14.3"]
    - [update_abstractmethods_qualname_len,
       update_abstractmethods.__qualname__.__len__,
       [],
       22,
       "abc.update_abstractmethods.__qualname__.__len__() == 22 — 'update_abstractmethods' has 22 characters; longest qualname of the five; new to abc_extra207; verified Python 3.14.3"]
    - [abcmeta_qualname_len,
       ABCMeta.__qualname__.__len__,
       [],
       7,
       "abc.ABCMeta.__qualname__.__len__() == 7 — 'ABCMeta' has 7 characters; new to abc_extra207; verified Python 3.14.3"]
    - [abc_qualname_len,
       ABC.__qualname__.__len__,
       [],
       3,
       "abc.ABC.__qualname__.__len__() == 3 — 'ABC' has 3 characters; shortest qualname of the five; new to abc_extra207; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: abc class and function __qualname__ lengths — all five
#
# ABCMeta: 7, ABC: 3, abstractmethod: 14,
# update_abstractmethods: 22, get_cache_token: 15
#
# Length axis for abstractmethod and get_cache_token not yet captured above.
