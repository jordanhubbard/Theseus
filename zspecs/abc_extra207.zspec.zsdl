       [],
       22,
       "abc.update_abstractmethods.__qualname__.__len__() == 22 — longer than get_cache_token (15) and abstractmethod (14); new to abc_extra207; verified Python 3.14.3"]
    - [abc_shortest_qualname,
       ABC.__qualname__.__len__,
       [],
       3,
       "abc.ABC.__qualname__.__len__() == 3 — 'ABC' has exactly 3 characters; shortest qualname of the five abc definitions; new to abc_extra207; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra207
# ---------------------------------------------------------------------------

invariant abc_extra207.ABCMeta.qualname_eq:
  description: "abc.ABCMeta.__qualname__.__eq__('ABCMeta') == True — ABCMeta is a top-level metaclass; its qualname equals its simple name because it is not nested inside any other class or function; new to abc_extra207; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: ABCMeta.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra207.ABC.qualname_eq:
  description: "abc.ABC.__qualname__.__eq__('ABC') == True — ABC is a top-level helper class that uses ABCMeta as its metaclass; its qualname equals its simple name; new to abc_extra207; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: ABC.__qualname__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra207.abstractmethod.qualname_eq:
  description: "abc.abstractmethod.__qualname__.__eq__('abstractmethod') == True — abstractmethod is a top-level decorator class; its qualname equals its simple name; new to abc_extra207; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
