  category: qualnames
  kind: python_call_eq
  function: get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra207.update_abstractmethods.qualname_len:
  description: "abc.update_abstractmethods.__qualname__.__len__() == 22 — 'update_abstractmethods' has exactly 22 characters; the longest qualname among the five abc definitions; new to abc_extra207; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
