spec: locale_extra4
version: ">=3.9"
backend: python_module(locale)

docs: https://docs.python.org/3/library/locale.html

provenance:
  derived_from:
    - "Python locale documentation — https://docs.python.org/3/library/locale.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/locale.py"
  notes:
    - "This spec extends locale.zspec.zsdl, locale_extra.zspec.zsdl, locale_extra2.zspec.zsdl, and locale_extra3.zspec.zsdl."
    - "locale.zspec.zsdl covers: LC_ALL/CTYPE/NUMERIC/TIME/COLLATE/MONETARY is_int; setlocale/getlocale/getpreferredencoding/format_string/atoi/atof __name__."
    - "locale_extra.zspec.zsdl covers: Error.__name__/__bases__; full func_names table (setlocale/getlocale/getdefaultlocale/getpreferredencoding/normalize/resetlocale/format_string/currency/str/atof/atoi); LC_ALL/COLLATE is_int."
    - "locale_extra2.zspec.zsdl covers: LC_MESSAGES is_int; LC_CTYPE/NUMERIC/TIME/MONETARY is_int; Error.__module__; normalize passthrough; currency __name__."
    - "locale_extra3.zspec.zsdl covers: func_modules table (setlocale/getlocale/normalize/format_string/atoi/atof/currency __module__); resetlocale/__module__; getpreferredencoding/__module__; LC_ALL ne LC_COLLATE; Error is_type; normalize('english') returns str; getdefaultlocale/__module__."
    - "This spec adds: __qualname__ checks for setlocale/getlocale/getdefaultlocale/getpreferredencoding/format_string/currency/str/atof/atoi; Error.__qualname__; CODESET is_int."
    - "Module-level functions have __qualname__ equal to their __name__."
    - "locale.str is a module-level function (locale-aware float formatter), not the built-in str type; __qualname__ == 'str'."
    - "locale.Error is defined at module level; __qualname__ == 'Error'."
    - "locale.CODESET is an integer constant (value is platform-specific) available on macOS and Linux."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "locale functions raise locale.Error (a subclass of Exception) when an unsupported locale is requested."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# __qualname__ checks for module-level functions
# Not covered in any prior locale spec.
# ---------------------------------------------------------------------------

table locale_extra4.func_qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [setlocale,           "setlocale.__qualname__.__eq__",           ["setlocale"],           true]
    - [getlocale,           "getlocale.__qualname__.__eq__",           ["getlocale"],           true]
    - [getdefaultlocale,    "getdefaultlocale.__qualname__.__eq__",    ["getdefaultlocale"],    true]
    - [getpreferredencoding,"getpreferredencoding.__qualname__.__eq__",["getpreferredencoding"],true]
    - [format_string,       "format_string.__qualname__.__eq__",       ["format_string"],       true]
    - [currency,            "currency.__qualname__.__eq__",            ["currency"],            true]
    - [locale_str,          "str.__qualname__.__eq__",                 ["str"],                 true]
    - [atof,                "atof.__qualname__.__eq__",                ["atof"],                true]
    - [atoi,                "atoi.__qualname__.__eq__",                ["atoi"],                true]

# ---------------------------------------------------------------------------
# Error.__qualname__ — class defined at module level
# Not covered in any prior locale spec.
# ---------------------------------------------------------------------------

invariant locale_extra4.Error.qualname:
  description: "locale.Error.__qualname__ == 'Error' — class defined at module level"
  category: classnames
  kind: python_call_eq
  function: "Error.__qualname__.__eq__"
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# CODESET — integer constant
# locale.CODESET is available on macOS and Linux; its value is platform-specific
# but it is always a plain int.
# locale.zspec.zsdl and locale_extra*.zspec.zsdl do not check CODESET.
# ---------------------------------------------------------------------------

invariant locale_extra4.CODESET.is_int:
  description: "locale.CODESET.__class__.__name__ == 'int' — CODESET is a plain int constant"
  category: constants
  kind: python_call_eq
  function: "CODESET.__class__.__name__.__eq__"
  args: ["int"]
  expected: true
