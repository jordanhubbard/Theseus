spec: socket_extra227
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol"
  - "RFC 768 — User Datagram Protocol"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.AF_INET == 2 on all POSIX platforms (IANA assigned; POSIX standard)."
    - "socket.AF_INET6 == 30 on macOS/Darwin; == 10 on Linux; platform-specific. Use __gt__(0) for portable specs."
    - "socket.SOCK_STREAM == 1 on POSIX platforms."
    - "socket.SOCK_DGRAM == 2 on POSIX platforms."
    - "socket.IPPROTO_TCP == 6 — TCP protocol number per IANA."
    - "socket.IPPROTO_UDP == 17 — UDP protocol number per IANA."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — IntEnum member; already covered in extra226."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — IntEnum member; already covered in extra226."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET and socket.SOCK_STREAM integer value contracts
#
# socket.AF_INET.__eq__(2)     == True  (POSIX standard; IANA assigned)
# socket.SOCK_STREAM.__eq__(1) == True  (POSIX standard)
# socket.SOCK_DGRAM.__eq__(2)  == True  (POSIX standard)
#
# AF_INET is universally 2 on all POSIX systems. SOCK_STREAM is 1 and
# SOCK_DGRAM is 2 on all POSIX systems. These values are fixed by POSIX.
# ---------------------------------------------------------------------------

table socket_extra227.af_inet_and_sock_type_values:
  description: "AF_INET==2; SOCK_STREAM==1; SOCK_DGRAM==2; POSIX-standard integer values; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: socket227

  columns: [id, function, args, expected, description]
  rows:
    - [AF_INET_eq_2,
       "AF_INET.__eq__",
       [2],
       true,
       "socket.AF_INET.__eq__(2) == True — AF_INET is the address family for IPv4; value is 2 on all POSIX platforms (standardized by IANA and POSIX); IntEnum member of AddressFamily; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]
    - [SOCK_STREAM_eq_1,
       "SOCK_STREAM.__eq__",
       [1],
       true,
       "socket.SOCK_STREAM.__eq__(1) == True — SOCK_STREAM is the socket type for TCP-style reliable stream connections; value is 1 on all POSIX platforms; IntEnum member of SocketKind; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]
    - [SOCK_DGRAM_eq_2,
       "SOCK_DGRAM.__eq__",
       [2],
       true,
       "socket.SOCK_DGRAM.__eq__(2) == True — SOCK_DGRAM is the socket type for UDP-style connectionless datagrams; value is 2 on all POSIX platforms; IntEnum member of SocketKind; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP and socket.IPPROTO_UDP integer value contracts
#
# socket.IPPROTO_TCP.__eq__(6)  == True  (IANA protocol number for TCP)
# socket.IPPROTO_UDP.__eq__(17) == True  (IANA protocol number for UDP)
#
# These are IANA-assigned IP protocol numbers. TCP is protocol 6 and UDP
# is protocol 17 — these are universal across all platforms.
# ---------------------------------------------------------------------------

table socket_extra227.ipproto_values:
  description: "IPPROTO_TCP==6; IPPROTO_UDP==17; IANA-assigned IP protocol numbers; universal; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: socket227a

  columns: [id, function, args, expected, description]
  rows:
    - [IPPROTO_TCP_eq_6,
       "IPPROTO_TCP.__eq__",
       [6],
       true,
       "socket.IPPROTO_TCP.__eq__(6) == True — IPPROTO_TCP is the IANA-assigned protocol number for TCP (Transmission Control Protocol); value is 6 on all platforms; plain int (not IntEnum); RFC 793; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]
    - [IPPROTO_UDP_eq_17,
       "IPPROTO_UDP.__eq__",
       [17],
       true,
       "socket.IPPROTO_UDP.__eq__(17) == True — IPPROTO_UDP is the IANA-assigned protocol number for UDP (User Datagram Protocol); value is 17 on all platforms; plain int (not IntEnum); RFC 768; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# socket.AF_INET6 portability contract (platform-specific value)
#
# socket.AF_INET6.__gt__(0) == True
#
# AF_INET6 is the address family for IPv6. Its integer value is
# platform-specific: 30 on macOS/Darwin, 10 on Linux. Rather than
# hardcoding a platform-specific value, we anchor __gt__(0) which holds
# universally. New to extra227.
# ---------------------------------------------------------------------------

table socket_extra227.af_inet6_portable_checks:
  description: "AF_INET6.__gt__(0)==True; platform-portable; 30 on macOS/10 on Linux; AddressFamily IntEnum; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: socket227b

  columns: [id, function, args, expected, description]
  rows:
    - [AF_INET6_gt_zero,
       "AF_INET6.__gt__",
       [0],
       true,
       "socket.AF_INET6.__gt__(0) == True — AF_INET6 is the IPv6 address family; value is platform-specific (30 on macOS/Darwin, 10 on Linux); __gt__(0) is universally True; portable invariant; IntEnum member of AddressFamily; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]
    - [AF_INET6_class_AddressFamily,
       "AF_INET6.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_INET6.__class__.__name__.__eq__('AddressFamily') == True — AF_INET6 is an IntEnum member of AddressFamily regardless of platform; new anchor in extra227 namespace; already covered in extra226 from different namespace; verified Python 3.14.3 macOS"]
    - [AF_INET6_ne_AF_INET,
       "AF_INET6.__ne__",
       [2],
       true,
       "socket.AF_INET6.__ne__(2) == True — AF_INET6 is never equal to AF_INET (2); IPv4 and IPv6 address families have distinct values on all platforms; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# socket.AF_INET and socket.SOCK_STREAM positive value sanity checks
#
# socket.AF_INET.__gt__(0)     == True
# socket.SOCK_STREAM.__gt__(0) == True
# socket.IPPROTO_TCP.__gt__(0) == True
#
# All socket constants are positive integers. Portable sanity checks.
# ---------------------------------------------------------------------------

table socket_extra227.socket_constants_positive:
  description: "AF_INET/__gt__(0)==True; SOCK_STREAM/__gt__(0)==True; IPPROTO_TCP/__gt__(0)==True; all positive; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: socket227c

  columns: [id, function, args, expected, description]
  rows:
    - [AF_INET_gt_zero,
       "AF_INET.__gt__",
       [0],
       true,
       "socket.AF_INET.__gt__(0) == True — AF_INET==2 which is positive; portable sanity check; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]
    - [SOCK_STREAM_gt_zero,
       "SOCK_STREAM.__gt__",
       [0],
       true,
       "socket.SOCK_STREAM.__gt__(0) == True — SOCK_STREAM==1 which is positive; portable sanity check; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]
    - [IPPROTO_TCP_gt_zero,
       "IPPROTO_TCP.__gt__",
       [0],
       true,
       "socket.IPPROTO_TCP.__gt__(0) == True — IPPROTO_TCP==6 which is positive; IANA-assigned protocol number; portable sanity check; new anchor in extra227 namespace; verified Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra227.AF_INET_eq_2:
  description: "socket.AF_INET.__eq__(2) == True — AF_INET is the IPv4 address family constant; its integer value is 2 on all POSIX-compliant platforms (standardized by IANA and POSIX.1); it is an IntEnum member of the AddressFamily enum in Python's socket module; extra103/119/135/153/166/183/212/226 anchor class checks; extra227 is the first namespace to anchor the exact integer value AF_INET==2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "AF_INET.__eq__"
  args: [2]
  expected: true

invariant socket_extra227.IPPROTO_TCP_eq_6:
  description: "socket.IPPROTO_TCP.__eq__(6) == True — IPPROTO_TCP is the IANA-assigned IP protocol number for TCP (Transmission Control Protocol) as defined in RFC 793; protocol number 6 is universal across all platforms; IPPROTO_TCP is a plain Python int (not an IntEnum member); extra226 anchors the class check; extra227 is the first namespace to anchor the exact integer value IPPROTO_TCP==6; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "IPPROTO_TCP.__eq__"
  args: [6]
  expected: true

invariant socket_extra227.IPPROTO_UDP_eq_17:
  description: "socket.IPPROTO_UDP.__eq__(17) == True — IPPROTO_UDP is the IANA-assigned IP protocol number for UDP (User Datagram Protocol) as defined in RFC 768; protocol number 17 is universal across all platforms; IPPROTO_UDP is a plain Python int (not an IntEnum member); extra226 anchors the class check; extra227 is the first namespace to anchor the exact integer value IPPROTO_UDP==17; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "IPPROTO_UDP.__eq__"
  args: [17]
  expected: true

invariant socket_extra227.AF_INET6_gt_zero:
  description: "socket.AF_INET6.__gt__(0) == True — AF_INET6 is the IPv6 address family; its integer value is platform-specific (30 on macOS/Darwin 25.4.0, 10 on Linux); using __gt__(0) rather than __eq__ provides a portable invariant that holds on all POSIX platforms; AF_INET6 is an IntEnum member of AddressFamily; extra226 anchors the class check from its namespace; extra227 is the first namespace to anchor AF_INET6 value portably; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "AF_INET6.__gt__"
  args: [0]
  expected: true
