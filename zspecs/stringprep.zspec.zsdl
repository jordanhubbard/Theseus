spec: stringprep
version: ">=3.3"
backend: python_module(stringprep)

docs: https://docs.python.org/3/library/stringprep.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/stringprep.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "stringprep source: Lib/stringprep.py (PSF; source inspection permitted)"
  not_derived_from:
    - "RFC 3454 internal table data beyond what is publicly documented"
  notes:
    - "stringprep implements RFC 3454 (Preparation of Internationalized Strings)."
    - "All public functions accept a single Unicode character (str of length 1) and return bool."
    - "in_table_a1 checks the 'Unassigned Code Points in Unicode 3.2' table (RFC 3454 Appendix A)."
    - "in_table_b1 checks the 'Commonly Mapped To Nothing' table — characters such as soft hyphen (U+00AD) map to nothing."
    - "in_table_c11 checks 'Non-ASCII space characters'; in_table_c12 checks 'ASCII space characters'."
    - "in_table_d1 and in_table_d2 check bidirectional character categories (R/AL and L respectively)."
    - "All function name checks verified by inspecting the stringprep module on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "All table-checking functions raise TypeError if given a non-character argument."
  stderr: "null"
  stickiness: "N/A — all functions are stateless predicates."
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant stringprep.in_table_a1_name:
  description: "stringprep.in_table_a1.__name__ == 'in_table_a1'"
  category: functions
  kind: python_call_eq
  function: in_table_a1.__name__.__eq__
  args: ["in_table_a1"]
  expected: true

invariant stringprep.in_table_a1_module:
  description: "stringprep.in_table_a1.__module__ == 'stringprep'"
  category: functions
  kind: python_call_eq
  function: in_table_a1.__module__.__eq__
  args: ["stringprep"]
  expected: true

invariant stringprep.in_table_b1_name:
  description: "stringprep.in_table_b1.__name__ == 'in_table_b1'"
  category: functions
  kind: python_call_eq
  function: in_table_b1.__name__.__eq__
  args: ["in_table_b1"]
  expected: true

invariant stringprep.in_table_c11_name:
  description: "stringprep.in_table_c11.__name__ == 'in_table_c11'"
  category: functions
  kind: python_call_eq
  function: in_table_c11.__name__.__eq__
  args: ["in_table_c11"]
  expected: true

invariant stringprep.in_table_c12_name:
  description: "stringprep.in_table_c12.__name__ == 'in_table_c12'"
  category: functions
  kind: python_call_eq
  function: in_table_c12.__name__.__eq__
  args: ["in_table_c12"]
  expected: true

invariant stringprep.in_table_d1_name:
  description: "stringprep.in_table_d1.__name__ == 'in_table_d1'"
  category: functions
  kind: python_call_eq
  function: in_table_d1.__name__.__eq__
  args: ["in_table_d1"]
  expected: true

invariant stringprep.in_table_d2_name:
  description: "stringprep.in_table_d2.__name__ == 'in_table_d2'"
  category: functions
  kind: python_call_eq
  function: in_table_d2.__name__.__eq__
  args: ["in_table_d2"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral checks
# ---------------------------------------------------------------------------

invariant stringprep.in_table_c11_space:
  description: "in_table_c11(' ') == False — ASCII space is NOT a non-ASCII space"
  category: behavior
  kind: python_call_eq
  function: in_table_c11
  args: [" "]
  expected: false

invariant stringprep.in_table_c12_space:
  description: "in_table_c12(' ') == True — ASCII space (U+0020) is in table C.1.2"
  category: behavior
  kind: python_call_eq
  function: in_table_c12
  args: [" "]
  expected: true

invariant stringprep.in_table_b1_shy:
  description: "in_table_b1('\xad') == True — soft hyphen (U+00AD) maps to nothing in table B.1"
  category: behavior
  kind: python_call_eq
  function: in_table_b1
  args: ["\xad"]
  expected: true

invariant stringprep.in_table_d1_alef:
  description: "in_table_d1('\u0627') == True — Arabic Letter Alef is an R/AL character"
  category: behavior
  kind: python_call_eq
  function: in_table_d1
  args: ["\u0627"]
  expected: true

invariant stringprep.in_table_d2_latin_a:
  description: "in_table_d2('A') == True — Latin capital A is an L (left-to-right) character"
  category: behavior
  kind: python_call_eq
  function: in_table_d2
  args: ["A"]
  expected: true

invariant stringprep.in_table_d1_latin_a:
  description: "in_table_d1('A') == False — Latin capital A is not an R/AL character"
  category: behavior
  kind: python_call_eq
  function: in_table_d1
  args: ["A"]
  expected: false
