spec: itertools_extra140
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.chain (C type), itertools.product (C type), itertools.combinations (C type), itertools.permutations (C type), itertools.combinations_with_replacement (C type) — doc string class, doc string len, __name__, __module__, __bases__, MRO (Wave 268)."
    - "All are C extension types defined in itertoolsmodule.c; their __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' (len 190). Verified with Python 3.14.3."
    - "itertools.product.__doc__.__class__.__name__ == 'str' (len 681). Verified with Python 3.14.3."
    - "itertools.combinations.__doc__.__class__.__name__ == 'str' (len 134). Verified with Python 3.14.3."
    - "itertools.permutations.__doc__.__class__.__name__ == 'str' (len 140). Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__doc__.__class__.__name__ == 'str' (len 234). Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' (len 29). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

