spec: modulefinder_extra3
version: ">=3.9"
backend: python_module(modulefinder)

docs: https://docs.python.org/3/library/modulefinder.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/modulefinder.html — Python modulefinder module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/modulefinder.py"
  notes:
    - "This spec extends modulefinder.zspec.zsdl, modulefinder_extra.zspec.zsdl, and modulefinder_extra2.zspec.zsdl."
    - "modulefinder (base) covers: ModuleFinder.__name__, Module.__name__, ModuleFinder.__module__, method names (run_script/report/any_missing/find_module/find_all_submodules), Module.__init__.__name__, behavioral any_missing()/instantiation."
    - "modulefinder_extra covers: ModuleFinder/__module__, Module/__module__, AddPackagePath/__name__/__module__/__class__, ReplacePackage/__name__/__module__/__class__, LOAD_FROM_PATH value/type, ModuleFinder/Module __class__.__name__=='type'."
    - "modulefinder_extra2 covers: ModuleFinder/__name__/__module__/__qualname__, Module/__name__/__module__/__qualname__, ModuleFinder/__bases__[0].__name__, Module/__bases__[0].__name__, LOAD_FROM_CACHE/__class__.__name__, LOAD_SOURCE/__class__.__name__."
    - "NEW in this spec: modulefinder.__name__ (module-level __name__ attribute), _PY_SOURCE and _C_EXTENSION integer constant values, ModuleFinder.__init__.__name__, ModuleFinder method __qualname__ checks (run_script/any_missing/report), AddPackagePath/__qualname__, ReplacePackage/__qualname__."
    - "modulefinder.__name__ == 'modulefinder' — the module's own __name__ attribute."
    - "modulefinder._PY_SOURCE == 1 — integer constant marking a plain Python source file (.py)."
    - "modulefinder._C_EXTENSION == 3 — integer constant marking a C extension module (.so/.pyd)."
    - "modulefinder.ModuleFinder.__init__.__name__ == '__init__' — constructor method name on the class."
    - "ModuleFinder method qualnames are prefixed with 'ModuleFinder.' since they are defined inside the class body."
    - "AddPackagePath and ReplacePackage are top-level functions, so their qualnames equal their names."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# module __name__ — modulefinder self-reports its own name.
# Not covered in any prior modulefinder spec.
# ---------------------------------------------------------------------------

invariant modulefinder_extra3.module.self_name:
  description: "modulefinder.__name__ == 'modulefinder' — the module's own __name__ attribute"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["modulefinder"]
  expected: true

# ---------------------------------------------------------------------------
# _PY_SOURCE and _C_EXTENSION — integer file-type constants.
# Not covered in any prior modulefinder spec.
# These are private but stable constants used internally by ModuleFinder to
# classify discovered modules.
# ---------------------------------------------------------------------------

invariant modulefinder_extra3._PY_SOURCE.is_int:
  description: "modulefinder._PY_SOURCE.__class__.__name__ == 'int' — _PY_SOURCE is an integer constant"
  category: constants
  kind: python_call_eq
  function: _PY_SOURCE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant modulefinder_extra3._PY_SOURCE.value:
  description: "modulefinder._PY_SOURCE == 1 — integer code marking a plain Python source file"
  category: constants
  kind: python_call_eq
  function: _PY_SOURCE.__eq__
  args: [1]
  expected: true

invariant modulefinder_extra3._C_EXTENSION.is_int:
  description: "modulefinder._C_EXTENSION.__class__.__name__ == 'int' — _C_EXTENSION is an integer constant"
  category: constants
  kind: python_call_eq
  function: _C_EXTENSION.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant modulefinder_extra3._C_EXTENSION.value:
  description: "modulefinder._C_EXTENSION == 3 — integer code marking a C extension module"
  category: constants
  kind: python_call_eq
  function: _C_EXTENSION.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# ModuleFinder.__init__.__name__ — constructor method name.
# modulefinder (base) covers Module.__init__.__name__; ModuleFinder.__init__ is new.
# Not covered in any prior modulefinder spec.
# ---------------------------------------------------------------------------

invariant modulefinder_extra3.ModuleFinder.init_name:
  description: "modulefinder.ModuleFinder.__init__.__name__ == '__init__'"
  category: method_names
  kind: python_call_eq
  function: ModuleFinder.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# ModuleFinder method __qualname__ checks.
# All ModuleFinder methods are defined inside the class body, so their
# qualnames are prefixed: 'ModuleFinder.run_script', etc.
# Prior specs covered __name__; __qualname__ is new here.
# Not covered in any prior modulefinder spec.
# ---------------------------------------------------------------------------

table modulefinder_extra3.ModuleFinder.method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqname

  columns: [id, function, args, expected]
  rows:
    - [run_script,  ModuleFinder.run_script.__qualname__.__eq__,  ["ModuleFinder.run_script"],  true]
    - [any_missing, ModuleFinder.any_missing.__qualname__.__eq__, ["ModuleFinder.any_missing"], true]
    - [report,      ModuleFinder.report.__qualname__.__eq__,      ["ModuleFinder.report"],      true]

# ---------------------------------------------------------------------------
# AddPackagePath and ReplacePackage __qualname__.
# These are top-level functions so their qualnames equal their names.
# Prior specs cover __name__ and __module__; __qualname__ is new here.
# Not covered in any prior modulefinder spec.
# ---------------------------------------------------------------------------

invariant modulefinder_extra3.AddPackagePath.qualname:
  description: "modulefinder.AddPackagePath.__qualname__ == 'AddPackagePath' — top-level function qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: AddPackagePath.__qualname__.__eq__
  args: ["AddPackagePath"]
  expected: true

invariant modulefinder_extra3.ReplacePackage.qualname:
  description: "modulefinder.ReplacePackage.__qualname__ == 'ReplacePackage' — top-level function qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: ReplacePackage.__qualname__.__eq__
  args: ["ReplacePackage"]
  expected: true
