spec: io_extra265
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "io.FileIO.__name__ == 'FileIO' and __module__ == '_io' (C implementation lives in _io)."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — the C-level base class name."
    - "Method qualnames for FileIO: read/write/seek/tell/readall/close all use 'FileIO.' prefix."
    - "io.FileIO.read.__class__.__name__ == 'method_descriptor' — C-implemented method descriptor type."
    - "io.RawIOBase.__name__ == 'RawIOBase', __module__ == 'io', bases[0].__name__ == '_RawIOBase'."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase', __module__ == 'io', bases[0].__name__ == '_BufferedIOBase'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FileIO — class identity
# ---------------------------------------------------------------------------

invariant io_extra265.FileIO.class_name:
  description: "io.FileIO.__name__ == 'FileIO'"
  category: class_metadata
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra265.FileIO.module:
  description: "io.FileIO.__module__ == '_io' — FileIO is implemented in the _io C extension"
  category: class_metadata
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra265.FileIO.base:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: FileIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_RawIOBase"

# ---------------------------------------------------------------------------
# FileIO — method qualnames
# ---------------------------------------------------------------------------

table io_extra265.FileIO.method_qualnames:
  description: "io.FileIO method __qualname__ attributes confirm fully-qualified names"
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [read,    FileIO.read.__qualname__.__eq__,    ["FileIO.read"],    true]
    - [write,   FileIO.write.__qualname__.__eq__,   ["FileIO.write"],   true]
    - [seek,    FileIO.seek.__qualname__.__eq__,    ["FileIO.seek"],    true]
    - [tell,    FileIO.tell.__qualname__.__eq__,    ["FileIO.tell"],    true]
    - [readall, FileIO.readall.__qualname__.__eq__, ["FileIO.readall"], true]
    - [close,   FileIO.close.__qualname__.__eq__,   ["FileIO.close"],   true]

# ---------------------------------------------------------------------------
# FileIO.read — descriptor class name
# ---------------------------------------------------------------------------

invariant io_extra265.FileIO.read.class_name:
  description: "io.FileIO.read.__class__.__name__ == 'method_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: FileIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# RawIOBase — class identity
# ---------------------------------------------------------------------------

invariant io_extra265.RawIOBase.class_name:
  description: "io.RawIOBase.__name__ == 'RawIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra265.RawIOBase.module:
  description: "io.RawIOBase.__module__ == 'io'"
  category: class_metadata
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra265.RawIOBase.base:
  description: "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: RawIOBase.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_RawIOBase"

# ---------------------------------------------------------------------------
# BufferedIOBase — class identity
# ---------------------------------------------------------------------------

invariant io_extra265.BufferedIOBase.class_name:
  description: "io.BufferedIOBase.__name__ == 'BufferedIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: BufferedIOBase.__name__.__eq__
  args: ["BufferedIOBase"]
  expected: true

invariant io_extra265.BufferedIOBase.module:
  description: "io.BufferedIOBase.__module__ == 'io'"
  category: class_metadata
  kind: python_call_eq
  function: BufferedIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra265.BufferedIOBase.base:
  description: "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: BufferedIOBase.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_BufferedIOBase"
