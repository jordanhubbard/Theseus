spec: inflected
version: ">=2.1.0"
backend: node(inflected)

docs: https://github.com/martinandert/inflected#readme

provenance:
  derived_from:
    - "inflected README — https://github.com/martinandert/inflected#readme"
    - "Rails ActiveSupport::Inflector — semantic basis for these transformations"
    - "Test vectors verified with inflected via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "inflected source"
  notes:
    - "Port of Rails inflector helpers — pluralize / singularize / camelize / underscore / humanize / titleize / etc."
    - "Install: npm install inflected"
    - "v2 CJS; named exports for each helper."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant inflected.has_pluralize:
  description: "pluralize() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "pluralize.constructor.name"}
  expected: "Function"

invariant inflected.pluralize_cat:
  description: "pluralize('cat') is 'cats'"
  category: pluralize
  kind: node_chain_eq
  entry: named
  function: pluralize
  entry_args: ["cat"]
  chain: []
  expected: "cats"

invariant inflected.singularize_dogs:
  description: "singularize('dogs') is 'dog'"
  category: singularize
  kind: node_chain_eq
  entry: named
  function: singularize
  entry_args: ["dogs"]
  chain: []
  expected: "dog"

invariant inflected.pluralize_irregular:
  description: "pluralize('person') is 'people' (irregular)"
  category: pluralize
  kind: node_chain_eq
  entry: named
  function: pluralize
  entry_args: ["person"]
  chain: []
  expected: "people"

invariant inflected.camelize:
  description: "camelize('user_name') is 'UserName'"
  category: case
  kind: node_chain_eq
  entry: named
  function: camelize
  entry_args: ["user_name"]
  chain: []
  expected: "UserName"

invariant inflected.camelize_lower_first:
  description: "camelize('user_name', false) returns lowerCamelCase 'userName'"
  category: case
  kind: node_chain_eq
  entry: named
  function: camelize
  entry_args: ["user_name", false]
  chain: []
  expected: "userName"

invariant inflected.underscore:
  description: "underscore('UserName') is 'user_name'"
  category: case
  kind: node_chain_eq
  entry: named
  function: underscore
  entry_args: ["UserName"]
  chain: []
  expected: "user_name"

invariant inflected.humanize:
  description: "humanize('user_name') is 'User name'"
  category: case
  kind: node_chain_eq
  entry: named
  function: humanize
  entry_args: ["user_name"]
  chain: []
  expected: "User name"

invariant inflected.dasherize:
  description: "dasherize('user_name') replaces underscores with dashes"
  category: case
  kind: node_chain_eq
  entry: named
  function: dasherize
  entry_args: ["user_name"]
  chain: []
  expected: "user-name"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:16:16Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
