spec: theseus_hashlib
version: ">=3.9"
backend: python_cleanroom(theseus_hashlib)
blocks: hashlib

docs: https://en.wikipedia.org/wiki/SHA-2

provenance:
  derived_from:
    - "https://nvlpubs.nist.gov/nistpubs/FIPS/NIST.FIPS.180-4.pdf — SHA-2 FIPS standard"
  notes:
    - "Clean-room SHA-256 hash implementation. Do NOT import hashlib, hmac, or _hashlib."
    - "Implement SHA-256 from the FIPS 180-4 specification using only built-in int/bytes ops."
    - "sha256(b'') == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855'."
    - "sha256(b'abc') == 'ba7816bf8f01cfea414140de5dae2ec73b00361bbef0469348423f656b162025'."
    - "Return hex digest string (64 lowercase hex chars)."
    - "Export: sha256(data: bytes) -> str."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_hashlib.sha256_empty:
  description: "sha256(b'') == 'e3b0c44...'"
  category: hash
  kind: python_call_eq
  function: sha256_empty
  args: []
  expected: "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"

invariant theseus_hashlib.sha256_abc:
  description: "sha256(b'abc') == 'ba7816bf...'"
  category: hash
  kind: python_call_eq
  function: sha256_abc
  args: []
  expected: "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"

invariant theseus_hashlib.sha256_length:
  description: "sha256 hex digest is always 64 characters"
  category: format
  kind: python_call_eq
  function: sha256_digest_length
  args: []
  expected: 64
