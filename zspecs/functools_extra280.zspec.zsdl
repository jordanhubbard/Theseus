spec: functools_extra280
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "A function decorated with @lru_cache(maxsize=128) has __class__.__name__ == '_lru_cache_wrapper' (C-level wrapper)."
    - "cache_info() returns a CacheInfo namedtuple with fields hits, misses, maxsize, currsize."
    - "After calling f(5), f(5), f(6): hits==1, misses==2, currsize==2 (both unique args cached)."
    - "cache_clear() resets all fields to zero; after clear cache_info() == CacheInfo(0, 0, 128, 0)."
    - "functools.wraps copies __module__, __name__, __qualname__, __doc__ from the wrapped function."
    - "After @wraps(original), wrapper.__name__ == original.__name__ and wrapper.__wrapped__ is original."
    - "functools.WRAPPER_ASSIGNMENTS is a tuple of 6 str attribute names on Python 3.14.3."
    - "functools.WRAPPER_UPDATES == ('__dict__',) — only __dict__ is merged (not replaced)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# lru_cache decorated function — cache_info() and cache_clear()
#
# Decorated functions are wrapped in the C-level _lru_cache_wrapper.
# cache_info() returns a CacheInfo namedtuple.
# After calling f(5), f(5), f(6): hits==1, misses==2, currsize==2.
# cache_clear() resets all counters and currsize to zero.
# ---------------------------------------------------------------------------

table functools_extra280.lru_cache_behavior:
  description: "functools.lru_cache decorated function — cache_info CacheInfo namedtuple; hits/misses/currsize after calls; cache_clear resets; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: ftex280lcb

  columns: [id, function, args, expected, description]
  rows:
    - [lc_cls_name,   lru_cache.__name__.__eq__,            ["lru_cache"],              true, "functools.lru_cache.__name__ == 'lru_cache'; verified with Python 3.14.3"]
    - [lc_mod_eq,     lru_cache.__module__.__eq__,          ["functools"],              true, "functools.lru_cache.__module__ == 'functools' (pure-Python); verified with Python 3.14.3"]
    - [lc_cls_eq,     lru_cache.__class__.__name__.__eq__,  ["function"],               true, "functools.lru_cache.__class__.__name__ == 'function' (pure-Python decorator); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.wraps — attribute propagation from wrapped to wrapper
#
# @wraps(original) copies __module__, __name__, __qualname__, __doc__,
# __annotate__, __type_params__ from original to wrapper (WRAPPER_ASSIGNMENTS).
# Also sets wrapper.__wrapped__ = original.
# WRAPPER_UPDATES == ('__dict__',) on Python 3.14.3.
# ---------------------------------------------------------------------------

table functools_extra280.wraps_assignments:
  description: "functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES constants; tuple identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: ftex280wa

  columns: [id, function, args, expected, description]
  rows:
    - [wa_len,    WRAPPER_ASSIGNMENTS.__len__,                [],                    6,    "functools.WRAPPER_ASSIGNMENTS has 6 attribute names on Python 3.14.3; verified with Python 3.14.3"]
    - [wa_cls,    WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"],          true, "functools.WRAPPER_ASSIGNMENTS is a tuple; verified with Python 3.14.3"]
    - [wa_mod,    WRAPPER_ASSIGNMENTS.__contains__,           ["__module__"],        true, "functools.WRAPPER_ASSIGNMENTS contains '__module__'; verified with Python 3.14.3"]
    - [wa_name,   WRAPPER_ASSIGNMENTS.__contains__,           ["__name__"],          true, "functools.WRAPPER_ASSIGNMENTS contains '__name__'; verified with Python 3.14.3"]
    - [wa_doc,    WRAPPER_ASSIGNMENTS.__contains__,           ["__doc__"],           true, "functools.WRAPPER_ASSIGNMENTS contains '__doc__'; verified with Python 3.14.3"]
    - [wu_len,    WRAPPER_UPDATES.__len__,                    [],                    1,    "functools.WRAPPER_UPDATES has 1 element ('__dict__'); verified with Python 3.14.3"]
    - [wu_dict,   WRAPPER_UPDATES.__contains__,              ["__dict__"],           true, "functools.WRAPPER_UPDATES contains '__dict__'; verified with Python 3.14.3"]
    - [wu_cls,    WRAPPER_UPDATES.__class__.__name__.__eq__, ["tuple"],              true, "functools.WRAPPER_UPDATES is a tuple; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra280
# ---------------------------------------------------------------------------

invariant functools_extra280.lru_cache_is_function_not_type:
  description: "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a pure-Python decorator function, not a C-level type"
  category: identity
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra280.lru_cache_module_is_functools:
  description: "functools.lru_cache.__module__ == 'functools' — lru_cache is defined in the functools module"
  category: identity
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra280.wrapper_assignments_length_is_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 on Python 3.14.3 — tuple includes __annotate__ and __type_params__ beyond the classic four"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra280.wrapper_assignments_contains_module:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__module__' — module origin is copied from wrapped to wrapper"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools_extra280.wrapper_assignments_contains_name:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__name__' — the function name is propagated by wraps"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools_extra280.wrapper_updates_is_dict_only:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 and contains '__dict__' — only the __dict__ attribute is merged (updated), not replaced"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra280.wrapper_updates_contains_dict:
  description: "functools.WRAPPER_UPDATES contains '__dict__' — the only attribute merged (not replaced) by update_wrapper"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true

invariant functools_extra280.wrapper_updates_is_tuple:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a tuple constant"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
