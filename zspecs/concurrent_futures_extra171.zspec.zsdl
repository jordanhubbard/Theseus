spec: concurrent_futures_extra171
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec covers: concurrent.futures.Future.__dict__.__class__.__name__=='mappingproxy' (the class dict is a read-only mappingproxy); concurrent.futures.Future.__init__.__code__.co_argcount==1 (only self — no timeout or other parameters in __init__); concurrent.futures.Future.result.__code__.co_argcount==2 (self + timeout — result takes an optional timeout); concurrent.futures.Future.cancel.__code__.co_argcount==1 (only self — cancel takes no parameters other than self); concurrent.futures._base.Future.__qualname__=='Future' (qualname equals name — not a nested class). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Future.__dict__.__class__.__name__=='mappingproxy': class __dict__ is always a mappingproxy in Python — a read-only view of the class's namespace preventing direct mutation. Verified with Python 3.14.3."
    - "Future.__init__.__code__.co_argcount==1: __init__ takes only self; the Future is initialized with no arguments (no executor, no loop reference). co_argcount counts positional arguments including self but not *args/**kwargs. Verified with Python 3.14.3."
    - "Future.result.__code__.co_argcount==2: result(self, timeout=None) — takes self and an optional timeout positional parameter. co_argcount==2 (self + timeout). Verified with Python 3.14.3."
    - "Future.cancel.__code__.co_argcount==1: cancel(self) — takes only self. Returns True if cancellation was successful, False otherwise. Verified with Python 3.14.3."
    - "concurrent.futures._base.Future.__qualname__=='Future': qualname=='Future' (not 'SomeOuter.Future') confirms Future is a top-level class definition, not nested inside another class. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future class dict and qualname — extra171
#
# concurrent.futures.Future.__dict__.__class__.__name__ == 'mappingproxy'
# concurrent.futures._base.Future.__qualname__ == 'Future'
# ---------------------------------------------------------------------------

table concurrent_futures_extra171.cf_future_dict_and_qualname:
  description: "concurrent.futures.Future class dict type and qualname checks in cffutdetail171dict namespace — concurrent.futures.Future.__dict__.__class__.__name__.__eq__('mappingproxy')==True (every Python class __dict__ is a mappingproxy — a read-only view of the class namespace; 'mappingproxy'=12: 'mapping'=7+'proxy'=5=12; direct assignment to Future.__dict__['key']=value raises TypeError; use type.__setattr__(Future, 'key', value) to add attributes programmatically); concurrent.futures.Future.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'=12); concurrent.futures._base.Future.__qualname__.__eq__('Future')==True (qualname equals name for top-level classes; 'Future'=6; __qualname__ would be 'OuterClass.Future' if Future were nested inside another class — the fact that __qualname__=='Future'=='__name__' confirms Future is a module-level class definition in concurrent.futures._base); concurrent.futures.Future.__name__.__eq__('Future')==True (name cross-check; 'Future'=6 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutdetail171dict

  columns: [id, function, args, expected, description]
  rows:
    - [fut_dict_cls_name,  concurrent.futures.Future.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],  true,  "Future.__dict__.__class__.__name__ == 'mappingproxy' (len=12; class dict is always read-only mappingproxy); verified with Python 3.14.3"]
    - [fut_dict_cls_len,   concurrent.futures.Future.__dict__.__class__.__name__.__len__, [],                12,    "Future.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12: 'mapping'=7+'proxy'=5=12); verified with Python 3.14.3"]
    - [fut_qualname_eq,    concurrent.futures._base.Future.__qualname__.__eq__,           ["Future"],        true,  "concurrent.futures._base.Future.__qualname__ == 'Future' (qualname==name; not a nested class); verified with Python 3.14.3"]
    - [fut_name_eq,        concurrent.futures.Future.__name__.__eq__,                     ["Future"],        true,  "Future.__name__ == 'Future' (len=6; cross-check with __qualname__); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future.__init__ code attributes — extra171
#
# concurrent.futures.Future.__init__.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table concurrent_futures_extra171.cf_future_init_code:
  description: "concurrent.futures.Future.__init__ code object attribute checks in cffutdetail171init namespace — concurrent.futures.Future.__init__.__code__.co_argcount.__eq__(1)==True (co_argcount==1 means __init__ takes exactly 1 positional argument: self; no other parameters; Future() is constructed with no arguments: future = concurrent.futures.Future(); co_argcount counts declared positional parameters including self but NOT *args or **kwargs; the Future is initialized internally by the executor, not by user code — executors create Futures via internal mechanisms); concurrent.futures.Future.__init__.__code__.co_argcount==1 (numeric check); concurrent.futures.Future.result.__code__.co_argcount==2 (cross-check: result(self, timeout=None) has 2 positional parameters — self and timeout — co_argcount==2); concurrent.futures.Future.cancel.__code__.co_argcount==1 (cross-check: cancel(self) has 1 positional parameter — only self); KEY DISTINCTION: co_argcount counts ALL declared positional args (including those with defaults like timeout=None); result has co_argcount==2 even though timeout is optional; cancel has co_argcount==1 (only self); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutdetail171init

  columns: [id, function, args, expected, description]
  rows:
    - [fut_init_argc,    concurrent.futures.Future.__init__.__code__.co_argcount.__eq__,    [1],  true,  "Future.__init__.__code__.co_argcount == 1 (only self; Future() takes no arguments); verified with Python 3.14.3"]
    - [fut_result_argc,  concurrent.futures.Future.result.__code__.co_argcount.__eq__,      [2],  true,  "Future.result.__code__.co_argcount == 2 (self + timeout; cross-check); verified with Python 3.14.3"]
    - [fut_cancel_argc,  concurrent.futures.Future.cancel.__code__.co_argcount.__eq__,      [1],  true,  "Future.cancel.__code__.co_argcount == 1 (only self; cross-check: cancel takes no extra params); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future method co_argcount values — extra171
#
# result.__code__.co_argcount == 2  (self, timeout)
# cancel.__code__.co_argcount == 1  (self)
# ---------------------------------------------------------------------------

table concurrent_futures_extra171.cf_future_method_argcounts:
  description: "concurrent.futures.Future method co_argcount values in cffutdetail171args namespace — concurrent.futures.Future.result.__code__.co_argcount==2 (result(self, timeout=None): 2 positional arguments — self and timeout; timeout defaults to None which means wait indefinitely; co_argcount==2 because both self and timeout are declared as positional parameters even though timeout has a default value; if timeout seconds elapse before the call completes, then a TimeoutError is raised); concurrent.futures.Future.cancel.__code__.co_argcount==1 (cancel(self): 1 positional argument — only self; Future.cancel() returns True if the Future can be cancelled (not yet running or completed), False otherwise; no parameters beyond self); concurrent.futures.Future.__init__.__code__.co_argcount==1 (cross-check: __init__ also takes only self); ARGCOUNT PATTERN: methods with no user-facing parameters have co_argcount==1 (cancel, __init__); methods with one user-facing parameter have co_argcount==2 (result with timeout); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutdetail171args

  columns: [id, function, args, expected, description]
  rows:
    - [result_argc,      concurrent.futures.Future.result.__code__.co_argcount.__eq__,      [2],  true,  "Future.result.__code__.co_argcount == 2 (self + timeout; result(self, timeout=None)); verified with Python 3.14.3"]
    - [cancel_argc,      concurrent.futures.Future.cancel.__code__.co_argcount.__eq__,      [1],  true,  "Future.cancel.__code__.co_argcount == 1 (only self; cancel takes no extra parameters); verified with Python 3.14.3"]
    - [init_argc_xchk,   concurrent.futures.Future.__init__.__code__.co_argcount.__eq__,   [1],  true,  "Future.__init__.__code__.co_argcount == 1 (cross-check; only self; no args for construction); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra171
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra171.cf_Future_dict_class_is_mappingproxy:
  description: "concurrent.futures.Future.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — concurrent.futures.Future.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); every Python class's __dict__ attribute is a mappingproxy — a read-only view of the class namespace; this is a fundamental Python implementation detail: you cannot assign to cls.__dict__['key'] = value (raises TypeError: 'mappingproxy' object does not support item assignment); to add class attributes you use setattr(cls, 'key', value) or type.__setattr__(cls, 'key', value); the mappingproxy wraps an underlying dict that Python manages internally; ALL class __dict__ attributes in Python have __class__.__name__=='mappingproxy': Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor, ABC, ABCMeta — all have the same mappingproxy type for their __dict__; 'mappingproxy'=12 is 2 chars longer than 'ModuleSpec'=10 (from abc_extra169); NEW in extra171: first standalone Future.__dict__.__class__.__name__ invariant in cffutdetail171dict namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant concurrent_futures_extra171.cf_Future_init_co_argcount:
  description: "concurrent.futures.Future.__init__.__code__.co_argcount.__eq__(1) returns True — concurrent.futures.Future.__init__.__code__.co_argcount==1; __init__ takes only self as a positional argument; Future() is constructed with no user-supplied arguments; the Future instance is created internally by executor implementations — ThreadPoolExecutor and ProcessPoolExecutor create Future objects internally when submit() is called; the Future is initialized in __init__ by setting internal state: _state='PENDING', _result=None, _exception=None, _done_callbacks=[] (using threading.Lock for thread safety); co_argcount==1 means the code object was compiled with exactly 1 positional parameter slot (self); COMPARISON: Future.result.__code__.co_argcount==2 (adds timeout parameter); Future.cancel.__code__.co_argcount==1 (same as __init__ — only self); NEW in extra171: first standalone Future.__init__.__code__.co_argcount invariant in cffutdetail171init namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__init__.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant concurrent_futures_extra171.cf_Future_result_co_argcount:
  description: "concurrent.futures.Future.result.__code__.co_argcount.__eq__(2) returns True — concurrent.futures.Future.result.__code__.co_argcount==2; result(self, timeout=None) has 2 positional parameters: self and timeout; co_argcount counts ALL declared positional parameters including those with default values (timeout defaults to None); calling future.result() with no arguments blocks indefinitely until the future completes; calling future.result(timeout=5.0) waits at most 5 seconds then raises TimeoutError; if the future was cancelled, result() raises CancelledError; if the future raised an exception, result() re-raises it; COMPARISON: Future.cancel.__code__.co_argcount==1 (only self — cancel takes no timeout) vs Future.result.__code__.co_argcount==2 (self + timeout); the difference reflects the design: you can set a timeout for waiting on a result but cancellation is always immediate; NEW in extra171: first standalone Future.result.__code__.co_argcount invariant in cffutdetail171args namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.result.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant concurrent_futures_extra171.cf_Future_cancel_co_argcount:
  description: "concurrent.futures.Future.cancel.__code__.co_argcount.__eq__(1) returns True — concurrent.futures.Future.cancel.__code__.co_argcount==1; cancel(self) takes only self; Future.cancel() attempts to cancel the call — if the call is currently being executed or finished running, it cannot be cancelled and will return False; if the call has not yet started, cancel() returns True and the Future is cancelled; co_argcount==1 matches Future.__init__.__code__.co_argcount==1 — both take only self; COMPARISON: result.__code__.co_argcount==2 (result has a timeout parameter) while cancel.__code__.co_argcount==1 (cancel has no extra parameters); the design is asymmetric — you can wait with a timeout for a result but cancellation is a synchronous, immediate operation with no timeout concept; NEW in extra171: first standalone Future.cancel.__code__.co_argcount invariant in cffutdetail171args namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.cancel.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant concurrent_futures_extra171.cf_base_Future_qualname_eq:
  description: "concurrent.futures._base.Future.__qualname__.__eq__('Future') returns True — concurrent.futures._base.Future.__qualname__=='Future' (len=6: 'Future'=6); __qualname__ is the qualified name that encodes a class's position in its enclosing namespace; for top-level class definitions, __qualname__==__name__ (both are 'Future'); if Future were a nested class inside e.g. class _FutureFactory, __qualname__ would be '_FutureFactory.Future'; the fact that __qualname__=='Future' (not 'SomeOuter.Future') confirms Future is a module-level class in concurrent.futures._base; COMPARISON: concurrent.futures.Future.__qualname__=='Future' (same; both point to the same class object via the re-export mechanism in concurrent/futures/__init__.py); ABC.__qualname__=='ABC' (from abc_extra168; also a top-level class with qualname==name); CONTRAST: a nested class would have e.g. __qualname__=='Outer.Inner'; 'Future'=6 chars in both __name__ and __qualname__; NEW in extra171: first standalone _base.Future.__qualname__ invariant in cffutdetail171dict namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.__qualname__.__eq__
  args: ["Future"]
  expected: true

