spec: asyncio_extra113
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra112.zspec.zsdl."
    - "This spec covers: wave 255 theme — asyncio.Event and asyncio.Semaphore class identity and method qualnames not covered in extra110 or extra111. NEW in extra113: asyncio.Event.__name__=='Event' (len=5); asyncio.Event.__qualname__=='Event' (len=5); asyncio.Event.__module__=='asyncio.locks' (len=13); asyncio.Event.__mro__.__len__()==3; asyncio.Event.is_set.__qualname__=='Event.is_set' (len=12, co_argcount=1, co_name=='is_set'); asyncio.Semaphore.__name__=='Semaphore' (len=9); asyncio.Semaphore.__qualname__=='Semaphore' (len=9); asyncio.Semaphore.__module__=='asyncio.locks' (len=13); asyncio.Semaphore.__init__.__qualname__=='Semaphore.__init__' (len=18, co_argcount=2: self and value); asyncio.Semaphore.locked.__qualname__=='Semaphore.locked' (len=16, co_argcount=1: self only, co_name=='locked'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Event.is_set.__qualname__ == 'Event.is_set' (len=12: 'Event.'=6+'is_set'=6=12). is_set() returns True if the internal flag is set, False otherwise (co_argcount=1: self only; type='function'). asyncio.Event.__module__ == 'asyncio.locks' (len=13). asyncio.Event.__mro__.__len__() == 3 ([Event, _LoopBoundMixin, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.__init__.__qualname__ == 'Semaphore.__init__' (len=18: 'Semaphore.'=10+'__init__'=8=18; co_argcount=2: self and value — value is the initial counter value, default=1). asyncio.Semaphore.locked.__qualname__ == 'Semaphore.locked' (len=16: 'Semaphore.'=10+'locked'=6=16; co_argcount=1: self only; returns True when the semaphore cannot be acquired immediately). asyncio.Semaphore.__mro__.__len__() == 4 ([Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Event class identity and is_set method — extra113
#
# Wave 255 theme: Event class identity attributes and is_set method qualname.
#
# asyncio.Event.__name__               == 'Event'          (len=5)
# asyncio.Event.__qualname__           == 'Event'          (len=5)
# asyncio.Event.__module__             == 'asyncio.locks'  (len=13)
# asyncio.Event.__mro__.__len__()      == 3
# asyncio.Event.is_set.__qualname__    == 'Event.is_set'   (len=12, co_argcount=1)
# ---------------------------------------------------------------------------

table asyncio_extra113.asyncio_event_identity_isset:
  description: "asyncio.Event class identity and is_set method checks in asyncioevt113 namespace — wave 255 theme: asyncio.Event.__name__.__eq__('Event')==True (len=5: 'Event'=5; top-level class in asyncio.locks); asyncio.Event.__name__.__len__()==5; asyncio.Event.__qualname__.__eq__('Event')==True (len=5; qualname equals name for a top-level class); asyncio.Event.__qualname__.__len__()==5; asyncio.Event.__module__.__eq__('asyncio.locks')==True (len=13: 'asyncio.locks'=13; Event is defined in the private locks submodule); asyncio.Event.__module__.__len__()==13; asyncio.Event.__mro__.__len__()==3 (MRO=[Event, _LoopBoundMixin, object]; 3-level chain: simpler than Semaphore MRO=4 which also includes _ContextManagerMixin); asyncio.Event.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True (Event does not support the async context manager protocol; compare: Semaphore.__bases__[0].__name__=='_ContextManagerMixin'); asyncio.Event.is_set.__qualname__.__eq__('Event.is_set')==True (len=12: 'Event.'=6+'is_set'=6=12; longest method qualname for Event in this spec — compare: Event.set=9 < Event.wait=10 < Event.clear=11 < Event.is_set=12); asyncio.Event.is_set.__qualname__.__len__()==12; asyncio.Event.is_set.__code__.co_name.__eq__('is_set')==True; asyncio.Event.is_set.__code__.co_argcount.__eq__(1)==True (self only); type(asyncio.Event.is_set).__name__.__eq__('function')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioevt113

  columns: [id, function, args, expected, description]
  rows:
    - [evt_name_eq,         asyncio.Event.__name__.__eq__,                                 ["Event"],              true, "Event.__name__ == 'Event' (len=5, top-level class in asyncio.locks); verified with Python 3.14.3"]
    - [evt_name_len,        asyncio.Event.__name__.__len__,                                [],                     5,    "Event.__name__.__len__() == 5 ('Event'=5); verified with Python 3.14.3"]
    - [evt_qn_eq,           asyncio.Event.__qualname__.__eq__,                             ["Event"],              true, "Event.__qualname__ == 'Event' (len=5, qualname equals name for top-level class); verified with Python 3.14.3"]
    - [evt_qn_len,          asyncio.Event.__qualname__.__len__,                            [],                     5,    "Event.__qualname__.__len__() == 5 ('Event'=5); verified with Python 3.14.3"]
    - [evt_module_eq,       asyncio.Event.__module__.__eq__,                               ["asyncio.locks"],      true, "Event.__module__ == 'asyncio.locks' (len=13); verified with Python 3.14.3"]
    - [evt_module_len,      asyncio.Event.__module__.__len__,                              [],                     13,   "Event.__module__.__len__() == 13 ('asyncio.locks'=13); verified with Python 3.14.3"]
    - [evt_mro_len,         asyncio.Event.__mro__.__len__,                                 [],                     3,    "Event.__mro__.__len__() == 3 ([Event, _LoopBoundMixin, object]); verified with Python 3.14.3"]
    - [evt_base_eq,         "asyncio.Event.__bases__[0].__name__.__eq__",                  ["_LoopBoundMixin"],    true, "Event.__bases__[0].__name__ == '_LoopBoundMixin' (MRO len=3, no ContextManagerMixin); verified with Python 3.14.3"]
    - [isset_qn_eq,         asyncio.Event.is_set.__qualname__.__eq__,                      ["Event.is_set"],       true, "Event.is_set.__qualname__ == 'Event.is_set' (len=12, longest Event method qualname in spec); verified with Python 3.14.3"]
    - [isset_qn_len,        asyncio.Event.is_set.__qualname__.__len__,                     [],                     12,   "Event.is_set.__qualname__.__len__() == 12 ('Event.is_set'=12); verified with Python 3.14.3"]
    - [isset_co_name_eq,    asyncio.Event.is_set.__code__.co_name.__eq__,                  ["is_set"],             true, "Event.is_set.__code__.co_name == 'is_set' (code object name matches function name); verified with Python 3.14.3"]
    - [isset_argc,          asyncio.Event.is_set.__code__.co_argcount.__eq__,              [1],                    true, "Event.is_set.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Semaphore class identity and __init__ method — extra113
#
# Wave 255 theme: Semaphore class identity attributes and __init__ qualname.
#
# asyncio.Semaphore.__name__              == 'Semaphore'          (len=9)
# asyncio.Semaphore.__qualname__          == 'Semaphore'          (len=9)
# asyncio.Semaphore.__module__            == 'asyncio.locks'      (len=13)
# asyncio.Semaphore.__mro__.__len__()     == 4
# asyncio.Semaphore.__init__.__qualname__ == 'Semaphore.__init__' (len=18, co_argcount=2)
# ---------------------------------------------------------------------------

table asyncio_extra113.asyncio_semaphore_identity_init:
  description: "asyncio.Semaphore class identity and __init__ method checks in asyncioevt113 namespace — wave 255 theme: asyncio.Semaphore.__name__.__eq__('Semaphore')==True (len=9: 'Semaphore'=9; top-level class in asyncio.locks); asyncio.Semaphore.__name__.__len__()==9; asyncio.Semaphore.__qualname__.__eq__('Semaphore')==True (len=9; qualname equals name for top-level class); asyncio.Semaphore.__qualname__.__len__()==9; asyncio.Semaphore.__module__.__eq__('asyncio.locks')==True (len=13; same module as Event — both in asyncio.locks); asyncio.Semaphore.__module__.__len__()==13; asyncio.Semaphore.__mro__.__len__()==4 (MRO=[Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; 4-level chain — deeper than Event=3 because Semaphore supports async context manager via _ContextManagerMixin); asyncio.Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (Semaphore supports 'async with' syntax; compare: Event.__bases__[0].__name__=='_LoopBoundMixin' — Event does not); asyncio.Semaphore.__init__.__qualname__.__eq__('Semaphore.__init__')==True (len=18: 'Semaphore.'=10+'__init__'=8=18; __init__ takes value parameter); asyncio.Semaphore.__init__.__qualname__.__len__()==18; asyncio.Semaphore.__init__.__code__.co_name.__eq__('__init__')==True; asyncio.Semaphore.__init__.__code__.co_argcount.__eq__(2)==True (self and value — value is the initial counter, default=1); type(asyncio.Semaphore.__init__).__name__.__eq__('function')==True; compare __init__ co_argcount: Semaphore=2 (self + value) vs Event.__init__ (inherits from _LoopBoundMixin); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioevt113a

  columns: [id, function, args, expected, description]
  rows:
    - [sema_name_eq,        asyncio.Semaphore.__name__.__eq__,                             ["Semaphore"],          true, "Semaphore.__name__ == 'Semaphore' (len=9); verified with Python 3.14.3"]
    - [sema_name_len,       asyncio.Semaphore.__name__.__len__,                            [],                     9,    "Semaphore.__name__.__len__() == 9 ('Semaphore'=9); verified with Python 3.14.3"]
    - [sema_qn_eq,          asyncio.Semaphore.__qualname__.__eq__,                         ["Semaphore"],          true, "Semaphore.__qualname__ == 'Semaphore' (len=9, qualname equals name); verified with Python 3.14.3"]
    - [sema_qn_len,         asyncio.Semaphore.__qualname__.__len__,                        [],                     9,    "Semaphore.__qualname__.__len__() == 9 ('Semaphore'=9); verified with Python 3.14.3"]
    - [sema_module_eq,      asyncio.Semaphore.__module__.__eq__,                           ["asyncio.locks"],      true, "Semaphore.__module__ == 'asyncio.locks' (len=13, same as Event); verified with Python 3.14.3"]
    - [sema_module_len,     asyncio.Semaphore.__module__.__len__,                          [],                     13,   "Semaphore.__module__.__len__() == 13 ('asyncio.locks'=13); verified with Python 3.14.3"]
    - [sema_mro_len,        asyncio.Semaphore.__mro__.__len__,                             [],                     4,    "Semaphore.__mro__.__len__() == 4 ([Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]); verified with Python 3.14.3"]
    - [sema_base_eq,        "asyncio.Semaphore.__bases__[0].__name__.__eq__",              ["_ContextManagerMixin"], true, "Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' (supports async with); verified with Python 3.14.3"]
    - [sema_init_qn_eq,     asyncio.Semaphore.__init__.__qualname__.__eq__,                ["Semaphore.__init__"], true, "Semaphore.__init__.__qualname__ == 'Semaphore.__init__' (len=18); verified with Python 3.14.3"]
    - [sema_init_qn_len,    asyncio.Semaphore.__init__.__qualname__.__len__,               [],                     18,   "Semaphore.__init__.__qualname__.__len__() == 18 ('Semaphore.__init__'=18); verified with Python 3.14.3"]
    - [sema_init_co_name,   asyncio.Semaphore.__init__.__code__.co_name.__eq__,            ["__init__"],           true, "Semaphore.__init__.__code__.co_name == '__init__'; verified with Python 3.14.3"]
    - [sema_init_argc,      asyncio.Semaphore.__init__.__code__.co_argcount.__eq__,        [2],                    true, "Semaphore.__init__.__code__.co_argcount == 2 (self and value); verified with Python 3.14.3"]

