# Event.__name__ len=5 < Semaphore.__name__ len=9
# Semaphore.__init__ qualname len=18 > Semaphore.locked qualname len=16
# ---------------------------------------------------------------------------

table asyncio_extra113.asyncio_semaphore_locked_comparisons:
  description: "asyncio.Semaphore.locked method code attributes and length comparisons in asyncioevt113 namespace — wave 255 theme: asyncio.Semaphore.locked.__qualname__.__eq__('Semaphore.locked')==True (len=16: 'Semaphore.'=10+'locked'=6=16; returns True when semaphore value is 0 and next acquire() would block); asyncio.Semaphore.locked.__qualname__.__len__()==16; asyncio.Semaphore.locked.__code__.co_name.__eq__('locked')==True (co_name matches function name); asyncio.Semaphore.locked.__code__.co_argcount.__eq__(1)==True (self only — locked() takes no args); type(asyncio.Semaphore.locked).__name__.__eq__('function')==True; compare qualname lengths in this spec: Event.is_set=12 < Semaphore.locked=16 < Semaphore.__init__=18 (qualname length order: is_set < locked < __init__); compare class name lengths: Event.__name__.__len__()==5 < Semaphore.__name__.__len__()==9 (Semaphore is 4 chars longer than Event); compare MRO lengths: Event.__mro__.__len__()==3 < Semaphore.__mro__.__len__()==4 (Semaphore has one extra mixin — _ContextManagerMixin — for async with support); Event.__module__.__len__()==Semaphore.__module__.__len__()==13 (both are in asyncio.locks, len=13); compare: Semaphore.locked (non-blocking predicate, co_argcount=1) vs Semaphore.acquire (async coroutine, co_argcount=1, from extra110 — both take only self but locked is synchronous while acquire is async); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: asyncioevt113b

  columns: [id, function, args, expected, description]
  rows:
    - [locked_qn_eq,        asyncio.Semaphore.locked.__qualname__.__eq__,                  ["Semaphore.locked"],   true, "Semaphore.locked.__qualname__ == 'Semaphore.locked' (len=16); verified with Python 3.14.3"]
    - [locked_qn_len,       asyncio.Semaphore.locked.__qualname__.__len__,                 [],                     16,   "Semaphore.locked.__qualname__.__len__() == 16 ('Semaphore.locked'=16); verified with Python 3.14.3"]
    - [locked_co_name,      asyncio.Semaphore.locked.__code__.co_name.__eq__,              ["locked"],             true, "Semaphore.locked.__code__.co_name == 'locked' (code object name matches function); verified with Python 3.14.3"]
    - [locked_argc,         asyncio.Semaphore.locked.__code__.co_argcount.__eq__,          [1],                    true, "Semaphore.locked.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [locked_type_eq,      type(asyncio.Semaphore.locked).__name__.__eq__,                ["function"],           true, "type(Semaphore.locked).__name__ == 'function' (synchronous, not a coroutine); verified with Python 3.14.3"]
    - [evt_name_lt_sema,    asyncio.Event.__name__.__len__,                                [],                     5,    "Event.__name__ len=5 < Semaphore.__name__ len=9 (Semaphore name is longer); verified with Python 3.14.3"]
    - [sema_name_gt_evt,    asyncio.Semaphore.__name__.__len__,                            [],                     9,    "Semaphore.__name__ len=9 > Event.__name__ len=5; verified with Python 3.14.3"]
    - [evt_mro_lt_sema,     asyncio.Event.__mro__.__len__,                                 [],                     3,    "Event.__mro__ len=3 < Semaphore.__mro__ len=4 (Semaphore has extra _ContextManagerMixin); verified with Python 3.14.3"]
    - [sema_module_len_13,  asyncio.Semaphore.__module__.__len__,                          [],                     13,   "Semaphore.__module__ len=13 equals Event.__module__ len=13 (both in asyncio.locks); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra113
# ---------------------------------------------------------------------------

invariant asyncio_extra113.Event_is_set_qualname_len_12:
  description: "asyncio.Event.is_set.__qualname__.__len__() == 12 — 'Event.is_set' = 'Event.'=6 + 'is_set'=6 = 12; this is the longest Event method qualname in this spec; compare Event method qualname lengths (from extra110 and extra113): Event.set=9 (shortest) < Event.wait=10 < Event.clear=11 < Event.is_set=12 (longest); asyncio.Event.is_set.__code__.co_argcount==1 (self only — is_set() returns bool without taking any argument beyond self); asyncio.Event.is_set.__code__.co_name=='is_set'; type(asyncio.Event.is_set).__name__=='function' (Python-defined, synchronous — unlike Event.wait which is an async coroutine); asyncio.Event.__module__=='asyncio.locks' (len=13); asyncio.Event.__mro__.__len__()==3; asyncio.Event.__name__.__len__()==5; NEW in extra113: first standalone Event.is_set qualname length invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Event.is_set.__qualname__.__len__
  args: []
  expected: 12

invariant asyncio_extra113.Event_module_len_13:
  description: "asyncio.Event.__module__.__len__() == 13 — 'asyncio.locks'=13 chars; asyncio.Event.__module__.__eq__('asyncio.locks')==True; the module name 'asyncio.locks' contains 'asyncio.'=8+'locks'=5=13; both asyncio.Event and asyncio.Semaphore share the same module 'asyncio.locks' (both len=13); compare: asyncio.Event.__mro__.__len__()==3 vs asyncio.Semaphore.__mro__.__len__()==4 — they differ in MRO depth even though they share the same module; asyncio.Event.__name__.__len__()==5 (shorter than Semaphore.__name__.__len__()==9); asyncio.Event.__bases__[0].__name__=='_LoopBoundMixin' (no context manager support); asyncio.Event.is_set.__qualname__.__len__()==12; NEW in extra113: first standalone Event.__module__ length invariant; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.__module__.__len__
  args: []
  expected: 13

invariant asyncio_extra113.Semaphore_init_qualname_len_18:
  description: "asyncio.Semaphore.__init__.__qualname__.__len__() == 18 — 'Semaphore.__init__' = 'Semaphore.'=10 + '__init__'=8 = 18; asyncio.Semaphore.__init__.__qualname__.__eq__('Semaphore.__init__')==True; asyncio.Semaphore.__init__.__code__.co_argcount==2 (self and value — value is the initial counter value for the semaphore, default=1; a semaphore with value=0 starts fully locked); asyncio.Semaphore.__init__.__code__.co_name=='__init__'; type(asyncio.Semaphore.__init__).__name__=='function' (Python-defined initializer); compare __init__ qualname lengths: Semaphore.__init__=18 > Semaphore.locked=16 > Event.is_set=12 in this spec; asyncio.Semaphore.__module__=='asyncio.locks' (len=13); asyncio.Semaphore.__mro__.__len__()==4; asyncio.Semaphore.__name__.__len__()==9; NEW in extra113: first standalone Semaphore.__init__ qualname length invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Semaphore.__init__.__qualname__.__len__
  args: []
  expected: 18

invariant asyncio_extra113.Semaphore_mro_len_4:
  description: "asyncio.Semaphore.__mro__.__len__() == 4 — Semaphore MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=4); asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (Semaphore supports 'async with' syntax via this mixin); compare MRO lengths in asyncio.locks classes: Event.__mro__.__len__()==3 (shorter — Event lacks _ContextManagerMixin) < Semaphore.__mro__.__len__()==4 (has _ContextManagerMixin) < BoundedSemaphore.__mro__.__len__()==5 (from extra110 — has Semaphore + _ContextManagerMixin + _LoopBoundMixin + object); asyncio.Semaphore.__module__=='asyncio.locks' (len=13); asyncio.Semaphore.__name__=='Semaphore' (len=9); asyncio.Semaphore.__qualname__=='Semaphore' (len=9); asyncio.Semaphore.__init__.__code__.co_argcount==2 (self and value); Semaphore.locked.__code__.co_argcount==1 (self only); NEW in extra113: first standalone Semaphore MRO length invariant; wave 255; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: asyncio.Semaphore.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra113.Semaphore_locked_co_name_eq:
  description: "asyncio.Semaphore.locked.__code__.co_name.__eq__('locked') returns True — the code object's co_name matches the function name 'locked'; asyncio.Semaphore.locked.__code__.co_argcount==1 (self only); asyncio.Semaphore.locked.__qualname__=='Semaphore.locked' (len=16); type(asyncio.Semaphore.locked).__name__=='function' (synchronous function — locked() is not a coroutine; it simply checks whether the semaphore's internal counter is zero); compare: Semaphore.locked (synchronous, co_argcount=1) vs Semaphore.acquire (async coroutine, co_argcount=1 from extra110) — both take only self but locked() returns immediately while acquire() may suspend; asyncio.Semaphore.__mro__.__len__()==4; asyncio.Semaphore.__module__=='asyncio.locks' (len=13); asyncio.Semaphore.__name__.__len__()==9; asyncio.Semaphore.locked.__qualname__.__len__()==16; NEW in extra113: first standalone Semaphore.locked co_name invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Semaphore.locked.__code__.co_name.__eq__
  args: ["locked"]
  expected: true

