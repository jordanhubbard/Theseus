spec: itertools_extra721
version: ">=3.9"
backend: python_module(itertools)
docs: "Behavioral specs for itertools zip_longest, compress, filterfalse, dropwhile, and infinite iterators"
error_model: python_exceptions
provenance:
  derived_from: "python stdlib itertools module"
  not_derived_from: "any third-party library"
  notes: "Covers itertools iterator class qualname/module identity for zip_longest, compress, filterfalse, dropwhile, count, cycle, and repeat"
  created_at: "2026-04-12"

table itertools_extra721.finite_iterators:
  description: "Identity checks for itertools finite iterator classes"
  kind: python_call_eq
  category: identity
  id_prefix: it721fi
  columns: [id, function, args, expected]
  rows:
    - [it721fi001, itertools.zip_longest.__qualname__.__eq__, ["zip_longest"], true]
    - [it721fi002, itertools.zip_longest.__module__.__eq__, ["itertools"], true]
    - [it721fi003, itertools.zip_longest.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it721fi004, itertools.compress.__qualname__.__eq__, ["compress"], true]
    - [it721fi005, itertools.compress.__module__.__eq__, ["itertools"], true]
    - [it721fi006, itertools.filterfalse.__qualname__.__eq__, ["filterfalse"], true]
    - [it721fi007, itertools.filterfalse.__module__.__eq__, ["itertools"], true]
    - [it721fi008, itertools.dropwhile.__qualname__.__eq__, ["dropwhile"], true]
    - [it721fi009, itertools.dropwhile.__module__.__eq__, ["itertools"], true]

table itertools_extra721.infinite_iterators:
  description: "Identity checks for itertools infinite iterator classes"
  kind: python_call_eq
  category: identity
  id_prefix: it721ii
  columns: [id, function, args, expected]
  rows:
    - [it721ii001, itertools.count.__qualname__.__eq__, ["count"], true]
    - [it721ii002, itertools.cycle.__qualname__.__eq__, ["cycle"], true]
    - [it721ii003, itertools.repeat.__qualname__.__eq__, ["repeat"], true]
