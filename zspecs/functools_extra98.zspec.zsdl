spec: functools_extra98
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra97

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra97.zspec.zsdl."
    - "This spec covers: functools lru_cache and cached_property descriptor identity — lru_cache wrapped function attributes (cache_info, cache_clear, __wrapped__), lru_cache decorator factory code attrs, cached_property descriptor protocol attrs, and WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES (Wave 253)."
    - "A function decorated with @functools.lru_cache(maxsize=128) yields an instance of functools._lru_cache_wrapper; its __class__.__name__ is '_lru_cache_wrapper'. Verified with Python 3.14.3."
    - "The cache_info attribute of a lru_cache-wrapped function is a bound C method; __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "The cache_clear attribute of a lru_cache-wrapped function is a bound C method; __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_name == 'lru_cache' — the Python function's code object co_name equals its def name. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_argcount == 2 — lru_cache takes maxsize and typed keyword parameters. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (len 9) — simple unqualified name in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cached_property instance func attribute __class__.__name__ == 'function' — the wrapped callable stored in .func. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__ __class__.__name__ == 'function' — __set_name__ is a pure-Python method on the class. Verified with Python 3.14.3."
    - "functools.cached_property instance attrname __class__.__name__ == 'str' — after __set_name__ is called by the class body, attrname is a str. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' (len 6). Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' (len 1). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: lru_cache wrapped function attributes
#
# Wave 253 theme: attributes of a function decorated with @lru_cache.
#
# A decorated function's __class__.__name__ == '_lru_cache_wrapper'
# cache_info.__class__.__name__ == 'builtin_function_or_method'
# cache_clear.__class__.__name__ == 'builtin_function_or_method'
#
# @lru_cache produces a _lru_cache_wrapper C extension object.
# cache_info and cache_clear are bound C methods on that wrapper.
# New to extra98.
# ---------------------------------------------------------------------------

table functools_extra98.lru_cache_fn_attrs:
  description: "lru_cache-decorated function class name and cache_info/cache_clear class names; C wrapper type; wave 253; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolslrucached98

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_wrapper_class_name_eq,
       "lru_cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is the pure-Python decorator factory defined in Lib/functools.py; it is a plain Python function so __class__.__name__ is 'function'; str.__eq__('function') returns True; prior spec extra97 also verified this; new context is decorator factory code attrs in extra98; new to extra98"]
    - [lru_cache_cache_info_class_name,
       "lru_cache.__code__.co_name.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — co_name is the name from the def statement in Lib/functools.py; str.__eq__('lru_cache') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Table 2: lru_cache decorator factory code attributes
#
# Wave 253 theme: __code__ attributes of functools.lru_cache itself.
#
# functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True
# functools.lru_cache.__code__.co_argcount.__eq__(2) == True
# functools.lru_cache.__qualname__.__len__().__eq__(9) == True
#
# lru_cache takes maxsize and typed; co_argcount is 2. qualname 'lru_cache' has length 9.
# New to extra98.
# ---------------------------------------------------------------------------

table functools_extra98.lru_cache_code_attrs:
  description: "functools.lru_cache __code__.co_name, co_argcount, and __qualname__.__len__(); wave 253; new to extra98"
  kind: python_call_eq
  category: integer_identity
  id_prefix: functoolslrucached98

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_co_argcount_eq_2,
       "lru_cache.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache takes maxsize and typed as positional-or-keyword parameters; co_argcount counts those; co_argcount is 2; int.__eq__(2) returns True; new to extra98"]
    - [lru_cache_qualname_len_eq_9,
       "lru_cache.__qualname__.__len__",
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — __qualname__ is 'lru_cache' (9 characters); lru_cache is defined at module scope in Lib/functools.py so its qualname is its simple def name; len('lru_cache') == 9; new to extra98"]

# ---------------------------------------------------------------------------
# Table 3: cached_property descriptor attrs
#
# Wave 253 theme: functools.cached_property descriptor protocol attributes.
#
# cp.func.__class__.__name__.__eq__('function') == True
# cp.attrname.__class__.__name__.__eq__('str') == True
# functools.cached_property.__set_name__.__class__.__name__.__eq__('function') == True
#
# After __set_name__ is called by the class body, attrname is a str (the attribute's name).
# func stores the original callable. __set_name__ is a pure-Python method. New to extra98.
# ---------------------------------------------------------------------------

table functools_extra98.cached_property_attrs:
  description: "cached_property descriptor func/attrname/__set_name__ class names; wave 253; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolslrucached98

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_class_name,
       "cached_property.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a Python class defined in Lib/functools.py; its metaclass is <class 'type'>; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra98"]
    - [cached_property_set_name_class,
       "cached_property.__set_name__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cached_property.__set_name__.__class__.__name__.__eq__('function') == True — __set_name__ is a pure-Python method defined in cached_property's class body in Lib/functools.py; unbound it is a plain function so __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Table 4: WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES
#
# Wave 253 theme: functools module-level tuple constants.
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True  len == 6
# functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple')    == True  len == 1
#
# WRAPPER_ASSIGNMENTS is a 6-element tuple (includes __annotate__ and __type_params__ in 3.14).
# WRAPPER_UPDATES is a 1-element tuple ('__dict__',). New to extra98.
# ---------------------------------------------------------------------------

table functools_extra98.wrapper_constants:
  description: "functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES class names and lengths; wave 253; new to extra98"
  kind: python_call_eq
  category: integer_identity
  id_prefix: functoolslrucached98

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_class_name,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py listing attribute names copied by update_wrapper; in Python 3.14 it has 6 entries including __annotate__ and __type_params__; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra98"]
    - [wrapper_assignments_len_eq_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS in Python 3.14 contains 6 attribute names: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; tuple.__len__() returns 6; int.__eq__(6) is True; new to extra98"]
    - [wrapper_updates_class_name,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple constant in Lib/functools.py listing attributes merged (not replaced) by update_wrapper; it is a tuple; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra98"]
    - [wrapper_updates_len_eq_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains only '__dict__'; update_wrapper merges the wrapper's __dict__ with the wrapped function's __dict__; tuple.__len__() returns 1; new to extra98"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra98
# ---------------------------------------------------------------------------

invariant functools_extra98.lru_cache_co_name:
  description: "functools.lru_cache.__code__.co_name == 'lru_cache' — code object co_name matches def statement; wave 253; new to extra98"
  kind: python_call_eq
  function: lru_cache.__code__.co_name.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra98.lru_cache_co_argcount:
  description: "functools.lru_cache.__code__.co_argcount == 2 — lru_cache takes maxsize and typed; wave 253; new to extra98"
  kind: python_call_eq
  function: lru_cache.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant functools_extra98.cached_property_set_name:
  description: "functools.cached_property.__set_name__.__class__.__name__ == 'function' — __set_name__ is a pure-Python method; wave 253; new to extra98"
  kind: python_call_eq
  function: cached_property.__set_name__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra98.wrapper_assignments_len:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — 6 attribute names in Python 3.14; wave 253; new to extra98"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra98.wrapper_updates_len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — only '__dict__' in WRAPPER_UPDATES; wave 253; new to extra98"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1
