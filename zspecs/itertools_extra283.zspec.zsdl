spec: itertools_extra283
version: ">=3.2"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.cycle and itertools.repeat behavioral contracts and type identity."
    - "itertools.cycle([1,2,3]).__next__() == 1 — cycle infinite-repeats a sequence; first element is 1. Verified with Python 3.14.3."
    - "list(itertools.repeat(42, 3)) == [42, 42, 42] — bounded repeat yields exactly 3 values. Verified with Python 3.14.3."
    - "itertools.repeat(42, 3).__length_hint__() == 3 — bounded repeat implements __length_hint__. Verified with Python 3.14.3."
    - "itertools.repeat(42).__next__() == 42 — unbounded repeat always yields 42. Verified with Python 3.14.3."
    - "itertools.repeat(42, 0).__next__() raises StopIteration — count=0 means no elements. Verified with Python 3.14.3."
    - "itertools.cycle.__name__ == 'cycle'; __module__ == 'itertools'; __class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.repeat.__name__ == 'repeat'; __module__ == 'itertools'; __class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.cycle and itertools.repeat type identity
#
# cycle.__name__ == 'cycle'
# cycle.__module__ == 'itertools'
# cycle.__class__.__name__ == 'type'  (C-level type)
# repeat.__name__ == 'repeat'
# repeat.__module__ == 'itertools'
# repeat.__class__.__name__ == 'type'  (C-level type)
# ---------------------------------------------------------------------------

table itertools_extra283.cycle_repeat_identity:
  description: "itertools.cycle and itertools.repeat C-level type identity: __name__, __module__, __class__.__name__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex283id

  columns: [id, function, args, expected, description]
  rows:
    - [cy_name_eq,  cycle.__name__.__eq__,               ["cycle"],    true, "itertools.cycle.__name__ == 'cycle' — C-level type name; verified with Python 3.14.3"]
    - [cy_mod_eq,   cycle.__module__.__eq__,              ["itertools"], true, "itertools.cycle.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [cy_cls_eq,   cycle.__class__.__name__.__eq__,      ["type"],     true, "itertools.cycle.__class__.__name__ == 'type' — cycle is a C-level type; verified with Python 3.14.3"]
    - [cy_name_len, cycle.__name__.__len__,               [],           5,    "itertools.cycle.__name__.__len__() == 5 — 'cycle' has 5 characters; verified with Python 3.14.3"]
    - [rp_name_eq,  repeat.__name__.__eq__,               ["repeat"],   true, "itertools.repeat.__name__ == 'repeat' — C-level type name; verified with Python 3.14.3"]
    - [rp_mod_eq,   repeat.__module__.__eq__,             ["itertools"], true, "itertools.repeat.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [rp_cls_eq,   repeat.__class__.__name__.__eq__,     ["type"],     true, "itertools.repeat.__class__.__name__ == 'type' — repeat is a C-level type; verified with Python 3.14.3"]
    - [rp_name_len, repeat.__name__.__len__,              [],           6,    "itertools.repeat.__name__.__len__() == 6 — 'repeat' has 6 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# First-element tests — cycle and repeat
#
# cycle([1,2,3]).__next__() == 1 — first element
# repeat(42).__next__() == 42 — unbounded repeat
# ---------------------------------------------------------------------------

invariant itertools_extra283.cycle_first_element:
  description: "itertools.cycle([1,2,3]).__next__() == 1 — cycle returns first element of the input sequence; new to extra283"
  category: first_element
  kind: python_call_eq
  function: cycle
  args: [[1, 2, 3]]
  method: __next__
  expected: 1

invariant itertools_extra283.repeat_unbounded_first:
  description: "itertools.repeat(42).__next__() == 42 — unbounded repeat returns the repeated value; new to extra283"
  category: first_element
  kind: python_call_eq
  function: repeat
  args: [42]
  method: __next__
  expected: 42

invariant itertools_extra283.cycle_name_is_cycle:
  description: "itertools.cycle.__name__ == 'cycle' — C-level type name matches the module-level attribute name; new to extra283"
  category: identity
  kind: python_call_eq
  function: cycle.__name__.__eq__
  args: ["cycle"]
  expected: true

invariant itertools_extra283.repeat_name_is_repeat:
  description: "itertools.repeat.__name__ == 'repeat' — C-level type name; new to extra283"
  category: identity
  kind: python_call_eq
  function: repeat.__name__.__eq__
  args: ["repeat"]
  expected: true

invariant itertools_extra283.cycle_module_is_itertools:
  description: "itertools.cycle.__module__ == 'itertools' — cycle is defined in the itertools module; new to extra283"
  category: identity
  kind: python_call_eq
  function: cycle.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra283.repeat_module_is_itertools:
  description: "itertools.repeat.__module__ == 'itertools' — repeat is defined in the itertools module; new to extra283"
  category: identity
  kind: python_call_eq
  function: repeat.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra283.cycle_is_type:
  description: "itertools.cycle.__class__.__name__ == 'type' — cycle is a C-level type, not a function; new to extra283"
  category: identity
  kind: python_call_eq
  function: cycle.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra283.repeat_is_type:
  description: "itertools.repeat.__class__.__name__ == 'type' — repeat is a C-level type, not a function; new to extra283"
  category: identity
  kind: python_call_eq
  function: repeat.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra283.repeat_zero_count_raises_stopiteration:
  description: "itertools.repeat(42, 0).__next__() raises StopIteration — count=0 means no elements are produced; new to extra283"
  category: errors
  kind: python_call_raises
  function: repeat
  args: [42, 0]
  method: __next__
  raises: StopIteration
