provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getclasstree (Python function), inspect.getmodule (Python function), inspect.getframeinfo (Python function), inspect.getouterframes (Python function), inspect.getmembers (Python function), inspect.classify_class_attrs (Python function) — __qualname__, __module__, __doc__ len, co_argcount (Wave 269)."
    - "inspect.getclasstree.__qualname__ == 'getclasstree' (len 12); co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.getmodule.__qualname__ == 'getmodule' (len 9); co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__qualname__ == 'getframeinfo' (len 12); co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.getouterframes.__qualname__ == 'getouterframes' (len 14); co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.getmembers.__qualname__ == 'getmembers' (len 10); co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__qualname__ == 'classify_class_attrs' (len 20); co_argcount == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
