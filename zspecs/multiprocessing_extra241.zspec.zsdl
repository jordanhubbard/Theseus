spec: multiprocessing_extra241
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py (Pool class implementation)"
  notes:
    - "multiprocessing.pool.Pool.apply.__name__ == 'apply' (len=5); __qualname__ == 'Pool.apply' (len=10); __module__ == 'multiprocessing.pool' (len=19)."
    - "multiprocessing.pool.Pool.apply_async.__name__ == 'apply_async' (len=11); __qualname__ == 'Pool.apply_async' (len=16)."
    - "multiprocessing.pool.Pool.map.__name__ == 'map' (len=3); __qualname__ == 'Pool.map' (len=8)."
    - "multiprocessing.pool.Pool.map_async.__name__ == 'map_async' (len=9); __qualname__ == 'Pool.map_async' (len=14)."
    - "multiprocessing.pool.Pool.imap.__name__ == 'imap' (len=4); __qualname__ == 'Pool.imap' (len=9)."
    - "multiprocessing.pool.Pool.imap_unordered.__name__ == 'imap_unordered' (len=14); __qualname__ == 'Pool.imap_unordered' (len=19) — longest qualname in this spec."
    - "multiprocessing.pool.Pool.starmap.__name__ == 'starmap' (len=7); __qualname__ == 'Pool.starmap' (len=12)."
    - "multiprocessing.pool.Pool.close.__name__ == 'close' (len=5); __qualname__ == 'Pool.close' (len=10)."
    - "multiprocessing.pool.Pool.terminate.__name__ == 'terminate' (len=9); __qualname__ == 'Pool.terminate' (len=14)."
    - "multiprocessing.pool.Pool.join.__name__ == 'join' (len=4); __qualname__ == 'Pool.join' (len=9)."
    - "All Pool methods are pure Python functions (__class__.__name__ == 'function') with __module__ == 'multiprocessing.pool' (len=19)."
    - "imap_unordered has the longest __name__ (len=14) and __qualname__ (len=19) among Pool's task-dispatch methods."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

