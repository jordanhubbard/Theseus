table multiprocessing_extra241.pool_lifecycle_method_identity:
  description: "multiprocessing.pool.Pool lifecycle method identity — close(len=5), terminate(len=9), join(len=4) are called to shut down a Pool; terminate(len=9) has the longest __name__ and __qualname__=='Pool.terminate'(len=14) among lifecycle methods; close and join both have __qualname__ length 10 and 9 respectively; all have __module__=='multiprocessing.pool'(len=19) and __class__.__name__=='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp241plc

  columns: [id, function, args, expected, description]
  rows:
    - [plc_cl_name_eq,    Pool.close.__name__.__eq__,               ["close"],                    true, "Pool.close.__name__ == 'close'; verified with Python 3.14.3"]
    - [plc_cl_name_len,   Pool.close.__name__.__len__,              [],                           5,    "Pool.close.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [plc_cl_qual_eq,    Pool.close.__qualname__.__eq__,           ["Pool.close"],               true, "Pool.close.__qualname__ == 'Pool.close'; verified with Python 3.14.3"]
    - [plc_cl_qual_len,   Pool.close.__qualname__.__len__,          [],                           10,   "Pool.close.__qualname__.__len__() == 10; verified with Python 3.14.3"]
    - [plc_cl_mod_eq,     Pool.close.__module__.__eq__,             ["multiprocessing.pool"],     true, "Pool.close.__module__ == 'multiprocessing.pool'; verified with Python 3.14.3"]
    - [plc_cl_cls_eq,     Pool.close.__class__.__name__.__eq__,     ["function"],                 true, "Pool.close.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [plc_tr_name_eq,    Pool.terminate.__name__.__eq__,           ["terminate"],                true, "Pool.terminate.__name__ == 'terminate'; verified with Python 3.14.3"]
    - [plc_tr_name_len,   Pool.terminate.__name__.__len__,          [],                           9,    "Pool.terminate.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [plc_tr_qual_eq,    Pool.terminate.__qualname__.__eq__,       ["Pool.terminate"],           true, "Pool.terminate.__qualname__ == 'Pool.terminate'; verified with Python 3.14.3"]
    - [plc_tr_qual_len,   Pool.terminate.__qualname__.__len__,      [],                           14,   "Pool.terminate.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [plc_tr_mod_eq,     Pool.terminate.__module__.__eq__,         ["multiprocessing.pool"],     true, "Pool.terminate.__module__ == 'multiprocessing.pool'; verified with Python 3.14.3"]
    - [plc_jn_name_eq,    Pool.join.__name__.__eq__,                ["join"],                     true, "Pool.join.__name__ == 'join'; verified with Python 3.14.3"]
    - [plc_jn_name_len,   Pool.join.__name__.__len__,               [],                           4,    "Pool.join.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [plc_jn_qual_eq,    Pool.join.__qualname__.__eq__,            ["Pool.join"],                true, "Pool.join.__qualname__ == 'Pool.join'; verified with Python 3.14.3"]
    - [plc_jn_qual_len,   Pool.join.__qualname__.__len__,           [],                           9,    "Pool.join.__qualname__.__len__() == 9; verified with Python 3.14.3"]
    - [plc_jn_mod_eq,     Pool.join.__module__.__eq__,              ["multiprocessing.pool"],     true, "Pool.join.__module__ == 'multiprocessing.pool'; verified with Python 3.14.3"]
    - [plc_jn_cls_eq,     Pool.join.__class__.__name__.__eq__,      ["function"],                 true, "Pool.join.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]

