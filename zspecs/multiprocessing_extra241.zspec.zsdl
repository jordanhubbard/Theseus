invariant multiprocessing_extra241.pool_imap_unordered_longest_name:
  description: "multiprocessing.pool.Pool.imap_unordered.__name__.__len__() == 14 — 'imap_unordered' (len=14) is the longest __name__ among all Pool task-dispatch methods in this spec; next longest is apply_async(len=11); map is shortest(len=3); imap_unordered.__qualname__=='Pool.imap_unordered'(len=19) is also the longest qualname; __module__=='multiprocessing.pool'(len=19); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Pool.imap_unordered.__name__.__len__
  args: []
  expected: 14

invariant multiprocessing_extra241.pool_module_eq:
  description: "multiprocessing.pool.Pool.apply.__module__.__eq__('multiprocessing.pool') returns True — all Pool methods are defined in multiprocessing.pool (len=19, not 'multiprocessing' len=16 or 'multiprocessing.context' len=23); Pool.apply.__name__=='apply'(len=5); Pool.apply.__qualname__=='Pool.apply'(len=10); __class__.__name__=='function'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Pool.apply.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true
