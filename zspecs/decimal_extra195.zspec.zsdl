spec: decimal_extra195
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers decimal module __name__ lengths not covered by prior decimal_extra specs."
    - "decimal.__name__ == 'decimal' (len=7); the module's own __name__ attribute; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__name__ == 'Decimal' (len=7); the main arbitrary-precision decimal type; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__name__ == 'Context' (len=7); the arithmetic context class; confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation' (len=16); signal for invalid operations; confirmed Python 3.14.3 macOS."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero' (len=14); signal for division by zero; confirmed Python 3.14.3 macOS."
    - "decimal.Overflow.__name__ == 'Overflow' (len=8); signal for overflow; confirmed Python 3.14.3 macOS."
    - "decimal.Underflow.__name__ == 'Underflow' (len=9); signal for underflow; confirmed Python 3.14.3 macOS."
    - "decimal.Inexact.__name__ == 'Inexact' (len=7); signal for inexact results; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal module and core type __name__ lengths
# decimal.__name__(7), Decimal(7), Context(7)
# ---------------------------------------------------------------------------

table decimal_extra195.module_and_core_type_name_lengths:
  description: "decimal module and core type __name__ lengths: decimal.__name__(7), Decimal(7), Context(7)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalnamelens195

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len,   decimal.__name__.__len__,         [], 7, "decimal.__name__.__len__() == 7 — d(1)e(2)c(3)i(4)m(5)a(6)l(7); the module's own __name__ attribute; confirmed Python 3.14.3 macOS"]
    - [decimal_name_len,  decimal.Decimal.__name__.__len__, [], 7, "decimal.Decimal.__name__.__len__() == 7 — D(1)e(2)c(3)i(4)m(5)a(6)l(7); the main arbitrary-precision decimal type; confirmed Python 3.14.3 macOS"]
    - [context_name_len,  decimal.Context.__name__.__len__, [], 7, "decimal.Context.__name__.__len__() == 7 — C(1)o(2)n(3)t(4)e(5)x(6)t(7); the arithmetic context controlling precision and rounding; confirmed Python 3.14.3 macOS"]
    - [module_name_eq,    decimal.__name__.__eq__,          ["decimal"], true, "decimal.__name__ == 'decimal' (len=7); confirmed Python 3.14.3 macOS"]
    - [decimal_name_eq,   decimal.Decimal.__name__.__eq__,  ["Decimal"], true, "decimal.Decimal.__name__ == 'Decimal' (len=7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal signal class __name__ lengths (longer names)
# InvalidOperation(16), DivisionByZero(14)
# ---------------------------------------------------------------------------

table decimal_extra195.signal_long_name_lengths:
  description: "decimal signal class __name__ lengths (longer): InvalidOperation(16), DivisionByZero(14)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalnamelens195

  columns: [id, function, args, expected, description]
  rows:
    - [invalidoperation_name_len, decimal.InvalidOperation.__name__.__len__, [], 16, "decimal.InvalidOperation.__name__.__len__() == 16 — I(1)n(2)v(3)a(4)l(5)i(6)d(7)O(8)p(9)e(10)r(11)a(12)t(13)i(14)o(15)n(16); signal for invalid operations; confirmed Python 3.14.3 macOS"]
    - [divisionbyzero_name_len,   decimal.DivisionByZero.__name__.__len__,   [], 14, "decimal.DivisionByZero.__name__.__len__() == 14 — D(1)i(2)v(3)i(4)s(5)i(6)o(7)n(8)B(9)y(10)Z(11)e(12)r(13)o(14); signal for division by zero; confirmed Python 3.14.3 macOS"]
    - [invalidoperation_name_eq,  decimal.InvalidOperation.__name__.__eq__,  ["InvalidOperation"], true, "decimal.InvalidOperation.__name__ == 'InvalidOperation' (len=16); confirmed Python 3.14.3 macOS"]
    - [divisionbyzero_name_eq,    decimal.DivisionByZero.__name__.__eq__,    ["DivisionByZero"], true, "decimal.DivisionByZero.__name__ == 'DivisionByZero' (len=14); confirmed Python 3.14.3 macOS"]
    - [context_name_eq,           decimal.Context.__name__.__eq__,           ["Context"], true, "decimal.Context.__name__ == 'Context' (len=7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal signal class __name__ lengths (shorter names)
# Overflow(8), Underflow(9), Inexact(7)
# ---------------------------------------------------------------------------

table decimal_extra195.signal_short_name_lengths:
  description: "decimal signal class __name__ lengths (shorter): Overflow(8), Underflow(9), Inexact(7)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalnamelens195

  columns: [id, function, args, expected, description]
  rows:
    - [overflow_name_len,  decimal.Overflow.__name__.__len__,  [], 8, "decimal.Overflow.__name__.__len__() == 8 — O(1)v(2)e(3)r(4)f(5)l(6)o(7)w(8); signal raised when a result is too large; confirmed Python 3.14.3 macOS"]
    - [underflow_name_len, decimal.Underflow.__name__.__len__, [], 9, "decimal.Underflow.__name__.__len__() == 9 — U(1)n(2)d(3)e(4)r(5)f(6)l(7)o(8)w(9); signal raised when a result is too small; confirmed Python 3.14.3 macOS"]
    - [inexact_name_len,   decimal.Inexact.__name__.__len__,   [], 7, "decimal.Inexact.__name__.__len__() == 7 — I(1)n(2)e(3)x(4)a(5)c(6)t(7); signal raised when a result is not exact; confirmed Python 3.14.3 macOS"]
    - [overflow_name_eq,   decimal.Overflow.__name__.__eq__,   ["Overflow"], true, "decimal.Overflow.__name__ == 'Overflow' (len=8); confirmed Python 3.14.3 macOS"]
    - [underflow_name_eq,  decimal.Underflow.__name__.__eq__,  ["Underflow"], true, "decimal.Underflow.__name__ == 'Underflow' (len=9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra195.module_name_len:
  description: "decimal.__name__.__len__() == 7 — 'decimal' has 7 characters: d(1)e(2)c(3)i(4)m(5)a(6)l(7); the module's own __name__ attribute; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra195.decimal_name_len:
  description: "decimal.Decimal.__name__.__len__() == 7 — 'Decimal' has 7 characters: D(1)e(2)c(3)i(4)m(5)a(6)l(7); tied with decimal.__name__ and Context in length; the main arbitrary-precision decimal type; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra195.context_name_len:
  description: "decimal.Context.__name__.__len__() == 7 — 'Context' has 7 characters: C(1)o(2)n(3)t(4)e(5)x(6)t(7); tied with decimal.__name__ and Decimal in length; controls precision and rounding; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra195.invalidoperation_name_len:
  description: "decimal.InvalidOperation.__name__.__len__() == 16 — 'InvalidOperation' has 16 characters; the longest name in the decimal module covered by this spec; signal for invalid operations; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.InvalidOperation.__name__.__len__
  args: []
  expected: 16

invariant decimal_extra195.divisionbyzero_name_len:
  description: "decimal.DivisionByZero.__name__.__len__() == 14 — 'DivisionByZero' has 14 characters; signal raised when division by zero is attempted; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.DivisionByZero.__name__.__len__
  args: []
  expected: 14

invariant decimal_extra195.overflow_name_len:
  description: "decimal.Overflow.__name__.__len__() == 8 — 'Overflow' has 8 characters: O(1)v(2)e(3)r(4)f(5)l(6)o(7)w(8); signal raised when a result is too large to be represented; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Overflow.__name__.__len__
  args: []
  expected: 8

invariant decimal_extra195.underflow_name_len:
  description: "decimal.Underflow.__name__.__len__() == 9 — 'Underflow' has 9 characters: U(1)n(2)d(3)e(4)r(5)f(6)l(7)o(8)w(9); signal raised when a result is too small after rounding; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Underflow.__name__.__len__
  args: []
  expected: 9

invariant decimal_extra195.inexact_name_len:
  description: "decimal.Inexact.__name__.__len__() == 7 — 'Inexact' has 7 characters: I(1)n(2)e(3)x(4)a(5)c(6)t(7); tied with decimal.__name__, Decimal, and Context; signal raised when a result is not exactly representable; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Inexact.__name__.__len__
  args: []
  expected: 7

