# ---------------------------------------------------------------------------

table cf2956.trunc:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_trunc
  id_prefix: trunc

  columns: [id, function, args, expected]
  rows:
    - ["trunc_Future",              operator.contains, [Future.__dict__,              "__trunc__"], false]
    - ["trunc_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__trunc__"], false]
    - ["trunc_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__trunc__"], false]
    - ["trunc_CancelledError",      operator.contains, [CancelledError.__dict__,      "__trunc__"], false]
    - ["trunc_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__trunc__"], false]
    - ["trunc_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__trunc__"], false]
    - ["trunc_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__trunc__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Spot-checks __invert__, __round__, __trunc__ absence across a representative
# selection of concurrent.futures classes in a single table for concise coverage.
# ---------------------------------------------------------------------------

table cf2956.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Future_inv",               operator.contains, [Future.__dict__,              "__invert__"], false]
    - ["comb_Future_rnd",               operator.contains, [Future.__dict__,              "__round__"],  false]
    - ["comb_Future_trunc",             operator.contains, [Future.__dict__,              "__trunc__"],  false]
    - ["comb_ThreadPoolExecutor_inv",   operator.contains, [ThreadPoolExecutor.__dict__,  "__invert__"], false]
    - ["comb_ThreadPoolExecutor_rnd",   operator.contains, [ThreadPoolExecutor.__dict__,  "__round__"],  false]
    - ["comb_ThreadPoolExecutor_trunc", operator.contains, [ThreadPoolExecutor.__dict__,  "__trunc__"],  false]
    - ["comb_ProcessPoolExecutor_inv",  operator.contains, [ProcessPoolExecutor.__dict__, "__invert__"], false]
    - ["comb_ProcessPoolExecutor_rnd",  operator.contains, [ProcessPoolExecutor.__dict__, "__round__"],  false]
    - ["comb_ProcessPoolExecutor_trunc",operator.contains, [ProcessPoolExecutor.__dict__, "__trunc__"],  false]
    - ["comb_CancelledError_inv",       operator.contains, [CancelledError.__dict__,      "__invert__"], false]
    - ["comb_CancelledError_rnd",       operator.contains, [CancelledError.__dict__,      "__round__"],  false]
    - ["comb_CancelledError_trunc",     operator.contains, [CancelledError.__dict__,      "__trunc__"],  false]
    - ["comb_BrokenExecutor_inv",       operator.contains, [BrokenExecutor.__dict__,      "__invert__"], false]
    - ["comb_BrokenExecutor_rnd",       operator.contains, [BrokenExecutor.__dict__,      "__round__"],  false]
    - ["comb_BrokenExecutor_trunc",     operator.contains, [BrokenExecutor.__dict__,      "__trunc__"],  false]
    - ["comb_InvalidStateError_inv",    operator.contains, [InvalidStateError.__dict__,   "__invert__"], false]
    - ["comb_InvalidStateError_rnd",    operator.contains, [InvalidStateError.__dict__,   "__round__"],  false]
    - ["comb_InvalidStateError_trunc",  operator.contains, [InvalidStateError.__dict__,   "__trunc__"],  false]
    - ["comb_TimeoutError_inv",         operator.contains, [TimeoutError.__dict__,        "__invert__"], false]
    - ["comb_TimeoutError_rnd",         operator.contains, [TimeoutError.__dict__,        "__round__"],  false]
    - ["comb_TimeoutError_trunc",       operator.contains, [TimeoutError.__dict__,        "__trunc__"],  false]
