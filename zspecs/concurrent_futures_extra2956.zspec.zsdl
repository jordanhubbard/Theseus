    - ["rnd_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__round__"], false]
    - ["rnd_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__round__"], false]
    - ["rnd_CancelledError",      operator.contains, [CancelledError.__dict__,      "__round__"], false]
    - ["rnd_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__round__"], false]
    - ["rnd_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__round__"], false]
    - ["rnd_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__round__"], false]

# ---------------------------------------------------------------------------
