spec: theseus_marshal_cr
version: ">=3.8"
backend: python_cleanroom(theseus_marshal_cr)
blocks: marshal

docs: https://docs.python.org/3/library/marshal.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/marshal.html"
  not_derived_from:
    - "CPython source: Python/marshal.c"
  notes:
    - "Clean-room marshal module. Do NOT import marshal."

error_model: python_exceptions

invariant theseus_marshal_cr.marshal2_roundtrip:
  description: "dumps/loads round-trip on a list"
  category: behavior
  kind: python_call_eq
  function: marshal2_roundtrip
  args: []
  expected: true

invariant theseus_marshal_cr.marshal2_int:
  description: "dumps integer produces bytes, loads returns integer"
  category: behavior
  kind: python_call_eq
  function: marshal2_int
  args: []
  expected: true

invariant theseus_marshal_cr.marshal2_version:
  description: "version attribute is an integer"
  category: behavior
  kind: python_call_eq
  function: marshal2_version
  args: []
  expected: true
