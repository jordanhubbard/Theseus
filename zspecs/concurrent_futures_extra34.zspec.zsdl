spec: concurrent_futures_extra34
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra33.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens for ThreadPoolExecutor/ProcessPoolExecutor/Executor, Future method qualname lens for result/add_done_callback/cancel/done/exception/running/set_result/set_exception/set_running_or_notify_cancel, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__() == 14, __mro__.__len__() for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor, __bases__[0].__name__.__len__() tables, Executor context manager __enter__/__exit__ qualname lens, InvalidStateError hierarchy, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, ThreadPoolExecutor.map/__qualname__.__len__()==12, ProcessPoolExecutor.map/__qualname__.__len__()==23, as_completed/__name__.__len__()==12, wait/__name__.__len__()==4, Future method __name__.__len__() tables (result/done/running/cancel/exception/add_done_callback/set_result/set_exception), ThreadPoolExecutor/__enter__/__exit__ __name__.__len__()."
    - "This spec covers: ThreadPoolExecutor.submit.__name__.__len__()==6 ('submit'); ThreadPoolExecutor.shutdown.__name__.__len__()==8 ('shutdown'); ProcessPoolExecutor.submit.__name__.__len__()==6 ('submit'); ProcessPoolExecutor.shutdown.__name__.__len__()==8 ('shutdown'); ThreadPoolExecutor.submit.__qualname__.__len__()==25 ('ThreadPoolExecutor.submit'); ThreadPoolExecutor.shutdown.__qualname__.__len__()==27 ('ThreadPoolExecutor.shutdown'); ProcessPoolExecutor.submit.__qualname__.__len__()==26 ('ProcessPoolExecutor.submit'); ProcessPoolExecutor.shutdown.__qualname__.__len__()==28 ('ProcessPoolExecutor.shutdown')."
    - "ThreadPoolExecutor.submit and ProcessPoolExecutor.submit share the same __name__.__len__() == 6 ('submit' is 6 characters for both). Similarly, ThreadPoolExecutor.shutdown and ProcessPoolExecutor.shutdown share __name__.__len__() == 8 ('shutdown' is 8 characters). The short names are identical because ProcessPoolExecutor inherits submit and defines shutdown with the same identifier as ThreadPoolExecutor."
    - "The __qualname__ lengths differ by executor type: 'ThreadPoolExecutor.' (19 chars) vs 'ProcessPoolExecutor.' (20 chars) as prefix. So submit: 19+6=25 vs 20+6=26; shutdown: 19+8=27 vs 20+8=28. ProcessPoolExecutor qualname lengths are always 1 char longer than ThreadPoolExecutor because 'Process' (7) is one char longer than 'Thread' (6)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor submit/shutdown __name__.__len__() — extra34
#
# Both ThreadPoolExecutor and ProcessPoolExecutor define submit() and
# shutdown() methods. The short __name__ is identical for both executors
# because the method identifier is the same:
#   ThreadPoolExecutor.submit.__name__   == 'submit'   (6 chars)
#   ProcessPoolExecutor.submit.__name__  == 'submit'   (6 chars)
#   ThreadPoolExecutor.shutdown.__name__ == 'shutdown' (8 chars)
#   ProcessPoolExecutor.shutdown.__name__ == 'shutdown' (8 chars)
# Prior spec extra33 covered __enter__/__exit__ __name__.__len__(), but
# submit and shutdown __name__.__len__() have not been measured.
# ---------------------------------------------------------------------------

table concurrent_futures_extra34.executor_submit_shutdown_name_lengths:
  description: "concurrent.futures executor submit/shutdown __name__.__len__() in extra34 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execssnamelen34

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_submit,   ThreadPoolExecutor.submit.__name__.__len__,    [], 6, "'submit' is 6 characters — same for both executor types"]
    - [tpe_shutdown, ThreadPoolExecutor.shutdown.__name__.__len__,   [], 8, "'shutdown' is 8 characters — same for both executor types"]
    - [ppe_submit,   ProcessPoolExecutor.submit.__name__.__len__,   [], 6, "'submit' is 6 characters — same as ThreadPoolExecutor.submit"]
    - [ppe_shutdown, ProcessPoolExecutor.shutdown.__name__.__len__,  [], 8, "'shutdown' is 8 characters — same as ThreadPoolExecutor.shutdown"]

# ---------------------------------------------------------------------------
# concurrent.futures executor submit/shutdown __qualname__.__len__() — extra34
#
# While the __name__ lengths are identical (6 for submit, 8 for shutdown),
# the __qualname__ lengths differ by executor type because the class name
# prefix length differs:
#   'ThreadPoolExecutor.' prefix  = 19 chars
#   'ProcessPoolExecutor.' prefix = 20 chars
# Therefore:
#   ThreadPoolExecutor.submit.__qualname__   == 'ThreadPoolExecutor.submit'   (25)
#   ProcessPoolExecutor.submit.__qualname__  == 'ProcessPoolExecutor.submit'  (26)
#   ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (27)
#   ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (28)
# The ProcessPoolExecutor qualname is always 1 longer because 'Process' (7)
# is one character longer than 'Thread' (6). No prior spec covers these
# four __qualname__.__len__() values as integer invariants.
# ---------------------------------------------------------------------------

table concurrent_futures_extra34.executor_submit_shutdown_qualname_lengths:
  description: "concurrent.futures executor submit/shutdown __qualname__.__len__() in extra34 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execssqnamelen34

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_submit,   ThreadPoolExecutor.submit.__qualname__.__len__,    [], 25, "'ThreadPoolExecutor.submit' is 25 chars: 'ThreadPoolExecutor.' (19) + 'submit' (6)"]
    - [tpe_shutdown, ThreadPoolExecutor.shutdown.__qualname__.__len__,   [], 27, "'ThreadPoolExecutor.shutdown' is 27 chars: 'ThreadPoolExecutor.' (19) + 'shutdown' (8)"]
    - [ppe_submit,   ProcessPoolExecutor.submit.__qualname__.__len__,   [], 26, "'ProcessPoolExecutor.submit' is 26 chars: 'ProcessPoolExecutor.' (20) + 'submit' (6)"]
    - [ppe_shutdown, ProcessPoolExecutor.shutdown.__qualname__.__len__,  [], 28, "'ProcessPoolExecutor.shutdown' is 28 chars: 'ProcessPoolExecutor.' (20) + 'shutdown' (8)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra34
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra34.ThreadPoolExecutor_submit_name_len:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__name__.__len__() == 6 — 'submit' has 6 characters; same as ProcessPoolExecutor.submit.__name__.__len__()"
  category: method_names
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__name__.__len__
  args: []
  expected: 6

invariant concurrent_futures_extra34.ProcessPoolExecutor_shutdown_qualname_len:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__len__() == 28 — 'ProcessPoolExecutor.shutdown' has 28 characters; the longest qualname in this spec"
  category: method_names
  kind: python_call_eq
  function: ProcessPoolExecutor.shutdown.__qualname__.__len__
  args: []
  expected: 28

invariant concurrent_futures_extra34.ProcessPoolExecutor_submit_qualname_len:
  description: "concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__len__() == 26 — 'ProcessPoolExecutor.submit' has 26 characters; 1 longer than ThreadPoolExecutor.submit (25)"
  category: method_names
  kind: python_call_eq
  function: ProcessPoolExecutor.submit.__qualname__.__len__
  args: []
  expected: 26
