spec: random_extra7
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra6.zspec.zsdl."
    - "random_extra5 covers __qualname__ for gauss/expovariate/betavariate and distribution __name__ for gammavariate/lognormvariate/normalvariate."
    - "random_extra6 covers __qualname__ for random/randint/randrange/choice/choices/shuffle/sample/uniform/seed/getstate/setstate."
    - "No prior spec covers __qualname__ for gammavariate/lognormvariate/normalvariate/triangular/vonmisesvariate/paretovariate/weibullvariate."
    - "No prior spec covers random.VERSION (== 2, the Mersenne Twister version marker)."
    - "No prior spec covers random.RECIP_BPF (== 1/53, the reciprocal of BPF used in float generation)."
    - "random.VERSION == 2 — the version tag used when pickling the RNG state."
    - "random.RECIP_BPF == 2**-53 — the reciprocal of BPF (bits per float = 53)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — remaining distribution functions
#
# random_extra5 covers gauss/expovariate/betavariate __qualname__.
# random_extra6 covers random/randint/randrange/choice/choices/shuffle/
#   sample/uniform/seed/getstate/setstate __qualname__.
# This table adds the distribution functions not yet covered.
# ---------------------------------------------------------------------------

table random_extra7.qualnames_distributions:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [gammavariate,   gammavariate.__qualname__.__eq__,   ["gammavariate"],   true]
    - [lognormvariate, lognormvariate.__qualname__.__eq__, ["lognormvariate"], true]
    - [normalvariate,  normalvariate.__qualname__.__eq__,  ["normalvariate"],  true]
    - [triangular,     triangular.__qualname__.__eq__,     ["triangular"],     true]
    - [vonmisesvariate, vonmisesvariate.__qualname__.__eq__, ["vonmisesvariate"], true]
    - [paretovariate,  paretovariate.__qualname__.__eq__,  ["paretovariate"],  true]
    - [weibullvariate, weibullvariate.__qualname__.__eq__, ["weibullvariate"], true]

# ---------------------------------------------------------------------------
# VERSION constant
#
# random.VERSION == 2 is the Mersenne Twister state pickle format version.
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant random_extra7.VERSION.value:
  description: "random.VERSION == 2 — Mersenne Twister state pickle format version"
  category: constants
  kind: python_call_eq
  function: VERSION.__eq__
  args: [2]
  expected: true

invariant random_extra7.VERSION.is_int:
  description: "random.VERSION.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: VERSION.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# RECIP_BPF constant
#
# random.RECIP_BPF == 2**-53 (approximately 1.1102230246251565e-16).
# It is used internally to convert Mersenne Twister output to a float in [0, 1).
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant random_extra7.RECIP_BPF.is_float:
  description: "random.RECIP_BPF.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: RECIP_BPF.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant random_extra7.RECIP_BPF.positive:
  description: "random.RECIP_BPF > 0 — reciprocal of BPF is always positive"
  category: constants
  kind: python_call_eq
  function: RECIP_BPF.__gt__
  args: [0]
  expected: true

invariant random_extra7.RECIP_BPF.less_than_one:
  description: "random.RECIP_BPF < 1 — 2**-53 is much less than 1"
  category: constants
  kind: python_call_eq
  function: RECIP_BPF.__lt__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks for remaining distribution functions
#
# random_extra5 covers gammavariate/lognormvariate/normalvariate __module__.
# No prior spec covers triangular/vonmisesvariate/paretovariate/weibullvariate __module__.
# ---------------------------------------------------------------------------

table random_extra7.modules_distributions:
  kind: python_call_eq
  category: function_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [triangular,     triangular.__module__.__eq__,     ["random"], true]
    - [vonmisesvariate, vonmisesvariate.__module__.__eq__, ["random"], true]
    - [paretovariate,  paretovariate.__module__.__eq__,  ["random"], true]
    - [weibullvariate, weibullvariate.__module__.__eq__, ["random"], true]
