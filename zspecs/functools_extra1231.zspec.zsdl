spec: functools_extra1231
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.__dict__.__contains__ for 'reduce', 'partial', 'lru_cache', 'cache', 'cached_property', 'wraps', 'total_ordering', 'singledispatch', 'update_wrapper', 'cmp_to_key', 'WRAPPER_ASSIGNMENTS', 'WRAPPER_UPDATES', and absent keys — not covered in _extra1201/_extra1216"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1231.dict_contains_core_functions:
  description: "functools.__dict__.__contains__ for core public functions and constants"
  kind: python_call_eq
  category: dict_contains_core_functions
  id_prefix: fn1231dc
  columns: [id, function, args, expected]
  rows:
    - [fn1231dc001, functools.__dict__.__contains__, ["reduce"],             true]
    - [fn1231dc002, functools.__dict__.__contains__, ["partial"],            true]
    - [fn1231dc003, functools.__dict__.__contains__, ["lru_cache"],          true]
    - [fn1231dc004, functools.__dict__.__contains__, ["cache"],              true]
    - [fn1231dc005, functools.__dict__.__contains__, ["cached_property"],    true]
    - [fn1231dc006, functools.__dict__.__contains__, ["wraps"],              true]
    - [fn1231dc007, functools.__dict__.__contains__, ["total_ordering"],     true]
    - [fn1231dc008, functools.__dict__.__contains__, ["singledispatch"],     true]

table functools_extra1231.dict_contains_wrapper_and_helpers:
  description: "functools.__dict__.__contains__ for update_wrapper, cmp_to_key, WRAPPER_ASSIGNMENTS, and WRAPPER_UPDATES"
  kind: python_call_eq
  category: dict_contains_wrapper_and_helpers
  id_prefix: fn1231wh
  columns: [id, function, args, expected]
  rows:
    - [fn1231wh001, functools.__dict__.__contains__, ["update_wrapper"],       true]
    - [fn1231wh002, functools.__dict__.__contains__, ["cmp_to_key"],           true]
    - [fn1231wh003, functools.__dict__.__contains__, ["WRAPPER_ASSIGNMENTS"],  true]
    - [fn1231wh004, functools.__dict__.__contains__, ["WRAPPER_UPDATES"],      true]
    - [fn1231wh005, functools.__dict__.__contains__, ["singledispatchmethod"], true]
    - [fn1231wh006, functools.__dict__.__contains__, ["partialmethod"],        true]
    - [fn1231wh007, functools.__dict__.__contains__, ["nonexistent_fn"],       false]
    - [fn1231wh008, functools.__dict__.__contains__, ["apply"],                false]

table functools_extra1231.dict_contains_absent_and_class_name:
  description: "functools.__dict__.__contains__ negative checks and module dict class identity"
  kind: python_call_eq
  category: dict_contains_absent_and_class_name
  id_prefix: fn1231ab
  columns: [id, function, args, expected]
  rows:
    - [fn1231ab001, functools.__dict__.__contains__, ["map"],                  false]
    - [fn1231ab002, functools.__dict__.__contains__, ["filter"],               false]
    - [fn1231ab003, functools.__dict__.__contains__, ["zip"],                  false]
    - [fn1231ab004, functools.__dict__.__contains__, ["sorted"],               false]
    - [fn1231ab005, functools.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [fn1231ab006, functools.__dict__.__contains__, ["reduce"],               true]
    - [fn1231ab007, functools.__dict__.__contains__, ["lru_cache"],            true]
    - [fn1231ab008, functools.__dict__.__contains__, ["__name__"],             true]
