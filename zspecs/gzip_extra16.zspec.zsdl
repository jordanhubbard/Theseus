spec: gzip_extra16
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
    - "gzip_extra15.zspec.zsdl — covers GzipFile.__module__ (extra15 anchor), GzipFile.__bases__[0].__name__ == 'BaseStream', BadGzipFile.__qualname__ (extra15 anchor), BadGzipFile.__bases__[0].__name__ == 'OSError', open/compress/decompress __module__."
    - "gzip_extra14.zspec.zsdl — covers GzipFile.__init__/__repr__/readable/writable/seekable __qualname__ (extra14); BadGzipFile.__qualname__ standalone (extra14 anchor)."
    - "gzip_extra13.zspec.zsdl — covers GzipFile.read/write/seek/tell/close/flush __qualname__ (extra13); open/compress/decompress __qualname__ (extra13 anchor)."
    - "gzip_extra12.zspec.zsdl — covers GzipFile/__qualname__ and BadGzipFile/__qualname__ standalone (extra12); open/compress/decompress __qualname__ standalone (extra12); gzip.__package__; GzipFile.__module__ standalone (extra12)."
    - "gzip_extra4.zspec.zsdl — covers GzipFile/__qualname__ and BadGzipFile/__qualname__ in a class_qualnames table; open/compress/decompress __qualname__ in a function_qualnames table."
    - "gzip_extra2.zspec.zsdl — covers GzipFile.read/__name__, GzipFile.write/__name__, GzipFile.close/__name__, GzipFile.readable/__name__ in a method names table."
  notes:
    - "This spec extends gzip through gzip_extra15; it does NOT duplicate invariants present in those files."
    - "Focus: GzipFile.peek/readline/read1/readinto __qualname__ (novel — not covered by any prior gzip spec); BadGzipFile.__module__ == 'gzip' (novel — extra15 covers GzipFile.__module__ and BadGzipFile.__bases__ but not BadGzipFile.__module__); BadGzipFile.__mro__[2].__name__ and mro[3].__name__ (novel hierarchy invariants); gzip.__loader__.__class__.__name__ and gzip.__spec__.__class__.__name__ (novel loader/spec type invariants)."
    - "GzipFile.peek.__qualname__ == 'GzipFile.peek': peek is a public method defined in Lib/gzip.py. Not covered in any prior gzip spec. Verified 2026-04-09."
    - "GzipFile.readline.__qualname__ == 'GzipFile.readline': readline is defined directly on GzipFile. Not covered in any prior gzip spec. Verified 2026-04-09."
    - "GzipFile.read1.__qualname__ == 'GzipFile.read1': read1 is a public method on GzipFile (buffered-IO interface). Not covered in any prior gzip spec. Verified 2026-04-09."
    - "GzipFile.readinto.__qualname__ == 'GzipFile.readinto': readinto is defined directly on GzipFile. Not covered in any prior gzip spec. Verified 2026-04-09."
    - "BadGzipFile.__module__ == 'gzip': the exception class is defined in Lib/gzip.py. No prior gzip spec checks BadGzipFile.__module__. Verified 2026-04-09."
    - "BadGzipFile.__mro__[2].__name__ == 'Exception': third MRO entry after BadGzipFile and OSError. No prior gzip spec checks this. Verified 2026-04-09."
    - "BadGzipFile.__mro__[3].__name__ == 'BaseException': fourth MRO entry. No prior gzip spec checks this. Verified 2026-04-09."
    - "gzip.__loader__.__class__.__name__ == 'SourceFileLoader': gzip is a pure-Python module loaded by SourceFileLoader. No prior gzip spec checks this. Verified 2026-04-09."
    - "gzip.__spec__.__class__.__name__ == 'ModuleSpec': the spec object for the gzip module is a ModuleSpec instance. No prior gzip spec checks this. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GzipFile.peek __qualname__ — novel, extra16 anchor
#
# No prior gzip spec checks GzipFile.peek.__qualname__. peek is a public
# method defined directly on GzipFile in Lib/gzip.py. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra16.GzipFile.peek.qualname:
  description: "gzip.GzipFile.peek.__qualname__ == 'GzipFile.peek' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: GzipFile.peek.__qualname__.__eq__
  args: ["GzipFile.peek"]
  expected: true

# ---------------------------------------------------------------------------
# GzipFile.readline __qualname__ — novel, extra16 anchor
#
# No prior gzip spec checks GzipFile.readline.__qualname__. readline is
# defined directly on GzipFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra16.GzipFile.readline.qualname:
  description: "gzip.GzipFile.readline.__qualname__ == 'GzipFile.readline' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: GzipFile.readline.__qualname__.__eq__
  args: ["GzipFile.readline"]
  expected: true

# ---------------------------------------------------------------------------
# GzipFile.read1 __qualname__ — novel, extra16 anchor
#
# No prior gzip spec checks GzipFile.read1.__qualname__. read1 is part of
# the buffered-IO interface, defined directly on GzipFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra16.GzipFile.read1.qualname:
  description: "gzip.GzipFile.read1.__qualname__ == 'GzipFile.read1' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: GzipFile.read1.__qualname__.__eq__
  args: ["GzipFile.read1"]
  expected: true

# ---------------------------------------------------------------------------
# GzipFile.readinto __qualname__ — novel, extra16 anchor
#
# No prior gzip spec checks GzipFile.readinto.__qualname__. readinto is
# defined directly on GzipFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra16.GzipFile.readinto.qualname:
  description: "gzip.GzipFile.readinto.__qualname__ == 'GzipFile.readinto' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: GzipFile.readinto.__qualname__.__eq__
  args: ["GzipFile.readinto"]
  expected: true

# ---------------------------------------------------------------------------
# BadGzipFile.__module__ == 'gzip' — novel, extra16 anchor
#
# extra15 covers GzipFile.__module__ and BadGzipFile.__bases__[0].__name__,
# but no prior gzip spec checks BadGzipFile.__module__. BadGzipFile is
# defined in Lib/gzip.py so its __module__ is 'gzip'. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra16.BadGzipFile.module:
  description: "gzip.BadGzipFile.__module__ == 'gzip' — exception class is defined in Lib/gzip.py (extra16)"
  category: module_affiliation
  kind: python_call_eq
  function: BadGzipFile.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# BadGzipFile.__mro__[2].__name__ == 'Exception' — novel, extra16 anchor
#
# extra15 covers BadGzipFile.__bases__[0].__name__ == 'OSError'. No prior
# gzip spec checks mro[2]. BadGzipFile MRO: BadGzipFile -> OSError ->
# Exception -> BaseException -> object. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra16.BadGzipFile.mro2_name:
  description: "gzip.BadGzipFile.__mro__[2].__name__ == 'Exception' — third MRO entry after OSError (extra16)"
  category: hierarchy
  kind: python_call_eq
  function: "BadGzipFile.__mro__.__getitem__"
  args: [2]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# BadGzipFile.__mro__[3].__name__ == 'BaseException' — novel, extra16 anchor
#
# No prior gzip spec checks BadGzipFile.__mro__[3]. Fourth entry in the MRO
# is BaseException. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra16.BadGzipFile.mro3_name:
  description: "gzip.BadGzipFile.__mro__[3].__name__ == 'BaseException' — fourth MRO entry is BaseException (extra16)"
  category: hierarchy
  kind: python_call_eq
  function: "BadGzipFile.__mro__.__getitem__"
  args: [3]
  method: __name__.__eq__
  method_args: ["BaseException"]
  expected: true

# ---------------------------------------------------------------------------
# gzip.__loader__.__class__.__name__ == 'SourceFileLoader' — novel, extra16 anchor
#
# No prior gzip spec checks the loader class name. gzip is a pure-Python
# stdlib module loaded by importlib's SourceFileLoader. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra16.loader.class_name:
  description: "gzip.__loader__.__class__.__name__ == 'SourceFileLoader' — module is loaded by SourceFileLoader (extra16)"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# gzip.__spec__.__class__.__name__ == 'ModuleSpec' — novel, extra16 anchor
#
# No prior gzip spec checks the spec object's class name. The import system
# attaches a ModuleSpec instance to every module as __spec__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra16.spec.class_name:
  description: "gzip.__spec__.__class__.__name__ == 'ModuleSpec' — module's __spec__ is a ModuleSpec instance (extra16)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — GzipFile.peek/readline/read1/readinto (extra16)
#
# No prior gzip spec presents these four method qualnames in any table.
# This table anchors all four from the extra16 namespace.
# ---------------------------------------------------------------------------

table gzip_extra16.method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn16

  columns: [id, function, args, expected]
  rows:
    - [GzipFile.peek,     GzipFile.peek.__qualname__.__eq__,     ["GzipFile.peek"],     true]
    - [GzipFile.readline, GzipFile.readline.__qualname__.__eq__, ["GzipFile.readline"], true]
    - [GzipFile.read1,    GzipFile.read1.__qualname__.__eq__,    ["GzipFile.read1"],    true]
    - [GzipFile.readinto, GzipFile.readinto.__qualname__.__eq__, ["GzipFile.readinto"], true]

# ---------------------------------------------------------------------------
# module_identity table — loader and spec class names (extra16)
#
# No prior gzip spec presents loader/spec class-name checks in a table.
# This table anchors both module_identity invariants from extra16.
# ---------------------------------------------------------------------------

table gzip_extra16.module_identity:
  kind: python_call_eq
  category: module_identity
  id_prefix: mid16

  columns: [id, function, args, expected]
  rows:
    - [loader_class, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]
    - [spec_class,   __spec__.__class__.__name__.__eq__,   ["ModuleSpec"],       true]
