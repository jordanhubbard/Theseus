spec: pathlib_extra55
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra54.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __class__.__qualname__.__eq__('type'); Path.cwd/__class__.__qualname__.__eq__('method'); Path.home/__class__.__qualname__.__eq__('method'); Path/__class__.__module__.__eq__('builtins'); PurePath/__class__.__module__.__eq__('builtins')."
    - "pathlib_extra53.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __class__.__name__.__eq__('type') and __class__.__name__.__len__()==4; Path.cwd/__class__.__name__.__eq__('method'); Path.home/__class__.__name__.__eq__('method')."
    - "pathlib_extra50.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__len__(); Path.cwd/__qualname__.__len__()==8; Path.home/__qualname__.__len__()==9."
    - "pathlib_extra49.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__eq__(); Path.cwd/__qualname__.__eq__('Path.cwd'); Path.home/__qualname__.__eq__('Path.home')."
  notes:
    - "This spec extends pathlib_extra54.zspec.zsdl."
    - "Prior specs collectively covered: all pathlib class __qualname__ equality and lengths (pathlib_extra49/pathlib_extra50); class __class__.__name__/__qualname__ equality (pathlib_extra53/pathlib_extra54); Path.cwd and Path.home __qualname__ equality and length (pathlib_extra49/pathlib_extra50) and __class__.__name__/__qualname__ equality (pathlib_extra53/pathlib_extra54). NO prior pathlib spec checks the __qualname__ attribute of any concrete file-operation method of the Path class (Path.open, Path.read_text, Path.write_text, etc). NO prior pathlib spec checks the __len__ of those method __qualname__ strings. All twelve __qualname__.__len__() anchors in this spec are novel."
    - "This spec covers: pathlib.Path.open.__qualname__.__len__()==9 (NOVEL — 'Path.open' is 9 chars; no prior pathlib spec checks Path.open.__qualname__ or its length; novel); pathlib.Path.read_text.__qualname__.__len__()==14 (NOVEL — 'Path.read_text' is 14 chars; novel); pathlib.Path.write_text.__qualname__.__len__()==15 (NOVEL — 'Path.write_text' is 15 chars; novel); pathlib.Path.read_bytes.__qualname__.__len__()==15 (NOVEL — 'Path.read_bytes' is 15 chars; novel); pathlib.Path.write_bytes.__qualname__.__len__()==16 (NOVEL — 'Path.write_bytes' is 16 chars; novel); pathlib.Path.mkdir.__qualname__.__len__()==10 (NOVEL — 'Path.mkdir' is 10 chars; novel); pathlib.Path.unlink.__qualname__.__len__()==11 (NOVEL — 'Path.unlink' is 11 chars; novel); pathlib.Path.exists.__qualname__.__len__()==11 (NOVEL — 'Path.exists' is 11 chars; novel); pathlib.Path.is_file.__qualname__.__len__()==12 (NOVEL — 'Path.is_file' is 12 chars; novel); pathlib.Path.is_dir.__qualname__.__len__()==11 (NOVEL — 'Path.is_dir' is 11 chars; novel); pathlib.Path.stat.__qualname__.__len__()==9 (NOVEL — 'Path.stat' is 9 chars; novel); pathlib.Path.rename.__qualname__.__len__()==11 (NOVEL — 'Path.rename' is 11 chars; novel)."
    - "pathlib.Path.open.__qualname__ == 'Path.open'. Path is a Python class; its method open has __qualname__ 'Path.open'. Length == 9 (P-a-t-h-.-o-p-e-n). No prior pathlib spec checks Path.open.__qualname__ or its length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.read_text.__qualname__ == 'Path.read_text'. Length == 14. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.write_text.__qualname__ == 'Path.write_text'. Length == 15. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes'. Length == 15. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes'. Length == 16. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir'. Length == 10. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.unlink.__qualname__ == 'Path.unlink'. Length == 11. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.exists.__qualname__ == 'Path.exists'. Length == 11. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.is_file.__qualname__ == 'Path.is_file'. Length == 12. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir'. Length == 11. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat'. Length == 9. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.rename.__qualname__ == 'Path.rename'. Length == 11. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path file-operation method __qualname__ lengths
#
# Path is a Python class in pathlib. Its concrete file-operation methods carry
# __qualname__ strings of the form 'Path.<methodname>'. The lengths are:
#
#   Path.open.__qualname__        == 'Path.open'        -> len  9
#   Path.read_text.__qualname__   == 'Path.read_text'   -> len 14
#   Path.write_text.__qualname__  == 'Path.write_text'  -> len 15
#   Path.read_bytes.__qualname__  == 'Path.read_bytes'  -> len 15
#   Path.write_bytes.__qualname__ == 'Path.write_bytes' -> len 16
#   Path.mkdir.__qualname__       == 'Path.mkdir'       -> len 10
#   Path.unlink.__qualname__      == 'Path.unlink'      -> len 11
#   Path.exists.__qualname__      == 'Path.exists'      -> len 11
#   Path.is_file.__qualname__     == 'Path.is_file'     -> len 12
#   Path.is_dir.__qualname__      == 'Path.is_dir'      -> len 11
#   Path.stat.__qualname__        == 'Path.stat'        -> len  9
#   Path.rename.__qualname__      == 'Path.rename'      -> len 11
#
# No prior pathlib spec checks __qualname__ or its length for any of these
# concrete Path methods (pathlib_extra49/50 cover the class __qualname__
# and Path.cwd/Path.home __qualname__ only).
# All twelve length anchors are novel in the pathlib_extra55 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra55.path_method_qualname_lens:
  description: "pathlib.Path file-operation method __qualname__.__len__() for open/read_text/write_text/read_bytes/write_bytes/mkdir/unlink/exists/is_file/is_dir/stat/rename — qualname strings are 'Path.<method>'; no prior pathlib spec checks __qualname__ or its length for any of these methods; all twelve novel length anchors in pathlib_extra55 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlipmlen55

  columns: [id, function, args, expected]
  rows:
    - [Path_open_qualname_len,        "Path.open.__qualname__.__len__",        [], 9]
    - [Path_read_text_qualname_len,   "Path.read_text.__qualname__.__len__",   [], 14]
    - [Path_write_text_qualname_len,  "Path.write_text.__qualname__.__len__",  [], 15]
    - [Path_read_bytes_qualname_len,  "Path.read_bytes.__qualname__.__len__",  [], 15]
    - [Path_write_bytes_qualname_len, "Path.write_bytes.__qualname__.__len__", [], 16]
    - [Path_mkdir_qualname_len,       "Path.mkdir.__qualname__.__len__",       [], 10]
    - [Path_unlink_qualname_len,      "Path.unlink.__qualname__.__len__",      [], 11]
    - [Path_exists_qualname_len,      "Path.exists.__qualname__.__len__",      [], 11]
    - [Path_is_file_qualname_len,     "Path.is_file.__qualname__.__len__",     [], 12]
    - [Path_is_dir_qualname_len,      "Path.is_dir.__qualname__.__len__",      [], 11]
    - [Path_stat_qualname_len,        "Path.stat.__qualname__.__len__",        [], 9]
    - [Path_rename_qualname_len,      "Path.rename.__qualname__.__len__",      [], 11]
