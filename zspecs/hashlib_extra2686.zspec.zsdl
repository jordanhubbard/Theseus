spec: hashlib_extra2686
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 626: checks hashlib HASH (accessed via hashlib.new('sha256').__class__), blake2b, blake2s __dict__ for __and__, __or__, __xor__ presence. All three classes return False for all three dunders — none defines __and__, __or__, or __xor__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table hashlib_extra2686.HASH_dict_presence:
  description: "hashlib HASH class (hashlib.new('sha256').__class__) __dict__ does not contain __and__, __or__, or __xor__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2686hd
  columns: [id, function, args, expected]
  rows:
    - ["hl2686hd001", hashlib.new("sha256").__class__.__dict__.__contains__, ["__and__"], false]
    - ["hl2686hd002", hashlib.new("sha256").__class__.__dict__.__contains__, ["__or__"],  false]
    - ["hl2686hd003", hashlib.new("sha256").__class__.__dict__.__contains__, ["__xor__"], false]

