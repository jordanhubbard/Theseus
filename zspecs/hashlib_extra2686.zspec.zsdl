table hashlib_extra2686.hash_types_cross:
  description: "Cross-checks: HASH class, blake2b, blake2s __dict__ do not contain __and__, __or__, __xor__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2686cx
  columns: [id, function, args, expected]
  rows:
    - ["hl2686cx001", hashlib.new("sha256").__class__.__dict__.__contains__, ["__and__"], false]
    - ["hl2686cx002", hashlib.blake2b.__dict__.__contains__,                 ["__or__"],  false]
    - ["hl2686cx003", hashlib.blake2s.__dict__.__contains__,                 ["__xor__"], false]
    - ["hl2686cx004", hashlib.new("sha256").__class__.__dict__.__contains__, ["__xor__"], false]
    - ["hl2686cx005", hashlib.blake2b.__dict__.__contains__,                 ["__xor__"], false]
    - ["hl2686cx006", hashlib.blake2s.__dict__.__contains__,                 ["__and__"], false]
