spec: decimal_extra2281
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count, dict size."
    - "Subjects: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.DivisionByZero, decimal.Overflow, decimal.Underflow, decimal.Inexact, decimal.Rounded, decimal.Subnormal, decimal.FloatOperation."
    - "decimal.Decimal and decimal.Context are direct object subclasses: __mro__.__len__ == 2."
    - "decimal.DecimalException: __mro__.__len__ == 5 (DecimalException→ArithmeticError→Exception→BaseException→object)."
    - "decimal.DivisionByZero: __mro__.__len__ == 7 (multiple inheritance: DecimalException + ZeroDivisionError); __bases__.__len__ == 2."
    - "decimal.Overflow: __mro__.__len__ == 8 (Overflow→Inexact→Rounded→DecimalException→...); __bases__.__len__ == 2."
    - "decimal.Underflow: __mro__.__len__ == 9 (deepest: adds Subnormal); __bases__.__len__ == 3."
    - "decimal.FloatOperation: __mro__.__len__ == 7 (DecimalException + TypeError branches); __bases__.__len__ == 2."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

