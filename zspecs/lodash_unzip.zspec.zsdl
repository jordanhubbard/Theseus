spec: lodash_unzip
version: ">=4.0.0"
backend: node(lodash.unzip)

docs: https://lodash.com/docs/#unzip

provenance:
  derived_from:
    - "lodash.unzip README — https://www.npmjs.com/package/lodash.unzip"
    - "Test vectors verified with lodash.unzip@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.unzip exports the _.unzip function directly as module.exports."
    - "unzip(array) accepts an array of grouped elements and regroupes by position."
    - "Inverse of _.zip."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns regrouped array of arrays."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_unzip.unzip:
  kind: node_module_call_eq
  function: ~
  category: unzip
  id_prefix: luz

  columns: [id, args, expected]
  rows:
    - [two_groups,   [[[1, "a"], [2, "b"], [3, "c"]]],
       [[1, 2, 3], ["a", "b", "c"]]]
    - [three_cols,   [[[1, "x", true], [2, "y", false]]],
       [[1, 2], ["x", "y"], [true, false]]]
