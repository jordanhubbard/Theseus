    - "object-rename-keys README — https://www.npmjs.com/package/object-rename-keys"
    - "Test vectors verified with object-rename-keys via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "object-rename-keys source"
  notes:
    - "object-rename-keys is an npm package. Install: npm install object-rename-keys"
    - "Returns a copy of the object with specified keys renamed according to a mapping."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_rename_keys.rename:
  kind: node_module_call_eq
  function: ~
  category: objects
  id_prefix: orkk

  columns: [id, args, expected]
  rows:
    - [two_renames, [{"a": 1, "b": 2, "c": 3}, {"a": "x", "b": "y"}], {"c": 3, "x": 1, "y": 2}]
    - [one_rename,  [{"foo": 1, "bar": 2}, {"foo": "baz"}],            {"bar": 2, "baz": 1}]

