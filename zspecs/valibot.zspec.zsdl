spec: valibot
version: ">=1.0.0"
backend: node(valibot)

docs: https://valibot.dev

provenance:
  derived_from:
    - "Valibot docs — https://valibot.dev"
    - "Test vectors verified with valibot via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "valibot source"
  notes:
    - "Modular bundle-size-optimized schema validator — alternative to zod / yup."
    - "Install: npm install valibot"
    - "v1 ESM only; named exports per validator (string, number, boolean, object, array, ...) plus parse / safeParse pipelines."
    - "Validator functions return schema objects with stable .kind / .type / .expects shape."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "parse() throws ValiError on failure; safeParse() returns {success, output, issues}."
  stderr: "null"
  stickiness: "N/A — schemas are immutable values."
  codes: {}

invariant valibot.string_kind_is_schema:
  description: "string() returns a schema (kind === 'schema')"
  category: shape
  kind: node_chain_eq
  entry: named
  function: string
  entry_args: []
  chain:
    - {get: kind}
  expected: "schema"

invariant valibot.string_type_is_string:
  description: "string().type is 'string'"
  category: shape
  kind: node_chain_eq
  entry: named
  function: string
  entry_args: []
  chain:
    - {get: type}
  expected: "string"

invariant valibot.string_expects:
  description: "string().expects is 'string'"
  category: shape
  kind: node_chain_eq
  entry: named
  function: string
  entry_args: []
  chain:
    - {get: expects}
  expected: "string"

invariant valibot.string_async_false:
  description: "string().async is false (synchronous validator)"
  category: shape
  kind: node_chain_eq
  entry: named
  function: string
  entry_args: []
  chain:
    - {get: async}
  expected: false

invariant valibot.number_type:
  description: "number().type is 'number'"
  category: shape
  kind: node_chain_eq
  entry: named
  function: number
  entry_args: []
  chain:
    - {get: type}
  expected: "number"

invariant valibot.boolean_type:
  description: "boolean().type is 'boolean'"
  category: shape
  kind: node_chain_eq
  entry: named
  function: boolean
  entry_args: []
  chain:
    - {get: type}
  expected: "boolean"

invariant valibot.any_type:
  description: "any().type is 'any'"
  category: shape
  kind: node_chain_eq
  entry: named
  function: any
  entry_args: []
  chain:
    - {get: type}
  expected: "any"

invariant valibot.null_type:
  description: "null_().type is 'null'"
  category: shape
  kind: node_chain_eq
  entry: named
  function: null_
  entry_args: []
  chain:
    - {get: type}
  expected: "null"

invariant valibot.number_kind:
  description: "number().kind is 'schema'"
  category: shape
  kind: node_chain_eq
  entry: named
  function: number
  entry_args: []
  chain:
    - {get: kind}
  expected: "schema"
