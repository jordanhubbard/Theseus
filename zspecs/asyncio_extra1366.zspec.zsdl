spec: asyncio_extra1366
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio: Asynchronous I/O"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks."
    - "asyncio.Queue, Task, Future, Lock, Event, Semaphore, Barrier are all pure-Python classes."
    - "__flags__, __basicsize__, and __itemsize__ are type object attributes present on every Python class."
    - "Only the types (int) of these attributes are checked — exact integer values are platform-specific."
    - "asyncio.Queue.__flags__.__class__.__name__ == 'int' on all CPython platforms."
    - "asyncio.Task.__basicsize__.__class__.__name__ == 'int' on all CPython platforms."
    - "asyncio.Barrier was added in Python 3.11; verified present on Darwin 25.4.0 with Python 3.12+."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra1366.Queue_Task_flags_basicsize_itemsize:
  description: "asyncio.Queue and asyncio.Task __flags__, __basicsize__, __itemsize__ are all of type int"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: as1366qt
  columns: [id, function, args, expected]
  rows:
    - [as1366qt001, asyncio.Queue.__flags__.__class__.__name__.__eq__,     ["int"], true]
    - [as1366qt002, asyncio.Queue.__basicsize__.__class__.__name__.__eq__, ["int"], true]
    - [as1366qt003, asyncio.Queue.__itemsize__.__class__.__name__.__eq__,  ["int"], true]
    - [as1366qt004, asyncio.Task.__flags__.__class__.__name__.__eq__,      ["int"], true]
    - [as1366qt005, asyncio.Task.__basicsize__.__class__.__name__.__eq__,  ["int"], true]
    - [as1366qt006, asyncio.Task.__itemsize__.__class__.__name__.__eq__,   ["int"], true]

