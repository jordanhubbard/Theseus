spec: inspect_extra78
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra77.zspec.zsdl."
    - "This spec covers: inspect getsource/getdoc/getcomments code attrs + stack/trace code attrs + currentframe class name and module (Wave 244)."
    - "getsource.__code__.co_name == 'getsource' — code object name matches function name. Verified with Python 3.14.3."
    - "getsource.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "getdoc.__code__.co_name == 'getdoc' — code object name matches function name. Verified with Python 3.14.3."
    - "getdoc.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "getcomments.__code__.co_name == 'getcomments' — code object name matches function name. Verified with Python 3.14.3."
    - "getcomments.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "stack.__code__.co_name == 'stack' — code object name matches function name. Verified with Python 3.14.3."
    - "stack.__code__.co_argcount == 1 — stack(context=1) has one positional-or-keyword arg with default. Verified with Python 3.14.3."
    - "trace.__code__.co_name == 'trace' — code object name matches function name. Verified with Python 3.14.3."
    - "trace.__code__.co_argcount == 1 — trace(context=1) has one positional-or-keyword arg with default. Verified with Python 3.14.3."
    - "currentframe.__class__.__name__ == 'function' — inspect.currentframe is a pure-Python wrapper around sys._getframe. Verified with Python 3.14.3."
    - "currentframe.__module__ == 'inspect' — currentframe is defined in the inspect module. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getsource and getdoc code objects — extra78
#
# Wave 244 theme: getsource/getdoc code object attributes.
#
# inspect.getsource.__code__.co_name     == 'getsource'
# inspect.getsource.__code__.co_argcount == 1
# inspect.getdoc.__code__.co_name        == 'getdoc'
# inspect.getdoc.__code__.co_argcount    == 1
#
# No prior inspect spec checks getsource/getdoc code objects via inspmore78. New to extra78.
# ---------------------------------------------------------------------------

table inspect_extra78.getsource_getdoc_code:
  description: "getsource.__code__.co_name=='getsource', co_argcount==1; getdoc co_name=='getdoc', co_argcount==1; wave 244 getsource/getdoc code attrs; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore78

  columns: [id, function, args, expected, description]
  rows:
    - [getsource_code_co_name_eq_getsource,
       getsource.__code__.co_name.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__code__.co_name.__eq__('getsource') == True — getsource is a pure-Python function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'getsource' (9 chars); str.__eq__('getsource') returns True; no prior inspect spec checks getsource.__code__.co_name via inspmore78; new to extra78"]
    - [getsource_code_co_argcount_eq_1,
       getsource.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getsource.__code__.co_argcount.__eq__(1) == True — getsource(object) takes exactly one positional argument 'object'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getsource.__code__.co_argcount via inspmore78; new to extra78"]
    - [getdoc_code_co_name_eq_getdoc,
       getdoc.__code__.co_name.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__code__.co_name.__eq__('getdoc') == True — getdoc is a pure-Python function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'getdoc' (6 chars); str.__eq__('getdoc') returns True; no prior inspect spec checks getdoc.__code__.co_name via inspmore78; new to extra78"]
    - [getdoc_code_co_argcount_eq_1,
       getdoc.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — getdoc(object) takes exactly one positional argument 'object'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getdoc.__code__.co_argcount via inspmore78; new to extra78"]

# ---------------------------------------------------------------------------
# getcomments code object — extra78
#
# Wave 244 theme: getcomments code object attributes.
#
# inspect.getcomments.__code__.co_name     == 'getcomments'
# inspect.getcomments.__code__.co_argcount == 1
#
# No prior inspect spec checks getcomments code objects via inspmore78. New to extra78.
# ---------------------------------------------------------------------------

table inspect_extra78.getcomments_code:
  description: "getcomments.__code__.co_name=='getcomments', co_argcount==1; wave 244 getcomments code attrs; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore78

  columns: [id, function, args, expected, description]
  rows:
    - [getcomments_code_co_name_eq_getcomments,
       getcomments.__code__.co_name.__eq__,
       ["getcomments"],
       true,
       "inspect.getcomments.__code__.co_name.__eq__('getcomments') == True — getcomments is a pure-Python function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'getcomments' (11 chars); str.__eq__('getcomments') returns True; no prior inspect spec checks getcomments.__code__.co_name via inspmore78; new to extra78"]
    - [getcomments_code_co_argcount_eq_1,
       getcomments.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getcomments.__code__.co_argcount.__eq__(1) == True — getcomments(object) takes exactly one positional argument 'object'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getcomments.__code__.co_argcount via inspmore78; new to extra78"]

# ---------------------------------------------------------------------------
# stack and trace code objects — extra78
#
# Wave 244 theme: stack/trace code object attributes.
#
# inspect.stack.__code__.co_name     == 'stack'
# inspect.stack.__code__.co_argcount == 1
# inspect.trace.__code__.co_name     == 'trace'
# inspect.trace.__code__.co_argcount == 1
#
# No prior inspect spec checks stack/trace code objects via inspmore78. New to extra78.
# ---------------------------------------------------------------------------

table inspect_extra78.stack_trace_code:
  description: "stack.__code__.co_name=='stack', co_argcount==1; trace co_name=='trace', co_argcount==1; wave 244 stack/trace code attrs; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore78

  columns: [id, function, args, expected, description]
  rows:
    - [stack_code_co_name_eq_stack,
       stack.__code__.co_name.__eq__,
       ["stack"],
       true,
       "inspect.stack.__code__.co_name.__eq__('stack') == True — stack is a pure-Python function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'stack' (5 chars); str.__eq__('stack') returns True; no prior inspect spec checks stack.__code__.co_name via inspmore78; new to extra78"]
    - [stack_code_co_argcount_eq_1,
       stack.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.stack.__code__.co_argcount.__eq__(1) == True — stack(context=1) takes one positional-or-keyword argument 'context' with a default value of 1; co_argcount counts positional-or-keyword args regardless of defaults, so it is 1; int.__eq__(1) returns True; no prior inspect spec checks stack.__code__.co_argcount via inspmore78; new to extra78"]
    - [trace_code_co_name_eq_trace,
       trace.__code__.co_name.__eq__,
       ["trace"],
       true,
       "inspect.trace.__code__.co_name.__eq__('trace') == True — trace is a pure-Python function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'trace' (5 chars); str.__eq__('trace') returns True; no prior inspect spec checks trace.__code__.co_name via inspmore78; new to extra78"]
    - [trace_code_co_argcount_eq_1,
       trace.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.trace.__code__.co_argcount.__eq__(1) == True — trace(context=1) takes one positional-or-keyword argument 'context' with a default value of 1; co_argcount counts positional-or-keyword args regardless of defaults, so it is 1; int.__eq__(1) returns True; no prior inspect spec checks trace.__code__.co_argcount via inspmore78; new to extra78"]

# ---------------------------------------------------------------------------
# currentframe class name and module — extra78
#
# Wave 244 theme: currentframe is a pure-Python wrapper in the inspect module.
#
# inspect.currentframe.__class__.__name__ == 'function'
# inspect.currentframe.__module__         == 'inspect'
#
# No prior inspect spec checks currentframe attrs via inspmore78. New to extra78.
# ---------------------------------------------------------------------------

table inspect_extra78.currentframe_attrs:
  description: "currentframe.__class__.__name__=='function', __module__=='inspect'; wave 244 currentframe attrs; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore78

  columns: [id, function, args, expected, description]
  rows:
    - [currentframe_class_name_eq_function,
       currentframe.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.currentframe.__class__.__name__.__eq__('function') == True — inspect.currentframe is a pure-Python wrapper function defined in Lib/inspect.py that calls sys._getframe; its __class__.__name__ is 'function' (8 chars); str.__eq__('function') returns True; no prior inspect spec checks currentframe.__class__.__name__ via inspmore78; new to extra78"]
    - [currentframe_module_eq_inspect,
       currentframe.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.currentframe.__module__.__eq__('inspect') == True — inspect.currentframe is defined in Lib/inspect.py and its __module__ attribute records the module name 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks currentframe.__module__ via inspmore78; new to extra78"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra78
# ---------------------------------------------------------------------------

invariant inspect_extra78.getsource_code_co_name:
  description: "inspect.getsource.__code__.co_name.__eq__('getsource') == True — getsource code object name is 'getsource'; wave 244 getsource code attrs; new to extra78"
  kind: python_call_eq
  function: getsource.__code__.co_name.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra78.getsource_code_co_argcount:
  description: "inspect.getsource.__code__.co_argcount.__eq__(1) == True — getsource takes one argument (object); wave 244 getsource code attrs; new to extra78"
  kind: python_call_eq
  function: getsource.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra78.getcomments_code_co_name:
  description: "inspect.getcomments.__code__.co_name.__eq__('getcomments') == True — getcomments code object name is 'getcomments'; wave 244 getcomments code attrs; new to extra78"
  kind: python_call_eq
  function: getcomments.__code__.co_name.__eq__
  args: ["getcomments"]
  expected: true

invariant inspect_extra78.stack_code_co_argcount:
  description: "inspect.stack.__code__.co_argcount.__eq__(1) == True — stack(context=1) has 1 positional-or-keyword arg; wave 244 stack code attrs; new to extra78"
  kind: python_call_eq
  function: stack.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra78.currentframe_module:
  description: "inspect.currentframe.__module__.__eq__('inspect') == True — currentframe is defined in the inspect module; wave 244 currentframe attrs; new to extra78"
  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true
