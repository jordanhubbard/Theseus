spec: is_primitive
version: ">=3.0.1"
backend: node(is-primitive)

docs: https://www.npmjs.com/package/is-primitive

provenance:
  derived_from:
    - "is-primitive README — https://www.npmjs.com/package/is-primitive"
    - "Test vectors verified with is-primitive via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-primitive source"
  notes:
    - "is-primitive is an npm package. Install: npm install is-primitive"
    - "Returns true if the value is a primitive (number, string, boolean, null, undefined, symbol, bigint)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_primitive.isPrimitive:
  kind: node_module_call_eq
  function: ~
  category: type
  id_prefix: isprim

  columns: [id, args, expected]
  rows:
    - [num,     [42],       true]
    - [str,     ["hello"],  true]
    - [bool,    [true],     true]
    - [null_v,  [null],     true]
    - [obj,     [{}],       false]
    - [array,   [[1, 2]],   false]
