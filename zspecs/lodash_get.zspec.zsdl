spec: lodash_get
version: ">=4.0.0"
backend: node(lodash.get)

docs: https://lodash.com/docs/#get

provenance:
  derived_from:
    - "lodash.get README — https://www.npmjs.com/package/lodash.get"
    - "Test vectors verified with lodash.get@4.4.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.get exports the _.get function directly as module.exports."
    - "get(object, path, defaultValue) gets the value at path of object."
    - "Path can be a dot-notation string or array of keys."
    - "Returns defaultValue if path resolves to undefined."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns value at path or defaultValue."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_get.get:
  kind: node_module_call_eq
  function: ~
  category: get
  id_prefix: lget

  columns: [id, args, expected]
  rows:
    - [simple,    [{"a": 1}, "a"],                          1]
    - [nested,    [{"a": {"b": {"c": 3}}}, "a.b.c"],        3]
    - [array,     [{"a": [10, 20, 30]}, "a[1]"],            20]
    - [default,   [{"a": 1}, "b", 42],                      42]
    - [missing,   [{"a": 1}, "x.y", null],                  null]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:26:14Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
