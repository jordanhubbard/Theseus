spec: lodash_get
version: ">=4.0.0"
backend: node(lodash.get)

docs: https://lodash.com/docs/#get

provenance:
  derived_from:
    - "lodash.get README — https://www.npmjs.com/package/lodash.get"
    - "Test vectors verified with lodash.get@4.4.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.get exports the _.get function directly as module.exports."
    - "get(object, path) retrieves a nested value using dot-notation or bracket-notation path."
    - "get(object, path, defaultValue) returns defaultValue when the path resolves to undefined."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the resolved value or undefined. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_get.get:
  kind: node_module_call_eq
  function: ~
  category: get
  id_prefix: lg

  columns: [id, args, expected]
  rows:
    - [nested,    [{"a": {"b": 1}}, "a.b"],        1]
    - [top,       [{"x": 2}, "x"],                 2]
    - [default,   [{}, "z", 42],                   42]
    - [array,     [{"a": [1, 2, 3]}, "a[1]"],      2]
