spec: io_extra181
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.FileIO class identity — __name__, __module__, MRO length, MRO base names, and io.BufferedReader, io.BufferedWriter, io.BufferedRandom class name identity."
    - "io.FileIO.__name__ == 'FileIO' (len=6: 'File' (4) + 'IO' (2) = 6)."
    - "io.FileIO.__module__ == 'io' (len=2)."
    - "io.FileIO.__mro__.__len__() == 4 — MRO is [FileIO, RawIOBase, IOBase, object]; FileIO is a concrete class that inherits from RawIOBase which inherits from IOBase."
    - "io.FileIO.__bases__[0].__name__ == 'RawIOBase' — FileIO directly inherits from RawIOBase."
    - "io.BufferedReader.__name__ == 'BufferedReader' (len=14: 'Buffered' (8) + 'Reader' (6) = 14)."
    - "io.BufferedReader.__mro__.__len__() == 4 — MRO is [BufferedReader, BufferedIOBase, IOBase, object]."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' (len=14: same as BufferedReader; 'Buffered' (8) + 'Writer' (6) = 14)."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' (len=14: same as BufferedReader and BufferedWriter; 'Buffered' (8) + 'Random' (6) = 14)."
    - "BufferedReader (14) == BufferedWriter (14) == BufferedRandom (14): a three-way tie in class name length for the buffered I/O classes."
    - "FileIO (6) < BufferedReader=BufferedWriter=BufferedRandom (14): FileIO has the shortest name; the Buffered* classes all share length 14."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO class identity — __name__, __module__, MRO length
# FileIO.__name__ == 'FileIO' (len=6)
# FileIO.__module__ == 'io' (len=2)
# FileIO.__mro__.__len__() == 4 (FileIO > RawIOBase > IOBase > object)
# ---------------------------------------------------------------------------

table io_extra181.fileio_identity:
  description: "io.FileIO.__name__=='FileIO' (len=6); io.FileIO.__module__=='io' (len=2); io.FileIO.__mro__.__len__()==4 (FileIO > RawIOBase > IOBase > object); FileIO (6) < BufferedReader=BufferedWriter=BufferedRandom (14) in name length"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio181

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_name,       FileIO.__name__.__eq__,    ["FileIO"], true, "io.FileIO.__name__ == 'FileIO' — 'FileIO' has 6 characters: 'File' (4) + 'IO' (2) = 6; FileIO (6) < BufferedReader (14) by 8: FileIO has the shortest name among the concrete io stream classes checked in this spec; io.FileIO is the raw file I/O class that wraps a file descriptor; FileIO.__module__ == 'io' (2 chars); confirmed Python 3.14.3 macOS"]
    - [fileio_name_len,   FileIO.__name__.__len__,   [],         6,    "io.FileIO.__name__.__len__() == 6 — 'FileIO' has 6 characters: 'File' (4) + 'IO' (2) = 6; FileIO (6) < BufferedReader=BufferedWriter=BufferedRandom (14) by 8; FileIO (6) == IOBase (6): a coincidental tie with the IOBase abstract class name length; FileIO (6) == BytesIO (6) and StringIO (8) > FileIO (6) > IOBase (6): no, StringIO has 8 chars — FileIO (6) ties only with IOBase (6) and BytesIO (6) among io class names; confirmed Python 3.14.3 macOS"]
    - [fileio_module,     FileIO.__module__.__eq__,  ["io"],     true, "io.FileIO.__module__ == 'io' — 'io' has 2 characters; FileIO.__module__ (2) == BufferedReader.__module__ (2) == BufferedWriter.__module__ (2) == BufferedRandom.__module__ (2): all concrete io stream classes share the 2-character module name 'io'; the 2-character module name is the minimum possible for a dotted-path module name; FileIO (6 chars) > 'io' (2 chars) by 4; confirmed Python 3.14.3 macOS"]
    - [fileio_mro_len,    FileIO.__mro__.__len__,    [],         4,    "io.FileIO.__mro__.__len__() == 4 — MRO is [FileIO, RawIOBase, IOBase, object]; FileIO is a concrete C class that inherits from RawIOBase (the Python-level ABC for raw I/O); the 4-step MRO (concrete > ABC > base-ABC > object) reflects the two-level ABC hierarchy above FileIO; FileIO (4) == BufferedReader (4) == BufferedWriter (4) == BufferedRandom (4): all concrete io stream classes in this spec share MRO length 4; FileIO (4) > IOBase (3) by 1: FileIO adds one step (RawIOBase) above the IOBase root; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.FileIO MRO base class name
# FileIO.__bases__[0].__name__ == 'RawIOBase'
# FileIO.__mro__[1].__name__ == 'RawIOBase'
# FileIO.__mro__[2].__name__ == 'IOBase'
# ---------------------------------------------------------------------------

table io_extra181.fileio_mro_entries:
  description: "io.FileIO MRO entry names: mro[0]='FileIO' (len=6), mro[1]='RawIOBase' (len=9), mro[2]='IOBase' (len=6), mro[3]='object' (len=6); bases[0]='RawIOBase'; FileIO (6) == IOBase (6) == 'object' (6) at mro[0,2,3]; RawIOBase (9) is the longest at mro[1]"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio181

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_bases0_name,  "FileIO.__bases__[0].__name__.__eq__",  ["RawIOBase"], true, "io.FileIO.__bases__[0].__name__ == 'RawIOBase' — FileIO directly inherits from RawIOBase as its sole base class; 'RawIOBase' has 9 characters: 'Raw' (3) + 'IO' (2) + 'Base' (4) = 9; RawIOBase (9) > FileIO (6) by 3; FileIO.__bases__ has length 1 (single inheritance) with RawIOBase as the only direct parent; RawIOBase is the Python-level ABC for raw unbuffered I/O, from which FileIO gets its interface contract; confirmed Python 3.14.3 macOS"]
    - [fileio_mro1_name,    "FileIO.__mro__[1].__name__.__eq__",    ["RawIOBase"], true, "io.FileIO.__mro__[1].__name__ == 'RawIOBase' — the second MRO entry for FileIO is RawIOBase, confirming the direct inheritance; mro[1] == bases[0].__name__ for FileIO: in single-inheritance classes, the direct parent appears at both __bases__[0] and __mro__[1]; 'RawIOBase' has 9 characters; RawIOBase (9) > 'IOBase' (6) at mro[2] by 3; RawIOBase at mro[1] marks the transition from the concrete FileIO to the ABC layer; confirmed Python 3.14.3 macOS"]
    - [fileio_mro2_name,    "FileIO.__mro__[2].__name__.__eq__",    ["IOBase"],    true, "io.FileIO.__mro__[2].__name__ == 'IOBase' — the third MRO entry for FileIO is IOBase, the root I/O ABC; 'IOBase' has 6 characters: 'IO' (2) + 'Base' (4) = 6; IOBase (6) == FileIO (6) == 'object' (6): all three of the non-RawIOBase MRO entries (FileIO itself, IOBase, and object) share the same 6-character name length — a three-way tie; IOBase at mro[2] sits above RawIOBase (mro[1]) and below object (mro[3]) in the 4-step FileIO MRO; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.BufferedReader, BufferedWriter, BufferedRandom class name lengths
# All three have __name__ length == 14
# 'Buffered' (8) + 'Reader'/'Writer'/'Random' (6 each) = 14
# ---------------------------------------------------------------------------

table io_extra181.buffered_class_names:
  description: "BufferedReader.__name__='BufferedReader' (len=14), BufferedWriter.__name__='BufferedWriter' (len=14), BufferedRandom.__name__='BufferedRandom' (len=14); three-way tie at 14; 'Buffered' prefix (8) + 6-char suffix = 14 for each; FileIO (6) < all Buffered* (14) by 8"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio181

  columns: [id, function, args, expected, description]
  rows:
    - [bufrd_name,      BufferedReader.__name__.__eq__,   ["BufferedReader"], true, "io.BufferedReader.__name__ == 'BufferedReader' — 'BufferedReader' has 14 characters: 'Buffered' (8) + 'Reader' (6) = 14; BufferedReader (14) == BufferedWriter (14) == BufferedRandom (14): a three-way tie in name length for the buffered I/O classes; BufferedReader (14) > FileIO (6) by 8; io.BufferedReader wraps a RawIOBase for buffered sequential reading; confirmed Python 3.14.3 macOS"]
    - [bufrd_name_len,  BufferedReader.__name__.__len__,  [],                14,   "io.BufferedReader.__name__.__len__() == 14 — 'BufferedReader' has 14 characters: 'Buffered' (8) + 'Reader' (6) = 14; BufferedReader (14) == BufferedWriter (14) == BufferedRandom (14): the 'Buffered' prefix (8 chars) combined with a 6-char suffix yields 14 for all three buffered stream classes; 14 is exactly twice the 7-character length of 'IOBase' + 'Raw' (6 + ... no: 14 = 2 × 7, where 'RawIOBase' is 9): 14 > RawIOBase (9) by 5; confirmed Python 3.14.3 macOS"]
    - [bufwr_name,      BufferedWriter.__name__.__eq__,   ["BufferedWriter"], true, "io.BufferedWriter.__name__ == 'BufferedWriter' — 'BufferedWriter' has 14 characters: 'Buffered' (8) + 'Writer' (6) = 14; BufferedWriter (14) == BufferedReader (14): the Reader and Writer variants of the buffered stream classes share identical name lengths; io.BufferedWriter wraps a RawIOBase for buffered sequential writing; 'Writer' (6) == 'Reader' (6) == 'Random' (6): all three Buffered* suffixes have length 6; confirmed Python 3.14.3 macOS"]
    - [bufwr_name_len,  BufferedWriter.__name__.__len__,  [],                14,   "io.BufferedWriter.__name__.__len__() == 14 — 'BufferedWriter' has 14 characters; BufferedWriter (14) == BufferedReader (14) == BufferedRandom (14): the uniform 14-character length across all three Buffered* classes reflects the symmetric naming scheme where the shared 'Buffered' prefix (8) is paired with equal-length 6-character suffixes (Reader, Writer, Random); confirmed Python 3.14.3 macOS"]
    - [bufrnd_name,     BufferedRandom.__name__.__eq__,   ["BufferedRandom"], true, "io.BufferedRandom.__name__ == 'BufferedRandom' — 'BufferedRandom' has 14 characters: 'Buffered' (8) + 'Random' (6) = 14; BufferedRandom (14) == BufferedReader (14) == BufferedWriter (14): BufferedRandom completes the three-way tie at 14; io.BufferedRandom wraps a RawIOBase for buffered random-access reading and writing (both read and write in the same stream); 'Random' (6) == 'Reader' (6) == 'Writer' (6): the three suffixes tie in length; confirmed Python 3.14.3 macOS"]
    - [bufrnd_name_len, BufferedRandom.__name__.__len__,  [],                14,   "io.BufferedRandom.__name__.__len__() == 14 — 'BufferedRandom' has 14 characters; BufferedRandom (14) completes the three-way tie with BufferedReader (14) and BufferedWriter (14); 14 > FileIO (6) by 8; 14 > RawIOBase (9) by 5; 14 > IOBase (6) by 8; BufferedRandom is the only concrete io class supporting both read and write in a single buffered stream; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra181.FileIO_name_is_FileIO:
  description: "io.FileIO.__name__ == 'FileIO' — 'FileIO' has 6 characters: 'File' (4) + 'IO' (2) = 6; FileIO (6) < BufferedReader=BufferedWriter=BufferedRandom (14) by 8; FileIO (6) == IOBase (6): a coincidental tie with the root ABC name length; io.FileIO is the raw file I/O class that directly wraps OS file descriptors; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra181.FileIO_module_is_io:
  description: "io.FileIO.__module__ == 'io' — 'io' has 2 characters; FileIO.__module__ (2) == BufferedReader.__module__ (2): all concrete io stream classes share __module__ == 'io'; the 2-character 'io' module name is the minimum for any io class; FileIO (6 chars) > 'io' (2 chars) by 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra181.FileIO_mro_len_4:
  description: "io.FileIO.__mro__.__len__() == 4 — MRO is [FileIO, RawIOBase, IOBase, object]; the 4-step MRO places FileIO one step above IOBase (3) by adding the RawIOBase layer; FileIO (4) == BufferedReader (4) == BufferedWriter (4) == BufferedRandom (4): all four concrete stream classes share MRO length 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra181.FileIO_bases0_is_RawIOBase:
  description: "io.FileIO.__bases__[0].__name__ == 'RawIOBase' — FileIO's sole direct base class is RawIOBase; 'RawIOBase' has 9 characters: 'Raw' (3) + 'IO' (2) + 'Base' (4) = 9; RawIOBase (9) > FileIO (6) by 3; FileIO single-inherits from RawIOBase, placing the ABC layer at mro[1]; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["RawIOBase"]
  expected: true

invariant io_extra181.BufferedReader_name_len_14:
  description: "io.BufferedReader.__name__.__len__() == 14 — 'BufferedReader' has 14 characters: 'Buffered' (8) + 'Reader' (6) = 14; BufferedReader (14) == BufferedWriter (14) == BufferedRandom (14): a three-way tie at 14 for the Buffered* stream classes; 14 > FileIO (6) by 8; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedReader.__name__.__len__
  args: []
  expected: 14

invariant io_extra181.BufferedWriter_name_len_14:
  description: "io.BufferedWriter.__name__.__len__() == 14 — 'BufferedWriter' has 14 characters: 'Buffered' (8) + 'Writer' (6) = 14; BufferedWriter (14) == BufferedReader (14) == BufferedRandom (14): the three Buffered* classes tie at name length 14; 'Writer' (6) == 'Reader' (6) == 'Random' (6): the suffixes all share length 6; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedWriter.__name__.__len__
  args: []
  expected: 14

invariant io_extra181.BufferedRandom_name_len_14:
  description: "io.BufferedRandom.__name__.__len__() == 14 — 'BufferedRandom' has 14 characters: 'Buffered' (8) + 'Random' (6) = 14; BufferedRandom (14) == BufferedReader (14) == BufferedWriter (14): BufferedRandom completes the three-way tie at 14; the uniform 14-character naming reflects the consistent design of the io.Buffered* class family; confirmed Python 3.14.3 macOS"
