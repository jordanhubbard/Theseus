spec: easing_utils
version: ">=1.0.0"
backend: node(easing-utils)

docs: https://www.npmjs.com/package/easing-utils

provenance:
  derived_from:
    - "easing-utils README — https://www.npmjs.com/package/easing-utils"
    - "Test vectors verified with easing-utils via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "easing-utils source"
  notes:
    - "easing-utils is an npm package. Install: npm install easing-utils"
    - "Provides easing functions for animation (input and output range: 0 to 1)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number between 0 and 1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table easing_utils.linear:
  kind: node_module_call_eq
  function: linear
  category: math
  id_prefix: easelin

  columns: [id, args, expected]
  rows:
    - [zero,  [0],    0]
    - [half,  [0.5],  0.5]
    - [one,   [1],    1]

table easing_utils.easeInQuad:
  kind: node_module_call_eq
  function: easeInQuad
  category: math
  id_prefix: easeinq

  columns: [id, args, expected]
  rows:
    - [zero,  [0],    0]
    - [half,  [0.5],  0.25]
    - [one,   [1],    1]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:35:27Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
