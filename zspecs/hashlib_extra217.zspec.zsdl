spec: hashlib_extra217
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "verified with Python 3.14.3."
    - "hashlib.new('nonexistent_algorithm_xyz') raises ValueError: unsupported hash type nonexistent_algorithm_xyz."
    - "hashlib.new('') raises ValueError: unsupported hash type (empty string)."
    - "hashlib.pbkdf2_hmac('bad_hash', b'password', b'salt', 1) raises ValueError: [digital envelope routines] unsupported."
    - "hashlib.pbkdf2_hmac('sha256', b'password', b'salt', 0) raises ValueError: iteration value must be greater than 0."
    - "hashlib.file_digest('not a file', 'sha256') raises ValueError: 'not a file' is not a file-like object in binary reading mode."
    - "All exception types verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new — raises ValueError on unknown or empty algorithm name
#
# hashlib.new('nonexistent_algorithm_xyz') raises ValueError
# hashlib.new('') raises ValueError
# ---------------------------------------------------------------------------

table hashlib_extra217.new_bad_algo_raises:
  description: "hashlib.new raises ValueError for unknown or empty algorithm names in hashliberr217 namespace — wave 217 theme: hashlib.new('nonexistent_algorithm_xyz') raises ValueError; hashlib.new('') raises ValueError; unsupported hash names are rejected immediately; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: hashliberr217

  columns: [id, function, args, expected, description]
  rows:
    - [new_unknown_algo,  hashlib.new, ["nonexistent_algorithm_xyz"], ValueError, "hashlib.new('nonexistent_algorithm_xyz') raises ValueError — unknown hash algorithm name"]
    - [new_empty_name,    hashlib.new, [""],                          ValueError, "hashlib.new('') raises ValueError — empty string is not a valid hash algorithm name"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac — raises ValueError on bad hash name or zero iterations
#
# hashlib.pbkdf2_hmac('bad_hash', ...) raises ValueError
# hashlib.pbkdf2_hmac('sha256', ..., 0) raises ValueError
# ---------------------------------------------------------------------------

table hashlib_extra217.pbkdf2_hmac_bad_args_raises:
  description: "hashlib.pbkdf2_hmac raises ValueError for invalid hash name or non-positive iteration count in hashliberr217a namespace — wave 217 theme: hashlib.pbkdf2_hmac('bad_hash', b'password', b'salt', 1) raises ValueError; hashlib.pbkdf2_hmac('sha256', b'password', b'salt', 0) raises ValueError; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: hashliberr217a

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_bad_hash_name,     hashlib.pbkdf2_hmac, ["bad_hash", {type: bytes_ascii, value: "password"}, {type: bytes_ascii, value: "salt"}, 1], ValueError, "hashlib.pbkdf2_hmac('bad_hash', ...) raises ValueError — unsupported hash algorithm"]
    - [pbkdf2_zero_iterations,   hashlib.pbkdf2_hmac, ["sha256",   {type: bytes_ascii, value: "password"}, {type: bytes_ascii, value: "salt"}, 0], ValueError, "hashlib.pbkdf2_hmac('sha256', ..., 0) raises ValueError — iteration count must be greater than 0"]

# ---------------------------------------------------------------------------
# hashlib.file_digest — raises ValueError for non-file-like argument
# ---------------------------------------------------------------------------

invariant hashlib_extra217.file_digest_non_file_raises:
  description: "hashlib.file_digest('not a file', 'sha256') raises ValueError — argument is not a file-like object in binary reading mode; hashlib.file_digest validates that its first argument supports the binary read interface before attempting to hash; passing a plain string raises ValueError with a descriptive message; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: hashlib.file_digest
  args: ["not a file", "sha256"]
  expected_exception: ValueError

