  description: "multiprocessing types __hash__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3421

  columns: [id, function, args, expected]
  rows:
    - ["mp3421001", operator.contains, [multiprocessing.Process.__dict__,                 "__hash__"], false]
    - ["mp3421002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__hash__"], false]
    - ["mp3421003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__hash__"], false]
    - ["mp3421004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__hash__"], false]
    - ["mp3421005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__hash__"], false]
    - ["mp3421006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__hash__"], false]
    - ["mp3421007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__hash__"], false]
    - ["mp3421008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ dict-presence — operator.contains(Cls.__dict__, '__eq__')
#
# All 8 multiprocessing classes return false for __eq__.
# == delegates to __eq__ when defined in the class's own __dict__.
# multiprocessing types do not define __eq__ in their own __dict__; equality
#   falls back to inherited identity comparison from object.
# managers.BaseListProxy: relays collection operations to the managed server
#   process via proxy methods, but does not define __eq__ in its __dict__.
# managers._BaseDictProxy: proxies dict operations; __eq__ is not defined
#   in its own __dict__.
# managers._BaseSetProxy: proxies set operations; __eq__ is not defined
#   in its own __dict__.
# multiprocessing.Process: identity-based equality by inheritance; __eq__
#   is absent from Process.__dict__.
# pool.Pool/AsyncResult/MapResult/SyncManager: process-management types with
#   no __eq__ customization in their own __dict__.
# ---------------------------------------------------------------------------

table mp3421.eq:
  description: "multiprocessing types __eq__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3421

  columns: [id, function, args, expected]
  rows:
    - ["mp3421009",  operator.contains, [multiprocessing.Process.__dict__,                 "__eq__"], false]
    - ["mp3421010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__eq__"], false]
    - ["mp3421011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__eq__"], false]
    - ["mp3421012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__eq__"], false]
    - ["mp3421013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__eq__"], false]
    - ["mp3421014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__eq__"], false]
    - ["mp3421015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__eq__"], false]
    - ["mp3421016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__eq__"], false]

# ---------------------------------------------------------------------------
# __lt__ dict-presence — operator.contains(Cls.__dict__, '__lt__')
#
# All 8 multiprocessing classes return false for __lt__.
# < delegates to __lt__ when defined in the class's own __dict__.
# None of the 8 multiprocessing classes define a Python-level __lt__
#   in their own __dict__.
# managers.BaseListProxy key note: BaseListProxy defines __getitem__,
#   __setitem__, __delitem__, __len__, __contains__, __add__, __mul__,
#   and other collection protocol methods in its __dict__, but __lt__
#   is not among them. List ordering is not proxied through __lt__.
# managers._BaseDictProxy: defines dict proxy methods in its __dict__,
#   but not __lt__.
# managers._BaseSetProxy: defines set proxy methods in its __dict__,
#   but not __lt__.
# multiprocessing.Process: no __lt__ defined; processes are not ordered.
# pool.Pool/AsyncResult/MapResult/SyncManager: no __lt__ in their own
#   __dict__; ordering falls back to inherited behavior (raises TypeError
#   at runtime since object has no __lt__).
# ---------------------------------------------------------------------------

table mp3421.lt:
  description: "multiprocessing types __lt__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3421

  columns: [id, function, args, expected]
  rows:
    - ["mp3421017",  operator.contains, [multiprocessing.Process.__dict__,                 "__lt__"], false]
    - ["mp3421018",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__lt__"], false]
    - ["mp3421019",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__lt__"], false]
    - ["mp3421020",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__lt__"], false]
    - ["mp3421021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__lt__"], false]
    - ["mp3421022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__lt__"], false]
    - ["mp3421023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__lt__"], false]
    - ["mp3421024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__lt__"], false]

# ---------------------------------------------------------------------------
# combined — __hash__, __eq__, __lt__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __hash__: false for all 8 — not in any type's own __dict__.
# __eq__: false for all 8 — not in any type's own __dict__.
# __lt__: false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# The proxy types (_BaseSetProxy, _BaseDictProxy, BaseListProxy) are the most
#   analytically interesting subjects here. BaseListProxy proxies list and does
#   define some collection protocol methods (__add__, __mul__, __getitem__, etc.)
#   in its own __dict__ — but __hash__, __eq__, and __lt__ are not among them.
#   _BaseDictProxy and _BaseSetProxy similarly define proxy dispatch methods but
#   not comparison or hashing dunders. The proxy types relay operations to a
#   managed server process via IPC; comparison and hashing are not part of the
#   proxy protocol.
# multiprocessing is a process-based concurrency library; its types interact
#   exclusively through explicit method calls, subprocess lifecycle management,
#   and IPC — not through comparison or hashing protocol overrides in any
#   class __dict__.
# ---------------------------------------------------------------------------

