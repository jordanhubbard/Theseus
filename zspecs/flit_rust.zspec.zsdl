spec: flit_rust
version: ">=3.9"
backend: rust_module(flit_rust)

docs: https://flit.pypa.io/

provenance:
  derived_from:
    - "https://flit.pypa.io/ — flit build tool"
  notes:
    - "flit provides a simple way to put Python packages on PyPI."
    - "flit.upload is importable."
    - "flit.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant flit_rust.has_upload:
  description: "flit.upload is importable"
  category: presence
  kind: python_call_eq
  function: flit_has_upload
  args: []
  expected: true

invariant flit_rust.has_build:
  description: "flit has build module"
  category: presence
  kind: python_call_eq
  function: flit_has_build
  args: []
  expected: true

invariant flit_rust.version_nonempty:
  description: "flit.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: flit_version_nonempty
  args: []
  expected: true

