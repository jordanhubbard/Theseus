spec: fileinput_extra3
version: ">=3.9"
backend: python_module(fileinput)

docs: https://docs.python.org/3/library/fileinput.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fileinput.html — Python fileinput module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fileinput.py"
  notes:
    - "This spec extends fileinput.zspec.zsdl and prior extras."
    - "fileinput.zspec.zsdl covers: FileInput.__name__, FileInput.__module__, and a table of __name__ checks for all module-level functions."
    - "fileinput_extra.zspec.zsdl covers: standalone __name__ invariants for all module-level functions and FileInput, FileInput class type check, callability checks for input/hook_compressed/hook_encoded."
    - "fileinput_extra2.zspec.zsdl covers: __module__ checks for module-level functions, FileInput.__qualname__, FileInput.__bases__[0].__name__=='object', function qualnames table."
    - "This spec adds: hook_compressed.__module__, hook_encoded.__module__, hook_compressed.__qualname__, hook_encoded.__qualname__, nextfile.__qualname__, close.__qualname__, FileInput.__name__ and __module__ as anchor invariants in this spec namespace."
    - "fileinput.hook_compressed.__module__ == 'fileinput' — not covered in fileinput_extra2 function_modules table."
    - "fileinput.hook_encoded.__module__ == 'fileinput' — same rationale."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hook_compressed and hook_encoded — __module__ checks
# fileinput_extra2 function_modules table did not include these two hooks.
# ---------------------------------------------------------------------------

invariant fileinput_extra3.hook_compressed.module:
  description: "fileinput.hook_compressed.__module__ == 'fileinput'"
  category: functions
  kind: python_call_eq
  function: hook_compressed.__module__.__eq__
  args: ["fileinput"]
  expected: true

invariant fileinput_extra3.hook_encoded.module:
  description: "fileinput.hook_encoded.__module__ == 'fileinput'"
  category: functions
  kind: python_call_eq
  function: hook_encoded.__module__.__eq__
  args: ["fileinput"]
  expected: true

# ---------------------------------------------------------------------------
# hook_compressed and hook_encoded — __qualname__ checks
# Module-level functions have __qualname__ == __name__.
# Not covered in fileinput_extra2 function_qualnames table (only covered
# input, filename, fileno, lineno, filelineno, isfirstline, isstdin).
# ---------------------------------------------------------------------------

invariant fileinput_extra3.hook_compressed.qualname:
  description: "fileinput.hook_compressed.__qualname__ == 'hook_compressed'"
  category: functions
  kind: python_call_eq
  function: hook_compressed.__qualname__.__eq__
  args: ["hook_compressed"]
  expected: true

invariant fileinput_extra3.hook_encoded.qualname:
  description: "fileinput.hook_encoded.__qualname__ == 'hook_encoded'"
  category: functions
  kind: python_call_eq
  function: hook_encoded.__qualname__.__eq__
  args: ["hook_encoded"]
  expected: true

# ---------------------------------------------------------------------------
# nextfile and close — __qualname__ checks
# fileinput_extra2 function_qualnames table did not include nextfile or close.
# ---------------------------------------------------------------------------

invariant fileinput_extra3.nextfile.qualname:
  description: "fileinput.nextfile.__qualname__ == 'nextfile'"
  category: functions
  kind: python_call_eq
  function: nextfile.__qualname__.__eq__
  args: ["nextfile"]
  expected: true

invariant fileinput_extra3.close.qualname:
  description: "fileinput.close.__qualname__ == 'close'"
  category: functions
  kind: python_call_eq
  function: close.__qualname__.__eq__
  args: ["close"]
  expected: true

# ---------------------------------------------------------------------------
# FileInput class — __name__ and __module__ anchor invariants in extra3 namespace
# ---------------------------------------------------------------------------

invariant fileinput_extra3.FileInput.name:
  description: "fileinput.FileInput.__name__ == 'FileInput'"
  category: classes
  kind: python_call_eq
  function: FileInput.__name__.__eq__
  args: ["FileInput"]
  expected: true

invariant fileinput_extra3.FileInput.module:
  description: "fileinput.FileInput.__module__ == 'fileinput'"
  category: classes
  kind: python_call_eq
  function: FileInput.__module__.__eq__
  args: ["fileinput"]
  expected: true

invariant fileinput_extra3.FileInput.qualname:
  description: "fileinput.FileInput.__qualname__ == 'FileInput' — the class is not nested"
  category: classes
  kind: python_call_eq
  function: FileInput.__qualname__.__eq__
  args: ["FileInput"]
  expected: true

invariant fileinput_extra3.FileInput.base_is_object:
  description: "fileinput.FileInput.__bases__[0].__name__ == 'object' — FileInput inherits from object"
  category: classes
  kind: python_call_eq
  function: FileInput.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
