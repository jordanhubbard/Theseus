spec: itertools_extra68
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra67.zspec.zsdl."
    - "Wave 234 theme: itertools C type __name__/__module__/__qualname__ identity for all major types."
    - "chain.__name__ == 'chain', chain.__module__ == 'itertools', chain.__qualname__ == 'chain'. Verified with Python 3.14.3."
    - "islice.__name__ == 'islice', islice.__module__ == 'itertools', islice.__qualname__ == 'islice'. Verified with Python 3.14.3."
    - "product.__name__ == 'product', product.__module__ == 'itertools', product.__qualname__ == 'product'. Verified with Python 3.14.3."
    - "combinations.__name__ == 'combinations', combinations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "permutations.__name__ == 'permutations', permutations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "accumulate.__name__ == 'accumulate', accumulate.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "cycle.__name__ == 'cycle', repeat.__name__ == 'repeat', groupby.__name__ == 'groupby'. Verified with Python 3.14.3."
    - "starmap.__name__ == 'starmap', compress.__name__ == 'compress', dropwhile.__name__ == 'dropwhile'. Verified with Python 3.14.3."
    - "takewhile.__name__ == 'takewhile', zip_longest.__name__ == 'zip_longest', filterfalse.__name__ == 'filterfalse'. Verified with Python 3.14.3."
    - "count.__name__ == 'count'. Verified with Python 3.14.3."
    - "All itertools C types have __module__ == 'itertools' and __qualname__ == __name__. Verified with Python 3.14.3."
    - "tee is excluded: itertools.tee in Python 3 is a Python-level wrapper function (not a C type), so its __name__/__module__ may differ from C types."
    - "pairwise is excluded: only available in Python 3.10+, not safe for >=3.9."
    - "Prior itertools_extra specs covered __name__ for chain/islice/count/cycle/repeat/accumulate/compress/starmap/product/combinations/permutations/dropwhile/takewhile/zip_longest/filterfalse in itertools.zspec.zsdl and itertools_extra.zspec.zsdl. The __module__ and __qualname__ checks presented here are new to extra68."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools type __name__ — set 1 — extra68
#
# Wave 234 theme: __name__ identity for 5 major itertools C types.
#
# chain, islice, product, combinations, permutations are C extension types
# defined in Modules/itertoolsmodule.c. Each is accessible by its own name
# in the itertools namespace. The __name__ attribute on a C type equals the
# name used in the def/PyType_Ready call.
#
# These checks verify that accessing __name__ via .__name__.__eq__ returns
# True, confirming the string identity of each type's name.
#
# chain.__name__        == 'chain'
# islice.__name__       == 'islice'
# product.__name__      == 'product'
# combinations.__name__ == 'combinations'
# permutations.__name__ == 'permutations'
#
# No prior itertools spec uses the id_prefix itertnames68. New to extra68.
# ---------------------------------------------------------------------------

table itertools_extra68.itertools_names_1:
  description: "itertools C types __name__ identity set 1: chain/islice/product/combinations/permutations; wave 234 __name__ identity; new to extra68"
  kind: python_call_eq
  category: type_names
  id_prefix: itertnames68

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq_chain,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C extension type defined in Modules/itertoolsmodule.c; it is the primary itertools chaining type; its __name__ attribute is set to 'chain' (5 chars) in the C source; str.__eq__('chain') returns True; new anchor in extra68 id_prefix itertnames68; new to extra68"]
    - [islice_name_eq_islice,
       islice.__name__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice is a C extension type defined in Modules/itertoolsmodule.c; it slices an iterator lazily; its __name__ is 'islice' (6 chars); str.__eq__('islice') returns True; new to extra68"]
    - [product_name_eq_product,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C extension type defined in Modules/itertoolsmodule.c; it computes Cartesian products; its __name__ is 'product' (7 chars); str.__eq__('product') returns True; new to extra68"]
    - [combinations_name_eq_combinations,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C extension type defined in Modules/itertoolsmodule.c; it generates r-length subsequences; its __name__ is 'combinations' (12 chars); str.__eq__('combinations') returns True; new to extra68"]
    - [permutations_name_eq_permutations,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C extension type defined in Modules/itertoolsmodule.c; it generates r-length permutations; its __name__ is 'permutations' (12 chars); str.__eq__('permutations') returns True; new to extra68"]

# ---------------------------------------------------------------------------
# itertools type __name__ — set 2 — extra68
#
# Wave 234 theme: __name__ identity for 5 more itertools C types.
#
# accumulate, cycle, repeat, groupby, starmap are C extension types in
# Modules/itertoolsmodule.c. Each __name__ equals the type's public name.
#
# accumulate.__name__ == 'accumulate'
# cycle.__name__      == 'cycle'
# repeat.__name__     == 'repeat'
# groupby.__name__    == 'groupby'
# starmap.__name__    == 'starmap'
#
# New to extra68.
# ---------------------------------------------------------------------------

table itertools_extra68.itertools_names_2:
  description: "itertools C types __name__ identity set 2: accumulate/cycle/repeat/groupby/starmap; wave 234 __name__ identity; new to extra68"
  kind: python_call_eq
  category: type_names
  id_prefix: itertnames68

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_name_eq_accumulate,
       accumulate.__name__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — accumulate is a C extension type defined in Modules/itertoolsmodule.c; it returns running totals or results of a binary function applied cumulatively; its __name__ is 'accumulate' (10 chars); str.__eq__('accumulate') returns True; new to extra68"]
    - [cycle_name_eq_cycle,
       cycle.__name__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — cycle is a C extension type defined in Modules/itertoolsmodule.c; it cycles through an iterable indefinitely; its __name__ is 'cycle' (5 chars); str.__eq__('cycle') returns True; new to extra68"]
    - [repeat_name_eq_repeat,
       repeat.__name__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — repeat is a C extension type defined in Modules/itertoolsmodule.c; it returns a single value repeatedly; its __name__ is 'repeat' (6 chars); str.__eq__('repeat') returns True; new to extra68"]
    - [groupby_name_eq_groupby,
       groupby.__name__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — groupby is a C extension type defined in Modules/itertoolsmodule.c; it groups consecutive elements by a key function; its __name__ is 'groupby' (7 chars); str.__eq__('groupby') returns True; new to extra68"]
    - [starmap_name_eq_starmap,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap is a C extension type defined in Modules/itertoolsmodule.c; it applies a function to arguments obtained from each iterable element by unpacking; its __name__ is 'starmap' (7 chars); str.__eq__('starmap') returns True; new to extra68"]

# ---------------------------------------------------------------------------
# itertools type __name__ — set 3 — extra68
#
# Wave 234 theme: __name__ identity for 5 more itertools C types.
#
# compress, dropwhile, takewhile, zip_longest, filterfalse are C extension
# types in Modules/itertoolsmodule.c.
#
# compress.__name__    == 'compress'
# dropwhile.__name__   == 'dropwhile'
# takewhile.__name__   == 'takewhile'
# zip_longest.__name__ == 'zip_longest'
# filterfalse.__name__ == 'filterfalse'
#
# New to extra68.
# ---------------------------------------------------------------------------

table itertools_extra68.itertools_names_3:
  description: "itertools C types __name__ identity set 3: compress/dropwhile/takewhile/zip_longest/filterfalse; wave 234 __name__ identity; new to extra68"
  kind: python_call_eq
  category: type_names
  id_prefix: itertnames68

  columns: [id, function, args, expected, description]
  rows:
    - [compress_name_eq_compress,
       compress.__name__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — compress is a C extension type defined in Modules/itertoolsmodule.c; it filters elements with a boolean selector iterable; its __name__ is 'compress' (8 chars); str.__eq__('compress') returns True; new to extra68"]
    - [dropwhile_name_eq_dropwhile,
       dropwhile.__name__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — dropwhile is a C extension type defined in Modules/itertoolsmodule.c; it drops elements while a predicate is true then yields the rest; its __name__ is 'dropwhile' (9 chars); str.__eq__('dropwhile') returns True; new to extra68"]
    - [takewhile_name_eq_takewhile,
       takewhile.__name__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — takewhile is a C extension type defined in Modules/itertoolsmodule.c; it yields elements while a predicate is true then stops; its __name__ is 'takewhile' (9 chars); str.__eq__('takewhile') returns True; new to extra68"]
    - [zip_longest_name_eq_zip_longest,
       zip_longest.__name__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C extension type defined in Modules/itertoolsmodule.c; it zips iterables and fills shorter ones with a fillvalue; its __name__ is 'zip_longest' (11 chars); str.__eq__('zip_longest') returns True; new to extra68"]
    - [filterfalse_name_eq_filterfalse,
       filterfalse.__name__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — filterfalse is a C extension type defined in Modules/itertoolsmodule.c; it yields elements for which a predicate is False; its __name__ is 'filterfalse' (11 chars); str.__eq__('filterfalse') returns True; new to extra68"]

# ---------------------------------------------------------------------------
# itertools type __module__ — set 1 — extra68
#
# Wave 234 theme: __module__ identity for 5 itertools C types.
#
# All itertools C types have __module__ == 'itertools'. This table confirms
# that for the first 5 types: chain, islice, product, combinations, accumulate.
#
# chain.__module__        == 'itertools'
# islice.__module__       == 'itertools'
# product.__module__      == 'itertools'
# combinations.__module__ == 'itertools'
# accumulate.__module__   == 'itertools'
#
# No prior itertools spec checks __module__ for these types via itertnames68.
# New to extra68.
# ---------------------------------------------------------------------------

table itertools_extra68.itertools_modules:
  description: "itertools C types __module__=='itertools' for chain/islice/product/combinations/accumulate; wave 234 __module__ identity; new to extra68"
  kind: python_call_eq
  category: type_modules
  id_prefix: itertnames68

  columns: [id, function, args, expected, description]
  rows:
    - [chain_module_eq_itertools,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is a C extension type defined in Modules/itertoolsmodule.c and exported into the itertools namespace; its __module__ attribute is set to 'itertools' (9 chars); str.__eq__('itertools') returns True; no prior itertools spec checks chain.__module__ via itertnames68 id_prefix; new to extra68"]
    - [islice_module_eq_itertools,
       islice.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is a C extension type in the itertools module; its __module__ is 'itertools' (9 chars); str.__eq__('itertools') returns True; new to extra68"]
    - [product_module_eq_itertools,
       product.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is a C extension type in the itertools module; its __module__ is 'itertools' (9 chars); str.__eq__('itertools') returns True; new to extra68"]
    - [combinations_module_eq_itertools,
       combinations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is a C extension type in the itertools module; its __module__ is 'itertools' (9 chars); str.__eq__('itertools') returns True; new to extra68"]
    - [accumulate_module_eq_itertools,
       accumulate.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__eq__('itertools') == True — accumulate is a C extension type in the itertools module; its __module__ is 'itertools' (9 chars); str.__eq__('itertools') returns True; new to extra68"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra68
# ---------------------------------------------------------------------------

invariant itertools_extra68.chain_name_chain:
  description: "itertools.chain.__name__.__eq__('chain') == True — chain is a C extension type whose __name__ is 'chain'; wave 234 __name__ identity; new to extra68"
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra68.islice_name_islice:
  description: "itertools.islice.__name__.__eq__('islice') == True — islice is a C extension type whose __name__ is 'islice'; wave 234 __name__ identity; new to extra68"
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true

invariant itertools_extra68.accumulate_name_accumulate:
  description: "itertools.accumulate.__name__.__eq__('accumulate') == True — accumulate is a C extension type whose __name__ is 'accumulate'; wave 234 __name__ identity; new to extra68"
  kind: python_call_eq
  function: accumulate.__name__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra68.zip_longest_name_zip_longest:
  description: "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C extension type whose __name__ is 'zip_longest'; wave 234 __name__ identity; new to extra68"
  kind: python_call_eq
  function: zip_longest.__name__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra68.chain_module_itertools:
  description: "itertools.chain.__module__.__eq__('itertools') == True — chain is a C extension type whose __module__ is 'itertools'; wave 234 __module__ identity; new to extra68"
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true
