spec: struct_extra84
version: ">=3.9"
extends: struct_extra83
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra83.zspec.zsdl — covers module-level function __qualname__.__eq__ for pack/unpack/pack_into/unpack_from/iter_unpack/calcsize / Struct.__dict__.__contains__ for pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct_extra82.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ / Struct.__name__/__qualname__/__bases__[0].__name__/__mro__.__len__() / Struct.iter_unpack.__qualname__.__eq__ (table + invariants)."
    - "struct_extra80.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack/__repr__/format/size __qualname__.__eq__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra83; it does NOT duplicate invariants present in those files."
    - "Wave 254 theme: struct.Struct method __qualname__ string lengths / module-level function __qualname__ string lengths / Struct and error name string lengths."
    - "struct.Struct.pack.__qualname__.__len__() == 11 ('Struct.pack' = 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__.__len__() == 13 ('Struct.unpack' = 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__.__len__() == 16 ('Struct.pack_into' = 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__.__len__() == 18 ('Struct.unpack_from' = 18). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__.__len__() == 18 ('Struct.iter_unpack' = 18). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__.__len__() == 4 ('pack' = 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__.__len__() == 6 ('unpack' = 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__.__len__() == 9 ('pack_into' = 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__.__len__() == 11 ('unpack_from' = 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__.__len__() == 11 ('iter_unpack' = 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__.__len__() == 8 ('calcsize' = 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__.__len__() == 6 ('Struct' = 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__.__len__() == 6 ('Struct' = 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__.__len__() == 5 ('error' = 5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__.__len__() == 5 ('error' = 5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack/__qualname__/__len__() == 11
# struct.Struct.unpack/__qualname__/__len__() == 13
# struct.Struct.pack_into/__qualname__/__len__() == 16
# struct.Struct.unpack_from/__qualname__/__len__() == 18
#
# Wave 254 theme: Struct method qualname string lengths (group 1).
#
# Struct method __qualname__ strings are 'Struct.pack' (11), 'Struct.unpack' (13),
# 'Struct.pack_into' (16), 'Struct.unpack_from' (18). struct_extra82 anchors
# the full string equality; this table anchors the __len__ values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra84.struct_method_qualname_lengths_group1:
  description: "struct.Struct.pack/__qualname__/__len__()==11 / Struct.unpack/__qualname__/__len__()==13 / Struct.pack_into/__qualname__/__len__()==16 / Struct.unpack_from/__qualname__/__len__()==18 — Struct method __qualname__ strings use the 'Struct.<name>' form; pack=11 chars, unpack=13, pack_into=16, unpack_from=18; struct_extra82 anchors the string equality; this table anchors the __len__ values under structquallen84; first structquallen84 anchor for Struct method qualname lengths"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structquallen84

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_qualname_len,      Struct.pack.__qualname__.__len__,      [], 11]
    - [struct_unpack_qualname_len,    Struct.unpack.__qualname__.__len__,    [], 13]
    - [struct_pack_into_qualname_len, Struct.pack_into.__qualname__.__len__, [], 16]
    - [struct_unpack_from_qualname_len, Struct.unpack_from.__qualname__.__len__, [], 18]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack/__qualname__/__len__() == 18
# struct.pack/__qualname__/__len__() == 4
# struct.unpack/__qualname__/__len__() == 6
# struct.pack_into/__qualname__/__len__() == 9
#
# Wave 254 theme: Struct iter_unpack qualname length + module function qualname lengths (group 1).
#
# Struct.iter_unpack has __qualname__ 'Struct.iter_unpack' (18 chars, same as
# unpack_from). Module-level functions pack/unpack/pack_into have bare qualnames
# of length 4/6/9 respectively. struct_extra82/83 anchors the string equality;
# this table anchors the __len__ values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra84.struct_module_func_qualname_lengths_group1:
  description: "struct.Struct.iter_unpack/__qualname__/__len__()==18 / struct.pack/__qualname__/__len__()==4 / struct.unpack/__qualname__/__len__()==6 / struct.pack_into/__qualname__/__len__()==9 — Struct.iter_unpack qualname is 18 chars (same as unpack_from); module-level pack is 4 chars (bare name), unpack is 6, pack_into is 9; this table anchors the __len__ values for these four under structquallen84; first structquallen84 anchor for module-level function qualname lengths"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structquallen84

  columns: [id, function, args, expected]
  rows:
    - [struct_iter_unpack_qualname_len,  Struct.iter_unpack.__qualname__.__len__, [], 18]
    - [struct_mod_pack_qualname_len,     pack.__qualname__.__len__,               [], 4]
    - [struct_mod_unpack_qualname_len,   unpack.__qualname__.__len__,             [], 6]
    - [struct_mod_pack_into_qualname_len, pack_into.__qualname__.__len__,         [], 9]

# ---------------------------------------------------------------------------
# struct.unpack_from/__qualname__/__len__() == 11
# struct.iter_unpack/__qualname__/__len__() == 11
# struct.calcsize/__qualname__/__len__() == 8
# struct.Struct/__name__/__len__() == 6
#
# Wave 254 theme: module function qualname lengths (group 2) + Struct name length.
#
# unpack_from and iter_unpack both have bare qualnames of 11 chars. calcsize
# is 8 chars. Struct.__name__ is 'Struct' (6 chars). These anchor the remaining
# module function and class name lengths under structquallen84.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra84.struct_name_lengths:
  description: "struct.unpack_from/__qualname__/__len__()==11 / struct.iter_unpack/__qualname__/__len__()==11 / struct.calcsize/__qualname__/__len__()==8 / struct.Struct/__name__/__len__()==6 — unpack_from and iter_unpack have equal qualname lengths of 11 chars; calcsize is 8; Struct.__name__ is 6 chars; this table anchors the remaining module function qualname lengths and the Struct class name length; first structquallen84 anchor for unpack_from/iter_unpack/calcsize module qualname lengths"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structquallen84

  columns: [id, function, args, expected]
  rows:
    - [struct_mod_unpack_from_qualname_len, unpack_from.__qualname__.__len__,  [], 11]
    - [struct_mod_iter_unpack_qualname_len, iter_unpack.__qualname__.__len__,  [], 11]
    - [struct_mod_calcsize_qualname_len,    calcsize.__qualname__.__len__,     [], 8]
    - [struct_cls_name_len,                 Struct.__name__.__len__,           [], 6]

# ---------------------------------------------------------------------------
# struct.Struct/__qualname__/__len__() == 6
# struct.error/__name__/__len__() == 5
# struct.error/__qualname__/__len__() == 5
# struct.Struct.pack/__qualname__/__len__() == 11 (cross-check)
#
# Wave 254 theme: Struct/error name and qualname lengths cross-check.
#
# Struct.__qualname__ is 'Struct' (6 chars, same as __name__). error.__name__
# and error.__qualname__ are both 'error' (5 chars). Cross-check includes
# Struct.pack qualname length from group 1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra84.struct_error_name_lengths:
  description: "struct.Struct/__qualname__/__len__()==6 / struct.error/__name__/__len__()==5 / struct.error/__qualname__/__len__()==5 / struct.Struct.pack/__qualname__/__len__()==11 — Struct.__qualname__ is 'Struct' (6 chars, equal to __name__); error.__name__ and __qualname__ are both 'error' (5 chars); cross-check includes Struct.pack qualname length; first structquallen84 anchor for Struct.__qualname__.__len__() and error name lengths"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structquallen84

  columns: [id, function, args, expected]
  rows:
    - [struct_cls_qualname_len,    Struct.__qualname__.__len__,           [], 6]
    - [struct_error_name_len,      error.__name__.__len__,                [], 5]
    - [struct_error_qualname_len,  error.__qualname__.__len__,            [], 5]
    - [struct_pack_qualname_len2,  Struct.pack.__qualname__.__len__,      [], 11]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__len__() == 11 — standalone
#
# Struct.pack.__qualname__ is 'Struct.pack' (11 chars). struct_extra82 anchors
# the full string equality. No prior struct spec checks this __len__ call.
# First __qualname__.__len__() standalone for struct.Struct.pack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra84.struct_pack_qualname_len:
  description: "struct.Struct.pack.__qualname__.__len__() == 11 — Struct.pack.__qualname__ is 'Struct.pack' (11 characters: 'Struct' + '.' + 'pack'); struct_extra82 anchors the string equality; this standalone anchors the __len__ call; first __qualname__.__len__() standalone for struct.Struct.pack"
  category: class_attrs
  kind: python_call_eq
  function: Struct.pack.__qualname__.__len__
  args: []
  expected: 11

