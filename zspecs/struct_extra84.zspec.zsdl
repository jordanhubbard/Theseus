invariant struct_extra84.struct_unpack_from_qualname_len:
  description: "struct.Struct.unpack_from.__qualname__.__len__() == 18 — Struct.unpack_from.__qualname__ is 'Struct.unpack_from' (18 characters: 'Struct' + '.' + 'unpack_from'); struct_extra82 anchors the string equality; this standalone anchors the __len__ call; first __qualname__.__len__() standalone for struct.Struct.unpack_from"
  category: class_attrs
  kind: python_call_eq
  function: Struct.unpack_from.__qualname__.__len__
  args: []
