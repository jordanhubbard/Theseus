invariant struct_extra84.struct_cls_name_len:
  description: "struct.Struct.__name__.__len__() == 6 — struct.Struct.__name__ is 'Struct' (6 characters); struct_extra82 anchors __name__ and __qualname__ as values; this standalone anchors the __len__ call; first __name__.__len__() standalone for struct.Struct"
