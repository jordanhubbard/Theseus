invariant struct_extra84.struct_calcsize_qualname_len:
  description: "struct.calcsize.__qualname__.__len__() == 8 — struct.calcsize.__qualname__ is 'calcsize' (8 characters); struct_extra83 anchors the string equality; this standalone anchors the __len__ call; first __qualname__.__len__() standalone for struct.calcsize"
  category: class_attrs
