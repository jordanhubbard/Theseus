invariant struct_extra84.struct_error_name_len:
  description: "struct.error.__name__.__len__() == 5 — struct.error.__name__ is 'error' (5 characters); struct_extra75 anchors error.__name__ as a value; this standalone anchors the __len__ call; first __name__.__len__() standalone for struct.error"
  category: class_attrs
