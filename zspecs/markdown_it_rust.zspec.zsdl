spec: markdown_it_rust
version: ">=3.9"
backend: rust_module(markdown_it_rust)

docs: https://markdown-it-py.readthedocs.io/

provenance:
  derived_from:
    - "https://markdown-it-py.readthedocs.io/ — markdown-it-py documentation"
  not_derived_from:
    - "markdown-it-py source: markdown_it/"
  notes:
    - "Clean-room Rust reimplementation of markdown-it-py rendering, exposed via PyO3."
    - "MarkdownIt is imported from markdown_it."
    - "MarkdownIt().render('# Hello') == '<h1>Hello</h1>\\n'."
    - "MarkdownIt().render('**bold**') == '<p><strong>bold</strong></p>\\n'."
    - "MarkdownIt().render('hello *world*') == '<p>hello <em>world</em></p>\\n'."
    - "MarkdownIt().render('- item1\\n- item2') == '<ul>\\n<li>item1</li>\\n<li>item2</li>\\n</ul>\\n'."
    - "All test vectors verified against markdown-it-py 4.0.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# MarkdownIt().render — convert Markdown to HTML
table markdown_it_rust.render.vectors:
  kind: python_call_eq
  category: render
  id_prefix: mdi_render
  function: MarkdownIt
  method: render

  columns: [id, args, method_args, expected]
  rows:
    - [h1,       [], ["# Hello"],         "<h1>Hello</h1>\n"]
    - [h2,       [], ["## World"],        "<h2>World</h2>\n"]
    - [bold,     [], ["**bold**"],        "<p><strong>bold</strong></p>\n"]
    - [italic,   [], ["*italic*"],        "<p><em>italic</em></p>\n"]
    - [em_word,  [], ["hello *world*"],   "<p>hello <em>world</em></p>\n"]
    - [plain,    [], ["hello world"],     "<p>hello world</p>\n"]
    - [empty,    [], [""],               ""]

# List rendering
invariant markdown_it_rust.render.unordered_list:
  description: "MarkdownIt().render('- item1\\n- item2') renders as <ul>"
  category: render
  kind: python_call_eq
  function: MarkdownIt
  args: []
  method: render
  method_args: ["- item1\n- item2"]
  expected: "<ul>\n<li>item1</li>\n<li>item2</li>\n</ul>\n"

