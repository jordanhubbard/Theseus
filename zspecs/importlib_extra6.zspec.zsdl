spec: importlib_extra6
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
    - "importlib_util.zspec.zsdl — covers importlib.util functions via python_module(importlib.util) backend"
    - "importlib_abc.zspec.zsdl — covers importlib.abc classes via python_module(importlib.abc) backend"
  notes:
    - "This spec extends importlib.zspec.zsdl and prior extras."
    - "Prior specs cover: __name__/__module__/__qualname__ for import_module/reload/invalidate_caches (importlib_extra, importlib_extra2, importlib_extra3, importlib_extra4); importlib.__name__/__package__/__spec__ (importlib_extra4); util.__name__ and util function __qualname__ (importlib_extra5); abc.Loader/__qualname__/abc.Finder (importlib_extra5, but abc.Finder no longer exists in Python 3.12+)."
    - "This spec adds __module__ for importlib.util functions (find_spec, module_from_spec, spec_from_file_location) and for importlib.abc.Loader."
    - "This spec adds __qualname__ and __name__ for importlib.util.spec_from_loader (a new function not covered in prior specs)."
    - "importlib.abc.Loader.__module__ == 'importlib._abc' — Loader is defined in the internal _abc submodule."
    - "importlib.util.find_spec.__module__ == 'importlib.util' — defined in the util submodule."
    - "importlib.util.module_from_spec.__module__ == '_frozen_importlib' — defined in frozen bootstrap."
    - "importlib.util.spec_from_file_location.__module__ == '_frozen_importlib_external' — defined in frozen external bootstrap."
    - "importlib.util.spec_from_loader.__name__ == 'spec_from_loader', __qualname__ == 'spec_from_loader', __module__ == '_frozen_importlib'."
    - "importlib.abc.__package__ == 'importlib' — abc is a submodule of the importlib package."
    - "importlib.util.__package__ == 'importlib' — util is a submodule of the importlib package."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib.abc submodule package attribute
# abc is a submodule of the importlib package; its __package__ == 'importlib'.
# ---------------------------------------------------------------------------

invariant importlib_extra6.abc.package:
  description: "importlib.abc.__package__ == 'importlib'"
  category: submodules
  kind: python_call_eq
  function: abc.__package__.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.util submodule package attribute
# util is a submodule of the importlib package; its __package__ == 'importlib'.
# ---------------------------------------------------------------------------

invariant importlib_extra6.util.package:
  description: "importlib.util.__package__ == 'importlib'"
  category: submodules
  kind: python_call_eq
  function: util.__package__.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.abc.Loader — __module__ attribute
# Loader is defined in the internal importlib._abc submodule.
# ---------------------------------------------------------------------------

invariant importlib_extra6.abc_Loader.module:
  description: "importlib.abc.Loader.__module__ == 'importlib._abc'"
  category: class_attrs
  kind: python_call_eq
  function: abc.Loader.__module__.__eq__
  args: ["importlib._abc"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.util function __module__ checks
# find_spec is in importlib.util; module_from_spec and spec_from_file_location
# are in the frozen bootstrap modules.
# ---------------------------------------------------------------------------

invariant importlib_extra6.util_find_spec.module:
  description: "importlib.util.find_spec.__module__ == 'importlib.util'"
  category: function_attrs
  kind: python_call_eq
  function: util.find_spec.__module__.__eq__
  args: ["importlib.util"]
  expected: true

invariant importlib_extra6.util_module_from_spec.module:
  description: "importlib.util.module_from_spec.__module__ == '_frozen_importlib'"
  category: function_attrs
  kind: python_call_eq
  function: util.module_from_spec.__module__.__eq__
  args: ["_frozen_importlib"]
  expected: true

invariant importlib_extra6.util_spec_from_file_location.module:
  description: "importlib.util.spec_from_file_location.__module__ == '_frozen_importlib_external'"
  category: function_attrs
  kind: python_call_eq
  function: util.spec_from_file_location.__module__.__eq__
  args: ["_frozen_importlib_external"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.util.spec_from_loader — name, qualname, module
# spec_from_loader is defined in the frozen importlib bootstrap.
# ---------------------------------------------------------------------------

invariant importlib_extra6.util_spec_from_loader.name:
  description: "importlib.util.spec_from_loader.__name__ == 'spec_from_loader'"
  category: function_attrs
  kind: python_call_eq
  function: util.spec_from_loader.__name__.__eq__
  args: ["spec_from_loader"]
  expected: true

invariant importlib_extra6.util_spec_from_loader.qualname:
  description: "importlib.util.spec_from_loader.__qualname__ == 'spec_from_loader'"
  category: qualnames
  kind: python_call_eq
  function: util.spec_from_loader.__qualname__.__eq__
  args: ["spec_from_loader"]
  expected: true

invariant importlib_extra6.util_spec_from_loader.module:
  description: "importlib.util.spec_from_loader.__module__ == '_frozen_importlib'"
  category: function_attrs
  kind: python_call_eq
  function: util.spec_from_loader.__module__.__eq__
  args: ["_frozen_importlib"]
  expected: true
