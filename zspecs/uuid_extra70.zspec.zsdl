spec: uuid_extra70
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra69.zspec.zsdl — covers UUID/__dict__.__contains__('__repr__'/'__int__'/'__setattr__') / SafeUUID/__dict__/__class__/__name__=='mappingproxy' / UUID/__setattr__/__code__/co_name/co_argcount (table + invariants)."
    - "uuid_extra68.zspec.zsdl — covers UUID/__repr__/__eq__/__code__/co_varnames/__class__/__name__=='tuple' / SafeUUID/__doc__/__class__/__name__=='str' / UUID/__init__/__str__/__code__/co_flags/__class__/__name__=='int' (table + invariants)."
    - "uuid_extra67.zspec.zsdl — covers NAMESPACE_DNS/URL/__class__/__name__=='UUID' / RESERVED_NCS/__contains__('NCS') / RFC_4122/__contains__('RFC') / UUID/__repr__/__code__/co_name=='__repr__' (table + invariants)."
    - "uuid_extra60.zspec.zsdl — covers UUID/__repr__/__str__/__hash__/__eq__/__code__/co_name and co_argcount / SafeUUID class identity / SafeUUID/__bases__[0]/__name__=='IntEnum' (table + invariants)."
    - "uuid_extra52.zspec.zsdl — covers UUID/__setattr__/__qualname__.__eq__('UUID.__setattr__') / UUID/__getstate__/__setstate__/__init_subclass__/__subclasshook__ __qualname__ (table + invariants)."
    - "uuid_extra29.zspec.zsdl — covers SafeUUID/__mro__/__len__()==3 / UUID/__mro__/__len__()==2 (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra69; it does NOT duplicate invariants present in those files."
    - "Wave 245 theme: UUID __dict__ additional method membership + UUID.__init__ code object attributes."
    - "uuid.UUID.__dict__.__contains__('__init__') == True — UUID defines __init__ in its class __dict__. No prior uuid spec checks UUID.__dict__.__contains__('__init__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__str__') == True — UUID defines __str__ in its class __dict__. No prior uuid spec checks UUID.__dict__.__contains__('__str__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__eq__') == True — UUID defines __eq__ in its class __dict__. No prior uuid spec checks UUID.__dict__.__contains__('__eq__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__hash__') == True — UUID defines __hash__ in its class __dict__. No prior uuid spec checks UUID.__dict__.__contains__('__hash__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__lt__') == True — UUID defines __lt__ in its class __dict__ (for ordering). No prior uuid spec checks UUID.__dict__.__contains__('__lt__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('int') == True — UUID.int is a property defined in the class __dict__. uuid_extra69 covers UUID.__dict__.__contains__('__int__') but NOT 'int' (the property). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('hex') == True — UUID.hex is a property. No prior uuid spec checks UUID.__dict__.__contains__('hex'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('urn') == True — UUID.urn is a property. No prior uuid spec checks UUID.__dict__.__contains__('urn'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('version') == True — UUID.version is a property. No prior uuid spec checks UUID.__dict__.__contains__('version'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes') == True — UUID.bytes is a property. No prior uuid spec checks UUID.__dict__.__contains__('bytes'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('fields') == True — UUID.fields is a property. No prior uuid spec checks UUID.__dict__.__contains__('fields'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_name == '__init__' — the code object's co_name matches the function name. No prior uuid spec checks UUID.__init__.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_argcount == 7 — __init__ takes self + hex, bytes, bytes_le, fields, int, version (7 positional args; is_safe is keyword-only). No prior uuid spec checks UUID.__init__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__ for __init__, __str__, __eq__
#
# Wave 245 theme: UUID class __dict__ core method membership.
#
# uuid.UUID defines __init__, __str__, and __eq__ directly in its class __dict__
# as Python methods. uuid_extra69 covers __repr__, __int__, __setattr__ in
# __dict__; no prior uuid spec checks __init__, __str__, or __eq__ dict membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra70.UUID_dict_contains_init_str_eq:
  description: "uuid.UUID/__dict__.__contains__('__init__')==True / __contains__('__str__')==True / __contains__('__eq__')==True — UUID defines __init__/__str__/__eq__ directly in its class __dict__; uuid_extra69 covers __repr__/__int__/__setattr__ dict membership; no prior uuid spec checks UUID.__dict__.__contains__ for __init__/__str__/__eq__; first dict membership anchor for UUID.__init__/__str__/__eq__"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidextra70

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_has_init,  UUID.__dict__.__contains__, ["__init__"], true]
    - [UUID_dict_has_str,   UUID.__dict__.__contains__, ["__str__"],  true]
    - [UUID_dict_has_eq,    UUID.__dict__.__contains__, ["__eq__"],   true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__ for __hash__ and __lt__
#
# Wave 245 theme: UUID comparison and hashing method membership.
#
# uuid.UUID defines both __hash__ (for use in sets/dicts) and __lt__ (for
# ordering) in its class __dict__. No prior uuid spec checks either
# UUID.__dict__.__contains__('__hash__') or UUID.__dict__.__contains__('__lt__').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra70.UUID_dict_contains_hash_lt:
  description: "uuid.UUID/__dict__.__contains__('__hash__')==True / __contains__('__lt__')==True — UUID defines __hash__ for hashing and __lt__ for ordering in its class __dict__; no prior uuid spec checks UUID.__dict__.__contains__ for __hash__ or __lt__; first dict membership anchor for UUID.__hash__/__lt__"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidextra70

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_has_hash, UUID.__dict__.__contains__, ["__hash__"], true]
    - [UUID_dict_has_lt,   UUID.__dict__.__contains__, ["__lt__"],   true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__ for property attributes: int, hex, urn, version
#
# Wave 245 theme: UUID property membership in __dict__.
#
# uuid.UUID exposes int, hex, urn, and version as Python properties defined
# in its class __dict__. uuid_extra69 covers UUID.__dict__.__contains__('__int__')
# (the dunder) but NOT 'int' (the property). No prior uuid spec checks hex, urn,
# or version __dict__ membership. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra70.UUID_dict_contains_properties:
  description: "uuid.UUID/__dict__.__contains__('int')==True / __contains__('hex')==True / __contains__('urn')==True / __contains__('version')==True — UUID exposes int/hex/urn/version as properties in its class __dict__; uuid_extra69 covers '__int__' (dunder) but NOT 'int' (property); no prior uuid spec checks hex/urn/version dict membership; first property dict membership anchor for UUID"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidextra70

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_has_int_prop,     UUID.__dict__.__contains__, ["int"],     true]
    - [UUID_dict_has_hex_prop,     UUID.__dict__.__contains__, ["hex"],     true]
    - [UUID_dict_has_urn_prop,     UUID.__dict__.__contains__, ["urn"],     true]
    - [UUID_dict_has_version_prop, UUID.__dict__.__contains__, ["version"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_name and co_argcount
#
# Wave 245 theme: UUID.__init__ code object attributes.
#
# uuid.UUID.__init__ is a Python function. Its code object has
# co_name == '__init__' and co_argcount == 7 (self + hex, bytes, bytes_le,
# fields, int, version — is_safe is keyword-only). No prior uuid spec checks
# UUID.__init__.__code__.co_name or co_argcount.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra70.UUID_init_code_attrs:
  description: "uuid.UUID/__init__/__code__/co_name.__eq__('__init__')==True / UUID/__init__/__code__/co_argcount.__eq__(7)==True — UUID.__init__ has co_name=='__init__' and co_argcount==7 (self+hex+bytes+bytes_le+fields+int+version); is_safe is keyword-only so not counted; no prior uuid spec checks UUID.__init__.__code__.co_name or co_argcount; first code object anchor for UUID.__init__"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidextra70

  columns: [id, function, args, expected]
  rows:
    - [UUID_init_co_name_eq,     UUID.__init__.__code__.co_name.__eq__,     ["__init__"], true]
    - [UUID_init_co_argcount_eq, UUID.__init__.__code__.co_argcount.__eq__,  [7],          true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__init__') — standalone
#
# UUID defines __init__ in its class __dict__. No prior uuid spec checks
# UUID.__dict__.__contains__('__init__'). First __init__ dict membership
# standalone for UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra70.UUID_dict_has_init:
  description: "uuid.UUID.__dict__.__contains__('__init__') == True — UUID defines __init__ directly in its class __dict__; no prior uuid spec checks UUID.__dict__.__contains__('__init__'); first __init__ dict membership standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__hash__') — standalone
#
# UUID defines __hash__ in its class __dict__. No prior uuid spec checks
# UUID.__dict__.__contains__('__hash__'). First __hash__ dict membership
# standalone for UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra70.UUID_dict_has_hash:
  description: "uuid.UUID.__dict__.__contains__('__hash__') == True — UUID defines __hash__ directly in its class __dict__; no prior uuid spec checks UUID.__dict__.__contains__('__hash__'); first __hash__ dict membership standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__hash__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('bytes') — standalone
#
# UUID.bytes is a property in the class __dict__. No prior uuid spec checks
# UUID.__dict__.__contains__('bytes'). First bytes property dict membership
# standalone for UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra70.UUID_dict_has_bytes:
  description: "uuid.UUID.__dict__.__contains__('bytes') == True — UUID.bytes is a property defined in its class __dict__; no prior uuid spec checks UUID.__dict__.__contains__('bytes'); first bytes property dict membership standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_name.__eq__('__init__') — standalone
#
# UUID.__init__ is a Python function; its code object's co_name is '__init__'.
# No prior uuid spec checks UUID.__init__.__code__.co_name. First co_name
# standalone for UUID.__init__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra70.UUID_init_co_name:
  description: "uuid.UUID.__init__.__code__.co_name.__eq__('__init__') == True — UUID.__init__ is a Python function; co_name matches the function name '__init__'; no prior uuid spec checks UUID.__init__.__code__.co_name; first co_name standalone for UUID.__init__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount.__eq__(7) — standalone
#
# UUID.__init__ takes 7 positional arguments (self, hex, bytes, bytes_le,
# fields, int, version). is_safe is keyword-only and not counted.
# No prior uuid spec checks UUID.__init__.__code__.co_argcount. First
# co_argcount standalone for UUID.__init__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra70.UUID_init_co_argcount:
  description: "uuid.UUID.__init__.__code__.co_argcount.__eq__(7) == True — UUID.__init__ takes 7 positional arguments (self+hex+bytes+bytes_le+fields+int+version); is_safe is keyword-only; no prior uuid spec checks UUID.__init__.__code__.co_argcount; first co_argcount standalone for UUID.__init__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__init__.__code__.co_argcount.__eq__
  args: [7]
  expected: true
