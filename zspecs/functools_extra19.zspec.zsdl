spec: functools_extra19
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra18.zspec.zsdl."
    - "functools_extra18 covers: __qualname__.__eq__ for partial, lru_cache, cache, reduce, singledispatch, singledispatchmethod; WRAPPER_ASSIGNMENTS[3]=='__doc__'; __contains__ for '__qualname__' and '__name__'; cache.__name__ and qualname_len; singledispatchmethod qualname_len."
    - "No prior functools spec covers __module__ for partial, lru_cache, wraps, total_ordering, singledispatch, cached_property, or cache as standalone __eq__ invariants."
    - "functools.reduce.__module__ == '_functools' (the underlying C extension module), not 'functools'."
    - "functools.partial.__module__ == 'functools' — the C type is registered under the public module name."
    - "WRAPPER_UPDATES is a tuple of length 1 containing only '__dict__'."
    - "WRAPPER_ASSIGNMENTS is a tuple of length 6 on Python 3.12+."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for functools public API members
#
# No prior functools spec checks __module__ as a standalone __eq__ invariant
# for partial, lru_cache, wraps, total_ordering, singledispatch,
# cached_property, or cache.
# Note: functools.reduce.__module__ == '_functools' (C extension module).
# ---------------------------------------------------------------------------

invariant functools_extra19.partial.module:
  description: "functools.partial.__module__ == 'functools' — C type registered under public module"
  category: module_attrs
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra19.lru_cache.module:
  description: "functools.lru_cache.__module__ == 'functools' — top-level function"
  category: module_attrs
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra19.wraps.module:
  description: "functools.wraps.__module__ == 'functools' — decorator defined in functools.py"
  category: module_attrs
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra19.total_ordering.module:
  description: "functools.total_ordering.__module__ == 'functools' — class decorator"
  category: module_attrs
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra19.singledispatch.module:
  description: "functools.singledispatch.__module__ == 'functools' — top-level decorator"
  category: module_attrs
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra19.cached_property.module:
  description: "functools.cached_property.__module__ == 'functools' — descriptor class"
  category: module_attrs
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra19.cache.module:
  description: "functools.cache.__module__ == 'functools' — thin wrapper added in 3.9"
  category: module_attrs
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra19.reduce.module:
  description: "functools.reduce.__module__ == '_functools' — underlying C extension module"
  category: module_attrs
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES — tuple of updatable attributes
#
# functools_extra15 covers WRAPPER_UPDATES.__contains__('__dict__') == True.
# No prior spec asserts WRAPPER_UPDATES.__len__() == 1 or WRAPPER_UPDATES[0].
# ---------------------------------------------------------------------------

invariant functools_extra19.WRAPPER_UPDATES.len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — only '__dict__' in the tuple"
  category: wrapper_updates
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra19.WRAPPER_UPDATES.index0:
  description: "functools.WRAPPER_UPDATES[0] == '__dict__' — sole element"
  category: wrapper_updates
  kind: python_call_eq
  function: WRAPPER_UPDATES.__getitem__
  args: [0]
  expected: "__dict__"

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS — tuple length and element count
#
# functools_extra17 covers indices 0, 1, 2. functools_extra18 covers index 3.
# functools_extra15 covers index 5 ('__type_params__').
# No prior spec asserts the total length of WRAPPER_ASSIGNMENTS as 6.
# ---------------------------------------------------------------------------

invariant functools_extra19.WRAPPER_ASSIGNMENTS.len:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — six elements on Python 3.12+"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# __module__ length cross-checks
#
# 'functools' has 9 characters. These complement the equality checks above
# with a second behavioral axis: string length rather than string content.
# ---------------------------------------------------------------------------

invariant functools_extra19.partial.module_len:
  description: "functools.partial.__module__.__len__() == 9 — len('functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: partial.__module__.__len__
  args: []
  expected: 9

invariant functools_extra19.cache.module_len:
  description: "functools.cache.__module__.__len__() == 9 — len('functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: cache.__module__.__len__
  args: []
  expected: 9
