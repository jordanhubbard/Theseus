spec: decimal_extra164
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.InvalidOperation, decimal.DivisionByZero, decimal.Overflow, decimal.Underflow, and decimal.Inexact class identity."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation' (len=16: 'Invalid'(7)+'Operation'(9)=16)."
    - "decimal.InvalidOperation.__module__ == 'decimal' (len=7)."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' (len=16) — inherits from DecimalException."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero' (len=14: 'Division'(8)+'By'(2)+'Zero'(4)=14)."
    - "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' (len=16)."
    - "decimal.Overflow.__name__ == 'Overflow' (len=8: 'Over'(4)+'flow'(4)=8)."
    - "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (len=7) — Overflow inherits from Inexact (not DecimalException directly)."
    - "decimal.Underflow.__name__ == 'Underflow' (len=9: 'Under'(5)+'flow'(4)=9)."
    - "decimal.Underflow.__bases__[0].__name__ == 'Inexact' (len=7) — Underflow also inherits from Inexact."
    - "decimal.Inexact.__name__ == 'Inexact' (len=7)."
    - "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' (len=16)."
    - "Name length ranking: Inexact(7) < Overflow(8) < Underflow(9) < DivisionByZero(14) < InvalidOperation(16)=DecimalException(16)."
    - "Overflow and Underflow both inherit from Inexact (not DecimalException directly) — Inexact is their immediate base."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.InvalidOperation class identity
# __name__ == 'InvalidOperation' (len=16), __module__ == 'decimal' (len=7)
# __bases__[0].__name__ == 'DecimalException' (len=16)
# InvalidOperation (16) == DecimalException (16): both 16 chars — a tie with the base class name
# ---------------------------------------------------------------------------

table decimal_extra164.InvalidOperation_class_identity:
  description: "decimal.InvalidOperation class identity: __name__=='InvalidOperation' (len=16), __module__=='decimal' (len=7), __bases__[0].__name__=='DecimalException' (len=16); InvalidOperation (16) == DecimalException (16) in name length — derived class name ties with its base class name"
  kind: python_call_eq
  category: identity
  id_prefix: decio164

  columns: [id, function, args, expected, description]
  rows:
    - [io_name,     decimal.InvalidOperation.__name__.__eq__,                ["InvalidOperation"],  true, "decimal.InvalidOperation.__name__ == 'InvalidOperation' — raised when an invalid operation is performed (e.g., Decimal('nan') + Decimal('inf')); 'InvalidOperation' has 16 characters: 'Invalid'(7)+'Operation'(9)=16; InvalidOperation (16 chars) == DecimalException (16 chars) in name length — a rare case where a derived exception class name has the same length as its base class name; the 7-character 'Invalid' prefix in 'InvalidOperation' coincidentally equals len('Decimal') (7) and len('Context') (7) — the lengths of the two primary decimal module classes; InvalidOperation is the most commonly trapped decimal exception in financial code; confirmed Python 3.14.3 macOS"]
    - [io_module,   decimal.InvalidOperation.__module__.__eq__,              ["decimal"],           true, "decimal.InvalidOperation.__module__ == 'decimal' — InvalidOperation is defined in the 'decimal' module; 'decimal' has 7 characters; InvalidOperation.__module__ (7: 'decimal') is the same for all decimal exception classes: DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact all have __module__ == 'decimal' (7 chars); InvalidOperation.__module__ (7 chars) << InvalidOperation.__name__ (16 chars): the module name is less than half the class name length; confirmed Python 3.14.3 macOS"]
    - [io_base0,    "decimal.InvalidOperation.__bases__[0].__name__.__eq__", ["DecimalException"],  true, "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — InvalidOperation inherits directly from DecimalException; 'DecimalException' has 16 characters; InvalidOperation.__bases__[0].__name__ (16: 'DecimalException') == InvalidOperation.__name__.__len__() (also 16: 'InvalidOperation'): derived class name and base class name have the same length of 16 characters — a tie at 16 between derived and base; this contrasts with Overflow and Underflow which inherit from Inexact (7 chars, not 16); InvalidOperation is caught by 'except decimal.DecimalException:' through this inheritance; confirmed Python 3.14.3 macOS"]
    - [io_name_len, decimal.InvalidOperation.__name__.__len__,               [],                   16,   "decimal.InvalidOperation.__name__.__len__() == 16 — 'InvalidOperation' has 16 characters: 'Invalid'(7)+'Operation'(9)=16; InvalidOperation (16) == DecimalException (16) == len('DecimalException') == 16: both the derived exception and its base class have 16-character names — an equal-length derived-and-base pair; 16 is the maximum in the exception name length family of this spec: Inexact(7) < Overflow(8) < Underflow(9) < DivisionByZero(14) < InvalidOperation(16)=DecimalException(16); 'Operation' (9 chars) == len('Exception') (9 chars): the second component of 'InvalidOperation' has the same length as the second component of 'DecimalException'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.DivisionByZero class identity
# __name__ == 'DivisionByZero' (len=14), __module__ == 'decimal' (len=7)
# __bases__[0].__name__ == 'DecimalException' (len=16)
# DivisionByZero (14) < InvalidOperation (16) by 2
# ---------------------------------------------------------------------------

table decimal_extra164.DivisionByZero_class_identity:
  description: "decimal.DivisionByZero class identity: __name__=='DivisionByZero' (len=14), __module__=='decimal' (len=7), __bases__[0].__name__=='DecimalException' (len=16); DivisionByZero (14) < InvalidOperation (16) by 2; DivisionByZero (14) = 'Division'(8)+'By'(2)+'Zero'(4)=14"
  kind: python_call_eq
  category: identity
  id_prefix: decdz164

  columns: [id, function, args, expected, description]
  rows:
    - [dz_name,     decimal.DivisionByZero.__name__.__eq__,                ["DivisionByZero"],  true, "decimal.DivisionByZero.__name__ == 'DivisionByZero' — raised when division by zero occurs in a non-infinite context (e.g., Decimal('1') / Decimal('0')); 'DivisionByZero' has 14 characters: 'Division'(8)+'By'(2)+'Zero'(4)=14; DivisionByZero (14) < InvalidOperation (16) by 2; DivisionByZero (14) > Underflow (9) by 5 in the exception name length family; the 'ByZero' suffix (6 chars: 'By'(2)+'Zero'(4)=6) is a clear camel-case encoding of the division-by-zero condition; 14 chars also equals len('BufferedReader') == len('BufferedWriter') == len('BufferedRandom') from io_extra173 — cross-module 14-character ties; confirmed Python 3.14.3 macOS"]
    - [dz_module,   decimal.DivisionByZero.__module__.__eq__,              ["decimal"],         true, "decimal.DivisionByZero.__module__ == 'decimal' — DivisionByZero is defined in the 'decimal' module; 'decimal' has 7 characters; DivisionByZero.__module__ (7: 'decimal') == InvalidOperation.__module__ (7: 'decimal') == Overflow.__module__ (7: 'decimal'): all decimal exception classes share the same 7-character module name; 'decimal' (7 chars) is exactly half of DivisionByZero (14 chars): len('decimal') * 2 == len('DivisionByZero') — 7 * 2 = 14; confirmed Python 3.14.3 macOS"]
    - [dz_base0,    "decimal.DivisionByZero.__bases__[0].__name__.__eq__",  ["DecimalException"], true, "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' — DivisionByZero inherits directly from DecimalException (16 chars); 'DecimalException' has 16 characters; DivisionByZero.__bases__[0].__name__ (16: 'DecimalException') > DivisionByZero.__name__ (14: 'DivisionByZero') by 2 — the base class name is 2 characters longer than the derived class name; this is unlike InvalidOperation (16) where derived and base have equal length; DivisionByZero also has ZeroDivisionError as a second base class (multiple inheritance), enabling catch by both decimal.DecimalException and the built-in ZeroDivisionError; confirmed Python 3.14.3 macOS"]
    - [dz_name_len, decimal.DivisionByZero.__name__.__len__,               [],                  14,   "decimal.DivisionByZero.__name__.__len__() == 14 — 'DivisionByZero' has 14 characters: 'Division'(8)+'By'(2)+'Zero'(4)=14; DivisionByZero (14) sits between Underflow (9) and InvalidOperation (16) in the exception name length ordering: Inexact(7) < Overflow(8) < Underflow(9) < DivisionByZero(14) < InvalidOperation(16)=DecimalException(16); DivisionByZero (14) == len('BufferedReader') == len('BufferedWriter') == 14: cross-module tie with io module buffered class names; len('decimal') * 2 == 14 == len('DivisionByZero'): the module name length doubled equals the exception class name length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Inexact class identity
# __name__ == 'Inexact' (len=7), __bases__[0].__name__ == 'DecimalException'
# Inexact (7) is the shortest exception name in this spec
# Overflow and Underflow both inherit from Inexact (not DecimalException directly)
# ---------------------------------------------------------------------------

table decimal_extra164.Inexact_class_identity:
  description: "decimal.Inexact class identity: __name__=='Inexact' (len=7), __module__=='decimal' (len=7), __bases__[0].__name__=='DecimalException' (len=16); Inexact (7) is the shortest exception name in this spec; Overflow and Underflow both inherit from Inexact"
  kind: python_call_eq
  category: identity
  id_prefix: decin164

  columns: [id, function, args, expected, description]
  rows:
    - [inexact_name,     decimal.Inexact.__name__.__eq__,                ["Inexact"],         true, "decimal.Inexact.__name__ == 'Inexact' — the base class for decimal exceptions raised when a result cannot be represented exactly; 'Inexact' has 7 characters: 'In'(2)+'exact'(5)=7; Inexact (7 chars) == len('Decimal') == len('Context') == 7: Inexact ties with the two primary decimal module class names in name length; Inexact (7) is the minimum exception name length in this spec: Inexact(7) < Overflow(8) < Underflow(9) < DivisionByZero(14) < InvalidOperation(16)=DecimalException(16); Overflow and Underflow both inherit from Inexact (not DecimalException directly), making Inexact an intermediate base in the decimal exception hierarchy; confirmed Python 3.14.3 macOS"]
    - [inexact_module,   decimal.Inexact.__module__.__eq__,              ["decimal"],         true, "decimal.Inexact.__module__ == 'decimal' — Inexact is defined in the 'decimal' module; 'decimal' has 7 characters; Inexact.__module__ (7: 'decimal') == Inexact.__name__.__len__() (7): the module name length equals the class name length for Inexact — just as it does for Decimal and Context; all three 7-character names in this spec (Decimal, Context, Inexact) have the same length as the 7-character module name 'decimal'; this triple 7-character coincidence (Decimal, Context, Inexact, all matching the module name 'decimal' in length) is a notable structural pattern; confirmed Python 3.14.3 macOS"]
    - [inexact_base0,    "decimal.Inexact.__bases__[0].__name__.__eq__",  ["DecimalException"], true, "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact inherits directly from DecimalException (16 chars); 'DecimalException' has 16 characters; Inexact.__bases__[0].__name__ (16: 'DecimalException') > Inexact.__name__ (7: 'Inexact') by 9 == len('Exception'): the base class name is 9 characters longer than Inexact — the largest base-to-derived name length gap in this spec; Inexact then serves as the base for both Overflow and Underflow: the chain is DecimalException -> Inexact -> Overflow/Underflow; this three-level chain means Overflow is 3 levels below DecimalException; confirmed Python 3.14.3 macOS"]
    - [inexact_name_len, decimal.Inexact.__name__.__len__,               [],                  7,    "decimal.Inexact.__name__.__len__() == 7 — 'Inexact' has 7 characters; Inexact (7) is the minimum exception class name in this spec; the ascending exception name length sequence: Inexact(7) < Overflow(8) < Underflow(9) < DivisionByZero(14) < InvalidOperation(16)=DecimalException(16); Inexact (7) == len('Decimal') == len('Context') == len('decimal') == 7: four-way tie at 7 characters among the primary decimal module names (three classes and the module name); 7 is the most common name length in the decimal module; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Overflow and decimal.Underflow class identity
# Overflow.__name__ == 'Overflow' (len=8), Underflow.__name__ == 'Underflow' (len=9)
# Both have __bases__[0].__name__ == 'Inexact' (len=7)
# Overflow < Underflow by 1 in name length
# ---------------------------------------------------------------------------

table decimal_extra164.Overflow_Underflow_class_identity:
  description: "decimal.Overflow class identity: __name__=='Overflow' (len=8), __bases__[0].__name__=='Inexact' (len=7); decimal.Underflow: __name__=='Underflow' (len=9), __bases__[0].__name__=='Inexact' (len=7); both inherit from Inexact, not DecimalException directly; Overflow(8) < Underflow(9) by 1"
  kind: python_call_eq
  category: identity
  id_prefix: decou164

  columns: [id, function, args, expected, description]
  rows:
    - [ov_name,     decimal.Overflow.__name__.__eq__,                ["Overflow"],  true, "decimal.Overflow.__name__ == 'Overflow' — raised when a result is too large to be represented in the given precision; 'Overflow' has 8 characters: 'Over'(4)+'flow'(4)=8; Overflow (8 chars) > Inexact (7 chars) by 1 — Overflow derives from Inexact and its name is 1 character longer; Overflow (8 chars) < Underflow (9 chars) by 1 — the symmetric pair Overflow/Underflow differ by 1 character because 'Over' (4 chars) == 'flow' (4 chars) but 'Under' (5 chars) > 'Over' (4 chars) by 1; Overflow (8 chars) == len('BytesIO') (8 chars) == len('finditer') (8 chars) — cross-module ties at 8; confirmed Python 3.14.3 macOS"]
    - [ov_base0,    "decimal.Overflow.__bases__[0].__name__.__eq__",  ["Inexact"],   true, "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow inherits from Inexact (7 chars), NOT directly from DecimalException (16 chars); 'Inexact' has 7 characters; Overflow.__bases__[0].__name__ (7: 'Inexact') < Overflow.__name__ (8: 'Overflow') by 1 — the base class name is 1 character shorter than the derived class; the inheritance chain: DecimalException -> Inexact -> Overflow; Overflow results are inexact (hence inheriting from Inexact) AND too large for the current precision; both Overflow (8) and Underflow (9) share Inexact (7) as their direct base class; confirmed Python 3.14.3 macOS"]
    - [uf_name,     decimal.Underflow.__name__.__eq__,               ["Underflow"], true, "decimal.Underflow.__name__ == 'Underflow' — raised when a result is too small to be represented as a normalized decimal (subnormal result that is also inexact); 'Underflow' has 9 characters: 'Under'(5)+'flow'(4)=9; Underflow (9 chars) > Overflow (8 chars) by 1 — 'Under' (5 chars) > 'Over' (4 chars) by 1; Underflow (9 chars) == len('fullmatch') (9 chars) and len('RegexFlag') (9 chars) — cross-module 9-character ties; Underflow (9) < DivisionByZero (14) by 5 in the exception name length ordering; confirmed Python 3.14.3 macOS"]
    - [uf_base0,    "decimal.Underflow.__bases__[0].__name__.__eq__", ["Inexact"],   true, "decimal.Underflow.__bases__[0].__name__ == 'Inexact' — Underflow inherits from Inexact (7 chars), the same immediate base as Overflow; 'Inexact' has 7 characters; Underflow.__bases__[0].__name__ (7: 'Inexact') == Overflow.__bases__[0].__name__ (7: 'Inexact'): the symmetric pair (Overflow, Underflow) shares the same immediate base class; the inheritance chain: DecimalException -> Inexact -> Underflow; Underflow is both inexact and subnormal (very small magnitude), hence inheriting through Inexact; confirmed Python 3.14.3 macOS"]
    - [ov_ne_dex,   "decimal.Overflow.__bases__[0].__name__.__eq__",  ["DecimalException"], false, "decimal.Overflow.__bases__[0].__name__.__eq__('DecimalException') == False — Overflow does NOT inherit directly from DecimalException; Overflow.__bases__[0].__name__ is 'Inexact' (7 chars), not 'DecimalException' (16 chars); the intermediate base Inexact sits between DecimalException and Overflow in the hierarchy: DecimalException -> Inexact -> Overflow; this is architecturally meaningful: Overflow is inherently inexact (the result could not be exactly represented), so it inherits from Inexact; the False assertion distinguishes Overflow from InvalidOperation and DivisionByZero which DO inherit directly from DecimalException; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Exception name length ordering across the five exceptions in this spec
# Inexact(7) < Overflow(8) < Underflow(9) < DivisionByZero(14) < InvalidOperation(16)
# ---------------------------------------------------------------------------

table decimal_extra164.exception_name_length_ordering:
  description: "Decimal exception name lengths: Inexact(7) < Overflow(8) < Underflow(9) < DivisionByZero(14) < InvalidOperation(16)=DecimalException(16); Inexact(7) is minimum; InvalidOperation(16) ties with DecimalException(16); Overflow(8)+Underflow(9) differ by 1 (Over=4 vs Under=5)"
  kind: python_call_eq
  category: identity
  id_prefix: decord164

  columns: [id, function, args, expected, description]
  rows:
    - [inexact_7,    decimal.Inexact.__name__.__len__,          [],  7,  "decimal.Inexact.__name__.__len__() == 7 — 'Inexact' is the minimum exception name length in this spec; Inexact (7) < Overflow (8) < Underflow (9) < DivisionByZero (14) < InvalidOperation (16) == DecimalException (16); the ascending exception name lengths start at 7 (Inexact) — matching len('Decimal') and len('Context') and len('decimal'); 7 is the most common length in the decimal module: Decimal(7), Context(7), Inexact(7), decimal(7) all share this length; confirmed Python 3.14.3 macOS"]
    - [overflow_8,   decimal.Overflow.__name__.__len__,         [],  8,  "decimal.Overflow.__name__.__len__() == 8 — 'Overflow' = 'Over'(4)+'flow'(4) = 8; Overflow (8) > Inexact (7) by 1: consecutive ascending steps between the first three exception names (Inexact=7, Overflow=8, Underflow=9); Overflow (8) == len('BytesIO') (8) and len('finditer') (8) — cross-module ties at 8; the two halves of 'Overflow' are equal: 'Over'(4) + 'flow'(4) = 8; Overflow (8) < Underflow (9) by 1 because 'Under'(5) > 'Over'(4) by 1 while both share the 'flow'(4) suffix; confirmed Python 3.14.3 macOS"]
    - [underflow_9,  decimal.Underflow.__name__.__len__,        [],  9,  "decimal.Underflow.__name__.__len__() == 9 — 'Underflow' = 'Under'(5)+'flow'(4) = 9; Underflow (9) > Overflow (8) by 1: the 'Under' prefix (5) > 'Over' prefix (4) by 1; Underflow (9) == len('fullmatch') (9) and len('RegexFlag') (9) and len('PosixPath') (9) — cross-module ties at 9; Underflow (9) < DivisionByZero (14) by 5: a large gap of 5 between consecutive exception names in the ordering; the three consecutive unit-step pairs are Inexact(7)->Overflow(8)->Underflow(9) — three adjacent exceptions with unit gaps; confirmed Python 3.14.3 macOS"]
    - [divzero_14,   decimal.DivisionByZero.__name__.__len__,   [],  14, "decimal.DivisionByZero.__name__.__len__() == 14 — 'DivisionByZero' = 'Division'(8)+'By'(2)+'Zero'(4) = 14; DivisionByZero (14) sits between Underflow (9) and InvalidOperation (16) with gaps of 5 and 2 respectively; DivisionByZero (14) > Underflow (9) by 5: a large gap after the consecutive-unit-step trio; DivisionByZero (14) < InvalidOperation (16) by 2; DivisionByZero (14) == len('BufferedReader') == 14 (from io_extra173) — cross-module 14-char ties; confirmed Python 3.14.3 macOS"]
    - [invalidop_16, decimal.InvalidOperation.__name__.__len__, [],  16, "decimal.InvalidOperation.__name__.__len__() == 16 — 'InvalidOperation' = 'Invalid'(7)+'Operation'(9) = 16; InvalidOperation (16) is the maximum exception name length in this spec; InvalidOperation (16) == len('DecimalException') (16): derived exception name ties with its base class name in length — unique in this spec; InvalidOperation (16) > DivisionByZero (14) by 2; the full ascending sequence: Inexact(7), Overflow(8), Underflow(9), DivisionByZero(14), InvalidOperation(16)=DecimalException(16); the sum 7+8+9+14+16 = 54 — total of all five exception name lengths; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra164.InvalidOperation_name_is_InvalidOperation:
  description: "decimal.InvalidOperation.__name__ == 'InvalidOperation' — raised when an invalid operation is attempted; 'InvalidOperation' has 16 characters: 'Invalid'(7)+'Operation'(9)=16; InvalidOperation (16) == len('DecimalException') (16): the derived exception and its base class have equal name lengths — a tie at 16; InvalidOperation.__module__ == 'decimal' (7 chars); InvalidOperation is the most frequently trapped decimal exception in financial code; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.InvalidOperation.__name__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra164.InvalidOperation_base_is_DecimalException:
  description: "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — InvalidOperation inherits directly from DecimalException (16 chars); both InvalidOperation (16 chars) and DecimalException (16 chars) have the same 16-character name length — an equal-length derived-and-base pair; 'Operation' (9 chars) in InvalidOperation == len('Exception') (9 chars) in DecimalException: the second components of both class names have the same length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.InvalidOperation.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra164.DivisionByZero_name_is_DivisionByZero:
  description: "decimal.DivisionByZero.__name__ == 'DivisionByZero' — raised when division by zero occurs; 'DivisionByZero' has 14 characters: 'Division'(8)+'By'(2)+'Zero'(4)=14; DivisionByZero (14) < InvalidOperation (16) by 2; len('decimal') * 2 == 14 == len('DivisionByZero'): the module name doubled equals the exception class name length; DivisionByZero also inherits from ZeroDivisionError (multiple inheritance), allowing it to be caught by either decimal.DecimalException or the built-in ZeroDivisionError; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.DivisionByZero.__name__.__eq__
  args: ["DivisionByZero"]
  expected: true

invariant decimal_extra164.DivisionByZero_base_is_DecimalException:
  description: "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' — DivisionByZero inherits from DecimalException (16 chars) as its first base; 'DecimalException' (16 chars) > 'DivisionByZero' (14 chars) by 2: the base is 2 characters longer than the derived; DivisionByZero also has ZeroDivisionError as a second base (via multiple inheritance) — making it catchable as both a decimal exception and a standard division-by-zero error; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.DivisionByZero.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra164.Overflow_name_is_Overflow:
  description: "decimal.Overflow.__name__ == 'Overflow' — raised when a result is too large for the current precision; 'Overflow' has 8 characters: 'Over'(4)+'flow'(4)=8; Overflow (8) > Inexact (7) by 1; Overflow (8) < Underflow (9) by 1; the symmetric pair Overflow/Underflow straddles 8 and 9 with a unit gap; Overflow inherits from Inexact (not DecimalException directly) because overflow results are inherently inexact; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Overflow.__name__.__eq__
  args: ["Overflow"]
  expected: true

invariant decimal_extra164.Overflow_base_is_Inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow inherits from Inexact (7 chars), NOT from DecimalException directly; 'Inexact' has 7 characters; the inheritance chain is: DecimalException -> Inexact -> Overflow; Overflow.__bases__[0].__name__ (7: 'Inexact') < Overflow.__name__ (8: 'Overflow') by 1: base is 1 character shorter; both Overflow and Underflow share Inexact as their immediate base — a parallel inheritance structure for the two magnitude-range exceptions; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

invariant decimal_extra164.Underflow_name_is_Underflow:
  description: "decimal.Underflow.__name__ == 'Underflow' — raised when a result is too small (subnormal and inexact); 'Underflow' has 9 characters: 'Under'(5)+'flow'(4)=9; Underflow (9) > Overflow (8) by 1 because 'Under' (5) > 'Over' (4) by 1; Underflow (9) == len('fullmatch') == len('RegexFlag') == len('PosixPath') — cross-module 9-character ties; Underflow inherits from Inexact (not DecimalException directly); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Underflow.__name__.__eq__
  args: ["Underflow"]
  expected: true

invariant decimal_extra164.Inexact_name_is_Inexact:
  description: "decimal.Inexact.__name__ == 'Inexact' — the base class for decimal exceptions where results cannot be represented exactly; 'Inexact' has 7 characters: 'In'(2)+'exact'(5)=7; Inexact (7) == len('Decimal') == len('Context') == len('decimal') == 7: a four-way tie at 7 characters across the primary decimal module names and the module name itself; Inexact (7) is the minimum exception name in this spec; Inexact serves as the immediate base for both Overflow and Underflow — an intermediate exception class in the decimal hierarchy; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Inexact.__name__.__eq__
  args: ["Inexact"]
  expected: true

invariant decimal_extra164.Inexact_base_is_DecimalException:
  description: "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact inherits directly from DecimalException (16 chars); 'DecimalException' has 16 characters; Inexact.__bases__[0].__name__ (16: 'DecimalException') > Inexact.__name__ (7: 'Inexact') by 9 == len('Exception'): the 9-character gap between base and derived name equals the length of the 'Exception' component; Inexact is the intermediate base in the chain DecimalException -> Inexact -> Overflow/Underflow; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Inexact.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

