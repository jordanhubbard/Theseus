# ---------------------------------------------------------------------------
# getmembers and classify_class_attrs code objects — extra79
#
# Wave 244 theme: getmembers/classify_class_attrs code object attributes.
#
# inspect.getmembers.__code__.co_name              == 'getmembers'
# inspect.getmembers.__code__.co_argcount          == 2
# inspect.classify_class_attrs.__code__.co_name    == 'classify_class_attrs'
# inspect.classify_class_attrs.__code__.co_argcount == 1
#
# No prior inspect spec checks getmembers/classify_class_attrs code objects via inspectextra79. New to extra79.
# ---------------------------------------------------------------------------

table inspect_extra79.getmembers_classify_code:
  description: "getmembers.__code__.co_name=='getmembers', co_argcount==2; classify_class_attrs co_name=='classify_class_attrs', co_argcount==1; wave 244 getmembers/classify_class_attrs code attrs; new to extra79"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra79

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_code_co_name_eq_getmembers,
       getmembers.__code__.co_name.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__code__.co_name.__eq__('getmembers') == True — getmembers is a pure-Python function defined in Lib/inspect.py that returns all the members of an object in a list of (name, value) pairs; its code object's co_name attribute records the function name 'getmembers' (10 chars); str.__eq__('getmembers') returns True; no prior inspect spec checks getmembers.__code__.co_name via inspectextra79; new to extra79"]
    - [getmembers_code_co_argcount_eq_2,
       getmembers.__code__.co_argcount.__eq__,
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers(object, predicate=None) takes two positional-or-keyword arguments: object and predicate (predicate has a default of None but co_argcount still counts it); the code object's co_argcount is 2; int.__eq__(2) returns True; no prior inspect spec checks getmembers.__code__.co_argcount via inspectextra79; new to extra79"]
    - [classify_class_attrs_code_co_name_eq_classify_class_attrs,
       classify_class_attrs.__code__.co_name.__eq__,
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__code__.co_name.__eq__('classify_class_attrs') == True — classify_class_attrs is a pure-Python function defined in Lib/inspect.py that returns a list of Attribute namedtuples describing the class's attributes; its code object's co_name attribute records the function name 'classify_class_attrs' (20 chars); str.__eq__('classify_class_attrs') returns True; no prior inspect spec checks classify_class_attrs.__code__.co_name via inspectextra79; new to extra79"]
    - [classify_class_attrs_code_co_argcount_eq_1,
       classify_class_attrs.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.classify_class_attrs.__code__.co_argcount.__eq__(1) == True — classify_class_attrs(cls) takes exactly one positional argument 'cls'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks classify_class_attrs.__code__.co_argcount via inspectextra79; new to extra79"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra79
# ---------------------------------------------------------------------------

invariant inspect_extra79.isfunction_code_co_name:
  description: "inspect.isfunction.__code__.co_name.__eq__('isfunction') == True — isfunction code object name is 'isfunction'; wave 244 isfunction code attrs; new to extra79"
  kind: python_call_eq
  function: isfunction.__code__.co_name.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra79.isclass_code_co_argcount:
  description: "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass(object) has 1 positional arg; wave 244 isclass code attrs; new to extra79"
  kind: python_call_eq
  function: isclass.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra79.isroutine_code_co_name:
  description: "inspect.isroutine.__code__.co_name.__eq__('isroutine') == True — isroutine code object name is 'isroutine'; wave 244 isroutine code attrs; new to extra79"
  kind: python_call_eq
  function: isroutine.__code__.co_name.__eq__
  args: ["isroutine"]
  expected: true

invariant inspect_extra79.getmembers_code_co_argcount:
  description: "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers(object, predicate=None) has 2 positional-or-keyword args; wave 244 getmembers code attrs; new to extra79"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra79.classify_class_attrs_code_co_name:
  description: "inspect.classify_class_attrs.__code__.co_name.__eq__('classify_class_attrs') == True — classify_class_attrs code object name is 'classify_class_attrs'; wave 244 classify_class_attrs code attrs; new to extra79"
  kind: python_call_eq
  function: classify_class_attrs.__code__.co_name.__eq__
  args: ["classify_class_attrs"]
  expected: true
