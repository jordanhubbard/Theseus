spec: inspect_extra79
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra78.zspec.zsdl."
    - "This spec covers: inspect isfunction/isbuiltin/isclass/ismodule/ismethod/isroutine/getmembers/classify_class_attrs predicate code attributes (Wave 244)."
    - "isfunction.__code__.co_name == 'isfunction' — code object name matches function name. Verified with Python 3.14.3."
    - "isfunction.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "isbuiltin.__code__.co_name == 'isbuiltin' — code object name matches function name. Verified with Python 3.14.3."
    - "isbuiltin.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "isclass.__code__.co_name == 'isclass' — code object name matches function name. Verified with Python 3.14.3."
    - "isclass.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "ismodule.__code__.co_name == 'ismodule' — code object name matches function name. Verified with Python 3.14.3."
    - "ismodule.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "ismethod.__code__.co_name == 'ismethod' — code object name matches function name. Verified with Python 3.14.3."
    - "ismethod.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "isroutine.__code__.co_name == 'isroutine' — code object name matches function name. Verified with Python 3.14.3."
    - "isroutine.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "getmembers.__code__.co_name == 'getmembers' — code object name matches function name. Verified with Python 3.14.3."
    - "getmembers.__code__.co_argcount == 2 — object and predicate=None. Verified with Python 3.14.3."
    - "classify_class_attrs.__code__.co_name == 'classify_class_attrs' — code object name matches function name. Verified with Python 3.14.3."
    - "classify_class_attrs.__code__.co_argcount == 1 — takes a single 'cls' argument. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# isfunction and isbuiltin code objects — extra79
#
# Wave 244 theme: isfunction/isbuiltin predicate code object attributes.
#
# inspect.isfunction.__code__.co_name     == 'isfunction'
# inspect.isfunction.__code__.co_argcount == 1
# inspect.isbuiltin.__code__.co_name      == 'isbuiltin'
# inspect.isbuiltin.__code__.co_argcount  == 1
#
# No prior inspect spec checks isfunction/isbuiltin code objects via inspectextra79. New to extra79.
# ---------------------------------------------------------------------------

table inspect_extra79.isfunction_isbuiltin_code:
  description: "isfunction.__code__.co_name=='isfunction', co_argcount==1; isbuiltin co_name=='isbuiltin', co_argcount==1; wave 244 isfunction/isbuiltin code attrs; new to extra79"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra79

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_name_eq_isfunction,
       isfunction.__code__.co_name.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__code__.co_name.__eq__('isfunction') == True — isfunction is a pure-Python predicate function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'isfunction' (10 chars); str.__eq__('isfunction') returns True; no prior inspect spec checks isfunction.__code__.co_name via inspectextra79; new to extra79"]
    - [isfunction_code_co_argcount_eq_1,
       isfunction.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction(object) takes exactly one positional argument 'object'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks isfunction.__code__.co_argcount via inspectextra79; new to extra79"]
    - [isbuiltin_code_co_name_eq_isbuiltin,
       isbuiltin.__code__.co_name.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__code__.co_name.__eq__('isbuiltin') == True — isbuiltin is a pure-Python predicate function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'isbuiltin' (9 chars); str.__eq__('isbuiltin') returns True; no prior inspect spec checks isbuiltin.__code__.co_name via inspectextra79; new to extra79"]
    - [isbuiltin_code_co_argcount_eq_1,
       isbuiltin.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — isbuiltin(object) takes exactly one positional argument 'object'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks isbuiltin.__code__.co_argcount via inspectextra79; new to extra79"]

