spec: copy_extra16
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
    - "copy_extra15.zspec.zsdl — covers module __name__/__package__; copy.__module__ in extra15 namespace; error.__qualname__ in extra15 namespace."
    - "copy_extra13.zspec.zsdl — covers copy/__name__/deepcopy/__name__/copy/__module__/deepcopy/__module__ standalone in extra13 namespace."
    - "copy_extra12.zspec.zsdl — covers copy/__name__ table; copy.__module__/__qualname__ standalone; Error.__qualname__; copy/deepcopy of [1,2,3]."
    - "copy_extra11.zspec.zsdl — covers copy/__name__/__module__; deepcopy/__name__/__module__; Error/__name__/__module__/__bases__; copy/deepcopy of 42/'hello'/True/[]."
    - "copy_extra6.zspec.zsdl — covers copy.__qualname__/deepcopy.__qualname__/Error.__qualname__; Error.__bases__[0].__name__; Error.__class__.__name__."
    - "copy_extra5.zspec.zsdl — covers copy.__qualname__/deepcopy.__qualname__/Error.__qualname__ as standalone invariants."
    - "copy_extra4.zspec.zsdl — covers copy.__name__/deepcopy.__name__/copy.__module__/deepcopy.__module__/Error.__name__/Error.__module__."
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra15.zspec.zsdl."
    - "Focus: copy.copy.__qualname__, copy.deepcopy.__qualname__, copy.Error.__qualname__, and copy.deepcopy.__module__ re-anchored in the extra16 namespace as standalone invariants and a consolidated table."
    - "copy.copy.__qualname__ == 'copy' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copy.deepcopy.__qualname__ == 'deepcopy' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copy.Error.__qualname__ == 'Error' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copy.copy.__module__ == 'copy' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copy.deepcopy.__module__ == 'copy' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copy.Error.__module__ == 'copy' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy.copy.__qualname__ — extra16 namespace standalone
#
# copy_extra5 and copy_extra6 cover copy.__qualname__ in those namespaces.
# Re-anchored here in the extra16 namespace as an independent standalone
# invariant. The function is defined at module top level in Lib/copy.py,
# so its __qualname__ equals its simple name 'copy'.
# ---------------------------------------------------------------------------

invariant copy_extra16.copy.qualname:
  description: "copy.copy.__qualname__ == 'copy' — top-level function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: copy.__qualname__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# copy.deepcopy.__qualname__ — extra16 namespace standalone
#
# copy_extra5 and copy_extra6 cover deepcopy.__qualname__ in those namespaces.
# Re-anchored here in the extra16 namespace as an independent standalone
# invariant. deepcopy is defined at module top level in Lib/copy.py,
# so its __qualname__ equals its simple name 'deepcopy'.
# ---------------------------------------------------------------------------

invariant copy_extra16.deepcopy.qualname:
  description: "copy.deepcopy.__qualname__ == 'deepcopy' — top-level function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: deepcopy.__qualname__.__eq__
  args: ["deepcopy"]
  expected: true

# ---------------------------------------------------------------------------
# copy.Error.__qualname__ — extra16 namespace standalone
#
# copy_extra5, copy_extra6, and copy_extra12 cover Error.__qualname__.
# Re-anchored here in the extra16 namespace as an independent standalone
# invariant. Error is defined at module top level in Lib/copy.py,
# so its __qualname__ equals its simple name 'Error'.
# ---------------------------------------------------------------------------

invariant copy_extra16.Error.qualname:
  description: "copy.Error.__qualname__ == 'Error' — top-level exception class; qualname equals simple name"
  category: class_qualname
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# copy.copy.__module__ — extra16 namespace standalone
#
# copy_extra4, copy_extra11, copy_extra13, and copy_extra15 cover
# copy.__module__ in various namespaces. Re-anchored here in the extra16
# namespace as an independent standalone invariant.
# ---------------------------------------------------------------------------

invariant copy_extra16.copy.module:
  description: "copy.copy.__module__ == 'copy' — function is defined in the copy module"
  category: function_module
  kind: python_call_eq
  function: copy.__module__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# copy.deepcopy.__module__ — extra16 namespace standalone
#
# copy_extra4, copy_extra11, copy_extra13 cover deepcopy.__module__
# in those namespaces. Re-anchored here in the extra16 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra16.deepcopy.module:
  description: "copy.deepcopy.__module__ == 'copy' — function is defined in the copy module"
  category: function_module
  kind: python_call_eq
  function: deepcopy.__module__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# copy.Error.__module__ — extra16 namespace standalone
#
# copy_extra4 and copy_extra11 cover Error.__module__ in those namespaces.
# Re-anchored here in the extra16 namespace as an independent standalone
# invariant. Error is defined in Lib/copy.py, so its __module__ == 'copy'.
# ---------------------------------------------------------------------------

invariant copy_extra16.Error.module:
  description: "copy.Error.__module__ == 'copy' — exception class is defined in the copy module"
  category: class_module
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — __qualname__ and __module__ for copy, deepcopy, Error
#
# Covers all six attribute checks in a single table in the extra16 namespace.
# ---------------------------------------------------------------------------

table copy_extra16.qualname_and_module:
  description: "__qualname__ and __module__ for copy.copy, copy.deepcopy, and copy.Error"
  kind: python_call_eq
  category: function_qualname

  columns: [id, function, args, expected]
  rows:
    - [copy_qualname,    copy.__qualname__.__eq__,    ["copy"],     true]
    - [deepcopy_qualname, deepcopy.__qualname__.__eq__, ["deepcopy"], true]
    - [Error_qualname,   Error.__qualname__.__eq__,   ["Error"],    true]
    - [copy_module,      copy.__module__.__eq__,      ["copy"],     true]
    - [deepcopy_module,  deepcopy.__module__.__eq__,  ["copy"],     true]
    - [Error_module,     Error.__module__.__eq__,     ["copy"],     true]
