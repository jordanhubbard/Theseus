spec: re_extra262
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra261.zspec.zsdl — covers flag integer values, I/M/S/X aliases, escape/purge identity"
    - "re_extra.zspec.zsdl — covers Pattern/Match class names, flag equality table, match/search/sub/split/findall"
  notes:
    - "re.Pattern.__name__ == 'Pattern', __module__ == 're'."
    - "re.Match.__name__ == 'Match', __module__ == 're'."
    - "re.RegexFlag.__name__ == 'RegexFlag', __module__ == 're', __bases__[0].__name__ == 'IntFlag', __bases__[0].__module__ == 'enum'."
    - "re.Scanner exists as a class: __name__ == 'Scanner', __module__ == 're'."
    - "re.sub.__name__ == 'sub', __qualname__ == 'sub', __module__ == 're', __class__.__name__ == 'function'."
    - "re.subn.__name__ == 'subn', __qualname__ == 'subn'."
    - "re.purge.__module__ == 're'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern — class identity
# ---------------------------------------------------------------------------

invariant re_extra262.Pattern.name:
  description: "re.Pattern.__name__ == 'Pattern'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra262.Pattern.module:
  description: "re.Pattern.__module__ == 're'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.Match — class identity
# ---------------------------------------------------------------------------

invariant re_extra262.Match.name:
  description: "re.Match.__name__ == 'Match'"
  category: class_metadata
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra262.Match.module:
  description: "re.Match.__module__ == 're'"
  category: class_metadata
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.RegexFlag — enum class identity and base
# ---------------------------------------------------------------------------

invariant re_extra262.RegexFlag.name:
  description: "re.RegexFlag.__name__ == 'RegexFlag'"
  category: class_metadata
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra262.RegexFlag.module:
  description: "re.RegexFlag.__module__ == 're'"
  category: class_metadata
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra262.RegexFlag.base_name:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag"
  category: class_metadata
  kind: python_call_eq
  function: RegexFlag.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "IntFlag"

invariant re_extra262.RegexFlag.base_module:
  description: "re.RegexFlag.__bases__[0].__module__ == 'enum' — IntFlag lives in the enum module"
  category: class_metadata
  kind: python_call_eq
  function: RegexFlag.__bases__.__getitem__
  args: [0]
  method: __module__
  method_args: []
  expected: "enum"

