spec: asyncio_extra91
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra90

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra90.zspec.zsdl."
    - "This spec covers: wave 251 theme — asyncio sync primitive class hierarchy: __bases__[0].__name__ and __mro__.__len__(). NEW in extra91: Lock.__bases__[0].__name__=='_ContextManagerMixin'; Lock.__mro__.__len__()==4; Semaphore.__bases__[0].__name__=='_ContextManagerMixin'; Semaphore.__mro__.__len__()==4; BoundedSemaphore.__bases__[0].__name__=='Semaphore'; BoundedSemaphore.__mro__.__len__()==5; Condition.__bases__[0].__name__=='_ContextManagerMixin'; Condition.__mro__.__len__()==4; Event.__bases__[0].__name__=='_LoopBoundMixin'; Event.__mro__.__len__()==3; Queue.__bases__[0].__name__=='_LoopBoundMixin'; Queue.__mro__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin'. Lock directly subclasses _ContextManagerMixin in Python 3.14.3 (asyncio/locks.py). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__mro__.__len__() == 4. MRO is [Lock, _ContextManagerMixin, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'. Semaphore directly subclasses _ContextManagerMixin. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__mro__.__len__() == 4. MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'. BoundedSemaphore directly subclasses Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__mro__.__len__() == 5. MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin'. Condition directly subclasses _ContextManagerMixin. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__mro__.__len__() == 4. MRO is [Condition, _ContextManagerMixin, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin'. Event directly subclasses _LoopBoundMixin (no _ContextManagerMixin). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__mro__.__len__() == 3. MRO is [Event, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin'. Queue directly subclasses _LoopBoundMixin. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__mro__.__len__() == 3. MRO is [Queue, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

