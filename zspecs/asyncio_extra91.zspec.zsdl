table asyncio_extra91.Lock_Semaphore_hierarchy:
  description: "asyncio Lock and Semaphore class hierarchy checks in asynciolockshier91 namespace — wave 251 theme: asyncio sync primitive class hierarchy __bases__[0].__name__ and __mro__.__len__(); Lock.__bases__[0].__name__=='_ContextManagerMixin' (Lock directly subclasses _ContextManagerMixin in asyncio/locks.py); Lock.__mro__.__len__()==4 (MRO is [Lock, _ContextManagerMixin, _LoopBoundMixin, object]); Semaphore.__bases__[0].__name__=='_ContextManagerMixin'; Semaphore.__mro__.__len__()==4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolockshier91

  columns: [id, function, args, expected, description]
  rows:
    - [lock_base_name,   "Lock.__bases__[0].__name__.__eq__",      ["_ContextManagerMixin"], true, "Lock.__bases__[0].__name__ == '_ContextManagerMixin' — Lock directly subclasses _ContextManagerMixin; verified with Python 3.14.3"]
    - [lock_mro_len,     Lock.__mro__.__len__,                     [],                       4,    "Lock.__mro__.__len__() == 4 — MRO is [Lock, _ContextManagerMixin, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [sem_base_name,    "Semaphore.__bases__[0].__name__.__eq__", ["_ContextManagerMixin"], true, "Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' — Semaphore directly subclasses _ContextManagerMixin; verified with Python 3.14.3"]
    - [sem_mro_len,      Semaphore.__mro__.__len__,                [],                       4,    "Semaphore.__mro__.__len__() == 4 — MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; verified with Python 3.14.3"]

