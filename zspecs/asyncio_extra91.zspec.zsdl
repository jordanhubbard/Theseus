# ---------------------------------------------------------------------------
# asyncio cross-checks: hierarchy facts — extra91
#
# Cross-checks confirming key hierarchy facts.
# BoundedSemaphore has the deepest MRO (5).
# Event and Queue share the same shallow MRO depth (3).
# Lock, Semaphore, and Condition all have MRO depth 4.
# ---------------------------------------------------------------------------

table asyncio_extra91.cross_check_hierarchy:
  description: "asyncio sync primitive class hierarchy cross-checks in asynciolockshier91 namespace — wave 251 theme: asyncio sync primitive class hierarchy __bases__[0].__name__ and __mro__.__len__(); BoundedSemaphore.__mro__.__len__()==5 (cross-check; deepest hierarchy); Lock.__mro__.__len__()==4 (cross-check); Event.__mro__.__len__()==3 (cross-check); Queue.__mro__.__len__()==3 (cross-check); BoundedSemaphore.__bases__[0].__name__=='Semaphore' (cross-check); Lock.__bases__[0].__name__=='_ContextManagerMixin' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolockshier91c

  columns: [id, function, args, expected, description]
  rows:
    - [bsem_mro_cross,      BoundedSemaphore.__mro__.__len__,                [],                       5,    "BoundedSemaphore.__mro__.__len__() == 5 — cross-check; deepest hierarchy among sync primitives; verified with Python 3.14.3"]
    - [lock_mro_cross,      Lock.__mro__.__len__,                            [],                       4,    "Lock.__mro__.__len__() == 4 — cross-check; verified with Python 3.14.3"]
    - [event_mro_cross,     Event.__mro__.__len__,                           [],                       3,    "Event.__mro__.__len__() == 3 — cross-check; verified with Python 3.14.3"]
    - [queue_mro_cross,     Queue.__mro__.__len__,                           [],                       3,    "Queue.__mro__.__len__() == 3 — cross-check; verified with Python 3.14.3"]
    - [bsem_base_cross,     "BoundedSemaphore.__bases__[0].__name__.__eq__", ["Semaphore"],            true, "BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — cross-check; verified with Python 3.14.3"]
    - [lock_base_cross,     "Lock.__bases__[0].__name__.__eq__",             ["_ContextManagerMixin"], true, "Lock.__bases__[0].__name__ == '_ContextManagerMixin' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra91
# ---------------------------------------------------------------------------

invariant asyncio_extra91.Lock_base_is_ContextManagerMixin:
  description: "asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — Lock directly subclasses _ContextManagerMixin in asyncio/locks.py; this mixin provides the async context manager protocol (__aenter__/__aexit__); NEW in extra91: first standalone __bases__ hierarchy invariant for Lock in asynciolockshier91 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Lock.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra91.Lock_mro_len:
  description: "asyncio.Lock.__mro__.__len__() == 4 — MRO is [Lock, _ContextManagerMixin, _LoopBoundMixin, object]; Lock has two intermediate mixin classes in its hierarchy; NEW in extra91: first standalone MRO length invariant for Lock in asynciolockshier91 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Lock.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra91.BoundedSemaphore_base_is_Semaphore:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') returns True — BoundedSemaphore directly subclasses Semaphore, making it the only sync primitive in this group that directly subclasses another asyncio primitive (not a mixin); NEW in extra91: first standalone __bases__ hierarchy invariant for BoundedSemaphore in asynciolockshier91 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra91.Event_base_is_LoopBoundMixin:
  description: "asyncio.Event.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — Event directly subclasses _LoopBoundMixin (not _ContextManagerMixin), because Event does not support the async context manager protocol; NEW in extra91: first standalone __bases__ hierarchy invariant for Event in asynciolockshier91 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra91.BoundedSemaphore_mro_len:
  description: "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; BoundedSemaphore has the deepest class hierarchy among the asyncio sync primitives covered here; NEW in extra91: first standalone MRO length invariant for BoundedSemaphore in asynciolockshier91 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__mro__.__len__
  args: []
  expected: 5
