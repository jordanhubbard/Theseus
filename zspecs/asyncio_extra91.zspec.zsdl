    - [bsem_mro_len,    BoundedSemaphore.__mro__.__len__,                [],                       5,    "BoundedSemaphore.__mro__.__len__() == 5 — MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; verified with Python 3.14.3"]
