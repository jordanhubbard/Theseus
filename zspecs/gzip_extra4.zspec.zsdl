spec: gzip_extra4
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "RFC 1952 — GZIP file format specification version 4.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
    - "gzip.zspec.zsdl — covers compress/decompress roundtrips via pre-computed hex, compress output length, BadGzipFile error cases, BadGzipFile.__name__"
    - "gzip_extra.zspec.zsdl — covers GzipFile/__name__/__module__, BadGzipFile/__module__/base, compress/decompress/open __name__, compress/__module__, compress returns bytes, roundtrip"
    - "gzip_extra2.zspec.zsdl — covers compress(b'') behavior, decompress empty roundtrip, GzipFile base class, open/__module__, decompress/__module__, BadGzipFile MRO, GzipFile method names"
    - "gzip_extra3.zspec.zsdl — covers GzipFile/__name__, BadGzipFile/__name__, compress/decompress/open __name__ table, GzipFile/__module__, BadGzipFile base, compress returns bytes (method_chain), compress header magic byte[0], compress/__module__, decompress/__module__"
  notes:
    - "This spec adds __qualname__ vectors for gzip classes and functions."
    - "gzip.GzipFile.__qualname__ == 'GzipFile' — top-level class."
    - "gzip.BadGzipFile.__qualname__ == 'BadGzipFile' — top-level exception class (Python 3.8+)."
    - "gzip.open.__qualname__ == 'open' — module-level function."
    - "gzip.compress.__qualname__ == 'compress' — module-level function."
    - "gzip.decompress.__qualname__ == 'decompress' — module-level function."
    - "gzip.compress(b'').__class__.__name__ == 'bytes' — empty input produces bytes output."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — GzipFile class and BadGzipFile exception
# Top-level classes have __qualname__ == __name__.
# ---------------------------------------------------------------------------

table gzip_extra4.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__qualname__.__eq__,    ["GzipFile"],    true]
    - [BadGzipFile, BadGzipFile.__qualname__.__eq__, ["BadGzipFile"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — module-level functions
# All three are plain module-level functions; qualname == name.
# ---------------------------------------------------------------------------

table gzip_extra4.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [open,       open.__qualname__.__eq__,       ["open"],       true]
    - [compress,   compress.__qualname__.__eq__,   ["compress"],   true]
    - [decompress, decompress.__qualname__.__eq__, ["decompress"], true]

# ---------------------------------------------------------------------------
# compress(b'') returns bytes — via method_chain in invariant block
# gzip_extra2 covers b'' length and hex, but not via method_chain on __class__.
# gzip_extra3 covers b'hello' method_chain; this covers b'' (distinct vector).
# ---------------------------------------------------------------------------

invariant gzip_extra4.compress.empty_class_name:
  description: "gzip.compress(b'').__class__.__name__ == 'bytes' — empty input still returns bytes"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!hex ""]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# GzipFile.__qualname__ cross-check: qualname attribute is a str
# ---------------------------------------------------------------------------

invariant gzip_extra4.GzipFile.qualname_is_str:
  description: "gzip.GzipFile.__qualname__.__class__.__name__ == 'str' — __qualname__ is always a str"
  category: qualnames
  kind: python_call_eq
  function: GzipFile.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# decompress.__qualname__ == decompress.__name__ — module-level function invariant
# ---------------------------------------------------------------------------

invariant gzip_extra4.decompress.qualname_eq_name:
  description: "gzip.decompress.__qualname__ == 'decompress' — qualname matches name for module-level function"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true
