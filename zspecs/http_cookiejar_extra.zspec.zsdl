spec: http_cookiejar_extra
version: ">=3.0"
backend: python_module(http.cookiejar)

docs: https://docs.python.org/3/library/http.cookiejar.html

provenance:
  derived_from:
    - "Python http.cookiejar documentation — https://docs.python.org/3/library/http.cookiejar.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/cookiejar.py"
  notes:
    - "This spec extends http_cookiejar.zspec.zsdl."
    - "http_cookiejar.zspec.zsdl already covers: __name__ checks for CookieJar/CookiePolicy/DefaultCookiePolicy/FileCookieJar/LWPCookieJar/MozillaCookieJar/Cookie/LoadError (table), CookieJar.__module__, DefaultCookiePolicy/__bases__[0].__name__, FileCookieJar/__bases__[0].__name__, LoadError/__bases__[0].__name__, CookieJar().__len__()."
    - "This spec adds: __qualname__ checks for CookieJar/FileCookieJar/LWPCookieJar/MozillaCookieJar/Cookie/CookiePolicy/DefaultCookiePolicy — none are present in the base spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — all seven public http.cookiejar classes
# (http_cookiejar.zspec.zsdl covers __name__ but NOT __qualname__)
# ---------------------------------------------------------------------------

table http_cookiejar_extra.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [CookieJar,            CookieJar.__qualname__.__eq__,            ["CookieJar"],            true]
    - [FileCookieJar,        FileCookieJar.__qualname__.__eq__,        ["FileCookieJar"],        true]
    - [LWPCookieJar,         LWPCookieJar.__qualname__.__eq__,         ["LWPCookieJar"],         true]
    - [MozillaCookieJar,     MozillaCookieJar.__qualname__.__eq__,     ["MozillaCookieJar"],     true]
    - [Cookie,               Cookie.__qualname__.__eq__,               ["Cookie"],               true]
    - [CookiePolicy,         CookiePolicy.__qualname__.__eq__,         ["CookiePolicy"],         true]
    - [DefaultCookiePolicy,  DefaultCookiePolicy.__qualname__.__eq__,  ["DefaultCookiePolicy"],  true]
