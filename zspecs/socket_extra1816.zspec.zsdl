spec: socket_extra1816
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "socket module CPython source"
    - "Python data model documentation"
  not_derived_from:
    - "any third-party socket library"
  notes:
    - "Tests __format__, __repr__, __str__ presence in socket.socket and exception class __dict__"
    - "Tests __reduce__, __copy__, __deepcopy__, __getstate__ for copy/pickle protocol"
    - "socket.socket defines __repr__ and __reduce__ (to prevent pickling with error)"
    - "Tests socket module-level constants and class bindings"
  created_at: "2026-04-12"

table socket_extra1816.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["sk1816-fp-001", "socket.socket.__dict__.__contains__", ["__format__"], false]
    - ["sk1816-fp-002", "socket.socket.__dict__.__contains__", ["__repr__"], true]
    - ["sk1816-fp-003", "socket.socket.__dict__.__contains__", ["__str__"], false]
    - ["sk1816-fp-004", "socket.error.__dict__.__contains__", ["__format__"], false]
    - ["sk1816-fp-005", "socket.error.__dict__.__contains__", ["__repr__"], false]
    - ["sk1816-fp-006", "socket.timeout.__dict__.__contains__", ["__repr__"], false]
    - ["sk1816-fp-007", "socket.herror.__dict__.__contains__", ["__repr__"], false]
    - ["sk1816-fp-008", "socket.gaierror.__dict__.__contains__", ["__repr__"], false]

table socket_extra1816.copy_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["sk1816-cp-001", "socket.socket.__dict__.__contains__", ["__reduce__"], true]
    - ["sk1816-cp-002", "socket.socket.__dict__.__contains__", ["__copy__"], false]
    - ["sk1816-cp-003", "socket.socket.__dict__.__contains__", ["__deepcopy__"], false]
    - ["sk1816-cp-004", "socket.socket.__dict__.__contains__", ["__getstate__"], false]
    - ["sk1816-cp-005", "socket.error.__dict__.__contains__", ["__reduce__"], false]
    - ["sk1816-cp-006", "socket.error.__dict__.__contains__", ["__copy__"], false]

table socket_extra1816.socket_module_constants:
  columns: [id, function, args, expected]
  rows:
    - ["sk1816-mc-001", "socket.__dict__.__contains__", ["socket"], true]
    - ["sk1816-mc-002", "socket.__dict__.__contains__", ["error"], true]
    - ["sk1816-mc-003", "socket.__dict__.__contains__", ["timeout"], true]
    - ["sk1816-mc-004", "socket.__dict__.__contains__", ["herror"], true]
    - ["sk1816-mc-005", "socket.__dict__.__contains__", ["gaierror"], true]
    - ["sk1816-mc-006", "socket.__dict__.__contains__", ["AF_INET"], true]
    - ["sk1816-mc-007", "socket.__dict__.__contains__", ["AF_INET6"], true]
    - ["sk1816-mc-008", "socket.__dict__.__contains__", ["SOCK_STREAM"], true]
    - ["sk1816-mc-009", "socket.__dict__.__contains__", ["SOCK_DGRAM"], true]
    - ["sk1816-mc-010", "socket.__dict__.__contains__", ["getaddrinfo"], true]
