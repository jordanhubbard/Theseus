  id_prefix: mp370m

  columns: [id, function, args, expected]
  rows:
    - [mp370m001, multiprocessing.queues.Queue.__module__.__eq__, ["multiprocessing.queues"], true]
    - [mp370m002, multiprocessing.queues.SimpleQueue.__module__.__eq__, ["multiprocessing.queues"], true]
    - [mp370m003, multiprocessing.queues.JoinableQueue.__module__.__eq__, ["multiprocessing.queues"], true]

table multiprocessing_extra370.queue_class_bases:
  description: "Verify __bases__[0].__name__ (immediate base class name) of multiprocessing.queues classes"
  kind: python_call_eq
