  columns: [id, function, args, expected]
  rows:
    - ["mp370b001", "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__", ["object"], true]
    - ["mp370b002", "multiprocessing.queues.SimpleQueue.__bases__[0].__name__.__eq__", ["object"], true]
    - ["mp370b003", "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__", ["Queue"], true]

table multiprocessing_extra370.pipe_identity:
  description: "Verify __name__ and __module__ of multiprocessing.Pipe function"
