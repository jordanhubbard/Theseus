spec: multiprocessing_extra370
version: ">=3.9"
backend: python_module(multiprocessing.queues)
docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue — multiprocessing Queue documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.Queue is a function (not a class); type(multiprocessing.Queue).__name__ is 'method'"
    - "multiprocessing.queues.Queue lives in module multiprocessing.queues and derives from object"
    - "multiprocessing.queues.SimpleQueue lives in module multiprocessing.queues and derives from object"
    - "multiprocessing.queues.JoinableQueue lives in module multiprocessing.queues and derives from Queue"
    - "multiprocessing.Pipe is a function living in module multiprocessing.context"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra370.queue_class_names:
  description: "Verify __name__ attribute of multiprocessing.queues classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp370n

  columns: [id, function, args, expected]
  rows:
    - [mp370n001, multiprocessing.queues.Queue.__name__.__eq__, ["Queue"], true]
    - [mp370n002, multiprocessing.queues.SimpleQueue.__name__.__eq__, ["SimpleQueue"], true]
    - [mp370n003, multiprocessing.queues.JoinableQueue.__name__.__eq__, ["JoinableQueue"], true]

table multiprocessing_extra370.queue_class_modules:
  description: "Verify __module__ attribute of multiprocessing.queues classes"
