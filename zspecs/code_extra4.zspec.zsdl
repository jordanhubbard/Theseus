spec: code_extra4
version: ">=3.9"
backend: python_module(code)

docs: https://docs.python.org/3/library/code.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/code.html — Python code module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/code.py"
  notes:
    - "This spec extends code.zspec.zsdl and code_extra through code_extra3.zspec.zsdl."
    - "code covers: function __name__ (interact/compile_command); class __name__ (InteractiveConsole/InteractiveInterpreter/CommandCompiler); InteractiveConsole.__module__/__bases__[0]; InteractiveInterpreter method names; compile_command behavioral tests."
    - "code_extra covers: InteractiveConsole/__module__; InteractiveInterpreter/__module__; base hierarchy; CommandCompiler/__name__/__module__; function names; InteractiveInterpreter method names table."
    - "code_extra2 covers: InteractiveInterpreter.__bases__[0].__name__=='object'; compile_command/__module__=='codeop'; interact.__module__=='code'; class qualnames table."
    - "code_extra3 covers: InteractiveConsole/__InteractiveInterpreter __bases__.__len__==1; CommandCompiler/interact/compile_command __qualname__; InteractiveConsole.__bases__[0].__qualname__."
    - "This spec adds: InteractiveInterpreter method __qualname__ checks; InteractiveConsole method names (push/resetbuffer/raw_input); CommandCompiler.__bases__[0].__name__; CommandCompiler.__bases__.__len__."
    - "code.InteractiveInterpreter.runsource.__qualname__ == 'InteractiveInterpreter.runsource'."
    - "code.InteractiveConsole.push.__name__ == 'push' — appends a line to the buffer and tries to run it."
    - "code.InteractiveConsole.resetbuffer.__name__ == 'resetbuffer' — resets the input buffer."
    - "code.CommandCompiler.__bases__[0].__name__ == 'object' — CommandCompiler inherits directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# InteractiveInterpreter method __qualname__ checks
# code/code_extra cover method __name__; __qualname__ is new here.
# ---------------------------------------------------------------------------

invariant code_extra4.InteractiveInterpreter.runsource_qualname:
  description: "code.InteractiveInterpreter.runsource.__qualname__ == 'InteractiveInterpreter.runsource'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveInterpreter.runsource.__qualname__.__eq__
  args: ["InteractiveInterpreter.runsource"]
  expected: true

invariant code_extra4.InteractiveInterpreter.runcode_qualname:
  description: "code.InteractiveInterpreter.runcode.__qualname__ == 'InteractiveInterpreter.runcode'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveInterpreter.runcode.__qualname__.__eq__
  args: ["InteractiveInterpreter.runcode"]
  expected: true

invariant code_extra4.InteractiveInterpreter.write_qualname:
  description: "code.InteractiveInterpreter.write.__qualname__ == 'InteractiveInterpreter.write'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveInterpreter.write.__qualname__.__eq__
  args: ["InteractiveInterpreter.write"]
  expected: true

invariant code_extra4.InteractiveInterpreter.showtraceback_qualname:
  description: "code.InteractiveInterpreter.showtraceback.__qualname__ == 'InteractiveInterpreter.showtraceback'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveInterpreter.showtraceback.__qualname__.__eq__
  args: ["InteractiveInterpreter.showtraceback"]
  expected: true

invariant code_extra4.InteractiveInterpreter.showsyntaxerror_qualname:
  description: "code.InteractiveInterpreter.showsyntaxerror.__qualname__ == 'InteractiveInterpreter.showsyntaxerror'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveInterpreter.showsyntaxerror.__qualname__.__eq__
  args: ["InteractiveInterpreter.showsyntaxerror"]
  expected: true

# ---------------------------------------------------------------------------
# InteractiveConsole method names — push, resetbuffer, raw_input
# Not covered in any prior code spec.
# ---------------------------------------------------------------------------

invariant code_extra4.InteractiveConsole.push_name:
  description: "code.InteractiveConsole.push.__name__ == 'push'"
  category: method_names
  kind: python_call_eq
  function: InteractiveConsole.push.__name__.__eq__
  args: ["push"]
  expected: true

invariant code_extra4.InteractiveConsole.resetbuffer_name:
  description: "code.InteractiveConsole.resetbuffer.__name__ == 'resetbuffer'"
  category: method_names
  kind: python_call_eq
  function: InteractiveConsole.resetbuffer.__name__.__eq__
  args: ["resetbuffer"]
  expected: true

invariant code_extra4.InteractiveConsole.raw_input_name:
  description: "code.InteractiveConsole.raw_input.__name__ == 'raw_input'"
  category: method_names
  kind: python_call_eq
  function: InteractiveConsole.raw_input.__name__.__eq__
  args: ["raw_input"]
  expected: true

# ---------------------------------------------------------------------------
# CommandCompiler base class hierarchy
# code_extra covers CommandCompiler.__name__/__module__; base class is new here.
# ---------------------------------------------------------------------------

invariant code_extra4.CommandCompiler.base_is_object:
  description: "code.CommandCompiler.__bases__[0].__name__ == 'object' — CommandCompiler inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: CommandCompiler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant code_extra4.CommandCompiler.bases_len:
  description: "len(code.CommandCompiler.__bases__) == 1 — CommandCompiler has a single base class"
  category: class_hierarchy
  kind: python_call_eq
  function: CommandCompiler.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# InteractiveConsole method __qualname__ checks — push and resetbuffer
# Confirms the enclosing-class scope in qualname; not covered elsewhere.
# ---------------------------------------------------------------------------

invariant code_extra4.InteractiveConsole.push_qualname:
  description: "code.InteractiveConsole.push.__qualname__ == 'InteractiveConsole.push'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveConsole.push.__qualname__.__eq__
  args: ["InteractiveConsole.push"]
  expected: true

invariant code_extra4.InteractiveConsole.resetbuffer_qualname:
  description: "code.InteractiveConsole.resetbuffer.__qualname__ == 'InteractiveConsole.resetbuffer'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveConsole.resetbuffer.__qualname__.__eq__
  args: ["InteractiveConsole.resetbuffer"]
  expected: true
