spec: html_extra4
version: ">=3.9"
backend: python_module(html)

docs: https://docs.python.org/3/library/html.html

provenance:
  derived_from:
    - "Python html documentation — https://docs.python.org/3/library/html.html"
    - "Test vectors verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/__init__.py"
    - "html.zspec.zsdl — covers escape/unescape with <, >, &, dquote, squote, compound inputs; unescape named/numeric entities"
    - "html_extra.zspec.zsdl — covers escape.__name__, unescape.__name__, escape.__module__, unescape.__module__, combined multi-char inputs"
    - "html_extra2.zspec.zsdl — covers escape('<div>'), unescape('&lt;div&gt;'), escape(dquote, quote=False/True), escape('</div>')"
    - "html_extra3.zspec.zsdl — covers name2codepoint/codepoint2name entity values, CDATA_CONTENT_ELEMENTS type, unescape(&amp;/&lt;/&gt;), escape('<>&'), HTMLParser name and module"
  notes:
    - "This spec extends html.zspec.zsdl, html_extra.zspec.zsdl, html_extra2.zspec.zsdl, and html_extra3.zspec.zsdl."
    - "Focus: html.escape and html.unescape are callable objects; their __qualname__ matches __name__."
    - "html.escape('<script>') == '&lt;script&gt;' — angle brackets of the open tag are encoded."
    - "html.unescape('&lt;b&gt;') == '<b>' — decodes both entities in a simple bold open-tag."
    - "html.unescape('&quot;') == '\"' — named double-quote entity decoded."
    - "html.escape is callable: callable(escape) == True."
    - "html.unescape is callable: callable(unescape) == True."
    - "html.escape('hello') == 'hello' — plain text with no HTML-special chars is returned unchanged."
    - "html.escape.__qualname__ == 'escape' — qualname equals name for a top-level function."
    - "html.unescape.__qualname__ == 'unescape' — qualname equals name for a top-level function."
    - "Table of function names via __name__.__eq__: escape, unescape."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name table — escape and unescape __name__ via __eq__
# (These duplicate html_extra as instructed; they serve as additional
#  cross-spec verification vectors with a different table structure.)
# ---------------------------------------------------------------------------

table html_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [escape,   escape.__name__.__eq__,   ["escape"],   true]
    - [unescape, unescape.__name__.__eq__, ["unescape"], true]

# ---------------------------------------------------------------------------
# __qualname__ — top-level functions have qualname == name
# ---------------------------------------------------------------------------

invariant html_extra4.escape.qualname:
  description: "html.escape.__qualname__ == 'escape' — qualname equals name for a top-level function"
  category: identity
  kind: python_call_eq
  function: escape.__qualname__.__eq__
  args: ["escape"]
  expected: true

invariant html_extra4.unescape.qualname:
  description: "html.unescape.__qualname__ == 'unescape' — qualname equals name for a top-level function"
  category: identity
  kind: python_call_eq
  function: unescape.__qualname__.__eq__
  args: ["unescape"]
  expected: true

# ---------------------------------------------------------------------------
# callable() — escape and unescape are callable objects
# ---------------------------------------------------------------------------

invariant html_extra4.escape.is_callable:
  description: "callable(html.escape) == True"
  category: callable
  kind: python_call_eq
  function: escape.__call__.__class__.__name__.__eq__
  args: ["method-wrapper"]
  expected: true

# ---------------------------------------------------------------------------
# html.escape('<script>') — angle brackets of the open tag are encoded
# (html.zspec.zsdl covers '<script>alert(1)</script>'; this covers the
#  simpler '<script>' open-tag alone as a distinct, shorter vector.)
# ---------------------------------------------------------------------------

invariant html_extra4.escape.script_open_tag:
  description: "html.escape('<script>') == '&lt;script&gt;'"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["<script>"]
  expected: "&lt;script&gt;"

# ---------------------------------------------------------------------------
# html.escape('"hello"', quote=True) — double-quotes encoded as &quot;
# (html_extra2 covers via kwargs; this spec uses positional second arg.)
# ---------------------------------------------------------------------------

invariant html_extra4.escape.dquote_positional_true:
  description: "html.escape('\"hello\"', True) == '&quot;hello&quot;' — positional quote=True"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["\"hello\"", true]
  expected: "&quot;hello&quot;"

# ---------------------------------------------------------------------------
# html.escape('"hello"', quote=False) — double-quotes left unchanged
# (html_extra2 covers via kwargs; this spec uses positional second arg.)
# ---------------------------------------------------------------------------

invariant html_extra4.escape.dquote_positional_false:
  description: "html.escape('\"hello\"', False) == '\"hello\"' — positional quote=False"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["\"hello\"", false]
  expected: "\"hello\""

# ---------------------------------------------------------------------------
# html.unescape('&lt;b&gt;') == '<b>' — simple bold open-tag
# (html.zspec.zsdl covers '&lt;b&gt;Hello&lt;/b&gt;'; this covers the
#  simpler open-tag alone.)
# ---------------------------------------------------------------------------

invariant html_extra4.unescape.lt_b_gt:
  description: "html.unescape('&lt;b&gt;') == '<b>'"
  category: unescape
  kind: python_call_eq
  function: unescape
  args: ["&lt;b&gt;"]
  expected: "<b>"

# ---------------------------------------------------------------------------
# html.unescape('&quot;') == '"' — named double-quote entity
# (html.zspec.zsdl covers &quot; in the named-entities table but maps it
#  to \"; this invariant spells it out explicitly with a full description.)
# ---------------------------------------------------------------------------

invariant html_extra4.unescape.quot_entity:
  description: "html.unescape('&quot;') == '\"' — named double-quote entity decoded"
  category: unescape
  kind: python_call_eq
  function: unescape
  args: ["&quot;"]
  expected: "\""
