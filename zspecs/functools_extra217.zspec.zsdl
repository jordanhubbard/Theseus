spec: functools_extra217
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra216.zspec.zsdl — covers singledispatch.__code__.co_varnames membership, total_ordering.__doc__ checks, cached_property.__dict__ membership"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES and callable type checks"
  notes:
    - "functools.lru_cache.__qualname__ == 'lru_cache' — the qualified name of the lru_cache decorator is simply 'lru_cache'; it is a top-level function in the functools module. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' — the qualified name of the reduce function is 'reduce'; it is a top-level built-in function in functools. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' — the qualified name of the wraps decorator is 'wraps'; it is a top-level function. Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper' — the qualified name is 'update_wrapper'; len is 14. Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__ == 'cached_property' — the qualified name of the cached_property class is 'cached_property'; len is 15. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' — the qualified name is 'singledispatch'; len is 14. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__.__len__() == 9 — 'lru_cache' has 9 characters. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__.__len__() == 6 — 'reduce' has 6 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools __qualname__ equality checks — lru_cache, reduce, wraps
#
# lru_cache.__qualname__.__eq__('lru_cache')   == True
# reduce.__qualname__.__eq__('reduce')         == True
# wraps.__qualname__.__eq__('wraps')           == True
# reduce.__qualname__.__eq__('Reduce')         == False  (case-sensitive)
# ---------------------------------------------------------------------------

table functools_extra217.qualname_eq_group1:
  description: "functools __qualname__ equality checks for lru_cache, reduce, and wraps in functqualname217g1 namespace — lru_cache.__qualname__ is 'lru_cache' (True), reduce.__qualname__ is 'reduce' (True), wraps.__qualname__ is 'wraps' (True), and reduce.__qualname__.__eq__('Reduce') is False (case-sensitive comparison); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: qualname
  id_prefix: functqualname217g1

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a top-level function in functools; its __qualname__ is 'lru_cache' (9 characters); __eq__('lru_cache') returns True; verified with Python 3.14.3"]
    - [reduce_qualname_eq,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a top-level built-in in functools; its __qualname__ is 'reduce' (6 characters); __eq__('reduce') returns True; verified with Python 3.14.3"]
    - [wraps_qualname_eq,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is a top-level decorator function in functools; its __qualname__ is 'wraps' (5 characters); __eq__('wraps') returns True; verified with Python 3.14.3"]
    - [reduce_qualname_neq_Reduce,
       reduce.__qualname__.__eq__,
       ["Reduce"],
       false,
       "functools.reduce.__qualname__.__eq__('Reduce') == False — __qualname__ is 'reduce' (lowercase); comparing against 'Reduce' (capital R) returns False because __eq__ is case-sensitive; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: functools __qualname__ equality checks — update_wrapper, cached_property, singledispatch
#
# update_wrapper.__qualname__.__eq__('update_wrapper')     == True
# cached_property.__qualname__.__eq__('cached_property')   == True
# singledispatch.__qualname__.__eq__('singledispatch')     == True
# lru_cache.__qualname__.__eq__('lru_cache_x')             == False
# ---------------------------------------------------------------------------

table functools_extra217.qualname_eq_group2:
  description: "functools __qualname__ equality checks for update_wrapper, cached_property, and singledispatch in functqualname217g2 namespace — update_wrapper.__qualname__ is 'update_wrapper' (14 chars, True), cached_property.__qualname__ is 'cached_property' (15 chars, True), singledispatch.__qualname__ is 'singledispatch' (14 chars, True), and lru_cache.__qualname__.__eq__('lru_cache_x') is False; all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: qualname
  id_prefix: functqualname217g2

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_qualname_eq,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — update_wrapper is a top-level function in functools; its __qualname__ is 'update_wrapper' (14 characters); __eq__('update_wrapper') returns True; verified with Python 3.14.3"]
    - [cached_property_qualname_eq,
       "cached_property.__qualname__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property is a class in functools; its __qualname__ is 'cached_property' (15 characters); __eq__('cached_property') returns True; verified with Python 3.14.3"]
    - [singledispatch_qualname_eq,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is a top-level decorator in functools; its __qualname__ is 'singledispatch' (14 characters); __eq__('singledispatch') returns True; verified with Python 3.14.3"]
    - [lru_cache_qualname_neq_suffix,
       lru_cache.__qualname__.__eq__,
       ["lru_cache_x"],
       false,
       "functools.lru_cache.__qualname__.__eq__('lru_cache_x') == False — __qualname__ is 'lru_cache'; appending '_x' gives 'lru_cache_x' which is not equal; __eq__ returns False; verified with Python 3.14.3"]

