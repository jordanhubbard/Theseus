spec: pathlib_extra102
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra101

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra101.zspec.zsdl."
    - "This spec covers: pathlib.Path and PurePath __dict__ membership for dunder methods."
    - "pathlib.Path inherits most dunders from PurePath; only __new__ is defined directly in Path.__dict__."
    - "pathlib.PurePath defines virtually all dunders: __init__, __new__, __repr__, __str__, __hash__, __eq__, comparison operators, __truediv__, __rtruediv__, __bytes__, __reduce__, __fspath__."
    - "Path.__dict__.__contains__('__new__') = True (Path overrides __new__ to return the concrete platform subclass)."
    - "Path.__dict__.__contains__('__eq__') = False (inherited from PurePath)."
    - "Path.__dict__.__contains__('__str__') = False (inherited from PurePath)."
    - "PurePath.__dict__.__contains__('__init__') = True (PurePath defines __init__)."
    - "PurePath.__dict__.__contains__('__truediv__') = True (PurePath defines the / operator)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership for comparison dunders
# __eq__, __lt__, __gt__, __le__, __ge__, __hash__
# All False: Path inherits these from PurePath (they live in PurePath.__dict__)
# ---------------------------------------------------------------------------

table pathlib_extra102.Path_dict_comparison_dunders:
  description: "pathlib.Path.__dict__ membership for comparison dunders: __eq__, __lt__, __gt__, __le__, __ge__, __hash__ — all False (inherited from PurePath)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibpathdunder102

  columns: [id, function, args, expected]
  rows:
    - [path_has_eq,   "Path.__dict__.__contains__", ["__eq__"],   false]
    - [path_has_lt,   "Path.__dict__.__contains__", ["__lt__"],   false]
    - [path_has_gt,   "Path.__dict__.__contains__", ["__gt__"],   false]
    - [path_has_le,   "Path.__dict__.__contains__", ["__le__"],   false]
    - [path_has_ge,   "Path.__dict__.__contains__", ["__ge__"],   false]
    - [path_has_hash, "Path.__dict__.__contains__", ["__hash__"], false]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership for conversion dunders
# __str__, __repr__, __bytes__, __fspath__
# All False: Path inherits these from PurePath
# ---------------------------------------------------------------------------

table pathlib_extra102.Path_dict_conversion_dunders:
  description: "pathlib.Path.__dict__ membership for conversion dunders: __str__, __repr__, __bytes__, __fspath__ — all False (inherited from PurePath)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibpathdunder102

  columns: [id, function, args, expected]
  rows:
    - [path_has_str,   "Path.__dict__.__contains__", ["__str__"],   false]
    - [path_has_repr,  "Path.__dict__.__contains__", ["__repr__"],  false]
    - [path_has_bytes, "Path.__dict__.__contains__", ["__bytes__"], false]
    - [path_has_fspath,"Path.__dict__.__contains__", ["__fspath__"],false]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership for operator and constructor dunders
# __truediv__, __rtruediv__ -> False (inherited from PurePath)
# __new__ -> True (Path overrides __new__ to dispatch to the platform subclass)
# __init__ -> False (inherited from PurePath)
# ---------------------------------------------------------------------------

table pathlib_extra102.Path_dict_operator_dunders:
  description: "pathlib.Path.__dict__ membership for operator dunders: __truediv__ and __rtruediv__ are False (inherited); __new__ is True (Path override); __init__ is False"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibpathdunder102

  columns: [id, function, args, expected]
  rows:
    - [path_has_truediv,  "Path.__dict__.__contains__", ["__truediv__"],  false]
    - [path_has_rtruediv, "Path.__dict__.__contains__", ["__rtruediv__"], false]
    - [path_has_new,      "Path.__dict__.__contains__", ["__new__"],      true]
    - [path_has_init,     "Path.__dict__.__contains__", ["__init__"],     false]
    - [path_has_reduce,   "Path.__dict__.__contains__", ["__reduce__"],   false]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__ membership for the same dunders
# All True: PurePath defines all of these methods
# ---------------------------------------------------------------------------

table pathlib_extra102.PurePath_dict_dunders:
  description: "pathlib.PurePath.__dict__ membership for dunders: __init__, __new__, __repr__, __str__, __hash__, __eq__, __lt__, __gt__, __le__, __ge__, __truediv__, __rtruediv__, __bytes__, __fspath__ — all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibpathdunder102

  columns: [id, function, args, expected]
  rows:
    - [pp_has_init,     "PurePath.__dict__.__contains__", ["__init__"],     true]
    - [pp_has_new,      "PurePath.__dict__.__contains__", ["__new__"],      true]
    - [pp_has_repr,     "PurePath.__dict__.__contains__", ["__repr__"],     true]
    - [pp_has_str,      "PurePath.__dict__.__contains__", ["__str__"],      true]
    - [pp_has_hash,     "PurePath.__dict__.__contains__", ["__hash__"],     true]
    - [pp_has_eq,       "PurePath.__dict__.__contains__", ["__eq__"],       true]
    - [pp_has_lt,       "PurePath.__dict__.__contains__", ["__lt__"],       true]
    - [pp_has_gt,       "PurePath.__dict__.__contains__", ["__gt__"],       true]
    - [pp_has_le,       "PurePath.__dict__.__contains__", ["__le__"],       true]
    - [pp_has_ge,       "PurePath.__dict__.__contains__", ["__ge__"],       true]
    - [pp_has_truediv,  "PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - [pp_has_rtruediv, "PurePath.__dict__.__contains__", ["__rtruediv__"], true]
    - [pp_has_bytes,    "PurePath.__dict__.__contains__", ["__bytes__"],    true]
    - [pp_has_fspath,   "PurePath.__dict__.__contains__", ["__fspath__"],   true]
    - [pp_has_reduce,   "PurePath.__dict__.__contains__", ["__reduce__"],   true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra102.Path.new_in_dict:
  description: "pathlib.Path.__dict__.__contains__('__new__') == True (Path overrides __new__ to dispatch to the correct platform-specific subclass, e.g. PosixPath or WindowsPath)"
  category: dict_membership
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["__new__"]
  expected: true

invariant pathlib_extra102.Path.eq_not_in_dict:
  description: "pathlib.Path.__dict__.__contains__('__eq__') == False (__eq__ is defined in PurePath, not overridden in Path; Path inherits comparison semantics from PurePath)"
  category: dict_membership
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["__eq__"]
  expected: false

invariant pathlib_extra102.PurePath.eq_in_dict:
  description: "pathlib.PurePath.__dict__.__contains__('__eq__') == True (PurePath defines __eq__ to compare paths by their string representation)"
  category: dict_membership
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["__eq__"]
  expected: true

invariant pathlib_extra102.PurePath.truediv_in_dict:
  description: "pathlib.PurePath.__dict__.__contains__('__truediv__') == True (PurePath defines the / operator for path joining)"
  category: dict_membership
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["__truediv__"]
  expected: true

invariant pathlib_extra102.Path.str_not_in_dict:
  description: "pathlib.Path.__dict__.__contains__('__str__') == False (__str__ is defined in PurePath, not Path; Path inherits string conversion from PurePath)"
  category: dict_membership
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["__str__"]
  expected: false

