spec: io_extra227
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: io class __name__ lengths and __contains__/__startswith__ predicates for BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper, IOBase, RawIOBase, BufferedIOBase, TextIOBase."
    - "io.BytesIO.__name__ == 'BytesIO'; len == 7; verified with Python 3.14.3."
    - "io.StringIO.__name__ == 'StringIO'; len == 8; verified with Python 3.14.3."
    - "io.FileIO.__name__ == 'FileIO'; len == 6; verified with Python 3.14.3."
    - "io.BufferedReader.__name__ == 'BufferedReader'; len == 14; verified with Python 3.14.3."
    - "io.BufferedWriter.__name__ == 'BufferedWriter'; len == 14; verified with Python 3.14.3."
    - "io.BufferedRandom.__name__ == 'BufferedRandom'; len == 14; verified with Python 3.14.3."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper'; len == 13; verified with Python 3.14.3."
    - "io.IOBase.__name__ == 'IOBase'; len == 6; verified with Python 3.14.3."
    - "io.RawIOBase.__name__ == 'RawIOBase'; len == 9; verified with Python 3.14.3."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase'; len == 14; verified with Python 3.14.3."
    - "io.TextIOBase.__name__ == 'TextIOBase'; len == 10; verified with Python 3.14.3."
    - "io.BytesIO.__name__.__contains__('IO') == True; verified with Python 3.14.3."
    - "io.StringIO.__name__.__contains__('IO') == True; verified with Python 3.14.3."
    - "io.BufferedReader.__name__.__startswith__('Buffered') == True; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __name__ lengths
# All io public classes; lengths verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table io_extra227.class_name_lengths:
  description: "io class __name__ lengths for all public io classes; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: ioclsnamelen227

  columns: [id, function, args, expected]
  rows:
    - [bytesio_len,       BytesIO.__name__.__len__,       [], 7]
    - [stringio_len,      StringIO.__name__.__len__,      [], 8]
    - [fileio_len,        FileIO.__name__.__len__,        [], 6]
    - [bufread_len,       BufferedReader.__name__.__len__, [], 14]
    - [bufwrite_len,      BufferedWriter.__name__.__len__, [], 14]
    - [bufrandom_len,     BufferedRandom.__name__.__len__, [], 14]
    - [textiowrap_len,    TextIOWrapper.__name__.__len__, [], 13]
    - [iobase_len,        IOBase.__name__.__len__,        [], 6]
    - [rawiobase_len,     RawIOBase.__name__.__len__,     [], 9]
    - [bufiobase_len,     BufferedIOBase.__name__.__len__, [], 14]
    - [textiobase_len,    TextIOBase.__name__.__len__,    [], 10]

# ---------------------------------------------------------------------------
# io class __name__ contains/startswith predicates
# ---------------------------------------------------------------------------

invariant io_extra227.BytesIO.name.contains_IO:
  description: "io.BytesIO.__name__.__contains__('IO') == True — 'BytesIO' contains the substring 'IO'; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BytesIO.__name__.__contains__
  args: ["IO"]
  expected: true

invariant io_extra227.StringIO.name.contains_IO:
  description: "io.StringIO.__name__.__contains__('IO') == True — 'StringIO' contains the substring 'IO'; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: StringIO.__name__.__contains__
  args: ["IO"]
  expected: true

invariant io_extra227.BufferedReader.name.startswith_Buffered:
  description: "io.BufferedReader.__name__.__startswith__('Buffered') == True — 'BufferedReader' starts with 'Buffered'; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BufferedReader.__name__.__startswith__
  args: ["Buffered"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants for key class name lengths
# ---------------------------------------------------------------------------

invariant io_extra227.BytesIO.name.len:
  description: "io.BytesIO.__name__.__len__() == 7 — 'BytesIO' has 7 characters; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BytesIO.__name__.__len__
  args: []
  expected: 7

invariant io_extra227.StringIO.name.len:
  description: "io.StringIO.__name__.__len__() == 8 — 'StringIO' has 8 characters; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: StringIO.__name__.__len__
  args: []
  expected: 8

invariant io_extra227.BufferedReader.name.len:
  description: "io.BufferedReader.__name__.__len__() == 14 — 'BufferedReader' has 14 characters; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BufferedReader.__name__.__len__
  args: []
  expected: 14

invariant io_extra227.TextIOWrapper.name.len:
  description: "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__name__.__len__
  args: []
  expected: 13

invariant io_extra227.BufferedIOBase.name.len:
  description: "io.BufferedIOBase.__name__.__len__() == 14 — 'BufferedIOBase' has 14 characters; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BufferedIOBase.__name__.__len__
  args: []
  expected: 14
