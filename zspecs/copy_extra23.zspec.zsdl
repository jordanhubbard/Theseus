spec: copy_extra23
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/copy.py"
    - "copy_extra22.zspec.zsdl — covers copy.__all__.__len__()==4; Error.__mro__.__len__()==4; Error.__bases__[0].__name__.__len__()==9; __spec__.__class__.__name__.__len__()==10; __loader__.__class__.__name__.__len__()==16; __all__ name lengths table; Error_mro_name_lengths table."
    - "copy_extra21.zspec.zsdl — covers __name__.__len__() and __qualname__.__len__() tables for all 4 exports; replace/__name__/__module__.__len__(); Error/__name__/__qualname__.__len__()."
    - "copy_extra20.zspec.zsdl — covers __qualname__.__eq__ table for all 4 exports; copy/deepcopy/Error __module__.__len__(); copy/deepcopy __name__.__len__(); Error.__bases__[0].__name__; Error.__init__.__name__."
    - "copy_extra19.zspec.zsdl — covers __name__.__eq__ table for all 4 exports; __all__.__class__.__name__, __all__.__len__(), __all__[0].__class__.__name__; replace/__qualname__/__module__."
  notes:
    - "This spec extends copy_extra22; it does NOT duplicate invariants present in prior specs."
    - "Prior specs covered: all __name__/__qualname__/__module__ equality and length checks for copy/deepcopy/Error/replace; __all__ type/length/element type; Error MRO depth and base class name length; module spec/loader class name lengths; Error_mro name lengths."
    - "This spec covers: copy.copy.__class__.__name__ == 'function', len == 8 (NOVEL — no prior spec checks __class__.__name__ for copy.copy); copy.deepcopy.__class__.__name__ == 'function', len == 8 (NOVEL); copy.Error.__dict__.__class__.__name__.__len__() == 12 (NOVEL — 'mappingproxy'); copy._deepcopy_dispatch.__class__.__name__.__len__() == 4 (NOVEL — 'dict'); copy.Error.__init__.__qualname__.__len__() == 22 (NOVEL — 'BaseException.__init__' has 22 chars; Error uses inherited __init__); copy.__all__.__contains__ membership table (NOVEL — no prior spec uses __contains__ on copy.__all__); copy.__doc__.__class__.__name__.__len__() == 3 (NOVEL — module docstring is a str, len('str')==3)."
    - "copy.copy.__class__.__name__ == 'function'; len('function') == 8. Pure-Python function object type. No prior copy spec checks __class__.__name__ for copy.copy. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "copy.deepcopy.__class__.__name__ == 'function'; len('function') == 8. Same as copy.copy. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "copy.Error.__dict__.__class__.__name__ == 'mappingproxy'; len == 12. Class __dict__ is always a mappingproxy in CPython. No prior copy spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "copy._deepcopy_dispatch.__class__.__name__ == 'dict'; len('dict') == 4. _deepcopy_dispatch is a module-level dict (dispatch table). Note: task description named this '_copy_dispatch' but the actual attribute is '_deepcopy_dispatch'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "copy.Error.__init__.__qualname__ == 'BaseException.__init__'; len == 22. copy.Error does not define its own __init__, so the inherited __init__ from BaseException is used. The qualname reflects BaseException as the defining class. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "copy.__all__.__contains__('Error') == True; similar for 'copy', 'deepcopy', 'replace'. No prior copy spec uses __contains__ on __all__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "copy.__doc__.__class__.__name__ == 'str'; len('str') == 3. Module docstring is a str. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy.copy and copy.deepcopy __class__.__name__.__len__()
#
# No prior copy spec checks __class__.__name__ for copy.copy or copy.deepcopy.
# Both are pure-Python functions; __class__.__name__ == 'function' (len 8).
# ---------------------------------------------------------------------------

invariant copy_extra23.copy.class_name_len:
  description: "copy.copy.__class__.__name__.__len__() == 8 — len('function') == 8"
  category: function_type
  kind: python_call_eq
  function: copy.__class__.__name__.__len__
  args: []
  expected: 8

invariant copy_extra23.deepcopy.class_name_len:
  description: "copy.deepcopy.__class__.__name__.__len__() == 8 — len('function') == 8"
  category: function_type
  kind: python_call_eq
  function: deepcopy.__class__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# copy.Error.__dict__.__class__.__name__.__len__()
#
# Class __dict__ objects in CPython are mappingproxy instances.
# len('mappingproxy') == 12. No prior copy spec checks this for copy.Error.
# ---------------------------------------------------------------------------

invariant copy_extra23.Error.dict_class_name_len:
  description: "copy.Error.__dict__.__class__.__name__.__len__() == 12 — len('mappingproxy') == 12"
  category: class_identity
  kind: python_call_eq
  function: Error.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# copy._deepcopy_dispatch.__class__.__name__.__len__()
#
# copy._deepcopy_dispatch is a module-level dispatch dict. Its __class__.__name__
# is 'dict'; len('dict') == 4. No prior copy spec checks this private attribute.
# Note: the attribute is _deepcopy_dispatch (not _copy_dispatch).
# ---------------------------------------------------------------------------

invariant copy_extra23.deepcopy_dispatch.class_name_len:
  description: "copy._deepcopy_dispatch.__class__.__name__.__len__() == 4 — len('dict') == 4, dispatch table type"
  category: module_internals
  kind: python_call_eq
  function: _deepcopy_dispatch.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.Error.__init__.__qualname__.__len__()
#
# copy.Error does not define its own __init__; the inherited __init__ comes from
# BaseException. Therefore copy.Error.__init__.__qualname__ ==
# 'BaseException.__init__' (22 characters). No prior copy spec checks any
# __qualname__ attribute of copy.Error.__init__. Extra20 checks __init__.__name__
# == '__init__' but not __qualname__.__len__(). Novel.
# ---------------------------------------------------------------------------

invariant copy_extra23.Error.init_qualname_len:
  description: "copy.Error.__init__.__qualname__.__len__() == 22 — 'BaseException.__init__' has 22 characters (inherited __init__)"
  category: class_identity
  kind: python_call_eq
  function: Error.__init__.__qualname__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# copy.__doc__.__class__.__name__.__len__()
#
# The copy module has a docstring. copy.__doc__.__class__.__name__ == 'str';
# len('str') == 3. No prior copy spec checks the type of the module docstring.
# ---------------------------------------------------------------------------

invariant copy_extra23.doc.class_name_len:
  description: "copy.__doc__.__class__.__name__.__len__() == 3 — module docstring is a str; len('str') == 3"
  category: module_identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Table: copy.__all__ membership via __contains__
#
# No prior copy spec uses __contains__ on copy.__all__. All four exported names
# (Error, copy, deepcopy, replace) are present. This table anchors membership
# checks in the extra23 namespace with novel id_prefix cpal23.
# ---------------------------------------------------------------------------

table copy_extra23.all_membership:
  description: "copy.__all__.__contains__ checks — Error, copy, deepcopy, replace are all present"
  kind: python_call_eq
  category: module_identity
  id_prefix: cpal23

  columns: [id, function, args, expected]
  rows:
    - [contains_Error,    __all__.__contains__, ["Error"],    true]
    - [contains_copy,     __all__.__contains__, ["copy"],     true]
    - [contains_deepcopy, __all__.__contains__, ["deepcopy"], true]
    - [contains_replace,  __all__.__contains__, ["replace"],  true]

# ---------------------------------------------------------------------------
# Table: copy.copy and copy.deepcopy __class__.__name__ identity and length
#
# Groups __class__.__name__.__eq__ and __class__.__name__.__len__ for both
# copy and deepcopy functions. Both are pure-Python functions. All novel.
# ---------------------------------------------------------------------------

table copy_extra23.function_class_names:
  description: "copy.copy and copy.deepcopy __class__.__name__ — both are 'function' (len 8)"
  kind: python_call_eq
  category: function_type
  id_prefix: cpcn23

  columns: [id, function, args, expected]
  rows:
    - [copy_class_name_len,     copy.__class__.__name__.__len__,     [], 8]
    - [deepcopy_class_name_len, deepcopy.__class__.__name__.__len__, [], 8]
    - [Error_dict_len,          Error.__dict__.__class__.__name__.__len__, [], 12]
    - [dispatch_class_len,      _deepcopy_dispatch.__class__.__name__.__len__, [], 4]
