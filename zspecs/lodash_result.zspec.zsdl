spec: lodash_result
version: ">=4.0.0"
backend: node(lodash.result)

docs: https://lodash.com/docs/#result

provenance:
  derived_from:
    - "lodash.result README — https://www.npmjs.com/package/lodash.result"
    - "Test vectors verified with lodash.result@4.5.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.result exports the _.result function directly as module.exports."
    - "result(object, path, defaultValue) gets the value at path."
    - "For plain values behaves identically to _.get."
    - "Returns defaultValue if path resolves to undefined."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns value at path or defaultValue."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_result.result:
  kind: node_module_call_eq
  function: ~
  category: result
  id_prefix: lres

  columns: [id, args, expected]
  rows:
    - [top_level,  [{"a": 1, "b": 2}, "a"],        1]
    - [nested,     [{"a": {"b": 42}}, "a.b"],       42]
    - [default,    [{"a": 1}, "b", 99],             99]
    - [not_found,  [{"a": 1}, "c", "fallback"],     "fallback"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:40:05Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
