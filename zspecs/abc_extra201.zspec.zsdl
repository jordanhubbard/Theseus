    - ["instancecheck_is_function",       "abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__",              ["function"],          true, "abc.ABCMeta.__instancecheck__.__class__.__name__ == 'function' — __instancecheck__ is a Python function; verified Python 3.14.3"]
    - ["instancecheck_name_len_17",       "abc.ABCMeta.__instancecheck__.__name__.__len__",                       [],                    17,   "abc.ABCMeta.__instancecheck__.__name__.__len__() == 17 ('__instancecheck__'=17); verified Python 3.14.3"]
    - ["instancecheck_name_eq",           "abc.ABCMeta.__instancecheck__.__name__.__eq__",                        ["__instancecheck__"], true, "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__'; verified Python 3.14.3"]

