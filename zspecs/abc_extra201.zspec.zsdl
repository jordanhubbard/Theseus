    - ["abcmeta_is_type",             "abc.ABCMeta.__class__.__name__.__eq__",                       ["type"],     true, "abc.ABCMeta.__class__.__name__ == 'type' — ABCMeta is a metaclass (type of type); verified Python 3.14.3"]
    - ["abcmeta_name_len_7",          "abc.ABCMeta.__name__.__len__",                                [],           7,    "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta': A-B-C-M-e-t-a); verified Python 3.14.3"]
    - ["abc_class_is_abcmeta",        "abc.ABC.__class__.__name__.__eq__",                           ["ABCMeta"],  true, "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC is an instance of ABCMeta (a class with ABCMeta metaclass); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra201
# ---------------------------------------------------------------------------

invariant abc_extra201.abstractmethod_defaults_nonetype:
  description: "abc.abstractmethod.__defaults__.__class__.__name__.__eq__('NoneType') == True — abstractmethod has no default parameter values; abstractmethod(funcobj) takes exactly one required argument; Python sets __defaults__ to None (not ()) when there are no positional defaults; abstractmethod.__class__.__name__=='function' (len=8); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abstractmethod_defaults
  kind: python_call_eq
  function: abc.abstractmethod.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant abc_extra201.abstractmethod_is_function:
  description: "abc.abstractmethod.__class__.__name__.__eq__('function') == True — abstractmethod is a Python-level decorator function; abstractmethod.__class__.__name__=='function' (len=8: f-u-n-c-t-i-o-n); abstractmethod.__name__=='abstractmethod' (len=14); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abstractmethod_defaults
  kind: python_call_eq
  function: abc.abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra201.abstractmethod_name_len_14:
  description: "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters: a(1)b(2)s(3)t(4)r(5)a(6)c(7)t(8)m(9)e(10)t(11)h(12)o(13)d(14); abstractmethod.__name__.__len__(14) > ABCMeta.__name__.__len__(7) by 7; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abstractmethod_defaults
  kind: python_call_eq
  function: abc.abstractmethod.__name__.__len__
  args: []
  expected: 14

invariant abc_extra201.instancecheck_defaults_nonetype:
  description: "abc.ABCMeta.__instancecheck__.__defaults__.__class__.__name__.__eq__('NoneType') == True — __instancecheck__(self, instance) has no defaults; both parameters are required; ABCMeta.__instancecheck__ is called when using isinstance(obj, cls) where cls has ABCMeta as metaclass; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: instancecheck_defaults
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant abc_extra201.register_defaults_nonetype:
  description: "abc.ABCMeta.register.__defaults__.__class__.__name__.__eq__('NoneType') == True — register(cls, subclass) has no default values; both cls (self/the ABC class) and subclass (the class to register) are required; register.__defaults__ is None (NoneType); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: register_defaults
  kind: python_call_eq
  function: abc.ABCMeta.register.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant abc_extra201.abcmeta_is_type:
  description: "abc.ABCMeta.__class__.__name__.__eq__('type') == True — ABCMeta is a metaclass; its own type is 'type' (the default metaclass in Python); ABCMeta.__class__.__name__=='type' (len=4: t-y-p-e); ABCMeta is used as the metaclass for ABC and any class that inherits abstract methods; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: register_defaults
  kind: python_call_eq
  function: abc.ABCMeta.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra201.abcmeta_name_len_7:
  description: "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters: A(1)B(2)C(3)M(4)e(5)t(6)a(7); ABCMeta.__name__.__len__(7) < abstractmethod.__name__.__len__(14) by 7; ABCMeta.__name__.__len__(7) == register.__name__.__len__(8) - 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: register_defaults
  kind: python_call_eq
  function: abc.ABCMeta.__name__.__len__
  args: []
  expected: 7

invariant abc_extra201.abc_class_is_abcmeta:
  description: "abc.ABC.__class__.__name__.__eq__('ABCMeta') == True — abc.ABC is a class whose metaclass is ABCMeta; ABC.__class__.__name__=='ABCMeta' (len=7); ABC itself is not an instance of 'type' but of 'ABCMeta' because ABCMeta is its metaclass; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: register_defaults
  kind: python_call_eq
  function: abc.ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

