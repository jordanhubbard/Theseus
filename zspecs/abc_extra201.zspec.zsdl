spec: abc_extra201
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.abstractmethod.__defaults__ is None — abstractmethod is a decorator function that takes a single required argument (funcobj); it has no default parameter values."
    - "abc.ABCMeta.__instancecheck__.__defaults__ is None — __instancecheck__(self, instance) has no default values; both self and instance are required."
    - "abc.ABCMeta.register.__defaults__ is None — register(cls, subclass) has no default values; both cls (self) and subclass are required."
    - "All three functions have __defaults__.__class__.__name__ == 'NoneType' — Python sets __defaults__ to None (not ()) when a function has no positional defaults."
    - "abc.abstractmethod.__class__.__name__ == 'function' — abstractmethod is a Python-level function used as a decorator."
    - "abc.ABCMeta.__class__.__name__ == 'type' — ABCMeta is a metaclass (a class whose instances are classes)."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC is an instance of ABCMeta (a class created with ABCMeta as its metaclass)."
    - "abc.ABCMeta.register.__name__ == 'register' (len=8); abc.abstractmethod.__name__ == 'abstractmethod' (len=14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.abstractmethod __defaults__ and type identity
#
# abc.abstractmethod.__defaults__ is None -> __class__.__name__ == 'NoneType'
# abc.abstractmethod.__class__.__name__ == 'function'
# abc.abstractmethod.__name__ == 'abstractmethod' (len=14)
# ---------------------------------------------------------------------------

table abc_extra201.abstractmethod_defaults_identity:
  description: "abc.abstractmethod __defaults__ and identity checks in abcdefaults201 namespace — abstractmethod.__defaults__ is None (NoneType) because abstractmethod(funcobj) takes exactly one required argument with no defaults; abstractmethod.__class__.__name__=='function' (abstractmethod is a Python decorator function); abstractmethod.__name__=='abstractmethod' (len=14: 'abstract'=8+'method'=6=14); verified with Python 3.14.3"
  kind: python_call_eq
  category: abstractmethod_defaults
  id_prefix: abcdefaults201

  columns: [id, function, args, expected, description]
  rows:
    - ["abstractmethod_defaults_nonetype",  "abc.abstractmethod.__defaults__.__class__.__name__.__eq__", ["NoneType"],       true, "abc.abstractmethod.__defaults__.__class__.__name__ == 'NoneType' — abstractmethod has no defaults; verified Python 3.14.3"]
    - ["abstractmethod_is_function",        "abc.abstractmethod.__class__.__name__.__eq__",              ["function"],       true, "abc.abstractmethod.__class__.__name__ == 'function' — abstractmethod is a Python function; verified Python 3.14.3"]
    - ["abstractmethod_name_len_14",        "abc.abstractmethod.__name__.__len__",                       [],                 14,   "abc.abstractmethod.__name__.__len__() == 14 ('abstractmethod': a-b-s-t-r-a-c-t-m-e-t-h-o-d); verified Python 3.14.3"]
    - ["abstractmethod_name_eq",            "abc.abstractmethod.__name__.__eq__",                        ["abstractmethod"], true, "abc.abstractmethod.__name__ == 'abstractmethod'; verified Python 3.14.3"]

