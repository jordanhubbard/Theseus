invariant io_extra217.dbs_eq_131072:
  description: "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — DEFAULT_BUFFER_SIZE equals 131072 (128 KiB); confirmed Python 3.14.3 macOS"
  category: constant_metadata
