spec: io_extra217
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper, BufferedRandom, UnsupportedOperation class metadata"
    - "io_extra216.zspec.zsdl — covers io.StringIO and io.FileIO __dict__ membership (read/write/getvalue/seek/tell)"
  notes:
    - "io.BufferedWriter.__dict__ contains concrete method implementations: write, flush, seek, tell, detach."
    - "io.BufferedRandom.__dict__ contains concrete method implementations: seek, read, write, flush, read1, tell."
    - "BufferedWriter does NOT have read1 in __dict__; read1 is a BufferedReader method not applicable to write-only buffered streams."
    - "BufferedRandom has read1 in __dict__ because it supports both reading and writing."
    - "io.DEFAULT_BUFFER_SIZE is an int with value 131072 (128 KiB)."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'; confirmed Python 3.14.3 macOS."
    - "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True; confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.__dict__.__contains__('write') == True; confirmed Python 3.14.3 macOS."
    - "io.BufferedRandom.__dict__.__contains__('read1') == True; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.BufferedWriter.__dict__ membership — core write/flush/seek/tell methods
# BufferedWriter is a concrete buffered write-only stream; these methods live in __dict__
# ---------------------------------------------------------------------------

table io_extra217.bufferedwriter_dict_core_methods:
  description: "io.BufferedWriter.__dict__ contains concrete core write/flush/seek/tell method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iobuffered217

  columns: [id, function, args, expected, description]
  rows:
    - [buffwriter_has_write,  "io.BufferedWriter.__dict__.__contains__",  ["write"],  true,  "io.BufferedWriter.__dict__.__contains__('write') == True; write is a concrete method on BufferedWriter; confirmed Python 3.14.3 macOS"]
    - [buffwriter_has_flush,  "io.BufferedWriter.__dict__.__contains__",  ["flush"],  true,  "io.BufferedWriter.__dict__.__contains__('flush') == True; flush is a concrete method on BufferedWriter; confirmed Python 3.14.3 macOS"]
    - [buffwriter_has_seek,   "io.BufferedWriter.__dict__.__contains__",  ["seek"],   true,  "io.BufferedWriter.__dict__.__contains__('seek') == True; seek is a concrete method on BufferedWriter; confirmed Python 3.14.3 macOS"]
    - [buffwriter_has_tell,   "io.BufferedWriter.__dict__.__contains__",  ["tell"],   true,  "io.BufferedWriter.__dict__.__contains__('tell') == True; tell is a concrete method on BufferedWriter; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.BufferedRandom.__dict__ membership — read/write/seek/read1 methods
# BufferedRandom supports both reading and writing; read1 is present unlike BufferedWriter
# ---------------------------------------------------------------------------

table io_extra217.bufferedrandom_dict_methods:
  description: "io.BufferedRandom.__dict__ contains concrete read/write/seek/read1 method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iobuffered217

  columns: [id, function, args, expected, description]
  rows:
    - [buffrandom_has_seek,   "io.BufferedRandom.__dict__.__contains__",  ["seek"],   true,  "io.BufferedRandom.__dict__.__contains__('seek') == True; seek is a concrete method on BufferedRandom; confirmed Python 3.14.3 macOS"]
    - [buffrandom_has_read,   "io.BufferedRandom.__dict__.__contains__",  ["read"],   true,  "io.BufferedRandom.__dict__.__contains__('read') == True; read is a concrete method on BufferedRandom; confirmed Python 3.14.3 macOS"]
    - [buffrandom_has_write,  "io.BufferedRandom.__dict__.__contains__",  ["write"],  true,  "io.BufferedRandom.__dict__.__contains__('write') == True; write is a concrete method on BufferedRandom; confirmed Python 3.14.3 macOS"]
    - [buffrandom_has_read1,  "io.BufferedRandom.__dict__.__contains__",  ["read1"],  true,  "io.BufferedRandom.__dict__.__contains__('read1') == True; read1 is a concrete method on BufferedRandom (absent from BufferedWriter); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.DEFAULT_BUFFER_SIZE class metadata and equality
# DEFAULT_BUFFER_SIZE is an int constant equal to 131072 (128 KiB)
# ---------------------------------------------------------------------------

table io_extra217.default_buffer_size_metadata:
  description: "io.DEFAULT_BUFFER_SIZE class metadata: it is an int equal to 131072"
  kind: python_call_eq
  category: constant_metadata
  id_prefix: iobuffered217

  columns: [id, function, args, expected, description]
  rows:
    - [dbs_class_name,    io.DEFAULT_BUFFER_SIZE.__class__.__name__,  [],       "int",  "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'; DEFAULT_BUFFER_SIZE is a plain Python int; confirmed Python 3.14.3 macOS"]
    - [dbs_eq_131072,     io.DEFAULT_BUFFER_SIZE.__eq__,              [131072], true,   "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True; DEFAULT_BUFFER_SIZE equals 131072 (128 KiB); confirmed Python 3.14.3 macOS"]
    - [dbs_eq_8192_false, io.DEFAULT_BUFFER_SIZE.__eq__,              [8192],   false,  "io.DEFAULT_BUFFER_SIZE.__eq__(8192) == False; DEFAULT_BUFFER_SIZE does not equal 8192; confirmed Python 3.14.3 macOS"]
    - [buffwriter_no_read1, "io.BufferedWriter.__dict__.__contains__", ["read1"], false, "io.BufferedWriter.__dict__.__contains__('read1') == False; read1 is absent from BufferedWriter (write-only stream); confirmed Python 3.14.3 macOS"]

