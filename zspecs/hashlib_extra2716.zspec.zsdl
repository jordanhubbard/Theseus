spec: hashlib_extra2716
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/hashlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 628 theme: __neg__, __pos__, and __abs__ dict-presence checks (unary minus, unary plus, absolute value)."
    - "hashlib.HASH (the internal _hashlib.HASH type) is a hash object; it does not implement unary arithmetic protocols."
    - "hashlib.blake2b is a hash constructor class; it similarly defines none of __neg__, __pos__, or __abs__."
    - "hashlib.blake2s is a hash constructor class; it similarly defines none of __neg__, __pos__, or __abs__."
    - "None of the hashlib public classes define __neg__, __pos__, or __abs__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — absent from all hashlib classes
# ---------------------------------------------------------------------------

table hashlib_extra2716.neg_protocol:
  description: "__neg__ is absent from all hashlib class __dict__s — none implement unary minus"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2716

  columns: [id, function, args, expected]
  rows:
    - ["hl2716001", "type(hashlib.new('sha256')).__dict__.__contains__", ["__neg__"], false]
    - ["hl2716002", "hashlib.blake2b.__dict__.__contains__",             ["__neg__"], false]
    - ["hl2716003", "hashlib.blake2s.__dict__.__contains__",             ["__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — absent from all hashlib classes
# ---------------------------------------------------------------------------

table hashlib_extra2716.pos_protocol:
  description: "__pos__ is absent from all hashlib class __dict__s — none implement unary plus"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2716

  columns: [id, function, args, expected]
  rows:
    - ["hl2716004", "type(hashlib.new('sha256')).__dict__.__contains__", ["__pos__"], false]
    - ["hl2716005", "hashlib.blake2b.__dict__.__contains__",             ["__pos__"], false]
    - ["hl2716006", "hashlib.blake2s.__dict__.__contains__",             ["__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — absent from all hashlib classes
# ---------------------------------------------------------------------------

table hashlib_extra2716.abs_protocol:
  description: "__abs__ is absent from all hashlib class __dict__s — none implement absolute value"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2716

  columns: [id, function, args, expected]
  rows:
    - ["hl2716007", "type(hashlib.new('sha256')).__dict__.__contains__", ["__abs__"], false]
    - ["hl2716008", "hashlib.blake2b.__dict__.__contains__",             ["__abs__"], false]
    - ["hl2716009", "hashlib.blake2s.__dict__.__contains__",             ["__abs__"], false]

# ---------------------------------------------------------------------------
# Combined view — blake2b and blake2s vs. all three protocols
# ---------------------------------------------------------------------------

table hashlib_extra2716.blake_unary_combined:
  description: "hashlib.blake2b and hashlib.blake2s define none of __neg__, __pos__, __abs__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2716

  columns: [id, function, args, expected]
  rows:
    - ["hl2716010", "hashlib.blake2b.__dict__.__contains__", ["__neg__"], false]
    - ["hl2716011", "hashlib.blake2b.__dict__.__contains__", ["__pos__"], false]
    - ["hl2716012", "hashlib.blake2b.__dict__.__contains__", ["__abs__"], false]
    - ["hl2716013", "hashlib.blake2s.__dict__.__contains__", ["__neg__"], false]
    - ["hl2716014", "hashlib.blake2s.__dict__.__contains__", ["__pos__"], false]
    - ["hl2716015", "hashlib.blake2s.__dict__.__contains__", ["__abs__"], false]
