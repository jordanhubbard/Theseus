spec: hashlib_extra103
version: ">=3.9"
backend: python_module(hashlib)
extends: hashlib_extra99

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers hashlib.md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' / __name__ equality for those six / blake2b/blake2s class identity and __module__/__qualname__ / new __class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / algorithms_available membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 263 theme: hashlib sha3_*/shake_* constructor __name__ equality and __name__.__len__() / blake2b/blake2s __name__ equality and __name__.__len__() / new.__name__ equality."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__name__ == 'openssl_sha3_224'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__name__ == 'openssl_sha3_384'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__name__ == 'openssl_shake_128'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__name__ == 'openssl_shake_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__ == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__.__len__() == 16 ('openssl_sha3_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__.__len__() == 16 ('openssl_sha3_512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__name__.__len__() == 16 ('openssl_sha3_224'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__name__.__len__() == 16 ('openssl_sha3_384'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__name__.__len__() == 17 ('openssl_shake_128'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__name__.__len__() == 17 ('openssl_shake_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__.__len__() == 7 ('blake2b'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__.__len__() == 7 ('blake2s'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__.__len__() == 10 ('__hash_new'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: sha3_* constructors all have __name__ length 16: 'openssl_sha3_' (13) + 3-digit suffix (3). sha3_224/sha3_256/sha3_384/sha3_512 are all 16 chars."
    - "Note: shake_* constructors have __name__ length 17: 'openssl_shake_' (14) + 3-digit suffix (3). shake_128/shake_256 are both 17 chars."
    - "Note: blake2b/blake2s __name__ is 'blake2b'/'blake2s' (7 chars), lacking the 'openssl_' prefix because they come from the _blake2 extension, not _hashlib."
    - "Note: new.__name__ is '__hash_new' (10 chars), the internal implementation name of the hashlib.new wrapper function."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256')
# hashlib.sha3_512.__name__.__eq__('openssl_sha3_512')
# hashlib.sha3_224.__name__.__eq__('openssl_sha3_224')
# hashlib.sha3_384.__name__.__eq__('openssl_sha3_384')
#
# Wave 263 theme: sha3_* constructor __name__ equality.
#
# The four SHA-3 constructors (sha3_224, sha3_256, sha3_384, sha3_512) all carry
# the 'openssl_' prefix in their __name__, identifying them as OpenSSL-backed
# builtins from _hashlib. Their __name__ equals their __qualname__ (top-level
# C builtins). hashlib_extra98 anchors __qualname__.__eq__ for sha3_*; hashlib_extra99
# anchors __name__.__eq__ for the sha2_* family (md5/sha1/sha224/sha256/sha384/sha512);
# no prior spec anchors __name__.__eq__ for the sha3_* group under hashlibname103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra103.sha3_constructor_names:
  description: "hashlib.sha3_256/__name__/__eq__('openssl_sha3_256')==True / sha3_512/__name__/__eq__('openssl_sha3_512')==True / sha3_224/__name__/__eq__('openssl_sha3_224')==True / sha3_384/__name__/__eq__('openssl_sha3_384')==True — all sha3_* constructors carry the 'openssl_' prefix in __name__; __name__ equals __qualname__ for top-level C builtins; extra98 anchors qualname equality; extra99 anchors sha2_* __name__; first hashlibname103 anchor for sha3_* __name__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibname103

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_name, sha3_256.__name__.__eq__, ["openssl_sha3_256"], true, "sha3_256 is OpenSSL-backed; __name__ is 'openssl_sha3_256'"]
    - [sha3_512_name, sha3_512.__name__.__eq__, ["openssl_sha3_512"], true, "sha3_512 is OpenSSL-backed; __name__ is 'openssl_sha3_512'"]
    - [sha3_224_name, sha3_224.__name__.__eq__, ["openssl_sha3_224"], true, "sha3_224 is OpenSSL-backed; __name__ is 'openssl_sha3_224'"]
    - [sha3_384_name, sha3_384.__name__.__eq__, ["openssl_sha3_384"], true, "sha3_384 is OpenSSL-backed; __name__ is 'openssl_sha3_384'"]

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__eq__('openssl_shake_128')
# hashlib.shake_256.__name__.__eq__('openssl_shake_256')
# hashlib.blake2b.__name__.__eq__('blake2b')
# hashlib.blake2s.__name__.__eq__('blake2s')
# hashlib.new.__name__.__eq__('__hash_new')
#
# Wave 263 theme: shake_*/blake2*/new __name__ equality.
#
# shake_128 and shake_256 carry the 'openssl_' prefix in their __name__,
# identifying them as OpenSSL-backed builtins. blake2b and blake2s lack the
# 'openssl_' prefix: they come from the _blake2 extension (not _hashlib) and
# their __name__ is the simple class name. new.__name__ is '__hash_new', the
# internal function name used in the Python wrapper. No prior spec anchors
# shake_* or blake2* __name__.__eq__, nor new.__name__.__eq__ under hashlibname103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra103.shake_blake2_new_names:
  description: "hashlib.shake_128/__name__/__eq__('openssl_shake_128')==True / shake_256/__name__/__eq__('openssl_shake_256')==True / blake2b/__name__/__eq__('blake2b')==True / blake2s/__name__/__eq__('blake2s')==True / new/__name__/__eq__('__hash_new')==True — shake_* carry 'openssl_' prefix; blake2* lack it (come from _blake2, not _hashlib); new.__name__ is the internal wrapper name '__hash_new'; no prior spec anchors these __name__ values; first hashlibname103 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibname103

  columns: [id, function, args, expected, description]
  rows:
    - [shake_128_name, shake_128.__name__.__eq__, ["openssl_shake_128"], true, "shake_128 is OpenSSL-backed; __name__ is 'openssl_shake_128'"]
    - [shake_256_name, shake_256.__name__.__eq__, ["openssl_shake_256"], true, "shake_256 is OpenSSL-backed; __name__ is 'openssl_shake_256'"]
    - [blake2b_name,   blake2b.__name__.__eq__,   ["blake2b"],           true, "blake2b from _blake2 (not _hashlib); __name__ is 'blake2b' with no 'openssl_' prefix"]
    - [blake2s_name,   blake2s.__name__.__eq__,   ["blake2s"],           true, "blake2s from _blake2 (not _hashlib); __name__ is 'blake2s' with no 'openssl_' prefix"]
    - [new_name,       new.__name__.__eq__,        ["__hash_new"],        true, "new.__name__ is '__hash_new', the internal name of the Python wrapper function"]

# ---------------------------------------------------------------------------
# hashlib sha3_* __name__.__len__() values
# sha3_256/sha3_512/sha3_224/sha3_384 all have __name__.__len__()==16
# shake_128/shake_256 have __name__.__len__()==17
# blake2b/blake2s have __name__.__len__()==7
# new has __name__.__len__()==10
#
# Wave 263 theme: algorithm constructor __name__ string lengths.
#
# The sha3_* constructors all have __name__ length 16: 'openssl_sha3_' (13 chars)
# + 3-digit variant suffix (3 chars) = 16. shake_* are 17: 'openssl_shake_' (14)
# + 3 chars. blake2b/blake2s are 7 (simple class names). new is 10 ('__hash_new').
# No prior hashlib spec anchors __name__.__len__() for these constructors under
# hashlibname103. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra103.constructor_name_lengths:
  description: "hashlib.sha3_256/__name__/__len__()==16 / sha3_512/__name__/__len__()==16 / sha3_224/__name__/__len__()==16 / sha3_384/__name__/__len__()==16 / shake_128/__name__/__len__()==17 / shake_256/__name__/__len__()==17 / blake2b/__name__/__len__()==7 / blake2s/__name__/__len__()==7 — sha3_* share length 16; shake_* share length 17; blake2* are 7; new is 10; no prior spec anchors these __name__.__len__() values; first hashlibname103 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibname103

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_nlen, sha3_256.__name__.__len__, [], 16, "'openssl_sha3_256' is 16 chars: 'openssl_sha3_' (13) + '256' (3)"]
    - [sha3_512_nlen, sha3_512.__name__.__len__, [], 16, "'openssl_sha3_512' is 16 chars: 'openssl_sha3_' (13) + '512' (3)"]
    - [sha3_224_nlen, sha3_224.__name__.__len__, [], 16, "'openssl_sha3_224' is 16 chars: 'openssl_sha3_' (13) + '224' (3)"]
    - [sha3_384_nlen, sha3_384.__name__.__len__, [], 16, "'openssl_sha3_384' is 16 chars: 'openssl_sha3_' (13) + '384' (3)"]
    - [shake_128_nlen, shake_128.__name__.__len__, [], 17, "'openssl_shake_128' is 17 chars: 'openssl_shake_' (14) + '128' (3)"]
    - [shake_256_nlen, shake_256.__name__.__len__, [], 17, "'openssl_shake_256' is 17 chars: 'openssl_shake_' (14) + '256' (3)"]
    - [blake2b_nlen,   blake2b.__name__.__len__,   [], 7,  "'blake2b' is 7 chars, simple class name from _blake2"]
    - [blake2s_nlen,   blake2s.__name__.__len__,   [], 7,  "'blake2s' is 7 chars, simple class name from _blake2"]
    - [new_nlen,       new.__name__.__len__,        [], 10, "'__hash_new' is 10 chars: '__' (2) + 'hash_new' (8)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') — standalone
#
# hashlib.sha3_256.__name__ is 'openssl_sha3_256'. The sha3_256 constructor is
# a C builtin (builtin_function_or_method) from the _hashlib extension, where
# SHA-3 algorithms are implemented via OpenSSL's EVP interface. The 'openssl_'
# prefix in __name__ identifies the implementation as OpenSSL-backed, as opposed
# to a pure-Python or fallback implementation. hashlib_extra98 anchors
# sha3_256.__qualname__.__eq__; no prior spec anchors sha3_256.__name__.__eq__
# as a standalone under hashlibname103. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra103.sha3_256_name_openssl:
  description: "hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') == True — sha3_256 is a C builtin from _hashlib implementing SHA-3/256 via OpenSSL's EVP interface; 'openssl_' prefix in __name__ identifies OpenSSL backing; extra98 anchors __qualname__.__eq__; first standalone for sha3_256.__name__.__eq__ under hashlibname103"
  category: type_identity
  kind: python_call_eq
  function: sha3_256.__name__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__eq__('openssl_shake_128') — standalone
#
# hashlib.shake_128.__name__ is 'openssl_shake_128'. shake_128 (SHAKE-128) is
# an XOF (Extendable Output Function) from the SHA-3 family, implemented via
# OpenSSL's EVP interface in _hashlib. Unlike fixed-length SHA-3 hashes, SHAKE
# functions produce variable-length digests (the user calls .digest(length)).
# The 'openssl_' prefix in __name__ confirms OpenSSL backing. hashlib_extra98
# anchors shake_128.__qualname__; no prior spec anchors shake_128.__name__.__eq__
# as a standalone under hashlibname103. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra103.shake_128_name_openssl:
  description: "hashlib.shake_128.__name__.__eq__('openssl_shake_128') == True — shake_128 is a C builtin from _hashlib implementing SHAKE-128 (XOF) via OpenSSL EVP; 'openssl_' prefix confirms OpenSSL backing; SHAKE functions differ from fixed-output SHA-3 by accepting a length argument in .digest(); extra98 anchors __qualname__; first standalone for shake_128.__name__.__eq__ under hashlibname103"
  category: type_identity
  kind: python_call_eq
  function: shake_128.__name__.__eq__
  args: ["openssl_shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b') — standalone
#
# hashlib.blake2b.__name__ is 'blake2b'. Unlike the OpenSSL-backed constructors
# (md5, sha256, sha3_256, etc.), blake2b lacks the 'openssl_' prefix because it
# comes from the _blake2 C extension (not _hashlib). blake2b is a class object
# (its __class__.__name__ is 'type'), and its __name__ is the simple class name.
# hashlib_extra99 anchors blake2b.__class__.__name__.__eq__('type') and
# blake2b.__module__.__eq__('_blake2'); no prior spec anchors blake2b.__name__.__eq__
# as a standalone under hashlibname103. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra103.blake2b_name_blake2b:
  description: "hashlib.blake2b.__name__.__eq__('blake2b') == True — blake2b comes from _blake2 (not _hashlib), so __name__ is 'blake2b' with no 'openssl_' prefix; blake2b is a class object (type metaclass), not a builtin_function_or_method; extra99 anchors __class__.__name__=='type' and __module__=='_blake2'; first standalone for blake2b.__name__.__eq__ under hashlibname103"
  category: type_identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new') — standalone
#
# hashlib.new.__name__ is '__hash_new'. hashlib.new is a pure-Python function
# (class 'function') defined in Lib/hashlib.py. Its internal implementation
# name in the bytecode is '__hash_new' (with double-underscore prefix), which
# differs from the public attribute name 'new'. This double-underscore prefix
# is a CPython convention indicating a private internal function. hashlib_extra99
# anchors new.__class__.__name__.__eq__('function'); no prior spec anchors
# new.__name__.__eq__('__hash_new') as a standalone under hashlibname103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra103.new_name_hash_new:
  description: "hashlib.new.__name__.__eq__('__hash_new') == True — new is a pure-Python wrapper function; its internal bytecode name is '__hash_new' (with double-underscore prefix indicating private internal function), different from the public attribute name 'new'; extra99 anchors new.__class__.__name__=='function'; first standalone for new.__name__.__eq__ under hashlibname103"
  category: type_identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__len__()==16 — standalone
#
# hashlib.sha3_256.__name__.__len__() is 16. sha3_256.__name__ is
# 'openssl_sha3_256': the 'openssl_sha3_' prefix (13 chars) plus '256' (3 chars)
# = 16. All four sha3_* constructors share this length of 16 because their
# suffixes (224, 256, 384, 512) are each exactly 3 digits. This is consistent
# across the sha3_* family: the varying digest size suffix is always 3 chars.
# No prior hashlib spec anchors sha3_256.__name__.__len__() as a standalone under
# hashlibname103. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra103.sha3_256_name_len_16:
  description: "hashlib.sha3_256.__name__.__len__() == 16 — sha3_256.__name__ is 'openssl_sha3_256': 'openssl_sha3_' (13 chars) + '256' (3 chars) = 16; all four sha3_* constructors share this length; suffix is always 3 digits (224/256/384/512); no prior spec anchors sha3_256.__name__.__len__() as a standalone; first standalone under hashlibname103"
  category: type_identity
  kind: python_call_eq
  function: sha3_256.__name__.__len__
  args: []
  expected: 16
