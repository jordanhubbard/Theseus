spec: io3031
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (io3031): __missing__, __init_subclass__, __class_getitem__ dict-presence for io types."
    - "None of the io stream classes define __missing__ in their own __dict__; __missing__ is a dict-protocol hook, not an io concern."
    - "None of the io stream classes define __init_subclass__ in their own __dict__; subclass init is handled by the object hierarchy, not overridden per-class."
    - "None of the io stream classes define __class_getitem__ in their own __dict__; io types are not generic aliases."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __missing__ dict-presence — operator.contains(Cls.__dict__, '__missing__')
#
# io types are I/O stream classes, not mappings; none define __missing__; all false.
# ---------------------------------------------------------------------------

table io3031.missing:
  description: "io types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io3031
  columns: [id, function, args, expected]
  rows:
    - ["io3031001", operator.contains, [io.IOBase.__dict__,         "__missing__"], false]
    - ["io3031002", operator.contains, [io.RawIOBase.__dict__,      "__missing__"], false]
    - ["io3031003", operator.contains, [io.BufferedIOBase.__dict__, "__missing__"], false]
    - ["io3031004", operator.contains, [io.BytesIO.__dict__,        "__missing__"], false]
    - ["io3031005", operator.contains, [io.StringIO.__dict__,       "__missing__"], false]
    - ["io3031006", operator.contains, [io.TextIOWrapper.__dict__,  "__missing__"], false]

