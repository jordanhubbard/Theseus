invariant inspect_extra1546.parameter_no_and:
  description: "inspect.Parameter.__dict__.__contains__('__and__') == False — Parameter defines no __and__; wave 550; new to extra1546"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__and__"]
  expected: false

