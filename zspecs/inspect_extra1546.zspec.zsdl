spec: inspect_extra1546
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 550 theme: bitwise operator dict-presence checks via __dict__.__contains__ for inspect classes."
    - "inspect.Parameter.__dict__.__contains__ returns False for all bitwise dunder methods. Parameter is a Python class; it models function parameters and has no bitwise semantics. Verified with Python 3.14."
    - "inspect.Signature.__dict__.__contains__ returns False for all bitwise dunder methods. Signature is a Python class representing a callable's parameter signature; it defines no bitwise operators. Verified with Python 3.14."
    - "inspect.BoundArguments.__dict__.__contains__ returns False for all bitwise dunder methods. BoundArguments is a Python class representing bound parameters; it defines no bitwise operators. Verified with Python 3.14."
    - "inspect.Parameter.kind is a property returning a _ParameterKind enum value; the property object itself has no bitwise operators in its __dict__."
    - "Bitwise dunders checked: __and__, __or__, __xor__, __invert__, __lshift__, __rshift__, __rand__, __ror__, __rxor__, __rlshift__, __rrshift__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — bitwise operator dict-presence checks
#
# Wave 550 theme: Parameter is a pure Python class defined in Lib/inspect.py.
# It represents a parameter in a function signature. Its own __dict__ does
# not contain any bitwise dunder methods; Parameter objects are descriptors,
# not numeric or bitwise types.
# ---------------------------------------------------------------------------

table inspect_extra1546.parameter_bitwise_dict_contains:
  description: "inspect.Parameter.__dict__.__contains__ returns False for all bitwise dunder methods; wave 550; new to extra1546"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1546pa

  columns: [id, function, args, expected, description]
  rows:
    - ["in1546pa001",
       "Parameter.__dict__.__contains__",
       ["__and__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__and__') == False — Parameter is a Python class; its __dict__ does not define __and__; wave 550; new to extra1546"]
    - ["in1546pa002",
       "Parameter.__dict__.__contains__",
       ["__or__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__or__') == False — Parameter does not define __or__ in its own class __dict__; wave 550; new to extra1546"]
    - ["in1546pa003",
       "Parameter.__dict__.__contains__",
       ["__xor__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__xor__') == False — Parameter does not define __xor__ in its own class __dict__; wave 550; new to extra1546"]
    - ["in1546pa004",
       "Parameter.__dict__.__contains__",
       ["__invert__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__invert__') == False — Parameter does not define __invert__ in its own class __dict__; wave 550; new to extra1546"]
    - ["in1546pa005",
       "Parameter.__dict__.__contains__",
       ["__lshift__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__lshift__') == False — Parameter does not define __lshift__ in its own class __dict__; wave 550; new to extra1546"]
    - ["in1546pa006",
       "Parameter.__dict__.__contains__",
       ["__rshift__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__rshift__') == False — Parameter does not define __rshift__ in its own class __dict__; wave 550; new to extra1546"]
    - ["in1546pa007",
       "Parameter.__dict__.__contains__",
       ["__rand__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__rand__') == False — Parameter does not define __rand__ in its own class __dict__; wave 550; new to extra1546"]
    - ["in1546pa008",
       "Parameter.__dict__.__contains__",
       ["__ror__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__ror__') == False — Parameter does not define __ror__ in its own class __dict__; wave 550; new to extra1546"]
    - ["in1546pa009",
       "Parameter.__dict__.__contains__",
       ["__rxor__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__rxor__') == False — Parameter does not define __rxor__ in its own class __dict__; wave 550; new to extra1546"]
    - ["in1546pa010",
       "Parameter.__dict__.__contains__",
       ["__rlshift__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__rlshift__') == False — Parameter does not define __rlshift__ in its own class __dict__; wave 550; new to extra1546"]
    - ["in1546pa011",
       "Parameter.__dict__.__contains__",
       ["__rrshift__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__rrshift__') == False — Parameter does not define __rrshift__ in its own class __dict__; wave 550; new to extra1546"]

