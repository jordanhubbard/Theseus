error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_is_empty.isEmpty:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: jisempty

  columns: [id, args, expected]
  rows:
    - [empty_arr,      [[]],          true]
    - [empty_obj,      [{}],          true]
    - [nonempty_arr,   [[1, 2]],      false]
    - [nonempty_obj,   [{"a": 1}],   false]

