spec: asyncio_extra268
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "asyncio.Queue methods put, get, put_nowait, get_nowait, empty, full, qsize are plain functions; __class__.__name__ == 'function'."
    - "All Queue method __qualname__ values carry the 'Queue.' prefix (e.g. 'Queue.put')."
    - "asyncio.Queue.__module__ == 'asyncio.queues' (defined in queues submodule)."
    - "asyncio.LifoQueue and asyncio.PriorityQueue both inherit directly from asyncio.Queue."
    - "asyncio.Queue.maxsize is a property; its fget.__name__ == 'maxsize' and fget.__qualname__ == 'Queue.maxsize'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue method __name__ — table
#
# Seven methods of asyncio.Queue: put, get, put_nowait, get_nowait, empty,
# full, qsize. All are plain Python functions defined on the Queue class.
# ---------------------------------------------------------------------------

table asyncio_extra268.queue_method_names:
  description: "asyncio.Queue methods report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: mname

  columns: [id, function, args, expected, description]
  rows:
    - [put,         Queue.put.__name__.__eq__,         ["put"],         true, "Queue.put.__name__ == 'put'"]
    - [get,         Queue.get.__name__.__eq__,         ["get"],         true, "Queue.get.__name__ == 'get'"]
    - [put_nowait,  Queue.put_nowait.__name__.__eq__,  ["put_nowait"],  true, "Queue.put_nowait.__name__ == 'put_nowait'"]
    - [get_nowait,  Queue.get_nowait.__name__.__eq__,  ["get_nowait"],  true, "Queue.get_nowait.__name__ == 'get_nowait'"]
    - [empty,       Queue.empty.__name__.__eq__,       ["empty"],       true, "Queue.empty.__name__ == 'empty'"]
    - [full,        Queue.full.__name__.__eq__,        ["full"],        true, "Queue.full.__name__ == 'full'"]
    - [qsize,       Queue.qsize.__name__.__eq__,       ["qsize"],       true, "Queue.qsize.__name__ == 'qsize'"]

# ---------------------------------------------------------------------------
# Queue method __qualname__ — table
#
# All seven Queue methods carry the 'Queue.' prefix in their __qualname__.
# ---------------------------------------------------------------------------

table asyncio_extra268.queue_method_qualnames:
  description: "asyncio.Queue methods report 'Queue.'-prefixed __qualname__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: mqualname

  columns: [id, function, args, expected, description]
  rows:
    - [put,         Queue.put.__qualname__.__eq__,         ["Queue.put"],         true, "Queue.put.__qualname__ == 'Queue.put'"]
    - [get,         Queue.get.__qualname__.__eq__,         ["Queue.get"],         true, "Queue.get.__qualname__ == 'Queue.get'"]
    - [put_nowait,  Queue.put_nowait.__qualname__.__eq__,  ["Queue.put_nowait"],  true, "Queue.put_nowait.__qualname__ == 'Queue.put_nowait'"]
    - [get_nowait,  Queue.get_nowait.__qualname__.__eq__,  ["Queue.get_nowait"],  true, "Queue.get_nowait.__qualname__ == 'Queue.get_nowait'"]
    - [empty,       Queue.empty.__qualname__.__eq__,       ["Queue.empty"],       true, "Queue.empty.__qualname__ == 'Queue.empty'"]
    - [full,        Queue.full.__qualname__.__eq__,        ["Queue.full"],        true, "Queue.full.__qualname__ == 'Queue.full'"]
    - [qsize,       Queue.qsize.__qualname__.__eq__,       ["Queue.qsize"],       true, "Queue.qsize.__qualname__ == 'Queue.qsize'"]

# ---------------------------------------------------------------------------
# Queue method __class__.__name__ — standalone invariants
#
# put and get are plain Python functions; __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

invariant asyncio_extra268.put.class_name:
  description: "asyncio.Queue.put.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: Queue.put.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra268.get.class_name:
  description: "asyncio.Queue.get.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: Queue.get.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Queue.maxsize property fget — standalone invariants
#
# asyncio.Queue.maxsize is a property. Its fget.__name__ == 'maxsize' and
# fget.__qualname__ == 'Queue.maxsize'.
# ---------------------------------------------------------------------------

invariant asyncio_extra268.maxsize_fget.name:
  description: "asyncio.Queue.maxsize.fget.__name__ == 'maxsize'"
  category: identity
  kind: python_call_eq
  function: Queue.maxsize.fget.__name__.__eq__
  args: ["maxsize"]
  expected: true

invariant asyncio_extra268.maxsize_fget.qualname:
  description: "asyncio.Queue.maxsize.fget.__qualname__ == 'Queue.maxsize'"
  category: identity
  kind: python_call_eq
  function: Queue.maxsize.fget.__qualname__.__eq__
  args: ["Queue.maxsize"]
  expected: true

# ---------------------------------------------------------------------------
# LifoQueue and PriorityQueue identity — standalone invariants
#
# Both subclasses inherit directly from asyncio.Queue.
# ---------------------------------------------------------------------------

invariant asyncio_extra268.LifoQueue.name:
  description: "asyncio.LifoQueue.__name__ == 'LifoQueue'"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__name__.__eq__
  args: ["LifoQueue"]
  expected: true

invariant asyncio_extra268.LifoQueue.module:
  description: "asyncio.LifoQueue.__module__ == 'asyncio.queues'"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra268.LifoQueue.base_name:
  description: "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue'"
  category: identity
  kind: python_call_eq
  function: "LifoQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant asyncio_extra268.PriorityQueue.name:
  description: "asyncio.PriorityQueue.__name__ == 'PriorityQueue'"
  category: identity
  kind: python_call_eq
  function: PriorityQueue.__name__.__eq__
  args: ["PriorityQueue"]
  expected: true

invariant asyncio_extra268.PriorityQueue.base_name:
  description: "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue'"
  category: identity
  kind: python_call_eq
  function: "PriorityQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true
