spec: importlib_extra14
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "importlib_extra5.zspec.zsdl — covers __qualname__ for util.find_spec/util.module_from_spec/util.spec_from_file_location."
    - "importlib_extra7.zspec.zsdl — covers util.LazyLoader __name__/__module__/__qualname__; util.decode_source __qualname__."
    - "importlib_extra8.zspec.zsdl — covers util.cache_from_source __module__/__name__; util.source_hash __qualname__; util.resolve_name __qualname__."
    - "importlib_extra13.zspec.zsdl — covers importlib.__class__.__qualname__=='module'; import_module/reload/invalidate_caches __qualname__ (standalone)."
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra13.zspec.zsdl."
    - "Focus: __qualname__ for importlib.util.cache_from_source and util.source_from_cache (not covered in any prior spec); util.__class__.__name__ and util.__class__.__qualname__ for the util submodule object."
    - "importlib.util.cache_from_source.__qualname__ == 'cache_from_source' — verified at runtime."
    - "importlib.util.source_from_cache.__qualname__ == 'source_from_cache' — verified at runtime."
    - "importlib.util.__class__.__name__ == 'module' — util is a types.ModuleType; verified at runtime."
    - "importlib.util.__class__.__qualname__ == 'module' — the util submodule object's class qualname; verified at runtime."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib.util cache/source helpers — __qualname__ table
#
# importlib_extra8 covers util.cache_from_source __name__ and __module__ but
# does NOT cover __qualname__. No prior importlib spec covers
# util.source_from_cache at all. This table anchors both qualnames in the
# extra14 namespace.
# ---------------------------------------------------------------------------

table importlib_extra14.util_helper_qualnames:
  description: "__qualname__ for util.cache_from_source and util.source_from_cache"
  kind: python_call_eq
  category: function_attrs
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [cache_from_source, util.cache_from_source.__qualname__.__eq__, ["cache_from_source"], true]
    - [source_from_cache, util.source_from_cache.__qualname__.__eq__, ["source_from_cache"], true]

# ---------------------------------------------------------------------------
# importlib.util submodule object — __class__.__name__ and __class__.__qualname__
#
# importlib_extra13 checks importlib (top-level) __class__.__qualname__ == 'module'.
# No prior importlib spec checks util.__class__.__name__ or
# util.__class__.__qualname__ via dotted chain from the importlib backend root.
# util is a types.ModuleType, so both class name and qualname are 'module'.
# ---------------------------------------------------------------------------

table importlib_extra14.util_class_attrs:
  description: "__class__.__name__ and __class__.__qualname__ for importlib.util submodule object"
  kind: python_call_eq
  category: module_attrs

  columns: [id, function, args, expected]
  rows:
    - [class_name,     util.__class__.__name__.__eq__,     ["module"], true]
    - [class_qualname, util.__class__.__qualname__.__eq__, ["module"], true]

# ---------------------------------------------------------------------------
# importlib.util.cache_from_source — __qualname__ standalone
#
# The table above covers cache_from_source.__qualname__ in a row. This
# invariant re-anchors it as a standalone in the extra14 namespace.
# ---------------------------------------------------------------------------

invariant importlib_extra14.util_cache_from_source.qualname:
  description: "importlib.util.cache_from_source.__qualname__ == 'cache_from_source'"
  category: function_attrs
  kind: python_call_eq
  function: util.cache_from_source.__qualname__.__eq__
  args: ["cache_from_source"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.util.source_from_cache — __qualname__ standalone
#
# No prior importlib spec covers util.source_from_cache in any form. This
# invariant anchors source_from_cache.__qualname__ as a standalone in the
# extra14 namespace.
# ---------------------------------------------------------------------------

invariant importlib_extra14.util_source_from_cache.qualname:
  description: "importlib.util.source_from_cache.__qualname__ == 'source_from_cache'"
  category: function_attrs
  kind: python_call_eq
  function: util.source_from_cache.__qualname__.__eq__
  args: ["source_from_cache"]
  expected: true
