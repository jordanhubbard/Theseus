spec: re_extra266
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.__name__ == 're' — the module name."
    - "re.__package__ == 're' — re is itself its own package (it's a package directory in CPython 3.11+)."
    - "re.__spec__.__class__.__name__ == 'ModuleSpec'."
    - "re.__spec__.name == 're'."
    - "re.__loader__.__class__.__name__ == 'SourceFileLoader' — re is a Python source module."
    - "re.error is re.PatternError — they are the same class object (alias introduced in Python 3.13)."
    - "re.error.__name__ == 'PatternError' — the canonical class name (re.error is an alias)."
    - "re.PatternError.__name__ == 'PatternError' — confirmed via the canonical name."
    - "re.error.__module__ == 're'."
    - "re.T / re.TEMPLATE does not exist in Python 3.14.4 (removed deprecated flag)."
    - "int(re.DEBUG) == 128; int(re.UNICODE) == 32; int(re.IGNORECASE) == 2."
    - "int(re.MULTILINE) == 8; int(re.DOTALL) == 16; int(re.VERBOSE) == 64; int(re.ASCII) == 256."
    - "re.U is re.UNICODE (alias); re.I is re.IGNORECASE; re.M is re.MULTILINE; re.S is re.DOTALL; re.X is re.VERBOSE; re.A is re.ASCII."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module identity — __name__, __package__, __spec__
# ---------------------------------------------------------------------------

invariant re_extra266.module.name:
  description: "re.__name__ == 're'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["re"]
  expected: true

invariant re_extra266.module.package:
  description: "re.__package__ == 're' — re is its own package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["re"]
  expected: true

invariant re_extra266.module.spec_class:
  description: "re.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant re_extra266.module.spec_name:
  description: "re.__spec__.name == 're'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["re"]
  expected: true

invariant re_extra266.module.loader_class:
  description: "re.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# re.error / re.PatternError — class identity (Python 3.13+ alias)
# ---------------------------------------------------------------------------

invariant re_extra266.error.name:
  description: "re.error.__name__ == 'PatternError' — canonical class name (re.error is an alias)"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra266.error.module:
  description: "re.error.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra266.PatternError.name:
  description: "re.PatternError.__name__ == 'PatternError'"
  category: identity
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra266.PatternError.module:
  description: "re.PatternError.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: PatternError.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re flag integer values — DEBUG, UNICODE, IGNORECASE, MULTILINE, DOTALL, VERBOSE, ASCII
# ---------------------------------------------------------------------------

table re_extra266.flag_values:
  description: "Integer values of re flag constants verified on Python 3.14.4"
  kind: python_call_eq
  category: flags
  id_prefix: flag

  columns: [id, function, args, expected, description]
  rows:
    - [debug,      DEBUG.__index__,      [], 128, "int(re.DEBUG) == 128"]
    - [unicode,    UNICODE.__index__,    [], 32,  "int(re.UNICODE) == 32"]
    - [ignorecase, IGNORECASE.__index__, [], 2,   "int(re.IGNORECASE) == 2"]
    - [multiline,  MULTILINE.__index__,  [], 8,   "int(re.MULTILINE) == 8"]
    - [dotall,     DOTALL.__index__,     [], 16,  "int(re.DOTALL) == 16"]
    - [verbose,    VERBOSE.__index__,    [], 64,  "int(re.VERBOSE) == 64"]
    - [ascii,      ASCII.__index__,      [], 256, "int(re.ASCII) == 256"]

# ---------------------------------------------------------------------------
# re flag aliases — short-form aliases equal their long-form counterparts
# ---------------------------------------------------------------------------

invariant re_extra266.U_eq_UNICODE:
  description: "re.U.__eq__(re.UNICODE) is True — re.U is the short alias for re.UNICODE"
  category: flags
  kind: python_call_eq
  function: U.__eq__
  args: [32]
  expected: true

invariant re_extra266.I_eq_IGNORECASE:
  description: "re.I.__eq__(re.IGNORECASE) — int value 2"
  category: flags
  kind: python_call_eq
  function: I.__eq__
  args: [2]
  expected: true

invariant re_extra266.M_eq_MULTILINE:
  description: "re.M.__eq__(re.MULTILINE) — int value 8"
  category: flags
  kind: python_call_eq
  function: M.__eq__
  args: [8]
  expected: true

invariant re_extra266.S_eq_DOTALL:
  description: "re.S.__eq__(re.DOTALL) — int value 16"
  category: flags
  kind: python_call_eq
  function: S.__eq__
  args: [16]
  expected: true
