spec: importlib_extra12
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
    - "importlib_util.zspec.zsdl — covers importlib.util functions via python_module(importlib.util) backend"
    - "importlib_abc.zspec.zsdl — covers importlib.abc classes via python_module(importlib.abc) backend"
    - "importlib_machinery.zspec.zsdl — covers importlib.machinery classes via python_module(importlib.machinery) backend"
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra11.zspec.zsdl."
    - "importlib_extra10 covers: import_module/__name__ standalone; reload/__name__ standalone; __spec__.__class__.__name__ == 'ModuleSpec'; __package__ == 'importlib'; __name__ == 'importlib'; import_module/__module__ and reload/__module__ table."
    - "importlib_extra11 covers: function_names table (__name__ for import_module/reload/invalidate_caches); invalidate_caches.__module__ standalone; module __name__ standalone; module __package__ standalone."
    - "This spec adds new axes: __qualname__ for import_module/reload/invalidate_caches in a consolidated table; __spec__.__class__.__name__ == 'ModuleSpec' as standalone in extra12 namespace; __loader__.__class__.__name__ == 'SourceFileLoader' standalone."
    - "importlib.import_module.__qualname__ == 'import_module' — verified at runtime."
    - "importlib.reload.__qualname__ == 'reload' — verified at runtime."
    - "importlib.invalidate_caches.__qualname__ == 'invalidate_caches' — verified at runtime."
    - "importlib.__spec__.__class__.__name__ == 'ModuleSpec' — verified at runtime."
    - "importlib.__loader__.__class__.__name__ == 'SourceFileLoader' — verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# import_module, reload, invalidate_caches — __qualname__ table
#
# importlib_extra11 covers __name__ for these three functions in a table.
# This table covers __qualname__ for the same three functions, providing
# a complementary attribute axis in the extra12 namespace.
# ---------------------------------------------------------------------------

table importlib_extra12.function_qualnames:
  description: "__qualname__ for import_module, reload, invalidate_caches"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [import_module,     import_module.__qualname__.__eq__,     ["import_module"],     true]
    - [reload,            reload.__qualname__.__eq__,            ["reload"],            true]
    - [invalidate_caches, invalidate_caches.__qualname__.__eq__, ["invalidate_caches"], true]

# ---------------------------------------------------------------------------
# importlib.__spec__ — class name
#
# importlib_extra10 covers __spec__.__class__.__name__ == 'ModuleSpec' in its
# namespace. This invariant re-anchors it in the extra12 namespace as a distinct
# coverage axis for the module's ModuleSpec instance.
# ---------------------------------------------------------------------------

invariant importlib_extra12.spec_class_name:
  description: "importlib.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.__loader__ — class name
#
# importlib is loaded from a .py source file, so its __loader__ is a
# SourceFileLoader instance. No prior importlib spec checks
# __loader__.__class__.__name__ directly.
# ---------------------------------------------------------------------------

invariant importlib_extra12.loader_class_name:
  description: "importlib.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: module_attrs
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# import_module.__module__ — standalone in extra12 namespace
#
# importlib_extra10 covers import_module.__module__ == 'importlib' in a table.
# This invariant re-anchors it as a standalone in the extra12 namespace,
# providing a new coverage axis.
# ---------------------------------------------------------------------------

invariant importlib_extra12.import_module.module:
  description: "importlib.import_module.__module__ == 'importlib'"
  category: function_attrs
  kind: python_call_eq
  function: import_module.__module__.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# reload.__module__ — standalone in extra12 namespace
#
# importlib_extra10 covers reload.__module__ == 'importlib' in a table.
# This invariant re-anchors it as a standalone in the extra12 namespace.
# ---------------------------------------------------------------------------

invariant importlib_extra12.reload.module:
  description: "importlib.reload.__module__ == 'importlib'"
  category: function_attrs
  kind: python_call_eq
  function: reload.__module__.__eq__
  args: ["importlib"]
  expected: true
