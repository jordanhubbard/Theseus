# ---------------------------------------------------------------------------
# zoneinfo_create (category: zoneinfo_create) — ZoneInfo object .key attribute
#
# ZoneInfo(key).key == key — the .key attribute reflects the IANA name.
# Verified with tzdata 2026.1 on Python 3.14 / Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant tzdata.zoneinfo_create.utc_key:
  description: "ZoneInfo('UTC').key == 'UTC'"
  category: zoneinfo_create
  kind: python_call_eq
  function: ZoneInfo
  args: ["UTC"]
  method: key
  expected: "UTC"

invariant tzdata.zoneinfo_create.america_new_york_key:
  description: "ZoneInfo('America/New_York').key == 'America/New_York'"
  category: zoneinfo_create
  kind: python_call_eq
  function: ZoneInfo
  args: ["America/New_York"]
  method: key
  expected: "America/New_York"

invariant tzdata.zoneinfo_create.europe_london_key:
  description: "ZoneInfo('Europe/London').key == 'Europe/London'"
  category: zoneinfo_create
  kind: python_call_eq
  function: ZoneInfo
  args: ["Europe/London"]
  method: key
  expected: "Europe/London"

invariant tzdata.zoneinfo_create.asia_tokyo_key:
  description: "ZoneInfo('Asia/Tokyo').key == 'Asia/Tokyo'"
  category: zoneinfo_create
  kind: python_call_eq
  function: ZoneInfo
  args: ["Asia/Tokyo"]
  method: key
  expected: "Asia/Tokyo"

invariant tzdata.zoneinfo_create.america_chicago_key:
  description: "ZoneInfo('America/Chicago').key == 'America/Chicago'"
  category: zoneinfo_create
  kind: python_call_eq
  function: ZoneInfo
  args: ["America/Chicago"]
  method: key
  expected: "America/Chicago"

invariant tzdata.zoneinfo_create.europe_berlin_key:
  description: "ZoneInfo('Europe/Berlin').key == 'Europe/Berlin'"
  category: zoneinfo_create
  kind: python_call_eq
  function: ZoneInfo
  args: ["Europe/Berlin"]
  method: key
  expected: "Europe/Berlin"

invariant tzdata.zoneinfo_create.asia_shanghai_key:
  description: "ZoneInfo('Asia/Shanghai').key == 'Asia/Shanghai'"
  category: zoneinfo_create
  kind: python_call_eq
  function: ZoneInfo
  args: ["Asia/Shanghai"]
  method: key
  expected: "Asia/Shanghai"

# ---------------------------------------------------------------------------
# count (category: count) — available_timezones() key length checks
#
# The .key of ZoneInfo('UTC') is 'UTC' (length 3).
# The .key of ZoneInfo('America/New_York') is 'America/New_York' (length 16).
# These confirm that .key is a populated string, not an empty placeholder.
# Verified with tzdata 2026.1 on Python 3.14 / Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant tzdata.count.utc_key_len:
  description: "len(ZoneInfo('UTC').key) == 3 — 'UTC' is three characters"
  category: count
  kind: python_call_eq
  function: ZoneInfo
  args: ["UTC"]
  method: key
  method_chain: "__len__"
  expected: 3

invariant tzdata.count.america_new_york_key_len:
  description: "len(ZoneInfo('America/New_York').key) == 16"
  category: count
  kind: python_call_eq
  function: ZoneInfo
  args: ["America/New_York"]
  method: key
  method_chain: "__len__"
  expected: 16

invariant tzdata.count.pacific_auckland_key_len:
  description: "len(ZoneInfo('Pacific/Auckland').key) == 16 — 'Pacific/Auckland' is sixteen characters"
  category: count
  kind: python_call_eq
  function: ZoneInfo
  args: ["Pacific/Auckland"]
  method: key
  method_chain: "__len__"
  expected: 16

# ---------------------------------------------------------------------------
# error (category: error) — ZoneInfo raises on unknown key
#
# ZoneInfo('Not/A/Timezone') must raise zoneinfo.ZoneInfoNotFoundError.
# This is part of the IANA key contract: invalid names are rejected.
# Verified with tzdata 2026.1 on Python 3.14 / Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant tzdata.error.unknown_key_raises:
  description: "ZoneInfo('Not/A/Timezone') raises ZoneInfoNotFoundError"
  category: error
  kind: python_call_raises
  function: ZoneInfo
  args: ["Not/A/Timezone"]
  expected_exception: "zoneinfo.ZoneInfoNotFoundError"

