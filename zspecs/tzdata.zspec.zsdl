spec: tzdata
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://tzdata.readthedocs.io/

provenance:
  derived_from:
    - "tzdata PyPI page — https://pypi.org/project/tzdata/"
    - "PEP 615 — Support for the IANA Time Zone Database in the Standard Library"
    - "Python docs: zoneinfo — https://docs.python.org/3/library/zoneinfo.html"
    - "IANA Time Zone Database — https://www.iana.org/time-zones"
    - "Test vectors verified with tzdata 2026.1 / zoneinfo on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "tzdata source: tzdata/__init__.py"
    - "tzdata source: tzdata/zoneinfo/ (data files)"
    - "CPython source: Lib/zoneinfo/__init__.py"
  notes:
    - "tzdata provides IANA timezone data for the stdlib zoneinfo module."
    - "The invariants target zoneinfo as the consumer interface backed by tzdata."
    - "zoneinfo.available_timezones() returns a set; count varies by tzdata version but exceeds 400."
    - "ZoneInfo objects expose a .key attribute equal to the IANA key used to create them."
    - "ZoneInfo('Not/A/Timezone') raises zoneinfo.ZoneInfoNotFoundError for unknown keys."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# zoneinfo_keys (category: zoneinfo_keys) — available_timezones() membership
#
# available_timezones() returns a set of IANA key strings backed by tzdata.
# UTC, America/New_York, Europe/London, Asia/Tokyo, America/Los_Angeles,
# Pacific/Auckland, and Africa/Cairo are always present in every IANA release.
#
# Pattern: function='available_timezones', args=[], method='__contains__',
# method_args=[key], expected=true.
# Verified with tzdata 2026.1 on Python 3.14 / Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant tzdata.zoneinfo_keys.contains_utc:
  description: "'UTC' is in zoneinfo.available_timezones()"
  category: zoneinfo_keys
  kind: python_call_eq
  function: available_timezones
  args: []
  method: "__contains__"
  method_args: ["UTC"]
  expected: true

invariant tzdata.zoneinfo_keys.contains_america_new_york:
  description: "'America/New_York' is in zoneinfo.available_timezones()"
  category: zoneinfo_keys
  kind: python_call_eq
  function: available_timezones
  args: []
  method: "__contains__"
  method_args: ["America/New_York"]
  expected: true

invariant tzdata.zoneinfo_keys.contains_europe_london:
  description: "'Europe/London' is in zoneinfo.available_timezones()"
  category: zoneinfo_keys
  kind: python_call_eq
