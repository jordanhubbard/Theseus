spec: difflib_extra11
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra10.zspec.zsdl."
    - "difflib_extra10 covers: SequenceMatcher.ratio partial 4-of-5; quick_ratio partial 5-char; real_quick_ratio unequal lengths; HtmlDiff mro len; ndiff added-line prefix; get_close_matches cutoff high/low."
    - "difflib_extra9 covers: SequenceMatcher.ratio identical/empty/single-disjoint/partial; ndiff removed-line prefix; get_close_matches 'teh'/'speling'."
    - "difflib_extra8 covers: IS_LINE_JUNK/IS_CHARACTER_JUNK qualname and behavioral; Differ base class; SequenceMatcher/Differ mro_len; context_diff qualname; get_close_matches wheat/n=1."
    - "difflib_extra5 covers: restore/__name__/__module__; Differ/__module__; HtmlDiff/__module__; IS_LINE_JUNK/__module__; IS_CHARACTER_JUNK/__module__; get_close_matches banana."
    - "difflib_extra2 covers: SequenceMatcher/__name__/__module__; Differ/__name__; IS_LINE_JUNK/__name__; IS_CHARACTER_JUNK/__name__; unified_diff/__module__/ndiff/__module__/context_diff/__module__/get_close_matches/__module__."
    - "NOT yet covered: difflib.unified_diff.__qualname__ == 'unified_diff'."
    - "NOT yet covered: difflib.context_diff.__name__ == 'context_diff'."
    - "NOT yet covered: difflib.get_close_matches.__qualname__ == 'get_close_matches'."
    - "NOT yet covered: difflib.restore.__qualname__ == 'restore'."
    - "NOT yet covered: difflib.SequenceMatcher(None,'','').ratio() == 1.0 — two empty sequences are identical."
    - "NOT yet covered: difflib.SequenceMatcher(None,'a','a').ratio() == 1.0 — single identical char."
    - "NOT yet covered: difflib.SequenceMatcher(None,'ab','ab').quick_ratio() == 1.0 — identical two-char quick_ratio."
    - "NOT yet covered: difflib.SequenceMatcher(None,'abc','xyz').ratio().__lt__(0.1) — fully disjoint ratio is 0."
    - "NOT yet covered: difflib.ndiff(['a\\n'],['b\\n'])[0] — first line of single-line diff is '- a\\n'."
    - "NOT yet covered: difflib.HtmlDiff.__name__ == 'HtmlDiff' — class __name__ not yet a standalone invariant."
    - "difflib.unified_diff.__qualname__ == 'unified_diff' — module-level function qualname equals name."
    - "difflib.context_diff.__name__ == 'context_diff' — function __name__ attribute."
    - "difflib.get_close_matches.__qualname__ == 'get_close_matches' — qualname at module scope."
    - "difflib.restore.__qualname__ == 'restore' — restore is a module-level function."
    - "difflib.SequenceMatcher(None,'','').ratio() == 1.0 — two empty sequences are 100% identical."
    - "difflib.SequenceMatcher(None,'a','a').ratio() == 1.0 — single identical character."
    - "difflib.SequenceMatcher(None,'ab','ab').quick_ratio() == 1.0 — identical two-char quick_ratio."
    - "difflib.SequenceMatcher(None,'abc','xyz').ratio().__eq__(0.0) — fully disjoint ratio is 0.0."
    - "difflib.ndiff(['a\\n'],['b\\n'])[0] == '- a\\n' — first line of removed content."
    - "difflib.HtmlDiff.__name__ == 'HtmlDiff' — class __name__ attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function qualnames — unified_diff, context_diff, get_close_matches, restore
#
# difflib_extra8 covers context_diff.__qualname__. difflib_extra2 covers
# unified_diff/__module__ and context_diff/__module__.
# No prior spec covers unified_diff.__qualname__, context_diff.__name__,
# get_close_matches.__qualname__, or restore.__qualname__ as standalone
# invariants. All are module-scope functions so qualname equals name.
# ---------------------------------------------------------------------------

invariant difflib_extra11.unified_diff.qualname:
  description: "difflib.unified_diff.__qualname__ == 'unified_diff' — module-scope function"
  category: function_identity
  kind: python_call_eq
  function: unified_diff.__qualname__.__eq__
  args: ["unified_diff"]
  expected: true

invariant difflib_extra11.context_diff.name:
  description: "difflib.context_diff.__name__ == 'context_diff' — function __name__ attribute"
  category: function_identity
  kind: python_call_eq
  function: context_diff.__name__.__eq__
  args: ["context_diff"]
  expected: true

invariant difflib_extra11.get_close_matches.qualname:
  description: "difflib.get_close_matches.__qualname__ == 'get_close_matches' — module-scope qualname"
  category: function_identity
  kind: python_call_eq
  function: get_close_matches.__qualname__.__eq__
  args: ["get_close_matches"]
  expected: true

invariant difflib_extra11.restore.qualname:
  description: "difflib.restore.__qualname__ == 'restore' — restore is a module-level function"
  category: function_identity
  kind: python_call_eq
  function: restore.__qualname__.__eq__
  args: ["restore"]
  expected: true

# ---------------------------------------------------------------------------
# HtmlDiff.__name__ — class name attribute
#
# difflib_extra2 covers SequenceMatcher.__name__ and Differ.__name__.
# difflib_extra10 covers HtmlDiff.mro().__len__().
# No prior spec checks HtmlDiff.__name__ == 'HtmlDiff' as a standalone invariant.
# ---------------------------------------------------------------------------

invariant difflib_extra11.HtmlDiff.name:
  description: "difflib.HtmlDiff.__name__ == 'HtmlDiff' — class __name__ attribute"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__name__.__eq__
  args: ["HtmlDiff"]
  expected: true

# ---------------------------------------------------------------------------
# SequenceMatcher.ratio — edge cases: two empty sequences and single char
#
# difflib_extra9 covers ratio for identical 4-char and empty inputs.
# difflib_extra10 covers ratio for 4-of-5 partial match.
# No prior spec tests ratio for single identical character ('a','a') == 1.0.
# The two-empty-sequences case is covered by difflib_extra9 but not as a
# standalone invariant in this namespace.
# ---------------------------------------------------------------------------

invariant difflib_extra11.SequenceMatcher.ratio_single_char:
  description: "difflib.SequenceMatcher(None,'a','a').ratio() == 1.0 — single identical char"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "a", "a"]
  method: ratio.__eq__
  method_args: [1.0]
  expected: true

invariant difflib_extra11.SequenceMatcher.quick_ratio_two_char_identical:
  description: "difflib.SequenceMatcher(None,'ab','ab').quick_ratio() == 1.0 — identical two-char"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "ab", "ab"]
  method: quick_ratio.__eq__
  method_args: [1.0]
  expected: true

invariant difflib_extra11.SequenceMatcher.ratio_fully_disjoint:
  description: "difflib.SequenceMatcher(None,'abc','xyz').ratio() == 0.0 — fully disjoint sequences"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "abc", "xyz"]
  method: ratio.__eq__
  method_args: [0.0]
  expected: true

# ---------------------------------------------------------------------------
# ndiff — removed-content first line
#
# difflib_extra9 covers ndiff removed-line prefix for a two-line diff.
# difflib_extra10 covers ndiff added-line prefix.
# No prior spec uses a single-line diff and checks the first element:
# ndiff(['a\n'], ['b\n'])[0] == '- a\n' — the removed line is the first output.
# ---------------------------------------------------------------------------

invariant difflib_extra11.ndiff.single_line_removed:
  description: "difflib.ndiff(['a\\n'],['b\\n'])[0] == '- a\\n' — removed line is first in single-line diff"
  category: ndiff
  kind: python_call_eq
  function: ndiff
  args: [["a\n"], ["b\n"]]
  method: __next__
  expected: "- a\n"

# ---------------------------------------------------------------------------
# Table: function identity — qualname and __name__ checks
#
# Groups the four function-identity invariants in one indexed table.
# No prior spec provides a table covering unified_diff/context_diff/
# get_close_matches/restore name attributes together.
# ---------------------------------------------------------------------------

table difflib_extra11.function_identity:
  description: "difflib function __name__/__qualname__ identity checks — extra11 namespace"
  kind: python_call_eq
  category: function_identity
  id_prefix: fi

  columns: [id, function, args, expected]
  rows:
    - [unified_diff_qn,     unified_diff.__qualname__.__eq__,     ["unified_diff"],      true]
    - [context_diff_name,   context_diff.__name__.__eq__,         ["context_diff"],      true]
    - [gcm_qualname,        get_close_matches.__qualname__.__eq__, ["get_close_matches"], true]
    - [restore_qualname,    restore.__qualname__.__eq__,           ["restore"],           true]

# ---------------------------------------------------------------------------
# Table: SequenceMatcher ratio edge cases
#
# Groups ratio and quick_ratio edge-case vectors in one indexed table.
# ---------------------------------------------------------------------------

table difflib_extra11.SequenceMatcher_ratio_edges:
  description: "SequenceMatcher ratio edge cases — single char and fully disjoint"
  kind: python_call_eq
  category: SequenceMatcher
  id_prefix: sre

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [single_char_ratio, SequenceMatcher, [~, "a",   "a"],   ratio.__eq__,       [1.0], true]
    - [two_char_quick,    SequenceMatcher, [~, "ab",  "ab"],  quick_ratio.__eq__,  [1.0], true]
    - [disjoint_ratio,    SequenceMatcher, [~, "abc", "xyz"], ratio.__eq__,       [0.0], true]
