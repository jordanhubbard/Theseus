spec: just_compare
version: ">=2.3.0"
backend: node(just-compare)

docs: https://www.npmjs.com/package/just-compare

provenance:
  derived_from:
    - "just-compare README — https://www.npmjs.com/package/just-compare"
    - "Test vectors verified with just-compare via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-compare source"
  notes:
    - "just-compare is an npm package. Install: npm install just-compare"
    - "Deep equality comparison for objects, arrays, and primitives."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_compare.compare:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: jcmp

  columns: [id, args, expected]
  rows:
    - [equal_obj,   [{"a": 1, "b": 2}, {"a": 1, "b": 2}],  true]
    - [unequal_obj, [{"a": 1}, {"a": 2}],                   false]
    - [equal_arr,   [[1, 2, 3], [1, 2, 3]],                 true]
