spec: uuid_extra71
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra70.zspec.zsdl — covers UUID/__dict__.__contains__('__init__'/'__str__'/'__eq__'/'__hash__'/'__lt__'/'int'/'hex'/'urn'/'version'/'bytes'/'fields') / UUID/__init__/__code__/co_name/co_argcount (table + invariants)."
    - "uuid_extra69.zspec.zsdl — covers UUID/__dict__.__contains__('__repr__'/'__int__'/'__setattr__') / SafeUUID/__dict__/__class__/__name__ / UUID/__setattr__/__code__/co_name/co_argcount (table + invariants)."
    - "uuid_extra60.zspec.zsdl — covers UUID/__repr__/__str__/__hash__/__eq__/__code__/co_name and co_argcount / SafeUUID class identity (table + invariants)."
    - "uuid_extra52.zspec.zsdl — covers UUID/__setattr__/__qualname__ / UUID/__getstate__/__setstate__/__init_subclass__/__subclasshook__ __qualname__ (table + invariants)."
    - "uuid_extra29.zspec.zsdl — covers SafeUUID/__mro__/__len__()==3 / UUID/__mro__/__len__()==2 (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra70; it does NOT duplicate invariants present in those files."
    - "Wave 246 theme: uuid module-level functions uuid1/uuid3/uuid4/uuid5 code object attributes and identity."
    - "uuid.uuid1.__code__.co_name == 'uuid1' — the code object co_name matches the function name. No prior uuid spec checks uuid1.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_argcount == 2 — uuid1 takes node=None and clock_seq=None (2 positional args). No prior uuid spec checks uuid1.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_name == 'uuid4' — the code object co_name matches the function name. No prior uuid spec checks uuid4.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_argcount == 0 — uuid4 takes no positional args. No prior uuid spec checks uuid4.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_name == 'uuid3' — the code object co_name matches the function name. No prior uuid spec checks uuid3.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_argcount == 2 — uuid3 takes namespace and name (2 positional args). No prior uuid spec checks uuid3.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_name == 'uuid5' — the code object co_name matches the function name. No prior uuid spec checks uuid5.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_argcount == 2 — uuid5 takes namespace and name (2 positional args). No prior uuid spec checks uuid5.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__module__ == 'uuid' — uuid1 is defined in the uuid Python module. No prior uuid spec checks uuid1.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid' — uuid4 is defined in the uuid Python module. No prior uuid spec checks uuid4.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__module__ == 'uuid' — uuid3 is defined in the uuid Python module. No prior uuid spec checks uuid3.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__module__ == 'uuid' — uuid5 is defined in the uuid Python module. No prior uuid spec checks uuid5.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__qualname__ == 'uuid1' — uuid1 is a module-level function; qualname matches name. No prior uuid spec checks uuid1.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__ == 'uuid4' — uuid4 is a module-level function; qualname matches name. No prior uuid spec checks uuid4.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__ == 'uuid3' — uuid3 is a module-level function; qualname matches name. No prior uuid spec checks uuid3.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__ == 'uuid5' — uuid5 is a module-level function; qualname matches name. No prior uuid spec checks uuid5.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_name and co_argcount
#
# Wave 246 theme: uuid1 code object attributes.
#
# uuid.uuid1 is a Python function. Its code object has co_name == 'uuid1'
# and co_argcount == 2 (node=None, clock_seq=None are two positional args
# with defaults). No prior uuid spec checks uuid1.__code__.co_name or
# uuid1.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra71.uuid1_code_attrs:
  description: "uuid.uuid1/__code__/co_name.__eq__('uuid1')==True / uuid1/__code__/co_argcount.__eq__(2)==True — uuid1 has co_name=='uuid1' and co_argcount==2 (node and clock_seq are positional-with-defaults); no prior uuid spec checks uuid1.__code__.co_name or co_argcount; first code object anchor for uuid1"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidextra71

  columns: [id, function, args, expected]
  rows:
    - [uuid1_co_name_eq,     uuid1.__code__.co_name.__eq__,     ["uuid1"], true]
    - [uuid1_co_argcount_eq, uuid1.__code__.co_argcount.__eq__,  [2],       true]

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_name and co_argcount
# uuid.uuid3.__code__.co_name and co_argcount
#
# Wave 246 theme: uuid4 and uuid3 code object attributes.
#
# uuid4 takes no positional args (co_argcount==0). uuid3 takes namespace and
# name (co_argcount==2). No prior uuid spec checks these co_name or co_argcount
# values. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra71.uuid4_uuid3_code_attrs:
  description: "uuid.uuid4/__code__/co_name.__eq__('uuid4')==True / uuid4/__code__/co_argcount.__eq__(0)==True / uuid3/__code__/co_name.__eq__('uuid3')==True / uuid3/__code__/co_argcount.__eq__(2)==True — uuid4 takes no positional args; uuid3 takes namespace and name; no prior uuid spec checks these code object attributes; first code object anchor for uuid4 and uuid3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidextra71

  columns: [id, function, args, expected]
  rows:
    - [uuid4_co_name_eq,     uuid4.__code__.co_name.__eq__,     ["uuid4"], true]
    - [uuid4_co_argcount_eq, uuid4.__code__.co_argcount.__eq__,  [0],       true]
    - [uuid3_co_name_eq,     uuid3.__code__.co_name.__eq__,     ["uuid3"], true]
    - [uuid3_co_argcount_eq, uuid3.__code__.co_argcount.__eq__,  [2],       true]

# ---------------------------------------------------------------------------
# uuid.uuid5.__code__.co_name and co_argcount
# uuid.uuid1.__module__ and uuid.uuid4.__module__
#
# Wave 246 theme: uuid5 code attributes + uuid1/uuid4 module identity.
#
# uuid5 has co_name=='uuid5' and co_argcount==2 (namespace, name).
# uuid1.__module__ == 'uuid' and uuid4.__module__ == 'uuid'.
# No prior uuid spec checks uuid5.__code__.co_name/co_argcount,
# uuid1.__module__, or uuid4.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra71.uuid5_code_uuid1_uuid4_module:
  description: "uuid.uuid5/__code__/co_name.__eq__('uuid5')==True / uuid5/__code__/co_argcount.__eq__(2)==True / uuid1/__module__.__eq__('uuid')==True / uuid4/__module__.__eq__('uuid')==True — uuid5 takes namespace and name; uuid1/uuid4 are defined in the uuid module; no prior uuid spec checks uuid5 code attrs or uuid1/uuid4 __module__; first module anchor for uuid1 and uuid4"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidextra71

  columns: [id, function, args, expected]
  rows:
    - [uuid5_co_name_eq,     uuid5.__code__.co_name.__eq__,     ["uuid5"], true]
    - [uuid5_co_argcount_eq, uuid5.__code__.co_argcount.__eq__,  [2],       true]
    - [uuid1_module_uuid,    uuid1.__module__.__eq__,            ["uuid"],  true]
    - [uuid4_module_uuid,    uuid4.__module__.__eq__,            ["uuid"],  true]

# ---------------------------------------------------------------------------
# uuid.uuid3/__module__, uuid.uuid5/__module__, uuid.uuid1/__qualname__,
# uuid.uuid4/__qualname__
#
# Wave 246 theme: uuid3/uuid5 module identity and uuid1/uuid4 qualname.
#
# uuid3.__module__ == 'uuid', uuid5.__module__ == 'uuid'.
# uuid1.__qualname__ == 'uuid1', uuid4.__qualname__ == 'uuid4'.
# No prior uuid spec checks these attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra71.uuid3_uuid5_module_uuid1_uuid4_qualname:
  description: "uuid.uuid3/__module__.__eq__('uuid')==True / uuid5/__module__.__eq__('uuid')==True / uuid1/__qualname__.__eq__('uuid1')==True / uuid4/__qualname__.__eq__('uuid4')==True — uuid3/uuid5 are defined in the uuid module; uuid1/uuid4 are module-level functions with qualnames matching their names; no prior uuid spec checks these attributes; first module anchor for uuid3/uuid5 and first qualname anchor for uuid1/uuid4"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidextra71

  columns: [id, function, args, expected]
  rows:
    - [uuid3_module_uuid,    uuid3.__module__.__eq__,    ["uuid"],  true]
    - [uuid5_module_uuid,    uuid5.__module__.__eq__,    ["uuid"],  true]
    - [uuid1_qualname_uuid1, uuid1.__qualname__.__eq__,  ["uuid1"], true]
    - [uuid4_qualname_uuid4, uuid4.__qualname__.__eq__,  ["uuid4"], true]

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_name.__eq__('uuid1') — standalone
#
# uuid1 is a Python function; its code object co_name is 'uuid1'.
# No prior uuid spec checks uuid1.__code__.co_name. First co_name standalone
# for uuid1. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra71.uuid1_co_name:
  description: "uuid.uuid1.__code__.co_name.__eq__('uuid1') == True — uuid1 is a Python function; co_name matches the function name 'uuid1'; no prior uuid spec checks uuid1.__code__.co_name; first co_name standalone for uuid1"
  category: code_attrs
  kind: python_call_eq
  function: uuid1.__code__.co_name.__eq__
  args: ["uuid1"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_argcount.__eq__(0) — standalone
#
# uuid4 takes no positional arguments; co_argcount == 0.
# No prior uuid spec checks uuid4.__code__.co_argcount. First co_argcount
# standalone for uuid4. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra71.uuid4_co_argcount:
  description: "uuid.uuid4.__code__.co_argcount.__eq__(0) == True — uuid4 takes no positional arguments; no prior uuid spec checks uuid4.__code__.co_argcount; first co_argcount standalone for uuid4"
  category: code_attrs
  kind: python_call_eq
  function: uuid4.__code__.co_argcount.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid3.__code__.co_argcount.__eq__(2) — standalone
#
# uuid3 takes namespace and name (2 positional args); co_argcount == 2.
# No prior uuid spec checks uuid3.__code__.co_argcount. First co_argcount
# standalone for uuid3. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra71.uuid3_co_argcount:
  description: "uuid.uuid3.__code__.co_argcount.__eq__(2) == True — uuid3 takes namespace and name (2 positional args); no prior uuid spec checks uuid3.__code__.co_argcount; first co_argcount standalone for uuid3"
  category: code_attrs
  kind: python_call_eq
  function: uuid3.__code__.co_argcount.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__.__eq__('uuid') — standalone
#
# uuid1 is defined in the uuid Python module. No prior uuid spec checks
# uuid1.__module__. First __module__ standalone for uuid1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra71.uuid1_module_uuid:
  description: "uuid.uuid1.__module__.__eq__('uuid') == True — uuid1 is a Python function defined in the uuid module; no prior uuid spec checks uuid1.__module__; first __module__ standalone for uuid1"
  category: code_attrs
  kind: python_call_eq
  function: uuid1.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__qualname__.__eq__('uuid4') — standalone
#
# uuid4 is a module-level function; its __qualname__ matches its name.
# No prior uuid spec checks uuid4.__qualname__. First __qualname__ standalone
# for uuid4. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra71.uuid4_qualname_uuid4:
  description: "uuid.uuid4.__qualname__.__eq__('uuid4') == True — uuid4 is a module-level Python function; __qualname__ matches __name__; no prior uuid spec checks uuid4.__qualname__; first __qualname__ standalone for uuid4"
  category: code_attrs
  kind: python_call_eq
  function: uuid4.__qualname__.__eq__
  args: ["uuid4"]
  expected: true
