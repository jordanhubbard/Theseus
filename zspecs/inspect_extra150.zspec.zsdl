spec: inspect_extra150
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.__dict__.__contains__ membership checks — signature True, isfunction True, getmembers True, Parameter True, Signature True, isclass True, ismodule True, ismethod True, getsource True, getfile True, getdoc True, isgeneratorfunction True (Wave 279)."
    - "inspect.__dict__.__contains__('signature') == True — signature is a Python function in the inspect module dict. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('isfunction') == True — isfunction is a Python function in the inspect module dict. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('getmembers') == True — getmembers is a Python function in the inspect module dict. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('Parameter') == True — Parameter is a Python class in the inspect module dict. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('Signature') == True — Signature is a Python class in the inspect module dict. Verified with Python 3.14.3."
    - "inspect.signature is a Python function; __qualname__ == 'signature' (len 9); __module__ == 'inspect'; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.Signature: __name__ == 'Signature', __module__ == 'inspect', __bases__[0].__name__ == 'object', MRO len 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.__dict__.__contains__ — function membership checks
#
# Wave 279 theme: inspect module dict membership checks for key functions.
#
# inspect.__dict__.__contains__('signature') == True
# inspect.__dict__.__contains__('isfunction') == True
# inspect.__dict__.__contains__('getmembers') == True
# inspect.__dict__.__contains__('isclass') == True
# inspect.__dict__.__contains__('ismodule') == True
#
# These are all Python functions defined in Lib/inspect.py and registered
# in the module dict. New to extra150.
# ---------------------------------------------------------------------------

table inspect_extra150.module_dict_contains_functions:
  description: "inspect.__dict__.__contains__: signature True, isfunction True, getmembers True, isclass True, ismodule True; Python functions in module dict; wave 279; new to extra150"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmdcfunc150

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_signature,
       "__dict__.__contains__",
       ["signature"],
       true,
       "inspect.__dict__.__contains__('signature') == True — signature is a Python function defined in Lib/inspect.py; it returns a Signature object for a callable; dict.__contains__('signature') returns True; new to extra150"]
    - [dict_contains_isfunction,
       "__dict__.__contains__",
       ["isfunction"],
       true,
       "inspect.__dict__.__contains__('isfunction') == True — isfunction is a Python function defined in Lib/inspect.py; it returns True if the object is a Python function; dict.__contains__('isfunction') returns True; new to extra150"]
    - [dict_contains_getmembers,
       "__dict__.__contains__",
       ["getmembers"],
       true,
       "inspect.__dict__.__contains__('getmembers') == True — getmembers is a Python function defined in Lib/inspect.py; it returns all members of an object; dict.__contains__('getmembers') returns True; new to extra150"]
    - [dict_contains_isclass,
       "__dict__.__contains__",
       ["isclass"],
       true,
       "inspect.__dict__.__contains__('isclass') == True — isclass is a Python function defined in Lib/inspect.py; it returns True if the object is a class; dict.__contains__('isclass') returns True; new to extra150"]
    - [dict_contains_ismodule,
       "__dict__.__contains__",
       ["ismodule"],
       true,
       "inspect.__dict__.__contains__('ismodule') == True — ismodule is a Python function defined in Lib/inspect.py; it returns True if the object is a module; dict.__contains__('ismodule') returns True; new to extra150"]

# ---------------------------------------------------------------------------
# Table 2: inspect.__dict__.__contains__ — class and utility membership checks
#
# Wave 279 theme: inspect module dict membership checks for classes and utils.
#
# inspect.__dict__.__contains__('Parameter') == True
# inspect.__dict__.__contains__('Signature') == True
# inspect.__dict__.__contains__('ismethod') == True
# inspect.__dict__.__contains__('getsource') == True
# inspect.__dict__.__contains__('getfile') == True
#
# Parameter and Signature are Python classes; the others are functions.
# New to extra150.
# ---------------------------------------------------------------------------

table inspect_extra150.module_dict_contains_classes_utils:
  description: "inspect.__dict__.__contains__: Parameter True, Signature True, ismethod True, getsource True, getfile True; classes and utilities in module dict; wave 279; new to extra150"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmdcclass150

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_parameter,
       "__dict__.__contains__",
       ["Parameter"],
       true,
       "inspect.__dict__.__contains__('Parameter') == True — Parameter is a Python class defined in Lib/inspect.py representing a callable parameter in a Signature; dict.__contains__('Parameter') returns True; new to extra150"]
    - [dict_contains_signature_class,
       "__dict__.__contains__",
       ["Signature"],
       true,
       "inspect.__dict__.__contains__('Signature') == True — Signature is a Python class defined in Lib/inspect.py representing the call signature of a callable; dict.__contains__('Signature') returns True; new to extra150"]
    - [dict_contains_ismethod,
       "__dict__.__contains__",
       ["ismethod"],
       true,
       "inspect.__dict__.__contains__('ismethod') == True — ismethod is a Python function defined in Lib/inspect.py; it returns True if the object is a bound method; dict.__contains__('ismethod') returns True; new to extra150"]
    - [dict_contains_getsource,
       "__dict__.__contains__",
       ["getsource"],
       true,
       "inspect.__dict__.__contains__('getsource') == True — getsource is a Python function defined in Lib/inspect.py; it returns the source code of an object; dict.__contains__('getsource') returns True; new to extra150"]
    - [dict_contains_getfile,
       "__dict__.__contains__",
       ["getfile"],
       true,
       "inspect.__dict__.__contains__('getfile') == True — getfile is a Python function defined in Lib/inspect.py; it returns the file in which an object was defined; dict.__contains__('getfile') returns True; new to extra150"]

# ---------------------------------------------------------------------------
# Table 3: inspect.signature function identity and inspect.Signature class
#
# Wave 279 theme: inspect.signature function and inspect.Signature class.
#
# inspect.signature.__qualname__ == 'signature' (len 9)
# inspect.signature.__module__ == 'inspect'
# inspect.signature.__code__.co_argcount == 1
# inspect.Signature.__name__ == 'Signature'
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__bases__[0].__name__ == 'object'
# len(inspect.Signature.__mro__) == 2
#
# signature() is a Python function; Signature is a Python class defined in
# Lib/inspect.py. New to extra150.
# ---------------------------------------------------------------------------

table inspect_extra150.signature_func_and_class:
  description: "inspect.signature: function, __qualname__ 'signature' len 9, co_argcount 1; inspect.Signature class, __bases__[0]=='object', MRO len 2; wave 279; new to extra150"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectsig150

  columns: [id, function, args, expected, description]
  rows:
    - [signature_func_class_eq_function,
       "signature.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.signature.__class__.__name__.__eq__('function') == True — signature is a Python function defined in Lib/inspect.py that returns a Signature object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra150"]
    - [signature_func_qualname_eq,
       "signature.__qualname__.__eq__",
       ["signature"],
       true,
       "inspect.signature.__qualname__.__eq__('signature') == True — signature is defined at module scope; __qualname__ is 'signature'; str.__eq__('signature') returns True; new to extra150"]
    - [signature_func_qualname_len_eq_9,
       "signature.__qualname__.__len__",
       [],
       9,
       "inspect.signature.__qualname__.__len__() == 9 — __qualname__ is 'signature' which has 9 characters; len('signature') == 9; new to extra150"]
    - [signature_func_module_eq_inspect,
       "signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra150"]
    - [signature_func_co_argcount_eq_1,
       "signature.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — signature takes 1 positional argument: the callable whose signature to retrieve; co_argcount is 1; int.__eq__(1) returns True; new to extra150"]
    - [signature_class_name_eq,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a Python class defined in Lib/inspect.py; __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra150"]
    - [signature_class_module_eq_inspect,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra150"]
    - [signature_class_bases_first_eq_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra150"]
    - [signature_class_mro_len_eq_2,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — Signature inherits directly from object; MRO is [Signature, object]; len(__mro__) == 2; new to extra150"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra150
# ---------------------------------------------------------------------------

invariant inspect_extra150.dict_contains_signature:
  description: "inspect.__dict__.__contains__('signature') == True — signature function is in module dict; wave 279; new to extra150"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["signature"]
  expected: true

invariant inspect_extra150.dict_contains_isfunction:
  description: "inspect.__dict__.__contains__('isfunction') == True — isfunction is in module dict; wave 279; new to extra150"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["isfunction"]
  expected: true

invariant inspect_extra150.dict_contains_getmembers:
  description: "inspect.__dict__.__contains__('getmembers') == True — getmembers is in module dict; wave 279; new to extra150"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["getmembers"]
  expected: true

invariant inspect_extra150.dict_contains_parameter:
  description: "inspect.__dict__.__contains__('Parameter') == True — Parameter class is in module dict; wave 279; new to extra150"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Parameter"]
  expected: true

invariant inspect_extra150.dict_contains_signature_class:
  description: "inspect.__dict__.__contains__('Signature') == True — Signature class is in module dict; wave 279; new to extra150"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Signature"]
  expected: true

invariant inspect_extra150.dict_contains_isclass:
  description: "inspect.__dict__.__contains__('isclass') == True — isclass is in module dict; wave 279; new to extra150"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["isclass"]
  expected: true

invariant inspect_extra150.dict_contains_getsource:
  description: "inspect.__dict__.__contains__('getsource') == True — getsource is in module dict; wave 279; new to extra150"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["getsource"]
  expected: true

invariant inspect_extra150.signature_func_qualname_len:
  description: "len(inspect.signature.__qualname__) == 9 — __qualname__ is 'signature'; wave 279; new to extra150"
  kind: python_call_eq
  function: signature.__qualname__.__len__
  args: []
  expected: 9

invariant inspect_extra150.signature_func_co_argcount:
  description: "inspect.signature.__code__.co_argcount == 1 — signature takes one argument: the callable; wave 279; new to extra150"
  kind: python_call_eq
  function: signature.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra150.signature_class_mro_len:
  description: "len(inspect.Signature.__mro__) == 2 — Signature inherits from object only; MRO is [Signature, object]; wave 279; new to extra150"
  kind: python_call_eq
  function: Signature.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra150.signature_class_bases_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object; wave 279; new to extra150"
  kind: python_call_eq
  function: "Signature.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

