spec: struct_extra189
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic (for float/double format strings)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec does NOT duplicate invariants already present in struct.zspec.zsdl or prior struct_extra files."
    - "struct.calcsize.__qualname__ == 'calcsize' — C-extension builtin functions have flat qualnames."
    - "struct.pack.__qualname__ == 'pack' — likewise."
    - "struct.unpack.__qualname__ == 'unpack' — likewise."
    - "struct.pack_into.__qualname__ == 'pack_into' — likewise."
    - "struct.unpack_from.__qualname__ == 'unpack_from' — likewise."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack' — likewise."
    - "len(struct.calcsize.__name__) == 8 — 'calcsize' has 8 characters."
    - "len(struct.iter_unpack.__name__) == 11 — 'iter_unpack' has 11 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct function __qualname__ attributes — group 1 (calcsize, pack, unpack)
# ---------------------------------------------------------------------------

table struct_extra189.qualnames.group1:
  kind: python_call_eq
  category: qualnames
  id_prefix: structqualnames189

  columns: [id, function, args, expected]
  rows:
    - [calcsize_qualname, calcsize.__qualname__.__eq__, ["calcsize"], true]
    - [pack_qualname,     pack.__qualname__.__eq__,     ["pack"],     true]
    - [unpack_qualname,   unpack.__qualname__.__eq__,   ["unpack"],   true]

# ---------------------------------------------------------------------------
# struct function __qualname__ attributes — group 2 (pack_into, unpack_from, iter_unpack)
# ---------------------------------------------------------------------------

table struct_extra189.qualnames.group2:
  kind: python_call_eq
  category: qualnames
  id_prefix: structqualnames189

  columns: [id, function, args, expected]
  rows:
    - [pack_into_qualname,   pack_into.__qualname__.__eq__,   ["pack_into"],   true]
    - [unpack_from_qualname, unpack_from.__qualname__.__eq__, ["unpack_from"], true]
    - [iter_unpack_qualname, iter_unpack.__qualname__.__eq__, ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# struct function __name__ length checks
# ---------------------------------------------------------------------------

table struct_extra189.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: structqualnames189

  columns: [id, function, args, expected]
  rows:
    - [calcsize_len,    calcsize.__name__.__len__,    [], 8]
    - [iter_unpack_len, iter_unpack.__name__.__len__, [], 11]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra189.calcsize.qualname:
  description: "struct.calcsize.__qualname__ == 'calcsize' — C-extension builtin has flat qualname"
  category: qualnames
  kind: python_call_eq
  function: calcsize.__qualname__.__eq__
  args: ["calcsize"]
  expected: true

invariant struct_extra189.pack.qualname:
  description: "struct.pack.__qualname__ == 'pack' — C-extension builtin has flat qualname"
  category: qualnames
  kind: python_call_eq
  function: pack.__qualname__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra189.unpack.qualname:
