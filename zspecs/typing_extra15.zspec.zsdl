spec: typing_extra15
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 544 — Protocols: Structural subtyping (static duck typing)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra14.zspec.zsdl."
    - "typing_extra14 covers: Any/__name__; Union/__name__; Callable/__name__/__lname__; Optional/__name__; special_form_names table."
    - "typing_extra13 covers: overload/__module__/__qualname__; get_type_hints/__module__; get_args/__module__; get_origin/__module__; is_typeddict/__module__; runtime_checkable/__module__; TypeVar/__module__; ParamSpec/__module__; TypeVarTuple/__module__; no_type_check_decorator/__module__; helper_modules table."
    - "NOT yet covered: typing.TypeVar.__bases__.__len__() == 1 — TypeVar has one direct base (object)."
    - "NOT yet covered: typing.TypeVar.__bases__[0].__name__ == 'object'."
    - "NOT yet covered: typing.Protocol.__name__ == 'Protocol' as a standalone invariant."
    - "NOT yet covered: typing.Protocol.__module__ == 'typing' as a standalone invariant."
    - "NOT yet covered: typing.Protocol.__qualname__ == 'Protocol' as a standalone invariant."
    - "NOT yet covered: typing.NamedTuple.__name__ == 'NamedTuple' as a standalone invariant."
    - "NOT yet covered: typing.TypedDict.__name__ == 'TypedDict' as a standalone invariant."
    - "NOT yet covered: typing.get_args.__qualname__ == 'get_args' as a standalone invariant."
    - "NOT yet covered: typing.get_origin.__qualname__ == 'get_origin' as a standalone invariant."
    - "NOT yet covered: typing.cast.__qualname__ == 'cast' as a standalone invariant."
    - "typing.TypeVar.__bases__.__len__() == 1 — TypeVar's only direct base is object."
    - "typing.TypeVar.__bases__[0].__name__ == 'object'."
    - "typing.Protocol.__name__ == 'Protocol'."
    - "typing.Protocol.__module__ == 'typing'."
    - "typing.Protocol.__qualname__ == 'Protocol'."
    - "typing.NamedTuple.__name__ == 'NamedTuple'."
    - "typing.TypedDict.__name__ == 'TypedDict'."
    - "typing.get_args.__qualname__ == 'get_args'."
    - "typing.get_origin.__qualname__ == 'get_origin'."
    - "typing.cast.__qualname__ == 'cast'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TypeVar class __bases__ — length and first entry
#
# typing_extra10 covers TypeVar.__bases__ for ParamSpec and TypeVarTuple.
# typing_extra12 covers TypeVar.__name__ == 'TypeVar' (class name).
# No prior spec checks TypeVar.__bases__.__len__() or TypeVar.__bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant typing_extra15.TypeVar.bases_len:
  description: "typing.TypeVar.__bases__.__len__() == 1 — TypeVar has one direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: TypeVar.__bases__.__len__
  args: []
  expected: 1

invariant typing_extra15.TypeVar.base0_is_object:
  description: "typing.TypeVar.__bases__[0].__name__ == 'object' — TypeVar's only direct base is object"
  category: class_hierarchy
  kind: python_call_eq
  function: TypeVar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Protocol — __name__, __module__, __qualname__
#
# typing_protocol.zspec.zsdl covers runtime_checkable Protocol subclassing
# and typing_extra9 covers runtime_checkable.__name__.
# No prior spec checks Protocol.__name__, Protocol.__module__, or
# Protocol.__qualname__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant typing_extra15.Protocol.name:
  description: "typing.Protocol.__name__ == 'Protocol'"
  category: class_names
  kind: python_call_eq
  function: Protocol.__name__.__eq__
  args: ["Protocol"]
  expected: true

invariant typing_extra15.Protocol.module:
  description: "typing.Protocol.__module__ == 'typing'"
  category: class_modules
  kind: python_call_eq
  function: Protocol.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra15.Protocol.qualname:
  description: "typing.Protocol.__qualname__ == 'Protocol'"
  category: qualnames
  kind: python_call_eq
  function: Protocol.__qualname__.__eq__
  args: ["Protocol"]
  expected: true

# ---------------------------------------------------------------------------
# NamedTuple and TypedDict — __name__ standalone invariants
#
# typing_extra11 covers NamedTuple.__module__ and TypedDict.__module__.
# No prior spec covers NamedTuple.__name__ or TypedDict.__name__ as
# standalone invariants (both are accessible as string attributes).
# ---------------------------------------------------------------------------

invariant typing_extra15.NamedTuple.name:
  description: "typing.NamedTuple.__name__ == 'NamedTuple'"
  category: class_names
  kind: python_call_eq
  function: NamedTuple.__name__.__eq__
  args: ["NamedTuple"]
  expected: true

invariant typing_extra15.TypedDict.name:
  description: "typing.TypedDict.__name__ == 'TypedDict'"
  category: class_names
  kind: python_call_eq
  function: TypedDict.__name__.__eq__
  args: ["TypedDict"]
  expected: true

# ---------------------------------------------------------------------------
# get_args, get_origin, cast — __qualname__ standalone invariants
#
# typing_extra12 covers get_args.__name__ (helper_names table) and cast.__name__.
# typing_extra13 covers get_args.__module__, get_origin.__module__.
# typing_extra13 covers overload.__qualname__ as standalone.
# No prior spec checks get_args/__qualname__, get_origin/__qualname__, or
# cast/__qualname__ as standalone invariants. For top-level functions,
# __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant typing_extra15.get_args.qualname:
  description: "typing.get_args.__qualname__ == 'get_args' — top-level function qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: get_args.__qualname__.__eq__
  args: ["get_args"]
  expected: true

invariant typing_extra15.get_origin.qualname:
  description: "typing.get_origin.__qualname__ == 'get_origin' — top-level function qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: get_origin.__qualname__.__eq__
  args: ["get_origin"]
  expected: true

invariant typing_extra15.cast.qualname:
  description: "typing.cast.__qualname__ == 'cast' — top-level function qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: cast.__qualname__.__eq__
  args: ["cast"]
  expected: true
