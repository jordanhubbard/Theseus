    - [pr_name_len,  process.__name__.__len__,          [],                             26,   "concurrent.futures.process.__name__.__len__() == 26; verified with Python 3.14.3"]
    - [pr_pkg_eq,    process.__package__.__eq__,        ["concurrent.futures"],         true, "concurrent.futures.process.__package__ == 'concurrent.futures'; verified with Python 3.14.3"]
