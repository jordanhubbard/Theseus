# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra244
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra244.thread_name_eq:
  description: "concurrent.futures.thread.__name__.__eq__('concurrent.futures.thread') returns True — the thread submodule's fully qualified name (len=25 = 'concurrent.futures.'=19 + 'thread'=6); thread.__package__ == 'concurrent.futures' (len=19); thread.__class__.__name__ == 'module'; process.__name__.__len__()==26 (one longer); _base.__name__.__len__()==24 (one shorter); NEW in extra244: first standalone thread submodule name invariant in cf244submods namespace; verified with Python 3.14.3"
  category: thread_submod_identity
  kind: python_call_eq
  function: thread.__name__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra244.process_name_eq:
  description: "concurrent.futures.process.__name__.__eq__('concurrent.futures.process') returns True — the process submodule's fully qualified name (len=26 = 'concurrent.futures.'=19 + 'process'=7); process.__package__ == 'concurrent.futures' (len=19); process.__class__.__name__ == 'module'; thread.__name__.__len__()==25 (one shorter); _base.__name__.__len__()==24 (two shorter); NEW in extra244: first standalone process submodule name invariant; verified with Python 3.14.3"
  category: process_submod_identity
  kind: python_call_eq
  function: process.__name__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra244.base_name_eq:
  description: "concurrent.futures._base.__name__.__eq__('concurrent.futures._base') returns True — the _base submodule's fully qualified name (len=24 = 'concurrent.futures.'=19 + '_base'=5); _base.__package__ == 'concurrent.futures' (len=19); _base.__class__.__name__ == 'module'; _base.__name__.__len__()==24 is the shortest among the three submodule names (24 < 25 < 26); NEW in extra244: first standalone _base submodule name invariant; verified with Python 3.14.3"
  category: base_submod_identity
  kind: python_call_eq
  function: _base.__name__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
