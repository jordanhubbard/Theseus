spec: concurrent_futures_extra244
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#module-concurrent.futures.thread — thread submodule"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py (internal worker thread implementation)"
    - "CPython source: Lib/concurrent/futures/process.py (internal worker process implementation)"
    - "CPython source: Lib/concurrent/futures/_base.py (internal base class implementation)"
  notes:
    - "This spec covers concurrent.futures.thread, concurrent.futures.process, and concurrent.futures._base submodule identity."
    - "concurrent.futures.thread.__name__ == 'concurrent.futures.thread' (len=25)."
    - "concurrent.futures.process.__name__ == 'concurrent.futures.process' (len=26, one longer than thread)."
    - "concurrent.futures._base.__name__ == 'concurrent.futures._base' (len=24, one shorter than thread)."
    - "All three are module objects: __class__.__name__ == 'module'."
    - "All three share __package__ == 'concurrent.futures' (len=19)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.thread submodule identity
#
# thread.__name__ == 'concurrent.futures.thread' (len=25)
# thread.__package__ == 'concurrent.futures' (len=19)
# thread.__class__.__name__ == 'module'
# ---------------------------------------------------------------------------

table concurrent_futures_extra244.thread_submod_identity:
  description: "concurrent.futures.thread submodule identity — thread.__name__.__eq__('concurrent.futures.thread')==True (len=25); thread.__package__.__eq__('concurrent.futures')==True (len=19); thread.__class__.__name__.__eq__('module')==True; thread.__name__.__len__()==25; thread.__package__.__len__()==19; thread.__spec__.__class__.__name__.__eq__('ModuleSpec')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: thread_submod_identity
  id_prefix: cf244submods

  columns: [id, function, args, expected, description]
  rows:
    - [th_name_eq,   thread.__name__.__eq__,           ["concurrent.futures.thread"], true, "concurrent.futures.thread.__name__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [th_name_len,  thread.__name__.__len__,          [],                            25,   "concurrent.futures.thread.__name__.__len__() == 25; verified with Python 3.14.3"]
    - [th_pkg_eq,    thread.__package__.__eq__,        ["concurrent.futures"],        true, "concurrent.futures.thread.__package__ == 'concurrent.futures'; verified with Python 3.14.3"]
    - [th_pkg_len,   thread.__package__.__len__,       [],                            19,   "concurrent.futures.thread.__package__.__len__() == 19; verified with Python 3.14.3"]
    - [th_cls_eq,    thread.__class__.__name__.__eq__, ["module"],                    true, "concurrent.futures.thread.__class__.__name__ == 'module'; verified with Python 3.14.3"]

