spec: query_string
version: ">=7.0.0"
backend: node(query-string)

docs: https://github.com/sindresorhus/query-string#readme

provenance:
  derived_from:
    - "query-string README — https://github.com/sindresorhus/query-string#readme"
    - "Test vectors verified with query-string@7.1.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "query-string source: index.js"
  notes:
    - "query-string@7 (CJS) exports an object with parse() and stringify() methods."
    - "parse() converts a query string to a JS object (values are always strings)."
    - "stringify() converts a JS object to a query string."
    - "Arrays stringify as repeated keys by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "parse returns object; stringify returns string. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table query_string.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: qs_parse

  columns: [id, args, expected]
  rows:
    - [basic,   ["a=1&b=2"],  {"a": "1", "b": "2"}]
    - [single,  ["foo=bar"],  {"foo": "bar"}]

table query_string.stringify:
  kind: node_module_call_eq
  function: stringify
  category: stringify
  id_prefix: qs_str

  columns: [id, args, expected]
  rows:
    - [basic,   [{"a": "1", "b": "2"}],        "a=1&b=2"]
    - [array,   [{"a": ["1", "2"]}],            "a=1&a=2"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:08:41Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
