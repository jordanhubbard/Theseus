spec: spacy_rust
version: ">=3.9"
backend: rust_module(spacy_rust)

docs: https://spacy.io/api/

provenance:
  derived_from:
    - "https://spacy.io/api/ — spaCy API documentation"
  not_derived_from:
    - "spacy source: spacy/tokens/doc.pyx"
  notes:
    - "spaCy is an NLP library with pre-trained models."
    - "nlp = spacy.blank('en'); doc = nlp('Hello world'); len(doc) == 2."
    - "doc[0].text == 'Hello' for blank English model."
    - "nlp('one two three').__len__() == 3."
    - "doc.text == 'Hello world' — original text preserved."
    - "Expose spacy_token_count(text) -> int: len(nlp(text)) using blank en model."
    - "Expose spacy_token_text(text, i) -> str: nlp(text)[i].text."
    - "Expose spacy_doc_text(text) -> str: nlp(text).text."
    - "All test vectors verified against spacy 3.8.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# spacy_token_count — token count using blank English model
table spacy_rust.tokenize.token_count:
  kind: python_call_eq
  category: token_count
  id_prefix: spacy_tc
  function: spacy_token_count

  columns: [id, args, expected]
  rows:
    - [two,   ["Hello world"],   2]
    - [three, ["one two three"], 3]
    - [one,   ["hello"],         1]

# spacy_token_text — individual token text
table spacy_rust.tokenize.token_text:
  kind: python_call_eq
  category: token_text
  id_prefix: spacy_tt
  function: spacy_token_text

  columns: [id, args, expected]
  rows:
    - [first,  ["Hello world", 0], "Hello"]
    - [second, ["Hello world", 1], "world"]

# spacy_doc_text — document text preserved
invariant spacy_rust.doc.text_preserved:
  description: "doc.text == original text"
  category: doc_text
  kind: python_call_eq
  function: spacy_doc_text
  args: ["Hello world"]
  expected: "Hello world"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:10:54Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
