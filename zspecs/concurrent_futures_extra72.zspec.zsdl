spec: concurrent_futures_extra72
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra71.zspec.zsdl."
    - "This spec covers: wave 241 theme — concurrent.futures Future.__dict__ content + ThreadPoolExecutor __dict__. NEW in extra72: Future.__dict__.__class__.__name__=='mappingproxy'; Future.__dict__.__contains__('result')==True; Future.__dict__.__contains__('cancel')==True; Future.__dict__.__contains__('done')==True; Future.__dict__.__contains__('exception')==True; Future.__dict__.__contains__('add_done_callback')==True; ThreadPoolExecutor.__dict__.__class__.__name__=='mappingproxy'; ThreadPoolExecutor.__dict__.__contains__('submit')==True; ThreadPoolExecutor.__dict__.__contains__('shutdown')==True; Executor.__dict__.__class__.__name__=='mappingproxy'; Executor.__dict__.__contains__('map')==True."
    - "concurrent.futures.Future.__dict__.__class__.__name__ == 'mappingproxy'. The __dict__ of any Python class is a read-only mappingproxy; Future.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('result') == True. Future defines result directly in its own __dict__ in concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('cancel') == True. Future defines cancel directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('done') == True. Future defines done directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('exception') == True. Future defines exception directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('add_done_callback') == True. Future defines add_done_callback directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__ == 'mappingproxy'. ThreadPoolExecutor.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') == True. ThreadPoolExecutor defines submit in its own __dict__ in concurrent/futures/thread.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown') == True. ThreadPoolExecutor defines shutdown in its own __dict__ overriding Executor.shutdown. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__class__.__name__ == 'mappingproxy'. Executor.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('map') == True. Executor defines map directly in its own __dict__ in concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

