    - [future_dict_class_name, Future.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Future.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [future_dict_has_result, Future.__dict__.__contains__,              ["result"],       true, "Future.__dict__.__contains__('result') == True — Future defines result in concurrent/futures/_base.py; verified with Python 3.14.3"]
