invariant concurrent_futures_extra72.Future_dict_class_name:
  description: "concurrent.futures.Future.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — class __dict__ objects are always mappingproxy in CPython; NEW in extra72: first standalone __dict__.__class__.__name__ invariant for Future in cfmore72 namespace; wave 241; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Future.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant concurrent_futures_extra72.Future_dict_has_add_done_callback:
  description: "concurrent.futures.Future.__dict__.__contains__('add_done_callback') returns True — Future defines add_done_callback in concurrent/futures/_base.py; NEW in extra72: first standalone __contains__('add_done_callback') invariant for Future in cfmore72 namespace; wave 241; verified with Python 3.14.3"
