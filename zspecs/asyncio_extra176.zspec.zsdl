spec: asyncio_extra176
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-runner.html — asyncio runner documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec covers: asyncio runner and event loop functions — asyncio.run.__name__=='run' (len=3); asyncio.run.__module__=='asyncio' (len=7); asyncio.get_event_loop.__name__=='get_event_loop' (len=14: 'get'=3+'_event_loop'=11=14); asyncio.get_running_loop.__name__=='get_running_loop' (len=15: 'get'=3+'_running_loop'=12=15; 1 longer than get_event_loop); asyncio.new_event_loop.__name__=='new_event_loop' (len=14: 'new'=3+'_event_loop'=11=14; same length as get_event_loop); asyncio.sleep.__name__=='sleep' (len=5); asyncio.gather.__name__=='gather' (len=6); asyncio.wait.__name__=='wait' (len=4). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.run.__name__.__len__() == 3. 'run' is 3 characters: r-u-n. asyncio.run() is the main entry point for running asyncio programs; it runs the passed coroutine and always creates a new event loop. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.get_event_loop.__name__.__len__() == 14. 'get_event_loop' is 14 characters: 'get'=3+'_event_loop'=11=14. Returns the running event loop or creates a new one (deprecated usage without running loop). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.get_running_loop.__name__.__len__() == 15. 'get_running_loop' is 15 characters: 'get'=3+'_running_loop'=12=15; 1 longer than 'get_event_loop'=14. Raises RuntimeError if no event loop is running. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.new_event_loop.__name__.__len__() == 14. 'new_event_loop' is 14 characters: 'new'=3+'_event_loop'=11=14; same length as 'get_event_loop'=14 despite different prefix. Creates and returns a new event loop without setting it as the current loop. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.sleep.__name__=='sleep' (len=5); asyncio.gather.__name__=='gather' (len=6); asyncio.wait.__name__=='wait' (len=4). All three are coroutine functions in Lib/asyncio/tasks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.run and asyncio.get_event_loop function names
#
# asyncio.run.__name__ == 'run' (len=3)
# asyncio.run.__module__ == 'asyncio' (len=7)
# asyncio.get_event_loop.__name__ == 'get_event_loop' (len=14)
#
# asyncio.run() is the top-level entry point for running asyncio programs;
# it was added in Python 3.7. asyncio.get_event_loop() returns the running
# event loop in a coroutine or creates/returns a loop in a sync context.
# New to extra176.
# ---------------------------------------------------------------------------

table asyncio_extra176.run_and_get_event_loop_names:
  description: "asyncio.run.__name__ 'run' len 3; asyncio.run.__module__ 'asyncio' len 7; asyncio.get_event_loop.__name__ 'get_event_loop' len 14; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofns176

  columns: [id, function, args, expected, description]
  rows:
    - [run_name_eq,
       asyncio.run.__name__.__eq__,
       ["run"],
       true,
       "asyncio.run.__name__.__eq__('run') == True — asyncio.run is the top-level entry point for running asyncio programs, defined in Lib/asyncio/runners.py; its __name__ is 'run' (3 characters: r-u-n); str.__eq__('run') returns True; new to extra176"]
    - [run_name_len_3,
       asyncio.run.__name__.__len__,
       [],
       3,
       "asyncio.run.__name__.__len__() == 3 — the name 'run' has exactly 3 characters: r-u-n; shortest function name in this spec; str.__len__() returns 3; new to extra176"]
    - [run_module_asyncio,
       asyncio.run.__module__.__eq__,
       ["asyncio"],
       true,
       "asyncio.run.__module__.__eq__('asyncio') == True — asyncio.run is exposed at the top-level asyncio namespace; its __module__ is 'asyncio' (7 characters); str.__eq__('asyncio') returns True; new to extra176"]
    - [run_module_len_7,
       asyncio.run.__module__.__len__,
       [],
       7,
       "asyncio.run.__module__.__len__() == 7 — the module name 'asyncio' has exactly 7 characters: a-s-y-n-c-i-o; str.__len__() returns 7; new to extra176"]
    - [get_event_loop_name_eq,
       asyncio.get_event_loop.__name__.__eq__,
       ["get_event_loop"],
       true,
       "asyncio.get_event_loop.__name__.__eq__('get_event_loop') == True — asyncio.get_event_loop is a function in Lib/asyncio/events.py; its __name__ is 'get_event_loop' (14 chars: 'get'=3+'_event_loop'=11=14); str.__eq__('get_event_loop') returns True; new to extra176"]
    - [get_event_loop_name_len_14,
       asyncio.get_event_loop.__name__.__len__,
       [],
       14,
       "asyncio.get_event_loop.__name__.__len__() == 14 — the name 'get_event_loop' has 14 characters: 'get'=3+'_event_loop'=11=14; str.__len__() returns 14; new to extra176"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.get_running_loop and asyncio.new_event_loop names
#
# asyncio.get_running_loop.__name__ == 'get_running_loop' (len=15)
# asyncio.new_event_loop.__name__ == 'new_event_loop' (len=14; same as get_event_loop)
#
# get_running_loop was added in Python 3.7 as the preferred alternative to
# get_event_loop inside coroutines: it raises RuntimeError if no loop is
# running. new_event_loop creates a fresh event loop without setting it as
# current. NAME LENGTHS: 'get_running_loop'=15 is 1 longer than
# 'get_event_loop'=14 and 'new_event_loop'=14. New to extra176.
# ---------------------------------------------------------------------------

table asyncio_extra176.get_running_loop_and_new_event_loop_names:
  description: "asyncio.get_running_loop.__name__ 'get_running_loop' len 15; asyncio.new_event_loop.__name__ 'new_event_loop' len 14 (same as get_event_loop); new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofns176

  columns: [id, function, args, expected, description]
  rows:
    - [get_running_loop_name_eq,
       asyncio.get_running_loop.__name__.__eq__,
       ["get_running_loop"],
       true,
       "asyncio.get_running_loop.__name__.__eq__('get_running_loop') == True — asyncio.get_running_loop is a function in Lib/asyncio/events.py that returns the running event loop or raises RuntimeError if no loop is running; its __name__ is 'get_running_loop' (15 chars); str.__eq__('get_running_loop') returns True; new to extra176"]
    - [get_running_loop_name_len_15,
       asyncio.get_running_loop.__name__.__len__,
       [],
       15,
       "asyncio.get_running_loop.__name__.__len__() == 15 — the name 'get_running_loop' has 15 characters: 'get'=3+'_running_loop'=12=15; 1 longer than 'get_event_loop'=14; str.__len__() returns 15; new to extra176"]
    - [new_event_loop_name_eq,
       asyncio.new_event_loop.__name__.__eq__,
       ["new_event_loop"],
       true,
       "asyncio.new_event_loop.__name__.__eq__('new_event_loop') == True — asyncio.new_event_loop creates and returns a new event loop object without setting it as current; its __name__ is 'new_event_loop' (14 chars: 'new'=3+'_event_loop'=11=14); str.__eq__('new_event_loop') returns True; new to extra176"]
    - [new_event_loop_name_len_14,
       asyncio.new_event_loop.__name__.__len__,
       [],
       14,
       "asyncio.new_event_loop.__name__.__len__() == 14 — the name 'new_event_loop' has 14 characters: 'new'=3+'_event_loop'=11=14; same length as 'get_event_loop'=14 despite different prefix; str.__len__() returns 14; new to extra176"]
    - [get_running_loop_longer_than_new,
       asyncio.get_running_loop.__name__.__len__,
       [],
       15,
       "asyncio.get_running_loop.__name__.__len__() == 15 confirming it is 1 longer than new_event_loop (14) and get_event_loop (14); 'running_loop'=12 > 'event_loop'=10 by 2, but 'get' prefix is same length as 'new'=3, yielding a net difference of 2-1=1 extra char for get_running_loop; new to extra176"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.sleep, asyncio.gather, asyncio.wait names
#
# asyncio.sleep.__name__ == 'sleep' (len=5)
# asyncio.gather.__name__ == 'gather' (len=6)
# asyncio.wait.__name__ == 'wait' (len=4)
#
# All three are coroutine functions in Lib/asyncio/tasks.py.
# sleep() suspends the coroutine for a given delay.
# gather() runs multiple awaitables concurrently.
# wait() waits for futures/tasks with completion conditions.
# NAME LENGTHS: 'wait'=4 < 'sleep'=5 < 'gather'=6. New to extra176.
# ---------------------------------------------------------------------------

table asyncio_extra176.sleep_gather_wait_names:
  description: "asyncio.sleep.__name__ 'sleep' len 5; asyncio.gather.__name__ 'gather' len 6; asyncio.wait.__name__ 'wait' len 4; all coroutine functions; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofns176

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_name_eq,
       asyncio.sleep.__name__.__eq__,
       ["sleep"],
       true,
       "asyncio.sleep.__name__.__eq__('sleep') == True — asyncio.sleep is a coroutine function in Lib/asyncio/tasks.py that suspends the current task for the given number of seconds; its __name__ is 'sleep' (5 chars: s-l-e-e-p); str.__eq__('sleep') returns True; new to extra176"]
    - [sleep_name_len_5,
       asyncio.sleep.__name__.__len__,
       [],
       5,
       "asyncio.sleep.__name__.__len__() == 5 — the name 'sleep' has exactly 5 characters: s-l-e-e-p; str.__len__() returns 5; new to extra176"]
    - [gather_name_eq,
       asyncio.gather.__name__.__eq__,
       ["gather"],
       true,
       "asyncio.gather.__name__.__eq__('gather') == True — asyncio.gather is a coroutine function in Lib/asyncio/tasks.py that runs multiple awaitables concurrently; its __name__ is 'gather' (6 chars: g-a-t-h-e-r); str.__eq__('gather') returns True; new to extra176"]
    - [gather_name_len_6,
       asyncio.gather.__name__.__len__,
       [],
       6,
       "asyncio.gather.__name__.__len__() == 6 — the name 'gather' has exactly 6 characters: g-a-t-h-e-r; longest of the three names in this table; str.__len__() returns 6; new to extra176"]
    - [wait_name_eq,
       asyncio.wait.__name__.__eq__,
       ["wait"],
       true,
       "asyncio.wait.__name__.__eq__('wait') == True — asyncio.wait is a coroutine function in Lib/asyncio/tasks.py that waits for futures to complete with configurable conditions (FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED); its __name__ is 'wait' (4 chars: w-a-i-t); str.__eq__('wait') returns True; new to extra176"]
    - [wait_name_len_4,
       asyncio.wait.__name__.__len__,
       [],
       4,
       "asyncio.wait.__name__.__len__() == 4 — the name 'wait' has exactly 4 characters: w-a-i-t; shortest of the three names in this table; str.__len__() returns 4; NAME LENGTHS: 'wait'=4 < 'sleep'=5 < 'gather'=6; new to extra176"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra176
# ---------------------------------------------------------------------------

invariant asyncio_extra176.run_name_run:
  description: "asyncio.run.__name__ == 'run' — top-level entry point for running asyncio programs; __name__ is 'run' (3 chars); new to extra176"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__name__.__eq__
  args: ["run"]
  expected: true

invariant asyncio_extra176.run_module_asyncio:
  description: "asyncio.run.__module__ == 'asyncio' — asyncio.run is exposed at the top-level asyncio namespace; __module__ is 'asyncio' (7 chars); new to extra176"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__module__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra176.get_event_loop_name_len_14:
  description: "asyncio.get_event_loop.__name__.__len__() == 14 — 'get_event_loop' is 14 characters ('get'=3+'_event_loop'=11=14); new to extra176"
  category: identity
  kind: python_call_eq
  function: asyncio.get_event_loop.__name__.__len__
  args: []
  expected: 14

invariant asyncio_extra176.get_running_loop_name_len_15:
  description: "asyncio.get_running_loop.__name__.__len__() == 15 — 'get_running_loop' is 15 characters ('get'=3+'_running_loop'=12=15); 1 longer than get_event_loop=14; new to extra176"
  category: identity
  kind: python_call_eq
  function: asyncio.get_running_loop.__name__.__len__
  args: []
  expected: 15

invariant asyncio_extra176.new_event_loop_name_len_14:
  description: "asyncio.new_event_loop.__name__.__len__() == 14 — 'new_event_loop' is 14 characters ('new'=3+'_event_loop'=11=14); same length as get_event_loop=14; new to extra176"
  category: identity
  kind: python_call_eq
  function: asyncio.new_event_loop.__name__.__len__
  args: []
  expected: 14

invariant asyncio_extra176.sleep_name_sleep:
  description: "asyncio.sleep.__name__ == 'sleep' — coroutine function in Lib/asyncio/tasks.py; __name__ is 'sleep' (5 chars); new to extra176"
  category: identity
  kind: python_call_eq
  function: asyncio.sleep.__name__.__eq__
  args: ["sleep"]
  expected: true

invariant asyncio_extra176.gather_name_gather:
  description: "asyncio.gather.__name__ == 'gather' — coroutine function in Lib/asyncio/tasks.py; __name__ is 'gather' (6 chars); longest of sleep/gather/wait; new to extra176"
  category: identity
  kind: python_call_eq
  function: asyncio.gather.__name__.__eq__
  args: ["gather"]
  expected: true

invariant asyncio_extra176.wait_name_wait:
  description: "asyncio.wait.__name__ == 'wait' — coroutine function in Lib/asyncio/tasks.py; __name__ is 'wait' (4 chars); shortest of sleep/gather/wait; new to extra176"
  category: identity
  kind: python_call_eq
  function: asyncio.wait.__name__.__eq__
  args: ["wait"]
  expected: true
