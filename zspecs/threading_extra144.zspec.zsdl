spec: threading_extra144
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.RLock (Python factory function), threading.Lock (C type alias for _thread.lock), threading.Condition (Python class) — doc len, method qualnames and co_argcount; threading.Semaphore (Python class) — doc len, method qualnames; threading.Event (Python class) — doc len, method qualnames (Wave 271)."
    - "threading.RLock is a Python factory function: __qualname__ == 'RLock' (len 5); __module__ == 'threading'; __doc__ len == 286; co_argcount == 0. Verified with Python 3.14.3."
    - "threading.Lock is a C type (_thread.lock): __name__ == 'lock'; __module__ == '_thread'; __doc__ len == 469; MRO len == 2. Verified with Python 3.14.3."
    - "threading.Condition: __name__ == 'Condition'; __module__ == 'threading'; __doc__ len == 338; MRO len == 2; __init__ qualname len 18, co_argcount 2; wait co_argcount 2; notify co_argcount 2; notify_all qualname len 20. Verified with Python 3.14.3."
    - "threading.Semaphore: __name__ == 'Semaphore'; __module__ == 'threading'; __doc__ len == 307; MRO len == 2; __init__ qualname len 18, co_argcount 2; acquire co_argcount 3; release co_argcount 2. Verified with Python 3.14.3."
    - "threading.Event: __name__ == 'Event'; __module__ == 'threading'; __doc__ len == 226; MRO len == 2; __init__ qualname len 14, co_argcount 1; set qualname len 9; wait co_argcount 2; is_set qualname len 12. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.RLock and threading.Lock — identity and doc lengths
#
# Wave 271 theme: threading.RLock (factory function) and threading.Lock (C type).
#
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__qualname__ == 'RLock' (len 5)
# threading.RLock.__module__ == 'threading' (len 9)
# len(threading.RLock.__doc__) == 286
# threading.RLock.__code__.co_argcount == 0
# threading.Lock.__class__.__name__ == 'type'
# threading.Lock.__name__ == 'lock' (len 4)
# threading.Lock.__module__ == '_thread' (len 7)
# len(threading.Lock.__doc__) == 469
# len(threading.Lock.__mro__) == 2
#
# RLock is a factory function returning a reentrant lock; Lock is an alias
# for the C type _thread.lock. New to extra144.
# ---------------------------------------------------------------------------

table threading_extra144.rlock_lock_attrs:
  description: "threading.RLock (Python factory fn, qualname len 5, doc len 286, co_argcount 0) and Lock (C type _thread.lock, name len 4, doc len 469, MRO len 2); wave 271; new to extra144"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingrlocklock144

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_class_eq_function,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — RLock is a Python factory function defined in Lib/threading.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra144"]
    - [rlock_qualname_eq,
       "RLock.__qualname__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__qualname__.__eq__('RLock') == True — the factory function's __qualname__ is 'RLock'; str.__eq__('RLock') returns True; new to extra144"]
    - [rlock_qualname_len_eq_5,
       "RLock.__qualname__.__len__",
       [],
       5,
       "threading.RLock.__qualname__.__len__() == 5 — __qualname__ is 'RLock' which has 5 characters; len('RLock') == 5; new to extra144"]
    - [rlock_module_eq_threading,
       "RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra144"]
    - [rlock_doc_len_eq_286,
       "RLock.__doc__.__len__",
       [],
       286,
       "threading.RLock.__doc__.__len__() == 286 — the RLock docstring has 286 characters; len(__doc__) == 286; verified with Python 3.14.3; new to extra144"]
    - [rlock_co_argcount_eq_0,
       "RLock.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.RLock.__code__.co_argcount.__eq__(0) == True — RLock factory function takes no positional-or-keyword arguments; co_argcount is 0; int.__eq__(0) returns True; new to extra144"]
    - [lock_class_eq_type,
       "Lock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — Lock is a C type (_thread.lock); its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra144"]
    - [lock_name_eq_lock,
       "Lock.__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — Lock is an alias for _thread.lock; the C type's __name__ is 'lock'; str.__eq__('lock') returns True; new to extra144"]
    - [lock_name_len_eq_4,
       "Lock.__name__.__len__",
       [],
       4,
       "threading.Lock.__name__.__len__() == 4 — __name__ is 'lock' which has 4 characters; len('lock') == 4; new to extra144"]
    - [lock_module_eq__thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — Lock is the C type _thread.lock from _threadmodule.c; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra144"]
    - [lock_doc_len_eq_469,
       "Lock.__doc__.__len__",
       [],
       469,
       "threading.Lock.__doc__.__len__() == 469 — the Lock/_thread.lock docstring has 469 characters; len(__doc__) == 469; verified with Python 3.14.3; new to extra144"]
    - [lock_mro_len_eq_2,
       "Lock.__mro__.__len__",
       [],
       2,
       "threading.Lock.__mro__.__len__() == 2 — Lock's MRO is [lock, object]; len(__mro__) is 2; new to extra144"]

# ---------------------------------------------------------------------------
