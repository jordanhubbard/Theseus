# Standalone invariants — extra144
# ---------------------------------------------------------------------------

invariant threading_extra144.rlock_doc_len:
  description: "len(threading.RLock.__doc__) == 286 — the RLock factory function docstring has 286 characters; wave 271; new to extra144"
  kind: python_call_eq
  function: RLock.__doc__.__len__
  args: []
  expected: 286

invariant threading_extra144.rlock_co_argcount:
  description: "threading.RLock.__code__.co_argcount == 0 — factory function takes no arguments; wave 271; new to extra144"
  kind: python_call_eq
  function: RLock.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant threading_extra144.lock_doc_len:
  description: "len(threading.Lock.__doc__) == 469 — the _thread.lock docstring has 469 characters; wave 271; new to extra144"
