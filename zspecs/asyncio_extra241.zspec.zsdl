spec: asyncio_extra241
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-eventloop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec covers asyncio.AbstractEventLoop class identity and key method names."
    - "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop' — 17 characters."
    - "asyncio.AbstractEventLoop.__module__ == 'asyncio.events' — defined in the events submodule (14 chars)."
    - "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object' — AbstractEventLoop directly inherits from object."
    - "asyncio.AbstractEventLoop.__qualname__ == 'AbstractEventLoop' — simple top-level class name."
    - "AbstractEventLoop.run_until_complete.__name__ == 'run_until_complete'; __qualname__ == 'AbstractEventLoop.run_until_complete' (36 chars)."
    - "AbstractEventLoop.run_forever.__name__ == 'run_forever'; __qualname__ == 'AbstractEventLoop.run_forever' (29 chars)."
    - "AbstractEventLoop.stop.__name__ == 'stop'; __qualname__ == 'AbstractEventLoop.stop' (22 chars)."
    - "AbstractEventLoop.close.__name__ == 'close'; __qualname__ == 'AbstractEventLoop.close' (23 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.AbstractEventLoop class identity contracts
#
# Verifies __name__, __module__, __qualname__ to confirm the class is defined
# in asyncio.events and carries the expected identity attributes.
# ---------------------------------------------------------------------------

table asyncio_extra241.ael_class_identity:
  description: "asyncio.AbstractEventLoop class identity: name, module, qualname; new to extra241"
  kind: python_call_eq
  category: class_identity
  id_prefix: aioael241

  columns: [id, function, args, expected, description]
  rows:
    - [ael_name_eq,
       AbstractEventLoop.__name__.__eq__,
       ["AbstractEventLoop"],
       true,
       "asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop') == True — class carries unqualified name; new to extra241"]
    - [ael_module_eq,
       AbstractEventLoop.__module__.__eq__,
       ["asyncio.events"],
       true,
       "asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events') == True — AbstractEventLoop defined in asyncio.events submodule; new to extra241"]
    - [ael_qualname_eq,
       AbstractEventLoop.__qualname__.__eq__,
       ["AbstractEventLoop"],
       true,
       "asyncio.AbstractEventLoop.__qualname__.__eq__('AbstractEventLoop') == True — top-level class; qualname equals __name__; new to extra241"]
    - [ael_name_len_17,
       AbstractEventLoop.__name__.__len__,
       [],
       17,
       "asyncio.AbstractEventLoop.__name__.__len__() == 17 — 'AbstractEventLoop' has exactly 17 characters; new to extra241"]
    - [ael_module_len_14,
       AbstractEventLoop.__module__.__len__,
       [],
       14,
       "asyncio.AbstractEventLoop.__module__.__len__() == 14 — 'asyncio.events' has 14 characters; new to extra241"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.AbstractEventLoop base class contract
#
# AbstractEventLoop.__bases__[0].__name__ == 'object' — inherits from object.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table asyncio_extra241.ael_base_class:
  description: "asyncio.AbstractEventLoop base class identity; new to extra241"
  kind: python_call_eq
  category: class_identity
  id_prefix: aioael241b

  columns: [id, function, args, expected, description]
  rows:
    - [ael_base_name_eq,
       "AbstractEventLoop.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__('object') == True — AbstractEventLoop directly subclasses object; new to extra241"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.AbstractEventLoop method __name__ contracts
#
# run_until_complete, run_forever, stop, close each carry their simple __name__.
# ---------------------------------------------------------------------------

table asyncio_extra241.ael_method_names:
  description: "asyncio.AbstractEventLoop method __name__ contracts; new to extra241"
  kind: python_call_eq
  category: method_names
  id_prefix: aioaelm241

  columns: [id, function, args, expected, description]
  rows:
    - [ruc_name_eq,
       AbstractEventLoop.run_until_complete.__name__.__eq__,
       ["run_until_complete"],
       true,
       "asyncio.AbstractEventLoop.run_until_complete.__name__.__eq__('run_until_complete') == True — method carries its simple name; new to extra241"]
    - [rf_name_eq,
       AbstractEventLoop.run_forever.__name__.__eq__,
       ["run_forever"],
       true,
       "asyncio.AbstractEventLoop.run_forever.__name__.__eq__('run_forever') == True — method carries its simple name; new to extra241"]
    - [stop_name_eq,
       AbstractEventLoop.stop.__name__.__eq__,
       ["stop"],
       true,
       "asyncio.AbstractEventLoop.stop.__name__.__eq__('stop') == True — method carries its simple name; new to extra241"]
    - [close_name_eq,
       AbstractEventLoop.close.__name__.__eq__,
       ["close"],
       true,
       "asyncio.AbstractEventLoop.close.__name__.__eq__('close') == True — method carries its simple name; new to extra241"]

# ---------------------------------------------------------------------------
# Table 4: asyncio.AbstractEventLoop method __qualname__ contracts
#
# run_until_complete, run_forever, stop, close carry qualname
# 'AbstractEventLoop.<method>'.
# ---------------------------------------------------------------------------

table asyncio_extra241.ael_method_qualnames:
  description: "asyncio.AbstractEventLoop method __qualname__ contracts; new to extra241"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aioaelm241

  columns: [id, function, args, expected, description]
  rows:
    - [ruc_qualname_eq,
       AbstractEventLoop.run_until_complete.__qualname__.__eq__,
       ["AbstractEventLoop.run_until_complete"],
       true,
       "asyncio.AbstractEventLoop.run_until_complete.__qualname__ == 'AbstractEventLoop.run_until_complete' (36 chars); new to extra241"]
    - [rf_qualname_eq,
       AbstractEventLoop.run_forever.__qualname__.__eq__,
       ["AbstractEventLoop.run_forever"],
       true,
       "asyncio.AbstractEventLoop.run_forever.__qualname__ == 'AbstractEventLoop.run_forever' (29 chars); new to extra241"]
    - [stop_qualname_eq,
       AbstractEventLoop.stop.__qualname__.__eq__,
       ["AbstractEventLoop.stop"],
       true,
       "asyncio.AbstractEventLoop.stop.__qualname__ == 'AbstractEventLoop.stop' (22 chars); new to extra241"]
    - [close_qualname_eq,
       AbstractEventLoop.close.__qualname__.__eq__,
       ["AbstractEventLoop.close"],
       true,
       "asyncio.AbstractEventLoop.close.__qualname__ == 'AbstractEventLoop.close' (23 chars); new to extra241"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra241
# ---------------------------------------------------------------------------

invariant asyncio_extra241.AbstractEventLoop.name:
  description: "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop'; new to extra241"
  category: class_identity
  kind: python_call_eq
  function: AbstractEventLoop.__name__.__eq__
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra241.AbstractEventLoop.module:
  description: "asyncio.AbstractEventLoop.__module__ == 'asyncio.events'; new to extra241"
  category: class_identity
  kind: python_call_eq
  function: AbstractEventLoop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

