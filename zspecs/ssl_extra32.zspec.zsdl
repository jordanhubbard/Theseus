spec: ssl_extra32
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra31.zspec.zsdl — covers PROTOCOL_TLS_CLIENT value==16/__class__.__name__=='_SSLMethod'/__len__()==10; CERT_NONE/CERT_OPTIONAL/CERT_REQUIRED values/__class__.__name__=='VerifyMode'/__len__()==10; HAS_SNI/HAS_ALPN==True/__class__.__name__=='bool'; OP_NO_TLSv1/OP_NO_TLSv1_2 values/__class__.__name__=='Options'/__len__()==7; SSLContext/SSLError __dict__.__class__.__name__=='mappingproxy'/__len__()==12; SSLSocket.do_handshake/cipher __qualname__/__len__()."
    - "ssl_extra30.zspec.zsdl — covers SSLContext/__mro__.__len__()==3; SSLError/__mro__.__len__()==5; SSLSocket/__mro__.__len__()==4; SSLObject/__mro__.__len__()==2; SSLContext/__bases__[0].__name__=='_SSLContext'; SSLError/__bases__[0].__name__=='OSError'; SSLSocket/__bases__[0].__name__=='socket'; SSLContext.set_alpn_protocols/set_npn_protocols __qualname__/__len__(); SSLSocket.getpeercert __qualname__/__len__()."
    - "ssl_extra29.zspec.zsdl — covers SSLCertVerificationError __module__/__name__/__qualname__ __len__(); SSLContext.load_cert_chain/load_verify_locations/set_ciphers __qualname__/__name__ __len__(); SSLSocket.read/write __qualname__/__name__ __len__(); create_default_context.__qualname__.__len__()."
    - "ssl_extra28.zspec.zsdl — covers SSLContext/SSLError/SSLSocket/SSLObject __module__.__len__() and __name__.__len__(); create_default_context/__qualname__/__module__.__len__(); SSLContext.wrap_socket/__qualname__/__module__.__len__()."
  notes:
    - "This spec extends ssl_extra31.zspec.zsdl."
    - "Prior specs covered: SSLContext/SSLError/SSLSocket/SSLObject all __name__/__module__/__qualname__/__len__()/__mro__.__len__()/__bases__[0].__name__; SSLCertVerificationError/CertificateError; create_default_context; SSLContext.wrap_socket/load_cert_chain/load_verify_locations/set_ciphers/set_alpn_protocols/set_npn_protocols; SSLSocket.read/write/getpeercert/do_handshake/cipher; PROTOCOL_TLS_CLIENT/CERT_NONE/CERT_OPTIONAL/CERT_REQUIRED/HAS_SNI/HAS_ALPN/OP_NO_TLSv1/OP_NO_TLSv1_2; SSLContext/SSLError __dict__ as mappingproxy; ssl has no __all__."
    - "This spec covers: ssl.SSLSocket.__dict__.__class__.__name__=='mappingproxy'/__len__()==12; ssl.SSLCertVerificationError.__dict__.__class__.__name__=='mappingproxy'/__len__()==12; ssl.SSLObject.__dict__.__class__.__name__=='mappingproxy'/__len__()==12; ssl.SSLCertVerificationError.__mro__.__len__()==7; ssl.SSLSocket.__bases__[0].__name__=='socket'/__len__()==6; ssl.SSLCertVerificationError.__bases__[0].__name__=='SSLError'/__len__()==8; ssl.SSLObject.do_handshake/__qualname__.__len__()==22; ssl.SSLObject.read/__qualname__.__len__()==14; ssl.SSLObject.write/__qualname__.__len__()==15; ssl.SSLObject.getpeercert/__qualname__.__len__()==21; ssl.SSLObject.cipher/__qualname__.__len__()==16; ssl.SSLSocket.connect/__qualname__/__len__()==17; ssl.SSLSocket.send/__qualname__.__len__()==14; ssl.SSLSocket.unwrap/__qualname__.__len__()==16."
    - "ssl has no __all__ attribute — confirmed with hasattr(ssl, '__all__') == False. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.__dict__.__class__.__name__ == 'mappingproxy' — len 12. SSLCertVerificationError and SSLObject also mappingproxy. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLCertVerificationError.__mro__ has 7 entries: SSLCertVerificationError -> SSLError -> OSError -> ValueError -> Exception -> BaseException -> object. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.__bases__[0].__name__ == 'socket' — len 6 (inherits from socket.socket). SSLCertVerificationError.__bases__[0].__name__ == 'SSLError' — len 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLObject.do_handshake.__qualname__ == 'SSLObject.do_handshake' — len 22. read == 'SSLObject.read' — len 14. write == 'SSLObject.write' — len 15. getpeercert == 'SSLObject.getpeercert' — len 21. cipher == 'SSLObject.cipher' — len 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.connect.__qualname__ == 'SSLSocket.connect' — len 17. send == 'SSLSocket.send' — len 14. unwrap == 'SSLSocket.unwrap' — len 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ssl.SSLSocket, SSLCertVerificationError, SSLObject __dict__.__class__.__name__ and __len__()
#
# No prior spec checks __dict__.__class__.__name__ for SSLSocket, SSLCertVerificationError,
# or SSLObject. SSLContext and SSLError were covered in ssl_extra31.
# Class __dict__ is always a mappingproxy; __class__.__name__ == 'mappingproxy' (len 12).
# ---------------------------------------------------------------------------

invariant ssl_extra32.SSLSocket_dict_class_name:
  description: "ssl.SSLSocket.__dict__.__class__.__name__ == 'mappingproxy' — class namespace is a mappingproxy"
  category: class_structure
  kind: python_call_eq
  function: "SSLSocket.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant ssl_extra32.SSLSocket_dict_class_name_len:
  description: "len(ssl.SSLSocket.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"
  category: class_structure
  kind: python_call_eq
  function: "SSLSocket.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

table ssl_extra32.class_dict_proxy_names:
  description: "ssl.SSLCertVerificationError/SSLObject __dict__.__class__.__name__=='mappingproxy' and __len__()==12"
  kind: python_call_eq
  category: class_structure
  id_prefix: scdpn32

  columns: [id, function, args, expected, description]
  rows:
    - [SSLCertVerificationError_dict_class,
       "SSLCertVerificationError.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "ssl.SSLCertVerificationError.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [SSLCertVerificationError_dict_class_len,
       "SSLCertVerificationError.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]
    - [SSLObject_dict_class,
       "SSLObject.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "ssl.SSLObject.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [SSLObject_dict_class_len,
       "SSLObject.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]

# ---------------------------------------------------------------------------
# ssl.SSLCertVerificationError __mro__.__len__()
#
# No prior spec checks SSLCertVerificationError.__mro__.__len__().
# ssl_extra30 covered SSLContext(3)/SSLError(5)/SSLSocket(4)/SSLObject(2).
# SSLCertVerificationError.__mro__ has 7 entries:
#   SSLCertVerificationError -> SSLError -> OSError -> ValueError ->
#   Exception -> BaseException -> object
# ---------------------------------------------------------------------------

invariant ssl_extra32.SSLCertVerificationError_mro_len:
  description: "ssl.SSLCertVerificationError.__mro__.__len__() == 7 — SSLCertVerificationError -> SSLError -> OSError -> ValueError -> Exception -> BaseException -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLCertVerificationError.__mro__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# ssl.SSLSocket and SSLCertVerificationError __bases__[0].__name__ and __len__()
#
# No prior spec checks __bases__[0].__name__ for SSLSocket or SSLCertVerificationError.
# ssl_extra30 covered SSLContext.__bases__[0].__name__=='_SSLContext', SSLError.__bases__[0].__name__=='OSError',
# SSLSocket.__bases__[0].__name__=='socket' — BUT the name length is NEW.
# SSLCertVerificationError.__bases__[0].__name__ == 'SSLError' (len 8) — completely NEW.
# ---------------------------------------------------------------------------

invariant ssl_extra32.SSLSocket_base_name:
  description: "ssl.SSLSocket.__bases__[0].__name__ == 'socket' — SSLSocket inherits from socket.socket"
  category: class_hierarchy
  kind: python_call_eq
  function: "SSLSocket.__bases__[0].__name__.__eq__"
  args: ["socket"]
  expected: true

invariant ssl_extra32.SSLSocket_base_name_len:
  description: "len(ssl.SSLSocket.__bases__[0].__name__) == 6 — len('socket') == 6"
  category: class_hierarchy
  kind: python_call_eq
  function: "SSLSocket.__bases__[0].__name__.__len__"
  args: []
  expected: 6

table ssl_extra32.bases_names:
  description: "ssl.SSLCertVerificationError.__bases__[0].__name__=='SSLError'/__len__()==8"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: sbn32

  columns: [id, function, args, expected, description]
  rows:
    - [SSLCertVerificationError_base_name,
       "SSLCertVerificationError.__bases__[0].__name__.__eq__",
       ["SSLError"],
       true,
       "ssl.SSLCertVerificationError.__bases__[0].__name__ == 'SSLError'"]
    - [SSLCertVerificationError_base_name_len,
       "SSLCertVerificationError.__bases__[0].__name__.__len__",
       [],
       8,
       "len('SSLError') == 8"]

# ---------------------------------------------------------------------------
# ssl.SSLObject method __qualname__.__len__()
#
# No prior spec checks __qualname__ for any SSLObject method.
# ssl_extra31 covered SSLSocket.do_handshake/cipher.
# ssl_extra29 covered SSLSocket.read/write/getpeercert.
# SSLObject has its own parallel set of methods.
# SSLObject.do_handshake.__qualname__ == 'SSLObject.do_handshake' (len 22)
# SSLObject.read.__qualname__ == 'SSLObject.read' (len 14)
# SSLObject.write.__qualname__ == 'SSLObject.write' (len 15)
# SSLObject.getpeercert.__qualname__ == 'SSLObject.getpeercert' (len 21)
# SSLObject.cipher.__qualname__ == 'SSLObject.cipher' (len 16)
# ---------------------------------------------------------------------------

table ssl_extra32.SSLObject_method_qualname_lengths:
  description: "ssl.SSLObject method __qualname__.__len__() — do_handshake(22)/read(14)/write(15)/getpeercert(21)/cipher(16)"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: somql32

  columns: [id, function, args, expected, description]
  rows:
    - [do_handshake_qualname_len,
       SSLObject.do_handshake.__qualname__.__len__,
       [],
       22,
       "len('SSLObject.do_handshake') == 22"]
    - [read_qualname_len,
       SSLObject.read.__qualname__.__len__,
       [],
       14,
       "len('SSLObject.read') == 14"]
    - [write_qualname_len,
       SSLObject.write.__qualname__.__len__,
       [],
       15,
       "len('SSLObject.write') == 15"]
    - [getpeercert_qualname_len,
       SSLObject.getpeercert.__qualname__.__len__,
       [],
       21,
       "len('SSLObject.getpeercert') == 21"]
    - [cipher_qualname_len,
       SSLObject.cipher.__qualname__.__len__,
       [],
       16,
       "len('SSLObject.cipher') == 16"]

# ---------------------------------------------------------------------------
# ssl.SSLSocket.connect, send, unwrap __qualname__ and __len__()
#
# No prior spec checks __qualname__ for SSLSocket.connect, send, or unwrap.
# ssl_extra31 covered SSLSocket.do_handshake/cipher.
# ssl_extra29 covered SSLSocket.read/write/getpeercert.
# connect.__qualname__ == 'SSLSocket.connect' (len 17)
# send.__qualname__ == 'SSLSocket.send' (len 14)
# unwrap.__qualname__ == 'SSLSocket.unwrap' (len 16)
# ---------------------------------------------------------------------------

invariant ssl_extra32.SSLSocket_connect_qualname:
  description: "ssl.SSLSocket.connect.__qualname__ == 'SSLSocket.connect'"
  category: function_qualnames
  kind: python_call_eq
  function: SSLSocket.connect.__qualname__.__eq__
  args: ["SSLSocket.connect"]
  expected: true

invariant ssl_extra32.SSLSocket_connect_qualname_len:
  description: "len(ssl.SSLSocket.connect.__qualname__) == 17 — len('SSLSocket.connect') == 17"
  category: function_qualnames
  kind: python_call_eq
  function: SSLSocket.connect.__qualname__.__len__
  args: []
  expected: 17

table ssl_extra32.SSLSocket_method_qualname_lengths_new:
  description: "ssl.SSLSocket.send/__qualname__.__len__()==14; unwrap/__qualname__.__len__()==16"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: ssmqln32

  columns: [id, function, args, expected, description]
  rows:
    - [send_qualname_len,
       SSLSocket.send.__qualname__.__len__,
       [],
       14,
       "len('SSLSocket.send') == 14"]
    - [unwrap_qualname_len,
       SSLSocket.unwrap.__qualname__.__len__,
       [],
       16,
       "len('SSLSocket.unwrap') == 16"]
