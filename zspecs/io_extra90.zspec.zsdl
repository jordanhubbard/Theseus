spec: io_extra90
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra89."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ and key method membership; BytesIO/StringIO/FileIO __dict__.__class__.__name__ and membership; UnsupportedOperation identity, bases, MRO; DEFAULT_BUFFER_SIZE and SEEK_* constants class and value; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO; RawIOBase/BufferedIOBase/TextIOBase/IOBase class identity and hierarchy; io.open/__class__/__module__/__qualname__; io.open_code identity; io.DEFAULT_BUFFER_SIZE value; io.UnsupportedOperation hierarchy; BufferedReader/BufferedWriter/BufferedRandom __name__/__module__/bases/MRO/qualname; IOBase.__dict__.__contains__ for read/readline/readlines/writelines/close/flush/__enter__/__exit__/__iter__ (all False); IOBase/RawIOBase/BufferedIOBase/TextIOBase __dict__.__class__.__name__; IOBase/__qualname__; RawIOBase/__qualname__; IOBase/__name__; IOBase/__module__."
    - "This spec covers: io.TextIOWrapper.__dict__.__contains__ for 'read', 'readline', 'write', 'flush', 'close' (all True — TextIOWrapper implements these at the Python level); io.TextIOWrapper.__dict__.__contains__ for 'name', 'encoding' (True); 'mode' (False — not in TextIOWrapper.__dict__); io.TextIOWrapper.__dict__.__class__.__name__; io.TextIOWrapper.__name__; io.TextIOWrapper.__qualname__; io.StringIO/__dict__.__class__.__name__; io.BytesIO/__dict__.__class__.__name__; io.FileIO/__dict__.__class__.__name__."
    - "io.TextIOWrapper.__dict__.__contains__('read') == True — 'read' IS in TextIOWrapper.__dict__; TextIOWrapper overrides it."
    - "io.TextIOWrapper.__dict__.__contains__('readline') == True — overridden in TextIOWrapper."
    - "io.TextIOWrapper.__dict__.__contains__('write') == True — overridden in TextIOWrapper."
    - "io.TextIOWrapper.__dict__.__contains__('flush') == True — overridden in TextIOWrapper."
    - "io.TextIOWrapper.__dict__.__contains__('close') == True — overridden in TextIOWrapper."
    - "io.TextIOWrapper.__dict__.__contains__('name') == True — 'name' property is in TextIOWrapper.__dict__."
    - "io.TextIOWrapper.__dict__.__contains__('mode') == False — 'mode' is NOT in TextIOWrapper.__dict__."
    - "io.TextIOWrapper.__dict__.__contains__('encoding') == True — 'encoding' property is in TextIOWrapper.__dict__."
    - "io.TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy' — as expected for any type's __dict__."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' — the C type name."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — same as __name__ (top-level class)."
    - "io.StringIO.__dict__.__class__.__name__ == 'mappingproxy' — same as all types."
    - "io.BytesIO.__dict__.__class__.__name__ == 'mappingproxy' — same."
    - "io.FileIO.__dict__.__class__.__name__ == 'mappingproxy' — same."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__dict__.__contains__ for read/readline/write/flush
# TextIOWrapper overrides these methods at the Python level, so they appear
# in its __dict__. Contrast with IOBase where these are absent (C-level only).
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra90.TextIOWrapper_dict_read_write:
  description: "io.TextIOWrapper.__dict__.__contains__ for 'read', 'readline', 'write', 'flush' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioextra90

  columns: [id, function, args, expected]
  rows:
    - [tiow_read,     TextIOWrapper.__dict__.__contains__, ["read"],     true]
    - [tiow_readline, TextIOWrapper.__dict__.__contains__, ["readline"], true]
    - [tiow_write,    TextIOWrapper.__dict__.__contains__, ["write"],    true]
    - [tiow_flush,    TextIOWrapper.__dict__.__contains__, ["flush"],    true]

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__dict__.__contains__ for 'close', 'name', 'mode', 'encoding'
# 'close', 'name', 'encoding' are True; 'mode' is False (not in TextIOWrapper.__dict__).
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra90.TextIOWrapper_dict_props:
  description: "io.TextIOWrapper.__dict__.__contains__ for 'close', 'name', 'mode', 'encoding'"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioextra90

  columns: [id, function, args, expected]
  rows:
    - [tiow_close,    TextIOWrapper.__dict__.__contains__, ["close"],    true]
    - [tiow_name,     TextIOWrapper.__dict__.__contains__, ["name"],     true]
    - [tiow_mode,     TextIOWrapper.__dict__.__contains__, ["mode"],     false]
    - [tiow_encoding, TextIOWrapper.__dict__.__contains__, ["encoding"], true]

# ---------------------------------------------------------------------------
# io.TextIOWrapper __dict__.__class__.__name__ and class identity
# TextIOWrapper is a concrete class; __dict__ is a mappingproxy.
# __name__ and __qualname__ are both 'TextIOWrapper'.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra90.TextIOWrapper_identity:
  description: "io.TextIOWrapper __dict__.__class__.__name__, __name__, __qualname__"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra90

  columns: [id, function, args, expected]
  rows:
    - [tiow_dict_cls,  TextIOWrapper.__dict__.__class__.__name__.__eq__, ["mappingproxy"],  true]
    - [tiow_name,      TextIOWrapper.__name__.__eq__,                    ["TextIOWrapper"], true]
    - [tiow_qualname,  TextIOWrapper.__qualname__.__eq__,                ["TextIOWrapper"], true]

# ---------------------------------------------------------------------------
# io.StringIO, io.BytesIO, io.FileIO __dict__.__class__.__name__
# All concrete IO classes have a mappingproxy as their type's __dict__.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra90.concrete_io_dict_class_names:
  description: "io.StringIO/BytesIO/FileIO __dict__.__class__.__name__ == 'mappingproxy'"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioextra90

  columns: [id, function, args, expected]
  rows:
    - [sio_dict_cls,  StringIO.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [bio_dict_cls,  BytesIO.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [fio_dict_cls,  FileIO.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra90.TextIOWrapper_dict.contains_read:
  description: "io.TextIOWrapper.__dict__.__contains__('read') == True (TextIOWrapper overrides read at Python level)"
  category: dict_membership
  kind: python_call_eq
  function: TextIOWrapper.__dict__.__contains__
  args: ["read"]
  expected: true

invariant io_extra90.TextIOWrapper_dict.contains_write:
  description: "io.TextIOWrapper.__dict__.__contains__('write') == True (TextIOWrapper overrides write at Python level)"
  category: dict_membership
  kind: python_call_eq
  function: TextIOWrapper.__dict__.__contains__
  args: ["write"]
  expected: true

invariant io_extra90.TextIOWrapper_dict.mode_absent:
  description: "io.TextIOWrapper.__dict__.__contains__('mode') == False (mode is not in TextIOWrapper.__dict__)"
  category: dict_membership
  kind: python_call_eq
  function: TextIOWrapper.__dict__.__contains__
  args: ["mode"]
  expected: false

invariant io_extra90.TextIOWrapper.name:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper'"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra90.TextIOWrapper.qualname:
  description: "io.TextIOWrapper.__qualname__ == 'TextIOWrapper'"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true
