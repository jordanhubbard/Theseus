spec: importlib_extra5
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
    - "importlib_util.zspec.zsdl — covers importlib.util functions via python_module(importlib.util) backend"
    - "importlib_abc.zspec.zsdl — covers importlib.abc classes via python_module(importlib.abc) backend"
  notes:
    - "This spec extends importlib.zspec.zsdl, importlib_extra.zspec.zsdl, importlib_extra2.zspec.zsdl, importlib_extra3.zspec.zsdl, and importlib_extra4.zspec.zsdl."
    - "Focus: importlib.util.__name__, and __qualname__ for util.find_spec, util.module_from_spec, util.spec_from_file_location, abc.Loader, abc.Finder — via dotted attribute chains from the importlib module root."
    - "importlib.util is a submodule; accessing it as an attribute of importlib yields the util module object whose __name__ == 'importlib.util'."
    - "util.find_spec, util.module_from_spec, util.spec_from_file_location are pure-Python functions; each has __qualname__ equal to its unqualified function name."
    - "importlib.abc.Loader and importlib.abc.Finder are abstract base classes defined in importlib.abc; their __qualname__ equals their unqualified class name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib.util.__name__ — the util submodule name attribute
# Accessed as the dotted attribute util.__name__ from importlib module root.
# ---------------------------------------------------------------------------

invariant importlib_extra5.util.name:
  description: "importlib.util.__name__ == 'importlib.util'"
  category: submodules
  kind: python_call_eq
  function: util.__name__.__eq__
  args: ["importlib.util"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks — importlib.util functions
# Accessed via dotted chains from the importlib module root.
# ---------------------------------------------------------------------------

table importlib_extra5.util_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [find_spec,              util.find_spec.__qualname__.__eq__,              ["find_spec"],              true]
    - [module_from_spec,       util.module_from_spec.__qualname__.__eq__,       ["module_from_spec"],       true]
    - [spec_from_file_location, util.spec_from_file_location.__qualname__.__eq__, ["spec_from_file_location"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — importlib.abc classes
# Accessed via dotted chains from the importlib module root.
# ---------------------------------------------------------------------------

invariant importlib_extra5.abc_Loader.qualname:
  description: "importlib.abc.Loader.__qualname__ == 'Loader'"
  category: qualnames
  kind: python_call_eq
  function: abc.Loader.__qualname__.__eq__
  args: ["Loader"]
  expected: true

invariant importlib_extra5.abc_Finder.qualname:
  description: "importlib.abc.Finder.__qualname__ == 'Finder'"
  category: qualnames
  kind: python_call_eq
  function: abc.Finder.__qualname__.__eq__
  args: ["Finder"]
  expected: true
