spec: multiprocessing_extra240
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#managers — Managers section"
    - "https://docs.python.org/3/library/multiprocessing.shared_memory.html — shared_memory documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py (internal implementation)"
    - "CPython source: Lib/multiprocessing/shared_memory.py (internal implementation)"
  notes:
    - "multiprocessing.Semaphore, Lock, RLock, Event, Condition are context-bound methods (type.__name__ == 'method'), not classes."
    - "multiprocessing.managers.BaseManager.__name__ == 'BaseManager' (len=11); __module__ == 'multiprocessing.managers' (len=24); __bases__[0].__name__ == 'object' (len=6)."
    - "multiprocessing.managers.BaseProxy.__name__ == 'BaseProxy' (len=9); __module__ == 'multiprocessing.managers' (len=24); __bases__[0].__name__ == 'object' (len=6)."
    - "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' (len=11); __module__ == 'multiprocessing.managers' (len=24); __bases__[0].__name__ == 'BaseManager' (len=11)."
    - "multiprocessing.shared_memory.SharedMemory.__name__ == 'SharedMemory' (len=12); __module__ == 'multiprocessing.shared_memory' (len=29); __bases__[0].__name__ == 'object' (len=6)."
    - "multiprocessing.shared_memory.ShareableList.__name__ == 'ShareableList' (len=13); __module__ == 'multiprocessing.shared_memory' (len=29); __bases__[0].__name__ == 'object' (len=6)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

