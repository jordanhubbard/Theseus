invariant multiprocessing_extra240.syncmanager_base_is_base_manager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — SyncManager subclasses BaseManager (len=11), not object directly; this contrasts with BaseManager.__bases__[0].__name__=='object' and BaseProxy.__bases__[0].__name__=='object'; SyncManager.__name__ == 'SyncManager' (len=11); SyncManager.__module__ == 'multiprocessing.managers' (len=24); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra240.shared_memory_module_longest:
  description: "multiprocessing.shared_memory.SharedMemory.__module__.__len__() == 29 — 'multiprocessing.shared_memory' (len=29) is the longest module name in this spec, longer than 'multiprocessing.managers' (len=24); SharedMemory.__name__ == 'SharedMemory' (len=12); SharedMemory.__bases__[0].__name__ == 'object' (len=6); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: SharedMemory.__module__.__len__
  args: []
  expected: 29

invariant multiprocessing_extra240.base_manager_module_eq:
  description: "multiprocessing.managers.BaseManager.__module__.__eq__('multiprocessing.managers') returns True — BaseManager is defined in multiprocessing.managers (len=24); BaseManager.__name__ == 'BaseManager' (len=11); BaseManager.__bases__[0].__name__ == 'object' (len=6); SyncManager.__bases__[0].__name__ == 'BaseManager' (not 'object'), confirming the inheritance chain SyncManager -> BaseManager -> object; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BaseManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true
