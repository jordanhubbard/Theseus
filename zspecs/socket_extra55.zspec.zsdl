spec: socket_extra55
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra54.zspec.zsdl — covers herror/gaierror/timeout/gethostbyname/setdefaulttimeout __class__.__module__.__eq__('builtins'); herror/gaierror/timeout __init__.__class__.__name__/__module__.__eq__('wrapper_descriptor'/'builtins')."
    - "socket_extra53.zspec.zsdl — covers socket.socket/herror/gaierror/timeout __dict__/__class__/__qualname__.__eq__('mappingproxy'); socket module __dict__/__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "socket_extra52.zspec.zsdl — covers AF_INET6/AF_UNIX __class__.__qualname__/__module__.__eq__ and __class__.__qualname__.__len__()==13."
    - "socket_extra51.zspec.zsdl — covers AF_INET/SOCK_STREAM/SOCK_DGRAM __class__.__module__.__eq__('socket') and __len__()==6; SOCK_DGRAM __class__.__qualname__.__eq__('SocketKind') and __len__()==10."
    - "socket_extra48.zspec.zsdl — covers herror/gaierror/timeout __bases__[0].__qualname__.__eq__('OSError')."
    - "socket_extra47.zspec.zsdl — covers socket/herror/gaierror/timeout __class__.__qualname__.__eq__('type'); gethostname/gethostbyname __class__.__qualname__.__eq__; socket/gethostname/getaddrinfo __class__.__module__.__eq__('builtins')."
    - "socket_extra24.zspec.zsdl — covers AF_INET/__class__/__qualname__.__eq__('AddressFamily') and SOCK_STREAM/__class__/__qualname__.__eq__('SocketKind')."
    - "socket_extra2.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/__class__/__name__.__eq__('AddressFamily'); SOCK_STREAM/DGRAM/RAW/__class__/__name__.__eq__('SocketKind')."
  notes:
    - "This spec extends socket through socket_extra54; it does NOT duplicate invariants present in those files."
    - "Wave 222 theme: __repr__.__class__.__name__ checks + __weakref__ descriptor checks + __hash__ class name checks."
    - "Coverage gap 1: No prior socket spec checks __repr__.__class__.__name__ for socket.socket. socket.socket defines __repr__ as a Python function (Lib/socket.py); its __repr__.__class__.__name__ == 'function'. Prior specs check socket.socket's __class__.__qualname__, __class__.__module__, and __dict__.__class__, but none check socket.socket.__repr__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__repr__.__class__.__name__ == 'function'. socket.socket defines __repr__ as a Python function in Lib/socket.py; the built-in function type has __name__ == 'function'. No prior socket spec checks socket.socket.__repr__.__class__.__name__.__eq__('function'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior socket spec checks __repr__.__class__.__name__ for herror, gaierror, or timeout. socket_extra54 covers herror/gaierror/timeout __init__.__class__.__name__.__eq__('wrapper_descriptor') (__init__ slot), but NOT __repr__.__class__.__name__. herror/gaierror/timeout are exception classes ultimately inheriting from BaseException (a C type); their __repr__ is a wrapper_descriptor inherited from the C exception type chain via BaseException. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__repr__.__class__.__name__ == 'wrapper_descriptor'. herror is a Python subclass of OSError (which inherits from BaseException, a C type); its __repr__ resolves to a wrapper_descriptor via MRO from the C exception hierarchy. socket_extra54 covers herror.__init__.__class__.__name__ but NOT herror.__repr__.__class__.__name__. No prior socket spec checks herror.__repr__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__repr__.__class__.__name__ == 'wrapper_descriptor'. Same BaseException C slot wrapper inheritance as herror. No prior socket spec checks gaierror.__repr__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__repr__.__class__.__name__ == 'wrapper_descriptor'. Same BaseException C slot wrapper inheritance as herror/gaierror. No prior socket spec checks timeout.__repr__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior socket spec checks __class__.__qualname__.__eq__('SocketKind') for SOCK_RAW. socket_extra24 covers SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind'); socket_extra51 covers SOCK_DGRAM.__class__.__qualname__.__eq__('SocketKind'); socket_extra2 covers SOCK_RAW.__class__.__name__.__eq__('SocketKind') (__name__ axis). But no prior spec checks SOCK_RAW.__class__.__qualname__.__eq__('SocketKind') (__qualname__ axis). SOCK_RAW is a SocketKind enum member on most POSIX systems. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.__class__.__qualname__ == 'SocketKind'. SOCK_RAW is a SocketKind enum member; SocketKind.__qualname__ == 'SocketKind'. socket_extra2 covers SOCK_RAW.__class__.__name__.__eq__('SocketKind') (__name__ axis) but NOT __qualname__. socket_extra24/extra51 cover __qualname__ for SOCK_STREAM/SOCK_DGRAM but NOT SOCK_RAW. No prior socket spec checks SOCK_RAW.__class__.__qualname__.__eq__('SocketKind'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior socket spec checks __hash__.__class__.__name__ for socket.socket. socket.socket does not define __hash__ explicitly; it inherits __hash__ from object as a wrapper_descriptor. socket.socket TYPE __hash__.__class__.__name__ == 'wrapper_descriptor'. This is independent from the socket instance's hashability behavior. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket TYPE __hash__.__class__.__name__ == 'wrapper_descriptor'. socket.socket inherits __hash__ from object (C slot wrapper for tp_hash); the TYPE-level __hash__ attribute is a wrapper_descriptor. No prior socket spec checks socket.socket.__hash__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket __repr__.__class__.__name__.__eq__('function')
# socket.herror/gaierror/timeout __repr__.__class__.__name__.__eq__('wrapper_descriptor')
#
# socket.socket defines __repr__ as a Python function in Lib/socket.py;
# its __class__.__name__ is 'function'.
# herror/gaierror/timeout are exception subclasses inheriting from BaseException
# (a C type); their __repr__ is a wrapper_descriptor from the C exception chain.
# No prior socket spec checks __repr__.__class__.__name__ for any of these.
# ---------------------------------------------------------------------------

table socket_extra55.repr_class_name_eq:
  description: "socket.socket/__repr__/__class__/__name__.__eq__('function') and herror/gaierror/timeout/__repr__/__class__/__name__.__eq__('wrapper_descriptor') — socket.socket defines __repr__ as a Python function; exception classes inherit __repr__ as a C slot wrapper_descriptor from BaseException; no prior socket spec checks __repr__.__class__.__name__ for socket.socket, herror, gaierror, or timeout"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketr55

  columns: [id, function, args, expected]
  rows:
    - [socket_repr_class_name_eq,  socket.__repr__.__class__.__name__.__eq__,  ["function"],          true]
    - [herror_repr_class_name_eq,  herror.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [gaierror_repr_class_name_eq, gaierror.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [timeout_repr_class_name_eq,  timeout.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# socket.SOCK_RAW __class__.__qualname__.__eq__('SocketKind')
#
# socket_extra24 covers SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind').
# socket_extra51 covers SOCK_DGRAM.__class__.__qualname__.__eq__('SocketKind').
# socket_extra2 covers SOCK_RAW.__class__.__name__.__eq__('SocketKind') (__name__).
# But no prior socket spec checks __class__.__qualname__.__eq__ for SOCK_RAW.
# SOCK_RAW is a SocketKind enum member; SocketKind.__qualname__ == 'SocketKind'.
# The __qualname__ axis is distinct from __name__ and provides an independent
# regression vector.
# ---------------------------------------------------------------------------

invariant socket_extra55.SOCK_RAW.class_qualname_eq:
  description: "socket.SOCK_RAW.__class__.__qualname__ == 'SocketKind' — SOCK_RAW is a SocketKind enum member; socket_extra2 covers SOCK_RAW.__class__.__name__.__eq__('SocketKind') (__name__ axis) but NOT __qualname__; socket_extra24 covers SOCK_STREAM/__class__/__qualname__.__eq__ and socket_extra51 covers SOCK_DGRAM but NOT SOCK_RAW; no prior socket spec checks SOCK_RAW.__class__.__qualname__.__eq__('SocketKind')"
  category: type_structure
  kind: python_call_eq
  function: SOCK_RAW.__class__.__qualname__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket TYPE-level __hash__.__class__.__name__.__eq__('wrapper_descriptor')
#
# No prior socket spec checks __hash__.__class__.__name__ for socket.socket.
# socket.socket does not define __eq__ or __hash__; it inherits __hash__ from
# object as a wrapper_descriptor (C slot wrapper for tp_hash). The TYPE-level
# __hash__ attribute being a wrapper_descriptor is independent from whether
# socket instances are hashable at the instance level.
# ---------------------------------------------------------------------------

invariant socket_extra55.socket.hash_class_name_eq:
  description: "socket.socket TYPE __hash__.__class__.__name__ == 'wrapper_descriptor' — socket.socket inherits __hash__ from object (C slot wrapper); TYPE-level __hash__ is a wrapper_descriptor; no prior socket spec checks socket.socket.__hash__.__class__.__name__.__eq__('wrapper_descriptor')"
  category: type_structure
  kind: python_call_eq
  function: socket.__hash__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
