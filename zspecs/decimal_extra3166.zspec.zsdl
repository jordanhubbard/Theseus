spec: dc3166
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 658 (dc3166): __add__, __sub__, __mul__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "decimal.Decimal defines __add__, __sub__, and __mul__ in its own __dict__: it is a full numeric type implementing IEEE 754 arithmetic."
    - "decimal.Context does NOT define __add__, __sub__, or __mul__ in its own __dict__: Context is a configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __add__ dict-presence — operator.contains(Cls.__dict__, '__add__')
#
# decimal.Decimal defines __add__ in its own __dict__ (true): it is a numeric type.
# All other decimal classes are false: Context is a configuration object;
# exception subclasses do not define arithmetic.
# ---------------------------------------------------------------------------

table dc3166.add:
  description: "decimal types __add__ dict-presence checks; wave 658"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3166

  columns: [id, function, args, expected]
  rows:
    - ["dc3166001", operator.contains, [decimal.Decimal.__dict__,          "__add__"], true]
    - ["dc3166002", operator.contains, [decimal.Context.__dict__,           "__add__"], false]
    - ["dc3166003", operator.contains, [decimal.DecimalException.__dict__,  "__add__"], false]
    - ["dc3166004", operator.contains, [decimal.InvalidOperation.__dict__,  "__add__"], false]
    - ["dc3166005", operator.contains, [decimal.Overflow.__dict__,          "__add__"], false]
    - ["dc3166006", operator.contains, [decimal.Underflow.__dict__,         "__add__"], false]

