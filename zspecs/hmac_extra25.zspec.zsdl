spec: hmac_extra25
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra24.zspec.zsdl — covers HMAC method __qualname__.__eq__ and __len__ for update/digest/hexdigest/copy."
    - "hmac_extra23.zspec.zsdl — covers new/__qualname__.__len__()==3; digest/__qualname__.__len__()==6; compare_digest/__qualname__.__len__()==14; HMAC.__module__.__eq__."
    - "hmac_extra22.zspec.zsdl — covers HMAC.__mro__.__len__(); HMAC.__qualname__.__len__()==4; HMAC.__name__.__len__()==4."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__."
    - "hmac_extra14.zspec.zsdl — covers new/digest/compare_digest __qualname__.__eq__; HMAC.__qualname__.__eq__."
    - "hmac_extra11.zspec.zsdl — covers HMAC instance digest_size and block_size values for sha384/sha512/md5."
    - "hmac_extra2.zspec.zsdl — covers SHA256 digest_size/block_size values (__eq__)."
  notes:
    - "This spec extends hmac through hmac_extra24; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__.__len__() for HASH method qualnames re-anchored from extra25 namespace; HMAC.digest_size and HMAC.block_size __class__.__name__ at class level (member_descriptor) — not covered by any prior spec; instance-level digest_size/block_size __class__.__name__ == 'int' — new coverage."
    - "hmac.HMAC.digest_size.__class__.__name__ == 'member_descriptor': at class level, digest_size is a C-level member descriptor, not an int. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.block_size.__class__.__name__ == 'member_descriptor': at class level, block_size is similarly a member descriptor. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "HMAC instance method qualname __len__ re-anchored from extra25 namespace: extra24 covers __eq__ and __len__ in the same spec; these invariants provide independent regression coverage from a separate namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC class-level attribute types — digest_size and block_size
#
# At the class level, HMAC.digest_size and HMAC.block_size are C-level member
# descriptors (not ints). No prior hmac spec checks __class__.__name__ for
# these attributes at the class level.
# hmac_extra2 covers SHA256 HMAC instance digest_size/block_size values.
# hmac_extra11 covers sha384/sha512/md5 instance digest_size/block_size values.
# Neither covers the class-level descriptor type.
# ---------------------------------------------------------------------------

invariant hmac_extra25.HMAC.digest_size.class_type:
  description: "hmac.HMAC.digest_size.__class__.__name__ == 'member_descriptor' — C-level descriptor at class level"
  category: type_metadata
  kind: python_call_eq
  function: "HMAC.digest_size.__class__.__name__.__eq__"
  args: ["member_descriptor"]
  expected: true

invariant hmac_extra25.HMAC.block_size.class_type:
  description: "hmac.HMAC.block_size.__class__.__name__ == 'member_descriptor' — C-level descriptor at class level"
  category: type_metadata
  kind: python_call_eq
  function: "HMAC.block_size.__class__.__name__.__eq__"
  args: ["member_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# HMAC instance method __qualname__.__eq__ — re-anchored from extra25 namespace
#
# hmac_extra24 covers all four HMAC method qualnames via __eq__ and __len__.
# These invariants re-anchor the same __eq__ checks from the extra25 namespace
# for independent regression coverage.
# 'HMAC.update'=11, 'HMAC.digest'=11, 'HMAC.hexdigest'=14, 'HMAC.copy'=9.
# ---------------------------------------------------------------------------

table hmac_extra25.HMAC_method_qualnames:
  description: "HMAC instance method __qualname__ values — re-anchored from extra25 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hmacmq25

  columns: [id, function, args, expected]
  rows:
    - [update,    "HMAC.update.__qualname__.__eq__",    ["HMAC.update"],    true]
    - [digest,    "HMAC.digest.__qualname__.__eq__",    ["HMAC.digest"],    true]
    - [hexdigest, "HMAC.hexdigest.__qualname__.__eq__", ["HMAC.hexdigest"], true]
    - [copy,      "HMAC.copy.__qualname__.__eq__",      ["HMAC.copy"],      true]
