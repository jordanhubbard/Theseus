spec: inspect_extra255
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect error handling — TypeError from getfile, getsource, getsourcelines on built-in types; ValueError from signature on built-in types."
    - "inspect.getfile(int) raises TypeError: '<class int> is a built-in class'. Built-in types have no associated source file. Verified with Python 3.14.3."
    - "inspect.getsource(int) raises TypeError: '<class int> is a built-in class'. getsource delegates to getfile, which raises first. Verified with Python 3.14.3."
    - "inspect.getsourcelines(int) raises TypeError: '<class int> is a built-in class'. Same delegation as getsource. Verified with Python 3.14.3."
    - "inspect.signature(int) raises ValueError: 'no signature found for builtin type <class int>'. Verified with Python 3.14.3."
    - "inspect.getfile(len) raises TypeError: 'module, class, method, function, traceback, frame, or code object was expected, got builtin_function_or_method'. len is a builtin_function_or_method. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect function identity
#
# inspect.getfile.__name__ == 'getfile'
# inspect.getsource.__name__ == 'getsource'
# inspect.signature.__name__ == 'signature'
# inspect.getsourcelines.__name__ == 'getsourcelines'
# inspect.isclass.__name__ == 'isclass'
#
# These are pure Python functions defined in the inspect module. New to extra255.
# ---------------------------------------------------------------------------

table inspect_extra255.function_identity:
  description: "inspect.getfile, getsource, signature, getsourcelines, isclass __name__ identity contracts; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: inspfn255

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_name_eq,
       getfile.__name__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__name__.__eq__('getfile') == True — getfile is a pure Python function; __name__ is 'getfile'; new to extra255"]
    - [getsource_name_eq,
       getsource.__name__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__name__.__eq__('getsource') == True — getsource is a pure Python function; __name__ is 'getsource'; new to extra255"]
    - [signature_name_eq,
       signature.__name__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__name__.__eq__('signature') == True — signature is a pure Python function; __name__ is 'signature'; new to extra255"]
    - [getsourcelines_name_eq,
       getsourcelines.__name__.__eq__,
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__name__.__eq__('getsourcelines') == True — getsourcelines is a pure Python function; __name__ is 'getsourcelines'; new to extra255"]
    - [isclass_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — isclass is a pure Python function; __name__ is 'isclass'; new to extra255"]

# ---------------------------------------------------------------------------
# Table 2: inspect function module membership
#
# All core inspect functions have __module__ == 'inspect'. New to extra255.
# ---------------------------------------------------------------------------

table inspect_extra255.function_module:
  description: "inspect.getfile, getsource, signature, isclass, isbuiltin __module__ identity contracts; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: inspmod255

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_module_eq,
       getfile.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getfile.__module__.__eq__('inspect') == True — getfile is defined in the inspect module; new to extra255"]
    - [getsource_module_eq,
       getsource.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — getsource is defined in the inspect module; new to extra255"]
    - [signature_module_eq,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is defined in the inspect module; new to extra255"]
    - [isclass_module_eq,
       isclass.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is defined in the inspect module; new to extra255"]
    - [isbuiltin_module_eq,
       isbuiltin.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is defined in the inspect module; new to extra255"]

# ---------------------------------------------------------------------------
# Standalone invariants — error handling, extra255
# ---------------------------------------------------------------------------

invariant inspect_extra255.getfile.builtin_class_raises_typeerror:
  description: "inspect.getfile(int) raises TypeError — int is a built-in class with no associated source file; new to extra255"
  category: errors
  kind: python_call_raises
  function: getfile
  args: [int]
  raises: TypeError

invariant inspect_extra255.getsource.builtin_class_raises_typeerror:
  description: "inspect.getsource(int) raises TypeError — delegates to getfile which raises for built-in classes; new to extra255"
  category: errors
  kind: python_call_raises
  function: getsource
  args: [int]
  raises: TypeError

invariant inspect_extra255.getsourcelines.builtin_class_raises_typeerror:
  description: "inspect.getsourcelines(int) raises TypeError — delegates to getfile which raises for built-in classes; new to extra255"
  category: errors
  kind: python_call_raises
  function: getsourcelines
  args: [int]
  raises: TypeError

invariant inspect_extra255.signature.builtin_type_raises_valueerror:
  description: "inspect.signature(int) raises ValueError: 'no signature found for builtin type <class int>'; new to extra255"
  category: errors
  kind: python_call_raises
  function: signature
  args: [int]
  raises: ValueError

invariant inspect_extra255.getfile.builtin_function_raises_typeerror:
  description: "inspect.getfile(len) raises TypeError — len is a builtin_function_or_method, not a class or module; new to extra255"
  category: errors
  kind: python_call_raises
  function: getfile
  args: [len]
  raises: TypeError

# ---------------------------------------------------------------------------
# Standalone invariants — identity, extra255
# ---------------------------------------------------------------------------

invariant inspect_extra255.getfile.name_eq:
  description: "inspect.getfile.__name__ == 'getfile' — pure Python function in inspect; new to extra255"
  category: identity
  kind: python_call_eq
  function: getfile.__name__.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra255.getsource.name_eq:
  description: "inspect.getsource.__name__ == 'getsource' — pure Python function in inspect; new to extra255"
  category: identity
  kind: python_call_eq
  function: getsource.__name__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra255.signature.name_eq:
  description: "inspect.signature.__name__ == 'signature' — pure Python function in inspect; new to extra255"
  category: identity
  kind: python_call_eq
  function: signature.__name__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra255.isclass.name_eq:
  description: "inspect.isclass.__name__ == 'isclass' — pure Python predicate function in inspect; new to extra255"
  category: identity
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra255.isbuiltin.name_eq:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin' — pure Python predicate function in inspect; new to extra255"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true
