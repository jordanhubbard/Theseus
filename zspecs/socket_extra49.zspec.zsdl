spec: socket_extra49
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra48.zspec.zsdl — covers socket.herror/gaierror/timeout __bases__[0].__qualname__.__eq__('OSError') and herror/gaierror/timeout/socket.__doc__.__class__.__name__.__eq__('str') (exception/class __doc__ axis)."
    - "socket_extra47.zspec.zsdl — covers socket/herror/gaierror/timeout __class__.__qualname__.__eq__('type'), gethostname/gethostbyname __class__.__qualname__.__eq__('builtin_function_or_method'), getaddrinfo/getfqdn __class__.__qualname__.__eq__('function'), socket/gethostname/getaddrinfo __class__.__module__.__eq__('builtins')."
    - "socket_extra46.zspec.zsdl — covers socket.socket/__class__.__name__.__eq__('type'), herror/gaierror/timeout/__class__.__name__.__eq__('type'), gethostname/gethostbyname/__class__.__name__.__eq__('builtin_function_or_method'), getaddrinfo/getfqdn/__class__.__name__.__eq__('function')."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3; socket.error/__mro__.__len__()==4; timeout/herror/gaierror/__mro__.__len__()==5."
    - "socket_extra26.zspec.zsdl — covers timeout/herror/gaierror/__bases__[0].__name__.__eq__('OSError') and socket.socket/__init__.__name__."
    - "socket_extra25.zspec.zsdl — covers herror/gaierror/__module__.__eq__('socket'), timeout/__module__.__eq__('builtins')."
    - "socket_extra17.zspec.zsdl — covers herror/gaierror/timeout/__mro__.__len__()==5 and herror/gaierror/__bases__.__getitem__ forms."
    - "socket_extra3.zspec.zsdl — covers herror/__bases__[0].__name__.__eq__('OSError') and gaierror/__bases__[0].__name__.__eq__('OSError')."
  notes:
    - "This spec extends socket through socket_extra48; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior socket spec checks __doc__.__class__.__name__.__eq__('str') for module-level functions (gethostname, gethostbyname, getaddrinfo, getfqdn) or for the socket MODULE itself. socket_extra48 covers exception classes and socket.socket but NOT module-level functions or the module docstring. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostname.__doc__.__class__.__name__ == 'str'. gethostname is a builtin function with a C-level docstring exposed as a Python str. No prior spec checks gethostname.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__doc__.__class__.__name__ == 'str'. gethostbyname is a builtin function with a C-level docstring. No prior spec checks gethostbyname.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__doc__.__class__.__name__ == 'str'. getaddrinfo is a Python function with a docstring as a str. No prior spec checks getaddrinfo.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__doc__.__class__.__name__ == 'str'. getfqdn is a Python function with a docstring. No prior spec checks getfqdn.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.__doc__.__class__.__name__ == 'str'. The socket module has a module-level docstring as a Python str. No prior spec checks the socket module __doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.__doc__.__class__.__qualname__ == 'str'. The module docstring __class__.__qualname__ is 'str'. No prior spec checks socket module __doc__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.__doc__.__class__.__module__ == 'builtins'. The str type's __module__ is 'builtins'. No prior spec checks socket module __doc__.__class__.__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior socket spec checks socket.socket method __qualname__.__len__() for connect/bind/listen/accept/send/recv/close. socket.socket is the socket class; its methods' __qualname__ follows the pattern 'socket.<method>' (using the class name 'socket', not the module name). Each method's qualname length equals len('socket.') + len(method_name). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__.__len__() == 14. 'socket.connect' has 14 characters. No prior socket spec checks connect.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__.__len__() == 11. 'socket.bind' has 11 characters. No prior socket spec checks bind.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__.__len__() == 13. 'socket.listen' has 13 characters. No prior socket spec checks listen.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__.__len__() == 13. 'socket.accept' has 13 characters. No prior socket spec checks accept.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.send.__qualname__.__len__() == 11. 'socket.send' has 11 characters. No prior socket spec checks send.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__.__len__() == 11. 'socket.recv' has 11 characters. No prior socket spec checks recv.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__.__len__() == 12. 'socket.close' has 12 characters. No prior socket spec checks close.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module-level function and module __doc__.__class__.__name__.__eq__('str')
#
# socket_extra48 covers __doc__.__class__.__name__ for exception classes and
# socket.socket. No prior socket spec checks __doc__.__class__.__name__ for
# module-level functions (gethostname, gethostbyname, getaddrinfo, getfqdn)
# or the socket module's own docstring. This table extends the __doc__ type
# coverage to module-level callables and the module itself.
# ---------------------------------------------------------------------------

table socket_extra49.function_doc_class_names:
  description: "socket gethostname/gethostbyname/getaddrinfo/getfqdn/module __doc__.__class__.__name__.__eq__('str') — verifies that module-level socket function docstrings and the module docstring are Python str; novel extension of __doc__.__class__.__name__ coverage to module-level functions; socket_extra48 covers exception/socket.socket __doc__ but NOT module-level functions or the module itself"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketdoc49

  columns: [id, function, args, expected]
  rows:
    - [gethostname_doc_class_name_eq,  gethostname.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [gethostbyname_doc_class_name_eq, gethostbyname.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [getaddrinfo_doc_class_name_eq,  getaddrinfo.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [getfqdn_doc_class_name_eq,      getfqdn.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [module_doc_class_name_eq,       __doc__.__class__.__name__.__eq__,              ["str"], true]

# ---------------------------------------------------------------------------
# socket module-level __doc__.__class__.__qualname__ and __doc__.__class__.__module__
#
# No prior socket spec checks the socket module's own __doc__.__class__.__qualname__
# or __doc__.__class__.__module__. These provide additional independent structural
# regression vectors: __qualname__ confirms str's qualified name; __module__
# confirms that the str type belongs to the 'builtins' module.
# ---------------------------------------------------------------------------

table socket_extra49.module_doc_class_attrs:
  description: "socket module __doc__.__class__.__qualname__/__module__ — str.__qualname__=='str' and str.__module__=='builtins'; no prior socket spec checks module __doc__.__class__.__qualname__ or __module__; independent regression vectors for module docstring type identity"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketmoddoc49

  columns: [id, function, args, expected]
  rows:
    - [module_doc_class_qualname_eq, __doc__.__class__.__qualname__.__eq__, ["str"],      true]
    - [module_doc_class_module_eq,   __doc__.__class__.__module__.__eq__,   ["builtins"], true]

# ---------------------------------------------------------------------------
# socket.socket method __qualname__.__len__()
#
# socket.socket is the Python socket class (wrapping C socket objects). Its
# methods (connect, bind, listen, accept, send, recv, close) have __qualname__
# of the form 'socket.<method>' — where 'socket' is the CLASS name, not the
# module. The lengths: connect=14, bind=11, listen=13, accept=13, send=11,
# recv=11, close=12.
#
# No prior socket spec checks __qualname__.__len__() for any socket.socket method.
# This provides an independent regression vector: if a method is renamed, the
# length changes and this table detects it.
# ---------------------------------------------------------------------------

table socket_extra49.socket_method_qualname_lengths:
  description: "socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__len__() — method qualnames follow 'socket.<method>' pattern; lengths: connect=14, bind=11, listen=13, accept=13, send=11, recv=11, close=12; no prior socket spec checks socket.socket method __qualname__.__len__() for any of these methods"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketmethlen49

  columns: [id, function, args, expected]
  rows:
    - [socket_connect_qualname_len, socket.connect.__qualname__.__len__, [], 14]
    - [socket_bind_qualname_len,    socket.bind.__qualname__.__len__,    [], 11]
    - [socket_listen_qualname_len,  socket.listen.__qualname__.__len__,  [], 13]
    - [socket_accept_qualname_len,  socket.accept.__qualname__.__len__,  [], 13]
    - [socket_send_qualname_len,    socket.send.__qualname__.__len__,    [], 11]
    - [socket_recv_qualname_len,    socket.recv.__qualname__.__len__,    [], 11]
    - [socket_close_qualname_len,   socket.close.__qualname__.__len__,   [], 12]
