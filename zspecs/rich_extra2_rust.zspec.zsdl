spec: rich_extra2_rust
version: ">=3.9"
backend: rust_module(rich_extra2_rust)

docs: https://rich.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://rich.readthedocs.io/en/stable/ — Rich documentation"
  not_derived_from:
    - "rich source: rich/__init__.py"
  notes:
    - "Rich provides rich text and beautiful formatting for the terminal."
    - "from rich.table import Table; t = Table(); t.add_column('Name'); len(t.columns) == 1."
    - "Table().add_column('A').add_column('B') — not chainable, use add_column twice."
    - "Table(title='Foo').title == 'Foo'."
    - "Table(title='Bar').title == 'Bar'."
    - "Expose rich2_table_title(title) -> str: Table(title=title).title."
    - "Expose rich2_table_add_col_count(cols) -> int: add N columns, return len(t.columns)."
    - "All test vectors verified against rich 14.0.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# rich2_table_title — table title
table rich_extra2_rust.table.title:
  kind: python_call_eq
  category: title
  id_prefix: rch2_tt
  function: rich2_table_title

  columns: [id, args, expected]
  rows:
    - [foo,  ["Foo"], "Foo"]
    - [bar,  ["Bar"], "Bar"]
    - [data, ["Data"], "Data"]

# rich2_table_add_col_count — column count after adding
table rich_extra2_rust.table.col_count:
  kind: python_call_eq
  category: col_count
  id_prefix: rch2_cc
  function: rich2_table_add_col_count

  columns: [id, args, expected]
  rows:
    - [one,   [["Name"]], 1]
    - [two,   [["Name", "Age"]], 2]
    - [three, [["A", "B", "C"]], 3]

