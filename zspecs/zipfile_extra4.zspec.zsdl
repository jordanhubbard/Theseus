spec: zipfile_extra4
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
  notes:
    - "This spec extends prior zipfile specs."
    - "Focus: class names and constants not yet covered."
    - "zipfile.ZipFile.__name__ == 'ZipFile'."
    - "zipfile.ZipInfo.__name__ == 'ZipInfo'."
    - "zipfile.Path.__name__ == 'Path'."
    - "zipfile.BadZipFile.__name__ == 'BadZipFile'."
    - "zipfile.LargeZipFile.__name__ == 'LargeZipFile'."
    - "zipfile.ZIP_STORED == 0."
    - "zipfile.ZIP_DEFLATED == 8."
    - "zipfile.ZIP_BZIP2 == 12."
    - "zipfile.ZIP_LZMA == 14."
    - "zipfile.is_zipfile.__name__ == 'is_zipfile'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table zipfile_extra4.compression_constants:
  kind: python_call_eq
  category: constants
  id_prefix: compress

  columns: [id, function, args, expected]
  rows:
    - [ZIP_STORED,   ZIP_STORED.__eq__,   [0],  true]
    - [ZIP_DEFLATED, ZIP_DEFLATED.__eq__, [8],  true]
    - [ZIP_BZIP2,    ZIP_BZIP2.__eq__,    [12], true]
    - [ZIP_LZMA,     ZIP_LZMA.__eq__,     [14], true]

table zipfile_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [ZipFile,      ZipFile.__name__.__eq__,      ["ZipFile"],      true]
    - [ZipInfo,      ZipInfo.__name__.__eq__,      ["ZipInfo"],      true]
    - [Path,         Path.__name__.__eq__,         ["Path"],         true]
    - [BadZipFile,   BadZipFile.__name__.__eq__,   ["BadZipFile"],   true]
    - [LargeZipFile, LargeZipFile.__name__.__eq__, ["LargeZipFile"], true]

table zipfile_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [is_zipfile, is_zipfile.__name__.__eq__, ["is_zipfile"], true]

invariant zipfile_extra4.ZipFile.module:
  description: "zipfile.ZipFile.__module__ == 'zipfile'"
  category: module
  kind: python_call_eq
  function: ZipFile.__module__.__eq__
  args: ["zipfile"]
  expected: true

invariant zipfile_extra4.BadZipFile.base:
  description: "zipfile.BadZipFile.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: BadZipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant zipfile_extra4.LargeZipFile.base:
  description: "zipfile.LargeZipFile.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: LargeZipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant zipfile_extra4.ZipInfo.instance_class:
  description: "zipfile.ZipInfo('test.txt').__class__.__name__ == 'ZipInfo'"
  category: ZipInfo
  kind: python_call_eq
  function: ZipInfo
  args: ["test.txt"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["ZipInfo"]
  expected: true

invariant zipfile_extra4.ZipInfo.filename_attr:
  description: "zipfile.ZipInfo('test.txt').filename == 'test.txt'"
  category: ZipInfo
  kind: python_call_eq
  function: ZipInfo
  args: ["test.txt"]
  method: filename.__eq__
  method_args: ["test.txt"]
  expected: true

invariant zipfile_extra4.ZIP_STORED.class_name:
  description: "zipfile.ZIP_STORED.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ZIP_STORED.__class__.__name__.__eq__
  args: ["int"]
  expected: true
