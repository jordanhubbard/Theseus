spec: logging_extra10
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra9.zspec.zsdl."
    - "logging_extra9 covers Handler/Formatter/Filter method __qualname__; Handler/StreamHandler/FileHandler MRO[1..3]; function __qualname__ for makeLogRecord/disable/captureWarnings/addLevelName."
    - "logging_extra8 covers Manager/PlaceHolder __module__; LoggerAdapter __qualname__/__module__; Logger.setLevel/addHandler/removeHandler __qualname__; Filterer.addFilter/removeFilter __qualname__; BASIC_FORMAT content membership."
    - "NOT yet covered: logging.Formatter.__name__ == 'Formatter' as a standalone invariant."
    - "NOT yet covered: logging.Handler.__name__ == 'Handler' as a standalone invariant."
    - "NOT yet covered: logging.StreamHandler.__name__ == 'StreamHandler' as a standalone invariant."
    - "NOT yet covered: logging.FileHandler.__name__ == 'FileHandler' as a standalone invariant."
    - "NOT yet covered: logging.NullHandler.__name__ == 'NullHandler' as a standalone invariant."
    - "NOT yet covered: logging.Logger.__name__ == 'Logger' as a standalone invariant."
    - "NOT yet covered: logging.LogRecord.__name__ == 'LogRecord' as a standalone invariant."
    - "NOT yet covered: logging.Filter.__name__ == 'Filter' as a standalone invariant."
    - "NOT yet covered: logging.getLevelName(10) == 'DEBUG' as a standalone invariant."
    - "NOT yet covered: logging.getLevelName(20) == 'INFO' as a standalone invariant."
    - "NOT yet covered: logging.getLevelName(30) == 'WARNING' as a standalone invariant."
    - "NOT yet covered: logging.getLevelName(40) == 'ERROR' as a standalone invariant."
    - "NOT yet covered: logging.getLevelName(50) == 'CRITICAL' as a standalone invariant."
    - "NOT yet covered: logging.getLevelName('DEBUG') == 10 as a standalone invariant."
    - "logging.Formatter.__name__ == 'Formatter'."
    - "logging.Handler.__name__ == 'Handler'."
    - "logging.StreamHandler.__name__ == 'StreamHandler'."
    - "logging.FileHandler.__name__ == 'FileHandler'."
    - "logging.NullHandler.__name__ == 'NullHandler'."
    - "logging.Logger.__name__ == 'Logger'."
    - "logging.LogRecord.__name__ == 'LogRecord'."
    - "logging.Filter.__name__ == 'Filter'."
    - "logging.getLevelName(10) == 'DEBUG'."
    - "logging.getLevelName(20) == 'INFO'."
    - "logging.getLevelName(30) == 'WARNING'."
    - "logging.getLevelName(40) == 'ERROR'."
    - "logging.getLevelName(50) == 'CRITICAL'."
    - "logging.getLevelName('DEBUG') == 10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ attributes — standalone invariants
#
# Prior logging specs covered __name__ for these classes in combined tables
# (e.g., logging_extra4 covers __name__ alongside __module__/__qualname__).
# No prior spec records each class __name__ as its own standalone invariant
# using the dotted-attribute pattern Formatter.__name__.__eq__.
# ---------------------------------------------------------------------------

invariant logging_extra10.Formatter.name:
  description: "logging.Formatter.__name__ == 'Formatter'"
  category: class_names
  kind: python_call_eq
  function: Formatter.__name__.__eq__
  args: ["Formatter"]
  expected: true

invariant logging_extra10.Handler.name:
  description: "logging.Handler.__name__ == 'Handler'"
  category: class_names
  kind: python_call_eq
  function: Handler.__name__.__eq__
  args: ["Handler"]
  expected: true

invariant logging_extra10.StreamHandler.name:
  description: "logging.StreamHandler.__name__ == 'StreamHandler'"
  category: class_names
  kind: python_call_eq
  function: StreamHandler.__name__.__eq__
  args: ["StreamHandler"]
  expected: true

invariant logging_extra10.FileHandler.name:
  description: "logging.FileHandler.__name__ == 'FileHandler'"
  category: class_names
  kind: python_call_eq
  function: FileHandler.__name__.__eq__
  args: ["FileHandler"]
  expected: true

invariant logging_extra10.NullHandler.name:
  description: "logging.NullHandler.__name__ == 'NullHandler'"
  category: class_names
  kind: python_call_eq
  function: NullHandler.__name__.__eq__
  args: ["NullHandler"]
  expected: true

invariant logging_extra10.Logger.name:
  description: "logging.Logger.__name__ == 'Logger'"
  category: class_names
  kind: python_call_eq
  function: Logger.__name__.__eq__
  args: ["Logger"]
  expected: true

invariant logging_extra10.LogRecord.name:
  description: "logging.LogRecord.__name__ == 'LogRecord'"
  category: class_names
  kind: python_call_eq
  function: LogRecord.__name__.__eq__
  args: ["LogRecord"]
  expected: true

invariant logging_extra10.Filter.name:
  description: "logging.Filter.__name__ == 'Filter'"
  category: class_names
  kind: python_call_eq
  function: Filter.__name__.__eq__
  args: ["Filter"]
  expected: true

# ---------------------------------------------------------------------------
# getLevelName — integer → string direction
#
# logging.zspec.zsdl covers getLevelName in a table mapping int levels to
# strings (DEBUG/INFO/WARNING/ERROR/CRITICAL). These add standalone invariants
# for each standard level using the dotted-eq pattern for machine-readability.
# ---------------------------------------------------------------------------

invariant logging_extra10.getLevelName.debug:
  description: "logging.getLevelName(10) == 'DEBUG'"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [10]
  expected: "DEBUG"

invariant logging_extra10.getLevelName.info:
  description: "logging.getLevelName(20) == 'INFO'"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [20]
  expected: "INFO"

invariant logging_extra10.getLevelName.warning:
  description: "logging.getLevelName(30) == 'WARNING'"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [30]
  expected: "WARNING"

invariant logging_extra10.getLevelName.error:
  description: "logging.getLevelName(40) == 'ERROR'"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [40]
  expected: "ERROR"

invariant logging_extra10.getLevelName.critical:
  description: "logging.getLevelName(50) == 'CRITICAL'"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [50]
  expected: "CRITICAL"

# ---------------------------------------------------------------------------
# getLevelName — string → integer direction
#
# logging.zspec.zsdl covers getLevelName int→str only.
# getLevelName also accepts a string and returns the numeric level.
# This adds the reverse mapping for 'DEBUG' → 10 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant logging_extra10.getLevelName.str_to_int:
  description: "logging.getLevelName('DEBUG') == 10"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: ["DEBUG"]
  expected: 10
