spec: itertools_extra118
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra117.zspec.zsdl."
    - "This spec covers: itertools.count, itertools.cycle, and itertools.repeat class slot qualname attributes not yet covered — count.__next__.__qualname__ ('count.__next__', len 14), cycle.__next__.__qualname__ ('cycle.__next__', len 14), cycle.__iter__.__qualname__ ('cycle.__iter__', len 14), repeat.__next__.__qualname__ ('repeat.__next__', len 15), repeat.__iter__.__qualname__ ('repeat.__iter__', len 15); wave 269."
    - "itertools.count.__next__.__qualname__ == 'count.__next__'. Verified with Python 3.14.3."
    - "len(itertools.count.__next__.__qualname__) == 14. Verified with Python 3.14.3."
    - "itertools.cycle.__next__.__qualname__ == 'cycle.__next__'. Verified with Python 3.14.3."
    - "itertools.cycle.__iter__.__qualname__ == 'cycle.__iter__'. Verified with Python 3.14.3."
    - "len(itertools.cycle.__next__.__qualname__) == 14. Verified with Python 3.14.3."
    - "len(itertools.cycle.__iter__.__qualname__) == 14. Verified with Python 3.14.3."
    - "itertools.repeat.__next__.__qualname__ == 'repeat.__next__'. Verified with Python 3.14.3."
    - "itertools.repeat.__iter__.__qualname__ == 'repeat.__iter__'. Verified with Python 3.14.3."
    - "len(itertools.repeat.__next__.__qualname__) == 15. Verified with Python 3.14.3."
    - "len(itertools.repeat.__iter__.__qualname__) == 15. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.count.__next__ slot qualname
#
# Wave 269 theme: itertools.count is a C-extension iterator type. Its tp_iter
# slot qualname ('count.__iter__') was previously covered in extra-series specs.
# New here is the tp_iternext slot: count.__next__.__qualname__ is
# 'count.__next__' (14 chars: 'count'(5)+dot(1)+'__next__'(8)). This matches
# the chain.__next__.__qualname__ length (also 14) from extra116, because both
# 'count' and 'chain' are 5-char class names. The class name 'count' is 5 chars
# as with 'chain', giving qualname length 5+1+8=14.
#
# count.__next__.__qualname__ == 'count.__next__'   (len 14)
#
# New to extra118.
# ---------------------------------------------------------------------------

table itertools_extra118.count_next_qualname:
  description: "itertools.count.__next__ qualname: 'count.__next__' (14 chars); same length as chain (14) because 'count' is 5 chars like 'chain'; wrapper_descriptor; wave 269; new to extra118"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscnq118

  columns: [id, function, args, expected, description]
  rows:
    - [count_next_qualname_eq,
       "count.__next__.__qualname__.__eq__",
       ["count.__next__"],
       true,
       "itertools.count.__next__.__qualname__.__eq__('count.__next__') == True — count defines tp_iternext which surfaces as '__next__'; qualname is 'count.__next__' (14 chars); str.__eq__('count.__next__') returns True; new to extra118"]
    - [count_next_qualname_len,
       "count.__next__.__qualname__.__len__",
       [],
       14,
       "itertools.count.__next__.__qualname__.__len__() == 14 — 'count.__next__' has 14 chars: count(5)+dot(1)+__next__(8); same as chain (also 5 chars, also len 14); str.__len__() returns 14; new to extra118"]
    - [count_next_name_eq,
       "count.__next__.__name__.__eq__",
       ["__next__"],
       true,
       "itertools.count.__next__.__name__.__eq__('__next__') == True — the bare slot name is '__next__' (8 chars); the class prefix is stripped from __name__; str.__eq__('__next__') returns True; new to extra118"]
    - [count_next_class_name,
       "count.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.count.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — C tp_iternext is exposed as a wrapper_descriptor; same type as islice.__next__, chain.__next__; str.__eq__('wrapper_descriptor') returns True; new to extra118"]
    - [count_next_qualname_len_vs_islice,
       "count.__next__.__qualname__.__len__",
       [],
       14,
       "itertools.count.__next__.__qualname__.__len__() == 14 — one less than islice (15) because 'count' (5 chars) is one shorter than 'islice' (6 chars); qualname length scales with class name length; str.__len__() returns 14; new to extra118"]

# ---------------------------------------------------------------------------
# Table 2: itertools.cycle.__next__ and __iter__ slot qualnames
#
# Wave 269 theme: itertools.cycle is a C-extension iterator that cycles
# indefinitely through an iterable. Its __next__ and __iter__ slot qualnames
# are 'cycle.__next__' and 'cycle.__iter__' — both 14 chars, same as count
# (14) because 'cycle' is also 5 chars. The class 'cycle' has 5 chars giving
# qualname lengths of 5+1+8=14 for both slots. Previously covered: cycle
# __qualname__, __repr__.__qualname__, __new__.__class__.__name__, __module__,
# __name__, __mro__.__len__, __doc__. Not previously covered: cycle.__next__
# and cycle.__iter__ slot qualnames. New here.
#
# cycle.__next__.__qualname__ == 'cycle.__next__'   (len 14)
# cycle.__iter__.__qualname__ == 'cycle.__iter__'   (len 14)
#
# New to extra118.
# ---------------------------------------------------------------------------

table itertools_extra118.cycle_next_iter_qualnames:
  description: "itertools.cycle slot qualnames: __next__='cycle.__next__'(14), __iter__='cycle.__iter__'(14); both len=14; same as count and chain (all 5-char class names); wrapper_descriptor; wave 269; new to extra118"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscyiq118

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_next_qualname_eq,
       "cycle.__next__.__qualname__.__eq__",
       ["cycle.__next__"],
       true,
       "itertools.cycle.__next__.__qualname__.__eq__('cycle.__next__') == True — cycle defines tp_iternext; qualname is 'cycle.__next__' (14 chars); str.__eq__('cycle.__next__') returns True; new to extra118"]
    - [cycle_next_qualname_len,
       "cycle.__next__.__qualname__.__len__",
       [],
       14,
       "itertools.cycle.__next__.__qualname__.__len__() == 14 — 'cycle.__next__' has 14 chars: cycle(5)+dot(1)+__next__(8); same as count (14) and chain (14) because 'cycle' is also 5 chars; str.__len__() returns 14; new to extra118"]
    - [cycle_iter_qualname_eq,
       "cycle.__iter__.__qualname__.__eq__",
       ["cycle.__iter__"],
       true,
       "itertools.cycle.__iter__.__qualname__.__eq__('cycle.__iter__') == True — cycle defines tp_iter; qualname is 'cycle.__iter__' (14 chars); str.__eq__('cycle.__iter__') returns True; new to extra118"]
    - [cycle_iter_qualname_len,
       "cycle.__iter__.__qualname__.__len__",
       [],
       14,
       "itertools.cycle.__iter__.__qualname__.__len__() == 14 — 'cycle.__iter__' has 14 chars: cycle(5)+dot(1)+__iter__(8); same length as cycle.__next__.__qualname__; str.__len__() returns 14; new to extra118"]
    - [cycle_next_class_name,
       "cycle.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.cycle.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — C tp_iternext slot is a wrapper_descriptor; same type as count.__next__; str.__eq__('wrapper_descriptor') returns True; new to extra118"]

# ---------------------------------------------------------------------------
# Table 3: itertools.repeat.__next__ and __iter__ slot qualnames
#
# Wave 269 theme: itertools.repeat is a C-extension iterator that repeats a
# single value indefinitely (or N times). Its __next__ qualname is
# 'repeat.__next__' (15 chars) and __iter__ qualname is 'repeat.__iter__'
# (15 chars). Both are 15 chars because 'repeat' is 6 chars (one more than
# 'cycle'/'count'/'chain' which are all 5 chars). This 1-char class name
# difference gives qualname length 6+1+8=15. Previously covered:
# repeat.__next__.__class__.__name__ (not qualname), repeat.__qualname__,
# repeat.__name__, etc. New here: repeat.__next__.__qualname__ and
# repeat.__iter__.__qualname__.
#
# repeat.__next__.__qualname__ == 'repeat.__next__'   (len 15)
# repeat.__iter__.__qualname__ == 'repeat.__iter__'   (len 15)
#
# New to extra118.
# ---------------------------------------------------------------------------

table itertools_extra118.repeat_next_iter_qualnames:
  description: "itertools.repeat slot qualnames: __next__='repeat.__next__'(15), __iter__='repeat.__iter__'(15); both len=15; one more than cycle/count/chain (14) because 'repeat' is 6 chars; wave 269; new to extra118"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsriq118

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_next_qualname_eq,
       "repeat.__next__.__qualname__.__eq__",
       ["repeat.__next__"],
       true,
       "itertools.repeat.__next__.__qualname__.__eq__('repeat.__next__') == True — repeat defines tp_iternext; qualname is 'repeat.__next__' (15 chars); str.__eq__('repeat.__next__') returns True; new to extra118"]
    - [repeat_next_qualname_len,
       "repeat.__next__.__qualname__.__len__",
       [],
       15,
       "itertools.repeat.__next__.__qualname__.__len__() == 15 — 'repeat.__next__' has 15 chars: repeat(6)+dot(1)+__next__(8); one more than cycle/count/chain (14) because 'repeat' is 6 chars vs 5; str.__len__() returns 15; new to extra118"]
    - [repeat_iter_qualname_eq,
       "repeat.__iter__.__qualname__.__eq__",
       ["repeat.__iter__"],
       true,
       "itertools.repeat.__iter__.__qualname__.__eq__('repeat.__iter__') == True — repeat defines tp_iter; qualname is 'repeat.__iter__' (15 chars); str.__eq__('repeat.__iter__') returns True; new to extra118"]
    - [repeat_iter_qualname_len,
       "repeat.__iter__.__qualname__.__len__",
       [],
       15,
       "itertools.repeat.__iter__.__qualname__.__len__() == 15 — 'repeat.__iter__' has 15 chars; same length as repeat.__next__.__qualname__ (15); str.__len__() returns 15; new to extra118"]
    - [repeat_next_vs_cycle_next_len,
       "repeat.__next__.__qualname__.__len__",
       [],
       15,
       "itertools.repeat.__next__.__qualname__.__len__() == 15 — one more than cycle.__next__.__qualname__.__len__() (14); 'repeat'(6) is one char longer than 'cycle'(5); qualname length 15 equals islice qualname length (also 15) because 'islice' is also 6 chars; str.__len__() returns 15; new to extra118"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra118
# ---------------------------------------------------------------------------

invariant itertools_extra118.count_next_qualname:
  description: "itertools.count.__next__.__qualname__ == 'count.__next__' — tp_iternext slot; qualname length 14; same as chain (14); wave 269; new to extra118"
  kind: python_call_eq
  function: count.__next__.__qualname__.__eq__
  args: ["count.__next__"]
  expected: true

invariant itertools_extra118.cycle_next_qualname:
  description: "itertools.cycle.__next__.__qualname__ == 'cycle.__next__' — tp_iternext slot; qualname length 14; same as count and chain (all 5-char class names); wave 269; new to extra118"
  kind: python_call_eq
  function: cycle.__next__.__qualname__.__eq__
  args: ["cycle.__next__"]
  expected: true

invariant itertools_extra118.cycle_iter_qualname:
  description: "itertools.cycle.__iter__.__qualname__ == 'cycle.__iter__' — tp_iter slot; qualname length 14; equal to cycle.__next__ qualname length; wave 269; new to extra118"
  kind: python_call_eq
  function: cycle.__iter__.__qualname__.__eq__
  args: ["cycle.__iter__"]
  expected: true

invariant itertools_extra118.repeat_next_qualname:
  description: "itertools.repeat.__next__.__qualname__ == 'repeat.__next__' — tp_iternext slot; qualname length 15; one more than cycle (14) due to 6-char class name; wave 269; new to extra118"
  kind: python_call_eq
  function: repeat.__next__.__qualname__.__eq__
  args: ["repeat.__next__"]
  expected: true

invariant itertools_extra118.repeat_iter_qualname:
  description: "itertools.repeat.__iter__.__qualname__ == 'repeat.__iter__' — tp_iter slot; qualname length 15; equal to repeat.__next__ qualname length; wave 269; new to extra118"
  kind: python_call_eq
  function: repeat.__iter__.__qualname__.__eq__
  args: ["repeat.__iter__"]
  expected: true
