spec: concurrent_futures_extra228
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Future.result.__name__ == 'result' — 6 characters; qualname is 'Future.result'; verified with Python 3.14.3."
    - "concurrent.futures.Future.cancel.__name__ == 'cancel' — 6 characters; qualname is 'Future.cancel'; verified with Python 3.14.3."
    - "concurrent.futures.Future.done.__name__ == 'done' — 4 characters; qualname is 'Future.done'; verified with Python 3.14.3."
    - "concurrent.futures.Future.running.__name__ == 'running' — 7 characters; qualname is 'Future.running'; verified with Python 3.14.3."
    - "concurrent.futures.Future.cancelled.__name__ == 'cancelled' — 9 characters; qualname is 'Future.cancelled'; verified with Python 3.14.3."
    - "concurrent.futures.Future.add_done_callback.__name__ == 'add_done_callback' — 17 characters; verified with Python 3.14.3."
    - "concurrent.futures.Future.exception.__name__ == 'exception' — 9 characters; verified with Python 3.14.3."
    - "All Future methods live in concurrent.futures._base; module == 'concurrent.futures._base'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future method name contracts — extra228 namespace
#
# result, cancel, done, running, cancelled all have simple qualnames 'Future.<name>'.
# All methods live in concurrent.futures._base.
# ---------------------------------------------------------------------------

table concurrent_futures_extra228.future_method_names:
  description: "concurrent.futures.Future method __name__ contracts in cf228fmn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf228fmn

  columns: [id, function, args, expected, description]
  rows:
    - [future_result_name_eq,        Future.result.__name__.__eq__,           ["result"],           true, "concurrent.futures.Future.result.__name__ == 'result'; verified with Python 3.14.3"]
    - [future_result_name_len_6,     Future.result.__name__.__len__,          [],                   6,    "concurrent.futures.Future.result.__name__.__len__() == 6 — 'result' has 6 characters; verified with Python 3.14.3"]
    - [future_cancel_name_eq,        Future.cancel.__name__.__eq__,           ["cancel"],           true, "concurrent.futures.Future.cancel.__name__ == 'cancel'; verified with Python 3.14.3"]
    - [future_done_name_eq,          Future.done.__name__.__eq__,             ["done"],             true, "concurrent.futures.Future.done.__name__ == 'done'; verified with Python 3.14.3"]
    - [future_done_name_len_4,       Future.done.__name__.__len__,            [],                   4,    "concurrent.futures.Future.done.__name__.__len__() == 4 — 'done' has 4 characters; verified with Python 3.14.3"]
    - [future_running_name_eq,       Future.running.__name__.__eq__,          ["running"],          true, "concurrent.futures.Future.running.__name__ == 'running'; verified with Python 3.14.3"]
    - [future_cancelled_name_eq,     Future.cancelled.__name__.__eq__,        ["cancelled"],        true, "concurrent.futures.Future.cancelled.__name__ == 'cancelled'; verified with Python 3.14.3"]
    - [future_cancelled_name_len_9,  Future.cancelled.__name__.__len__,       [],                   9,    "concurrent.futures.Future.cancelled.__name__.__len__() == 9 — 'cancelled' has 9 characters; verified with Python 3.14.3"]
    - [future_exception_name_eq,     Future.exception.__name__.__eq__,        ["exception"],        true, "concurrent.futures.Future.exception.__name__ == 'exception'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future method qualname contracts — extra228 namespace
#
# All qualnames follow 'Future.<method>' pattern; verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table concurrent_futures_extra228.future_method_qualnames:
  description: "concurrent.futures.Future method __qualname__ contracts in cf228fmq namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf228fmq

  columns: [id, function, args, expected, description]
  rows:
    - [future_result_qualname_eq,        Future.result.__qualname__.__eq__,           ["Future.result"],           true, "concurrent.futures.Future.result.__qualname__ == 'Future.result'; verified with Python 3.14.3"]
    - [future_cancel_qualname_eq,        Future.cancel.__qualname__.__eq__,           ["Future.cancel"],           true, "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel'; verified with Python 3.14.3"]
    - [future_done_qualname_eq,          Future.done.__qualname__.__eq__,             ["Future.done"],             true, "concurrent.futures.Future.done.__qualname__ == 'Future.done'; verified with Python 3.14.3"]
    - [future_running_qualname_eq,       Future.running.__qualname__.__eq__,          ["Future.running"],          true, "concurrent.futures.Future.running.__qualname__ == 'Future.running'; verified with Python 3.14.3"]
    - [future_cancelled_qualname_eq,     Future.cancelled.__qualname__.__eq__,        ["Future.cancelled"],        true, "concurrent.futures.Future.cancelled.__qualname__ == 'Future.cancelled'; verified with Python 3.14.3"]
    - [future_add_done_cb_qualname_eq,   Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true, "concurrent.futures.Future.add_done_callback.__qualname__ == 'Future.add_done_callback'; verified with Python 3.14.3"]
