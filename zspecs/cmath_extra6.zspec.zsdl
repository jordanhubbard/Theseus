spec: cmath_extra6
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmath.html — Python cmath documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl and prior extras through cmath_extra5.zspec.zsdl."
    - "cmath.zspec: phase(1.0)==0.0, phase(-1.0)==pi, phase(0.0)==0.0 — all float args."
    - "cmath_extra5: phase(-1) == pi — integer arg. No prior spec covers phase(1) integer arg."
    - "cmath_extra/cmath_extra3: constant __class__.__name__ checks for pi/e/tau/inf/nan/infj/nanj."
    - "cmath_extra2: polar(1.0) components; rect(1.0, 0.0) real/imag — both with float args."
    - "cmath_extra5: polar(1) integer arg components — __getitem__(0) and __getitem__(1) covered."
    - "No prior spec covers cmath.phase(1).__class__.__name__ == 'float' (type of phase return)."
    - "No prior spec covers cmath.phase(1) == 0.0 with integer argument 1 (vs float 1.0 in cmath.zspec)."
    - "No prior spec covers cmath.polar(1).__class__.__name__ == 'tuple'."
    - "No prior spec covers cmath.polar(1).__len__() == 2 (polar always returns a 2-tuple)."
    - "No prior spec covers cmath.rect(1, 0).__class__.__name__ == 'complex'."
    - "No prior spec covers cmath.rect(1, 0).real == 1.0 with integer args (cmath_extra2 uses float 1.0, 0.0)."
    - "No prior spec covers cmath.sqrt(1).real == 1.0 (integer input; cmath.zspec uses float 4.0/9.0)."
    - "No prior spec covers cmath.sqrt(1).imag == 0.0 (integer input)."
    - "No prior spec covers cmath.sqrt(9).real == 3.0 (integer input; cmath.zspec uses float 9.0)."
    - "No prior spec covers cmath.isclose.__module__ == 'cmath' (cmath_extra2 checks phase.__module__ only)."
    - "No prior spec covers cmath.sqrt.__module__ == 'cmath'."
    - "cmath.phase(1).__class__.__name__ == 'float' — phase always returns a float."
    - "cmath.phase(1) == 0.0 — phase of positive integer 1 is zero."
    - "cmath.polar(1).__class__.__name__ == 'tuple' — polar returns a (r, phi) tuple."
    - "cmath.polar(1).__len__() == 2 — polar tuple always has exactly two elements."
    - "cmath.rect(1, 0).__class__.__name__ == 'complex' — rect returns a complex number."
    - "cmath.rect(1, 0).real == 1.0 — rect with integer args; real part equals r when phi==0."
    - "cmath.sqrt(1).real == 1.0 — sqrt of integer 1 has unit real part."
    - "cmath.sqrt(1).imag == 0.0 — sqrt of integer 1 has zero imaginary part."
    - "cmath.sqrt(9).real == 3.0 — sqrt of integer 9 has real part 3.0."
    - "cmath.isclose.__module__ == 'cmath' — isclose is defined in the cmath module."
    - "cmath.sqrt.__module__ == 'cmath' — sqrt is defined in the cmath module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cmath.phase(1) — integer argument, return type and value
#
# cmath.zspec covers phase(1.0) == 0.0 with a float argument.
# cmath_extra5 covers phase(-1) integer == pi.
# No prior spec covers phase(1) integer == 0.0, or the return type of phase.
# ---------------------------------------------------------------------------

invariant cmath_extra6.phase.one_int_class:
  description: "cmath.phase(1).__class__.__name__ == 'float' — phase always returns a float"
  category: phase
  kind: python_call_eq
  function: phase
  args: [1]
  method: __class__
  method_chain: __name__
  expected: "float"

invariant cmath_extra6.phase.one_int_value:
  description: "cmath.phase(1) == 0.0 — phase of positive integer 1 is zero"
  category: phase
  kind: python_call_eq
  function: phase
  args: [1]
  expected: 0.0

# ---------------------------------------------------------------------------
# cmath.polar(1) — type and length of the returned tuple
#
# cmath_extra5 covers polar(1).__getitem__(0) and [1] component values.
# No prior spec covers the type (__class__.__name__ == 'tuple') or length (__len__ == 2).
# ---------------------------------------------------------------------------

invariant cmath_extra6.polar.one_int_class:
  description: "cmath.polar(1).__class__.__name__ == 'tuple' — polar returns a 2-tuple"
  category: polar
  kind: python_call_eq
  function: polar
  args: [1]
  method: __class__
  method_chain: __name__
  expected: "tuple"

invariant cmath_extra6.polar.one_int_len:
  description: "cmath.polar(1).__len__() == 2 — polar tuple always has exactly two elements"
  category: polar
  kind: python_call_eq
  function: polar
  args: [1]
  method: __len__
  expected: 2

# ---------------------------------------------------------------------------
# cmath.rect(1, 0) — type and real part with integer arguments
#
# cmath_extra2 covers rect(1.0, 0.0) with float arguments.
# No prior spec covers rect with integer args or the __class__.__name__ of the result.
# rect(r, phi) == r*e^(i*phi); rect(1, 0) == 1+0j.
# ---------------------------------------------------------------------------

invariant cmath_extra6.rect.one_zero_int_class:
  description: "cmath.rect(1, 0).__class__.__name__ == 'complex' — rect returns a complex number"
  category: rect
  kind: python_call_eq
  function: rect
  args: [1, 0]
  method: __class__
  method_chain: __name__
  expected: "complex"

invariant cmath_extra6.rect.one_zero_int_real:
  description: "cmath.rect(1, 0).real == 1.0 — rect with integer args has real part r when phi==0"
  category: rect
  kind: python_call_eq
  function: rect
  args: [1, 0]
  method: real
  expected: 1.0

# ---------------------------------------------------------------------------
# cmath.sqrt — integer input vectors
#
# cmath.zspec covers sqrt(4.0)/sqrt(9.0) with float inputs.
# cmath_extra4 covers sqrt(0) and sqrt(-4) integer inputs.
# No prior spec covers sqrt(1) (integer input, result is 1+0j) or sqrt(9) integer.
# ---------------------------------------------------------------------------

invariant cmath_extra6.sqrt.one_int_real:
  description: "cmath.sqrt(1).real == 1.0 — sqrt of integer 1 has unit real part"
  category: sqrt
  kind: python_call_eq
  function: sqrt
  args: [1]
  method: real
  expected: 1.0

invariant cmath_extra6.sqrt.one_int_imag:
  description: "cmath.sqrt(1).imag == 0.0 — sqrt of integer 1 has zero imaginary part"
  category: sqrt
  kind: python_call_eq
  function: sqrt
  args: [1]
  method: imag
  expected: 0.0

invariant cmath_extra6.sqrt.nine_int_real:
  description: "cmath.sqrt(9).real == 3.0 — sqrt of integer 9 has real part 3.0"
  category: sqrt
  kind: python_call_eq
  function: sqrt
  args: [9]
  method: real
  expected: 3.0

# ---------------------------------------------------------------------------
# __module__ checks — confirm symbols belong to the cmath module
#
# cmath_extra2 checks phase.__module__ == 'cmath'.
# No prior spec checks isclose.__module__ or sqrt.__module__.
# ---------------------------------------------------------------------------

invariant cmath_extra6.isclose.module:
  description: "cmath.isclose.__module__ == 'cmath' — isclose is defined in the cmath module"
  category: function_identity
  kind: python_call_eq
  function: isclose.__module__.__eq__
  args: ["cmath"]
  expected: true

invariant cmath_extra6.sqrt.module:
  description: "cmath.sqrt.__module__ == 'cmath' — sqrt is defined in the cmath module"
  category: function_identity
  kind: python_call_eq
  function: sqrt.__module__.__eq__
  args: ["cmath"]
  expected: true
