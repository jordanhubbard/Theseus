spec: hashlib_extra109
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size and type names / sha3_256/sha3_512 HASH type identity / HASH.update/__hexdigest qualname string equality (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2, __bases__[0].__name__=='object') / HASH method qualname lengths (update=11, digest=11, hexdigest=14, copy=9) / md5/sha1/sha256/sha512 digest_size and block_size (table + invariants)."
    - "hashlib_extra106.zspec.zsdl — covers pbkdf2_hmac/scrypt __class__.__name__/__qualname__/__len__() and __name__.__eq__ / file_digest __qualname__/__name__/__module__.__len__() / sha3_224/256/384/512 and shake_128/256 __name__.__len__() (table + invariants)."
    - "hashlib_extra105.zspec.zsdl — covers sha3_*/shake_* __qualname__.__len__() / pbkdf2_hmac/__module__ / scrypt/__qualname__/__module__ / blake2b/blake2s __qualname__.__len__()==7 and __mro__/__bases__ (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class/module/qualname / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* __qualname__/__module__ equality and __class__.__name__ / file_digest class/qualname/module equality / hashlib.__all__ class name and length (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra108; it does NOT duplicate invariants present in those files."
    - "Wave 268 theme: hashlib.algorithms_guaranteed and hashlib.algorithms_available class names and set membership / subset relationship / hashlib.new function code attributes (__code__.co_name, co_argcount, type().__name__, __module__)."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.algorithms_guaranteed) == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.algorithms_available) == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha256' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'md5' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha1' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha512' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha224' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha384' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2b' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2s' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_name == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.new).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib_extra99 anchors algorithms_guaranteed.__len__()==14 at table level; this spec anchors __class__.__name__ equality and subset/membership checks."
    - "Note: algorithms_guaranteed is a frozenset-like plain set of algorithm names guaranteed on all platforms; algorithms_available is a superset that may include OpenSSL-specific algorithms. On macOS 25.4.0 / Python 3.14.3, guaranteed=14 and available=19."
    - "Note: hashlib.new is a public API function whose internal implementation is __hash_new (co_name). It wraps the algorithm lookup so callers can use hashlib.new('sha256') instead of hashlib.sha256()."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
# hashlib.algorithms_guaranteed.__len__()==14
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_available.__len__()==19
# hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available)==True
#
# Wave 268 theme: algorithms_guaranteed and algorithms_available class names
# and sizes, and subset relationship.
#
# Both algorithms_guaranteed and algorithms_available are plain Python sets
# (not frozenset). On Python 3.14.3 / macOS 25.4.0, algorithms_guaranteed
# has 14 members (the standard set required by all Python implementations)
# and algorithms_available has 19 members (OpenSSL may add extras).
# algorithms_guaranteed is always a subset of algorithms_available.
# hashlib_extra99 anchors algorithms_guaranteed.__len__()==14 at table level;
# no prior hashlib spec anchors __class__.__name__ or the subset relationship
# or algorithms_available.__len__() as a grouped table under hashhash109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra109.algorithms_sets_class_and_size:
  description: "algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_guaranteed.__len__()==14 / algorithms_available.__class__.__name__.__eq__('set')==True / algorithms_available.__len__()==19 / algorithms_guaranteed.issubset(algorithms_available)==True — both are plain set objects (not frozenset); guaranteed=14 (required on all platforms); available=19 (includes OpenSSL extras on macOS 25.4.0); guaranteed is always subset of available; extra99 anchors guaranteed.__len__()==14; first hashhash109 anchor grouping class names, sizes, and subset relationship"
  kind: python_call_eq
  category: set_properties
  id_prefix: hashhash109

  columns: [id, function, args, expected, description]
  rows:
    - [algos_guar_class,    "algorithms_guaranteed.__class__.__name__.__eq__",    ["set"], true, "algorithms_guaranteed.__class__.__name__ is 'set' (plain Python set, not frozenset)"]
    - [algos_guar_len,      "algorithms_guaranteed.__len__",                      [],      14,   "algorithms_guaranteed has 14 members (guaranteed on all Python platforms)"]
    - [algos_avail_class,   "algorithms_available.__class__.__name__.__eq__",     ["set"], true, "algorithms_available.__class__.__name__ is 'set' (plain Python set)"]
    - [algos_avail_len,     "algorithms_available.__len__",                       [],      19,   "algorithms_available has 19 members on Python 3.14.3 macOS 25.4.0 (includes OpenSSL extras)"]
    - [algos_guar_subset,   "algorithms_guaranteed.issubset",                     ["algorithms_available"], true, "algorithms_guaranteed.issubset(algorithms_available) == True (guaranteed is always subset of available)"]

# ---------------------------------------------------------------------------
# 'sha256' in hashlib.algorithms_guaranteed
# 'md5' in hashlib.algorithms_guaranteed
# 'sha1' in hashlib.algorithms_guaranteed
# 'sha512' in hashlib.algorithms_guaranteed
# 'blake2b' in hashlib.algorithms_guaranteed
#
# Wave 268 theme: membership of core algorithm names in algorithms_guaranteed.
#
# The algorithms_guaranteed set contains the names of algorithms available on
# all Python platforms. sha256, md5, sha1, sha512, blake2b, blake2s, sha224,
# sha384 are all guaranteed members. The __contains__ method on the set returns
# True for each. No prior hashlib spec anchors algorithms_guaranteed.__contains__
# calls for these names as a grouped table under hashhash109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra109.algorithms_guaranteed_membership:
  description: "'sha256' in algorithms_guaranteed==True / 'md5' in algorithms_guaranteed==True / 'sha1' in algorithms_guaranteed==True / 'sha512' in algorithms_guaranteed==True / 'blake2b' in algorithms_guaranteed==True — core hash algorithm names are guaranteed members; algorithms_guaranteed contains all standard SHA-2, MD5, SHA-1, and BLAKE2 names; no prior hashlib spec anchors __contains__ calls for these names; first hashhash109 anchor for membership tests"
  kind: python_call_eq
  category: set_membership
  id_prefix: hashhash109

  columns: [id, function, args, expected, description]
  rows:
    - [guar_has_sha256,  "algorithms_guaranteed.__contains__",  ["sha256"],  true, "'sha256' is in algorithms_guaranteed (SHA-2 256-bit; universally available)"]
    - [guar_has_md5,     "algorithms_guaranteed.__contains__",  ["md5"],     true, "'md5' is in algorithms_guaranteed (MD5; required despite being cryptographically weak)"]
    - [guar_has_sha1,    "algorithms_guaranteed.__contains__",  ["sha1"],    true, "'sha1' is in algorithms_guaranteed (SHA-1; required despite being deprecated)"]
    - [guar_has_sha512,  "algorithms_guaranteed.__contains__",  ["sha512"],  true, "'sha512' is in algorithms_guaranteed (SHA-2 512-bit; universally available)"]
    - [guar_has_blake2b, "algorithms_guaranteed.__contains__",  ["blake2b"], true, "'blake2b' is in algorithms_guaranteed (BLAKE2b; added in Python 3.6)"]

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_name.__eq__('__hash_new')
# hashlib.new.__code__.co_argcount.__eq__(1)
# type(hashlib.new).__name__.__eq__('function')
# hashlib.new.__module__.__eq__('hashlib')
# 'blake2s' in hashlib.algorithms_guaranteed
#
# Wave 268 theme: hashlib.new function code attributes and blake2s membership.
#
# hashlib.new is the public constructor function that looks up an algorithm by
# name. Its internal code object is named '__hash_new' (co_name) and it takes
# 1 positional argument (co_argcount==1: the algorithm name string). type(new)
# is 'function' (a regular Python function, not a builtin). Its __module__ is
# 'hashlib'. blake2s is also guaranteed like blake2b. No prior hashlib spec
# anchors hashlib.new.__code__ attributes or type(new).__name__ as a grouped
# table under hashhash109. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra109.new_code_attrs_and_blake2s:
  description: "new.__code__.co_name.__eq__('__hash_new')==True / new.__code__.co_argcount.__eq__(1)==True / type(new).__name__.__eq__('function')==True / new.__module__.__eq__('hashlib')==True / 'blake2s' in algorithms_guaranteed==True — hashlib.new wraps algorithm lookup via __hash_new; co_argcount==1 (the algorithm name); type is 'function' (Python-level, not builtin); __module__=='hashlib'; blake2s is also guaranteed like blake2b; no prior spec anchors new.__code__ attributes; first hashhash109 anchor"
  kind: python_call_eq
  category: function_attributes
  id_prefix: hashhash109

  columns: [id, function, args, expected, description]
  rows:
    - [new_co_name_eq,    "new.__code__.co_name.__eq__",       ["__hash_new"], true, "hashlib.new.__code__.co_name is '__hash_new' (internal implementation name)"]
    - [new_co_argcount,   "new.__code__.co_argcount.__eq__",   [1],            true, "hashlib.new.__code__.co_argcount is 1 (the algorithm name string argument)"]
    - [new_type_function, "new.__class__.__name__.__eq__",     ["function"],   true, "type(hashlib.new).__name__ is 'function' (Python-level function, not builtin)"]
    - [new_module_eq,     "new.__module__.__eq__",             ["hashlib"],    true, "hashlib.new.__module__ is 'hashlib' (defined in Lib/hashlib.py)"]
    - [guar_has_blake2s,  "algorithms_guaranteed.__contains__", ["blake2s"],   true, "'blake2s' is in algorithms_guaranteed (BLAKE2s 32-bit variant; added in Python 3.6)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__()==14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. This is the count of hash
# algorithm names guaranteed to be available on all Python implementations.
# The 14 members are: md5, sha1, sha224, sha256, sha384, sha512,
# blake2b, blake2s, sha3_224, sha3_256, sha3_384, sha3_512, shake_128,
# shake_256. hashlib_extra99 anchors this value at table level; no prior
# hashlib spec anchors algorithms_guaranteed.__len__()==14 as a standalone
# under hashhash109. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra109.algorithms_guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — the 14 guaranteed algorithms are: md5, sha1, sha224, sha256, sha384, sha512, blake2b, blake2s, sha3_224, sha3_256, sha3_384, sha3_512, shake_128, shake_256; guaranteed on all Python platforms regardless of OpenSSL version; extra99 anchors at table level; first standalone under hashhash109"
  category: set_properties
  kind: python_call_eq
  function: "algorithms_guaranteed.__len__"
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__()==19 — standalone
#
# hashlib.algorithms_available.__len__() is 19. This is the count of hash
# algorithm names available on this specific platform (Python 3.14.3,
# macOS/Darwin 25.4.0). algorithms_available is always a superset of
# algorithms_guaranteed (14 members); the extra 5 are OpenSSL-provided
# algorithms not guaranteed on all platforms. No prior hashlib spec anchors
# algorithms_available.__len__()==19 as a standalone under hashhash109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra109.algorithms_available_len_19:
  description: "hashlib.algorithms_available.__len__() == 19 — platform-specific count on Python 3.14.3 macOS 25.4.0; 14 guaranteed + 5 additional OpenSSL-provided algorithms; algorithms_available is always a superset of algorithms_guaranteed; no prior hashlib spec anchors this as standalone; first standalone under hashhash109"
  category: set_properties
  kind: python_call_eq
  function: "algorithms_available.__len__"
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_name.__eq__('__hash_new') — standalone
#
# hashlib.new.__code__.co_name is '__hash_new'. The hashlib.new() public API
# function is internally implemented as __hash_new in Lib/hashlib.py. The
# leading double-underscore in the co_name is a Python convention for
# name-mangled private names used internally but exposed via a public alias.
# co_name reflects the actual def statement name in the source, while the
# public name 'new' is the module-level alias. No prior hashlib spec anchors
# hashlib.new.__code__.co_name as a standalone under hashhash109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra109.new_co_name_hash_new:
  description: "hashlib.new.__code__.co_name.__eq__('__hash_new') == True — hashlib.new() is internally named __hash_new in Lib/hashlib.py; leading double-underscore indicates internal name exposed via public alias 'new'; co_name reflects def statement name in source; no prior hashlib spec anchors new.__code__.co_name as standalone; first standalone under hashhash109"
  category: function_attributes
  kind: python_call_eq
  function: "new.__code__.co_name.__eq__"
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available) — standalone
#
# hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available) is True.
# By design in Python's hashlib, algorithms_guaranteed is always a proper
# subset of algorithms_available: every guaranteed algorithm is also available,
# plus the platform may provide additional algorithms via OpenSSL. The subset
# relationship is enforced by the module implementation. No prior hashlib spec
# anchors the issubset() relationship as a standalone under hashhash109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra109.algorithms_guaranteed_subset_available:
  description: "hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available) == True — by design, guaranteed is always subset of available; every guaranteed algorithm is also available; platform may add extras via OpenSSL but cannot remove guaranteed ones; no prior hashlib spec anchors issubset as standalone; first standalone under hashhash109"
  category: set_properties
  kind: python_call_eq
  function: "algorithms_guaranteed.issubset"
  args: ["algorithms_available"]
  expected: true

# ---------------------------------------------------------------------------
# type(hashlib.new).__name__.__eq__('function') — standalone
#
# type(hashlib.new).__name__ is 'function'. hashlib.new is a regular Python
# function defined in Lib/hashlib.py, not a builtin_function_or_method. This
# contrasts with hashlib.md5, hashlib.sha256, etc. which are
# builtin_function_or_method (C-level callables from _hashlib). The 'function'
# type means hashlib.new has a __code__ object, __globals__, __closure__, etc.
# No prior hashlib spec anchors type(hashlib.new).__name__ as a standalone
# under hashhash109. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra109.new_type_is_function:
  description: "type(hashlib.new).__name__.__eq__('function') == True — hashlib.new is a Python-level function (not builtin_function_or_method like md5/sha256); has __code__, __globals__, __closure__ attributes; allows introspection via co_name=='__hash_new'; no prior hashlib spec anchors type(new).__name__ as standalone; first standalone under hashhash109"
  category: function_attributes
  kind: python_call_eq
  function: "new.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

