spec: lodash_add
version: ">=4.0.0"
backend: node(lodash.add)

docs: https://lodash.com/docs/#add

provenance:
  derived_from:
    - "lodash.add README — https://www.npmjs.com/package/lodash.add"
    - "Test vectors verified with lodash.add@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.add exports the _.add function directly as module.exports."
    - "add(augend, addend) adds two numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns sum of two numbers."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_add.add:
  kind: node_module_call_eq
  function: ~
  category: add
  id_prefix: ladd

  columns: [id, args, expected]
  rows:
    - [positive,  [6, 4],      10]
    - [zero,      [0, 0],      0]
    - [negative,  [-1, 1],     0]
    - [float,     [1.5, 2.5],  4]
