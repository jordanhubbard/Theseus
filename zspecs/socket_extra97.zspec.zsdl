spec: socket_extra97
version: ">=3.9"
backend: python_module(socket)
extends: socket_extra96

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC __class__.__name__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW __class__.__name__=='SocketKind' / IPPROTO_TCP/IPPROTO_UDP/SOL_SOCKET __class__.__name__=='int' / AddressFamily/SocketKind __bases__[0].__name__=='IntEnum' / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout builtin / getaddrinfo/create_connection Python function (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers socket.AddressFamily enum member values and names / socket.SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names for bind/connect/recv/send/etc. (table + invariants)."
    - "socket_extra92.zspec.zsdl — covers socket.socket class string identity / exception hierarchy / AddressFamily/SocketKind class identity (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra96; it does NOT duplicate invariants present in those files."
    - "Wave 260 theme: socket.socket Python-level method class names and modules — socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.SocketIO class identity / socket.socket method qualnames (send/sendall/fileno)."
    - "socket.socket.__init__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__class__.__name__ == 'ABCMeta'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__qualname__ == 'SocketIO'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__bases__[0].__name__ == 'RawIOBase'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__qualname__ == 'socket.send'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__qualname__ == 'socket.sendall'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__qualname__ == 'socket.fileno'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.__init__, accept, makefile, and close are pure-Python functions (class 'function') defined in Lib/socket.py, distinct from the C-level method_descriptors like connect, bind, recv, and send."
    - "Note: socket.SocketIO is a class with metaclass ABCMeta (not 'type') because it inherits from RawIOBase which uses ABCMeta as its metaclass via the io module ABC machinery."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__init__.__class__.__name__.__eq__('function')
# socket.socket.accept.__class__.__name__.__eq__('function')
# socket.socket.makefile.__class__.__name__.__eq__('function')
# socket.socket.close.__class__.__name__.__eq__('function')
#
# Wave 260 theme: socket.socket Python-level method class names.
#
# socket.socket is a Python class (Lib/socket.py) that wraps _socket.socket (C).
# Its __init__, accept, makefile, and close are pure-Python methods (class 'function'),
# as opposed to connect, bind, recv, and send which are inherited C-level
# method_descriptor objects from _socket.socket. This distinction reflects the
# two-layer architecture: socket.socket adds Python-level error handling and
# convenience methods on top of the C implementation.
# socket_extra93 anchors C-level method_descriptor class names; no prior socket
# spec anchors these four Python function class names together under socketsockid97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra97.socket_socket_python_method_class_names:
  description: "socket.socket.__init__/__class__.__name__.__eq__('function')==True / socket.accept/__class__.__name__.__eq__('function')==True / socket.makefile/__class__.__name__.__eq__('function')==True / socket.close/__class__.__name__.__eq__('function')==True — socket.socket.__init__/accept/makefile/close are pure-Python methods defined in Lib/socket.py; distinct from C-level method_descriptors like connect/bind/recv; socket_extra93 anchors the C-level names; no prior socket spec anchors these four together; first socketsockid97 anchor for Python-level socket method class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketsockid97

  columns: [id, function, args, expected]
  rows:
    - [init_class,     "socket.__init__.__class__.__name__.__eq__",    ["function"], true]
    - [accept_class,   "socket.accept.__class__.__name__.__eq__",      ["function"], true]
    - [makefile_class, "socket.makefile.__class__.__name__.__eq__",    ["function"], true]
    - [close_class,    "socket.close.__class__.__name__.__eq__",       ["function"], true]

# ---------------------------------------------------------------------------
# socket.socket.__init__.__module__.__eq__('socket')
# socket.socket.accept.__module__.__eq__('socket')
# socket.socket.makefile.__module__.__eq__('socket')
# socket.socket.close.__module__.__eq__('socket')
#
# Wave 260 theme: socket.socket Python-level method __module__ identity.
#
# The four Python-level socket.socket methods (__init__, accept, makefile, close)
# all have __module__ == 'socket', confirming they are defined in Lib/socket.py
# (not in the _socket C extension). This cross-check pairs with the class name
# cross-check above. No prior socket spec anchors these four __module__.__eq__
# calls together under socketsockid97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra97.socket_socket_python_method_modules:
  description: "socket.socket.__init__/__module__.__eq__('socket')==True / socket.accept/__module__.__eq__('socket')==True / socket.makefile/__module__.__eq__('socket')==True / socket.close/__module__.__eq__('socket')==True — the four Python-level socket methods all originate from Lib/socket.py (__module__=='socket'); distinct from C-level methods that carry no __module__; no prior socket spec anchors these four together; first socketsockid97 anchor for Python-level socket method __module__ cross-check"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketsockid97

  columns: [id, function, args, expected]
  rows:
    - [init_module,     "socket.__init__.__module__.__eq__",    ["socket"], true]
    - [accept_module,   "socket.accept.__module__.__eq__",      ["socket"], true]
    - [makefile_module, "socket.makefile.__module__.__eq__",    ["socket"], true]
    - [close_module,    "socket.close.__module__.__eq__",       ["socket"], true]

# ---------------------------------------------------------------------------
# socket.SocketIO.__class__.__name__.__eq__('ABCMeta')
# socket.SocketIO.__module__.__eq__('socket')
# socket.SocketIO.__qualname__.__eq__('SocketIO')
# socket.SocketIO.__bases__[0].__name__.__eq__('RawIOBase')
# socket.socket.send.__qualname__.__eq__('socket.send')
# socket.socket.sendall.__qualname__.__eq__('socket.sendall')
# socket.socket.fileno.__qualname__.__eq__('socket.fileno')
#
# Wave 260 theme: socket.SocketIO class identity and C-level method qualnames.
#
# socket.SocketIO is a class with metaclass ABCMeta (not 'type') because it
# inherits from RawIOBase which uses ABCMeta via the io module ABC machinery.
# Its __module__ is 'socket' and __qualname__ is 'SocketIO'. SocketIO wraps a
# socket.socket as an io.RawIOBase to allow use with io streams.
# socket.socket.send, sendall, and fileno are C-level method_descriptors whose
# __qualname__ is 'socket.<name>'. No prior socket spec anchors these seven
# checks together under socketsockid97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra97.socketio_class_and_method_qualnames:
  description: "socket.SocketIO/__class__.__name__.__eq__('ABCMeta')==True / SocketIO/__module__.__eq__('socket')==True / SocketIO/__qualname__.__eq__('SocketIO')==True / SocketIO/__bases__[0]/__name__.__eq__('RawIOBase')==True / socket.send/__qualname__.__eq__('socket.send')==True / socket.sendall/__qualname__.__eq__('socket.sendall')==True / socket.fileno/__qualname__.__eq__('socket.fileno')==True — SocketIO is an ABCMeta class (metaclass is ABCMeta because it inherits from RawIOBase); it wraps socket as an io stream; send/sendall/fileno are C-level method_descriptors with 'socket.' qualname prefix; no prior socket spec anchors these together; first socketsockid97 anchor for SocketIO identity and send/sendall/fileno qualnames"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketsockid97

  columns: [id, function, args, expected]
  rows:
    - [socketio_class,   "SocketIO.__class__.__name__.__eq__",    ["ABCMeta"],    true]
    - [socketio_module,  "SocketIO.__module__.__eq__",            ["socket"],     true]
    - [socketio_qualname, "SocketIO.__qualname__.__eq__",         ["SocketIO"],   true]
    - [socketio_base,    "SocketIO.__bases__[0].__name__.__eq__", ["RawIOBase"],  true]
    - [send_qualname,    "socket.send.__qualname__.__eq__",       ["socket.send"],    true]
    - [sendall_qualname, "socket.sendall.__qualname__.__eq__",    ["socket.sendall"], true]
    - [fileno_qualname,  "socket.fileno.__qualname__.__eq__",     ["socket.fileno"],  true]

# ---------------------------------------------------------------------------
# socket.socket.__init__.__class__.__name__.__eq__('function') — standalone
#
# socket.socket.__init__.__class__.__name__ is 'function'. socket.socket is a
# Python class (Lib/socket.py) that wraps the C-level _socket.socket. Its
# __init__ is a pure-Python function that takes the address family, socket type,
# and protocol parameters and delegates to the C implementation. This is different
# from C-extension types (like struct.Struct) where __init__ is a wrapper_descriptor.
# No prior socket spec anchors socket.__init__.__class__.__name__.__eq__('function')
# as a standalone under socketsockid97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra97.socket_init_class_function:
  description: "socket.socket.__init__.__class__.__name__.__eq__('function') == True — socket.socket is a Python class wrapping _socket.socket; its __init__ is a pure-Python function (not a wrapper_descriptor like struct.Struct.__init__); no prior socket spec anchors this as a standalone; first standalone for socket.socket.__init__ class name under socketsockid97"
  category: type_identity
  kind: python_call_eq
  function: "socket.__init__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketIO.__class__.__name__.__eq__('ABCMeta') — standalone
#
# socket.SocketIO.__class__.__name__ is 'ABCMeta'. SocketIO is a class with
# the ABCMeta metaclass because it inherits from io.RawIOBase, which is an
# abstract base class defined using ABCMeta. SocketIO wraps a socket.socket
# instance as an io.RawIOBase, enabling use of socket connections with Python's
# io stream interface. Unlike ordinary classes (which have metaclass 'type'),
# SocketIO's metaclass is 'ABCMeta'. No prior socket spec anchors
# SocketIO.__class__.__name__.__eq__('ABCMeta') as a standalone under socketsockid97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra97.socketio_class_abcmeta:
  description: "socket.SocketIO.__class__.__name__.__eq__('ABCMeta') == True — SocketIO wraps a socket as io.RawIOBase; its metaclass is ABCMeta (inherited from RawIOBase ABC machinery), not the ordinary 'type'; no prior socket spec anchors this as a standalone; first standalone for SocketIO metaclass name under socketsockid97"
  category: type_identity
  kind: python_call_eq
  function: "SocketIO.__class__.__name__.__eq__"
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__init__.__module__.__eq__('socket') — standalone
#
# socket.socket.__init__.__module__ is 'socket'. socket.socket.__init__ is a
# pure-Python function defined in Lib/socket.py. Its __module__ confirms it
# originates from the 'socket' module (Lib/socket.py), not from the _socket C
# extension. No prior socket spec anchors socket.__init__.__module__.__eq__ as a
# standalone under socketsockid97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra97.socket_init_module_socket:
  description: "socket.socket.__init__.__module__.__eq__('socket') == True — socket.socket.__init__ is a pure-Python function from Lib/socket.py; its __module__ is 'socket' (not '_socket'); no prior socket spec anchors this as a standalone; first standalone for socket.__init__ __module__ under socketsockid97"
  category: type_identity
  kind: python_call_eq
  function: "socket.__init__.__module__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketIO.__bases__[0].__name__.__eq__('RawIOBase') — standalone
#
# socket.SocketIO.__bases__[0].__name__ is 'RawIOBase'. SocketIO inherits directly
# from io.RawIOBase, the abstract base class for raw binary I/O. This inheritance
# makes SocketIO usable anywhere a raw I/O stream is expected. The RawIOBase
# abstract base class defines the raw read/write interface. No prior socket spec
# anchors SocketIO.__bases__[0].__name__.__eq__('RawIOBase') as a standalone under
# socketsockid97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra97.socketio_base_rawiobase:
  description: "socket.SocketIO.__bases__[0].__name__.__eq__('RawIOBase') == True — SocketIO inherits from io.RawIOBase (abstract base for raw binary I/O), making it usable as a raw I/O stream; no prior socket spec anchors SocketIO base class name as a standalone; first standalone for SocketIO.__bases__[0].__name__ under socketsockid97"
  category: type_identity
  kind: python_call_eq
  function: "SocketIO.__bases__[0].__name__.__eq__"
  args: ["RawIOBase"]
  expected: true
