spec: struct_extra1906
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "struct.Struct is a C-extension type; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "struct.error is a pure-Python exception subclass of Exception; its own __dict__ does not contain __match_args__ (not inherited from Exception)."
    - "struct.Struct.__qualname__ == 'Struct' — top-level C-extension type; __module__ == '_struct' (the backing C extension)."
    - "struct.error.__qualname__ == 'error' — top-level Python exception class defined in struct."
    - "struct.Struct.__dict__ contains pack, unpack, pack_into, unpack_from, iter_unpack, format, size, __new__, __repr__, __sizeof__."
    - "struct.error.__dict__ contains only __module__, __weakref__, __doc__ — no protocol dunders in its own dict."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra1906.reversed_protocol:
  description: "struct types __reversed__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1906

  columns: [id, function, args, expected]
  rows:
    - ["st1906001", "struct.Struct.__dict__.__contains__", ["__reversed__"], false]
    - ["st1906002", "struct.error.__dict__.__contains__", ["__reversed__"], false]

table struct_extra1906.missing_protocol:
  description: "struct types __missing__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1906

  columns: [id, function, args, expected]
  rows:
    - ["st1906011", "struct.Struct.__dict__.__contains__", ["__missing__"], false]
    - ["st1906012", "struct.error.__dict__.__contains__", ["__missing__"], false]

table struct_extra1906.match_args_protocol:
  description: "struct types __match_args__ dict-presence checks (structural pattern matching, 3.10+)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1906

  columns: [id, function, args, expected]
  rows:
    - ["st1906021", "struct.Struct.__dict__.__contains__", ["__match_args__"], false]
    - ["st1906022", "struct.error.__dict__.__contains__", ["__match_args__"], false]

table struct_extra1906.qualname_values:
  description: "struct class __qualname__ and __name__ values"
  kind: python_call_eq
  category: qualname_values
  id_prefix: st1906

  columns: [id, function, args, expected]
  rows:
    - ["st1906031", "struct.Struct.__qualname__", [], "Struct"]
    - ["st1906032", "struct.error.__qualname__", [], "error"]
    - ["st1906033", "struct.Struct.__name__", [], "Struct"]
    - ["st1906034", "struct.error.__name__", [], "error"]
    - ["st1906035", "struct.Struct.__module__", [], "_struct"]
    - ["st1906036", "struct.error.__module__", [], "struct"]

table struct_extra1906.struct_dict_method_presence:
  description: "struct.Struct __dict__ contains expected C-level method descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1906

  columns: [id, function, args, expected]
  rows:
    - ["st1906041", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st1906042", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st1906043", "struct.Struct.__dict__.__contains__", ["pack_into"], true]
    - ["st1906044", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1906045", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1906046", "struct.Struct.__dict__.__contains__", ["format"], true]
    - ["st1906047", "struct.Struct.__dict__.__contains__", ["size"], true]
    - ["st1906048", "struct.Struct.__dict__.__contains__", ["__new__"], true]
    - ["st1906049", "struct.Struct.__dict__.__contains__", ["__repr__"], true]
    - ["st1906050", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]

table struct_extra1906.struct_dict_absent_protocol_attrs:
  description: "struct.Struct __dict__ absent protocol dunders"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1906

  columns: [id, function, args, expected]
  rows:
    - ["st1906061", "struct.Struct.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["st1906062", "struct.Struct.__dict__.__contains__", ["__type_params__"], false]
    - ["st1906063", "struct.Struct.__dict__.__contains__", ["__length_hint__"], false]
    - ["st1906064", "struct.error.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["st1906065", "struct.error.__dict__.__contains__", ["__type_params__"], false]
    - ["st1906066", "struct.error.__dict__.__contains__", ["__length_hint__"], false]

table struct_extra1906.error_dict_presence:
  description: "struct.error __dict__ contains only its own minimal attrs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1906

  columns: [id, function, args, expected]
  rows:
    - ["st1906071", "struct.error.__dict__.__contains__", ["__module__"], true]
    - ["st1906072", "struct.error.__dict__.__contains__", ["__doc__"], true]
    - ["st1906073", "struct.error.__dict__.__contains__", ["__weakref__"], true]
    - ["st1906074", "struct.error.__dict__.__contains__", ["__init__"], false]
    - ["st1906075", "struct.error.__dict__.__contains__", ["__new__"], false]
