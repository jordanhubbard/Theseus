spec: traceback_extra10
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra9.zspec.zsdl."
    - "traceback_extra9 covers: TracebackException.format/format_exception_only/print method qualnames; TracebackException.from_exception classmethod qualname; StackSummary.extract classmethod qualname; FrameSummary.__init__/__repr__ qualnames; MRO lengths for TracebackException(2)/StackSummary(3)/FrameSummary(2)."
    - "traceback_extra8 covers: class __name__/__module__ via __eq__ predicate; function __name__ via __eq__ for print_exc/print_tb/print_stack/format_exc/format_tb/format_stack/clear_frames."
    - "traceback_extra7 covers: function __module__ for all public functions; StackSummary.from_list.__func__.__qualname__."
    - "NOT yet covered: TracebackException.__mro__[0] and [1] by index as standalone invariants."
    - "NOT yet covered: StackSummary.__mro__[0], [1], [2] by index as standalone invariants."
    - "NOT yet covered: FrameSummary.__mro__[0] and [1] by index as standalone invariants."
    - "NOT yet covered: StackSummary.format.__qualname__ == 'StackSummary.format'."
    - "NOT yet covered: TracebackException.__init__.__qualname__ == 'TracebackException.__init__'."
    - "TracebackException MRO: [TracebackException, object] — MRO[0] is TracebackException, MRO[1] is object."
    - "StackSummary MRO: [StackSummary, list, object] — MRO[0] is StackSummary, MRO[1] is list, MRO[2] is object."
    - "FrameSummary MRO: [FrameSummary, object] — MRO[0] is FrameSummary, MRO[1] is object."
    - "StackSummary.format is an instance method; __qualname__ == 'StackSummary.format'."
    - "TracebackException.__init__ is the constructor; __qualname__ == 'TracebackException.__init__'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TracebackException MRO entries by index
#
# traceback_extra9 confirmed the MRO length is 2.
# No prior spec accesses MRO[0] or MRO[1] by index for TracebackException.
# MRO[0] is the class itself; MRO[1] is object (direct base).
# ---------------------------------------------------------------------------

invariant traceback_extra10.TracebackException.mro_0:
  description: "traceback.TracebackException.__mro__[0].__name__ == 'TracebackException'"
  category: mro_entries
  kind: python_call_eq
  function: TracebackException.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "TracebackException"

invariant traceback_extra10.TracebackException.mro_1:
  description: "traceback.TracebackException.__mro__[1].__name__ == 'object' — direct base"
  category: mro_entries
  kind: python_call_eq
  function: TracebackException.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# StackSummary MRO entries by index
#
# traceback_extra9 confirmed the MRO length is 3.
# No prior spec accesses MRO[0], [1], or [2] by index for StackSummary.
# StackSummary subclasses list, so MRO is [StackSummary, list, object].
# ---------------------------------------------------------------------------

invariant traceback_extra10.StackSummary.mro_0:
  description: "traceback.StackSummary.__mro__[0].__name__ == 'StackSummary'"
  category: mro_entries
  kind: python_call_eq
  function: StackSummary.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "StackSummary"

invariant traceback_extra10.StackSummary.mro_1:
  description: "traceback.StackSummary.__mro__[1].__name__ == 'list' — StackSummary subclasses list"
  category: mro_entries
  kind: python_call_eq
  function: StackSummary.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "list"

invariant traceback_extra10.StackSummary.mro_2:
  description: "traceback.StackSummary.__mro__[2].__name__ == 'object' — root of MRO"
  category: mro_entries
  kind: python_call_eq
  function: StackSummary.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# FrameSummary MRO entries by index
#
# traceback_extra9 confirmed the MRO length is 2.
# No prior spec accesses MRO[0] or MRO[1] by index for FrameSummary.
# FrameSummary inherits directly from object.
# ---------------------------------------------------------------------------

invariant traceback_extra10.FrameSummary.mro_0:
  description: "traceback.FrameSummary.__mro__[0].__name__ == 'FrameSummary'"
  category: mro_entries
  kind: python_call_eq
  function: FrameSummary.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "FrameSummary"

invariant traceback_extra10.FrameSummary.mro_1:
  description: "traceback.FrameSummary.__mro__[1].__name__ == 'object' — direct base"
  category: mro_entries
  kind: python_call_eq
  function: FrameSummary.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# StackSummary.format — instance method __qualname__
#
# traceback_extra9 covers StackSummary.extract (classmethod) qualname.
# traceback_extra7 covers StackSummary.from_list (classmethod) qualname.
# No prior spec covers StackSummary.format, which is a regular instance method
# with __qualname__ == 'StackSummary.format'.
# ---------------------------------------------------------------------------

invariant traceback_extra10.StackSummary.format_qualname:
  description: "traceback.StackSummary.format.__qualname__ == 'StackSummary.format'"
  category: method_qualnames
  kind: python_call_eq
  function: StackSummary.format.__qualname__.__eq__
  args: ["StackSummary.format"]
  expected: true

# ---------------------------------------------------------------------------
# TracebackException.__init__ — constructor __qualname__
#
# traceback_extra9 covers TracebackException.format/format_exception_only/print
# and the from_exception classmethod. No prior spec covers __init__.__qualname__
# for TracebackException. The constructor is a plain instance method with
# __qualname__ == 'TracebackException.__init__'.
# ---------------------------------------------------------------------------

invariant traceback_extra10.TracebackException.init_qualname:
  description: "traceback.TracebackException.__init__.__qualname__ == 'TracebackException.__init__'"
  category: method_qualnames
  kind: python_call_eq
  function: TracebackException.__init__.__qualname__.__eq__
  args: ["TracebackException.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# FrameSummary special methods — __getitem__ and __len__ qualnames
#
# FrameSummary defines its own __getitem__ and __len__ methods (it provides
# sequence-like access to (filename, lineno, name, line) tuples).
# No prior spec records the __qualname__ of these special methods.
# ---------------------------------------------------------------------------

invariant traceback_extra10.FrameSummary.getitem_qualname:
  description: "traceback.FrameSummary.__getitem__.__qualname__ == 'FrameSummary.__getitem__'"
  category: method_qualnames
  kind: python_call_eq
  function: FrameSummary.__getitem__.__qualname__.__eq__
  args: ["FrameSummary.__getitem__"]
  expected: true

invariant traceback_extra10.FrameSummary.len_qualname:
  description: "traceback.FrameSummary.__len__.__qualname__ == 'FrameSummary.__len__'"
  category: method_qualnames
  kind: python_call_eq
  function: FrameSummary.__len__.__qualname__.__eq__
  args: ["FrameSummary.__len__"]
  expected: true
