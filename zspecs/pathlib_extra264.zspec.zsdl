spec: pathlib_extra264
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath component access, parent, parts, predicates, manipulation, joining, string representations"
    - "pathlib_extra.zspec.zsdl — covers Path/PurePosixPath class name/module, PurePosixPath component access variants, parent, truediv, parts, is_absolute"
    - "pathlib_extra263.zspec.zsdl — covers PurePosixPath/PureWindowsPath class identity and Path rename/replace/symlink_to/hardlink_to"
  notes:
    - "pathlib.Path.write_text/write_bytes/read_text/read_bytes/open all have __qualname__ 'Path.<method>'."
    - "pathlib.Path.write_text.__class__.__name__ == 'function' — defined in pure Python (Lib/pathlib/)."
    - "pathlib.PurePath.__truediv__/__str__/__fspath__ all have __qualname__ 'PurePath.<method>'."
    - "pathlib.PurePath.__truediv__.__class__.__name__ == 'function' — pure Python implementation."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path — write/read method qualnames
# ---------------------------------------------------------------------------

table pathlib_extra264.Path.method_qualnames_write_read:
  description: "write_text/write_bytes/read_text/read_bytes/open qualnames are 'Path.<method>'"
  kind: python_call_eq
  category: identity
  id_prefix: method_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [write_text_qualname,  Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true, "write_text qualname"]
    - [write_bytes_qualname, Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true, "write_bytes qualname"]
    - [read_text_qualname,   Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true, "read_text qualname"]
    - [read_bytes_qualname,  Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"],  true, "read_bytes qualname"]
    - [open_qualname,        Path.open.__qualname__.__eq__,        ["Path.open"],        true, "open qualname"]

# ---------------------------------------------------------------------------
# Path — write/read method class names
# ---------------------------------------------------------------------------

table pathlib_extra264.Path.method_class_names_write_read:
  description: "write_text/write_bytes/read_text/read_bytes/open are 'function' objects"
  kind: python_call_eq
  category: identity
  id_prefix: method_class

  columns: [id, function, args, expected, description]
  rows:
    - [write_text_class,  Path.write_text.__class__.__name__.__eq__,  ["function"], true, "write_text is function"]
    - [write_bytes_class, Path.write_bytes.__class__.__name__.__eq__, ["function"], true, "write_bytes is function"]
    - [read_text_class,   Path.read_text.__class__.__name__.__eq__,   ["function"], true, "read_text is function"]
    - [read_bytes_class,  Path.read_bytes.__class__.__name__.__eq__,  ["function"], true, "read_bytes is function"]
    - [open_class,        Path.open.__class__.__name__.__eq__,        ["function"], true, "open is function"]

# ---------------------------------------------------------------------------
# PurePath — dunder method qualnames: __truediv__, __str__, __fspath__
# ---------------------------------------------------------------------------

table pathlib_extra264.PurePath.dunder_qualnames:
  description: "__truediv__/__str__/__fspath__ qualnames are 'PurePath.<method>'"
  kind: python_call_eq
  category: identity
  id_prefix: dunder_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [truediv_qualname, PurePath.__truediv__.__qualname__.__eq__, ["PurePath.__truediv__"], true, "__truediv__ qualname"]
    - [str_qualname,     PurePath.__str__.__qualname__.__eq__,     ["PurePath.__str__"],     true, "__str__ qualname"]
    - [fspath_qualname,  PurePath.__fspath__.__qualname__.__eq__,  ["PurePath.__fspath__"],  true, "__fspath__ qualname"]

# ---------------------------------------------------------------------------
# PurePath — dunder method class name
# ---------------------------------------------------------------------------

invariant pathlib_extra264.PurePath.truediv_class:
  description: "pathlib.PurePath.__truediv__.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: PurePath.__truediv__.__class__.__name__.__eq__
  args: ["function"]
  expected: true
