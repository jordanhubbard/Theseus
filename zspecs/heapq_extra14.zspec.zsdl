spec: heapq_extra14
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
    - "heapq.zspec.zsdl — basic heapq invariants."
    - "heapq_extra.zspec.zsdl through heapq_extra13.zspec.zsdl — prior extras."
  notes:
    - "This spec extends heapq.zspec.zsdl through heapq_extra13.zspec.zsdl."
    - "Prior specs cover: __name__/__module__/__qualname__ for all 7 heapq functions; behavioral vectors for nlargest/nsmallest on varied inputs."
    - "This spec adds NEW axes:"
    - "  (1) __name__ equality invariants for all 7 functions from the extra14 namespace."
    - "  (2) __name__ length table for all 7 functions: heappush(8), heappop(7), heapify(7), heapreplace(11), heappushpop(11), nlargest(8), nsmallest(9)."
    - "  (3) nlargest(3, [1,2,3,4,5]) == [5,4,3] — canonical task-spec vector."
    - "  (4) nsmallest(3, [5,4,3,2,1]) == [1,2,3] — canonical task-spec vector."
    - "heapq.heappush.__name__ == 'heappush' — len 8. Verified Python 3.12 macOS."
    - "heapq.heappop.__name__ == 'heappop' — len 7. Verified."
    - "heapq.heapify.__name__ == 'heapify' — len 7. Verified."
    - "heapq.heapreplace.__name__ == 'heapreplace' — len 11. Verified."
    - "heapq.heappushpop.__name__ == 'heappushpop' — len 11. Verified."
    - "heapq.nlargest.__name__ == 'nlargest' — len 8. Verified."
    - "heapq.nsmallest.__name__ == 'nsmallest' — len 9. Verified."
    - "heapq.nlargest(3, [1,2,3,4,5]) == [5,4,3]. Verified."
    - "heapq.nsmallest(3, [5,4,3,2,1]) == [1,2,3]. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# heapq function __name__ attribute invariants
#
# All 7 heapq functions have __name__ equal to their canonical name.
# Prior specs confirm these from earlier namespaces; extra14 anchors them
# all as a coherent set.
# ---------------------------------------------------------------------------

invariant heapq_extra14.name.heappush:
  description: "heapq.heappush.__name__ == 'heappush' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: heappush.__name__.__eq__
  args: ["heappush"]
  expected: true

invariant heapq_extra14.name.heappop:
  description: "heapq.heappop.__name__ == 'heappop' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: heappop.__name__.__eq__
  args: ["heappop"]
  expected: true

invariant heapq_extra14.name.heapify:
  description: "heapq.heapify.__name__ == 'heapify' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: heapify.__name__.__eq__
  args: ["heapify"]
  expected: true

invariant heapq_extra14.name.heapreplace:
  description: "heapq.heapreplace.__name__ == 'heapreplace' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: heapreplace.__name__.__eq__
  args: ["heapreplace"]
  expected: true

invariant heapq_extra14.name.heappushpop:
  description: "heapq.heappushpop.__name__ == 'heappushpop' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: heappushpop.__name__.__eq__
  args: ["heappushpop"]
  expected: true

invariant heapq_extra14.name.nlargest:
  description: "heapq.nlargest.__name__ == 'nlargest' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: nlargest.__name__.__eq__
  args: ["nlargest"]
  expected: true

invariant heapq_extra14.name.nsmallest:
  description: "heapq.nsmallest.__name__ == 'nsmallest' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: nsmallest.__name__.__eq__
  args: ["nsmallest"]
  expected: true

# ---------------------------------------------------------------------------
# nlargest and nsmallest canonical task-spec vectors
#
# The task spec requires: nlargest(3, [1,2,3,4,5]) == [5,4,3] and
# nsmallest(3, [5,4,3,2,1]) == [1,2,3]. These are distinct input fixtures
# from heapq_extra13 which used [5,3,8,1,9,2] and other lists.
# ---------------------------------------------------------------------------

invariant heapq_extra14.nlargest.top3_ascending:
  description: "heapq.nlargest(3, [1,2,3,4,5]) == [5,4,3] — top 3 of ascending list"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [3, [1, 2, 3, 4, 5]]
  expected: [5, 4, 3]

invariant heapq_extra14.nsmallest.bottom3_descending:
  description: "heapq.nsmallest(3, [5,4,3,2,1]) == [1,2,3] — bottom 3 of descending list"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [3, [5, 4, 3, 2, 1]]
  expected: [1, 2, 3]

# ---------------------------------------------------------------------------
# __name__ length table — all 7 heapq functions
#
# heappush(8), heappop(7), heapify(7), heapreplace(11), heappushpop(11),
# nlargest(8), nsmallest(9). All verified at runtime.
# id_prefix hql14 does not conflict with any prior heapq spec.
# ---------------------------------------------------------------------------

table heapq_extra14.name_len.all_functions:
  description: "len of __name__ for all 7 heapq functions"
  kind: python_call_eq
  category: function_name_lengths
  id_prefix: hql14

  columns: [id, function, args, expected]
  rows:
    - [heappush_len,    heappush.__name__.__len__,    [], 8]
    - [heappop_len,     heappop.__name__.__len__,     [], 7]
    - [heapify_len,     heapify.__name__.__len__,     [], 7]
    - [heapreplace_len, heapreplace.__name__.__len__, [], 11]
    - [heappushpop_len, heappushpop.__name__.__len__, [], 11]
    - [nlargest_len,    nlargest.__name__.__len__,    [], 8]
    - [nsmallest_len,   nsmallest.__name__.__len__,   [], 9]
