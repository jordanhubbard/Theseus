spec: plistlib_extra2
version: ">=3.9"
backend: python_module(plistlib)

docs: https://docs.python.org/3/library/plistlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/plistlib.html — Python plistlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/plistlib.py"
  notes:
    - "This spec extends plistlib.zspec.zsdl and plistlib_extra.zspec.zsdl."
    - "plistlib.zspec.zsdl covers: loads/dumps/load/dump __name__; loads.__module__; InvalidFileException __name__ and base; FMT_XML.__ge__(1); dumps returns bytes."
    - "plistlib_extra.zspec.zsdl covers: loads/dumps/load/dump __name__ (table); FMT_XML.__class__.__name__; FMT_BINARY.__class__.__name__; FMT_XML == 1; FMT_BINARY == 2; PlistFormat.__name__; InvalidFileException.__name__ and base; UID.__name__ and __module__; FMT_XML != FMT_BINARY; FMT_XML MRO check."
    - "This spec adds: FMT_XML.name (enum member name attr); FMT_BINARY.name (enum member name attr); dumps.__module__; PlistFormat.__module__; InvalidFileException.__module__; table of __name__ checks for loads/dumps/load/dump."
    - "FMT_XML.name == 'FMT_XML' — IntEnum members have a .name attribute equal to their identifier."
    - "FMT_BINARY.name == 'FMT_BINARY' — same for FMT_BINARY."
    - "plistlib.dumps.__module__ == 'plistlib' — dumps is defined in the plistlib module."
    - "plistlib.PlistFormat.__module__ == 'plistlib' — PlistFormat is defined in the plistlib module."
    - "plistlib.InvalidFileException.__module__ == 'plistlib' — InvalidFileException is defined in plistlib."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FMT_XML.name — IntEnum member name attribute
# (plistlib/plistlib_extra cover __class__.__name__ and integer value; this
#  spec adds the .name attribute which returns the identifier string)
# ---------------------------------------------------------------------------

invariant plistlib_extra2.FMT_XML.name_attr:
  description: "plistlib.FMT_XML.name == 'FMT_XML' — IntEnum .name returns the member identifier"
  category: constants
  kind: python_call_eq
  function: FMT_XML.name.__eq__
  args: ["FMT_XML"]
  expected: true

invariant plistlib_extra2.FMT_BINARY.name_attr:
  description: "plistlib.FMT_BINARY.name == 'FMT_BINARY' — IntEnum .name returns the member identifier"
  category: constants
  kind: python_call_eq
  function: FMT_BINARY.name.__eq__
  args: ["FMT_BINARY"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — dumps, PlistFormat, InvalidFileException
# (plistlib.zspec.zsdl covers loads.__module__; this spec adds the remaining)
# ---------------------------------------------------------------------------

invariant plistlib_extra2.dumps.module:
  description: "plistlib.dumps.__module__ == 'plistlib'"
  category: module
  kind: python_call_eq
  function: dumps.__module__.__eq__
  args: ["plistlib"]
  expected: true

invariant plistlib_extra2.PlistFormat.module:
  description: "plistlib.PlistFormat.__module__ == 'plistlib'"
  category: module
  kind: python_call_eq
  function: PlistFormat.__module__.__eq__
  args: ["plistlib"]
  expected: true

invariant plistlib_extra2.InvalidFileException.module:
  description: "plistlib.InvalidFileException.__module__ == 'plistlib'"
  category: module
  kind: python_call_eq
  function: InvalidFileException.__module__.__eq__
  args: ["plistlib"]
  expected: true

# ---------------------------------------------------------------------------
# load and dump __module__ — not covered in prior specs
# ---------------------------------------------------------------------------

invariant plistlib_extra2.load.module:
  description: "plistlib.load.__module__ == 'plistlib'"
  category: module
  kind: python_call_eq
  function: load.__module__.__eq__
  args: ["plistlib"]
  expected: true

invariant plistlib_extra2.dump.module:
  description: "plistlib.dump.__module__ == 'plistlib'"
  category: module
  kind: python_call_eq
  function: dump.__module__.__eq__
  args: ["plistlib"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __name__ checks for core public functions
# (plistlib.zspec.zsdl and plistlib_extra.zspec.zsdl both have individual
#  and table __name__ rows for loads/dumps/load/dump; this table covers
#  the same four using method column syntax for cross-reference completeness,
#  but uses the module-level function objects directly — readPlist/writePlist
#  were removed in Python 3.9 and are intentionally omitted.)
# Note: this table differs from plistlib_extra by adding description column.
# ---------------------------------------------------------------------------

table plistlib_extra2.function_names_with_desc:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected, description]
  rows:
    - [loads, loads.__name__.__eq__, ["loads"], true, "plistlib.loads.__name__ == 'loads'"]
    - [dumps, dumps.__name__.__eq__, ["dumps"], true, "plistlib.dumps.__name__ == 'dumps'"]
    - [load,  load.__name__.__eq__,  ["load"],  true, "plistlib.load.__name__ == 'load'"]
    - [dump,  dump.__name__.__eq__,  ["dump"],  true, "plistlib.dump.__name__ == 'dump'"]

# ---------------------------------------------------------------------------
# FMT_XML and FMT_BINARY name attribute class is str
# ---------------------------------------------------------------------------

invariant plistlib_extra2.FMT_XML.name_is_str:
  description: "plistlib.FMT_XML.name.__class__.__name__ == 'str' — .name returns a str"
  category: constants
  kind: python_call_eq
  function: FMT_XML.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant plistlib_extra2.FMT_BINARY.name_is_str:
  description: "plistlib.FMT_BINARY.name.__class__.__name__ == 'str' — .name returns a str"
  category: constants
  kind: python_call_eq
  function: FMT_BINARY.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# PlistFormat — qualname check (not in prior specs)
# ---------------------------------------------------------------------------

invariant plistlib_extra2.PlistFormat.qualname:
  description: "plistlib.PlistFormat.__qualname__ == 'PlistFormat'"
  category: class_names
  kind: python_call_eq
  function: PlistFormat.__qualname__.__eq__
  args: ["PlistFormat"]
  expected: true

# ---------------------------------------------------------------------------
# InvalidFileException — qualname check (not in prior specs)
# ---------------------------------------------------------------------------

invariant plistlib_extra2.InvalidFileException.qualname:
  description: "plistlib.InvalidFileException.__qualname__ == 'InvalidFileException'"
  category: class_names
  kind: python_call_eq
  function: InvalidFileException.__qualname__.__eq__
  args: ["InvalidFileException"]
  expected: true
