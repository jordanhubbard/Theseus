spec: builtins_extra10
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/functions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functions.html — Python built-in functions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins_extra7.zspec.zsdl — covers __module__ for ord, hex, bin, chr, sorted, hash, repr, callable, iter, next, all, any, sum, min, max, divmod, round, pow, id, vars, dir"
    - "builtins_extra6.zspec.zsdl — covers __module__ for abs, len, print, type"
    - "builtins_extra3.zspec.zsdl — covers __module__ for built-in types (int/str/list/dict/tuple/set/frozenset/bytes/bytearray/bool/float/complex/type/object)"
    - "builtins_extra9.zspec.zsdl — covers __bases__[0].__name__ for range/type/memoryview/slice/property; MRO lengths for dict/tuple/set/float/complex/range"
  notes:
    - "This spec adds new axes not covered in any prior builtins spec."
    - "Axis 1: __module__ for hasattr, getattr, setattr, delattr, isinstance, issubclass — not in extra6 or extra7."
    - "Axis 2: __bases__[0].__name__ for filter, map, zip, reversed, super, staticmethod, classmethod — all inherit directly from object; not in extra9."
    - "Axis 3: __mro__ length for filter, map, zip, reversed, super, staticmethod, classmethod — all length 2."
    - "builtins_extra7 covers __module__ for: ord/hex/bin/chr/sorted/hash/repr/callable/iter/next/all/any/sum/min/max/divmod/round/pow/id/vars/dir."
    - "No prior spec checks __module__ for hasattr, getattr, setattr, delattr, isinstance, or issubclass."
    - "No prior spec checks __bases__[0].__name__ for filter, map, zip, reversed, super, staticmethod, or classmethod."
    - "builtins_extra9 covers MRO lengths for dict/tuple/set/float/complex/range (all 2); no prior spec covers filter/map/zip/reversed/super/staticmethod/classmethod MRO lengths."
    - "All built-in functions have __module__ == 'builtins' — they are implemented in CPython's C core."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ — hasattr, getattr, setattr, delattr, isinstance, issubclass
#
# builtins_extra7 covers __module__ for ord/hex/bin/chr/sorted/hash/repr/
# callable/iter/next/all/any/sum/min/max/divmod/round/pow/id/vars/dir.
# builtins_extra6 covers __module__ for abs/len/print/type.
# No prior spec covers __module__ for hasattr, getattr, setattr, delattr,
# isinstance, or issubclass. All are C built-in functions so __module__ == 'builtins'.
# ---------------------------------------------------------------------------

table builtins_extra10.attr_introspection_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [hasattr,    hasattr.__module__.__eq__,    ["builtins"], true]
    - [getattr,    getattr.__module__.__eq__,    ["builtins"], true]
    - [setattr,    setattr.__module__.__eq__,    ["builtins"], true]
    - [delattr,    delattr.__module__.__eq__,    ["builtins"], true]
    - [isinstance, isinstance.__module__.__eq__, ["builtins"], true]
    - [issubclass, issubclass.__module__.__eq__, ["builtins"], true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ — filter, map, zip, reversed, super, staticmethod, classmethod
#
# builtins_extra3 covers __bases__[0].__name__ for int/bool/str/list/dict/
# tuple/set/frozenset/bytes/bytearray.
# builtins_extra9 covers __bases__[0].__name__ for range/type/memoryview/slice/property.
# No prior spec covers __bases__[0].__name__ for filter, map, zip, reversed,
# super, staticmethod, or classmethod. All inherit directly from object.
# ---------------------------------------------------------------------------

invariant builtins_extra10.filter.base_is_object:
  description: "builtins.filter.__bases__[0].__name__ == 'object' — filter inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: filter.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant builtins_extra10.map.base_is_object:
  description: "builtins.map.__bases__[0].__name__ == 'object' — map inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: map.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant builtins_extra10.zip.base_is_object:
  description: "builtins.zip.__bases__[0].__name__ == 'object' — zip inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: zip.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant builtins_extra10.reversed.base_is_object:
  description: "builtins.reversed.__bases__[0].__name__ == 'object' — reversed inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: reversed.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant builtins_extra10.super.base_is_object:
  description: "builtins.super.__bases__[0].__name__ == 'object' — super inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: super.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant builtins_extra10.staticmethod.base_is_object:
  description: "builtins.staticmethod.__bases__[0].__name__ == 'object' — staticmethod inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: staticmethod.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant builtins_extra10.classmethod.base_is_object:
  description: "builtins.classmethod.__bases__[0].__name__ == 'object' — classmethod inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: classmethod.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# MRO length — filter, map, zip, reversed, super, staticmethod, classmethod
#
# builtins_extra9 covers MRO lengths for dict/tuple/set/float/complex/range (all 2).
# No prior spec covers MRO length for filter, map, zip, reversed, super,
# staticmethod, or classmethod. Each inherits directly from object only, so
# MRO is [type, object] — length 2.
# ---------------------------------------------------------------------------

table builtins_extra10.iterator_type_mro_lengths:
  kind: python_call_eq
  category: mro_lengths
  id_prefix: mrolen

  columns: [id, function, args, expected]
  rows:
    - [filter,      filter.__mro__.__len__,      [], 2]
    - [map,         map.__mro__.__len__,         [], 2]
    - [zip,         zip.__mro__.__len__,         [], 2]
    - [reversed,    reversed.__mro__.__len__,    [], 2]
    - [super,       super.__mro__.__len__,       [], 2]
    - [staticmethod, staticmethod.__mro__.__len__, [], 2]
    - [classmethod,  classmethod.__mro__.__len__,  [], 2]
