spec: inspect_extra1681
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "Python inspect documentation — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers isfunction, isbuiltin, isclass, ismodule, isroutine, signature, getmembers, getdoc, Parameter kind values and names, CO_* flag constants"
    - "inspect_extra.zspec.zsdl — covers __name__ and __module__ tables, isclass/isbuiltin true/false cases, Parameter/Signature classnames"
    - "inspect_extra1666.zspec.zsdl — covers __new__/__init__ presence and _ParameterKind enum checks"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol — which types define __call__ in their own __dict__."
    - "inspect.Parameter is a pure Python slots-based class — it is not callable → __call__ not in __dict__ → False."
    - "inspect.Signature is a pure Python slots-based class — it is not callable → __call__ not in __dict__ → False."
    - "inspect.BoundArguments is a pure Python slots-based class — it is not callable → __call__ not in __dict__ → False."
    - "inspect.Parameter DOES define __slots__ (immutable slots) — __slots__ in dict → True."
    - "inspect.Signature DOES define __slots__ — __slots__ in dict → True."
    - "inspect.BoundArguments DOES define __slots__ — __slots__ in dict → True."
    - "None of the three core inspect user-facing classes are callable; they are data containers."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: callable_protocol
#
# Confirms that the three core inspect classes (Parameter, Signature,
# BoundArguments) do NOT define __call__ in their own __dict__.  These
# are pure Python data container classes — not callable types.
# ---------------------------------------------------------------------------

table inspect_extra1681.callable_protocol:
  description: "inspect classes do not define __call__ in their own __dict__"
  kind: python_call_eq
  category: callable_protocol
  id_prefix: in1681

  columns: [id, function, args, expected]
  rows:
    - ["in1681001", "inspect.Parameter.__dict__.__contains__",      ["__call__"], false]
    - ["in1681002", "inspect.Signature.__dict__.__contains__",      ["__call__"], false]
    - ["in1681003", "inspect.BoundArguments.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 2: slots_and_protocol_attrs
#
# Verifies __slots__ presence (these are slot-based classes) and key
# protocol methods for Parameter, Signature, and BoundArguments.
# Contrasts the absent __call__ with the present structural methods.
# ---------------------------------------------------------------------------

table inspect_extra1681.slots_and_protocol_attrs:
  description: "inspect class __slots__ and protocol method presence checks"
  kind: python_call_eq
  category: slots_and_protocol_attrs
  id_prefix: in1681

  columns: [id, function, args, expected]
  rows:
    - ["in1681010", "inspect.Parameter.__dict__.__contains__",      ["__slots__"],        true]
    - ["in1681011", "inspect.Parameter.__dict__.__contains__",      ["__call__"],         false]
    - ["in1681012", "inspect.Parameter.__dict__.__contains__",      ["__init__"],         true]
    - ["in1681013", "inspect.Parameter.__dict__.__contains__",      ["__repr__"],         true]
    - ["in1681014", "inspect.Parameter.__dict__.__contains__",      ["__reduce__"],       true]
    - ["in1681015", "inspect.Parameter.__dict__.__contains__",      ["__setstate__"],     true]
    - ["in1681016", "inspect.Parameter.__dict__.__contains__",      ["replace"],          true]
    - ["in1681017", "inspect.Signature.__dict__.__contains__",      ["__slots__"],        true]
    - ["in1681018", "inspect.Signature.__dict__.__contains__",      ["__call__"],         false]
    - ["in1681019", "inspect.Signature.__dict__.__contains__",      ["__init__"],         true]
    - ["in1681020", "inspect.Signature.__dict__.__contains__",      ["__eq__"],           true]
    - ["in1681021", "inspect.Signature.__dict__.__contains__",      ["__hash__"],         true]
    - ["in1681022", "inspect.Signature.__dict__.__contains__",      ["bind"],             true]
    - ["in1681023", "inspect.Signature.__dict__.__contains__",      ["bind_partial"],     true]
    - ["in1681024", "inspect.Signature.__dict__.__contains__",      ["replace"],          true]
    - ["in1681025", "inspect.Signature.__dict__.__contains__",      ["from_callable"],    true]
    - ["in1681026", "inspect.BoundArguments.__dict__.__contains__", ["__slots__"],        true]
    - ["in1681027", "inspect.BoundArguments.__dict__.__contains__", ["__call__"],         false]
    - ["in1681028", "inspect.BoundArguments.__dict__.__contains__", ["__init__"],         true]
    - ["in1681029", "inspect.BoundArguments.__dict__.__contains__", ["apply_defaults"],   true]
    - ["in1681030", "inspect.BoundArguments.__dict__.__contains__", ["__getstate__"],     true]
    - ["in1681031", "inspect.BoundArguments.__dict__.__contains__", ["__setstate__"],     true]

# ---------------------------------------------------------------------------
# Table 3: module_and_type_identity
#
# Verifies __module__, __name__, and metatype for Parameter, Signature,
# BoundArguments.  All are standard Python types from the inspect module.
# ---------------------------------------------------------------------------

table inspect_extra1681.module_and_type_identity:
  description: "Module and metatype identity for inspect classes"
  kind: python_call_eq
  category: module_and_type_identity
  id_prefix: in1681

  columns: [id, function, args, expected]
  rows:
    - ["in1681040", "inspect.Parameter.__module__.__eq__",               ["inspect"],        true]
    - ["in1681041", "inspect.Parameter.__name__.__eq__",                 ["Parameter"],      true]
    - ["in1681042", "inspect.Parameter.__class__.__name__.__eq__",       ["type"],           true]
    - ["in1681043", "inspect.Signature.__module__.__eq__",               ["inspect"],        true]
    - ["in1681044", "inspect.Signature.__name__.__eq__",                 ["Signature"],      true]
    - ["in1681045", "inspect.Signature.__class__.__name__.__eq__",       ["type"],           true]
    - ["in1681046", "inspect.BoundArguments.__module__.__eq__",          ["inspect"],        true]
    - ["in1681047", "inspect.BoundArguments.__name__.__eq__",            ["BoundArguments"], true]
    - ["in1681048", "inspect.BoundArguments.__class__.__name__.__eq__",  ["type"],           true]
    - ["in1681049", "inspect.Parameter.__dict__.__contains__",           ["__new__"],        false]
    - ["in1681050", "inspect.Signature.__dict__.__contains__",           ["__new__"],        false]
    - ["in1681051", "inspect.BoundArguments.__dict__.__contains__",      ["__new__"],        false]
