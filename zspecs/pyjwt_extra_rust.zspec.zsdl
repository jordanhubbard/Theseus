spec: pyjwt_extra_rust
version: ">=3.9"
backend: rust_module(pyjwt_extra_rust)

docs: https://pyjwt.readthedocs.io/

provenance:
  derived_from:
    - "https://pyjwt.readthedocs.io/ — PyJWT library"
  notes:
    - "PyJWT encodes and decodes JSON Web Tokens."
    - "jwt.encode({'sub': 'test'}, 'secret', algorithm='HS256') returns str."
    - "jwt.decode(token, 'secret', algorithms=['HS256'])['sub'] == 'test'."
    - "jwt.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pyjwt_extra_rust.encode_decode_sub:
  description: "encode then decode recovers sub"
  category: roundtrip
  kind: python_call_eq
  function: pyjwt_encode_decode_sub
  args: []
  expected: "test"

invariant pyjwt_extra_rust.encode_returns_str:
  description: "jwt.encode returns str"
  category: encode
  kind: python_call_eq
  function: pyjwt_encode_is_str
  args: []
  expected: true

invariant pyjwt_extra_rust.version_nonempty:
  description: "jwt.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pyjwt_extra_version_nonempty
  args: []
  expected: true

