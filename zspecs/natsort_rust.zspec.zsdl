spec: natsort_rust
version: ">=3.9"
backend: rust_module(natsort_rust)

docs: https://natsort.readthedocs.io/

provenance:
  derived_from:
    - "https://natsort.readthedocs.io/ — natsort library"
  notes:
    - "natsort provides natural order sorting for strings."
    - "natsort.natsorted(['a10','a2','a1']) == ['a1','a2','a10']."
    - "natsort.natsorted(['b','a','c']) == ['a','b','c']."
    - "natsort.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant natsort_rust.natsorted_nums:
  description: "natsorted(['a10','a2','a1']) == ['a1','a2','a10']"
  category: natsorted
  kind: python_call_eq
  function: natsort_natsorted
  args: [["a10", "a2", "a1"]]
  expected: ["a1", "a2", "a10"]

invariant natsort_rust.natsorted_alpha:
  description: "natsorted(['b','a','c']) == ['a','b','c']"
  category: natsorted
  kind: python_call_eq
  function: natsort_natsorted
  args: [["b", "a", "c"]]
  expected: ["a", "b", "c"]

invariant natsort_rust.version_nonempty:
  description: "natsort.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: natsort_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
