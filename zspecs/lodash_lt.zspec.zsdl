spec: lodash_lt
version: ">=3.9.2"
backend: node(lodash.lt)

docs: https://lodash.com/docs/#lt

provenance:
  derived_from:
    - "lodash.lt README — https://www.npmjs.com/package/lodash.lt"
    - "Test vectors verified with lodash.lt@3.9.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.lt exports the _.lt function directly as module.exports."
    - "lt(value, other) checks if value is less than other."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_lt.lt:
  kind: node_module_call_eq
  function: ~
  category: lt
  id_prefix: llt

  columns: [id, args, expected]
  rows:
    - [less,     [1, 3],    true]
    - [equal,    [3, 3],    false]
    - [greater,  [3, 1],    false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:33:14Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
