spec: io_extra168
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bufferedio.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.BufferedWriter method __qualname__ values for write, flush, seek, tell, and BufferedWriter.__module__."
    - "All BufferedWriter method qualnames use the public class name 'BufferedWriter' (14 characters) as the prefix, plus a dot separator."
    - "The 'BufferedWriter.' prefix is 15 characters (14 chars for 'BufferedWriter' + 1 for '.')."
    - "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' (len=20; 'BufferedWriter.' (15) + 'write' (5) = 20; tied with flush at 20)."
    - "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' (len=20; 'BufferedWriter.' (15) + 'flush' (5) = 20; tied with write at 20)."
    - "io.BufferedWriter.seek.__qualname__ == 'BufferedWriter.seek' (len=19; 'BufferedWriter.' (15) + 'seek' (4) = 19; tied with tell at 19)."
    - "io.BufferedWriter.tell.__qualname__ == 'BufferedWriter.tell' (len=19; 'BufferedWriter.' (15) + 'tell' (4) = 19; tied with seek at 19)."
    - "io.BufferedWriter.__module__ == '_io' (len=3; BufferedWriter is implemented in the C extension module '_io')."
    - "Two-way tie at 20: write and flush — both 5-character method names."
    - "Two-way tie at 19: seek and tell — both 4-character method names."
    - "Length ranking: seek=tell=19, write=flush=20."
    - "Contrast with BytesIO (io_extra167) and StringIO (io_extra166): BufferedWriter uses the longer 'BufferedWriter.' prefix (15 chars) vs 'BytesIO.' (8) and 'StringIO.' (9)."
    - "BufferedWriter.__module__ == '_io' (private C-extension), unlike StringIO and BytesIO whose __module__ is also '_io' but the class name differs."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedWriter method __qualname__ values (group 1)
# write, flush — both tied at length 20 (5-character method names).
# All use 'BufferedWriter.' prefix (15 characters).
# ---------------------------------------------------------------------------

table io_extra168.BufferedWriter_method_qualnames_group1:
  description: "io.BufferedWriter method __qualname__ values: write=flush='BufferedWriter.write'/'BufferedWriter.flush' (both len=20); two-way tie at 20 for 5-char method names; 'BufferedWriter.' prefix is 15 chars"
  kind: python_call_eq
  category: qualname
  id_prefix: bwq168

  columns: [id, function, args, expected, description]
  rows:
    - [bw_write_qeq,  BufferedWriter.write.__qualname__.__eq__,  ["BufferedWriter.write"],  true, "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' (BufferedWriter.write() writes the given bytes-like object to the underlying raw stream; it buffers writes to reduce the number of system calls; returns the number of bytes written; 'BufferedWriter.write' has 20 characters: 'BufferedWriter.' (15) + 'write' (5) = 20; tied with 'BufferedWriter.flush' (also 20) — both write and flush have 5-character method names; the 15-character 'BufferedWriter.' prefix is the longest of any io class seen in this spec series — much longer than 'BytesIO.' (8), 'StringIO.' (9), or 'Path.' (5))"]
    - [bw_flush_qeq,  BufferedWriter.flush.__qualname__.__eq__,  ["BufferedWriter.flush"],  true, "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' (BufferedWriter.flush() forces all buffered data to be written to the underlying raw stream; it is essential before closing a file to ensure no data is silently lost in the buffer; 'BufferedWriter.flush' has 20 characters: 'BufferedWriter.' (15) + 'flush' (5) = 20; tied with 'BufferedWriter.write' (also 20); both write and flush are 5-character method names, creating a two-way tie at 20; flush() propagates to the underlying raw stream via RawIOBase.write())"]
    - [bw_write_qlen, BufferedWriter.write.__qualname__.__len__, [],                        20,   "io.BufferedWriter.write.__qualname__.__len__() == 20 ('BufferedWriter.write' has 20 characters: 'BufferedWriter.' (15) + 'write' (5) = 20; the two-way tie at 20 with flush is the maximum qualname length in this spec; the long prefix 'BufferedWriter.' (15 chars) dominates the total length — 'BufferedWriter' (14 chars) is the longest class name prefix of any io class seen in this series; for comparison: 'BytesIO.' is 8 chars, 'StringIO.' is 9 chars, 'TextIOWrapper.' would be 14 chars; length 20 for write is determined by 15-char prefix + 5-char method name)"]
    - [bw_flush_qlen, BufferedWriter.flush.__qualname__.__len__, [],                        20,   "io.BufferedWriter.flush.__qualname__.__len__() == 20 ('BufferedWriter.flush' has 20 characters: 'BufferedWriter.' (15) + 'flush' (5) = 20; tied with 'BufferedWriter.write' (also 20); both are 5-character method names under the 15-character 'BufferedWriter.' prefix; 20 is the maximum qualname length in this spec; length 20 for flush stands in contrast to smaller io class method qualnames: StringIO.write (14), BytesIO.write (13), Path.write_text (15) — the 15-char 'BufferedWriter.' prefix elevates all its method qualnames to be among the longest in this spec series)"]

# ---------------------------------------------------------------------------
# io.BufferedWriter method __qualname__ values (group 2)
# seek, tell — both tied at length 19 (4-character method names).
# Also check BufferedWriter.__module__ == '_io' (len=3, private C extension).
# ---------------------------------------------------------------------------

table io_extra168.BufferedWriter_method_qualnames_group2:
  description: "io.BufferedWriter method __qualname__ values: seek=tell='BufferedWriter.seek'/'BufferedWriter.tell' (both len=19); two-way tie at 19; also __module__='_io' (len=3, private C extension)"
  kind: python_call_eq
  category: qualname
  id_prefix: bwq168

  columns: [id, function, args, expected, description]
  rows:
    - [bw_seek_qeq,   BufferedWriter.seek.__qualname__.__eq__,    ["BufferedWriter.seek"],  true, "io.BufferedWriter.seek.__qualname__ == 'BufferedWriter.seek' (BufferedWriter.seek() changes the stream position to the given byte offset within the buffered stream; it flushes the write buffer before seeking to ensure consistency; accepts whence=0 (absolute), 1 (relative to current), 2 (relative to end); 'BufferedWriter.seek' has 19 characters: 'BufferedWriter.' (15) + 'seek' (4) = 19; tied with 'BufferedWriter.tell' (also 19) — both seek and tell have 4-character method names; 1 character shorter than write/flush (20))"]
    - [bw_tell_qeq,   BufferedWriter.tell.__qualname__.__eq__,    ["BufferedWriter.tell"],  true, "io.BufferedWriter.tell.__qualname__ == 'BufferedWriter.tell' (BufferedWriter.tell() returns the current stream position as an integer byte offset; for BufferedWriter the position accounts for both data written to the underlying stream and data still in the buffer; 'BufferedWriter.tell' has 19 characters: 'BufferedWriter.' (15) + 'tell' (4) = 19; tied with 'BufferedWriter.seek' (also 19); both are 4-character method names under the 15-char 'BufferedWriter.' prefix; compare with BytesIO.tell (12) and StringIO.tell (13) — same 4-character method names but much shorter prefixes)"]
    - [bw_seek_qlen,  BufferedWriter.seek.__qualname__.__len__,   [],                       19,   "io.BufferedWriter.seek.__qualname__.__len__() == 19 ('BufferedWriter.seek' has 19 characters: 'BufferedWriter.' (15) + 'seek' (4) = 19; the two-way tie at 19 with tell is the second-highest qualname length in this spec; the complete length ranking is: seek=tell=19, write=flush=20; all four method qualnames are 19 or 20 characters because the dominant 'BufferedWriter.' prefix (15 chars) is so long; compare with the analogous method seek() in BytesIO: 'BytesIO.seek' is only 12 chars, showing how the prefix length determines qualname length)"]
    - [bw_module_eq,  BufferedWriter.__module__.__eq__,           ["_io"],                  true, "io.BufferedWriter.__module__ == '_io' (BufferedWriter is implemented in the C extension module '_io', not the public 'io' Python module; '_io' has 3 characters: '_' (1) + 'io' (2) = 3; the leading underscore '_' is the Python convention for private/implementation modules; the public 'io' module re-exports BufferedWriter from '_io' so users import from 'io'; this mirrors io.FileIO.__module__ == '_io' and io.BytesIO.__module__ == '_io' — all C-implemented io classes use the '_io' private module; contrast with pathlib classes where __module__ == 'pathlib' (7 chars) the public module)"]

