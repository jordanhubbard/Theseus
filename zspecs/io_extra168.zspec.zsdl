invariant io_extra168.BufferedWriter_write_flush_tied_at_20:
  description: "io.BufferedWriter.write.__qualname__.__len__() == 20 — 'BufferedWriter.write' has 20 characters: 'BufferedWriter.' (15) + 'write' (5) = 20; tied with 'BufferedWriter.flush' (also 20: 'BufferedWriter.' (15) + 'flush' (5) = 20); write and flush form a two-way tie at 20 because both are 5-character method names under the 15-character 'BufferedWriter.' prefix; 20 is the maximum qualname length in this spec; length ranking: seek=tell=19, write=flush=20; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: BufferedWriter.write.__qualname__.__len__
  args: []
  expected: 20

invariant io_extra168.BufferedWriter_seek_tell_tied_at_19:
  description: "io.BufferedWriter.seek.__qualname__.__len__() == 19 — 'BufferedWriter.seek' has 19 characters: 'BufferedWriter.' (15) + 'seek' (4) = 19; tied with 'BufferedWriter.tell' (also 19: 'BufferedWriter.' (15) + 'tell' (4) = 19); seek and tell form a two-way tie at 19 because both are 4-character method names; all four BufferedWriter method qualnames in this spec are either 19 or 20 characters because the 15-char prefix dominates; length ranking: seek=tell=19, write=flush=20; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: BufferedWriter.seek.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra168.BufferedWriter_module_is_underscore_io:
  description: "io.BufferedWriter.__module__ == '_io' — BufferedWriter is implemented in '_io' (3 chars), the private C-extension module; the leading underscore marks it as an implementation detail; the public 'io' module imports and re-exports BufferedWriter from '_io'; '_io' (3 chars) is 1 character longer than 'io' (2) due to the underscore prefix; BufferedWriter, BytesIO, StringIO, FileIO, and RawIOBase all share __module__ == '_io'; pathlib classes differ: their __module__ == 'pathlib' (7 chars), the public module directly; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedWriter.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra168.BufferedWriter_flush_qualname_eq:
  description: "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' — flush() uses the public class name 'BufferedWriter' in its qualname; 'BufferedWriter.flush' has 20 characters: 'BufferedWriter.' (15) + 'flush' (5) = 20; flush() is the method that drains the write buffer to the underlying raw stream; tied with 'BufferedWriter.write' (also 20) — both are 5-character method names; the two-way tie at 20 (write, flush) is symmetric with the two-way tie at 19 (seek, tell); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: BufferedWriter.flush.__qualname__.__eq__
  args: ["BufferedWriter.flush"]
  expected: true

