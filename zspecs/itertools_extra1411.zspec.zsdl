spec: itertools_extra1411
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra140.zspec.zsdl — covers chain, product, combinations, permutations, combinations_with_replacement doc/name/module/MRO attrs"
    - "itertools_extra149.zspec.zsdl — covers other itertools wave 272 attrs"
  notes:
    - "Wave 541 theme: __sizeof__ method type on itertools C-extension class objects; __sizeof__ and __reduce_ex__ in __dict__ membership."
    - "All itertools C-extension types (chain, count, cycle, repeat, accumulate, combinations, product, islice) inherit __sizeof__ from object as a 'method_descriptor' on the class. Verified with Python 3.14.3."
    - "itertools.combinations.__sizeof__.__class__.__name__ == 'method_descriptor' — even though '__sizeof__' IS in itertools.combinations.__dict__ (True), the method_descriptor type applies. Verified with Python 3.14.3."
    - "itertools.product.__sizeof__.__class__.__name__ == 'method_descriptor' — '__sizeof__' IS in itertools.product.__dict__ (True). Verified with Python 3.14.3."
    - "All other itertools classes checked (chain, count, cycle, repeat, accumulate, islice) have '__sizeof__' NOT in their own __dict__. Verified with Python 3.14.3."
    - "None of the checked itertools classes define '__reduce_ex__' in their own __dict__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class __sizeof__ method type checks
#
# Wave 541 theme: __sizeof__ method class on itertools C-extension class
# objects. All itertools classes inherit __sizeof__ from object, appearing as
# 'method_descriptor' on the class object.
#
# chain, count, cycle, repeat: '__sizeof__' NOT in own __dict__
# combinations, product: '__sizeof__' IS in own __dict__ (override)
# accumulate, islice: '__sizeof__' NOT in own __dict__
# ---------------------------------------------------------------------------

table itertools_extra1411.sizeof_method_type:
  description: "itertools C-extension classes: __sizeof__.__class__.__name__ == 'method_descriptor' for chain, count, cycle, repeat, accumulate, combinations, product, islice; wave 541; new to extra1411"
  kind: python_call_eq
  category: sizeof_method_type
  id_prefix: it1411sz

  columns: [id, function, args, expected, description]
  rows:
    - [it1411sz001,
       "chain.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.chain.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — chain is a C extension type; __sizeof__ is inherited from object as a method_descriptor on the class object; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411sz002,
       "count.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.count.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — count is a C extension type; __sizeof__ is inherited from object as a method_descriptor on the class object; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411sz003,
       "cycle.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.cycle.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — cycle is a C extension type; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411sz004,
       "repeat.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.repeat.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — repeat is a C extension type; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411sz005,
       "accumulate.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.accumulate.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — accumulate is a C extension type; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411sz006,
       "combinations.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.combinations.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — combinations defines __sizeof__ in its own __dict__ as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411sz007,
       "product.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.product.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — product defines __sizeof__ in its own __dict__ as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411sz008,
       "islice.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.islice.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — islice is a C extension type; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]

# ---------------------------------------------------------------------------
# Table 2: itertools class __dict__ membership for __sizeof__
#
# Wave 541 theme: which itertools C-extension types define __sizeof__ in their
# own __dict__ (i.e., provide a custom implementation) vs. inheriting from
# object.
#
# combinations and product: True (custom __sizeof__ in itertoolsmodule.c)
# chain, count, cycle, repeat, accumulate, islice: False (inherited)
# ---------------------------------------------------------------------------

table itertools_extra1411.sizeof_dict_membership:
  description: "itertools classes __sizeof__ dict membership: combinations and product True; chain, count, cycle, repeat, accumulate, islice False; wave 541; new to extra1411"
  kind: python_call_eq
  category: sizeof_dict_membership
  id_prefix: it1411dm

  columns: [id, function, args, expected, description]
  rows:
    - [it1411dm001,
       "combinations.__dict__.__contains__",
       ["__sizeof__"],
       true,
       "itertools.combinations.__dict__.__contains__('__sizeof__') == True — combinations defines its own __sizeof__ in itertoolsmodule.c to report internal array size; dict.__contains__ returns True; new to extra1411"]
    - [it1411dm002,
       "product.__dict__.__contains__",
       ["__sizeof__"],
       true,
       "itertools.product.__dict__.__contains__('__sizeof__') == True — product defines its own __sizeof__ in itertoolsmodule.c to report internal pool size; dict.__contains__ returns True; new to extra1411"]
    - [it1411dm003,
       "chain.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "itertools.chain.__dict__.__contains__('__sizeof__') == False — chain does not define __sizeof__ in its own __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [it1411dm004,
       "count.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "itertools.count.__dict__.__contains__('__sizeof__') == False — count does not define __sizeof__ in its own __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [it1411dm005,
       "cycle.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "itertools.cycle.__dict__.__contains__('__sizeof__') == False — cycle does not define __sizeof__ in its own __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [it1411dm006,
       "repeat.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "itertools.repeat.__dict__.__contains__('__sizeof__') == False — repeat does not define __sizeof__ in its own __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [it1411dm007,
       "accumulate.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__sizeof__') == False — accumulate does not define __sizeof__ in its own __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [it1411dm008,
       "islice.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "itertools.islice.__dict__.__contains__('__sizeof__') == False — islice does not define __sizeof__ in its own __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]

# ---------------------------------------------------------------------------
# Table 3: itertools class __reduce_ex__ method type and dict membership
#
# Wave 541 theme: __reduce_ex__ is inherited from object as a
# 'method_descriptor' on all itertools class objects. None of the checked
# itertools classes define __reduce_ex__ in their own __dict__.
# ---------------------------------------------------------------------------

table itertools_extra1411.reduce_ex_checks:
  description: "itertools classes: __reduce_ex__.__class__.__name__ == 'method_descriptor' and not in __dict__ for chain, count, cycle, repeat, accumulate, combinations, product, islice; wave 541; new to extra1411"
  kind: python_call_eq
  category: reduce_ex_checks
  id_prefix: it1411rx

  columns: [id, function, args, expected, description]
  rows:
    - [it1411rx001,
       "chain.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.chain.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — chain inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411rx002,
       "count.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.count.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — count inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411rx003,
       "combinations.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.combinations.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — combinations inherits __reduce_ex__ from object; even though it has a custom __sizeof__, __reduce_ex__ is inherited; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411rx004,
       "product.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.product.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — product inherits __reduce_ex__ from object; even though it has a custom __sizeof__, __reduce_ex__ is inherited; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [it1411rx005,
       "chain.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "itertools.chain.__dict__.__contains__('__reduce_ex__') == False — chain does not define __reduce_ex__ in its own __dict__; dict.__contains__ returns False; new to extra1411"]
    - [it1411rx006,
       "combinations.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "itertools.combinations.__dict__.__contains__('__reduce_ex__') == False — combinations does not define __reduce_ex__ in its own __dict__ despite having custom __sizeof__; dict.__contains__ returns False; new to extra1411"]
    - [it1411rx007,
       "product.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "itertools.product.__dict__.__contains__('__reduce_ex__') == False — product does not define __reduce_ex__ in its own __dict__ despite having custom __sizeof__; dict.__contains__ returns False; new to extra1411"]
    - [it1411rx008,
       "accumulate.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__reduce_ex__') == False — accumulate does not define __reduce_ex__ in its own __dict__; dict.__contains__ returns False; new to extra1411"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1411
# ---------------------------------------------------------------------------

invariant itertools_extra1411.chain_sizeof_is_method_descriptor:
  description: "itertools.chain.__sizeof__.__class__.__name__ == 'method_descriptor' — inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: chain.__sizeof__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant itertools_extra1411.combinations_sizeof_in_dict:
  description: "'__sizeof__' in itertools.combinations.__dict__ == True — combinations has a custom __sizeof__ in itertoolsmodule.c; wave 541; new to extra1411"
  kind: python_call_eq
  function: combinations.__dict__.__contains__
  args: ["__sizeof__"]
  expected: true

invariant itertools_extra1411.product_sizeof_in_dict:
  description: "'__sizeof__' in itertools.product.__dict__ == True — product has a custom __sizeof__ in itertoolsmodule.c; wave 541; new to extra1411"
  kind: python_call_eq
  function: product.__dict__.__contains__
  args: ["__sizeof__"]
  expected: true

invariant itertools_extra1411.chain_sizeof_not_in_dict:
  description: "'__sizeof__' not in itertools.chain.__dict__ — chain inherits __sizeof__ from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__sizeof__"]
  expected: false

invariant itertools_extra1411.chain_reduce_ex_is_method_descriptor:
  description: "itertools.chain.__reduce_ex__.__class__.__name__ == 'method_descriptor' — inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: chain.__reduce_ex__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant itertools_extra1411.combinations_reduce_ex_not_in_dict:
  description: "'__reduce_ex__' not in itertools.combinations.__dict__ — combinations does not override __reduce_ex__; wave 541; new to extra1411"
  kind: python_call_eq
  function: combinations.__dict__.__contains__
  args: ["__reduce_ex__"]
  expected: false
