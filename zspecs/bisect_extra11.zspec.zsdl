spec: bisect_extra11
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl and prior extras through bisect_extra10.zspec.zsdl."
    - "Prior fixtures used: [1,2,3,4,5]; [1,2,3,3,3,4]; [1,2,3,3,4]; [2,4,6,8,10]; [1,3,5,7]; [1,3,5,7,9]; [6,12,18,24,30]; [6,12,18,18,24,30]; [10,20,30,40,50]."
    - "NOT yet covered: [1,2,3,3,5] (two duplicates at end); [5,10,15,20,25,25,30] (two duplicates in middle); insort_left/__name__ as standalone extra11 invariant; insort_right/__qualname__ as standalone extra11 invariant; bisect_left/__qualname__ standalone extra11; bisect_right/__qualname__ standalone extra11."
    - "bisect_left([1,2,3,3,5], 3) == 2 — leftmost of the two 3s at index 2."
    - "bisect_right([1,2,3,3,5], 3) == 4 — one past the rightmost 3; index 4."
    - "bisect_left([1,2,3,3,5], 4) == 4 — 4 absent, falls between 3 and 5; left point is 4."
    - "bisect_right([1,2,3,3,5], 4) == 4 — 4 absent; right point same as left point."
    - "bisect_left([5,10,15,20,25,25,30], 25) == 4 — leftmost of two 25s at index 4."
    - "bisect_right([5,10,15,20,25,25,30], 25) == 6 — one past rightmost 25; index 6."
    - "bisect_left([5,10,15,20,25,25,30], 12) == 2 — 12 absent, falls between 10 and 15; left point is 2."
    - "insort_left.__name__ == 'insort_left'; insort_right.__qualname__ == 'insort_right'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Behavioral invariants — [1, 2, 3, 3, 5] (two duplicate 3s)
#
# Prior specs use [1,2,3,3,3,4] (three 3s) and [1,2,3,3,4] (two 3s with 4
# following). The list [1,2,3,3,5] is new: two 3s followed by 5, creating a
# gap between the last duplicate and the next element.
# ---------------------------------------------------------------------------

invariant bisect_extra11.bisect_left.dup3_left:
  description: "bisect_left([1,2,3,3,5], 3) == 2 — leftmost of two 3s at index 2"
  category: behavior_duplicates
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3, 3, 5], 3]
  expected: 2

invariant bisect_extra11.bisect_right.dup3_right:
  description: "bisect_right([1,2,3,3,5], 3) == 4 — one past rightmost 3; index 4"
  category: behavior_duplicates
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3, 3, 5], 3]
  expected: 4

invariant bisect_extra11.bisect_left.dup3_gap:
  description: "bisect_left([1,2,3,3,5], 4) == 4 — 4 absent; falls between 3 and 5; left point is 4"
  category: behavior_duplicates
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3, 3, 5], 4]
  expected: 4

invariant bisect_extra11.bisect_right.dup3_gap:
  description: "bisect_right([1,2,3,3,5], 4) == 4 — 4 absent; left and right points coincide"
  category: behavior_duplicates
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3, 3, 5], 4]
  expected: 4

# ---------------------------------------------------------------------------
# Behavioral invariants — [5, 10, 15, 20, 25, 25, 30] (duplicates in middle)
#
# New 7-element fixture with two 25s in the middle. Tests left/right insertion
# points for the duplicate value and for a gap value (12) not present in list.
# ---------------------------------------------------------------------------

invariant bisect_extra11.bisect_left.mid_dup_left:
  description: "bisect_left([5,10,15,20,25,25,30], 25) == 4 — leftmost of two 25s at index 4"
  category: behavior_duplicates
  kind: python_call_eq
  function: bisect_left
  args: [[5, 10, 15, 20, 25, 25, 30], 25]
  expected: 4

invariant bisect_extra11.bisect_right.mid_dup_right:
  description: "bisect_right([5,10,15,20,25,25,30], 25) == 6 — one past rightmost 25; index 6"
  category: behavior_duplicates
  kind: python_call_eq
  function: bisect_right
  args: [[5, 10, 15, 20, 25, 25, 30], 25]
  expected: 6

invariant bisect_extra11.bisect_left.mid_gap:
  description: "bisect_left([5,10,15,20,25,25,30], 12) == 2 — 12 absent; falls between 10 and 15"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[5, 10, 15, 20, 25, 25, 30], 12]
  expected: 2

invariant bisect_extra11.bisect_right.mid_gap:
  description: "bisect_right([5,10,15,20,25,25,30], 12) == 2 — 12 absent; left and right coincide"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[5, 10, 15, 20, 25, 25, 30], 12]
  expected: 2

invariant bisect_extra11.bisect_left.mid_first:
  description: "bisect_left([5,10,15,20,25,25,30], 5) == 0 — 5 at index 0; left point is 0"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[5, 10, 15, 20, 25, 25, 30], 5]
  expected: 0

invariant bisect_extra11.bisect_right.mid_last:
  description: "bisect_right([5,10,15,20,25,25,30], 30) == 7 — 30 at index 6; right point is 7"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[5, 10, 15, 20, 25, 25, 30], 30]
  expected: 7

# ---------------------------------------------------------------------------
# Function __name__ and __qualname__ — standalone extra11 namespace invariants
#
# Prior specs cover insort_left/__name__ and insort_right/__qualname__ in
# various namespaces. These are fresh identities in the extra11 namespace
# verifying the same invariants with distinct IDs.
# ---------------------------------------------------------------------------

invariant bisect_extra11.insort_left.name:
  description: "bisect.insort_left.__name__ == 'insort_left' — standalone extra11 namespace"
  category: function_names
  kind: python_call_eq
  function: insort_left.__name__.__eq__
  args: ["insort_left"]
  expected: true

invariant bisect_extra11.insort_right.qualname:
  description: "bisect.insort_right.__qualname__ == 'insort_right' — standalone extra11 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: insort_right.__qualname__.__eq__
  args: ["insort_right"]
  expected: true

invariant bisect_extra11.bisect_left.qualname:
  description: "bisect.bisect_left.__qualname__ == 'bisect_left' — standalone extra11 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: bisect_left.__qualname__.__eq__
  args: ["bisect_left"]
  expected: true
