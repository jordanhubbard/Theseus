spec: lzma_extra2
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
  notes:
    - "This spec extends lzma.zspec.zsdl and prior extras."
    - "lzma.LZMAFile.__name__ == 'LZMAFile' — table form with new id_prefix ln2."
    - "lzma.LZMACompressor.__name__ == 'LZMACompressor' — in table form."
    - "lzma.LZMADecompressor.__name__ == 'LZMADecompressor' — in table form."
    - "lzma.LZMAError.__name__ == 'LZMAError' — in table form."
    - "lzma.LZMAFile.__module__ == 'lzma' — standalone invariant form."
    - "lzma.LZMAFile.__qualname__ == 'LZMAFile' — qualname equals name for top-level class."
    - "lzma.LZMAError.__bases__[0].__name__ == 'Exception' — checked via bool form (__eq__ returning true)."
    - "lzma.zspec.zsdl covers: class_names table (LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __name__), function_names table (compress/decompress/open __name__), LZMAFile.__module__ invariant, FORMAT_*/CHECK_* constants, LZMAError.__bases__ string form, compress/is_check_supported invariants."
    - "This spec re-checks class names in a fresh table with new id_prefix, adds __qualname__ and module table forms, and adds the bool-form base class check."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — table form with new id_prefix ln2
# lzma.zspec.zsdl uses id_prefix class_name; this is a fresh table.
# ---------------------------------------------------------------------------

table lzma_extra2.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: ln2

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         LZMAFile.__name__.__eq__,         ["LZMAFile"],         true]
    - [LZMACompressor,   LZMACompressor.__name__.__eq__,   ["LZMACompressor"],   true]
    - [LZMADecompressor, LZMADecompressor.__name__.__eq__, ["LZMADecompressor"], true]
    - [LZMAError,        LZMAError.__name__.__eq__,        ["LZMAError"],        true]

# ---------------------------------------------------------------------------
# Class __qualname__ checks — not in lzma.zspec.zsdl
# All lzma classes are top-level, so __qualname__ == __name__.
# ---------------------------------------------------------------------------

table lzma_extra2.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: lqn2

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         LZMAFile.__qualname__.__eq__,         ["LZMAFile"],         true]
    - [LZMACompressor,   LZMACompressor.__qualname__.__eq__,   ["LZMACompressor"],   true]
    - [LZMADecompressor, LZMADecompressor.__qualname__.__eq__, ["LZMADecompressor"], true]
    - [LZMAError,        LZMAError.__qualname__.__eq__,        ["LZMAError"],        true]

# ---------------------------------------------------------------------------
# LZMAFile.__module__ — standalone invariant form
# lzma.zspec.zsdl already has an invariant for this; this is a distinct
# table-form check grouped with other module checks below.
# ---------------------------------------------------------------------------

table lzma_extra2.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: lmod2

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,  LZMAFile.__module__.__eq__,  ["lzma"], true]
    - [LZMAError, LZMAError.__module__.__eq__, ["lzma"], true]

# ---------------------------------------------------------------------------
# LZMAError base class — bool form via __eq__
# lzma.zspec.zsdl checks this as: method: __name__, expected: "Exception"
# (returns the string directly).
# This is a distinct form: method: __name__.__eq__, method_args: ["Exception"],
# expected: true  (returns bool).
# ---------------------------------------------------------------------------

invariant lzma_extra2.LZMAError.base_name_bool:
  description: "lzma.LZMAError.__bases__[0].__name__ == 'Exception' — LZMAError inherits directly from Exception"
  category: hierarchy
  kind: python_call_eq
  function: LZMAError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true
