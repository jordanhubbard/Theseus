spec: itertools_extra241
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra240.zspec.zsdl — covers combinations and combinations_with_replacement identity"
    - "itertools.zspec.zsdl — covers chain/islice/count/cycle/repeat/accumulate/compress/product/combinations/zip_longest class names and first-element tests"
    - "itertools_extra.zspec.zsdl — covers filterfalse class name, chain/repeat/islice length hints"
  notes:
    - "This spec covers itertools.groupby and itertools.zip_longest class identity contracts."
    - "itertools.groupby.__name__ == 'groupby' (len=7) — groupby is a C class in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools' (len=9) — groupby is exposed via the itertools module. Verified with Python 3.14.3."
    - "itertools.groupby.__bases__[0].__name__ == 'object' — groupby inherits directly from object. Verified with Python 3.14.3."
    - "itertools.groupby.__class__.__name__ == 'type' — groupby is a class; its metaclass is type. Verified with Python 3.14.3."
    - "itertools.groupby.__qualname__ == 'groupby' (len=7) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "itertools.groupby.__doc__ contains 'key' == True — docstring mentions key function. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' (len=11) — zip_longest is a C class in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' (len=9) — zip_longest is exposed via the itertools module. Verified with Python 3.14.3."
    - "itertools.zip_longest.__bases__[0].__name__ == 'object' — zip_longest inherits directly from object. Verified with Python 3.14.3."
    - "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a class; its metaclass is type. Verified with Python 3.14.3."
    - "itertools.zip_longest.__qualname__ == 'zip_longest' (len=11) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "itertools.zip_longest.__doc__ contains 'fillvalue' == True — docstring mentions fillvalue parameter. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.groupby identity contracts
#
# itertools.groupby.__name__ == 'groupby' (len=7)
# itertools.groupby.__module__ == 'itertools' (len=9)
# itertools.groupby.__bases__[0].__name__ == 'object'
# itertools.groupby.__class__.__name__ == 'type'
# itertools.groupby.__qualname__ == 'groupby' (len=7)
#
# groupby is a C class in itertoolsmodule.c. New to extra241.
# ---------------------------------------------------------------------------

table itertools_extra241.groupby241_identity:
  description: "itertools.groupby identity: name, module, bases, class, qualname; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: groupby241

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_name_eq,
       groupby.__name__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — groupby is a C class in itertoolsmodule.c; __name__ is 'groupby' (len=7); new to extra241"]
    - [groupby_name_len_7,
       groupby.__name__.__len__,
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — 'groupby' has exactly 7 characters; str.__len__() returns 7; new to extra241"]
    - [groupby_module_eq,
       groupby.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.groupby.__module__.__eq__('itertools') == True — groupby is exposed via the itertools module; __module__ is 'itertools' (len=9); new to extra241"]
    - [groupby_module_len_9,
       groupby.__module__.__len__,
       [],
       9,
       "itertools.groupby.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra241"]
    - [groupby_bases_0_is_object,
       "groupby.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.groupby.__bases__[0].__name__.__eq__('object') == True — groupby inherits directly from object; __bases__[0] is object; new to extra241"]

# ---------------------------------------------------------------------------
# Table 2: itertools.groupby class and qualname contracts
#
# itertools.groupby.__class__.__name__ == 'type'
# itertools.groupby.__qualname__ == 'groupby' (len=7)
# itertools.groupby.__doc__.__contains__('key') == True
# itertools.groupby.__module__.__contains__('itertools') == True
# itertools.groupby.__qualname__.__len__() == 7
#
# New to extra241.
# ---------------------------------------------------------------------------

table itertools_extra241.groupby241_class:
  description: "itertools.groupby class, qualname, doc checks; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: groupby241cls

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_class_is_type,
       groupby.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.groupby.__class__.__name__.__eq__('type') == True — groupby is a class; its metaclass is the built-in type; new to extra241"]
    - [groupby_qualname_eq,
       groupby.__qualname__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__qualname__.__eq__('groupby') == True — __qualname__ is 'groupby' (len=7); same as __name__ for top-level class; new to extra241"]
    - [groupby_qualname_len_7,
       groupby.__qualname__.__len__,
       [],
       7,
       "itertools.groupby.__qualname__.__len__() == 7 — 'groupby' has exactly 7 characters; str.__len__() returns 7; new to extra241"]
    - [groupby_doc_contains_key,
       groupby.__doc__.__contains__,
       ["key"],
       true,
       "itertools.groupby.__doc__.__contains__('key') == True — docstring describes groupby using a key function; new to extra241"]
    - [groupby_module_contains_itertools,
       groupby.__module__.__contains__,
       ["itertools"],
       true,
       "itertools.groupby.__module__.__contains__('itertools') == True — 'itertools' contains the substring 'itertools'; new to extra241"]

# ---------------------------------------------------------------------------
# Table 3: itertools.zip_longest identity contracts
#
# itertools.zip_longest.__name__ == 'zip_longest' (len=11)
# itertools.zip_longest.__module__ == 'itertools' (len=9)
# itertools.zip_longest.__bases__[0].__name__ == 'object'
# itertools.zip_longest.__class__.__name__ == 'type'
# itertools.zip_longest.__qualname__ == 'zip_longest' (len=11)
#
# zip_longest is a C class in itertoolsmodule.c. New to extra241.
# ---------------------------------------------------------------------------

table itertools_extra241.ziplong241_identity:
  description: "itertools.zip_longest identity: name, module, bases, class, qualname; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: ziplong241

  columns: [id, function, args, expected, description]
  rows:
    - [ziplong_name_eq,
       zip_longest.__name__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C class in itertoolsmodule.c; __name__ is 'zip_longest' (len=11); new to extra241"]
    - [ziplong_name_len_11,
       zip_longest.__name__.__len__,
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has exactly 11 characters; str.__len__() returns 11; new to extra241"]
    - [ziplong_module_eq,
       zip_longest.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — zip_longest is exposed via the itertools module; __module__ is 'itertools' (len=9); new to extra241"]
    - [ziplong_module_len_9,
       zip_longest.__module__.__len__,
       [],
       9,
       "itertools.zip_longest.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra241"]
    - [ziplong_bases_0_is_object,
       "zip_longest.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__name__.__eq__('object') == True — zip_longest inherits directly from object; __bases__[0] is object; new to extra241"]

# ---------------------------------------------------------------------------
# Table 4: itertools.zip_longest class and qualname contracts
#
# itertools.zip_longest.__class__.__name__ == 'type'
# itertools.zip_longest.__qualname__ == 'zip_longest' (len=11)
# itertools.zip_longest.__doc__.__contains__('fillvalue') == True
# itertools.zip_longest.__qualname__.__len__() == 11
# itertools.zip_longest.__module__.__contains__('itertools') == True
#
# New to extra241.
# ---------------------------------------------------------------------------

table itertools_extra241.ziplong241_class:
  description: "itertools.zip_longest class, qualname, doc checks; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: ziplong241cls

  columns: [id, function, args, expected, description]
  rows:
    - [ziplong_class_is_type,
       zip_longest.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.zip_longest.__class__.__name__.__eq__('type') == True — zip_longest is a class; its metaclass is the built-in type; new to extra241"]
    - [ziplong_qualname_eq,
       zip_longest.__qualname__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — __qualname__ is 'zip_longest' (len=11); same as __name__ for top-level class; new to extra241"]
    - [ziplong_qualname_len_11,
       zip_longest.__qualname__.__len__,
       [],
       11,
       "itertools.zip_longest.__qualname__.__len__() == 11 — 'zip_longest' has exactly 11 characters; str.__len__() returns 11; new to extra241"]
    - [ziplong_doc_contains_fillvalue,
       zip_longest.__doc__.__contains__,
       ["fillvalue"],
       true,
       "itertools.zip_longest.__doc__.__contains__('fillvalue') == True — docstring mentions fillvalue parameter for padding shorter iterables; new to extra241"]
    - [ziplong_module_contains_itertools,
       zip_longest.__module__.__contains__,
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__contains__('itertools') == True — 'itertools' contains the substring 'itertools'; new to extra241"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra241
# ---------------------------------------------------------------------------

invariant itertools_extra241.groupby_name_eq:
  description: "itertools.groupby.__name__ == 'groupby' (len=7); new to extra241"
  kind: python_call_eq
  function: groupby.__name__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra241.groupby_name_len_7:
  description: "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 characters; new to extra241"
  kind: python_call_eq
  function: groupby.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra241.groupby_module_eq:
  description: "itertools.groupby.__module__ == 'itertools' — C class exposed via itertools; new to extra241"
