spec: struct_extra200
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra199.zspec.zsdl — covers struct module __dict__.__contains__ for pack/unpack/calcsize/Struct/error/pack_into/unpack_from/iter_unpack; struct.Struct.__mro__.__len__()==2 and __mro__[0].__name__=='Struct'."
  notes:
    - "struct.Struct.__mro__ is a tuple of length 2: (Struct, object). Struct is a C extension type. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__mro__[0].__name__ == 'Struct' — first MRO entry is Struct itself. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__mro__[1].__name__ == 'object' — second MRO entry is object. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.error.__mro__ is a tuple of length 4: (error, Exception, BaseException, object). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.error.__mro__[0].__name__ == 'error' — first MRO entry is struct.error itself. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.error.__mro__[1].__name__ == 'Exception' — struct.error inherits from Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.error.__mro__[2].__name__ == 'BaseException' — third MRO entry is BaseException. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__dict__.__contains__('pack') == True — pack is in the Struct class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__dict__.__contains__('unpack') == True — unpack is in the Struct class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__dict__.__contains__('size') == True — size is in the Struct class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__mro__ — type, length, and entry names
# ---------------------------------------------------------------------------

table struct_extra200.Struct_mro_type_and_entries:
  description: "struct.Struct.__mro__ is a tuple of length 2; __mro__[0].__name__=='Struct' and __mro__[1].__name__=='object'"
  kind: python_call_eq
  category: class_mro
  id_prefix: structmro200

  columns: [id, function, args, expected, description]
  rows:
    - [struct_mro_type,    Struct.__mro__.__class__.__name__.__eq__,  ["tuple"],   true,  "struct.Struct.__mro__.__class__.__name__ == 'tuple' — __mro__ is always a tuple"]
    - [struct_mro_len,     Struct.__mro__.__len__,                    [],          2,     "struct.Struct.__mro__.__len__() == 2 — Struct inherits from object only (Struct, object)"]
    - ["struct_mro0",      "Struct.__mro__[0].__name__.__eq__",       ["Struct"],  true,  "struct.Struct.__mro__[0].__name__ == 'Struct' — first MRO entry is Struct itself"]
    - ["struct_mro1",      "Struct.__mro__[1].__name__.__eq__",       ["object"],  true,  "struct.Struct.__mro__[1].__name__ == 'object' — second MRO entry is object"]

# ---------------------------------------------------------------------------
# struct.error.__mro__ — length and entry names
# ---------------------------------------------------------------------------

table struct_extra200.error_mro_length_and_names:
  description: "struct.error.__mro__.__len__()==4; error->Exception->BaseException->object chain"
  kind: python_call_eq
  category: class_mro
  id_prefix: structmro200

  columns: [id, function, args, expected, description]
  rows:
    - [error_mro_len,   error.__mro__.__len__,                    [], 4,              "struct.error.__mro__.__len__() == 4 — MRO is (error, Exception, BaseException, object)"]
    - ["error_mro0",    "error.__mro__[0].__name__.__eq__",       ["error"],       true, "struct.error.__mro__[0].__name__ == 'error' — first MRO entry is struct.error itself"]
    - ["error_mro1",    "error.__mro__[1].__name__.__eq__",       ["Exception"],   true, "struct.error.__mro__[1].__name__ == 'Exception' — struct.error inherits from Exception"]
    - ["error_mro2",    "error.__mro__[2].__name__.__eq__",       ["BaseException"], true, "struct.error.__mro__[2].__name__ == 'BaseException' — third MRO entry is BaseException"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ membership — pack, unpack, size
# ---------------------------------------------------------------------------

table struct_extra200.Struct_class_dict_membership:
  description: "struct.Struct.__dict__.__contains__ checks for pack, unpack, size — the core Struct instance methods and the size descriptor"
  kind: python_call_eq
  category: class_dict
  id_prefix: structmro200

  columns: [id, function, args, expected, description]
  rows:
    - [struct_dict_pack,   Struct.__dict__.__contains__, ["pack"],   true, "struct.Struct.__dict__.__contains__('pack') — pack method is in Struct.__dict__"]
    - [struct_dict_unpack, Struct.__dict__.__contains__, ["unpack"], true, "struct.Struct.__dict__.__contains__('unpack') — unpack method is in Struct.__dict__"]
    - [struct_dict_size,   Struct.__dict__.__contains__, ["size"],   true, "struct.Struct.__dict__.__contains__('size') — size property descriptor is in Struct.__dict__"]
    - [error_mro_len_2,    error.__mro__.__len__,        [],         4,    "struct.error.__mro__.__len__() == 4 re-anchored in dict table"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant struct_extra200.Struct_mro_type_is_tuple:
  description: "struct.Struct.__mro__.__class__.__name__ == 'tuple' — the MRO is always a tuple"
  category: class_mro
  kind: python_call_eq
  function: Struct.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant struct_extra200.Struct_mro_len:
  description: "struct.Struct.__mro__.__len__() == 2 — Struct is a C extension type inheriting only from object"
  category: class_mro
  kind: python_call_eq
  function: Struct.__mro__.__len__
  args: []
  expected: 2

invariant struct_extra200.Struct_mro0_name:
  description: "struct.Struct.__mro__[0].__name__ == 'Struct' — first entry in Struct's MRO is Struct itself"
  category: class_mro
  kind: python_call_eq
  function: "Struct.__mro__[0].__name__.__eq__"
  args: ["Struct"]
  expected: true

invariant struct_extra200.Struct_mro1_name:
  description: "struct.Struct.__mro__[1].__name__ == 'object' — second entry in Struct's MRO is object"
  category: class_mro
  kind: python_call_eq
  function: "Struct.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant struct_extra200.error_mro_len:
  description: "struct.error.__mro__.__len__() == 4 — struct.error MRO is (error, Exception, BaseException, object)"
  category: class_mro
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

invariant struct_extra200.error_mro1_name:
  description: "struct.error.__mro__[1].__name__ == 'Exception' — struct.error's immediate base class is Exception"
  category: class_mro
  kind: python_call_eq
  function: "error.__mro__[1].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant struct_extra200.Struct_dict_has_pack:
  description: "struct.Struct.__dict__.__contains__('pack') == True — pack is a method in the Struct class __dict__"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["pack"]
  expected: true

invariant struct_extra200.Struct_dict_has_unpack:
  description: "struct.Struct.__dict__.__contains__('unpack') == True — unpack is a method in the Struct class __dict__"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["unpack"]
  expected: true

