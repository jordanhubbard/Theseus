spec: re_extra29
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra28.zspec.zsdl."
    - "Prior specs covered: re.__name__/__package__, re.compile/__name__/__module__, re.match/__name__, re.search/__name__, re.fullmatch/__name__, re.findall/__name__, re.finditer/__name__, re.sub/__name__, re.subn/__name__, re.split/__name__, re.escape/__name__, re.purge/__name__, Pattern/__name__/__module__/__qualname__, Match/__name__/__module__/__qualname__, re.error/__name__/__module__, Pattern.__bases__[0].__name__, Match.__bases__[0].__name__, re.error.__bases__[0].__name__, re.IGNORECASE/MULTILINE/DOTALL/VERBOSE values, various __qualname__ checks for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape in earlier namespaces, search/match/fullmatch/findall/finditer/subn/split __module__ in re_extra28."
    - "This spec covers: compile.__qualname__ (extra29 anchor), match.__qualname__ (extra29 anchor), search.__qualname__ (extra29 anchor), fullmatch.__qualname__ (extra29 anchor), findall.__qualname__ (extra29 anchor), finditer.__qualname__ (extra29 anchor), sub.__qualname__ (extra29 anchor), subn.__qualname__ (extra29 anchor), split.__qualname__ (extra29 anchor), escape.__qualname__ (extra29 anchor), compile.__module__ (extra29 anchor), match.__module__ (extra29 anchor)."
    - "re.compile.__qualname__ == 'compile' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.match.__qualname__ == 'match' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.search.__qualname__ == 'search' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.fullmatch.__qualname__ == 'fullmatch' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.findall.__qualname__ == 'findall' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.finditer.__qualname__ == 'finditer' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.sub.__qualname__ == 'sub' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.subn.__qualname__ == 'subn' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.split.__qualname__ == 'split' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.escape.__qualname__ == 'escape' — module-level function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.compile.__module__ == 're' — module-level function; __module__ equals module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.match.__module__ == 're' — module-level function; __module__ equals module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile.__qualname__ (extra29-namespace anchor)
#
# re_extra25 records compile.__qualname__ == 'compile' in the extra25 namespace.
# re_extra8 covers compile.__qualname__ in a table. This spec provides a fresh
# extra29-namespace standalone anchor. Module-level functions have __qualname__
# equal to their simple __name__.
# ---------------------------------------------------------------------------

invariant re_extra29.compile.qualname:
  description: "re.compile.__qualname__ == 'compile' — module-level function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

