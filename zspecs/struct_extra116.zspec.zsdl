spec: struct_extra116
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra115.zspec.zsdl — covers error.__class__.__module__.__eq__('builtins') / error.__class__.__module__.__len__()==8 / __all__.__class__.__module__.__eq__('builtins') / __all__.__class__.__module__.__len__()==8 (table + invariants)."
    - "struct_extra112.zspec.zsdl — covers Struct.__new__/__repr__/__sizeof__/__reduce_ex__/__reduce__ __qualname__.__eq__ and __qualname__.__len__() / __new__/__sizeof__/__reduce__ __class__.__name__.__eq__ (table + invariants)."
    - "struct_extra101.zspec.zsdl — covers Struct.__init__.__qualname__.__eq__('Struct.__init__') / Struct.__init__.__qualname__.__len__()==15 / Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') (table + invariants)."
    - "struct_extra40.zspec.zsdl — covers Struct.__init__.__name__.__eq__('__init__') / Struct.__init__.__name__.__len__()==8 as grouped table rows (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra115; it does NOT duplicate invariants present in those files."
    - "Wave 280 theme: Struct dunder __name__ (bare method name, not __qualname__) for __new__, __sizeof__, __reduce__, __reduce_ex__ not yet covered — extra112 anchors all four __qualname__ equality/length; extra40 anchors Struct.__init__.__name__.__eq__ and __len__; NOT YET covered: __new__.__name__.__eq__('__new__') and __len__()==7; __sizeof__.__name__.__eq__('__sizeof__') and __len__()==10; __reduce__.__name__.__eq__('__reduce__') and __len__()==10; __reduce_ex__.__name__.__eq__('__reduce_ex__') and __len__()==13."
    - "struct.Struct.__new__.__name__ == '__new__'. len('__new__')==7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__name__ == '__sizeof__'. len('__sizeof__')==10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce__.__name__ == '__reduce__'. len('__reduce__')==10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce_ex__.__name__ == '__reduce_ex__'. len('__reduce_ex__')==13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__name__.__len__() == 8 — len('__init__')==8 (covered in extra40; cross-check in this spec)."
    - "Note: __sizeof__ and __reduce__ both have __name__.__len__()==10 — a coincidence since len('__sizeof__')==len('__reduce__')==10. __reduce_ex__ is 3 chars longer (13) due to the '_ex' suffix. __new__ is the shortest at 7 chars. These are the BARE method names (just '__reduce__' etc.) as stored in the __name__ attribute, distinct from the __qualname__ ('object.__reduce__') which includes the defining class prefix. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__name__.__eq__('__new__') == True
# struct.Struct.__new__.__name__.__len__() == 7
# struct.Struct.__sizeof__.__name__.__eq__('__sizeof__') == True
# struct.Struct.__sizeof__.__name__.__len__() == 10
# struct.Struct.__reduce__.__name__.__len__() == 10
#
# Wave 280 theme: Struct dunder method bare __name__ values and lengths.
#
# struct_extra40 anchors Struct.__init__.__name__.__eq__('__init__') and
# Struct.__init__.__name__.__len__()==8. struct_extra112 anchors all the __qualname__
# equality and length values for __new__/__sizeof__/__reduce__/__reduce_ex__. But
# no prior spec anchors the BARE __name__ (without the class prefix) for __new__,
# __sizeof__, __reduce__, or __reduce_ex__. The bare __name__ is the method name as
# stored in the descriptor — for Struct-defined methods ('__new__', '__sizeof__') it
# is the method name; for object-inherited methods ('__reduce__', '__reduce_ex__') it
# is also the bare method name. __sizeof__ and __reduce__ both have __name__ of length
# 10 — a coincidence. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra116.Struct_dunder_bare_name_values:
  description: "Struct.__new__.__name__.__eq__('__new__')==True / Struct.__new__.__name__.__len__()==7 / Struct.__sizeof__.__name__.__eq__('__sizeof__')==True / Struct.__sizeof__.__name__.__len__()==10 / Struct.__reduce__.__name__.__len__()==10 — bare __name__ for Struct dunder methods (distinct from __qualname__ which includes defining class prefix); extra40 anchors __init__ bare name; no prior spec anchors __new__/__sizeof__/__reduce__ bare names; coincidence: __sizeof__ and __reduce__ both have __name__.__len__()==10; first structmeth116 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmeth116

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq,      "Struct.__new__.__name__.__eq__",     ["__new__"],    true, "Struct.__new__.__name__ is '__new__' (bare method name; qualname is 'Struct.__new__'; extra112 anchors qualname; first bare name anchor for __new__)"]
    - [new_name_len,     "Struct.__new__.__name__.__len__",    [],             7,    "Struct.__new__.__name__.__len__() is 7 (len('__new__')==7; shortest dunder name in this group; '__'=2 + 'new'=3 + '__'=2)"]
    - [sizeof_name_eq,   "Struct.__sizeof__.__name__.__eq__",  ["__sizeof__"], true, "Struct.__sizeof__.__name__ is '__sizeof__' (bare method name; qualname is 'Struct.__sizeof__'; extra112 anchors qualname; first bare name anchor for __sizeof__)"]
    - [sizeof_name_len,  "Struct.__sizeof__.__name__.__len__", [],             10,   "Struct.__sizeof__.__name__.__len__() is 10 (len('__sizeof__')==10; coincidentally same as len('__reduce__')==10; '__'=2 + 'sizeof'=6 + '__'=2)"]
    - [reduce_name_len,  "Struct.__reduce__.__name__.__len__", [],             10,   "Struct.__reduce__.__name__.__len__() is 10 (len('__reduce__')==10; coincidentally same as len('__sizeof__')==10; inherited from object; '__'=2 + 'reduce'=6 + '__'=2)"]

# ---------------------------------------------------------------------------
# struct.Struct.__reduce__.__name__.__eq__('__reduce__') == True
# struct.Struct.__reduce_ex__.__name__.__eq__('__reduce_ex__') == True
# struct.Struct.__reduce_ex__.__name__.__len__() == 13
# struct.Struct.__new__.__name__.__len__() == 7
# struct.Struct.__sizeof__.__name__.__len__() == 10
#
# Wave 280 theme: __reduce__/__reduce_ex__ bare names and the length progression.
#
# The dunder names in this spec form an arithmetic length sequence: __new__=7,
# __init__=8 (extra40), __sizeof__=10, __reduce__=10, __reduce_ex__=13. The three
# longest (__sizeof__=10, __reduce__=10, __reduce_ex__=13) have a notable pattern:
# __sizeof__ and __reduce__ share length 10, then __reduce_ex__ adds '_ex' (3 chars)
# to reach 13. This table anchors the __reduce__ and __reduce_ex__ equality checks
# and the __reduce_ex__ length as a grouped table row. No prior spec anchors
# Struct.__reduce__.__name__.__eq__('__reduce__') or __reduce_ex__.__name__.__eq__
# ('__reduce_ex__') as table rows. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra116.Struct_reduce_and_reduce_ex_bare_names:
  description: "Struct.__reduce__.__name__.__eq__('__reduce__')==True / Struct.__reduce_ex__.__name__.__eq__('__reduce_ex__')==True / Struct.__reduce_ex__.__name__.__len__()==13 / Struct.__new__.__name__.__len__()==7 / Struct.__sizeof__.__name__.__len__()==10 — bare names for object-inherited pickle methods on Struct; __reduce_ex__ adds '_ex' suffix (3 chars) making it 13 chars; progression: __new__=7, __sizeof__=10, __reduce__=10, __reduce_ex__=13; extra112 anchors qualnames; no prior spec anchors bare __reduce__/__reduce_ex__ names; first structmeth116 anchor for reduce group"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmeth116

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,      "Struct.__reduce__.__name__.__eq__",      ["__reduce__"],    true, "Struct.__reduce__.__name__ is '__reduce__' (bare name; inherited from object; qualname is 'object.__reduce__'; extra112 anchors qualname; first bare name anchor)"]
    - [reduce_ex_name_eq,   "Struct.__reduce_ex__.__name__.__eq__",   ["__reduce_ex__"], true, "Struct.__reduce_ex__.__name__ is '__reduce_ex__' (bare name; inherited from object; qualname is 'object.__reduce_ex__'; extra112 anchors qualname; first bare name anchor)"]
    - [reduce_ex_name_len,  "Struct.__reduce_ex__.__name__.__len__",  [],                13,   "Struct.__reduce_ex__.__name__.__len__() is 13 (len('__reduce_ex__')==13; '_ex' suffix adds 3 chars over __reduce__=10; longest dunder name in this group)"]
    - [new_name_len2,       "Struct.__new__.__name__.__len__",        [],                7,    "Struct.__new__.__name__.__len__() is 7 (cross-check; shortest dunder name in this group; '__new__'=7)"]
    - [sizeof_name_len2,    "Struct.__sizeof__.__name__.__len__",     [],                10,   "Struct.__sizeof__.__name__.__len__() is 10 (cross-check; same as __reduce__=10; '__sizeof__'=10)"]

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__name__.__eq__('__new__') — standalone
# struct.Struct.__new__.__name__.__len__() == 7
# struct.Struct.__reduce__.__name__.__eq__('__reduce__') — standalone
# struct.Struct.__reduce__.__name__.__len__() == 10
# struct.Struct.__reduce_ex__.__name__.__eq__('__reduce_ex__') — standalone
#
# Wave 280 theme: cross-check grouping all five bare name checks.
#
# This table cross-checks the equality and length values across all four methods
# to confirm consistency. struct_extra40 anchors Struct.__init__.__name__.__eq__('__init__')
# and __len__()==8; this table anchors __new__, __sizeof__, __reduce__, __reduce_ex__
# bare names. No other existing spec groups these four together for cross-verification.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra116.Struct_dunder_bare_name_cross_check:
  description: "Struct.__new__.__name__.__eq__('__new__')==True / Struct.__sizeof__.__name__.__eq__('__sizeof__')==True / Struct.__reduce__.__name__.__eq__('__reduce__')==True / Struct.__reduce_ex__.__name__.__eq__('__reduce_ex__')==True / Struct.__reduce_ex__.__name__.__len__()==13 — cross-check grouping all four bare name equality assertions together; extra40 anchors __init__ bare name; extra112 anchors qualnames; this table is the first to group all four in a cross-check table; first structmeth116 cross-check anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmeth116

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq2,       "Struct.__new__.__name__.__eq__",      ["__new__"],    true, "Struct.__new__.__name__ is '__new__' (cross-check; bare method name; confirms extra112 qualname starts with '__new__')"]
    - [sizeof_name_eq2,    "Struct.__sizeof__.__name__.__eq__",   ["__sizeof__"], true, "Struct.__sizeof__.__name__ is '__sizeof__' (cross-check; bare method name; confirms extra112 qualname starts with '__sizeof__')"]
    - [reduce_name_eq2,    "Struct.__reduce__.__name__.__eq__",   ["__reduce__"], true, "Struct.__reduce__.__name__ is '__reduce__' (cross-check; inherited from object; qualname is 'object.__reduce__' but bare name is '__reduce__')"]
    - [reduce_ex_name_eq2, "Struct.__reduce_ex__.__name__.__eq__",["__reduce_ex__"],true,"Struct.__reduce_ex__.__name__ is '__reduce_ex__' (cross-check; inherited from object; bare name has '_ex' suffix)"]
    - [reduce_ex_len2,     "Struct.__reduce_ex__.__name__.__len__",[],             13,  "Struct.__reduce_ex__.__name__.__len__() is 13 (cross-check; len('__reduce_ex__')==13; longest bare dunder name in this spec)"]

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__name__.__len__() == 7 — standalone
#
# struct.Struct.__new__.__name__.__len__() is 7. '__new__' has 7 chars:
# '__'=2 + 'new'=3 + '__'=2 = 7. Struct.__new__ is the constructor function for
# new Struct instances — it allocates memory and initializes the C-level format
# string field. At the C level it is a builtin_function_or_method (not a
# wrapper_descriptor like __init__). struct_extra40 anchors Struct.__init__.__name__
# .__len__()==8; struct_extra112 anchors Struct.__new__.__qualname__.__len__()==14.
# No prior struct spec anchors Struct.__new__.__name__.__len__()==7 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra116.Struct_new_name_len_7:
  description: "struct.Struct.__new__.__name__.__len__() == 7 — len('__new__')==7 ('__'=2 + 'new'=3 + '__'=2; Struct.__new__ is builtin_function_or_method allocating new Struct instances; extra40 anchors __init__.__name__.__len__()==8; extra112 anchors __new__.__qualname__.__len__()==14; no prior spec anchors __new__ bare name length as standalone; first standalone under structmeth116)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__new__.__name__.__len__"
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__name__.__len__() == 10 — standalone
#
# struct.Struct.__sizeof__.__name__.__len__() is 10. '__sizeof__' has 10 chars:
# '__'=2 + 'sizeof'=6 + '__'=2 = 10. Struct.__sizeof__ is a Struct-defined method_descriptor
# that returns the internal size of the Struct object in bytes (C struct size). It is
# the same length as Struct.__reduce__.__name__.__len__()==10 — a coincidence since both
# names have 6-char bodies ('sizeof' and 'reduce') surrounded by double underscores.
# struct_extra112 anchors __sizeof__.__qualname__.__len__()==17; no prior spec anchors
# __sizeof__.__name__.__len__()==10 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra116.Struct_sizeof_name_len_10:
  description: "struct.Struct.__sizeof__.__name__.__len__() == 10 — len('__sizeof__')==10 ('__'=2 + 'sizeof'=6 + '__'=2; method_descriptor returning C-level memory size of Struct object; coincidentally same length as '__reduce__'=10; extra112 anchors __sizeof__.__qualname__.__len__()==17; no prior spec anchors __sizeof__ bare name length as standalone; first standalone under structmeth116)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__sizeof__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# struct.Struct.__reduce__.__name__.__len__() == 10 — standalone
#
# struct.Struct.__reduce__.__name__.__len__() is 10. '__reduce__' has 10 chars:
# '__'=2 + 'reduce'=6 + '__'=2 = 10. Struct.__reduce__ is inherited from object (its
# __qualname__ is 'object.__reduce__', not 'Struct.__reduce__'). The bare __name__ is
# '__reduce__' regardless of inheritance — the __name__ attribute stores only the
# method's own name, not the defining class. struct_extra112 anchors
# __reduce__.__qualname__.__len__()==17; no prior spec anchors __reduce__ bare name
# length as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra116.Struct_reduce_name_len_10:
  description: "struct.Struct.__reduce__.__name__.__len__() == 10 — len('__reduce__')==10 ('__'=2 + 'reduce'=6 + '__'=2; inherited from object; qualname is 'object.__reduce__' but bare __name__ is '__reduce__'; coincidentally same as '__sizeof__'=10; extra112 anchors qualname length==17; no prior spec anchors __reduce__ bare name length as standalone; first standalone under structmeth116)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__reduce__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# struct.Struct.__reduce_ex__.__name__.__len__() == 13 — standalone
#
# struct.Struct.__reduce_ex__.__name__.__len__() is 13. '__reduce_ex__' has 13 chars:
# '__'=2 + 'reduce_ex'=9 + '__'=2 = 13. __reduce_ex__ is the extended version of
# __reduce__, taking a protocol parameter. It is inherited from object (qualname is
# 'object.__reduce_ex__'). The 3-char suffix '_ex' differentiates it from __reduce__
# (10 chars), making __reduce_ex__ (13 chars) the longest bare dunder name in this spec.
# struct_extra112 anchors __reduce_ex__.__qualname__.__len__()==20; no prior struct
# spec anchors __reduce_ex__ bare name length as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra116.Struct_reduce_ex_name_len_13:
  description: "struct.Struct.__reduce_ex__.__name__.__len__() == 13 — len('__reduce_ex__')==13 ('__'=2 + 'reduce_ex'=9 + '__'=2; '_ex' suffix adds 3 chars over __reduce__=10; inherited from object; used by pickle protocol versions; extra112 anchors qualname __len__()==20; no prior spec anchors __reduce_ex__ bare name length as standalone; first standalone under structmeth116)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__reduce_ex__.__name__.__len__"
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__name__.__eq__('__sizeof__') — standalone
#
# struct.Struct.__sizeof__.__name__ is '__sizeof__'. __sizeof__ is a Struct-specific
# method returning the internal C-level memory size of a Struct object (not the format
# string size — that is .size). struct_extra112 anchors __sizeof__.__qualname__.__eq__
# ('Struct.__sizeof__') confirming the Struct prefix; this standalone confirms that
# the bare __name__ (without class prefix) is '__sizeof__'. No prior struct spec
# anchors __sizeof__.__name__.__eq__('__sizeof__') as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra116.Struct_sizeof_name_eq:
  description: "struct.Struct.__sizeof__.__name__.__eq__('__sizeof__') == True — bare __name__ is '__sizeof__' (without class prefix; qualname is 'Struct.__sizeof__' with prefix; extra112 anchors qualname equality; no prior struct spec anchors bare __sizeof__ name as standalone; first standalone under structmeth116)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__sizeof__.__name__.__eq__"
  args: ["__sizeof__"]
  expected: true
