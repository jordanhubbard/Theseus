spec: decimal_extra1441
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 543 (_extra1441): ABC machinery focus — __subclasshook__ and __instancecheck__ checks."
    - "decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation use plain 'type' metaclass."
    - "__subclasshook__ is inherited from object.__dict__ — not present in any decimal class __dict__."
    - "__instancecheck__ is on the plain 'type' metaclass — not in the class __dict__ itself."
    - "All __subclasshook__.__class__.__name__ and __instancecheck__.__class__.__name__ yield 'builtin_function_or_method'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1441.subclasshook_class_name:
  description: "decimal class __subclasshook__.__class__.__name__ — all resolve as builtin_function_or_method"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: dc1441sh
  columns: [id, function, args, expected]
  rows:
    - [dc1441sh001, decimal.Decimal.__subclasshook__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [dc1441sh002, decimal.Context.__subclasshook__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [dc1441sh003, decimal.DecimalException.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [dc1441sh004, decimal.InvalidOperation.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table decimal_extra1441.instancecheck_class_name:
  description: "decimal class __instancecheck__.__class__.__name__ — all resolve as builtin_function_or_method (plain type metaclass)"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: dc1441ic
  columns: [id, function, args, expected]
  rows:
    - [dc1441ic001, decimal.Decimal.__instancecheck__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [dc1441ic002, decimal.Context.__instancecheck__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [dc1441ic003, decimal.DecimalException.__instancecheck__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [dc1441ic004, decimal.InvalidOperation.__instancecheck__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table decimal_extra1441.subclasshook_not_in_dict:
  description: "decimal class __dict__ does NOT contain __subclasshook__ — inherited from object"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: dc1441sd
  columns: [id, function, args, expected]
  rows:
    - [dc1441sd001, decimal.Decimal.__dict__.__contains__,          ["__subclasshook__"], false]
    - [dc1441sd002, decimal.Context.__dict__.__contains__,          ["__subclasshook__"], false]
    - [dc1441sd003, decimal.DecimalException.__dict__.__contains__, ["__subclasshook__"], false]
    - [dc1441sd004, decimal.InvalidOperation.__dict__.__contains__, ["__subclasshook__"], false]

table decimal_extra1441.instancecheck_not_in_dict:
  description: "decimal class __dict__ does NOT contain __instancecheck__ — it is on the metaclass"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: dc1441id
  columns: [id, function, args, expected]
  rows:
    - [dc1441id001, decimal.Decimal.__dict__.__contains__,          ["__instancecheck__"], false]
    - [dc1441id002, decimal.Context.__dict__.__contains__,          ["__instancecheck__"], false]
    - [dc1441id003, decimal.DecimalException.__dict__.__contains__, ["__instancecheck__"], false]
    - [dc1441id004, decimal.InvalidOperation.__dict__.__contains__, ["__instancecheck__"], false]

table decimal_extra1441.plain_type_metaclass:
  description: "decimal classes use plain 'type' metaclass — no ABCMeta involvement"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: dc1441mc
  columns: [id, function, args, expected]
  rows:
    - [dc1441mc001, decimal.Decimal.__class__.__name__.__eq__,          ["type"], true]
    - [dc1441mc002, decimal.Context.__class__.__name__.__eq__,          ["type"], true]
    - [dc1441mc003, decimal.DecimalException.__class__.__name__.__eq__, ["type"], true]
    - [dc1441mc004, decimal.InvalidOperation.__class__.__name__.__eq__, ["type"], true]

table decimal_extra1441.doc_and_module_in_dict:
  description: "decimal classes carry __doc__ and __module__ in their own __dict__"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: dc1441dm
  columns: [id, function, args, expected]
  rows:
    - [dc1441dm001, decimal.Decimal.__dict__.__contains__,          ["__doc__"], true]
    - [dc1441dm002, decimal.Context.__dict__.__contains__,          ["__doc__"], true]
    - [dc1441dm003, decimal.DecimalException.__dict__.__contains__, ["__doc__"], true]
    - [dc1441dm004, decimal.InvalidOperation.__dict__.__contains__, ["__doc__"], true]
    - [dc1441dm005, decimal.Decimal.__dict__.__contains__,          ["__module__"], true]
    - [dc1441dm006, decimal.InvalidOperation.__dict__.__contains__, ["__module__"], true]
