table itertools_extra1231.dict_contains_infinite_and_combinatoric:
  description: "itertools.__dict__.__contains__ for infinite iterators and combinatoric iterators"
  kind: python_call_eq
  category: dict_contains_infinite_and_combinatoric
  id_prefix: it1231dc
  columns: [id, function, args, expected]
  rows:
    - [it1231dc001, itertools.__dict__.__contains__, ["chain"],           true]
    - [it1231dc002, itertools.__dict__.__contains__, ["count"],           true]
    - [it1231dc003, itertools.__dict__.__contains__, ["cycle"],           true]
    - [it1231dc004, itertools.__dict__.__contains__, ["repeat"],          true]
    - [it1231dc005, itertools.__dict__.__contains__, ["accumulate"],      true]
    - [it1231dc006, itertools.__dict__.__contains__, ["combinations"],    true]
    - [it1231dc007, itertools.__dict__.__contains__, ["product"],         true]
    - [it1231dc008, itertools.__dict__.__contains__, ["groupby"],         true]

