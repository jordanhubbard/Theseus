spec: pretty_time
version: ">=1.1.0"
backend: node(pretty-time)

docs: https://github.com/jonschlinkert/pretty-time#readme

provenance:
  derived_from:
    - "pretty-time README — https://github.com/jonschlinkert/pretty-time#readme"
    - "process.hrtime() docs — https://nodejs.org/api/process.html#processhrtimetime"
    - "Test vectors verified with pretty-time via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "pretty-time source"
  notes:
    - "Format process.hrtime [seconds, nanoseconds] tuples into human readable durations (5μs / 1s / 1m)."
    - "Install: npm install pretty-time"
    - "v1 CJS; module export IS the function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; returns a string."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant pretty_time.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant pretty_time.one_second_with_partial_nanos:
  description: "[1, 250000000] formats as '1s' (rounding picks the largest unit)"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [[1, 250000000]]
  chain: []
  expected: "1s"

invariant pretty_time.microseconds:
  description: "[0, 5000] (5μs) renders with the μs unit"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [[0, 5000]]
  chain: []
  expected: "5μs"

invariant pretty_time.minute_threshold:
  description: "[60, 0] formats as '1m'"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [[60, 0]]
  chain: []
  expected: "1m"

invariant pretty_time.explicit_seconds_unit:
  description: "Forcing 's' unit on [1, 0] returns '1s'"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [[1, 0], "s"]
  chain: []
  expected: "1s"

invariant pretty_time.zero_input:
  description: "[0, 0] formats as empty string (no significant unit)"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [[0, 0]]
  chain: []
  expected: ""

invariant pretty_time.nanoseconds:
  description: "[0, 999] formats with the ns unit"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [[0, 999]]
  chain: []
  expected: "999ns"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:52:04Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
