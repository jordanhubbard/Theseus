spec: glob_extra19
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra18.zspec.zsdl — covers __qualname__/__module__/__name__.__len__() for glob/iglob/escape in tables; glob.__name__.__len__()==4; glob.__package__.__len__()==0; glob.__name__.__class__.__name__=='str'."
  notes:
    - "This spec extends glob_extra18.zspec.zsdl."
    - "Prior specs covered: __qualname__/__module__/__name__.__len__() for glob/iglob/escape as tables; module-level __name__/__package__.__len__(); __name__.__class__.__name__; __spec__/__loader__ identity; __qualname__/__module__/__name__ equality for all public functions."
    - "This spec covers: __qualname__.__eq__() equality checks for glob/iglob/escape as a table (confirming qualname equals name for top-level functions); __doc__.__class__.__name__ for glob/iglob/escape/module as a table (all 'str'); __spec__.__class__.__name__.__len__()==10 ('ModuleSpec'); __loader__.__class__.__name__.__len__()==16 ('SourceFileLoader'); __spec__/__loader__ class name eq-checks as standalone invariants."
    - "glob.glob.__qualname__.__eq__('glob') == True. Verified."
    - "glob.iglob.__qualname__.__eq__('iglob') == True. Verified."
    - "glob.escape.__qualname__.__eq__('escape') == True. Verified."
    - "glob.__doc__.__class__.__name__ == 'str'. Verified."
    - "glob.glob.__doc__.__class__.__name__ == 'str'. Verified."
    - "glob.iglob.__doc__.__class__.__name__ == 'str'. Verified."
    - "glob.escape.__doc__.__class__.__name__ == 'str'. Verified."
    - "glob.__spec__.__class__.__name__ == 'ModuleSpec' (len 10). Verified."
    - "glob.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16). Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__eq__() for glob/iglob/escape
#
# For top-level functions __qualname__ equals __name__. glob_extra17 confirmed
# this via __eq__ for individual functions. This table groups the eq-checks
# in the extra19 namespace as a dense cross-reference table.
# Verified: glob==True, iglob==True, escape==True.
# ---------------------------------------------------------------------------

table glob_extra19.qualname_eq:
  description: "__qualname__.__eq__() confirms qualname equals name for top-level functions glob/iglob/escape"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqeq19

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__qualname__.__eq__",   ["glob"],   true]
    - [iglob,  "iglob.__qualname__.__eq__",  ["iglob"],  true]
    - [escape, "escape.__qualname__.__eq__", ["escape"], true]

# ---------------------------------------------------------------------------
# Table: __doc__.__class__.__name__ for glob/iglob/escape and module
#
# All docstrings are str objects. No prior glob spec groups __doc__.__class__.__name__
# checks for functions and the module itself in a single table.
# Verified: glob.__doc__.__class__.__name__=='str', glob.glob.__doc__.__class__.__name__=='str',
#           glob.iglob.__doc__.__class__.__name__=='str', glob.escape.__doc__.__class__.__name__=='str'.
# ---------------------------------------------------------------------------

table glob_extra19.doc_class_names:
  description: "__doc__.__class__.__name__ == 'str' for glob module and glob/iglob/escape functions"
  kind: python_call_eq
  category: doc_attrs
  id_prefix: doccn19

  columns: [id, function, args, expected]
  rows:
    - [module, "__doc__.__class__.__name__.__eq__",        ["str"], true]
    - [glob,   "glob.__doc__.__class__.__name__.__eq__",   ["str"], true]
    - [iglob,  "iglob.__doc__.__class__.__name__.__eq__",  ["str"], true]
    - [escape, "escape.__doc__.__class__.__name__.__eq__", ["str"], true]

# ---------------------------------------------------------------------------
# Standalone: glob.__spec__.__class__.__name__.__len__() == 10
#
# glob.__spec__.__class__.__name__ == 'ModuleSpec'. len('ModuleSpec') == 10.
# No prior glob spec checks __len__() on __spec__.__class__.__name__.
# Verified: 10.
# ---------------------------------------------------------------------------

invariant glob_extra19.spec.class_name_len:
  description: "glob.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Standalone: glob.__loader__.__class__.__name__.__len__() == 16
#
# glob.__loader__.__class__.__name__ == 'SourceFileLoader'. len('SourceFileLoader') == 16.
# No prior glob spec checks __len__() on __loader__.__class__.__name__.
# Verified: 16.
# ---------------------------------------------------------------------------

invariant glob_extra19.loader.class_name_len:
  description: "glob.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters"
  category: module_identity
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__len__"
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Standalone: glob.__spec__.__class__.__name__.__eq__('ModuleSpec') == True
#
# Confirms the loader class is exactly 'ModuleSpec' by string equality.
# No prior glob spec checks __spec__.__class__.__name__.__eq__().
# Verified: True.
# ---------------------------------------------------------------------------

invariant glob_extra19.spec.class_name_eq:
  description: "glob.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — spec class is ModuleSpec"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True
#
# Confirms the loader class is exactly 'SourceFileLoader' by string equality.
# No prior glob spec checks __loader__.__class__.__name__.__eq__().
# Verified: True.
# ---------------------------------------------------------------------------

invariant glob_extra19.loader.class_name_eq:
  description: "glob.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — loader class is SourceFileLoader"
  category: module_identity
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__eq__"
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob.__doc__.__class__.__name__.__len__() == 3
#
# The module-level __doc__ attribute is a str. len('str') == 3.
# No prior glob spec checks __len__() on __doc__.__class__.__name__ at the
# module level.
# Verified: 3.
# ---------------------------------------------------------------------------

invariant glob_extra19.module.doc_class_name_len:
  description: "glob.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; module docstring is a str"
  category: doc_attrs
  kind: python_call_eq
  function: "__doc__.__class__.__name__.__len__"
  args: []
  expected: 3
