spec: array_extra15
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra.zspec.zsdl — covers array.__name__/__module__, ArrayType.__name__, typecodes is str, itemsize b/h, typecode b, length/getitem/tolist for 'b'."
    - "array_extra2.zspec.zsdl — covers typecodes min_length, typecodes contains b/B/h/i/l/q/f/d, itemsize table b/B/h/f/d, typecode_attr b/B/h/i/f/d."
    - "array_extra3.zspec.zsdl — covers ArrayType.__module__, itemsize H/I, typecode H/d, buffer_info, tolist/count/index on 'i', unsigned short tolist."
    - "array_extra4.zspec.zsdl — covers typecodes contains H/L/Q, itemsize l/L/Q, typecode_attr l/L/Q, array.__qualname__, bases_object, getitem B[1]."
    - "array_extra5.zspec.zsdl — covers ArrayType.__qualname__, typecodes contains 'I', tobytes class/length for 'b', itemsize lower-bound guard."
    - "array_extra6.zspec.zsdl — covers array metaclass, MRO length 2, typecodes contains 'u'/'w', class identity table, float array tolist/length/typecode for 'f'."
    - "array_extra7.zspec.zsdl — covers double array tolist/typecode/itemsize; count/index on 'b'; 'B' tolist; 'h' tolist; tobytes length for 'd'; typecodes len upper-bound guard."
    - "array_extra8.zspec.zsdl — covers typecodes.__class__.__name__ standalone; array.__name__/__module__ via __eq__ chain; 'b'/'B' typecode attr; 'i'/'h'/'d' itemsize standalone; buffer_info class/length; count/index on 'b'."
    - "array_extra9.zspec.zsdl — covers class_names table; typecodes via class path; 'i'/'l'/'q' tolist; 'f' itemsize; 'b' length [5,10,15]; 'i' index(1)==0."
    - "array_extra10.zspec.zsdl — covers 'B'/'h'/'H' boundary tolist; empty 'i' tolist; single 'b' max tolist; 'L' itemsize >= 4."
    - "array_extra14.zspec.zsdl — covers typecodes.__contains__ for all 12 typecodes; typecodes class_name_len; array module_len; array qualname_len."
  notes:
    - "This spec extends array.zspec.zsdl through array_extra14.zspec.zsdl."
    - "array.array('b', [1,2,3]).tolist() == [1,2,3] — basic tolist for signed byte. Verified."
    - "array.array('b', [1,2,3]).__len__() == 3 — length of 3-element array is 3. Verified."
    - "array.array('i', [1,2,3]).itemsize == 4 — signed int is 4 bytes on all modern platforms. Verified."
    - "array.array('b').itemsize == 1 — signed char is always 1 byte. Verified."
    - "array.array('H').itemsize == 2 — unsigned short is 2 bytes. Verified."
    - "array.array('d').itemsize == 8 — double is 8 bytes (IEEE 754). Verified."
    - "itemsize table covers b/B/h/H/i/I/d with __eq__ comparisons (all verified at runtime)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# array.array('b', [1,2,3]).tolist() == [1,2,3]
#
# array_extra and array_extra10 cover tolist for 'b' but with different
# fixtures (multi-element and single-element). This anchor confirms the
# standard [1,2,3] fixture from the extra15 namespace.
# ---------------------------------------------------------------------------

invariant array_extra15.tolist.signed_byte_123:
  description: "array.array('b', [1,2,3]).tolist() == [1,2,3] — tolist converts to plain Python list"
  category: tolist
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: tolist
  method_args: []
  expected: [1, 2, 3]

# ---------------------------------------------------------------------------
# array.array('b', [1,2,3]).__len__() == 3
#
# The length of an array with 3 elements is 3. array_extra covers __len__
# for 'b'[1,2,3] in a prior namespace; this anchors the same fact from extra15.
# ---------------------------------------------------------------------------

invariant array_extra15.len.signed_byte_123:
  description: "array.array('b', [1,2,3]).__len__() == 3 — 3-element array has length 3"
  category: length
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: __len__
  method_args: []
  expected: 3

# ---------------------------------------------------------------------------
# itemsize table — b/B/h/H/i/I/d
#
# Each typecode has a fixed itemsize on all modern platforms. This table
# uses exact __eq__ comparisons via method: itemsize.__eq__, providing a
# fresh id_prefix (is15) that does not conflict with any prior spec.
# Values: b=1, B=1, h=2, H=2, i=4, I=4, d=8. All verified at runtime.
# ---------------------------------------------------------------------------

table array_extra15.itemsize.exact:
  description: "array.array(typecode).itemsize exact values for b/B/h/H/i/I/d"
  kind: python_call_eq
  category: itemsize
  id_prefix: is15

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [b, array, ["b"], itemsize.__eq__, [1], true]
    - [B, array, ["B"], itemsize.__eq__, [1], true]
    - [h, array, ["h"], itemsize.__eq__, [2], true]
    - [H, array, ["H"], itemsize.__eq__, [2], true]
    - [i, array, ["i"], itemsize.__eq__, [4], true]
    - [I, array, ["I"], itemsize.__eq__, [4], true]
    - [d, array, ["d"], itemsize.__eq__, [8], true]
