spec: asyncio_extra131
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec covers: wave 255 theme — asyncio.PriorityQueue and asyncio.LifoQueue class identity. NEW in extra131: asyncio.PriorityQueue.__name__=='PriorityQueue' (len=13); asyncio.PriorityQueue.__module__=='asyncio.queues' (len=14); asyncio.PriorityQueue.__bases__[0].__name__=='Queue'; asyncio.PriorityQueue.__mro__.__len__()==4 (MRO=[PriorityQueue, Queue, _LoopBoundMixin, object]); asyncio.PriorityQueue.__qualname__=='PriorityQueue' (len=13); asyncio.LifoQueue.__name__=='LifoQueue' (len=9); asyncio.LifoQueue.__module__=='asyncio.queues'; asyncio.LifoQueue.__bases__[0].__name__=='Queue'; asyncio.LifoQueue.__mro__.__len__()==4 (MRO=[LifoQueue, Queue, _LoopBoundMixin, object]); asyncio.LifoQueue.__qualname__=='LifoQueue' (len=9); asyncio.PriorityQueue.get.__qualname__=='Queue.get' (inherited from Queue); asyncio.LifoQueue.put.__qualname__=='Queue.put' (inherited from Queue). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.PriorityQueue.__mro__.__len__() == 4. MRO is [PriorityQueue, Queue, _LoopBoundMixin, object] — four elements because the asyncio Queue hierarchy includes _LoopBoundMixin as an intermediate class between Queue and object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.PriorityQueue.get.__qualname__ == 'Queue.get'. PriorityQueue and LifoQueue inherit all their methods (get, put, get_nowait, put_nowait, empty) from the parent Queue class; the qualnames reflect the defining class 'Queue', not the subclass 'PriorityQueue' or 'LifoQueue'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.PriorityQueue.__module__ == 'asyncio.queues'. PriorityQueue and LifoQueue are both pure-Python classes defined in Lib/asyncio/queues.py; their __module__ is 'asyncio.queues' (len=14), not '_asyncio' (unlike asyncio.Task and asyncio.Future which are C extension classes). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.PriorityQueue class identity — extra131
#
# Wave 255 theme: asyncio PriorityQueue and LifoQueue class identity.
#
# asyncio.PriorityQueue.__name__               == 'PriorityQueue'    (len=13)
# asyncio.PriorityQueue.__module__             == 'asyncio.queues'   (len=14)
# asyncio.PriorityQueue.__bases__[0].__name__  == 'Queue'
# asyncio.PriorityQueue.__mro__.__len__()      == 4
# asyncio.PriorityQueue.__qualname__           == 'PriorityQueue'    (len=13)
# asyncio.PriorityQueue.__class__.__name__     == 'type'
# ---------------------------------------------------------------------------

table asyncio_extra131.asyncio_priorityqueue_class_identity:
  description: "asyncio.PriorityQueue class identity checks in asynciopqident131 namespace — wave 255 theme: PriorityQueue and LifoQueue class identity in asyncio.queues; asyncio.PriorityQueue.__name__.__eq__('PriorityQueue')==True (len=13: 'Priority'=8 + 'Queue'=5); asyncio.PriorityQueue.__module__.__eq__('asyncio.queues')==True (len=14: 'asyncio.'=8 + 'queues'=6; pure-Python, not the C extension '_asyncio'); asyncio.PriorityQueue.__bases__[0].__name__.__eq__('Queue')==True (PriorityQueue inherits directly from asyncio.Queue); asyncio.PriorityQueue.__mro__.__len__()==4 (MRO is [PriorityQueue, Queue, _LoopBoundMixin, object] — four elements including the _LoopBoundMixin intermediate mixin); asyncio.PriorityQueue.__qualname__.__eq__('PriorityQueue')==True (module-level class, qualname equals name, len=13); asyncio.PriorityQueue.__class__.__name__.__eq__('type')==True (PriorityQueue is a class, metaclass is type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciopqident131

  columns: [id, function, args, expected, description]
  rows:
    - [pq_name_eq,   asyncio.PriorityQueue.__name__.__eq__,                 ["PriorityQueue"],  true, "asyncio.PriorityQueue.__name__ == 'PriorityQueue' (len=13); verified with Python 3.14.3"]
    - [pq_name_len,  asyncio.PriorityQueue.__name__.__len__,                [],                 13,   "asyncio.PriorityQueue.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [pq_module_eq, asyncio.PriorityQueue.__module__.__eq__,               ["asyncio.queues"], true, "asyncio.PriorityQueue.__module__ == 'asyncio.queues' (len=14, pure-Python not C extension); verified with Python 3.14.3"]
    - [pq_base0,     "asyncio.PriorityQueue.__bases__[0].__name__.__eq__",  ["Queue"],          true, "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue' (inherits from asyncio.Queue); verified with Python 3.14.3"]
    - [pq_mro_len,   asyncio.PriorityQueue.__mro__.__len__,                 [],                 4,    "asyncio.PriorityQueue.__mro__.__len__() == 4 — [PriorityQueue, Queue, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [pq_qualname,  asyncio.PriorityQueue.__qualname__.__eq__,             ["PriorityQueue"],  true, "asyncio.PriorityQueue.__qualname__ == 'PriorityQueue' (len=13, qualname equals name); verified with Python 3.14.3"]
    - [pq_class_nm,  asyncio.PriorityQueue.__class__.__name__.__eq__,       ["type"],           true, "asyncio.PriorityQueue.__class__.__name__ == 'type' (metaclass is type); verified with Python 3.14.3"]

