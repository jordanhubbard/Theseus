table asyncio_extra131.asyncio_queue_inherited_qualnames:
  description: "asyncio PriorityQueue and LifoQueue inherited method __qualname__ checks in asynciopqident131 namespace — wave 255 theme: PriorityQueue and LifoQueue inherit all methods from their parent asyncio.Queue; when accessed on PriorityQueue or LifoQueue, method qualnames use 'Queue.' prefix (the defining class, not the inheriting class); asyncio.PriorityQueue.get.__qualname__.__eq__('Queue.get')==True (len=9: 'Queue.'=6+'get'=3); asyncio.PriorityQueue.put.__qualname__.__eq__('Queue.put')==True (len=9: same length as Queue.get); asyncio.PriorityQueue.put_nowait.__qualname__.__eq__('Queue.put_nowait')==True (len=15: 'Queue.'=6+'put_nowait'=9); asyncio.PriorityQueue.get_nowait.__qualname__.__eq__('Queue.get_nowait')==True (len=15: same length as put_nowait); asyncio.LifoQueue.get.__qualname__.__eq__('Queue.get')==True (same as PriorityQueue.get — both inherit from Queue); asyncio.LifoQueue.put.__qualname__.__eq__('Queue.put')==True; asyncio.PriorityQueue.__module__.__len__()==14; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciopqident131b

  columns: [id, function, args, expected, description]
  rows:
    - [pq_get_qeq,   asyncio.PriorityQueue.get.__qualname__.__eq__,         ["Queue.get"],      true, "asyncio.PriorityQueue.get.__qualname__ == 'Queue.get' (len=9, inherited from Queue); verified with Python 3.14.3"]
    - [pq_get_qlen,  asyncio.PriorityQueue.get.__qualname__.__len__,        [],                 9,    "asyncio.PriorityQueue.get.__qualname__.__len__() == 9 ('Queue.'=6+'get'=3); verified with Python 3.14.3"]
    - [pq_put_qeq,   asyncio.PriorityQueue.put.__qualname__.__eq__,         ["Queue.put"],      true, "asyncio.PriorityQueue.put.__qualname__ == 'Queue.put' (len=9, inherited from Queue); verified with Python 3.14.3"]
    - [pq_pnw_qeq,   asyncio.PriorityQueue.put_nowait.__qualname__.__eq__,  ["Queue.put_nowait"], true, "asyncio.PriorityQueue.put_nowait.__qualname__ == 'Queue.put_nowait' (len=15); verified with Python 3.14.3"]
    - [pq_gnw_qeq,   asyncio.PriorityQueue.get_nowait.__qualname__.__eq__,  ["Queue.get_nowait"], true, "asyncio.PriorityQueue.get_nowait.__qualname__ == 'Queue.get_nowait' (len=15); verified with Python 3.14.3"]
    - [lq_get_qeq,   asyncio.LifoQueue.get.__qualname__.__eq__,             ["Queue.get"],      true, "asyncio.LifoQueue.get.__qualname__ == 'Queue.get' (len=9, same as PriorityQueue.get); verified with Python 3.14.3"]
    - [lq_put_qeq,   asyncio.LifoQueue.put.__qualname__.__eq__,             ["Queue.put"],      true, "asyncio.LifoQueue.put.__qualname__ == 'Queue.put' (len=9, inherited from Queue); verified with Python 3.14.3"]
    - [pq_mod_len,   asyncio.PriorityQueue.__module__.__len__,              [],                 14,   "asyncio.PriorityQueue.__module__.__len__() == 14 ('asyncio.queues'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra131
# ---------------------------------------------------------------------------

invariant asyncio_extra131.PriorityQueue_mro_len_is_4:
  description: "asyncio.PriorityQueue.__mro__.__len__() == 4 — asyncio.PriorityQueue's MRO is [PriorityQueue, Queue, _LoopBoundMixin, object]; this 4-element chain contrasts with asyncio.Task (MRO=[Task, Future, object], len=3) and asyncio.Future (MRO=[Future, object], len=2); the extra element is _LoopBoundMixin, a mixin that binds asyncio queue objects to the running event loop; asyncio.Queue itself has MRO len=3 ([Queue, _LoopBoundMixin, object]); PriorityQueue and LifoQueue both share the same 4-element MRO depth; PriorityQueue.__module__ is 'asyncio.queues' (pure-Python, unlike Task which is in C extension '_asyncio'); NEW in extra131: first standalone PriorityQueue MRO length invariant in asynciopqident131 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.PriorityQueue.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra131.LifoQueue_mro_len_is_4:
  description: "asyncio.LifoQueue.__mro__.__len__() == 4 — asyncio.LifoQueue's MRO is [LifoQueue, Queue, _LoopBoundMixin, object]; identical MRO depth to PriorityQueue (both subclass asyncio.Queue directly); LifoQueue.__name__ is 'LifoQueue' (len=9, shorter than PriorityQueue.__name__ len=13 by 4); LifoQueue.__module__ is 'asyncio.queues'; LifoQueue.__bases__[0].__name__ is 'Queue'; LifoQueue.get.__qualname__ is 'Queue.get' (inherited); LifoQueue.put.__qualname__ is 'Queue.put' (inherited); NEW in extra131: first standalone LifoQueue MRO length invariant in asynciopqident131 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.LifoQueue.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra131.PriorityQueue_name_len_is_13:
  description: "asyncio.PriorityQueue.__name__.__len__() == 13 — asyncio.PriorityQueue.__name__ is 'PriorityQueue' (13 chars: 'Priority'=8 + 'Queue'=5); asyncio.PriorityQueue.__qualname__ is also 'PriorityQueue' (len=13, same as __name__ because it is a module-level class); asyncio.PriorityQueue.__module__ is 'asyncio.queues' (len=14); PriorityQueue.__name__.__len__() == 13 is longer than LifoQueue.__name__.__len__()==9 by 4 chars; PriorityQueue.__class__.__name__ is 'type'; PriorityQueue.__bases__[0].__name__ is 'Queue'; NEW in extra131: first standalone PriorityQueue name length invariant in asynciopqident131 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.PriorityQueue.__name__.__len__
  args: []
  expected: 13

invariant asyncio_extra131.LifoQueue_name_len_is_9:
  description: "asyncio.LifoQueue.__name__.__len__() == 9 — asyncio.LifoQueue.__name__ is 'LifoQueue' (9 chars: 'Lifo'=4 + 'Queue'=5); asyncio.LifoQueue.__qualname__ is 'LifoQueue' (len=9, equals __name__); LifoQueue.__name__.__len__() == 9 is shorter than PriorityQueue.__name__.__len__()==13 by 4 chars; LifoQueue.__module__ is 'asyncio.queues' (len=14, same as PriorityQueue); LifoQueue.__mro__.__len__() == 4 (same as PriorityQueue); the name 'LIFO' (Last In First Out) reflects the stack-like ordering of this queue; NEW in extra131: first standalone LifoQueue name length invariant in asynciopqident131 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.LifoQueue.__name__.__len__
  args: []
  expected: 9

invariant asyncio_extra131.PriorityQueue_module_len_is_14:
  description: "asyncio.PriorityQueue.__module__.__len__() == 14 — asyncio.PriorityQueue.__module__ is 'asyncio.queues' (14 chars: 'asyncio.'=8 + 'queues'=6); asyncio.LifoQueue.__module__ is also 'asyncio.queues' (same len=14) — both PriorityQueue and LifoQueue are defined in the same Lib/asyncio/queues.py file; contrast with asyncio.Task.__module__=='_asyncio' (len=7, C extension) — the queue classes are pure-Python; asyncio.PriorityQueue is not the same as multiprocessing.queues.Queue (which is at 'multiprocessing.queues', len=22); NEW in extra131: first standalone PriorityQueue module length invariant in asynciopqident131 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.PriorityQueue.__module__.__len__
  args: []
  expected: 14
