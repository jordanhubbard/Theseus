table asyncio_extra131.asyncio_lifoqueue_class_identity:
  description: "asyncio.LifoQueue class identity checks in asynciopqident131 namespace — wave 255 theme: asyncio.LifoQueue.__name__.__eq__('LifoQueue')==True (len=9: 'Lifo'=4 + 'Queue'=5; shorter than PriorityQueue len=13 by 4 chars); asyncio.LifoQueue.__module__.__eq__('asyncio.queues')==True (same module as PriorityQueue — both defined in Lib/asyncio/queues.py); asyncio.LifoQueue.__bases__[0].__name__.__eq__('Queue')==True (LifoQueue also inherits directly from asyncio.Queue, parallel to PriorityQueue); asyncio.LifoQueue.__mro__.__len__()==4 (MRO is [LifoQueue, Queue, _LoopBoundMixin, object] — same 4-element chain as PriorityQueue); asyncio.LifoQueue.__qualname__.__eq__('LifoQueue')==True (len=9, module-level class); asyncio.LifoQueue.__class__.__name__.__eq__('type')==True; asyncio.LifoQueue.put.__qualname__.__eq__('Queue.put')==True (inherited from Queue, qualname uses defining class); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciopqident131a

  columns: [id, function, args, expected, description]
  rows:
    - [lq_name_eq,   asyncio.LifoQueue.__name__.__eq__,                 ["LifoQueue"],      true, "asyncio.LifoQueue.__name__ == 'LifoQueue' (len=9); verified with Python 3.14.3"]
    - [lq_name_len,  asyncio.LifoQueue.__name__.__len__,                [],                 9,    "asyncio.LifoQueue.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [lq_module_eq, asyncio.LifoQueue.__module__.__eq__,               ["asyncio.queues"], true, "asyncio.LifoQueue.__module__ == 'asyncio.queues' (same module as PriorityQueue); verified with Python 3.14.3"]
    - [lq_base0,     "asyncio.LifoQueue.__bases__[0].__name__.__eq__",  ["Queue"],          true, "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue' (inherits from asyncio.Queue); verified with Python 3.14.3"]
    - [lq_mro_len,   asyncio.LifoQueue.__mro__.__len__,                 [],                 4,    "asyncio.LifoQueue.__mro__.__len__() == 4 — [LifoQueue, Queue, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [lq_qualname,  asyncio.LifoQueue.__qualname__.__eq__,             ["LifoQueue"],      true, "asyncio.LifoQueue.__qualname__ == 'LifoQueue' (len=9); verified with Python 3.14.3"]
    - [lq_class_nm,  asyncio.LifoQueue.__class__.__name__.__eq__,       ["type"],           true, "asyncio.LifoQueue.__class__.__name__ == 'type'; verified with Python 3.14.3"]

