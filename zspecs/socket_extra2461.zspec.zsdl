spec: socket_extra2461
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl, socket_extra.zspec.zsdl, and socket_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "Theme: __len__ and __length_hint__ dict-presence — checking whether socket.socket defines the length protocol in its class __dict__."
    - "socket.socket.__dict__.__contains__('__len__') == False — socket objects are not sequences; len(sock) raises TypeError."
    - "socket.socket.__dict__.__contains__('__length_hint__') == False — socket objects do not define __length_hint__ either."
    - "socket.socket.__dict__.__contains__('accept') == True — accept is a method in socket.__dict__ (pure-Python wrapper in Lib/socket.py)."
    - "socket.socket.__dict__.__contains__('close') == True — close is a method in socket.__dict__."
    - "socket.socket.__dict__.__contains__('sendfile') == True — sendfile is a method in socket.__dict__."
    - "socket.socket.__dict__.__contains__('detach') == True — detach is a method in socket.__dict__."
    - "socket.socket.__dict__.__contains__('dup') == True — dup is a method in socket.__dict__."
    - "socket.socket.__dict__.__contains__('makefile') == True — makefile is a method in socket.__dict__."
    - "socket.socket.__dict__.__contains__('family') == True — family is a property descriptor in socket.__dict__."
    - "socket.socket.__dict__.__contains__('get_inheritable') == True — get_inheritable is a method in socket.__dict__."
    - "socket.socket.__dict__.__contains__('bind') == False — bind is inherited from _socket.socket (C layer), not in the Python socket.__dict__."
    - "socket.socket.__dict__.__contains__('recv') == False — recv is inherited from the C layer, not in the Python socket.__dict__."
    - "socket.socket.__dict__.__contains__('__iter__') == False — socket objects are not iterable."
    - "socket.socket.__dict__.__contains__('__bool__') == False — socket objects do not override truthiness."
    - "socket.socket.__dict__.__contains__('__hash__') == False — socket does not define __hash__ in its class __dict__."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ and __length_hint__ absence — core theme of this spec
# socket.socket defines neither __len__ nor __length_hint__ in its class __dict__.
# Sockets are I/O objects, not sequences or collections.
# ---------------------------------------------------------------------------

table socket_extra2461.socket.len_protocol:
  description: "socket.socket class __dict__ does NOT contain __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2461

  columns: [id, function, args, expected]
  rows:
    - ["sk2461-001", "socket.__dict__.__contains__", ["__len__"],         false]
    - ["sk2461-002", "socket.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Method presence — pure-Python methods defined in socket.socket.__dict__
# These are implemented in Lib/socket.py (not inherited from _socket.socket).
# ---------------------------------------------------------------------------

table socket_extra2461.socket.method_presence:
  description: "socket.socket class __dict__ contains the pure-Python wrapper methods"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2461

  columns: [id, function, args, expected]
  rows:
    - ["sk2461-010", "socket.__dict__.__contains__", ["accept"],          true]
    - ["sk2461-011", "socket.__dict__.__contains__", ["close"],           true]
    - ["sk2461-012", "socket.__dict__.__contains__", ["sendfile"],        true]
    - ["sk2461-013", "socket.__dict__.__contains__", ["detach"],          true]
    - ["sk2461-014", "socket.__dict__.__contains__", ["dup"],             true]
    - ["sk2461-015", "socket.__dict__.__contains__", ["makefile"],        true]
    - ["sk2461-016", "socket.__dict__.__contains__", ["get_inheritable"], true]

# ---------------------------------------------------------------------------
# Descriptor presence — family and type are Python-level properties
# ---------------------------------------------------------------------------

table socket_extra2461.socket.descriptor_presence:
  description: "socket.socket class __dict__ contains the family and type descriptors"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2461

  columns: [id, function, args, expected]
  rows:
    - ["sk2461-020", "socket.__dict__.__contains__", ["family"], true]
    - ["sk2461-021", "socket.__dict__.__contains__", ["type"],   true]

# ---------------------------------------------------------------------------
# C-layer method absence — bind, connect, recv, send are NOT in Python socket.__dict__
# They live in the _socket.socket C base class __dict__, not the Python subclass.
# ---------------------------------------------------------------------------

table socket_extra2461.socket.c_layer_absent:
  description: "socket.socket class __dict__ does NOT contain C-layer methods bind, connect, recv, send"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2461

  columns: [id, function, args, expected]
  rows:
    - ["sk2461-030", "socket.__dict__.__contains__", ["bind"],    false]
    - ["sk2461-031", "socket.__dict__.__contains__", ["connect"], false]
    - ["sk2461-032", "socket.__dict__.__contains__", ["recv"],    false]
    - ["sk2461-033", "socket.__dict__.__contains__", ["send"],    false]

# ---------------------------------------------------------------------------
# Absent protocols — socket.socket does not define iteration or truthiness
# ---------------------------------------------------------------------------

table socket_extra2461.socket.absent_protocols:
  description: "socket.socket class __dict__ does not contain __iter__, __bool__, or __hash__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2461

  columns: [id, function, args, expected]
  rows:
    - ["sk2461-040", "socket.__dict__.__contains__", ["__iter__"], false]
    - ["sk2461-041", "socket.__dict__.__contains__", ["__bool__"], false]
    - ["sk2461-042", "socket.__dict__.__contains__", ["__hash__"], false]
