spec: struct_extra1936
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol dict-presence checks, __set_name__ dict presence, __class__.__name__ checks."
    - "struct.Struct is a C extension type; it does NOT define __get__/__set__/__delete__ in its own __dict__."
    - "struct.error is a pure Python exception subclass; it also does NOT define descriptor protocol methods in its own __dict__."
    - "Neither the struct module, struct.Struct, nor struct.error define __set_name__ in their __dict__."
    - "struct.__class__.__name__ is 'module'; struct.Struct.__class__.__name__ is 'type'; struct.error.__class__.__name__ is 'type'."
    - "struct.Struct.__dict__ DOES contain pack, unpack, pack_into, unpack_from, size, format, __init__, __doc__, __module__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra1936.struct_type_descriptor_protocol:
  description: "struct.Struct __get__/__set__/__delete__ dict-presence checks (C extension — no descriptor protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1936

  columns: [id, function, args, expected]
  rows:
    - ["st1936001", "struct.Struct.__dict__.__contains__", ["__get__"], false]
    - ["st1936002", "struct.Struct.__dict__.__contains__", ["__set__"], false]
    - ["st1936003", "struct.Struct.__dict__.__contains__", ["__delete__"], false]

table struct_extra1936.error_type_descriptor_protocol:
  description: "struct.error __get__/__set__/__delete__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1936

  columns: [id, function, args, expected]
  rows:
    - ["st1936011", "struct.error.__dict__.__contains__", ["__get__"], false]
    - ["st1936012", "struct.error.__dict__.__contains__", ["__set__"], false]
    - ["st1936013", "struct.error.__dict__.__contains__", ["__delete__"], false]

table struct_extra1936.set_name_protocol:
  description: "struct.Struct and struct.error __set_name__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1936

  columns: [id, function, args, expected]
  rows:
    - ["st1936021", "struct.Struct.__dict__.__contains__", ["__set_name__"], false]
    - ["st1936022", "struct.error.__dict__.__contains__", ["__set_name__"], false]
    - ["st1936023", "struct.__dict__.__contains__", ["__set_name__"], false]

table struct_extra1936.module_descriptor_protocol:
  description: "struct module-level __get__/__set__/__delete__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1936

  columns: [id, function, args, expected]
  rows:
    - ["st1936031", "struct.__dict__.__contains__", ["__get__"], false]
    - ["st1936032", "struct.__dict__.__contains__", ["__set__"], false]
    - ["st1936033", "struct.__dict__.__contains__", ["__delete__"], false]

table struct_extra1936.struct_dict_known_members:
  description: "struct.Struct dict-presence checks for well-known members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1936

  columns: [id, function, args, expected]
  rows:
    - ["st1936041", "struct.Struct.__dict__.__contains__", ["__init__"], true]
    - ["st1936042", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st1936043", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st1936044", "struct.Struct.__dict__.__contains__", ["pack_into"], true]
    - ["st1936045", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1936046", "struct.Struct.__dict__.__contains__", ["size"], true]
    - ["st1936047", "struct.Struct.__dict__.__contains__", ["format"], true]
    - ["st1936048", "struct.Struct.__dict__.__contains__", ["__doc__"], true]
    - ["st1936049", "struct.Struct.__dict__.__contains__", ["__module__"], true]

table struct_extra1936.module_known_members:
  description: "struct module dict-presence checks for well-known members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1936

  columns: [id, function, args, expected]
  rows:
    - ["st1936051", "struct.__dict__.__contains__", ["pack"], true]
    - ["st1936052", "struct.__dict__.__contains__", ["unpack"], true]
    - ["st1936053", "struct.__dict__.__contains__", ["calcsize"], true]
    - ["st1936054", "struct.__dict__.__contains__", ["Struct"], true]
    - ["st1936055", "struct.__dict__.__contains__", ["error"], true]
    - ["st1936056", "struct.__dict__.__contains__", ["__name__"], true]
    - ["st1936057", "struct.__dict__.__contains__", ["__doc__"], true]

table struct_extra1936.error_dict_known_members:
  description: "struct.error dict-presence checks for well-known members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1936

  columns: [id, function, args, expected]
  rows:
    - ["st1936061", "struct.error.__dict__.__contains__", ["__doc__"], true]
    - ["st1936062", "struct.error.__dict__.__contains__", ["__module__"], true]
    - ["st1936063", "struct.error.__dict__.__contains__", ["__init__"], false]

table struct_extra1936.class_name_checks:
  description: "struct __class__.__name__ checks for module, Struct type, and error type"
  kind: python_call_eq
  category: attribute_value
  id_prefix: st1936

  columns: [id, function, args, expected]
  rows:
    - ["st1936071", "struct.__class__.__name__.__eq__", ["module"], true]
    - ["st1936072", "struct.Struct.__class__.__name__.__eq__", ["type"], true]
    - ["st1936073", "struct.error.__class__.__name__.__eq__", ["type"], true]
