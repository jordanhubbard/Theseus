spec: decimal_extra283
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Decimal string conversion and arithmetic method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c, Lib/_pydecimal.py"
  notes:
    - "decimal.Decimal provides arbitrary-precision decimal arithmetic"
    - "__qualname__ attributes verified for dunder and named conversion/arithmetic methods"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra283.decimal_dunder_qualnames:
  description: "Decimal dunder conversion method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: dcd283

  columns: [id, function, args, expected, description]
  rows:
    - [dcd283_001, decimal.Decimal.__str__.__qualname__, [], "Decimal.__str__", "Decimal.__str__ qualname"]
    - [dcd283_002, decimal.Decimal.__repr__.__qualname__, [], "Decimal.__repr__", "Decimal.__repr__ qualname"]
    - [dcd283_003, decimal.Decimal.__format__.__qualname__, [], "Decimal.__format__", "Decimal.__format__ qualname"]
    - [dcd283_004, decimal.Decimal.__hash__.__qualname__, [], "Decimal.__hash__", "Decimal.__hash__ qualname"]
    - [dcd283_005, decimal.Decimal.__int__.__qualname__, [], "Decimal.__int__", "Decimal.__int__ qualname"]
    - [dcd283_006, decimal.Decimal.__float__.__qualname__, [], "Decimal.__float__", "Decimal.__float__ qualname"]
    - [dcd283_007, decimal.Decimal.__round__.__qualname__, [], "Decimal.__round__", "Decimal.__round__ qualname"]
    - [dcd283_008, decimal.Decimal.__floor__.__qualname__, [], "Decimal.__floor__", "Decimal.__floor__ qualname"]
    - [dcd283_009, decimal.Decimal.__ceil__.__qualname__, [], "Decimal.__ceil__", "Decimal.__ceil__ qualname"]
    - [dcd283_010, decimal.Decimal.__trunc__.__qualname__, [], "Decimal.__trunc__", "Decimal.__trunc__ qualname"]

table decimal_extra283.decimal_named_method_qualnames:
  description: "Decimal named conversion and arithmetic method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: dcn283

  columns: [id, function, args, expected, description]
  rows:
    - [dcn283_001, decimal.Decimal.to_eng_string.__qualname__, [], "Decimal.to_eng_string", "Decimal.to_eng_string qualname"]
    - [dcn283_002, decimal.Decimal.to_integral.__qualname__, [], "Decimal.to_integral", "Decimal.to_integral qualname"]
    - [dcn283_003, decimal.Decimal.to_integral_value.__qualname__, [], "Decimal.to_integral_value", "Decimal.to_integral_value qualname"]
    - [dcn283_004, decimal.Decimal.to_integral_exact.__qualname__, [], "Decimal.to_integral_exact", "Decimal.to_integral_exact qualname"]
    - [dcn283_005, decimal.Decimal.normalize.__qualname__, [], "Decimal.normalize", "Decimal.normalize qualname"]

invariant decimal_extra283.decimal_str_qualname:
  description: "Decimal.__str__ qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__str__.__qualname__
  args: []
  expected: "Decimal.__str__"

invariant decimal_extra283.decimal_repr_qualname:
  description: "Decimal.__repr__ qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__repr__.__qualname__
  args: []
  expected: "Decimal.__repr__"

invariant decimal_extra283.decimal_to_eng_string_qualname:
  description: "Decimal.to_eng_string qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.to_eng_string.__qualname__
  args: []
  expected: "Decimal.to_eng_string"

invariant decimal_extra283.decimal_normalize_qualname:
  description: "Decimal.normalize qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.normalize.__qualname__
  args: []
  expected: "Decimal.normalize"
