spec: pathlib_extra251
version: ">=3.6"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath components, joinpath, parts, str, relative_to"
    - "pathlib_extra.zspec.zsdl — covers Path.__name__, Path.__module__, PurePosixPath variants"
  notes:
    - "Path.touch is an instance method; its __name__ is 'touch' and __qualname__ is 'Path.touch'."
    - "Path.open is an instance method; its __name__ is 'open' and __qualname__ is 'Path.open'."
    - "Path.expanduser is an instance method; its __name__ is 'expanduser' and __qualname__ is 'Path.expanduser'."
    - "Path.cwd is a classmethod; accessed on the class it has __name__ 'cwd' and __qualname__ 'Path.cwd'."
    - "Path.home is a classmethod; accessed on the class it has __name__ 'home' and __qualname__ 'Path.home'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.touch — instance method identity
# ---------------------------------------------------------------------------

table pathlib_extra251.touch.identity:
  description: "Path.touch method identity attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibmisc251

  columns: [id, function, args, expected]
  rows:
    - [touch_name,      Path.touch.__name__.__eq__,      ["touch"],       true]
    - [touch_qualname,  Path.touch.__qualname__.__eq__,  ["Path.touch"],  true]

# ---------------------------------------------------------------------------
# Path.touch — standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra251.touch.name:
  description: "Path.touch.__name__ == 'touch'"
  category: method_identity
  kind: python_call_eq
  function: Path.touch.__name__.__eq__
  args: ["touch"]
  expected: true

invariant pathlib_extra251.touch.qualname:
  description: "Path.touch.__qualname__ == 'Path.touch'"
  category: method_identity
  kind: python_call_eq
  function: Path.touch.__qualname__.__eq__
  args: ["Path.touch"]
  expected: true

invariant pathlib_extra251.touch.class_is_function:
  description: "Path.touch is a plain function (not a classmethod or staticmethod)"
  category: method_identity
  kind: python_call_eq
  function: Path.touch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

