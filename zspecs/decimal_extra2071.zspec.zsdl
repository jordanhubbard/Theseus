spec: decimal_extra2071
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "decimal.Decimal defines __pos__ and __neg__ (numeric unary sign operators)."
    - "decimal.Decimal defines __getattribute__ (True) — Decimal is a C type with custom attribute access."
    - "decimal.Decimal defines __reduce__ (True) — Decimal customizes pickle reconstruction."
    - "decimal.Decimal does NOT define __reduce_ex__ in its own __dict__ (False)."
    - "decimal.Decimal defines __copy__ and __deepcopy__ (True) — Decimal supports shallow and deep copy."
    - "decimal.Context defines __getattribute__ (True) — Context is a C type with custom attribute access."
    - "decimal.Context defines __reduce__ (True) — Context customizes pickle reconstruction."
    - "decimal.Context defines __copy__ (True) but NOT __deepcopy__ (False) — Context supports shallow copy only."
    - "decimal.Context does NOT define __pos__ or __neg__ (False) — Context is not a numeric type."
    - "decimal.DecimalException defines none of the seven operators (all False) — it is a plain exception subclass."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra2071.unary_sign_protocol:
  description: "decimal types __pos__/__neg__ dict-presence — Decimal defines both (True); Context and DecimalException define neither (False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2071

  columns: [id, function, args, expected]
  rows:
    - ["dc2071001", "decimal.Decimal.__dict__.__contains__",          ["__pos__"], true]
    - ["dc2071002", "decimal.Decimal.__dict__.__contains__",          ["__neg__"], true]
    - ["dc2071003", "decimal.Context.__dict__.__contains__",          ["__pos__"], false]
    - ["dc2071004", "decimal.Context.__dict__.__contains__",          ["__neg__"], false]
    - ["dc2071005", "decimal.DecimalException.__dict__.__contains__", ["__pos__"], false]
    - ["dc2071006", "decimal.DecimalException.__dict__.__contains__", ["__neg__"], false]

table decimal_extra2071.getattribute_protocol:
  description: "decimal types __getattribute__ dict-presence — Decimal and Context define it (True, C types with custom attr access); DecimalException does not (False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2071

  columns: [id, function, args, expected]
  rows:
    - ["dc2071007", "decimal.Decimal.__dict__.__contains__",          ["__getattribute__"], true]
    - ["dc2071008", "decimal.Context.__dict__.__contains__",          ["__getattribute__"], true]
    - ["dc2071009", "decimal.DecimalException.__dict__.__contains__", ["__getattribute__"], false]

table decimal_extra2071.reduce_protocol:
  description: "decimal types __reduce__/__reduce_ex__ dict-presence — Decimal and Context define __reduce__ (True); __reduce_ex__ absent in all; DecimalException defines neither"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2071

  columns: [id, function, args, expected]
  rows:
    - ["dc2071010", "decimal.Decimal.__dict__.__contains__",          ["__reduce__"],    true]
    - ["dc2071011", "decimal.Decimal.__dict__.__contains__",          ["__reduce_ex__"], false]
    - ["dc2071012", "decimal.Context.__dict__.__contains__",          ["__reduce__"],    true]
    - ["dc2071013", "decimal.Context.__dict__.__contains__",          ["__reduce_ex__"], false]
    - ["dc2071014", "decimal.DecimalException.__dict__.__contains__", ["__reduce__"],    false]
    - ["dc2071015", "decimal.DecimalException.__dict__.__contains__", ["__reduce_ex__"], false]

table decimal_extra2071.copy_protocol:
  description: "decimal types __copy__/__deepcopy__ dict-presence — Decimal defines both (True); Context defines __copy__ only (True/__deepcopy__ False); DecimalException defines neither"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2071

  columns: [id, function, args, expected]
  rows:
    - ["dc2071016", "decimal.Decimal.__dict__.__contains__",          ["__copy__"],     true]
    - ["dc2071017", "decimal.Decimal.__dict__.__contains__",          ["__deepcopy__"], true]
    - ["dc2071018", "decimal.Context.__dict__.__contains__",          ["__copy__"],     true]
    - ["dc2071019", "decimal.Context.__dict__.__contains__",          ["__deepcopy__"], false]
    - ["dc2071020", "decimal.DecimalException.__dict__.__contains__", ["__copy__"],     false]
    - ["dc2071021", "decimal.DecimalException.__dict__.__contains__", ["__deepcopy__"], false]
    - ["dc2071022", "decimal.Decimal.__dict__.__contains__",          ["__pos__"],      true]
    - ["dc2071023", "decimal.Decimal.__dict__.__contains__",          ["__neg__"],      true]
    - ["dc2071024", "decimal.Decimal.__dict__.__contains__",          ["__reduce__"],   true]
    - ["dc2071025", "decimal.Context.__dict__.__contains__",          ["__copy__"],     true]
    - ["dc2071026", "decimal.Context.__dict__.__contains__",          ["__pos__"],      false]
