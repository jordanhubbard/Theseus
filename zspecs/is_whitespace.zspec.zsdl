spec: is_whitespace
version: ">=0.3.0"
backend: node(is-whitespace)

docs: https://www.npmjs.com/package/is-whitespace

provenance:
  derived_from:
    - "is-whitespace README — https://www.npmjs.com/package/is-whitespace"
    - "Test vectors verified with is-whitespace via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-whitespace source"
  notes:
    - "is-whitespace is an npm package. Install: npm install is-whitespace"
    - "Returns true if the string contains only whitespace characters."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_whitespace.isWhitespace:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: isws

  columns: [id, args, expected]
  rows:
    - [spaces,      ["   "],   true]
    - [tab,         ["\t"],    true]
    - [word,        ["hi"],    false]
    - [mixed,       ["hi "],   false]

