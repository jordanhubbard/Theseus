spec: re_extra330
version: ">=3.7"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.escape and re.purge identity and behavioral invariants
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
#
# re.escape.__name__ == 'escape'
# re.escape.__module__ == 're'
# re.escape('hello.world') == 'hello\\.world'
# re.escape('abc') == 'abc'         — plain letters are not escaped
# re.escape('1+1=2') == '1\\+1=2'  — '=' is NOT escaped in Python 3.7+
# re.escape('') == ''
# re.purge.__name__ == 'purge'
# re.purge.__module__ == 're'
# re.purge.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

invariant re_extra330.escape.name:
  description: "re.escape.__name__ == 'escape' — function is named 'escape'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: escape.__name__.__eq__
  args: ["escape"]
  expected: true

invariant re_extra330.escape.module:
  description: "re.escape.__module__ == 're' — escape is defined in the re module; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: escape.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra330.escape.dot:
  description: "re.escape('hello.world') == 'hello\\.world' — dot is a metacharacter and is escaped; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: escape
  args: ["hello.world"]
  expected: "hello\\.world"

invariant re_extra330.escape.plain_letters:
  description: "re.escape('abc') == 'abc' — plain alphanumeric letters are not escaped; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: escape
  args: ["abc"]
  expected: "abc"

invariant re_extra330.escape.plus_not_equals:
  description: "re.escape('1+1=2') == '1\\+1=2' — '+' is escaped but '=' is not (Python 3.7+ escapes only regex metacharacters); verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: escape
  args: ["1+1=2"]
  expected: "1\\+1=2"

invariant re_extra330.escape.empty_string:
  description: "re.escape('') == '' — escaping an empty string yields an empty string; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: escape
  args: [""]
  expected: ""

invariant re_extra330.purge.name:
  description: "re.purge.__name__ == 'purge' — function is named 'purge'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: purge.__name__.__eq__
  args: ["purge"]
  expected: true

invariant re_extra330.purge.module:
  description: "re.purge.__module__ == 're' — purge is defined in the re module; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: purge.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra330.purge.class_name:
  description: "re.purge.__class__.__name__ == 'function' — purge is a plain function object; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: purge.__class__.__name__.__eq__
  args: ["function"]
  expected: true
