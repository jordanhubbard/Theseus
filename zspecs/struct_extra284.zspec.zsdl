spec: struct_extra284
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct.calcsize for network byte-order formats"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "'!' prefix is network byte order, identical to '>' (big-endian) for size calculations"
    - "Compound sizes are the sum of each component's size with no padding in network byte order"
    - "bhi=1+2+4=7, qi=8+4=12, IHB=4+2+1=7, Qd=8+8=16, IIi=4+4+4=12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra284.calcsize_network_single:
  description: "struct.calcsize for '!' prefix single-format strings"
  kind: python_call_eq
  category: identity
  id_prefix: sx284

  columns: [id, function, args, expected, description]
  rows:
    - [sx284-001, struct.calcsize, ["!b"], 1, "signed byte: 1 byte"]
    - [sx284-002, struct.calcsize, ["!B"], 1, "unsigned byte: 1 byte"]
    - [sx284-003, struct.calcsize, ["!h"], 2, "signed short: 2 bytes"]
    - [sx284-004, struct.calcsize, ["!H"], 2, "unsigned short: 2 bytes"]
    - [sx284-005, struct.calcsize, ["!i"], 4, "signed int: 4 bytes"]
    - [sx284-006, struct.calcsize, ["!I"], 4, "unsigned int: 4 bytes"]
    - [sx284-007, struct.calcsize, ["!q"], 8, "signed long long: 8 bytes"]
    - [sx284-008, struct.calcsize, ["!Q"], 8, "unsigned long long: 8 bytes"]
    - [sx284-009, struct.calcsize, ["!f"], 4, "float: 4 bytes"]
    - [sx284-010, struct.calcsize, ["!d"], 8, "double: 8 bytes"]
    - [sx284-011, struct.calcsize, ["!?"], 1, "bool: 1 byte"]

table struct_extra284.calcsize_network_compound:
  description: "struct.calcsize for '!' prefix compound format strings"
  kind: python_call_eq
  category: identity
  id_prefix: sx284

  columns: [id, function, args, expected, description]
  rows:
    - [sx284-012, struct.calcsize, ["!bhi"], 7, "signed byte + short + int: 1+2+4=7"]
    - [sx284-013, struct.calcsize, ["!qi"], 12, "signed long long + int: 8+4=12"]
    - [sx284-014, struct.calcsize, ["!IHB"], 7, "unsigned int + short + byte: 4+2+1=7"]
    - [sx284-015, struct.calcsize, ["!Qd"], 16, "unsigned long long + double: 8+8=16"]
    - [sx284-016, struct.calcsize, ["!IIi"], 12, "two unsigned ints + signed int: 4+4+4=12"]

invariant struct_extra284.calcsize_network_qi:
  description: "network byte order qi compound format is 12 bytes"
  category: identity
  kind: python_call_eq
  function: struct.calcsize
  args: ["!qi"]
  expected: 12

invariant struct_extra284.calcsize_network_Qi:
  description: "network byte order Qi compound format is 12 bytes"
  category: identity
  kind: python_call_eq
  function: struct.calcsize
  args: ["!Qi"]
  expected: 12

invariant struct_extra284.calcsize_network_bool:
  description: "network byte order bool format is 1 byte"
  category: identity
  kind: python_call_eq
  function: struct.calcsize
  args: ["!?"]
  expected: 1
