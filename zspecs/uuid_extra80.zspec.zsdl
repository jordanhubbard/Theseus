spec: uuid_extra80
version: ">=3.9"
extends: uuid_extra79
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra79.zspec.zsdl — covers UUID dunder method __qualname__.__eq__ for __init__/__str__/__repr__/__eq__/__hash__/__int__/__lt__/__setattr__ / uuid1/uuid3/uuid4/uuid5 __qualname__.__eq__ / UUID.__name__/__module__.__eq__ (table + invariants)."
    - "uuid_extra78.zspec.zsdl — covers UUID.__dict__.__contains__ for __init__/__str__/__repr__/__eq__/__hash__/int/hex/bytes/variant/version / UUID.__dict__.__class__.__name__=='mappingproxy' / UUID.__mro__.__len__()==2 (table + invariants)."
    - "uuid_extra76.zspec.zsdl — covers UUID/__init__/__str__/__repr__/__eq__/__hash__/__lt__/__setattr__/__class__/__name__=='function' / UUID.int/__class__.__name__=='member_descriptor' / UUID.hex/__class__.__name__=='property' (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra79; it does NOT duplicate invariants present in those files."
    - "Wave 254 theme: uuid.UUID property __class__.__name__ identity and uuid.SafeUUID class hierarchy."
    - "uuid.UUID.hex.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_low.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_mid.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.int.__class__.__name__ == 'member_descriptor' (NOT 'property'); anchored in uuid_extra76."
    - "uuid.SafeUUID.__name__.__eq__('SafeUUID') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__.__eq__('uuid') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' (SafeUUID extends Enum, NOT IntEnum). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__.__len__() == 3 (MRO: [SafeUUID, Enum, object]). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex/__class__/__name__.__eq__('property')
# uuid.UUID.bytes/__class__/__name__.__eq__('property')
# uuid.UUID.bytes_le/__class__/__name__.__eq__('property')
# uuid.UUID.fields/__class__/__name__.__eq__('property')
#
# Wave 254 theme: UUID property __class__.__name__ identity (group 1).
#
# uuid_extra76 anchors UUID.hex.__class__.__name__=='property' as a value.
# This table anchors the __eq__ call form for hex/bytes/bytes_le/fields
# under the new id_prefix uuidpropclass80.
# Note: UUID.int.__class__.__name__ is 'member_descriptor' (not 'property').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra80.uuid_property_class_group1:
  description: "uuid.UUID.hex/__class__.__name__.__eq__('property')==True / UUID.bytes/__class__.__name__.__eq__('property')==True / UUID.bytes_le/__class__.__name__.__eq__('property')==True / UUID.fields/__class__.__name__.__eq__('property')==True — hex/bytes/bytes_le/fields are Python property descriptors on uuid.UUID; uuid_extra76 anchors UUID.hex.__class__.__name__ as a value; this table anchors the __eq__ call form for all four under uuidpropclass80; first uuidpropclass80 anchor for UUID property class identity group 1"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidpropclass80

  columns: [id, function, args, expected]
  rows:
    - [uuid_hex_class_prop,      UUID.hex.__class__.__name__.__eq__,      ["property"], true]
    - [uuid_bytes_class_prop,    UUID.bytes.__class__.__name__.__eq__,    ["property"], true]
    - [uuid_bytes_le_class_prop, UUID.bytes_le.__class__.__name__.__eq__, ["property"], true]
    - [uuid_fields_class_prop,   UUID.fields.__class__.__name__.__eq__,   ["property"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.time_low/__class__/__name__.__eq__('property')
# uuid.UUID.time_mid/__class__/__name__.__eq__('property')
# uuid.UUID.variant/__class__/__name__.__eq__('property')
# uuid.UUID.version/__class__/__name__.__eq__('property')
#
# Wave 254 theme: UUID property __class__.__name__ identity (group 2).
#
# time_low/time_mid/variant/version are all Python property descriptors on
# uuid.UUID. uuid_extra76 only anchors UUID.hex as an explicit example.
# This table anchors the __eq__ call form for time_low/time_mid/variant/version.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra80.uuid_property_class_group2:
  description: "uuid.UUID.time_low/__class__.__name__.__eq__('property')==True / UUID.time_mid/__class__.__name__.__eq__('property')==True / UUID.variant/__class__.__name__.__eq__('property')==True / UUID.version/__class__.__name__.__eq__('property')==True — time_low/time_mid/variant/version are Python property descriptors on uuid.UUID; this table anchors the __eq__ call form for all four under uuidpropclass80; first uuidpropclass80 anchor for UUID.time_low/time_mid/variant/version property class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidpropclass80

  columns: [id, function, args, expected]
  rows:
    - [uuid_time_low_class_prop, UUID.time_low.__class__.__name__.__eq__, ["property"], true]
    - [uuid_time_mid_class_prop, UUID.time_mid.__class__.__name__.__eq__, ["property"], true]
    - [uuid_variant_class_prop,  UUID.variant.__class__.__name__.__eq__,  ["property"], true]
    - [uuid_version_class_prop,  UUID.version.__class__.__name__.__eq__,  ["property"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID/__name__/__eq__('SafeUUID')
# uuid.SafeUUID/__module__/__eq__('uuid')
# uuid.SafeUUID/__qualname__/__eq__('SafeUUID')
# uuid.SafeUUID/__bases__[0]/__name__/__eq__('Enum')
#
# Wave 254 theme: SafeUUID class identity.
#
# SafeUUID extends Enum (not IntEnum). Its __bases__[0].__name__ is 'Enum'.
# SafeUUID.__mro__ is [SafeUUID, Enum, object] with len 3.
# uuid_extra79 does not anchor SafeUUID at all.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra80.safeuuid_class_identity:
  description: "uuid.SafeUUID/__name__.__eq__('SafeUUID')==True / SafeUUID/__module__.__eq__('uuid')==True / SafeUUID/__qualname__.__eq__('SafeUUID')==True / SafeUUID/__bases__[0]/__name__.__eq__('Enum')==True — SafeUUID is a top-level Enum subclass in uuid.py (NOT IntEnum); its __bases__[0] is Enum; no prior uuid spec anchors SafeUUID identity; first uuidpropclass80 anchor for SafeUUID class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidpropclass80

  columns: [id, function, args, expected]
  rows:
    - [safeuuid_name_eq,          SafeUUID.__name__.__eq__,                    ["SafeUUID"], true]
    - [safeuuid_module_eq,        SafeUUID.__module__.__eq__,                  ["uuid"],     true]
    - [safeuuid_qualname_eq,      SafeUUID.__qualname__.__eq__,                ["SafeUUID"], true]
    - [safeuuid_bases_enum,       "SafeUUID.__bases__[0].__name__.__eq__",     ["Enum"],     true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID/__mro__/__len__() == 3
# uuid.SafeUUID/__name__/__eq__('SafeUUID') (cross-check)
# uuid.UUID.hex/__class__/__name__.__eq__('property') (cross-check)
# uuid.UUID.version/__class__.__name__.__eq__('property') (cross-check)
#
# Wave 254 theme: SafeUUID hierarchy depth cross-check.
#
# SafeUUID.__mro__ is [SafeUUID, Enum, object] — exactly 3 entries.
# This table anchors the MRO length alongside cross-check rows from the
# class identity and property tables.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra80.safeuuid_hierarchy:
  description: "uuid.SafeUUID/__mro__/__len__()==3 / SafeUUID/__name__/__eq__('SafeUUID')==True / UUID.hex/__class__.__name__.__eq__('property')==True / UUID.version/__class__.__name__.__eq__('property')==True — SafeUUID.__mro__ is [SafeUUID, Enum, object] with exactly 3 entries; cross-checks anchor SafeUUID name and two UUID property class identities alongside the MRO depth; first uuidpropclass80 anchor for SafeUUID.__mro__.__len__()==3"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidpropclass80

  columns: [id, function, args, expected]
  rows:
    - [safeuuid_mro_len_3,        SafeUUID.__mro__.__len__,                    [],           3]
    - [safeuuid_name_eq2,         SafeUUID.__name__.__eq__,                    ["SafeUUID"], true]
    - [uuid_hex_class_prop2,      UUID.hex.__class__.__name__.__eq__,          ["property"], true]
    - [uuid_version_class_prop2,  UUID.version.__class__.__name__.__eq__,      ["property"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.__class__.__name__.__eq__('property') — standalone
#
# UUID.hex is a Python property descriptor. Its __class__.__name__ is
# 'property'. uuid_extra76 anchors UUID.hex.__class__.__name__ as a value.
# This standalone anchors the __eq__ call form.
# First __class__.__name__.__eq__ standalone for uuid.UUID.hex.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra80.uuid_hex_class_prop:
  description: "uuid.UUID.hex.__class__.__name__.__eq__('property') == True — UUID.hex is a Python property descriptor; uuid_extra76 anchors its __class__.__name__ as a value; this standalone anchors the __eq__ call form; first __class__.__name__.__eq__ standalone for uuid.UUID.hex"
  category: class_attrs
  kind: python_call_eq
  function: UUID.hex.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.variant.__class__.__name__.__eq__('property') — standalone
#
# UUID.variant is a Python property descriptor. Its __class__.__name__ is
# 'property'. No prior uuid spec checks UUID.variant.__class__.__name__.__eq__.
# First __class__.__name__.__eq__ standalone for uuid.UUID.variant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra80.uuid_variant_class_prop:
  description: "uuid.UUID.variant.__class__.__name__.__eq__('property') == True — UUID.variant is a Python property descriptor that returns the UUID variant as an integer constant; its __class__.__name__ is 'property'; no prior uuid spec checks UUID.variant.__class__.__name__.__eq__; first standalone for uuid.UUID.variant property class identity"
  category: class_attrs
  kind: python_call_eq
  function: UUID.variant.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__name__.__eq__('SafeUUID') — standalone
#
# SafeUUID.__name__ is 'SafeUUID'. No prior uuid spec checks SafeUUID.__name__.__eq__
# as a call. First __name__.__eq__ standalone for uuid.SafeUUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra80.safeuuid_name_eq:
  description: "uuid.SafeUUID.__name__.__eq__('SafeUUID') == True — SafeUUID is a top-level Enum subclass in uuid.py; its __name__ is 'SafeUUID'; no prior uuid spec checks SafeUUID.__name__.__eq__ as a call; first __name__.__eq__ standalone for uuid.SafeUUID"
  category: class_attrs
  kind: python_call_eq
  function: SafeUUID.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') — standalone
#
# SafeUUID.__bases__[0].__name__ is 'Enum'. SafeUUID extends Enum, not IntEnum.
# No prior uuid spec checks SafeUUID.__bases__[0].__name__.__eq__ as a call.
# First __bases__[0].__name__.__eq__ standalone for uuid.SafeUUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra80.safeuuid_bases_enum:
  description: "uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') == True — SafeUUID extends Enum (not IntEnum); __bases__[0] is Enum; no prior uuid spec checks SafeUUID.__bases__[0].__name__.__eq__; first standalone for uuid.SafeUUID base class identity"
  category: class_attrs
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__.__len__() == 3 — standalone
#
# SafeUUID.__mro__ is [SafeUUID, Enum, object] with exactly 3 entries.
# No prior uuid spec checks SafeUUID.__mro__.__len__() as a call.
# First __mro__.__len__() standalone for uuid.SafeUUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra80.safeuuid_mro_len_3:
  description: "uuid.SafeUUID.__mro__.__len__() == 3 — SafeUUID.__mro__ is [SafeUUID, Enum, object]; the MRO has exactly 3 entries because SafeUUID is a direct Enum subclass (not IntEnum); no prior uuid spec checks SafeUUID.__mro__.__len__(); first standalone for uuid.SafeUUID MRO depth"
  category: class_attrs
  kind: python_call_eq
  function: SafeUUID.__mro__.__len__
  args: []
  expected: 3
