spec: theseus_sre_constants_cr
version: ">=3.0"
backend: python_cleanroom(theseus_sre_constants_cr)
blocks: sre_constants

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Lib/sre_constants.py"
  notes:
    - "Clean-room sre_constants module. Do NOT import sre_constants."

error_model: python_exceptions

invariant theseus_sre_constants_cr.srec2_opcodes:
  description: "Regex opcode constants are defined"
  category: behavior
  kind: python_call_eq
  function: srec2_opcodes
  args: []
  expected: true

invariant theseus_sre_constants_cr.srec2_flags:
  description: "Regex flag constants are defined"
  category: behavior
  kind: python_call_eq
  function: srec2_flags
  args: []
  expected: true

invariant theseus_sre_constants_cr.srec2_error:
  description: "error exception class exists"
  category: behavior
  kind: python_call_eq
  function: srec2_error
  args: []
  expected: true
