spec: faker_rust
version: ">=3.9"
backend: rust_module(faker_rust)

docs: https://faker.readthedocs.io/

provenance:
  derived_from:
    - "https://faker.readthedocs.io/ — Faker library documentation"
  not_derived_from:
    - "faker source: faker/factory.py"
  notes:
    - "Faker generates fake data for testing."
    - "Faker(seed=42) — seeded for determinism."
    - "Expose seeded_name() -> str: Faker(); Faker.seed(0); fake.name() — type check."
    - "Expose seeded_email() -> str: fake.email() — always contains '@'."
    - "Expose seeded_url() -> str: fake.url() — always starts with 'http'."
    - "Expose faker_name_is_str() -> bool: isinstance(fake.name(), str)."
    - "Expose faker_email_has_at() -> bool: '@' in fake.email()."
    - "Expose faker_url_has_scheme() -> bool: fake.url().startswith('http')."
    - "Expose seeded_int(seed, min_v, max_v) -> int: Faker(seed=seed).random_int(min=min_v, max=max_v)."
    - "Faker(seed=42).random_int(min=0, max=100) is deterministic and in [0,100]."
    - "All test vectors verified against Faker 36.2.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# type checks on generated data
invariant faker_rust.generate.name_is_str:
  description: "fake.name() is a str"
  category: type
  kind: python_call_eq
  function: faker_name_is_str
  args: []
  expected: true

invariant faker_rust.generate.email_has_at:
  description: "'@' in fake.email()"
  category: type
  kind: python_call_eq
  function: faker_email_has_at
  args: []
  expected: true

invariant faker_rust.generate.url_has_scheme:
  description: "fake.url() starts with 'http'"
  category: type
  kind: python_call_eq
  function: faker_url_has_scheme
  args: []
  expected: true

# seeded_int — deterministic integer generation
table faker_rust.seeded.int:
  kind: python_call_eq
  category: seeded
  id_prefix: fk_int
  function: faker_int_in_range

  columns: [id, args, expected]
  rows:
    - [zero_to_ten,  [42, 0, 10], true]
    - [zero_to_100,  [42, 0, 100], true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:37:49Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
