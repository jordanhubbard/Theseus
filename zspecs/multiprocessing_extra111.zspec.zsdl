spec: multiprocessing_extra111
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra110.zspec.zsdl."
    - "This spec covers: wave 255 theme — multiprocessing exception class attributes. NEW in extra111: multiprocessing.ProcessError.__name__=='ProcessError' (len=12); multiprocessing.ProcessError.__module__=='multiprocessing.context' (len=23); multiprocessing.ProcessError.__mro__.__len__()==4; multiprocessing.ProcessError.__bases__[0].__name__=='Exception'; multiprocessing.AuthenticationError.__name__=='AuthenticationError' (len=19, longest class name in this spec); multiprocessing.AuthenticationError.__module__=='multiprocessing.context' (len=23); multiprocessing.AuthenticationError.__mro__.__len__()==5; multiprocessing.AuthenticationError.__bases__[0].__name__=='ProcessError'; multiprocessing.BufferTooShort.__name__=='BufferTooShort' (len=14); multiprocessing.BufferTooShort.__module__=='multiprocessing.context' (len=23); multiprocessing.BufferTooShort.__mro__.__len__()==5; multiprocessing.BufferTooShort.__bases__[0].__name__=='ProcessError'; multiprocessing.TimeoutError.__name__=='TimeoutError' (len=12, tied with ProcessError); multiprocessing.TimeoutError.__module__=='multiprocessing.context' (len=23); multiprocessing.TimeoutError.__mro__.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.ProcessError.__mro__.__len__() == 4 ([ProcessError, Exception, BaseException, object]). multiprocessing.ProcessError is the base exception for all multiprocessing-specific exceptions; it inherits from Exception (not RuntimeError or OSError). The three subclasses (AuthenticationError, BufferTooShort, TimeoutError) all have __mro__.__len__()==5 (one level deeper, adding ProcessError to the chain). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All three ProcessError subclasses (AuthenticationError, BufferTooShort, TimeoutError) share __module__=='multiprocessing.context' (len=23). AuthenticationError.__name__='AuthenticationError' (len=19, longest); BufferTooShort.__name__='BufferTooShort' (len=14); TimeoutError.__name__='TimeoutError' (len=12, shortest, tied with ProcessError). Note: multiprocessing.TimeoutError is distinct from the built-in TimeoutError — it has __module__=='multiprocessing.context', not 'builtins'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.ProcessError class identity — extra111
#
# Wave 255 theme: ProcessError as the base exception for multiprocessing.
#
# multiprocessing.ProcessError.__name__            == 'ProcessError'            (len=12)
# multiprocessing.ProcessError.__module__          == 'multiprocessing.context' (len=23)
# multiprocessing.ProcessError.__mro__.__len__()   == 4
# multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'
# ---------------------------------------------------------------------------

table multiprocessing_extra111.mp_process_error_identity:
  description: "multiprocessing.ProcessError class identity checks in mpexc111 namespace — wave 255 theme: multiprocessing.ProcessError.__name__.__eq__('ProcessError')==True (len=12: 'ProcessError'=12; base exception class for all multiprocessing-specific exceptions); multiprocessing.ProcessError.__name__.__len__()==12; multiprocessing.ProcessError.__qualname__.__eq__('ProcessError')==True (len=12; qualname equals name for a top-level class); multiprocessing.ProcessError.__module__.__eq__('multiprocessing.context')==True (len=23: 'multiprocessing.context'=23; ProcessError is defined in the context submodule — same module as cpu_count from extra110 but a different kind of object); multiprocessing.ProcessError.__module__.__len__()==23; multiprocessing.ProcessError.__mro__.__len__()==4 (MRO=[ProcessError, Exception, BaseException, object]; 4-level chain — shorter than its subclasses which add ProcessError itself as level 2); multiprocessing.ProcessError.__bases__[0].__name__.__eq__('Exception')==True (ProcessError inherits from the standard Exception, not from RuntimeError or OSError); compare: multiprocessing.TimeoutError is a subclass of ProcessError (not the built-in TimeoutError which inherits from OSError via builtins); all multiprocessing exceptions are grouped under ProcessError; multiprocessing.ProcessError.__mro__.__len__()==4 (one level shorter than AuthenticationError/BufferTooShort/TimeoutError which all have MRO len=5); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpexc111

  columns: [id, function, args, expected, description]
  rows:
    - [pe_name_eq,          multiprocessing.ProcessError.__name__.__eq__,                  ["ProcessError"],        true, "ProcessError.__name__ == 'ProcessError' (len=12); verified with Python 3.14.3"]
    - [pe_name_len,         multiprocessing.ProcessError.__name__.__len__,                 [],                      12,   "ProcessError.__name__.__len__() == 12 ('ProcessError'=12); verified with Python 3.14.3"]
    - [pe_qn_eq,            multiprocessing.ProcessError.__qualname__.__eq__,              ["ProcessError"],        true, "ProcessError.__qualname__ == 'ProcessError' (len=12, qualname equals name); verified with Python 3.14.3"]
    - [pe_module_eq,        multiprocessing.ProcessError.__module__.__eq__,                ["multiprocessing.context"], true, "ProcessError.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [pe_module_len,       multiprocessing.ProcessError.__module__.__len__,               [],                      23,   "ProcessError.__module__.__len__() == 23 ('multiprocessing.context'=23); verified with Python 3.14.3"]
    - [pe_mro_len,          multiprocessing.ProcessError.__mro__.__len__,                  [],                      4,    "ProcessError.__mro__.__len__() == 4 ([ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [pe_base_eq,          "multiprocessing.ProcessError.__bases__[0].__name__.__eq__",   ["Exception"],           true, "ProcessError.__bases__[0].__name__ == 'Exception' (base is the standard Exception); verified with Python 3.14.3"]
    - [pe_type_is_type,     type(multiprocessing.ProcessError).__name__.__eq__,            ["type"],                true, "type(ProcessError).__name__ == 'type' (ProcessError is a class); verified with Python 3.14.3"]
    - [pe_name_len_12,      multiprocessing.ProcessError.__name__.__len__,                 [],                      12,   "ProcessError name len=12 (same as TimeoutError len=12, shorter than AuthenticationError=19); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.AuthenticationError and BufferTooShort identity — extra111
#
# Wave 255 theme: ProcessError subclass names and MRO lengths.
#
# multiprocessing.AuthenticationError.__name__  == 'AuthenticationError' (len=19, longest)
# multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context' (len=23)
# multiprocessing.AuthenticationError.__mro__.__len__() == 5
# multiprocessing.BufferTooShort.__name__       == 'BufferTooShort'      (len=14)
# multiprocessing.BufferTooShort.__mro__.__len__() == 5
# ---------------------------------------------------------------------------

table multiprocessing_extra111.mp_auth_buffer_identity:
  description: "multiprocessing.AuthenticationError and BufferTooShort class identity checks in mpexc111 namespace — wave 255 theme: multiprocessing.AuthenticationError.__name__.__eq__('AuthenticationError')==True (len=19: 'AuthenticationError'=19; longest exception class name in this spec — raised when an authentication attempt fails in multiprocessing connections); multiprocessing.AuthenticationError.__name__.__len__()==19; multiprocessing.AuthenticationError.__qualname__.__eq__('AuthenticationError')==True (len=19); multiprocessing.AuthenticationError.__module__.__eq__('multiprocessing.context')==True (len=23; same module as ProcessError — all defined in multiprocessing.context); multiprocessing.AuthenticationError.__mro__.__len__()==5 (MRO=[AuthenticationError, ProcessError, Exception, BaseException, object]; 5-level chain — one deeper than ProcessError=4 because AuthenticationError adds ProcessError as level 2); multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__('ProcessError')==True (direct subclass of ProcessError); multiprocessing.BufferTooShort.__name__.__eq__('BufferTooShort')==True (len=14: 'BufferTooShort'=14; raised when a supplied buffer is too small to hold the message read — an IPC-specific exception); multiprocessing.BufferTooShort.__name__.__len__()==14; multiprocessing.BufferTooShort.__module__.__eq__('multiprocessing.context')==True (len=23; same module); multiprocessing.BufferTooShort.__mro__.__len__()==5 (same as AuthenticationError — both are direct subclasses of ProcessError); multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__('ProcessError')==True; compare name lengths: BufferTooShort=14 < AuthenticationError=19 (5 chars difference); both have MRO len=5; both in 'multiprocessing.context'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpexc111a

  columns: [id, function, args, expected, description]
  rows:
    - [ae_name_eq,          multiprocessing.AuthenticationError.__name__.__eq__,           ["AuthenticationError"], true, "AuthenticationError.__name__ == 'AuthenticationError' (len=19, longest in spec); verified with Python 3.14.3"]
    - [ae_name_len,         multiprocessing.AuthenticationError.__name__.__len__,          [],                      19,   "AuthenticationError.__name__.__len__() == 19 ('AuthenticationError'=19, longest exception name in spec); verified with Python 3.14.3"]
    - [ae_qn_eq,            multiprocessing.AuthenticationError.__qualname__.__eq__,       ["AuthenticationError"], true, "AuthenticationError.__qualname__ == 'AuthenticationError' (len=19, qualname equals name); verified with Python 3.14.3"]
    - [ae_module_eq,        multiprocessing.AuthenticationError.__module__.__eq__,         ["multiprocessing.context"], true, "AuthenticationError.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [ae_module_len,       multiprocessing.AuthenticationError.__module__.__len__,        [],                      23,   "AuthenticationError.__module__.__len__() == 23 ('multiprocessing.context'=23); verified with Python 3.14.3"]
    - [ae_mro_len,          multiprocessing.AuthenticationError.__mro__.__len__,           [],                      5,    "AuthenticationError.__mro__.__len__() == 5 ([AuthError, ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [ae_base_eq,          "multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"],   true, "AuthenticationError.__bases__[0].__name__ == 'ProcessError' (direct subclass of ProcessError); verified with Python 3.14.3"]
    - [bts_name_eq,         multiprocessing.BufferTooShort.__name__.__eq__,                ["BufferTooShort"],      true, "BufferTooShort.__name__ == 'BufferTooShort' (len=14); verified with Python 3.14.3"]
    - [bts_name_len,        multiprocessing.BufferTooShort.__name__.__len__,               [],                      14,   "BufferTooShort.__name__.__len__() == 14 ('BufferTooShort'=14); verified with Python 3.14.3"]
    - [bts_module_eq,       multiprocessing.BufferTooShort.__module__.__eq__,              ["multiprocessing.context"], true, "BufferTooShort.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [bts_mro_len,         multiprocessing.BufferTooShort.__mro__.__len__,                [],                      5,    "BufferTooShort.__mro__.__len__() == 5 (same as AuthenticationError=5); verified with Python 3.14.3"]
    - [bts_base_eq,         "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__", ["ProcessError"],        true, "BufferTooShort.__bases__[0].__name__ == 'ProcessError' (direct subclass of ProcessError); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.TimeoutError identity and comparison — extra111
#
# Wave 255 theme: multiprocessing.TimeoutError (different from built-in TimeoutError).
#
# multiprocessing.TimeoutError.__name__            == 'TimeoutError'            (len=12, tied with ProcessError)
# multiprocessing.TimeoutError.__module__          == 'multiprocessing.context' (len=23, NOT 'builtins')
# multiprocessing.TimeoutError.__mro__.__len__()   == 5
# multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'
# ---------------------------------------------------------------------------

table multiprocessing_extra111.mp_timeout_error_identity:
  description: "multiprocessing.TimeoutError class identity checks in mpexc111 namespace — wave 255 theme: multiprocessing.TimeoutError.__name__.__eq__('TimeoutError')==True (len=12: 'TimeoutError'=12; tied with ProcessError=12 for shortest exception name in spec); multiprocessing.TimeoutError.__name__.__len__()==12; multiprocessing.TimeoutError.__qualname__.__eq__('TimeoutError')==True (len=12); multiprocessing.TimeoutError.__module__.__eq__('multiprocessing.context')==True (len=23; THIS IS THE KEY DISTINCTION from the built-in TimeoutError: multiprocessing.TimeoutError is defined in multiprocessing.context, NOT builtins — it is a ProcessError subclass, not an OSError subclass; compare: concurrent.futures.TimeoutError.__module__=='builtins' from extra109 — that one IS the built-in TimeoutError); multiprocessing.TimeoutError.__module__.__len__()==23; multiprocessing.TimeoutError.__mro__.__len__()==5 (MRO=[TimeoutError, ProcessError, Exception, BaseException, object]; inherits from ProcessError, not from OSError); multiprocessing.TimeoutError.__bases__[0].__name__.__eq__('ProcessError')==True (direct subclass of ProcessError — distinct from built-in TimeoutError whose base is OSError); compare: multiprocessing.TimeoutError (subclass of ProcessError, module=multiprocessing.context) vs concurrent.futures.TimeoutError (alias for built-in TimeoutError, module=builtins, base=OSError from extra109); all three ProcessError subclasses (AuthenticationError, BufferTooShort, TimeoutError) share __module__=='multiprocessing.context' (len=23) and __mro__.__len__()==5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpexc111b

  columns: [id, function, args, expected, description]
  rows:
    - [te_name_eq,          multiprocessing.TimeoutError.__name__.__eq__,                  ["TimeoutError"],        true, "TimeoutError.__name__ == 'TimeoutError' (len=12, tied with ProcessError=12); verified with Python 3.14.3"]
    - [te_name_len,         multiprocessing.TimeoutError.__name__.__len__,                 [],                      12,   "TimeoutError.__name__.__len__() == 12 ('TimeoutError'=12, tied shortest in spec with ProcessError); verified with Python 3.14.3"]
    - [te_qn_eq,            multiprocessing.TimeoutError.__qualname__.__eq__,              ["TimeoutError"],        true, "TimeoutError.__qualname__ == 'TimeoutError' (len=12, qualname equals name); verified with Python 3.14.3"]
    - [te_module_eq,        multiprocessing.TimeoutError.__module__.__eq__,                ["multiprocessing.context"], true, "TimeoutError.__module__ == 'multiprocessing.context' (NOT builtins — distinct from built-in TimeoutError); verified with Python 3.14.3"]
    - [te_module_len,       multiprocessing.TimeoutError.__module__.__len__,               [],                      23,   "TimeoutError.__module__.__len__() == 23 ('multiprocessing.context'=23); verified with Python 3.14.3"]
    - [te_mro_len,          multiprocessing.TimeoutError.__mro__.__len__,                  [],                      5,    "TimeoutError.__mro__.__len__() == 5 ([TimeoutError, ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [te_base_eq,          "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__",   ["ProcessError"],        true, "TimeoutError.__bases__[0].__name__ == 'ProcessError' (NOT OSError — distinct from built-in TimeoutError); verified with Python 3.14.3"]
    - [pe_mro_lt_subclass,  multiprocessing.ProcessError.__mro__.__len__,                  [],                      4,    "ProcessError.__mro__ len=4 < subclasses MRO len=5 (subclasses add one level); verified with Python 3.14.3"]
    - [all_same_module,     multiprocessing.TimeoutError.__module__.__len__,               [],                      23,   "All four exceptions share __module__.__len__()==23 ('multiprocessing.context'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra111
# ---------------------------------------------------------------------------

invariant multiprocessing_extra111.AuthenticationError_name_len_19:
  description: "multiprocessing.AuthenticationError.__name__.__len__() == 19 — 'AuthenticationError'=19 chars; this is the longest exception class name in this spec; compare exception name lengths: ProcessError=TimeoutError=12 (tied shortest) < BufferTooShort=14 < AuthenticationError=19 (longest — 5 chars more than BufferTooShort, 7 chars more than ProcessError/TimeoutError); multiprocessing.AuthenticationError.__module__=='multiprocessing.context' (len=23); multiprocessing.AuthenticationError.__mro__.__len__()==5 ([AuthenticationError, ProcessError, Exception, BaseException, object]); multiprocessing.AuthenticationError.__bases__[0].__name__=='ProcessError'; AuthenticationError is raised when an authentication attempt fails during multiprocessing inter-process connection setup; multiprocessing.AuthenticationError.__qualname__=='AuthenticationError' (len=19, qualname equals name); NEW in extra111: first standalone AuthenticationError name length invariant in mpexc111 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.AuthenticationError.__name__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra111.ProcessError_mro_len_4:
  description: "multiprocessing.ProcessError.__mro__.__len__() == 4 — ProcessError MRO is [ProcessError, Exception, BaseException, object] (length=4); this is shorter than its three subclasses (AuthenticationError, BufferTooShort, TimeoutError) which all have MRO len=5 (they add ProcessError as an intermediate level); multiprocessing.ProcessError.__bases__[0].__name__=='Exception'; compare: ProcessError.__mro__.__len__()==4 < subclasses.__mro__.__len__()==5; multiprocessing.ProcessError is the common base for all multiprocessing-specific exceptions — raising a ProcessError or any subclass indicates an error specific to multiprocessing IPC mechanisms; multiprocessing.ProcessError.__module__=='multiprocessing.context' (len=23); multiprocessing.ProcessError.__name__=='ProcessError' (len=12); multiprocessing.ProcessError.__qualname__=='ProcessError' (len=12); NEW in extra111: first standalone ProcessError MRO length invariant in mpexc111 namespace; wave 255; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.ProcessError.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra111.TimeoutError_module_not_builtins:
  description: "multiprocessing.TimeoutError.__module__.__eq__('multiprocessing.context') returns True — multiprocessing.TimeoutError.__module__=='multiprocessing.context' (len=23; NOT 'builtins'); this is the key distinguishing fact: multiprocessing.TimeoutError is a DIFFERENT class from the built-in TimeoutError; concurrent.futures.TimeoutError.__module__=='builtins' (from extra109) because that one is simply a re-export of the built-in; multiprocessing.TimeoutError.__bases__[0].__name__=='ProcessError' (inherits from ProcessError, not from OSError); multiprocessing.TimeoutError.__mro__.__len__()==5 ([TimeoutError, ProcessError, Exception, BaseException, object]) vs built-in TimeoutError MRO ([TimeoutError, OSError, Exception, BaseException, object]); multiprocessing.TimeoutError.__name__=='TimeoutError' (len=12); multiprocessing.TimeoutError is raised when a timeout occurs in multiprocessing operations (e.g., Process.join(timeout=...)); NEW in extra111: first standalone TimeoutError module invariant in mpexc111 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.TimeoutError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra111.BufferTooShort_name_len_14:
  description: "multiprocessing.BufferTooShort.__name__.__len__() == 14 — 'BufferTooShort'=14 chars; compare exception name lengths: ProcessError=TimeoutError=12 (tied shortest) < BufferTooShort=14 < AuthenticationError=19 (longest); multiprocessing.BufferTooShort.__module__=='multiprocessing.context' (len=23); multiprocessing.BufferTooShort.__mro__.__len__()==5 ([BufferTooShort, ProcessError, Exception, BaseException, object]); multiprocessing.BufferTooShort.__bases__[0].__name__=='ProcessError'; BufferTooShort is raised in IPC (inter-process communication) when the supplied read buffer is too small to hold the message; the exception instance carries the message that could not be received (accessible as exception.args[0]); multiprocessing.BufferTooShort.__qualname__=='BufferTooShort' (len=14, qualname equals name); multiprocessing.BufferTooShort.__name__.__len__()==14 > ProcessError.__name__.__len__()==12 by 2 chars; NEW in extra111: first standalone BufferTooShort name length invariant in mpexc111 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.BufferTooShort.__name__.__len__
  args: []
  expected: 14

invariant multiprocessing_extra111.all_subclasses_mro_len_5:
  description: "multiprocessing.AuthenticationError.__mro__.__len__() == 5 — all three ProcessError direct subclasses (AuthenticationError, BufferTooShort, TimeoutError) have __mro__.__len__()==5 ([XxxError, ProcessError, Exception, BaseException, object]); this invariant confirms AuthenticationError's MRO length=5 as representative; compare: ProcessError.__mro__.__len__()==4 (the base) vs its subclasses.__mro__.__len__()==5 (one level deeper); the consistent MRO depth=5 across all three subclasses reflects that they all directly subclass ProcessError without any additional intermediate classes; multiprocessing.AuthenticationError.__bases__[0].__name__=='ProcessError'; multiprocessing.BufferTooShort.__mro__.__len__()==5 (tied); multiprocessing.TimeoutError.__mro__.__len__()==5 (tied); multiprocessing.AuthenticationError.__module__=='multiprocessing.context' (len=23); multiprocessing.AuthenticationError.__name__.__len__()==19 (longest exception name in spec); NEW in extra111: confirms AuthenticationError MRO length as representative of all subclass MRO lengths; wave 255; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.AuthenticationError.__mro__.__len__
  args: []
  expected: 5

