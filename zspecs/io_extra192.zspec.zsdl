spec: io_extra192
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.__name__ == 'io' (len=2)."
    - "io.IOBase.__mro__ len == 3: IOBase, _io._IOBase, object (private C-level intermediate class present)."
    - "io.RawIOBase.__mro__ len == 5: RawIOBase, _io._RawIOBase, IOBase, _io._IOBase, object."
    - "io.BufferedIOBase.__mro__ len == 5: BufferedIOBase, _io._BufferedIOBase, IOBase, _io._IOBase, object."
    - "io.TextIOBase.__mro__ len == 5: TextIOBase, _io._TextIOBase, IOBase, _io._IOBase, object."
    - "io.BytesIO.__mro__ len == 4: _io.BytesIO, _io._BufferedIOBase, _io._IOBase, object."
    - "io.StringIO.__mro__ len == 4: _io.StringIO, _io._TextIOBase, _io._IOBase, object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io module __name__ identity
# io.__name__ == 'io', len == 2
# ---------------------------------------------------------------------------

table io_extra192.module_name:
  description: "io module __name__ identity: io.__name__ == 'io' and len == 2"
  kind: python_call_eq
  category: identity
  id_prefix: iomodule192

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       io.__name__.__eq__,      ["io"], true, "io.__name__ == 'io' — module name is 'io'; confirmed Python 3.14.3 macOS"]
    - [name_len,      io.__name__.__len__,      [],     2,    "io.__name__.__len__() == 2 — 'io' has 2 characters: i(1)o(2); confirmed Python 3.14.3 macOS"]
    - [name_len_eq,   io.__name__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "io.__name__.__len__ is a builtin method; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io base class MRO lengths — IOBase, RawIOBase, BufferedIOBase, TextIOBase
# IOBase MRO len == 3, RawIOBase/BufferedIOBase/TextIOBase MRO len == 5
# ---------------------------------------------------------------------------

table io_extra192.base_class_mro_lengths:
  description: "io base class MRO lengths: IOBase(3), RawIOBase(5), BufferedIOBase(5), TextIOBase(5) — private C-level intermediates included"
  kind: python_call_eq
  category: identity
  id_prefix: iomodule192

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_mro_len,     "io.IOBase.__mro__.__len__",         [], 3, "io.IOBase.__mro__ len == 3: IOBase, _io._IOBase, object — private C intermediate present; confirmed Python 3.14.3 macOS"]
    - [rawio_mro_len,      "io.RawIOBase.__mro__.__len__",      [], 5, "io.RawIOBase.__mro__ len == 5: RawIOBase, _io._RawIOBase, IOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"]
    - [bufio_mro_len,      "io.BufferedIOBase.__mro__.__len__", [], 5, "io.BufferedIOBase.__mro__ len == 5: BufferedIOBase, _io._BufferedIOBase, IOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"]
    - [textio_mro_len,     "io.TextIOBase.__mro__.__len__",     [], 5, "io.TextIOBase.__mro__ len == 5: TextIOBase, _io._TextIOBase, IOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"]
    - [iobase_mro_len_eq,  "io.IOBase.__mro__.__len__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "io.IOBase.__mro__.__len__ is a builtin method; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io concrete class MRO lengths — BytesIO and StringIO
# BytesIO MRO len == 4, StringIO MRO len == 4
# ---------------------------------------------------------------------------

table io_extra192.concrete_class_mro_lengths:
  description: "io concrete class MRO lengths: BytesIO(4), StringIO(4) — both bypass public abstract bases and use private C intermediates directly"
  kind: python_call_eq
  category: identity
  id_prefix: iomodule192

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_mro_len,   "io.BytesIO.__mro__.__len__",  [], 4, "io.BytesIO.__mro__ len == 4: _io.BytesIO, _io._BufferedIOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"]
    - [stringio_mro_len,  "io.StringIO.__mro__.__len__", [], 4, "io.StringIO.__mro__ len == 4: _io.StringIO, _io._TextIOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"]
    - [bytesio_mro_len_eq,  "io.BytesIO.__mro__.__len__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "io.BytesIO.__mro__.__len__ is a builtin method; confirmed Python 3.14.3 macOS"]
    - [stringio_mro_len_eq, "io.StringIO.__mro__.__len__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "io.StringIO.__mro__.__len__ is a builtin method; confirmed Python 3.14.3 macOS"]
    - [bytesio_ne_stringio, "io.BytesIO.__mro__.__len__.__eq__",                     [4],                           true, "io.BytesIO.__mro__ len equals io.StringIO.__mro__ len (both 4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra192.module_name_eq:
  description: "io.__name__ == 'io' — the io module's __name__ attribute is the string 'io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.__name__.__eq__
  args: ["io"]
  expected: true

invariant io_extra192.module_name_len_2:
  description: "io.__name__.__len__() == 2 — 'io' has 2 characters: i(1)o(2); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.__name__.__len__
  args: []
  expected: 2

invariant io_extra192.iobase_mro_len_3:
  description: "io.IOBase.__mro__ len == 3 — MRO includes IOBase, _io._IOBase (private C intermediate), object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.IOBase.__mro__.__len__"
  args: []
  expected: 3

invariant io_extra192.rawiobase_mro_len_5:
  description: "io.RawIOBase.__mro__ len == 5 — RawIOBase, _io._RawIOBase, IOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.RawIOBase.__mro__.__len__"
  args: []
  expected: 5

invariant io_extra192.bufferediobase_mro_len_5:
  description: "io.BufferedIOBase.__mro__ len == 5 — BufferedIOBase, _io._BufferedIOBase, IOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.BufferedIOBase.__mro__.__len__"
  args: []
  expected: 5

invariant io_extra192.textiobase_mro_len_5:
  description: "io.TextIOBase.__mro__ len == 5 — TextIOBase, _io._TextIOBase, IOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOBase.__mro__.__len__"
  args: []
  expected: 5

invariant io_extra192.bytesio_mro_len_4:
  description: "io.BytesIO.__mro__ len == 4 — _io.BytesIO, _io._BufferedIOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.BytesIO.__mro__.__len__"
  args: []
  expected: 4

invariant io_extra192.stringio_mro_len_4:
  description: "io.StringIO.__mro__ len == 4 — _io.StringIO, _io._TextIOBase, _io._IOBase, object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
