spec: itertools_extra172
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.__name__ 'itertools'; itertools.__spec__.__class__.__name__ 'ModuleSpec'; itertools.__loader__.__class__.__name__ 'type' (the BuiltinImporter class object itself); itertools.__package__ '' (empty string); itertools.__doc__.__class__.__name__ 'str'; itertools.__doc__.__contains__('iterator') True (Wave 301)."
    - "itertools.__name__ == 'itertools' — itertools is the name of the C extension module; the module's __name__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — itertools.__spec__ is an importlib.machinery.ModuleSpec object describing the module; its __class__.__name__ is 'ModuleSpec'. Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' — itertools.__loader__ is the BuiltinImporter class itself (not an instance); as a class object, its __class__ is 'type' (the metaclass). itertools.__loader__.__name__ is 'BuiltinImporter'. Verified with Python 3.14.3."
    - "itertools.__package__ == '' — itertools is a top-level built-in C extension module; its __package__ attribute is the empty string '' (not 'itertools' and not None). Verified with Python 3.14.3."
    - "itertools.__doc__.__class__.__name__ == 'str' — itertools has a module-level docstring; the __doc__ attribute is a str instance. Verified with Python 3.14.3."
    - "itertools.__doc__.__contains__('iterator') == True — the itertools module docstring begins 'Functional tools for creating and using iterators.' which contains the word 'iterator'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module-level __name__ identity
#
# Wave 301 theme: itertools.__name__ is the string 'itertools'; the module's
# name attribute is a str with the expected value.
#
# itertools.__name__ == 'itertools'
# itertools.__name__.__class__.__name__ == 'str'
# itertools.__name__.__len__() == 9
# itertools.__name__ != 'itertool'  (no trailing 's')
#
# itertools is a C extension module whose module name is 'itertools'. The
# __name__ attribute of any module is the string name of that module. New to
# extra172.
# ---------------------------------------------------------------------------

table itertools_extra172.module_name_identity:
  description: "itertools.__name__: 'itertools', class 'str', len 9; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsmni172

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_itertools,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the itertools module's __name__ attribute is the string 'itertools'; str.__eq__('itertools') returns True; new to extra172"]
    - [module_name_class_str,
       "__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__name__.__class__.__name__.__eq__('str') == True — itertools.__name__ is a str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra172"]
    - [module_name_len_9,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — the string 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra172"]
    - [module_name_ne_itertool,
       "__name__.__eq__",
       ["itertool"],
       false,
       "itertools.__name__.__eq__('itertool') == False — the module name is 'itertools' (with trailing 's'), not 'itertool' (without trailing 's'); str.__eq__('itertool') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 2: itertools.__spec__.__class__.__name__ == 'ModuleSpec'
#
# Wave 301 theme: itertools.__spec__ is an importlib.machinery.ModuleSpec
# object; its __class__.__name__ is 'ModuleSpec'.
#
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__spec__.__class__.__name__ != 'ModuleType'
# itertools.__spec__.__class__.__name__ != 'str'
# itertools.__spec__.__class__.__name__ != 'type'
#
# Python's import system attaches a ModuleSpec to every imported module as
# __spec__. The ModuleSpec holds the module's name, loader, origin, and
# submodule search paths. For the built-in itertools C extension the spec's
# origin is 'built-in'. New to extra172.
# ---------------------------------------------------------------------------

table itertools_extra172.spec_class_name:
  description: "itertools.__spec__: __class__.__name__ 'ModuleSpec'; not ModuleType, str, or type; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsscn172

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — itertools.__spec__ is an importlib.machinery.ModuleSpec object created by the import system to describe the itertools built-in C extension module; its __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra172"]
    - [spec_class_not_moduletype,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleType"],
       false,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleType') == False — itertools.__spec__ is a ModuleSpec (metadata about the module), NOT the module itself (which would be ModuleType); str.__eq__('ModuleType') returns False; new to extra172"]
    - [spec_class_not_str,
       "__spec__.__class__.__name__.__eq__",
       ["str"],
       false,
       "itertools.__spec__.__class__.__name__.__eq__('str') == False — itertools.__spec__ is a ModuleSpec object, NOT a string; str.__eq__('str') returns False; new to extra172"]
    - [spec_class_not_type,
       "__spec__.__class__.__name__.__eq__",
       ["type"],
       false,
       "itertools.__spec__.__class__.__name__.__eq__('type') == False — itertools.__spec__ is a ModuleSpec object (an instance), NOT a class (type); str.__eq__('type') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 3: itertools.__loader__.__class__.__name__ == 'type' and
# itertools.__package__ == ''
#
# Wave 301 theme: itertools.__loader__ is the BuiltinImporter class itself
# (its __class__ is 'type'); itertools.__package__ is the empty string ''.
#
# itertools.__loader__.__class__.__name__ == 'type'
# itertools.__package__.__eq__('') == True
# itertools.__package__.__eq__('itertools') == False
# itertools.__loader__.__class__.__name__ != 'BuiltinImporter'
#
# itertools.__loader__ is the importlib._bootstrap.BuiltinImporter class
# object (not an instance of it). Because it IS a class object, its
# __class__.__name__ is 'type' (the metaclass of all classes). To get the
# name 'BuiltinImporter' one must access itertools.__loader__.__name__.
# itertools.__package__ is '' (empty string) for top-level built-in modules.
# New to extra172.
# ---------------------------------------------------------------------------

table itertools_extra172.loader_class_and_package:
  description: "itertools.__loader__: __class__.__name__ 'type' (BuiltinImporter class); __package__ is ''; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolslcp172

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools.__loader__ is the BuiltinImporter class itself (not an instance); as a class object its __class__ is 'type' (the metaclass of all Python classes); str.__eq__('type') returns True; new to extra172"]
    - [package_empty_string,
       "__package__.__eq__",
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a top-level built-in C extension module; its __package__ attribute is the empty string '' (not 'itertools' and not None); str.__eq__('') returns True; new to extra172"]
    - [package_not_itertools,
       "__package__.__eq__",
       ["itertools"],
       false,
       "itertools.__package__.__eq__('itertools') == False — itertools.__package__ is the empty string '' (a top-level built-in has no enclosing package), NOT 'itertools'; str.__eq__('itertools') returns False; new to extra172"]
    - [loader_class_not_builtin_importer,
       "__loader__.__class__.__name__.__eq__",
       ["BuiltinImporter"],
       false,
       "itertools.__loader__.__class__.__name__.__eq__('BuiltinImporter') == False — itertools.__loader__ IS the BuiltinImporter class, so its __class__.__name__ is 'type' (not 'BuiltinImporter'); to get 'BuiltinImporter' one accesses __loader__.__name__; str.__eq__('BuiltinImporter') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 4: itertools.__doc__ is a str containing 'iterator'
#
# Wave 301 theme: itertools.__doc__ is a str instance whose content contains
# the word 'iterator'.
#
# itertools.__doc__.__class__.__name__ == 'str'
# itertools.__doc__.__contains__('iterator') == True
# itertools.__doc__.__contains__('Functional') == True
# itertools.__doc__.__class__.__name__ != 'NoneType'
#
# The itertools module has a docstring beginning 'Functional tools for
# creating and using iterators.' The __doc__ attribute is a non-None str
# object. It contains both 'iterator' (from 'iterators') and 'Functional'.
# New to extra172.
# ---------------------------------------------------------------------------

table itertools_extra172.doc_class_and_content:
  description: "itertools.__doc__: __class__.__name__ 'str'; contains 'iterator' and 'Functional'; not NoneType; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsdcc172

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_str,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — itertools has a module-level docstring; its __doc__ attribute is a str instance; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra172"]
    - [doc_contains_iterator,
       "__doc__.__contains__",
       ["iterator"],
       true,
       "itertools.__doc__.__contains__('iterator') == True — the itertools module docstring begins 'Functional tools for creating and using iterators.' which contains the substring 'iterator'; str.__contains__('iterator') returns True; new to extra172"]
    - [doc_contains_functional,
       "__doc__.__contains__",
       ["Functional"],
       true,
       "itertools.__doc__.__contains__('Functional') == True — the itertools module docstring begins 'Functional tools for creating and using iterators.' which starts with the word 'Functional'; str.__contains__('Functional') returns True; new to extra172"]
    - [doc_not_nonetype,
       "__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "itertools.__doc__.__class__.__name__.__eq__('NoneType') == False — itertools.__doc__ is a non-None str (the module has a real docstring); its __class__.__name__ is 'str', not 'NoneType'; str.__eq__('NoneType') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 5: itertools module-level attributes summary cross-checks
#
# Wave 301 theme: cross-checks confirming the overall module identity
# attributes — __name__ is a str of length 9, __spec__ class is ModuleSpec,
# __package__ is empty, and __doc__ contains 'iterator'.
#
# itertools.__name__.__len__() == 9
# itertools.__spec__.__class__.__name__ != 'str'
# itertools.__package__.__class__.__name__ == 'str'
# itertools.__doc__.__class__.__name__ != 'bytes'
#
# These cross-checks confirm the module's identity attributes are of the
# correct Python types. New to extra172.
# ---------------------------------------------------------------------------

table itertools_extra172.module_attrs_cross_checks:
  description: "itertools module attrs: __name__ len 9; __spec__ class not str; __package__ class str; __doc__ class not bytes; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsmacc172

  columns: [id, function, args, expected, description]
  rows:
    - [name_len_9_xcheck,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — cross-check confirming 'itertools' has 9 characters; str.__len__() returns 9; new to extra172"]
    - [spec_class_not_str,
       "__spec__.__class__.__name__.__eq__",
       ["str"],
       false,
       "itertools.__spec__.__class__.__name__.__eq__('str') == False — itertools.__spec__ is a ModuleSpec object, not a string; cross-check confirming the spec is a structured object; str.__eq__('str') returns False; new to extra172"]
    - [package_class_str,
       "__package__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__package__.__class__.__name__.__eq__('str') == True — itertools.__package__ is the empty string '' which is a str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra172"]
    - [doc_not_bytes,
       "__doc__.__class__.__name__.__eq__",
       ["bytes"],
       false,
       "itertools.__doc__.__class__.__name__.__eq__('bytes') == False — itertools.__doc__ is a str (Python 3 docstrings are always str, never bytes); __class__.__name__ is 'str', not 'bytes'; str.__eq__('bytes') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra172
# ---------------------------------------------------------------------------

invariant itertools_extra172.module_name_itertools:
  description: "itertools.__name__ == 'itertools' — the module's name attribute is the string 'itertools'; wave 301; new to extra172"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra172.spec_class_modulespec:
  description: "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec describing the built-in itertools module; wave 301; new to extra172"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra172.loader_class_type:
  description: "itertools.__loader__.__class__.__name__ == 'type' — __loader__ is the BuiltinImporter class itself (a class object), so its __class__ is 'type'; wave 301; new to extra172"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra172.package_empty_string:
  description: "itertools.__package__ == '' — top-level built-in C extension modules have __package__ as the empty string; wave 301; new to extra172"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra172.doc_class_str:
  description: "itertools.__doc__.__class__.__name__ == 'str' — the itertools module has a non-None docstring; __doc__ is a str instance; wave 301; new to extra172"
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra172.doc_contains_iterator:
  description: "itertools.__doc__.__contains__('iterator') == True — the module docstring 'Functional tools for creating and using iterators.' contains the substring 'iterator'; wave 301; new to extra172"
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["iterator"]
  expected: true

invariant itertools_extra172.package_not_itertools:
  description: "itertools.__package__ != 'itertools' — __package__ is '' (empty string) for top-level built-ins, not 'itertools'; wave 301; new to extra172"
  kind: python_call_eq
  function: __package__.__eq__
  args: ["itertools"]
  expected: false

invariant itertools_extra172.module_name_len_9:
  description: "itertools.__name__.__len__() == 9 — 'itertools' is 9 characters long; wave 301; new to extra172"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9
