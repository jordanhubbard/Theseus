# ---------------------------------------------------------------------------
# Table 3: inspect predicate function __qualname__ lengths
#
# Wave 257 theme: inspect predicate function __qualname__ lengths.
#
# inspect.isclass.__qualname__ len == 7
# inspect.ismethod.__qualname__ len == 8
# inspect.ismodule.__qualname__ len == 8
# inspect.isbuiltin.__qualname__ len == 9
# inspect.isfunction.__qualname__ len == 10
# inspect.isasyncgen.__qualname__ len == 10
# inspect.isabstract.__qualname__ len == 10
# inspect.isgenerator.__qualname__ len == 11
# inspect.iscoroutine.__qualname__ len == 11
# inspect.isawaitable.__qualname__ len == 11
# inspect.isdatadescriptor.__qualname__ len == 16
# inspect.ismethoddescriptor.__qualname__ len == 18
# inspect.isgetsetdescriptor.__qualname__ len == 18
# inspect.ismemberdescriptor.__qualname__ len == 18
