# ---------------------------------------------------------------------------
# Standalone invariants — extra104
# ---------------------------------------------------------------------------

invariant inspect_extra104.isfunction_module:
  description: "inspect.isfunction.__module__ == 'inspect' — pure-Python predicate in Lib/inspect.py; wave 257; new to extra104"
  kind: python_call_eq
  function: isfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra104.isabstract_module:
  description: "inspect.isabstract.__module__ == 'inspect' — pure-Python predicate in Lib/inspect.py; wave 257; new to extra104"
  kind: python_call_eq
  function: isabstract.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra104.ismethoddescriptor_qualname_len:
  description: "inspect.ismethoddescriptor.__qualname__.__len__() == 18 — 'ismethoddescriptor' has 18 characters; wave 257; new to extra104"
  kind: python_call_eq
  function: ismethoddescriptor.__qualname__.__len__
  args: []
  expected: 18

invariant inspect_extra104.isclass_qualname_len:
  description: "inspect.isclass.__qualname__.__len__() == 7 — 'isclass' has 7 characters; wave 257; new to extra104"
  kind: python_call_eq
  function: isclass.__qualname__.__len__
  args: []
  expected: 7

invariant inspect_extra104.isgenerator_module:
  description: "inspect.isgenerator.__module__ == 'inspect' — pure-Python predicate in Lib/inspect.py; wave 257; new to extra104"
  kind: python_call_eq
  function: isgenerator.__module__.__eq__
  args: ["inspect"]
  expected: true
