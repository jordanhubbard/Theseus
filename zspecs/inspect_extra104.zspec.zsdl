  description: "inspect predicate function __qualname__.__len__() values for all 14 predicates; wave 257; new to extra104"
  kind: python_call_eq
  category: string_lengths
  id_prefix: inspectpredqn104

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_qualname_len_7,
       "isclass.__qualname__.__len__",
       [],
       7,
