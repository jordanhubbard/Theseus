spec: inspect_extra104
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra99

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra99.zspec.zsdl."
    - "This spec covers: inspect module predicate function __module__ strings (all 'inspect'); inspect predicate function __qualname__ lengths; inspect predicate function __class__.__name__ (all 'function') (Wave 257)."
    - "inspect.isfunction.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isclass.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.ismethod.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.ismodule.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isgenerator.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isawaitable.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isasyncgen.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isdatadescriptor.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isgetsetdescriptor.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.ismemberdescriptor.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isabstract.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isfunction.__qualname__ == 'isfunction', len 10. Verified with Python 3.14.3."
    - "inspect.isclass.__qualname__ == 'isclass', len 7. Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__qualname__ == 'ismethoddescriptor', len 18. Verified with Python 3.14.3."
    - "inspect.isdatadescriptor.__qualname__ == 'isdatadescriptor', len 16. Verified with Python 3.14.3."
    - "All predicate functions have __class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect predicate function __module__ == 'inspect'
#
# Wave 257 theme: inspect predicate function __module__ is always 'inspect'.
#
# inspect.isfunction.__module__ == 'inspect'
# inspect.isclass.__module__ == 'inspect'
# inspect.ismethod.__module__ == 'inspect'
# inspect.isbuiltin.__module__ == 'inspect'
# inspect.ismodule.__module__ == 'inspect'
# inspect.isgenerator.__module__ == 'inspect'
# inspect.iscoroutine.__module__ == 'inspect'
# inspect.isawaitable.__module__ == 'inspect'
#
# All inspect predicate functions are defined in Lib/inspect.py.
# New to extra104.
# ---------------------------------------------------------------------------

table inspect_extra104.predicate_module_group1:
  description: "inspect predicate __module__ == 'inspect' for isfunction/isclass/ismethod/isbuiltin/ismodule/isgenerator/iscoroutine/isawaitable; all defined in Lib/inspect.py; wave 257; new to extra104"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpredmod104

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_module_eq_inspect,
       "isfunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — inspect.isfunction is a pure-Python predicate defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra104"]
    - [isclass_module_eq_inspect,
       "isclass.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — inspect.isclass is a pure-Python predicate defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra104"]
    - [ismethod_module_eq_inspect,
       "ismethod.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ismethod.__module__.__eq__('inspect') == True — inspect.ismethod is a pure-Python predicate defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra104"]
    - [isbuiltin_module_eq_inspect,
       "isbuiltin.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — inspect.isbuiltin is a pure-Python predicate defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra104"]
    - [ismodule_module_eq_inspect,
       "ismodule.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ismodule.__module__.__eq__('inspect') == True — inspect.ismodule is a pure-Python predicate defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra104"]
    - [isgenerator_module_eq_inspect,
       "isgenerator.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isgenerator.__module__.__eq__('inspect') == True — inspect.isgenerator is a pure-Python predicate defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra104"]
    - [iscoroutine_module_eq_inspect,
       "iscoroutine.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.iscoroutine.__module__.__eq__('inspect') == True — inspect.iscoroutine is a pure-Python predicate defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra104"]
    - [isawaitable_module_eq_inspect,
       "isawaitable.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isawaitable.__module__.__eq__('inspect') == True — inspect.isawaitable is a pure-Python predicate defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra104"]

# ---------------------------------------------------------------------------
