spec: io_extra57
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase/RawIOBase/BufferedIOBase/TextIOBase and module."
    - "io_extra55.zspec.zsdl — covers BytesIO method qualname lengths (read=12, write=13, seek=12, tell=12, getvalue=16) and StringIO method qualname lengths (read=13, write=14, seek=13, getvalue=17)."
    - "io_extra54.zspec.zsdl — covers io concrete class __class__.__qualname__.__eq__('type') for FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper; IOBase.__class__.__qualname__.__eq__('ABCMeta'); open.__class__.__qualname__.__eq__('builtin_function_or_method'); DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__('int')."
    - "io_extra53.zspec.zsdl — covers concrete io class __class__.__name__.__len__()==4; IOBase.__class__.__name__.__eq__('ABCMeta'); open.__name__/__qualname__.__len__()==4; open.__class__.__name__.__eq__('builtin_function_or_method')."
    - "io_extra50.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedWriter/BufferedReader/TextIOWrapper __qualname__.__len__()."
    - "io_extra49.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedWriter/BufferedReader/TextIOWrapper __qualname__.__eq__()."
    - "io_extra33.zspec.zsdl — covers open.__qualname__.__eq__('open')."
    - "io_extra3.zspec.zsdl — covers open.__name__.__eq__('open')."
  notes:
    - "This spec extends io_extra56.zspec.zsdl."
    - "Prior specs collectively covered: all concrete io class __qualname__ equality and lengths (io_extra49/io_extra50); concrete io class __class__.__name__/__qualname__ equality (io_extra4/io_extra53/io_extra54); IOBase.__class__.__name__/__qualname__ equality (io_extra53/io_extra54); open identity attributes (io_extra3/io_extra33/io_extra53/io_extra54); DEFAULT_BUFFER_SIZE.__class__.__qualname__ (io_extra54); BytesIO/StringIO method __qualname__ lengths (io_extra55); io class __doc__.__class__.__name__/__qualname__ (io_extra56). NO prior io spec checks the __qualname__ string equality for any method of BytesIO or StringIO (io_extra55 covers lengths only)."
    - "This spec covers: io.BytesIO.read.__qualname__.__eq__('BytesIO.read') (NOVEL — io_extra55 covers __qualname__.__len__()==12 for BytesIO.read; no prior io spec checks __qualname__.__eq__() for BytesIO.read; novel string equality anchor); io.BytesIO.write.__qualname__.__eq__('BytesIO.write') (NOVEL); io.BytesIO.seek.__qualname__.__eq__('BytesIO.seek') (NOVEL); io.BytesIO.tell.__qualname__.__eq__('BytesIO.tell') (NOVEL); io.BytesIO.getvalue.__qualname__.__eq__('BytesIO.getvalue') (NOVEL); io.StringIO.read.__qualname__.__eq__('StringIO.read') (NOVEL); io.StringIO.write.__qualname__.__eq__('StringIO.write') (NOVEL); io.StringIO.seek.__qualname__.__eq__('StringIO.seek') (NOVEL); io.StringIO.getvalue.__qualname__.__eq__('StringIO.getvalue') (NOVEL); io.DEFAULT_BUFFER_SIZE.__eq__(131072) (NOVEL — no prior io spec checks the numeric value of DEFAULT_BUFFER_SIZE; novel integer equality anchor)."
    - "io.BytesIO.read.__qualname__ == 'BytesIO.read'. BytesIO is a C-extension type in _io; its method read has __qualname__ 'BytesIO.read'. io_extra55 records the length 12; no prior io spec checks the full string equality. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.write.__qualname__ == 'BytesIO.write'. io_extra55 records length 13. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.seek.__qualname__ == 'BytesIO.seek'. io_extra55 records length 12. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.tell.__qualname__ == 'BytesIO.tell'. io_extra55 records length 12. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue'. io_extra55 records length 16. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.read.__qualname__ == 'StringIO.read'. io_extra55 records length 13. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.write.__qualname__ == 'StringIO.write'. io_extra55 records length 14. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.seek.__qualname__ == 'StringIO.seek'. io_extra55 records length 13. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue'. io_extra55 records length 17. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.DEFAULT_BUFFER_SIZE == 131072. The io module defines DEFAULT_BUFFER_SIZE as the default buffer size in bytes for I/O operations. Its value is 8192*16 == 131072. No prior io spec checks the numeric value; novel integer equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO method __qualname__ string equality
#
# BytesIO is a C-extension type in _io. Its methods carry __qualname__ strings
# of the form 'BytesIO.<methodname>'. io_extra55 records the lengths; this spec
# records the exact string values via __qualname__.__eq__():
#
#   BytesIO.read.__qualname__     == 'BytesIO.read'
#   BytesIO.write.__qualname__    == 'BytesIO.write'
#   BytesIO.seek.__qualname__     == 'BytesIO.seek'
#   BytesIO.tell.__qualname__     == 'BytesIO.tell'
#   BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue'
#
# No prior io spec checks __qualname__.__eq__() for any BytesIO method.
# All five equality anchors are novel in the io_extra57 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra57.bytesio_method_qualname_eq:
  description: "io.BytesIO method __qualname__.__eq__() for read/write/seek/tell/getvalue — qualname strings are 'BytesIO.<method>'; io_extra55 covers lengths; no prior io spec checks __qualname__.__eq__() for any BytesIO method; all five novel equality anchors in io_extra57 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: iometh57

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_read_qualname_eq,     "BytesIO.read.__qualname__.__eq__",     ["BytesIO.read"],     true]
    - [BytesIO_write_qualname_eq,    "BytesIO.write.__qualname__.__eq__",    ["BytesIO.write"],    true]
    - [BytesIO_seek_qualname_eq,     "BytesIO.seek.__qualname__.__eq__",     ["BytesIO.seek"],     true]
    - [BytesIO_tell_qualname_eq,     "BytesIO.tell.__qualname__.__eq__",     ["BytesIO.tell"],     true]
    - [BytesIO_getvalue_qualname_eq, "BytesIO.getvalue.__qualname__.__eq__", ["BytesIO.getvalue"], true]

# ---------------------------------------------------------------------------
# io.StringIO method __qualname__ string equality
#
# StringIO is a C-extension type in _io. Its methods carry __qualname__ strings
# of the form 'StringIO.<methodname>'. io_extra55 records the lengths; this spec
# records the exact string values via __qualname__.__eq__():
#
#   StringIO.read.__qualname__     == 'StringIO.read'
#   StringIO.write.__qualname__    == 'StringIO.write'
#   StringIO.seek.__qualname__     == 'StringIO.seek'
#   StringIO.getvalue.__qualname__ == 'StringIO.getvalue'
#
# No prior io spec checks __qualname__.__eq__() for any StringIO method.
# All four equality anchors are novel in the io_extra57 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra57.stringio_method_qualname_eq:
  description: "io.StringIO method __qualname__.__eq__() for read/write/seek/getvalue — qualname strings are 'StringIO.<method>'; io_extra55 covers lengths; no prior io spec checks __qualname__.__eq__() for any StringIO method; all four novel equality anchors in io_extra57 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: iometh57s

  columns: [id, function, args, expected]
  rows:
    - [StringIO_read_qualname_eq,     "StringIO.read.__qualname__.__eq__",     ["StringIO.read"],     true]
    - [StringIO_write_qualname_eq,    "StringIO.write.__qualname__.__eq__",    ["StringIO.write"],    true]
    - [StringIO_seek_qualname_eq,     "StringIO.seek.__qualname__.__eq__",     ["StringIO.seek"],     true]
    - [StringIO_getvalue_qualname_eq, "StringIO.getvalue.__qualname__.__eq__", ["StringIO.getvalue"], true]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE numeric value
#
# io.DEFAULT_BUFFER_SIZE is the default number of bytes used for buffered I/O
# operations. It equals 8192 * 16 == 131072. No prior io spec checks the
# numeric value of DEFAULT_BUFFER_SIZE (prior specs only checked its type via
# __class__.__qualname__.__eq__('int') in io_extra54). This equality anchor
# is novel in the io_extra57 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra57.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — default I/O buffer size is 8192*16 bytes; no prior io spec checks the numeric value; novel integer equality anchor in io_extra57 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: module_constant
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true
