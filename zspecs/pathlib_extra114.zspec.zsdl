spec: pathlib_extra114
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra113.zspec.zsdl."
    - "This spec covers: pathlib.Path.stat, chmod, touch, symlink_to method qualnames and co_argcount; and Path.joinpath/with_name/with_suffix (inherited from PurePath) qualnames."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat' (len 9); type is 'function'."
    - "pathlib.Path.touch.__qualname__ == 'Path.touch' (len 10); co_argcount == 3."
    - "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' (len 15); co_argcount == 3."
    - "pathlib.Path.chmod.__qualname__ == 'Path.chmod' (len 10); co_argcount == 2."
    - "pathlib.Path.replace.__qualname__ == 'Path.replace' (len 12); co_argcount == 2."
    - "pathlib.Path.joinpath.__qualname__ == 'PurePath.joinpath' (len 17); defined on PurePath, co_argcount == 1."
    - "pathlib.Path.with_name.__qualname__ == 'PurePath.with_name' (len 18); defined on PurePath, co_argcount == 2."
    - "pathlib.Path.with_suffix.__qualname__ == 'PurePath.with_suffix' (len 20); defined on PurePath, co_argcount == 2."
    - "joinpath/with_name/with_suffix show 'PurePath.' prefix (9 chars) because they are defined on PurePath, not on Path."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.stat, chmod, touch, symlink_to method qualnames and co_argcount
# These methods are defined on Path (not PurePath) — qualnames use 'Path.' prefix.
# stat: qualname 'Path.stat' (9 chars); type 'function'.
# touch: qualname 'Path.touch' (10 chars); co_argcount == 3 (self, mode, exist_ok).
# symlink_to: qualname 'Path.symlink_to' (15 chars); co_argcount == 3 (self, target, target_is_directory).
# chmod: qualname 'Path.chmod' (10 chars); co_argcount == 2 (self, mode).
# ---------------------------------------------------------------------------

table pathlib_extra114.Path_stat_chmod_touch_symlink_qualnames:
  description: "pathlib.Path stat/chmod/touch/symlink_to method __qualname__: stat='Path.stat'(9), chmod='Path.chmod'(10), touch='Path.touch'(10), symlink_to='Path.symlink_to'(15); type='function'"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn114a

  columns: [id, function, args, expected, description]
  rows:
    - [stat_qn_eq,        "Path.stat.__qualname__.__eq__",         ["Path.stat"],       true,  "pathlib.Path.stat.__qualname__ == 'Path.stat' (defined on Path, not PurePath)"]
    - [stat_qn_len,       "Path.stat.__qualname__.__len__",        [],                  9,     "pathlib.Path.stat.__qualname__.__len__() == 9 ('Path.stat' has 9 chars)"]
    - [stat_type,         "Path.stat.__class__.__name__.__eq__",   ["function"],        true,  "type(pathlib.Path.stat).__name__ == 'function' (pure Python method)"]
    - [chmod_qn_eq,       "Path.chmod.__qualname__.__eq__",        ["Path.chmod"],      true,  "pathlib.Path.chmod.__qualname__ == 'Path.chmod'"]
    - [chmod_qn_len,      "Path.chmod.__qualname__.__len__",       [],                  10,    "pathlib.Path.chmod.__qualname__.__len__() == 10 ('Path.chmod' has 10 chars)"]
    - [chmod_argcount,    "Path.chmod.__code__.co_argcount.__eq__",[2],                 true,  "pathlib.Path.chmod.__code__.co_argcount == 2 (self, mode)"]
    - [touch_qn_eq,       "Path.touch.__qualname__.__eq__",        ["Path.touch"],      true,  "pathlib.Path.touch.__qualname__ == 'Path.touch'"]
    - [touch_qn_len,      "Path.touch.__qualname__.__len__",       [],                  10,    "pathlib.Path.touch.__qualname__.__len__() == 10 ('Path.touch' has 10 chars; same length as chmod)"]
    - [touch_argcount,    "Path.touch.__code__.co_argcount.__eq__",[3],                 true,  "pathlib.Path.touch.__code__.co_argcount == 3 (self, mode, exist_ok)"]
    - [symlink_qn_eq,     "Path.symlink_to.__qualname__.__eq__",   ["Path.symlink_to"], true,  "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to'"]
    - [symlink_qn_len,    "Path.symlink_to.__qualname__.__len__",  [],                  15,    "pathlib.Path.symlink_to.__qualname__.__len__() == 15 ('Path.symlink_to' has 15 chars)"]
    - [symlink_argcount,  "Path.symlink_to.__code__.co_argcount.__eq__", [3],           true,  "pathlib.Path.symlink_to.__code__.co_argcount == 3 (self, target, target_is_directory)"]

# ---------------------------------------------------------------------------
# pathlib.Path.joinpath, with_name, with_suffix method qualnames
# These methods are defined on PurePath, not Path.
# Their qualnames use 'PurePath.' prefix (9 chars including dot).
# joinpath: 'PurePath.joinpath' (17 chars); co_argcount == 1 (*args via *pathsegments).
# with_name: 'PurePath.with_name' (18 chars); co_argcount == 2 (self, name).
# with_suffix: 'PurePath.with_suffix' (20 chars); co_argcount == 2 (self, suffix).
# ---------------------------------------------------------------------------

table pathlib_extra114.Path_purepath_method_qualnames:
  description: "pathlib.Path methods inherited from PurePath: joinpath='PurePath.joinpath'(17), with_name='PurePath.with_name'(18), with_suffix='PurePath.with_suffix'(20); qualnames use 'PurePath.' prefix"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn114b

  columns: [id, function, args, expected, description]
  rows:
    - [joinpath_qn_eq,    "Path.joinpath.__qualname__.__eq__",    ["PurePath.joinpath"],   true,  "pathlib.Path.joinpath.__qualname__ == 'PurePath.joinpath' (method defined on PurePath, not Path)"]
    - [joinpath_qn_len,   "Path.joinpath.__qualname__.__len__",   [],                      17,    "pathlib.Path.joinpath.__qualname__.__len__() == 17 ('PurePath.joinpath' has 17 chars)"]
    - [joinpath_argcount, "Path.joinpath.__code__.co_argcount.__eq__", [1],                true,  "pathlib.Path.joinpath.__code__.co_argcount == 1 (only 'self'; path segments passed as *args)"]
    - [withname_qn_eq,    "Path.with_name.__qualname__.__eq__",   ["PurePath.with_name"],  true,  "pathlib.Path.with_name.__qualname__ == 'PurePath.with_name' (method defined on PurePath)"]
    - [withname_qn_len,   "Path.with_name.__qualname__.__len__",  [],                      18,    "pathlib.Path.with_name.__qualname__.__len__() == 18 ('PurePath.with_name' has 18 chars)"]
    - [withname_argcount, "Path.with_name.__code__.co_argcount.__eq__", [2],               true,  "pathlib.Path.with_name.__code__.co_argcount == 2 (self, name)"]
    - [withsuffix_qn_eq,  "Path.with_suffix.__qualname__.__eq__", ["PurePath.with_suffix"], true, "pathlib.Path.with_suffix.__qualname__ == 'PurePath.with_suffix' (method defined on PurePath)"]
    - [withsuffix_qn_len, "Path.with_suffix.__qualname__.__len__",[], 20, "pathlib.Path.with_suffix.__qualname__.__len__() == 20 ('PurePath.with_suffix' has 20 chars; longest of the three PurePath-inherited methods)"]
    - [withsuffix_argcount,"Path.with_suffix.__code__.co_argcount.__eq__", [2],            true,  "pathlib.Path.with_suffix.__code__.co_argcount == 2 (self, suffix)"]
    - [joinpath_ne_path_prefix, "Path.joinpath.__qualname__.__eq__", ["Path.joinpath"],    false, "pathlib.Path.joinpath.__qualname__ != 'Path.joinpath' (joinpath is defined on PurePath, so qualname uses 'PurePath.' prefix, not 'Path.')"]

# ---------------------------------------------------------------------------
# pathlib.Path.replace method qualname and argcount
# replace is defined on Path (not PurePath) — qualname uses 'Path.' prefix.
# 'Path.replace' has 12 chars; co_argcount == 2 (self, target).
# Combined with stat/chmod/touch/symlink_to from table a: covers the full set
# of Path-specific mutating methods.
# ---------------------------------------------------------------------------

table pathlib_extra114.Path_replace_qualnames:
  description: "pathlib.Path.replace method: __qualname__='Path.replace'(12), co_argcount=2; contrast with PurePath-inherited methods that use 'PurePath.' prefix"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn114c

  columns: [id, function, args, expected, description]
  rows:
    - [replace_qn_eq,      "Path.replace.__qualname__.__eq__",   ["Path.replace"],   true,  "pathlib.Path.replace.__qualname__ == 'Path.replace' (defined on Path, not PurePath)"]
    - [replace_qn_len,     "Path.replace.__qualname__.__len__",  [],                 12,    "pathlib.Path.replace.__qualname__.__len__() == 12 ('Path.replace' has 12 chars)"]
    - [replace_argcount,   "Path.replace.__code__.co_argcount.__eq__", [2],          true,  "pathlib.Path.replace.__code__.co_argcount == 2 (self, target)"]
    - [replace_type,       "Path.replace.__class__.__name__.__eq__", ["function"],   true,  "type(pathlib.Path.replace).__name__ == 'function' (pure Python method)"]
    - [symlink_longer_than_replace, "Path.symlink_to.__qualname__.__len__.__gt__", [12], true, "len('Path.symlink_to') > len('Path.replace') (15 > 12)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra114.Path.stat_qualname:
  description: "pathlib.Path.stat.__qualname__ == 'Path.stat' (length 9; stat is defined on Path, not PurePath, so the qualname uses the 'Path.' prefix; contrast with joinpath/with_name/with_suffix which use the 'PurePath.' prefix)"
  category: qualnames
  kind: python_call_eq
  function: "Path.stat.__qualname__.__eq__"
  args: ["Path.stat"]
  expected: true

invariant pathlib_extra114.Path.symlink_to_argcount:
  description: "pathlib.Path.symlink_to.__code__.co_argcount == 3 (the three positional parameters are self, target, and target_is_directory; the target_is_directory parameter defaults to False and matters on Windows for directory symlinks)"
  category: qualnames
  kind: python_call_eq
  function: "Path.symlink_to.__code__.co_argcount.__eq__"
  args: [3]
  expected: true

invariant pathlib_extra114.Path.joinpath_purepath_qualname:
  description: "pathlib.Path.joinpath.__qualname__ == 'PurePath.joinpath' (length 17; joinpath is inherited from PurePath, so its qualname carries the 'PurePath.' prefix rather than 'Path.'; this is the defining-class prefix, not the accessing-class prefix)"
  category: qualnames
  kind: python_call_eq
  function: "Path.joinpath.__qualname__.__eq__"
  args: ["PurePath.joinpath"]
  expected: true

invariant pathlib_extra114.Path.with_suffix_qualname_len:
  description: "pathlib.Path.with_suffix.__qualname__.__len__() == 20 ('PurePath.with_suffix' has 20 characters; it is the longest qualname among the three PurePath-inherited methods joinpath(17)/with_name(18)/with_suffix(20))"
  category: qualnames
  kind: python_call_eq
  function: "Path.with_suffix.__qualname__.__len__"
  args: []
  expected: 20

invariant pathlib_extra114.Path.chmod_argcount:
  description: "pathlib.Path.chmod.__code__.co_argcount == 2 (the two positional parameters are self and mode; the follow_symlinks keyword-only argument is not counted in co_argcount since it is keyword-only)"
  category: qualnames
  kind: python_call_eq
  function: "Path.chmod.__code__.co_argcount.__eq__"
  args: [2]
  expected: true

