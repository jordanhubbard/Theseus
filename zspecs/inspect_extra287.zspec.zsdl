spec: inspect_extra287
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module FrameInfo, Traceback namedtuples and stack/frame/source functions identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "FrameInfo and Traceback are namedtuples defined in inspect.py with __module__ == 'inspect'"
    - "ArgInfo is also a namedtuple in inspect with __module__ == 'inspect'"
    - "inspect.currentframe is a pure Python wrapper with __module__ == 'inspect'"
    - "All stack/source functions are pure Python with __module__ == 'inspect'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra287.function_name_identity:
  description: "__name__ for getouterframes, getinnerframes, stack, trace, getsource, getsourcelines, getsourcefile, getfile, currentframe"
  kind: python_call_eq
  category: identity
  id_prefix: inex287

  columns: [id, function, args, expected, description]
  rows:
    - [inex287_001, inspect.getouterframes.__name__.__eq__, ["getouterframes"], true, "getouterframes __name__"]
    - [inex287_002, inspect.getinnerframes.__name__.__eq__, ["getinnerframes"], true, "getinnerframes __name__"]
    - [inex287_003, inspect.stack.__name__.__eq__, ["stack"], true, "stack __name__"]
    - [inex287_004, inspect.trace.__name__.__eq__, ["trace"], true, "trace __name__"]
    - [inex287_005, inspect.getsource.__name__.__eq__, ["getsource"], true, "getsource __name__"]
    - [inex287_006, inspect.getsourcelines.__name__.__eq__, ["getsourcelines"], true, "getsourcelines __name__"]
    - [inex287_007, inspect.getsourcefile.__name__.__eq__, ["getsourcefile"], true, "getsourcefile __name__"]
    - [inex287_008, inspect.getfile.__name__.__eq__, ["getfile"], true, "getfile __name__"]
    - [inex287_009, inspect.currentframe.__name__.__eq__, ["currentframe"], true, "currentframe __name__"]

table inspect_extra287.function_module_identity:
  description: "__module__ == 'inspect' for pure-Python inspect functions"
  kind: python_call_eq
  category: identity
  id_prefix: inex287m

  columns: [id, function, args, expected, description]
  rows:
    - [inex287m_001, inspect.getouterframes.__module__.__eq__, ["inspect"], true, "getouterframes __module__"]
    - [inex287m_002, inspect.getinnerframes.__module__.__eq__, ["inspect"], true, "getinnerframes __module__"]
    - [inex287m_003, inspect.stack.__module__.__eq__, ["inspect"], true, "stack __module__"]
    - [inex287m_004, inspect.trace.__module__.__eq__, ["inspect"], true, "trace __module__"]
    - [inex287m_005, inspect.getsource.__module__.__eq__, ["inspect"], true, "getsource __module__"]
    - [inex287m_006, inspect.getsourcelines.__module__.__eq__, ["inspect"], true, "getsourcelines __module__"]
    - [inex287m_007, inspect.getsourcefile.__module__.__eq__, ["inspect"], true, "getsourcefile __module__"]
    - [inex287m_008, inspect.getfile.__module__.__eq__, ["inspect"], true, "getfile __module__"]
    - [inex287m_009, inspect.currentframe.__module__.__eq__, ["inspect"], true, "currentframe __module__"]

invariant inspect_extra287.frameinfo_name:
  description: "FrameInfo namedtuple __name__ is FrameInfo"
  category: identity
  kind: python_call_eq
  function: inspect.FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra287.frameinfo_module:
  description: "FrameInfo namedtuple __module__ is inspect"
  category: identity
  kind: python_call_eq
  function: inspect.FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra287.traceback_name:
  description: "Traceback namedtuple __name__ is Traceback"
  category: identity
  kind: python_call_eq
  function: inspect.Traceback.__name__.__eq__
  args: ["Traceback"]
  expected: true

invariant inspect_extra287.traceback_module:
  description: "Traceback namedtuple __module__ is inspect"
  category: identity
  kind: python_call_eq
  function: inspect.Traceback.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra287.currentframe_module:
  description: "currentframe __module__ is inspect"
  category: identity
  kind: python_call_eq
  function: inspect.currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true
