spec: socket_extra333
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec focuses on socket module option and flag constants available on macOS/Darwin."
    - "errno-based constants (EADDRINUSE, ECONNREFUSED, ETIMEDOUT, ENOBUFS, EADDRNOTAVAIL) are NOT exported by the socket module on macOS — hasattr(socket, 'EADDRINUSE') is False. Use the errno module for those."
    - "SOCK_NONBLOCK is not available on macOS (it is Linux-only). This spec targets macOS/Darwin."
    - "socket_extra.zspec.zsdl covers: create_connection/create_server/setdefaulttimeout/htons/ntohs function names; setdefaulttimeout(None)==None; inet_aton/inet_ntoa vectors; htons/ntohs/ntohl zero; htonl(1)==16777216."
    - "socket_extra2.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX AddressFamily class names; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW SocketKind class names; AF_INET==2; SOCK_STREAM==1; SOCK_DGRAM==2; gethostname/getfqdn return str; error.__name__=='OSError'; timeout.__name__=='TimeoutError'."
    - "socket.MSG_WAITALL.__class__.__name__ == 'MsgFlag' — MSG_WAITALL is a member of the MsgFlag IntFlag enum. On macOS its value is 64. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.MSG_PEEK.__class__.__name__ == 'MsgFlag' — MSG_PEEK is a member of the MsgFlag IntFlag enum. On macOS its value is 2. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SO_KEEPALIVE.__class__.__name__ == 'int' — SO_KEEPALIVE is a plain int constant (not an enum member). On macOS its value is 8. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SO_SNDBUF.__class__.__name__ == 'int' — SO_SNDBUF is a plain int constant. On macOS its value is 4097. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SO_RCVBUF.__class__.__name__ == 'int' — SO_RCVBUF is a plain int constant. On macOS its value is 4098. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "socket raises OSError for I/O failures. Module-level constant accesses never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are module-level constant accesses."
  codes: {}

# ---------------------------------------------------------------------------
# MSG_WAITALL and MSG_PEEK — MsgFlag IntFlag enum members
# These are flag-like constants in socket.MsgFlag (an IntFlag enum).
# Their class name is 'MsgFlag', not 'int'.
# Integer values are macOS-specific: MSG_WAITALL==64, MSG_PEEK==2.
# ---------------------------------------------------------------------------

invariant socket_extra333.MSG_WAITALL.class_name:
  description: "socket.MSG_WAITALL.__class__.__name__ == 'MsgFlag' — MSG_WAITALL is an IntFlag enum member on macOS"
  category: msg_flags
  kind: python_call_eq
  function: MSG_WAITALL.__class__.__name__.__eq__
  args: ["MsgFlag"]
  expected: true

invariant socket_extra333.MSG_WAITALL.value:
  description: "socket.MSG_WAITALL.__eq__(64) == True — value is 64 on macOS/Darwin"
  category: msg_flags
  kind: python_call_eq
  function: MSG_WAITALL.__eq__
  args: [64]
  expected: true

invariant socket_extra333.MSG_PEEK.class_name:
  description: "socket.MSG_PEEK.__class__.__name__ == 'MsgFlag' — MSG_PEEK is an IntFlag enum member on macOS"
  category: msg_flags
  kind: python_call_eq
  function: MSG_PEEK.__class__.__name__.__eq__
  args: ["MsgFlag"]
  expected: true

invariant socket_extra333.MSG_PEEK.value:
  description: "socket.MSG_PEEK.__eq__(2) == True — value is 2 on macOS/Darwin"
  category: msg_flags
  kind: python_call_eq
  function: MSG_PEEK.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# SO_KEEPALIVE, SO_SNDBUF, SO_RCVBUF — plain int constants
# These socket option level constants are plain ints (not enum members).
# Values are macOS-specific: SO_KEEPALIVE==8, SO_SNDBUF==4097, SO_RCVBUF==4098.
# ---------------------------------------------------------------------------

invariant socket_extra333.SO_KEEPALIVE.class_name:
  description: "socket.SO_KEEPALIVE.__class__.__name__ == 'int' — SO_KEEPALIVE is a plain int constant on macOS"
  category: socket_options
  kind: python_call_eq
  function: SO_KEEPALIVE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra333.SO_KEEPALIVE.value:
  description: "socket.SO_KEEPALIVE.__eq__(8) == True — value is 8 on macOS/Darwin"
  category: socket_options
  kind: python_call_eq
  function: SO_KEEPALIVE.__eq__
  args: [8]
  expected: true

invariant socket_extra333.SO_SNDBUF.class_name:
  description: "socket.SO_SNDBUF.__class__.__name__ == 'int' — SO_SNDBUF is a plain int constant on macOS"
  category: socket_options
  kind: python_call_eq
  function: SO_SNDBUF.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra333.SO_SNDBUF.value:
  description: "socket.SO_SNDBUF.__eq__(4097) == True — value is 4097 on macOS/Darwin"
  category: socket_options
  kind: python_call_eq
  function: SO_SNDBUF.__eq__
  args: [4097]
  expected: true

invariant socket_extra333.SO_RCVBUF.class_name:
  description: "socket.SO_RCVBUF.__class__.__name__ == 'int' — SO_RCVBUF is a plain int constant on macOS"
  category: socket_options
  kind: python_call_eq
  function: SO_RCVBUF.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra333.SO_RCVBUF.value:
  description: "socket.SO_RCVBUF.__eq__(4098) == True — value is 4098 on macOS/Darwin"
  category: socket_options
  kind: python_call_eq
  function: SO_RCVBUF.__eq__
  args: [4098]
  expected: true
