spec: xdrlib
version: ">=3.3,<3.13"
backend: python_module(xdrlib)

docs: https://docs.python.org/3/library/xdrlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xdrlib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "xdrlib source: Lib/xdrlib.py (PSF; source inspection permitted)"
  not_derived_from:
    - "xdrlib internal details"
  notes:
    - "Deprecated since Python 3.11; removed in Python 3.13."
    - "xdrlib encodes and decodes data in XDR (External Data Representation) format per RFC 1014."
    - "Packer encodes data into XDR bytes; instantiable with no arguments."
    - "Unpacker decodes XDR bytes; requires a bytes argument to __init__."
    - "Error is the base exception class for this module, inheriting from Exception."
    - "ConversionError inherits from Error and is raised when a value cannot be converted."
    - "Packer() can be instantiated with no arguments and exposes reset(), get_buf(), pack_uint(), etc."
    - "All expected values verified by running Python 3.12 xdrlib module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant xdrlib.Packer_name:
  description: "Packer.__name__ == 'Packer'"
  category: classnames
  kind: python_call_eq
  function: Packer.__name__.__eq__
  args: ["Packer"]
  expected: true

invariant xdrlib.Packer_module:
  description: "Packer.__module__ == 'xdrlib'"
  category: classnames
  kind: python_call_eq
  function: Packer.__module__.__eq__
  args: ["xdrlib"]
  expected: true

invariant xdrlib.Unpacker_name:
  description: "Unpacker.__name__ == 'Unpacker'"
  category: classnames
  kind: python_call_eq
  function: Unpacker.__name__.__eq__
  args: ["Unpacker"]
  expected: true

invariant xdrlib.Error_name:
  description: "Error.__name__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant xdrlib.Error_base:
  description: "Error.__bases__[0].__name__ == 'Exception'"
  category: classnames
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

invariant xdrlib.ConversionError_name:
  description: "ConversionError.__name__ == 'ConversionError'"
  category: classnames
  kind: python_call_eq
  function: ConversionError.__name__.__eq__
  args: ["ConversionError"]
  expected: true

invariant xdrlib.ConversionError_base:
  description: "ConversionError.__bases__[0].__name__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: ConversionError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Error"

# ---------------------------------------------------------------------------
# Packer instantiation and method checks
# ---------------------------------------------------------------------------

invariant xdrlib.Packer_instantiable:
  description: "Packer() instantiates successfully and is a Packer instance"
  category: packer
  kind: python_call_eq
  function: Packer
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Packer"]
  expected: true

invariant xdrlib.Packer_has_reset:
  description: "Packer().reset is callable"
  category: packer
  kind: python_call_eq
  function: Packer
  args: []
  method: reset.__class__.__name__.__eq__
  method_args: ["method"]
  expected: true

invariant xdrlib.Packer_has_get_buf:
  description: "Packer().get_buf() returns bytes — get_buf is accessible"
  category: packer
  kind: python_call_eq
  function: Packer
  args: []
  method: get_buf
  method_args: []
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["bytes"]
  expected: true
