spec: multiprocessing_extra181
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec covers: multiprocessing.managers.BaseManager and SyncManager class identity — BaseManager.__name__=='BaseManager'(len=11); BaseManager.__module__=='multiprocessing.managers'; BaseManager.__qualname__=='BaseManager'; BaseManager.__bases__[0].__name__=='object'; SyncManager.__name__=='SyncManager'(len=11); SyncManager.__module__=='multiprocessing.managers'; SyncManager.__qualname__=='SyncManager'; SyncManager.__bases__[0].__name__=='BaseManager'; multiprocessing.Manager.__class__.__name__=='method' (Manager at top level is a bound method, not a class)."
    - "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'. BaseManager is a top-level class with no explicit superclass; its only base is object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'. SyncManager directly subclasses BaseManager. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Manager.__class__.__name__ == 'method'. The top-level multiprocessing.Manager is a bound method of the DefaultContext object (BaseContext.Manager), not a class. This differs from multiprocessing.managers.SyncManager which is the actual class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.managers.BaseManager class identity
#
# multiprocessing.managers.BaseManager.__name__ == 'BaseManager' (len=11)
# multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'
# multiprocessing.managers.BaseManager.__qualname__ == 'BaseManager'
#
# BaseManager is the abstract base for managed shared-state servers.
# It is defined in multiprocessing.managers.
# ---------------------------------------------------------------------------

table multiprocessing_extra181.base_manager_identity:
  description: "multiprocessing.managers.BaseManager class identity: __name__=='BaseManager'(len=11), __module__=='multiprocessing.managers', __qualname__=='BaseManager'; new to multiprocessing_extra181"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanager181

  columns: [id, function, args, expected, description]
  rows:
    - [bm_name_eq,
       BaseManager.__name__.__eq__,
       ["BaseManager"],
       true,
       "multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager') == True — BaseManager is the abstract base for managed shared-state servers; __name__ is 'BaseManager' (11 chars: B-a-s-e-M-a-n-a-g-e-r); str.__eq__('BaseManager') returns True; new to multiprocessing_extra181"]
    - [bm_name_len_11,
       BaseManager.__name__.__len__,
       [],
       11,
       "multiprocessing.managers.BaseManager.__name__.__len__() == 11 — 'BaseManager' has 11 characters: B-a-s-e-M-a-n-a-g-e-r; NAME LENGTHS: BaseManager=11 == SyncManager=11; both managers share the same name length; str.__len__() returns 11; new to multiprocessing_extra181"]
    - [bm_module_eq,
       BaseManager.__module__.__eq__,
       ["multiprocessing.managers"],
       true,
       "multiprocessing.managers.BaseManager.__module__.__eq__('multiprocessing.managers') == True — BaseManager is defined in multiprocessing.managers; str.__eq__('multiprocessing.managers') returns True; new to multiprocessing_extra181"]
    - [bm_qualname_eq,
       BaseManager.__qualname__.__eq__,
       ["BaseManager"],
       true,
       "multiprocessing.managers.BaseManager.__qualname__.__eq__('BaseManager') == True — top-level class so __qualname__ equals __name__; str.__eq__('BaseManager') returns True; new to multiprocessing_extra181"]
    - [bm_module_len_24,
       BaseManager.__module__.__len__,
       [],
       24,
       "multiprocessing.managers.BaseManager.__module__.__len__() == 24 — 'multiprocessing.managers' has 24 characters: m-u-l-t-i-p-r-o-c-e-s-s-i-n-g-.-m-a-n-a-g-e-r-s; str.__len__() returns 24; new to multiprocessing_extra181"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.managers.SyncManager class identity
#
# multiprocessing.managers.SyncManager.__name__ == 'SyncManager' (len=11)
# multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'
# multiprocessing.managers.SyncManager.__qualname__ == 'SyncManager'
# multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'
#
# SyncManager subclasses BaseManager and provides proxies for common sync types.
# ---------------------------------------------------------------------------

table multiprocessing_extra181.sync_manager_identity:
  description: "multiprocessing.managers.SyncManager class identity: __name__=='SyncManager'(len=11), __module__=='multiprocessing.managers', __bases__[0].__name__=='BaseManager'; new to multiprocessing_extra181"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanager181

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name_eq,
       SyncManager.__name__.__eq__,
       ["SyncManager"],
       true,
       "multiprocessing.managers.SyncManager.__name__.__eq__('SyncManager') == True — SyncManager provides proxies for Lock, Event, Queue and other sync primitives; __name__ is 'SyncManager' (11 chars); str.__eq__('SyncManager') returns True; new to multiprocessing_extra181"]
    - [sm_name_len_11,
       SyncManager.__name__.__len__,
       [],
       11,
       "multiprocessing.managers.SyncManager.__name__.__len__() == 11 — 'SyncManager' has 11 characters: S-y-n-c-M-a-n-a-g-e-r; NAME LENGTHS: SyncManager=11 == BaseManager=11; same length as its base class name; str.__len__() returns 11; new to multiprocessing_extra181"]
    - [sm_module_eq,
       SyncManager.__module__.__eq__,
       ["multiprocessing.managers"],
       true,
       "multiprocessing.managers.SyncManager.__module__.__eq__('multiprocessing.managers') == True — SyncManager is defined in multiprocessing.managers alongside BaseManager; str.__eq__('multiprocessing.managers') returns True; new to multiprocessing_extra181"]
    - [sm_qualname_eq,
       SyncManager.__qualname__.__eq__,
       ["SyncManager"],
       true,
       "multiprocessing.managers.SyncManager.__qualname__.__eq__('SyncManager') == True — top-level class so __qualname__ equals __name__; str.__eq__('SyncManager') returns True; new to multiprocessing_extra181"]
    - [sm_base0_name_eq,
       "SyncManager.__bases__[0].__name__.__eq__",
       ["BaseManager"],
       true,
       "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') == True — SyncManager directly subclasses BaseManager; its first and only base is BaseManager; str.__eq__('BaseManager') returns True; new to multiprocessing_extra181"]

# ---------------------------------------------------------------------------
# Table 3: BaseManager base class and multiprocessing.Manager bound-method identity
#
# multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'
# multiprocessing.Manager.__class__.__name__ == 'method'
#
# BaseManager's only base is object. The top-level multiprocessing.Manager
# is a bound method of DefaultContext, not a class.
# ---------------------------------------------------------------------------

table multiprocessing_extra181.base_and_toplevel_identity:
  description: "BaseManager.__bases__[0].__name__=='object'; multiprocessing.Manager.__class__.__name__=='method' (bound method of DefaultContext, not a class); new to multiprocessing_extra181"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanager181

  columns: [id, function, args, expected, description]
  rows:
    - [bm_base0_name_eq,
       "BaseManager.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object') == True — BaseManager has no explicit superclass; its only base is object; str.__eq__('object') returns True; new to multiprocessing_extra181"]
    - [bm_base0_name_len_6,
       "BaseManager.__bases__[0].__name__.__len__",
       [],
       6,
       "multiprocessing.managers.BaseManager.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters: o-b-j-e-c-t; str.__len__() returns 6; new to multiprocessing_extra181"]
    - [bm_bases_len_1,
       "BaseManager.__bases__.__len__",
       [],
       1,
       "multiprocessing.managers.BaseManager.__bases__.__len__() == 1 — BaseManager has exactly one direct base class: object; tuple.__len__() returns 1; new to multiprocessing_extra181"]
    - [manager_class_name_eq,
       "Manager.__class__.__name__.__eq__",
       ["method"],
       true,
       "multiprocessing.Manager.__class__.__name__.__eq__('method') == True — the top-level multiprocessing.Manager is a bound method of DefaultContext (BaseContext.Manager), not a class; __class__.__name__ is 'method'; str.__eq__('method') returns True; new to multiprocessing_extra181"]
    - [sm_base0_name_len_11,
       "SyncManager.__bases__[0].__name__.__len__",
       [],
       11,
       "multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__() == 11 — 'BaseManager' has 11 characters; SyncManager's base class name has same length as SyncManager itself; str.__len__() returns 11; new to multiprocessing_extra181"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra181
# ---------------------------------------------------------------------------

invariant multiprocessing_extra181.base_manager_name_eq:
  description: "multiprocessing.managers.BaseManager.__name__ == 'BaseManager' — abstract base for managed shared-state servers; len=11; new to multiprocessing_extra181"
  category: identity
  kind: python_call_eq
  function: BaseManager.__name__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra181.base_manager_module_eq:
  description: "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers' — defined in multiprocessing.managers; new to multiprocessing_extra181"
  category: identity
  kind: python_call_eq
  function: BaseManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra181.base_manager_qualname_eq:
  description: "multiprocessing.managers.BaseManager.__qualname__ == 'BaseManager' — top-level class so __qualname__ equals __name__; new to multiprocessing_extra181"
  category: identity
  kind: python_call_eq
  function: BaseManager.__qualname__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra181.base_manager_base0_name_eq:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object' — no explicit superclass; only base is object; new to multiprocessing_extra181"
  category: identity
  kind: python_call_eq
  function: "BaseManager.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra181.sync_manager_name_eq:
  description: "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' — provides proxies for Lock/Event/Queue etc; len=11; new to multiprocessing_extra181"
  category: identity
  kind: python_call_eq
  function: SyncManager.__name__.__eq__
  args: ["SyncManager"]
  expected: true

invariant multiprocessing_extra181.sync_manager_module_eq:
  description: "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers' — defined alongside BaseManager; new to multiprocessing_extra181"
  category: identity
  kind: python_call_eq
  function: SyncManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra181.sync_manager_base0_name_eq:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager' — SyncManager directly subclasses BaseManager; new to multiprocessing_extra181"
  category: identity
  kind: python_call_eq
  function: "SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra181.manager_class_name_eq:
  description: "multiprocessing.Manager.__class__.__name__ == 'method' — top-level Manager is a bound method of DefaultContext, not a class; new to multiprocessing_extra181"
  category: identity
  kind: python_call_eq
  function: "Manager.__class__.__name__.__eq__"
  args: ["method"]
  expected: true
