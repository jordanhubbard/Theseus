spec: string_to_color
version: ">=1.0.0"
backend: node(string-to-color)

docs: https://www.npmjs.com/package/string-to-color

provenance:
  derived_from:
    - "string-to-color README — https://www.npmjs.com/package/string-to-color"
    - "Test vectors verified with string-to-color via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "string-to-color source"
  notes:
    - "string-to-color is an npm package. Install: npm install string-to-color"
    - "stringToColor(str) deterministically maps any string to a hex color code."
    - "The same input always produces the same color."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns deterministic hex color string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_to_color.color:
  kind: node_module_call_eq
  function: ~
  category: generate
  id_prefix: stc

  columns: [id, args, expected]
  rows:
    - [hello, ["hello"], "#6cd3c8"]
    - [world, ["world"], "#69a416"]
    - [test,  ["test"],  "#a0e732"]
    - [empty, [""],      "#6d2f43"]

