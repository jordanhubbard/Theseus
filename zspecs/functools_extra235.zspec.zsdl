spec: functools_extra235
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.total_ordering and functools.singledispatch identity contracts: __name__, __qualname__, __module__, and name length contracts."
    - "functools.total_ordering.__name__ == 'total_ordering' — total_ordering is a Python-level class decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' — defined in the functools module. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has 14 characters. Verified with Python 3.14.3."
    - "functools.singledispatch.__name__ == 'singledispatch' — singledispatch is a Python-level decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' — defined in the functools module. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has 14 characters. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' — C-level helper in _functoolsmodule.c; __name__ is 'cmp_to_key'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' — implemented in C extension _functools. Verified with Python 3.14.3."
    - "functools.reduce.__name__ == 'reduce' — C-level reduce in _functoolsmodule.c; __name__ is 'reduce'. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — implemented in C extension _functools. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.total_ordering identity contracts
#
# functools.total_ordering.__name__ == 'total_ordering'
# functools.total_ordering.__qualname__ == 'total_ordering'
# functools.total_ordering.__module__ == 'functools'
# functools.total_ordering.__name__.__len__() == 14
# functools.total_ordering.__qualname__.__len__() == 14
#
# New to extra235.
# ---------------------------------------------------------------------------

table functools_extra235.total_ordering_identity:
  description: "functools.total_ordering identity contracts: __name__, __qualname__, __module__, name length; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra235totordid

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_name_eq,
       total_ordering.__name__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__ == 'total_ordering' — total_ordering is a class decorator in Lib/functools.py that fills in missing comparison methods; __name__.__eq__('total_ordering') returns True; new to extra235"]
    - [total_ordering_qualname_eq,
       total_ordering.__qualname__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__ == 'total_ordering' — total_ordering is a top-level function with unqualified qualname 'total_ordering'; __qualname__.__eq__('total_ordering') returns True; new to extra235"]
    - [total_ordering_module_eq,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__ == 'functools' — total_ordering is defined in the Python functools module (Lib/functools.py); __module__.__eq__('functools') returns True; new to extra235"]
    - [total_ordering_name_len_14,
       total_ordering.__name__.__len__,
       [],
       14,
       "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has exactly 14 characters (t-o-t-a-l-_-o-r-d-e-r-i-n-g); __len__() returns 14; new to extra235"]
    - [total_ordering_qualname_len_14,
       total_ordering.__qualname__.__len__,
       [],
       14,
       "functools.total_ordering.__qualname__.__len__() == 14 — qualname 'total_ordering' has exactly 14 characters; __len__() returns 14; new to extra235"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatch identity contracts
#
# functools.singledispatch.__name__ == 'singledispatch'
# functools.singledispatch.__qualname__ == 'singledispatch'
# functools.singledispatch.__module__ == 'functools'
# functools.singledispatch.__name__.__len__() == 14
# functools.singledispatch.__qualname__.__len__() == 14
#
# New to extra235.
# ---------------------------------------------------------------------------

table functools_extra235.singledispatch_identity:
  description: "functools.singledispatch identity contracts: __name__, __qualname__, __module__, name length; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra235sdispid

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_name_eq,
       singledispatch.__name__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__ == 'singledispatch' — singledispatch is a generic function decorator in Lib/functools.py; __name__.__eq__('singledispatch') returns True; new to extra235"]
    - [singledispatch_qualname_eq,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__ == 'singledispatch' — singledispatch is a top-level function with unqualified qualname 'singledispatch'; __qualname__.__eq__('singledispatch') returns True; new to extra235"]
    - [singledispatch_module_eq,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__ == 'functools' — singledispatch is defined in the Python functools module (Lib/functools.py); __module__.__eq__('functools') returns True; new to extra235"]
    - [singledispatch_name_len_14,
       singledispatch.__name__.__len__,
       [],
       14,
       "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has exactly 14 characters (s-i-n-g-l-e-d-i-s-p-a-t-c-h); __len__() returns 14; new to extra235"]
    - [singledispatch_qualname_len_14,
       singledispatch.__qualname__.__len__,
       [],
       14,
       "functools.singledispatch.__qualname__.__len__() == 14 — qualname 'singledispatch' has exactly 14 characters; __len__() returns 14; new to extra235"]

# ---------------------------------------------------------------------------
# Table 3: functools.cmp_to_key and functools.reduce C-extension identity
#
# functools.cmp_to_key.__name__ == 'cmp_to_key'
# functools.cmp_to_key.__module__ == '_functools'
# functools.cmp_to_key.__name__.__len__() == 10
# functools.reduce.__name__ == 'reduce'
# functools.reduce.__module__ == '_functools'
#
# New to extra235.
# ---------------------------------------------------------------------------

table functools_extra235.cmp_to_key_reduce_identity:
  description: "functools.cmp_to_key and reduce identity contracts: C-extension __name__ and __module__; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra235cmpredid

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_name_eq,
       cmp_to_key.__name__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__name__ == 'cmp_to_key' — cmp_to_key is a C-level function in Modules/_functoolsmodule.c; its __name__ is 'cmp_to_key'; __name__.__eq__('cmp_to_key') returns True; new to extra235"]
    - [cmp_to_key_module_eq,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in the C extension module _functools; __module__.__eq__('_functools') returns True; new to extra235"]
    - [cmp_to_key_name_len_10,
       cmp_to_key.__name__.__len__,
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' has exactly 10 characters (c-m-p-_-t-o-_-k-e-y); __len__() returns 10; new to extra235"]
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__ == 'reduce' — reduce is a C-level function in Modules/_functoolsmodule.c; its __name__ is 'reduce'; __name__.__eq__('reduce') returns True; new to extra235"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__ == '_functools' — reduce is implemented in the C extension module _functools; __module__.__eq__('_functools') returns True; new to extra235"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra235
# ---------------------------------------------------------------------------

invariant functools_extra235.total_ordering_name_eq:
  description: "functools.total_ordering.__name__ == 'total_ordering'; new to extra235"
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra235.total_ordering_qualname_eq:
  description: "functools.total_ordering.__qualname__ == 'total_ordering'; new to extra235"
  kind: python_call_eq
