  args: ["functools"]
  expected: true

invariant functools_extra235.total_ordering_name_len_14:
  description: "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has 14 characters; new to extra235"
  kind: python_call_eq
  function: total_ordering.__name__.__len__
  args: []
  expected: 14

