spec: collections_extra21
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra20.zspec.zsdl."
    - "collections_extra20 covers: __qualname__.__len__ for ChainMap/Counter/UserDict/UserList/UserString; __module__.__len__ table for all six; deque.__module__.__len__() extra20 anchor."
    - "collections_extra19 covers: deque.__bases__.__len__()==1; deque.__module__.__len__()==11; ChainMap.__module__.__len__()==11 re-anchor."
    - "collections_extra15 covers: deque.__qualname__.__len__()==5; deque.__module__.__eq__ ."
    - "No prior collections spec records deque([1,2,3]).__len__()==3 as a ZSDL invariant."
    - "No prior collections spec records deque.__bases__.__getitem__(0).__name__=='object' in the extra21 namespace."
    - "No prior collections spec records Counter('aabbc').__getitem__('a')==2/'b'==2/'c'==1 in the extra21 namespace."
    - "No prior collections spec records OrderedDict.__bases__.__getitem__(0).__name__=='dict' in the extra21 namespace."
    - "All five classes have __qualname__ equal to their unqualified name (no enclosing scope)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# deque behavioral: instance __len__
#
# deque([1,2,3]).__len__() == 3.
# No prior collections spec records this as a ZSDL invariant.
# ---------------------------------------------------------------------------

invariant collections_extra21.deque.len_three:
  description: "collections.deque([1,2,3]).__len__() == 3 — deque of three elements has length 3"
  category: behavioral
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: __len__
  expected: 3

# ---------------------------------------------------------------------------
# deque base class: deque.__bases__[0].__name__ == 'object'
#
# deque inherits directly from object. Accessed via __getitem__(0) on __bases__.
# No prior collections spec records this in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra21.deque.bases_first_name:
  description: "collections.deque.__bases__.__getitem__(0).__name__ == 'object' — deque's direct base class is object"
  category: class_hierarchy
  kind: python_call_eq
  function: deque.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Counter behavioral: character frequency in 'aabbc'
#
# Counter('aabbc') counts: a->2, b->2, c->1.
# Counter.__getitem__ provides element access by key.
# No prior collections spec records these three counts in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra21.Counter.aabbc_a:
  description: "collections.Counter('aabbc').__getitem__('a') == 2 — 'a' appears twice"
  category: behavioral
  kind: python_call_eq
  function: Counter
  args: ["aabbc"]
  method: __getitem__
  method_args: ["a"]
  expected: 2

invariant collections_extra21.Counter.aabbc_b:
  description: "collections.Counter('aabbc').__getitem__('b') == 2 — 'b' appears twice"
  category: behavioral
  kind: python_call_eq
  function: Counter
  args: ["aabbc"]
  method: __getitem__
  method_args: ["b"]
  expected: 2

invariant collections_extra21.Counter.aabbc_c:
  description: "collections.Counter('aabbc').__getitem__('c') == 1 — 'c' appears once"
  category: behavioral
  kind: python_call_eq
  function: Counter
  args: ["aabbc"]
  method: __getitem__
  method_args: ["c"]
  expected: 1

# ---------------------------------------------------------------------------
# OrderedDict base class: OrderedDict.__bases__[0].__name__ == 'dict'
#
# OrderedDict inherits from dict. Accessed via __getitem__(0) on __bases__.
# No prior collections spec records this in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra21.OrderedDict.bases_first_name:
  description: "collections.OrderedDict.__bases__.__getitem__(0).__name__ == 'dict' — OrderedDict's direct base class is dict"
  category: class_hierarchy
  kind: python_call_eq
  function: OrderedDict.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "dict"

# ---------------------------------------------------------------------------
# __qualname__ table — deque, Counter, OrderedDict, ChainMap, defaultdict
#
# collections_extra20 covers __qualname__.__len__ for Counter/ChainMap.
# collections_extra18 covers OrderedDict.__qualname__.__len__.
# collections_extra15 covers deque.__qualname__.__len__.
# No prior spec records __qualname__.__eq__ for these five in one table
# under the extra21 namespace.
# All five classes have __qualname__ equal to their simple name
# (no enclosing class scope).
# ---------------------------------------------------------------------------

table collections_extra21.qualnames:
  kind: python_call_eq
  category: qualname_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra21.qualnames.deque,
       deque.__qualname__.__eq__,
       ["deque"],
       true,
       "collections.deque.__qualname__ == 'deque'"]
    - [collections_extra21.qualnames.Counter,
       Counter.__qualname__.__eq__,
       ["Counter"],
       true,
       "collections.Counter.__qualname__ == 'Counter'"]
    - [collections_extra21.qualnames.OrderedDict,
       OrderedDict.__qualname__.__eq__,
       ["OrderedDict"],
       true,
       "collections.OrderedDict.__qualname__ == 'OrderedDict'"]
    - [collections_extra21.qualnames.ChainMap,
       ChainMap.__qualname__.__eq__,
       ["ChainMap"],
       true,
       "collections.ChainMap.__qualname__ == 'ChainMap'"]
    - [collections_extra21.qualnames.defaultdict,
       defaultdict.__qualname__.__eq__,
       ["defaultdict"],
       true,
       "collections.defaultdict.__qualname__ == 'defaultdict'"]
