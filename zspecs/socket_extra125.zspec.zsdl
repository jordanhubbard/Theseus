spec: socket_extra125
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra124.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/recv/close/setsockopt __qualname__.__eq__ string equality (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() (gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout) / socket.SocketIO class identity (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket method __qualname__.__len__() for connect/bind/listen/send/recv/__init__/accept/close/makefile and others (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6 class names / SOCK_STREAM/SOCK_DGRAM class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout/getaddrinfo/create_connection class names (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers socket.AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier socket specs."
    - "Wave 277 theme: socket.socket Python-level method __code__ attributes — co_name, co_argcount, co_varnames[0] for accept/__init__/close/makefile/detach/dup methods."
    - "socket.socket.accept.__code__.co_name == 'accept'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__code__.co_name == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__code__.co_name == 'close'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_name == 'makefile'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__code__.co_name == 'detach'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__code__.co_name == 'dup'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__code__.co_argcount == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_argcount == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra97 anchors __class__.__name__=='function' and __module__=='socket' for __init__/accept/makefile/close; this spec first anchors __code__ attributes (co_name, co_argcount, co_varnames[0]) for these and additional methods (detach, dup)."
    - "Note: makefile.__code__.co_argcount == 3 (self, mode, buffering) but co_kwonlyargcount == 3 as well (mode/buffering/encoding are keyword-only in practice). co_argcount counts positional-or-keyword args including self."
    - "Note: socket.socket.__init__.__code__.co_argcount == 5 reflects: self, family, type, proto, fileno — all positional-or-keyword. The socket class is named 'socket' (same as module), so methods use 'socket.' prefix in __qualname__."
    - "Note: detach and dup are Python-level function methods in Lib/socket.py not covered by prior socket specs for __code__ attributes. detach makes the socket non-closable on gc; dup creates a duplicate socket."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_name.__eq__('accept')
# socket.socket.__init__.__code__.co_name.__eq__('__init__')
# socket.socket.close.__code__.co_name.__eq__('close')
# socket.socket.makefile.__code__.co_name.__eq__('makefile')
# socket.socket.detach.__code__.co_name.__eq__('detach')
# socket.socket.dup.__code__.co_name.__eq__('dup')
#
# Wave 277 theme: socket.socket Python-level method code object co_name equality.
#
# co_name is the name of the function as written in the def statement in
# Lib/socket.py. For all six Python-level methods, co_name equals the method
# name. extra97 anchors __class__.__name__=='function' and __module__=='socket'
# for accept/__init__/makefile/close; no prior socket spec anchors co_name for
# any socket.socket method under sockcode125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra125.socket_socket_py_method_co_name:
  description: "socket.socket.accept/__code__.co_name.__eq__('accept')==True / __init__/__code__.co_name.__eq__('__init__')==True / close/__code__.co_name.__eq__('close')==True / makefile/__code__.co_name.__eq__('makefile')==True / detach/__code__.co_name.__eq__('detach')==True / dup/__code__.co_name.__eq__('dup')==True — co_name equals def statement name; all Python-level function methods from Lib/socket.py; extra97 anchors class name and module; first sockcode125 anchor for co_name equality"
  kind: python_call_eq
  category: code_attributes
  id_prefix: sockcode125

  columns: [id, function, args, expected, description]
  rows:
    - [accept_co_name,  "socket.__init__.__code__.co_name.__eq__",  ["__init__"],  true, "socket.socket.__init__.__code__.co_name is '__init__' (def statement name in Lib/socket.py)"]
    - [init_co_name,    "socket.accept.__code__.co_name.__eq__",    ["accept"],    true, "socket.socket.accept.__code__.co_name is 'accept' (Python-level method wrapping _socket.socket.accept)"]
    - [close_co_name,   "socket.close.__code__.co_name.__eq__",     ["close"],     true, "socket.socket.close.__code__.co_name is 'close' (Python-level close with _real_close() delegation)"]
    - [makefile_co_name,"socket.makefile.__code__.co_name.__eq__",  ["makefile"],  true, "socket.socket.makefile.__code__.co_name is 'makefile' (creates file-like wrapper over socket)"]
    - [detach_co_name,  "socket.detach.__code__.co_name.__eq__",    ["detach"],    true, "socket.socket.detach.__code__.co_name is 'detach' (detaches file descriptor from socket object)"]
    - [dup_co_name,     "socket.dup.__code__.co_name.__eq__",       ["dup"],       true, "socket.socket.dup.__code__.co_name is 'dup' (creates duplicate socket from dup(fd))"]

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_argcount.__eq__(1)
# socket.socket.__init__.__code__.co_argcount.__eq__(5)
# socket.socket.close.__code__.co_argcount.__eq__(1)
# socket.socket.makefile.__code__.co_argcount.__eq__(3)
# socket.socket.detach.__code__.co_argcount.__eq__(1)
# socket.socket.dup.__code__.co_argcount.__eq__(1)
#
# Wave 277 theme: socket.socket Python-level method code object co_argcount.
#
# co_argcount counts positional-or-keyword parameters including self.
# accept: 1 (self only; returns (conn, addr)). __init__: 5 (self, family, type,
# proto, fileno). close: 1 (self only). makefile: 3 (self, mode, buffering —
# note: additional keyword-only args exist counted separately in co_kwonlyargcount).
# detach: 1 (self only). dup: 1 (self only). No prior socket spec anchors co_argcount
# for any socket.socket method under sockcode125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra125.socket_socket_py_method_co_argcount:
  description: "socket.socket.accept/__code__.co_argcount.__eq__(1)==True / __init__/__code__.co_argcount.__eq__(5)==True / close/__code__.co_argcount.__eq__(1)==True / makefile/__code__.co_argcount.__eq__(3)==True / detach/__code__.co_argcount.__eq__(1)==True / dup/__code__.co_argcount.__eq__(1)==True — accept/close/detach/dup are single-arg (self only); __init__ has 5 (self+family+type+proto+fileno); makefile has 3 (self+mode+buffering); no prior socket spec anchors co_argcount; first sockcode125 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: sockcode125

  columns: [id, function, args, expected, description]
  rows:
    - [init_co_argcount,    "socket.__init__.__code__.co_argcount.__eq__",  [5], true, "socket.__init__ has 5 positional-or-keyword args: self, family, type, proto, fileno"]
    - [accept_co_argcount,  "socket.accept.__code__.co_argcount.__eq__",    [1], true, "socket.accept has 1 positional-or-keyword arg: self (returns (conn, addr) pair)"]
    - [close_co_argcount,   "socket.close.__code__.co_argcount.__eq__",     [1], true, "socket.close has 1 positional-or-keyword arg: self (delegates to _real_close())"]
    - [makefile_co_argcount,"socket.makefile.__code__.co_argcount.__eq__",  [3], true, "socket.makefile has 3 positional-or-keyword args: self, mode, buffering (plus keyword-only args)"]
    - [detach_co_argcount,  "socket.detach.__code__.co_argcount.__eq__",    [1], true, "socket.detach has 1 positional-or-keyword arg: self (makes fd non-closeable by gc)"]
    - [dup_co_argcount,     "socket.dup.__code__.co_argcount.__eq__",       [1], true, "socket.dup has 1 positional-or-keyword arg: self (duplicates socket via dup(fd))"]

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_varnames[0].__eq__('self')
# socket.socket.__init__.__code__.co_varnames[0].__eq__('self')
# socket.socket.close.__code__.co_varnames[0].__eq__('self')
# socket.socket.makefile.__code__.co_varnames[0].__eq__('self')
# socket.socket.detach.__code__.co_varnames[0].__eq__('self')
# socket.socket.dup.__code__.co_varnames[0].__eq__('self')
#
# Wave 277 theme: socket.socket Python-level method co_varnames[0] == 'self'.
#
# co_varnames is the tuple of all local variable names (arguments first, then
# locals). co_varnames[0] is the first argument name for instance methods.
# All six Python-level socket.socket methods have 'self' as their first argument,
# confirming they are instance methods defined in Lib/socket.py. No prior socket
# spec anchors co_varnames[0] for any socket.socket method under sockcode125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra125.socket_socket_py_method_co_varnames0:
  description: "socket.socket.accept/__code__.co_varnames[0].__eq__('self')==True / __init__/__code__.co_varnames[0].__eq__('self')==True / close/__code__.co_varnames[0].__eq__('self')==True / makefile/__code__.co_varnames[0].__eq__('self')==True / detach/__code__.co_varnames[0].__eq__('self')==True / dup/__code__.co_varnames[0].__eq__('self')==True — all Python-level socket.socket instance methods have 'self' as first arg; no prior socket spec anchors co_varnames[0]; first sockcode125 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: sockcode125

  columns: [id, function, args, expected, description]
  rows:
    - [accept_varnames0,  "socket.accept.__code__.co_varnames[0].__eq__",   ["self"], true, "socket.accept first arg is 'self' (instance method in Lib/socket.py)"]
    - [init_varnames0,    "socket.__init__.__code__.co_varnames[0].__eq__",  ["self"], true, "socket.__init__ first arg is 'self' (instance method; subsequent args: family, type, proto, fileno)"]
    - [close_varnames0,   "socket.close.__code__.co_varnames[0].__eq__",    ["self"], true, "socket.close first arg is 'self' (instance method in Lib/socket.py)"]
    - [makefile_varnames0,"socket.makefile.__code__.co_varnames[0].__eq__", ["self"], true, "socket.makefile first arg is 'self' (instance method; subsequent args: mode, buffering, plus keyword-only)"]
    - [detach_varnames0,  "socket.detach.__code__.co_varnames[0].__eq__",   ["self"], true, "socket.detach first arg is 'self' (instance method in Lib/socket.py)"]
    - [dup_varnames0,     "socket.dup.__code__.co_varnames[0].__eq__",      ["self"], true, "socket.dup first arg is 'self' (instance method; creates new socket from dup(fd))"]

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_name.__eq__('accept') — standalone
#
# socket.socket.accept.__code__.co_name is 'accept'. accept is a Python-level
# function in Lib/socket.py that calls the underlying C-level _socket.socket.accept()
# and wraps the returned C socket in a Python socket.socket instance. The co_name
# attribute of the code object equals the function name as written in the def
# statement. extra97 anchors accept.__class__.__name__=='function'; no prior
# socket spec anchors accept.__code__.co_name as a standalone under sockcode125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra125.accept_co_name_eq:
  description: "socket.socket.accept.__code__.co_name.__eq__('accept') == True — accept is a Python-level wrapper in Lib/socket.py calling _socket.socket.accept() and wrapping result in socket.socket; co_name equals the def statement name; extra97 anchors class name; first standalone for accept co_name under sockcode125"
  category: code_attributes
  kind: python_call_eq
  function: "socket.accept.__code__.co_name.__eq__"
  args: ["accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__init__.__code__.co_argcount.__eq__(5) — standalone
#
# socket.socket.__init__.__code__.co_argcount is 5. socket.socket.__init__
# accepts: self, family (default AF_INET), type (default SOCK_STREAM),
# proto (default 0), fileno (default None). All five are positional-or-keyword
# parameters. co_argcount does not count keyword-only args or variadic args.
# extra97 anchors __init__.__class__.__name__=='function'; no prior socket spec
# anchors __init__.__code__.co_argcount as a standalone under sockcode125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra125.init_co_argcount_5:
  description: "socket.socket.__init__.__code__.co_argcount.__eq__(5) == True — socket.__init__ has 5 positional-or-keyword args: self, family, type, proto, fileno (all optional except self); co_argcount does not count keyword-only args; extra97 anchors __class__.__name__=='function'; first standalone for __init__ co_argcount under sockcode125"
  category: code_attributes
  kind: python_call_eq
  function: "socket.__init__.__code__.co_argcount.__eq__"
  args: [5]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.close.__code__.co_name.__eq__('close') — standalone
#
# socket.socket.close.__code__.co_name is 'close'. socket.socket.close is
# a Python-level function in Lib/socket.py. It is NOT the same as the C-level
# close method on _socket.socket. The Python close marks the socket as closed
# and calls the internal _real_close() which performs the actual C-level close.
# extra97 anchors close.__class__.__name__=='function'; no prior socket spec
# anchors close.__code__.co_name as a standalone under sockcode125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra125.close_co_name_eq:
  description: "socket.socket.close.__code__.co_name.__eq__('close') == True — socket.close is a Python-level wrapper in Lib/socket.py; marks socket as closed and calls _real_close() for C-level close; extra97 anchors __class__.__name__=='function'; first standalone for close co_name under sockcode125"
  category: code_attributes
  kind: python_call_eq
  function: "socket.close.__code__.co_name.__eq__"
  args: ["close"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.makefile.__code__.co_argcount.__eq__(3) — standalone
#
# socket.socket.makefile.__code__.co_argcount is 3. makefile has positional-or-keyword
# arguments: self, mode (default 'rb'), buffering (default None). Note that
# makefile also has co_kwonlyargcount == 3 (additional keyword-only arguments:
# encoding, errors, newline). co_argcount counts only positional-or-keyword args.
# makefile creates a file-like object associated with the socket, wrapping it
# in a BufferedReader, BufferedWriter, or TextIOWrapper. extra97 anchors
# makefile.__class__.__name__=='function'; no prior socket spec anchors
# makefile co_argcount as a standalone under sockcode125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra125.makefile_co_argcount_3:
  description: "socket.socket.makefile.__code__.co_argcount.__eq__(3) == True — makefile has 3 positional-or-keyword args: self, mode, buffering; also has 3 keyword-only args (encoding, errors, newline) counted separately in co_kwonlyargcount; creates file-like wrapper (BufferedReader/Writer or TextIOWrapper); extra97 anchors __class__.__name__=='function'; first standalone under sockcode125"
  category: code_attributes
  kind: python_call_eq
  function: "socket.makefile.__code__.co_argcount.__eq__"
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.detach.__code__.co_name.__eq__('detach') — standalone
#
# socket.socket.detach.__code__.co_name is 'detach'. socket.socket.detach is a
# Python-level method in Lib/socket.py. It detaches the file descriptor from the
# socket object by setting the socket's internal fd to -1 and returning the
# original fd. After detach(), the socket object is marked as closed but the
# underlying file descriptor remains open and can be used directly or wrapped
# in another socket. No prior socket spec anchors detach.__code__ attributes
# as a standalone under sockcode125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra125.detach_co_name_eq:
  description: "socket.socket.detach.__code__.co_name.__eq__('detach') == True — detach is a Python-level method in Lib/socket.py; sets internal fd to -1 and returns original fd; socket becomes closed but fd remains open; no prior socket spec anchors detach co_name as standalone; first standalone under sockcode125"
  category: code_attributes
  kind: python_call_eq
  function: "socket.detach.__code__.co_name.__eq__"
  args: ["detach"]
  expected: true

