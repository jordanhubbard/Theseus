spec: unflatten
version: ">=1.0.4"
backend: node(unflatten)

docs: https://www.npmjs.com/package/unflatten

provenance:
  derived_from:
    - "unflatten README — https://www.npmjs.com/package/unflatten"
    - "Test vectors verified with unflatten via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "unflatten source"
  notes:
    - "unflatten is an npm package. Install: npm install unflatten"
    - "Converts a flat object with dot-separated keys into a nested object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a nested object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table unflatten.unflatten:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: unflat

  columns: [id, args, expected]
  rows:
    - [two_level,   [{"a.b": 1, "a.c": 2}],  {"a": {"b": 1, "c": 2}}]
    - [three_level, [{"x.y.z": 42}],          {"x": {"y": {"z": 42}}}]
    - [flat,        [{"a": 1}],               {"a": 1}]
