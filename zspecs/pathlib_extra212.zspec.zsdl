spec: pathlib_extra212
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: __defaults__ attributes of pathlib.Path method __init__ methods."
    - "pathlib.Path.with_name.__defaults__ == None — with_name takes exactly one required positional argument (name); no defaults. __defaults__.__class__.__name__ == 'NoneType'."
    - "pathlib.Path.with_suffix.__defaults__ == None — with_suffix takes exactly one required positional argument (suffix); no defaults. __defaults__.__class__.__name__ == 'NoneType'."
    - "pathlib.Path.open.__defaults__ == ('r', -1, None, None, None) — five defaults: mode='r', buffering=-1, encoding=None, errors=None, newline=None. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 5."
    - "pathlib.Path.__init__.__defaults__ == None — Path.__init__ uses *args syntax with no defaults. __defaults__.__class__.__name__ == 'NoneType'."
    - "pathlib.Path.resolve.__defaults__ == (False,) — one default: strict=False. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "pathlib.Path.touch.__defaults__ == (438, True) — two defaults: mode=438 (0o666) and exist_ok=True. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 2."
    - "pathlib.Path.mkdir.__defaults__ == (511, False, False) — three defaults: mode=511 (0o777), parents=False, exist_ok=False. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.with_name and with_suffix __defaults__ — NoneType
#
# pathlib.Path.with_name takes one required argument: name (str)
#   __defaults__ == None  →  __class__.__name__ == 'NoneType'
# pathlib.Path.with_suffix takes one required argument: suffix (str)
#   __defaults__ == None  →  __class__.__name__ == 'NoneType'
# pathlib.Path.__init__ uses *args; no defaults.
#   __defaults__ == None  →  __class__.__name__ == 'NoneType'
# ---------------------------------------------------------------------------

table pathlib_extra212.Path_no_defaults_methods:
  description: "pathlib.Path methods with __defaults__ == None: with_name, with_suffix, __init__ all take required args with no defaults; __defaults__.__class__.__name__ == 'NoneType'; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: pathlibdefaults212

  columns: [id, function, args, expected, description]
  rows:
    - [with_name_defs_cls,   Path.with_name.__defaults__.__class__.__name__.__eq__,   ["NoneType"], true,  "pathlib.Path.with_name.__defaults__.__class__.__name__ == 'NoneType' — with_name takes exactly one required arg; no defaults; verified Python 3.14.3"]
    - [with_suffix_defs_cls, Path.with_suffix.__defaults__.__class__.__name__.__eq__, ["NoneType"], true,  "pathlib.Path.with_suffix.__defaults__.__class__.__name__ == 'NoneType' — with_suffix takes exactly one required arg; no defaults; verified Python 3.14.3"]
    - [init_defs_cls,        Path.__init__.__defaults__.__class__.__name__.__eq__,    ["NoneType"], true,  "pathlib.Path.__init__.__defaults__.__class__.__name__ == 'NoneType' — Path.__init__ uses *args; no defaults; verified Python 3.14.3"]
    - [with_name_not_tuple,  Path.with_name.__defaults__.__class__.__name__.__eq__,   ["tuple"],    false, "pathlib.Path.with_name.__defaults__.__class__.__name__ != 'tuple' — with_name has no default args; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# pathlib.Path.open.__defaults__ — class name and length
#
# pathlib.Path.open mirrors the builtin open() signature:
#   def open(self, mode='r', buffering=-1, encoding=None, errors=None, newline=None)
# __defaults__ == ('r', -1, None, None, None)  — length 5
# __defaults__.__class__.__name__ == 'tuple'
# __defaults__.__len__() == 5
# ---------------------------------------------------------------------------

table pathlib_extra212.Path_open_defaults:
  description: "pathlib.Path.open.__defaults__ class name and length — defaults ('r', -1, None, None, None) for mode/buffering/encoding/errors/newline; __class__.__name__=='tuple'; __len__()==5; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: pathlibdefaults212

  columns: [id, function, args, expected, description]
  rows:
    - [open_defs_cls,     Path.open.__defaults__.__class__.__name__.__eq__, ["tuple"],    true,  "pathlib.Path.open.__defaults__.__class__.__name__ == 'tuple' — five defaults: mode='r', buffering=-1, encoding=None, errors=None, newline=None; verified Python 3.14.3"]
    - [open_defs_len,     Path.open.__defaults__.__len__,                   [],           5,     "pathlib.Path.open.__defaults__.__len__() == 5 — mirrors open() signature with five optional params; verified Python 3.14.3"]
    - [open_not_nonetype, Path.open.__defaults__.__class__.__name__.__eq__, ["NoneType"], false, "pathlib.Path.open.__defaults__.__class__.__name__ != 'NoneType' — open() has five defaults unlike with_name/with_suffix; verified Python 3.14.3"]
    - [open_not_len_1,    Path.open.__defaults__.__len__,                   [],           5,     "pathlib.Path.open.__defaults__.__len__() == 5 (not 1 or 2); largest __defaults__ tuple among checked Path methods; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# pathlib.Path.resolve, touch, mkdir __defaults__ — class name and length
#
# resolve: strict=False  →  __defaults__ == (False,), len == 1
# touch: mode=438, exist_ok=True  →  __defaults__ == (438, True), len == 2
# mkdir: mode=511, parents=False, exist_ok=False  →  __defaults__ == (511, False, False), len == 3
# ---------------------------------------------------------------------------

table pathlib_extra212.Path_filesystem_defaults:
  description: "pathlib.Path filesystem methods __defaults__: resolve len=1, touch len=2, mkdir len=3; all __class__.__name__=='tuple'; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: pathlibdefaults212

  columns: [id, function, args, expected, description]
  rows:
    - [resolve_defs_cls,  Path.resolve.__defaults__.__class__.__name__.__eq__, ["tuple"], true, "pathlib.Path.resolve.__defaults__.__class__.__name__ == 'tuple' — one default: strict=False; verified Python 3.14.3"]
    - [resolve_defs_len,  Path.resolve.__defaults__.__len__,                   [],        1,    "pathlib.Path.resolve.__defaults__.__len__() == 1 — single default: strict=False; verified Python 3.14.3"]
    - [touch_defs_cls,    Path.touch.__defaults__.__class__.__name__.__eq__,   ["tuple"], true, "pathlib.Path.touch.__defaults__.__class__.__name__ == 'tuple' — two defaults: mode=438 (0o666) and exist_ok=True; verified Python 3.14.3"]
    - [touch_defs_len,    Path.touch.__defaults__.__len__,                     [],        2,    "pathlib.Path.touch.__defaults__.__len__() == 2 — defaults: mode=438 (0o666), exist_ok=True; verified Python 3.14.3"]
    - [mkdir_defs_cls,    Path.mkdir.__defaults__.__class__.__name__.__eq__,   ["tuple"], true, "pathlib.Path.mkdir.__defaults__.__class__.__name__ == 'tuple' — three defaults: mode=511 (0o777), parents=False, exist_ok=False; verified Python 3.14.3"]
    - [mkdir_defs_len,    Path.mkdir.__defaults__.__len__,                     [],        3,    "pathlib.Path.mkdir.__defaults__.__len__() == 3 — defaults: mode=511, parents=False, exist_ok=False; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlib_extra212
# ---------------------------------------------------------------------------

invariant pathlib_extra212.Path_with_name_defaults_NoneType:
  description: "pathlib.Path.with_name.__defaults__.__class__.__name__ == 'NoneType' — with_name(name) takes exactly one required positional argument; Python sets __defaults__ to None when a function has no default values; None.__class__.__name__ == 'NoneType'; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Path.with_name.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant pathlib_extra212.Path_with_suffix_defaults_NoneType:
  description: "pathlib.Path.with_suffix.__defaults__.__class__.__name__ == 'NoneType' — with_suffix(suffix) takes exactly one required positional argument; Python sets __defaults__ to None when a function has no default values; None.__class__.__name__ == 'NoneType'; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Path.with_suffix.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant pathlib_extra212.Path_open_defaults_class_name:
  description: "pathlib.Path.open.__defaults__.__class__.__name__ == 'tuple' — Path.open mirrors builtin open() with five defaults: mode='r', buffering=-1, encoding=None, errors=None, newline=None; __defaults__.__class__.__name__ == 'tuple'; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Path.open.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant pathlib_extra212.Path_open_defaults_len_5:
  description: "pathlib.Path.open.__defaults__.__len__() == 5 — five defaults for mode, buffering, encoding, errors, newline; the largest __defaults__ tuple among checked Path methods; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Path.open.__defaults__.__len__
  args: []
  expected: 5

invariant pathlib_extra212.Path_init_defaults_NoneType:
  description: "pathlib.Path.__init__.__defaults__.__class__.__name__ == 'NoneType' — Path.__init__ uses *args with no default values; Python sets __defaults__ to None; None.__class__.__name__ == 'NoneType'; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Path.__init__.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant pathlib_extra212.Path_resolve_defaults_len_1:
  description: "pathlib.Path.resolve.__defaults__.__len__() == 1 — single default: strict=False; resolve(strict=False) makes strict mode opt-in; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Path.resolve.__defaults__.__len__
  args: []
  expected: 1

invariant pathlib_extra212.Path_touch_defaults_len_2:
  description: "pathlib.Path.touch.__defaults__.__len__() == 2 — two defaults: mode=438 (octal 0o666) and exist_ok=True; 438 is the integer representation of octal 0o666 (rw-rw-rw-); verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Path.touch.__defaults__.__len__
  args: []
  expected: 2

invariant pathlib_extra212.Path_mkdir_defaults_len_3:
  description: "pathlib.Path.mkdir.__defaults__.__len__() == 3 — three defaults: mode=511 (octal 0o777), parents=False, exist_ok=False; 511 is the integer representation of octal 0o777 (rwxrwxrwx); verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: Path.mkdir.__defaults__.__len__
  args: []
  expected: 3
