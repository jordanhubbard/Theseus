spec: concurrent_futures_extra231
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.wait.__name__ == 'wait' — 4 characters; qualname is 'wait'; module is 'concurrent.futures._base'; verified with Python 3.14.3."
    - "concurrent.futures.as_completed.__name__ == 'as_completed' — 12 characters; qualname is 'as_completed'; module is 'concurrent.futures._base'; verified with Python 3.14.3."
    - "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' — 15 characters; a str constant; verified with Python 3.14.3."
    - "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION' — 15 characters; a str constant; verified with Python 3.14.3."
    - "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED' — 13 characters; a str constant; verified with Python 3.14.3."
    - "All three wait-return constants are uppercase strings (isupper() == True); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.wait and as_completed function name contracts — extra231 namespace
#
# wait.__name__ == 'wait' (4 chars); qualname == 'wait'.
# as_completed.__name__ == 'as_completed' (12 chars); qualname == 'as_completed'.
# Both live in module 'concurrent.futures._base'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra231.wait_as_completed_names:
  description: "concurrent.futures.wait and as_completed function name contracts in cf231wac namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf231wac

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,           wait.__name__.__eq__,              ["wait"],             true, "concurrent.futures.wait.__name__ == 'wait'; verified with Python 3.14.3"]
    - [wait_name_len_4,        wait.__name__.__len__,             [],                   4,    "concurrent.futures.wait.__name__.__len__() == 4 — 'wait' has 4 characters; verified with Python 3.14.3"]
    - [wait_qualname_eq,       wait.__qualname__.__eq__,          ["wait"],             true, "concurrent.futures.wait.__qualname__ == 'wait' — module-level function; verified with Python 3.14.3"]
    - [ac_name_eq,             as_completed.__name__.__eq__,      ["as_completed"],     true, "concurrent.futures.as_completed.__name__ == 'as_completed'; verified with Python 3.14.3"]
    - [ac_name_len_12,         as_completed.__name__.__len__,     [],                   12,   "concurrent.futures.as_completed.__name__.__len__() == 12 — 'as_completed' has 12 characters; verified with Python 3.14.3"]
    - [ac_qualname_eq,         as_completed.__qualname__.__eq__,  ["as_completed"],     true, "concurrent.futures.as_completed.__qualname__ == 'as_completed' — module-level function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures wait-return constants — extra231 namespace
#
# FIRST_COMPLETED == 'FIRST_COMPLETED' (15 chars, starts with 'FIRST').
# FIRST_EXCEPTION == 'FIRST_EXCEPTION' (15 chars, starts with 'FIRST').
# ALL_COMPLETED == 'ALL_COMPLETED' (13 chars, starts with 'ALL').
# All three are str instances with isupper() == True.
# ---------------------------------------------------------------------------

table concurrent_futures_extra231.wait_return_constants:
  description: "concurrent.futures wait-return constant value and type contracts in cf231wrc namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf231wrc

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_eq,     FIRST_COMPLETED.__eq__,            ["FIRST_COMPLETED"],  true, "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED'; verified with Python 3.14.3"]
    - [first_completed_len_15, FIRST_COMPLETED.__len__,           [],                   15,   "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — 'FIRST_COMPLETED' has 15 characters; verified with Python 3.14.3"]
    - [first_completed_isupper, FIRST_COMPLETED.isupper,          [],                   true, "concurrent.futures.FIRST_COMPLETED.isupper() == True — all uppercase; verified with Python 3.14.3"]
    - [first_exception_eq,     FIRST_EXCEPTION.__eq__,            ["FIRST_EXCEPTION"],  true, "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION'; verified with Python 3.14.3"]
    - [first_exception_len_15, FIRST_EXCEPTION.__len__,           [],                   15,   "concurrent.futures.FIRST_EXCEPTION.__len__() == 15 — 'FIRST_EXCEPTION' has 15 characters; verified with Python 3.14.3"]
    - [first_exception_isupper, FIRST_EXCEPTION.isupper,          [],                   true, "concurrent.futures.FIRST_EXCEPTION.isupper() == True — all uppercase; verified with Python 3.14.3"]
    - [all_completed_eq,       ALL_COMPLETED.__eq__,              ["ALL_COMPLETED"],     true, "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED'; verified with Python 3.14.3"]
    - [all_completed_len_13,   ALL_COMPLETED.__len__,             [],                   13,   "concurrent.futures.ALL_COMPLETED.__len__() == 13 — 'ALL_COMPLETED' has 13 characters; verified with Python 3.14.3"]
    - [all_completed_isupper,  ALL_COMPLETED.isupper,             [],                   true, "concurrent.futures.ALL_COMPLETED.isupper() == True — all uppercase; verified with Python 3.14.3"]
