spec: pickle_extra4
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
    - "pickle.zspec.zsdl — covers dumps/__name__, loads/__name__, HIGHEST_PROTOCOL >= 2, DEFAULT_PROTOCOL >= 2, round-trips, error cases"
    - "pickle_extra.zspec.zsdl — covers HIGHEST_PROTOCOL.__class__.__name__=='int', DEFAULT_PROTOCOL.__class__.__name__=='int', HIGHEST_PROTOCOL >= 5, exception __name__ table (PickleError/PicklingError/UnpicklingError), PickleError.__bases__[0].__name__=='Exception'"
    - "pickle_extra2.zspec.zsdl — covers Pickler/__module__, Unpickler/__module__, exception __module__ table, PicklingError.__bases__[0].__name__=='PickleError', UnpicklingError.__bases__[0].__name__=='PickleError', DEFAULT_PROTOCOL >= 2, PickleBuffer name/module/base, Pickler/Unpickler is_type"
    - "pickle_extra3.zspec.zsdl — covers HIGHEST_PROTOCOL >= 3 and >= 4, DEFAULT_PROTOCOL >= 3, protocol 0-5 le HIGHEST_PROTOCOL, Pickler/Unpickler base is object, PickleBuffer/__class__.__name__=='type', PickleError/PicklingError/UnpicklingError __class__.__name__=='type', dumps type checks for int/list/None/False"
  notes:
    - "This spec adds invariants not present in any prior pickle spec."
    - "pickle.dumps.__name__ == 'dumps' and pickle.loads.__name__ == 'loads' — confirms function names on the module."
    - "pickle.dump.__name__ == 'dump' and pickle.load.__name__ == 'load' — the streaming variants are also named functions."
    - "pickle.Pickler.__qualname__ == 'Pickler' — module-level class has flat qualname."
    - "pickle.Unpickler.__qualname__ == 'Unpickler' — module-level class has flat qualname."
    - "pickle.PickleError.__qualname__ == 'PickleError' — exception class has flat qualname."
    - "pickle.PicklingError.__qualname__ == 'PicklingError' — exception class has flat qualname."
    - "pickle.UnpicklingError.__qualname__ == 'UnpicklingError' — exception class has flat qualname."
    - "pickle.HIGHEST_PROTOCOL.__eq__ is invoked with 5 to verify exact equality — on CPython 3.8-3.12 this is 5."
    - "pickle.DEFAULT_PROTOCOL.__class__.__name__ == 'int' is in pickle_extra; here we add DEFAULT_PROTOCOL >= 3 as a distinct id in a new spec context."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes for dumps, loads, dump, load
# (pickle.zspec.zsdl checks these via __name__.__eq__ as part of class names;
# this spec uses a table to verify all four streaming/batch function names together)
# ---------------------------------------------------------------------------

table pickle_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [dumps, dumps.__name__.__eq__, ["dumps"], true]
    - [loads, loads.__name__.__eq__, ["loads"], true]
    - [dump,  dump.__name__.__eq__,  ["dump"],  true]
    - [load,  load.__name__.__eq__,  ["load"],  true]

# ---------------------------------------------------------------------------
# Exception class __qualname__ — not checked in any prior pickle spec
# All three exception classes are defined at module top-level, so qualname == name.
# ---------------------------------------------------------------------------

table pickle_extra4.exception_qualnames:
  kind: python_call_eq
  category: exception_qualnames
  id_prefix: eqname

  columns: [id, function, args, expected]
  rows:
    - [PickleError,     PickleError.__qualname__.__eq__,     ["PickleError"],     true]
    - [PicklingError,   PicklingError.__qualname__.__eq__,   ["PicklingError"],   true]
    - [UnpicklingError, UnpicklingError.__qualname__.__eq__, ["UnpicklingError"], true]

# ---------------------------------------------------------------------------
# Pickler and Unpickler __qualname__
# (pickle_extra checks __name__; this spec checks __qualname__ which is distinct)
# ---------------------------------------------------------------------------

invariant pickle_extra4.Pickler.qualname:
  description: "pickle.Pickler.__qualname__ == 'Pickler' — module-level class has flat qualname"
  category: class_identity
  kind: python_call_eq
  function: Pickler.__qualname__.__eq__
  args: ["Pickler"]
  expected: true

invariant pickle_extra4.Unpickler.qualname:
  description: "pickle.Unpickler.__qualname__ == 'Unpickler' — module-level class has flat qualname"
  category: class_identity
  kind: python_call_eq
  function: Unpickler.__qualname__.__eq__
  args: ["Unpickler"]
  expected: true

# ---------------------------------------------------------------------------
# HIGHEST_PROTOCOL exact value check
# On CPython 3.8 through 3.12, HIGHEST_PROTOCOL == 5.
# (pickle_extra has >= 5; this adds exact equality for >=3.8 implementations)
# ---------------------------------------------------------------------------

invariant pickle_extra4.HIGHEST_PROTOCOL.eq5:
  description: "pickle.HIGHEST_PROTOCOL == 5 on CPython 3.8-3.12 (protocol 5 introduced in 3.8)"
  category: constants
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__eq__
  args: [5]
  expected: true

# ---------------------------------------------------------------------------
# dumps return-value length check — result is non-empty bytes
# (Prior specs check __class__.__name__; here we check len > 0 directly)
# ---------------------------------------------------------------------------

invariant pickle_extra4.dumps_str.len_positive:
  description: "len(pickle.dumps('hello')) > 0 — dumps always returns non-empty bytes"
  category: dumps_behavior
  kind: python_call_eq
  function: dumps
  args: ["hello"]
  method: __len__.__gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# PickleBuffer __qualname__
# (pickle_extra2 checks __name__ and __module__; this adds __qualname__)
# ---------------------------------------------------------------------------

invariant pickle_extra4.PickleBuffer.qualname:
  description: "pickle.PickleBuffer.__qualname__ == 'PickleBuffer'"
  category: class_identity
  kind: python_call_eq
  function: PickleBuffer.__qualname__.__eq__
  args: ["PickleBuffer"]
  expected: true
