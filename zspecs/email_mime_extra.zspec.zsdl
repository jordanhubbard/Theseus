spec: email_mime_extra
version: ">=3.0"
backend: python_module(email.mime.multipart)

docs: https://docs.python.org/3/library/email.mime.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.mime.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "email.mime source: Lib/email/mime/ (PSF; source inspection permitted)"
  not_derived_from:
    - "email.mime source: internal encoding and generation internals"
  notes:
    - "This spec covers MIMEMultipart, MIMEText, and MIMEBase — none of which appear in email_message.zspec.zsdl."
    - "MIMEMultipart lives in email.mime.multipart; MIMEText in email.mime.text; MIMEBase in email.mime.base."
    - "MIMEBase inherits from email.mime.base.MIMEBase which inherits from email.message.Message."
    - "MIMEText inherits from email.mime.nonmultipart.MIMENonMultipart."
    - "MIMEMultipart inherits from email.mime.base.MIMEBase."
    - "MIMEMultipart() default _subtype is 'mixed'."
    - "MIMEText(text) wraps a plain-text string into a MIME part."
    - "MIMEText('hello').get_content_type() == 'text/plain' by default."
    - "MIMEMultipart().get_content_type() == 'multipart/mixed' by default."
    - "MIMEBase('application', 'octet-stream').get_content_type() == 'application/octet-stream'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table email_mime_extra.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [MIMEMultipart, MIMEMultipart.__name__.__eq__, ["MIMEMultipart"], true]
    - [MIMEText,      MIMEText.__name__.__eq__,      ["MIMEText"],      true]
    - [MIMEBase,      MIMEBase.__name__.__eq__,       ["MIMEBase"],      true]

# ---------------------------------------------------------------------------
# Module checks
# ---------------------------------------------------------------------------

table email_mime_extra.module_checks:
  kind: python_call_eq
  category: modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [MIMEMultipart_mod, MIMEMultipart.__module__.__eq__, ["email.mime.multipart"], true]
    - [MIMEText_mod,      MIMEText.__module__.__eq__,      ["email.mime.text"],      true]
    - [MIMEBase_mod,      MIMEBase.__module__.__eq__,       ["email.mime.base"],      true]

# ---------------------------------------------------------------------------
# Class inheritance checks
# ---------------------------------------------------------------------------

invariant email_mime_extra.MIMEText_base:
  description: "MIMEText.__bases__[0].__name__ == 'MIMENonMultipart'"
  category: hierarchy
  kind: python_call_eq
  function: MIMEText.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "MIMENonMultipart"

invariant email_mime_extra.MIMEMultipart_base:
  description: "MIMEMultipart.__bases__[0].__name__ == 'MIMEBase'"
  category: hierarchy
  kind: python_call_eq
  function: MIMEMultipart.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "MIMEBase"

invariant email_mime_extra.MIMEBase_base:
  description: "MIMEBase.__bases__[0].__name__ == 'Message'"
  category: hierarchy
  kind: python_call_eq
  function: MIMEBase.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Message"

# ---------------------------------------------------------------------------
# MIMEMultipart() — default content type
# ---------------------------------------------------------------------------

invariant email_mime_extra.MIMEMultipart_default_content_type:
  description: "MIMEMultipart().get_content_type() == 'multipart/mixed'"
  category: MIMEMultipart
  kind: python_call_eq
  function: MIMEMultipart
  args: []
  method: get_content_type
  method_args: []
  expected: "multipart/mixed"

invariant email_mime_extra.MIMEMultipart_is_multipart:
  description: "MIMEMultipart().is_multipart() == True"
  category: MIMEMultipart
  kind: python_call_eq
  function: MIMEMultipart
  args: []
  method: is_multipart
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# MIMEText — default content type and charset
# ---------------------------------------------------------------------------

invariant email_mime_extra.MIMEText_default_content_type:
  description: "MIMEText('hello').get_content_type() == 'text/plain'"
  category: MIMEText
  kind: python_call_eq
  function: MIMEText
  args: ["hello"]
  method: get_content_type
  method_args: []
  expected: "text/plain"

invariant email_mime_extra.MIMEText_not_multipart:
  description: "MIMEText('hello').is_multipart() == False"
  category: MIMEText
  kind: python_call_eq
  function: MIMEText
  args: ["hello"]
  method: is_multipart
  method_args: []
  expected: false

# ---------------------------------------------------------------------------
# MIMEBase — explicit maintype/subtype
# ---------------------------------------------------------------------------

invariant email_mime_extra.MIMEBase_content_type:
  description: "MIMEBase('application', 'octet-stream').get_content_type() == 'application/octet-stream'"
  category: MIMEBase
  kind: python_call_eq
  function: MIMEBase
  args: ["application", "octet-stream"]
  method: get_content_type
  method_args: []
  expected: "application/octet-stream"

invariant email_mime_extra.MIMEBase_maintype:
  description: "MIMEBase('image', 'png').get_content_maintype() == 'image'"
  category: MIMEBase
  kind: python_call_eq
  function: MIMEBase
  args: ["image", "png"]
  method: get_content_maintype
  method_args: []
  expected: "image"
