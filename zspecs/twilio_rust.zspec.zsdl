spec: twilio_rust
version: ">=3.9"
backend: rust_module(twilio_rust)

docs: https://www.twilio.com/docs/libraries/python

provenance:
  derived_from:
    - "https://www.twilio.com/docs/libraries/python — twilio-python"
  notes:
    - "twilio provides Twilio SMS/voice API integration."
    - "twilio.rest.Client is a class."
    - "twilio.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant twilio_rust.has_rest_client:
  description: "twilio.rest.Client is a class"
  category: presence
  kind: python_call_eq
  function: twilio_has_rest_client
  args: []
  expected: true

invariant twilio_rust.has_base_client:
  description: "twilio.base.Client is accessible"
  category: presence
  kind: python_call_eq
  function: twilio_has_base_client
  args: []
  expected: true

invariant twilio_rust.version_nonempty:
  description: "twilio.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: twilio_version_nonempty
  args: []
  expected: true

