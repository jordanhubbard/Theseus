spec: http_proxy_agent
version: ">=7.0.0"
backend: node(http-proxy-agent)

docs: https://github.com/TooTallNate/proxy-agents/tree/main/packages/http-proxy-agent#readme

provenance:
  derived_from:
    - "http-proxy-agent README — https://github.com/TooTallNate/proxy-agents/tree/main/packages/http-proxy-agent#readme"
    - "Test vectors verified with http-proxy-agent via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "http-proxy-agent source"
  notes:
    - "http.Agent that tunnels HTTP requests through an HTTP proxy."
    - "Install: npm install http-proxy-agent"
    - "v7 CJS; named export HttpProxyAgent (extends agent-base.Agent)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Connection errors propagate via the http request object."
  stderr: "null"
  stickiness: "Each agent instance owns its own connection-pool state."
  codes: {}

invariant http_proxy_agent.has_HttpProxyAgent:
  description: "HttpProxyAgent class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "HttpProxyAgent.constructor.name"}
  expected: "Function"

invariant http_proxy_agent.HttpProxyAgent_name:
  description: "HttpProxyAgent.name is 'HttpProxyAgent'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "HttpProxyAgent.name"}
  expected: "HttpProxyAgent"

invariant http_proxy_agent.proto_has_connect:
  description: "HttpProxyAgent.prototype.connect defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "HttpProxyAgent.prototype.connect.constructor.name"}
  expected: "AsyncFunction"
