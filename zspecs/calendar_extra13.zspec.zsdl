spec: calendar_extra13
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
    - "calendar_extra7.zspec.zsdl — covers Calendar/__qualname__; TextCalendar/__name__/__bases__; HTMLCalendar/__name__/__bases__; isleap; leapdays; monthrange; firstweekday/__module__; timegm/__module__"
    - "calendar_extra9.zspec.zsdl — covers TextCalendar/__module__/__qualname__; HTMLCalendar/__module__/__qualname__; MRO lengths"
    - "calendar_extra10.zspec.zsdl — covers Calendar/TextCalendar/HTMLCalendar __qualname__ standalone; Calendar.__module__; base class checks; isleap truth-table"
    - "calendar_extra12.zspec.zsdl — covers LocaleTextCalendar/__module__; LocaleHTMLCalendar/__module__; isleap/monthrange/weekday __module__ table"
  notes:
    - "This spec extends calendar.zspec.zsdl and prior extras through calendar_extra12.zspec.zsdl."
    - "NEW in extra13 — Axis 1: LocaleTextCalendar.__qualname__ and LocaleHTMLCalendar.__qualname__ as standalone extra13-namespace invariants."
    - "NEW in extra13 — Axis 2: isleap.__qualname__ as a standalone extra13-namespace invariant."
    - "NEW in extra13 — Axis 3: calendar.month and calendar.calendar are bound methods whose __qualname__ reflects the owning class (TextCalendar.formatmonth and TextCalendar.formatyear)."
    - "calendar.LocaleTextCalendar.__qualname__ == 'LocaleTextCalendar' — verified Python 3.12."
    - "calendar.LocaleHTMLCalendar.__qualname__ == 'LocaleHTMLCalendar' — verified Python 3.12."
    - "calendar.isleap.__qualname__ == 'isleap' — verified Python 3.12."
    - "calendar.month.__qualname__ == 'TextCalendar.formatmonth' — module-level 'month' is a bound method of the default TextCalendar instance."
    - "calendar.calendar.__qualname__ == 'TextCalendar.formatyear' — module-level 'calendar' is a bound method of the default TextCalendar instance."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# LocaleTextCalendar.__qualname__ and LocaleHTMLCalendar.__qualname__
#
# calendar_extra12 covers __module__ for LocaleTextCalendar and
# LocaleHTMLCalendar. No prior spec anchors their __qualname__ as standalone
# invariants. Both are module-level classes so their qualname is flat.
# ---------------------------------------------------------------------------

invariant calendar_extra13.LocaleTextCalendar.qualname:
  description: "calendar.LocaleTextCalendar.__qualname__ == 'LocaleTextCalendar' — flat qualname for module-level class"
  category: class_qualnames
  kind: python_call_eq
  function: LocaleTextCalendar.__qualname__.__eq__
  args: ["LocaleTextCalendar"]
  expected: true

invariant calendar_extra13.LocaleHTMLCalendar.qualname:
  description: "calendar.LocaleHTMLCalendar.__qualname__ == 'LocaleHTMLCalendar' — flat qualname for module-level class"
  category: class_qualnames
  kind: python_call_eq
  function: LocaleHTMLCalendar.__qualname__.__eq__
  args: ["LocaleHTMLCalendar"]
  expected: true

# ---------------------------------------------------------------------------
# isleap.__qualname__
#
# calendar_extra (extra1) and extra12 cover isleap.__name__ and __module__.
# This spec anchors isleap.__qualname__ as a standalone invariant in the
# extra13 namespace.
# ---------------------------------------------------------------------------

invariant calendar_extra13.isleap.qualname:
  description: "calendar.isleap.__qualname__ == 'isleap' — flat qualname for module-level function"
  category: function_qualnames
  kind: python_call_eq
  function: isleap.__qualname__.__eq__
  args: ["isleap"]
  expected: true

# ---------------------------------------------------------------------------
# calendar.month and calendar.calendar are bound methods
#
# The module-level names 'month' and 'calendar' are bound methods on the
# default TextCalendar instance created at import time. Their __qualname__
# reflects the defining class (TextCalendar.formatmonth and
# TextCalendar.formatyear). No prior spec captures these __qualname__ values.
# ---------------------------------------------------------------------------

invariant calendar_extra13.month.qualname:
  description: "calendar.month.__qualname__ == 'TextCalendar.formatmonth' — module-level 'month' is a bound method"
  category: function_qualnames
  kind: python_call_eq
  function: month.__qualname__.__eq__
  args: ["TextCalendar.formatmonth"]
  expected: true

invariant calendar_extra13.calendar.qualname:
  description: "calendar.calendar.__qualname__ == 'TextCalendar.formatyear' — module-level 'calendar' is a bound method"
  category: function_qualnames
  kind: python_call_eq
  function: calendar.__qualname__.__eq__
  args: ["TextCalendar.formatyear"]
  expected: true
