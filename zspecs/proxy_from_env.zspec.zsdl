spec: proxy_from_env
version: ">=1.1.0"
backend: node(proxy-from-env)

docs: https://github.com/Rob--W/proxy-from-env#readme

provenance:
  derived_from:
    - "proxy-from-env README — https://github.com/Rob--W/proxy-from-env#readme"
    - "Test vectors verified with proxy-from-env via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "proxy-from-env source"
  notes:
    - "Resolve a URL's proxy from HTTP_PROXY / HTTPS_PROXY / NO_PROXY env vars."
    - "Install: npm install proxy-from-env"
    - "v1 CJS; named export getProxyForUrl(url) → '' if no proxy, otherwise the proxy URL."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "Reads env vars at call time."
  codes: {}

invariant proxy_from_env.has_getProxyForUrl:
  description: "getProxyForUrl() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getProxyForUrl.constructor.name"}
  expected: "Function"

invariant proxy_from_env.no_env_returns_empty:
  description: "Without HTTP_PROXY, returns '' (no proxy)"
  category: resolve
  kind: node_chain_eq
  entry: named
  function: getProxyForUrl
  entry_args: ["http://example.com"]
  chain: []
  expected: ""

invariant proxy_from_env.getProxyForUrl_arity:
  description: "getProxyForUrl takes 1 arg"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getProxyForUrl.length"}
  expected: 1

invariant proxy_from_env.getProxyForUrl_name:
  description: "getProxyForUrl.name is 'getProxyForUrl'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getProxyForUrl.name"}
  expected: "getProxyForUrl"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:04:37Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
