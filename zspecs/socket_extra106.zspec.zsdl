spec: socket_extra106
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra105.zspec.zsdl — covers AF_*/SOCK_* class module/qualname/mro / AF_*/SOCK_* IntEnum base and int values / AddressFamily/SocketKind name/module/metaclass/base identity (table + invariants)."
    - "socket_extra104.zspec.zsdl — covers socket.socket C-method types (method_descriptor) / socket.socket method qualname lengths / socket.socket Python-level method types (function) and class identity (table + invariants)."
    - "socket_extra103.zspec.zsdl — covers socket.inet_aton/ntoa/pton/ntop __class__.__name__ and qualname lengths / htons/htonl/ntohs/ntohl class names and qualname lengths / herror/gaierror __mro__.__len__()==5 / AddressFamily/SocketKind __mro__.__len__()==6 (table + invariants)."
    - "socket_extra102.zspec.zsdl — covers socket.socket/__qualname__/__name__/__len__()==6 / error/__name__.__eq__('OSError') / herror/gaierror qualname/module/bases / AddressFamily/SocketKind qualname lengths and module (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method qualname lengths (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket Python method class/module / send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra105; it does NOT duplicate invariants present in those files."
    - "Wave 268 theme: socket IPPROTO_* constants (IPPROTO_TCP, IPPROTO_UDP, IPPROTO_IP, IPPROTO_ICMP, IPPROTO_IPV6) class names and integer values; SOL_SOCKET class name and value."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.IPPROTO_TCP) == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.IPPROTO_UDP) == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.IPPROTO_IP) == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_ICMP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.IPPROTO_ICMP) == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IPV6.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.IPPROTO_IPV6) == 41. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_SOCKET.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "int(socket.SOL_SOCKET) == 65535. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP.__class__.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: IPPROTO_* and SOL_SOCKET are plain 'int' objects (not IntEnum like AF_INET/SOCK_STREAM). Their __class__.__name__ is 'int' and __class__.__module__ is 'builtins'. This contrasts with AF_*/SOCK_* which are IntEnum members."
    - "Note: IPPROTO_TCP==6 (TCP protocol number per IANA), IPPROTO_UDP==17, IPPROTO_IP==0 (dummy for IP), IPPROTO_ICMP==1, IPPROTO_IPV6==41 (macOS value; may differ on some platforms)."
    - "Note: SOL_SOCKET==65535 (0xFFFF) on macOS/Darwin. This is the socket-level option constant used with getsockopt/setsockopt. The value 65535 is macOS-specific; Linux uses SOL_SOCKET==1."
    - "Note: socket_extra96 anchors AF_*/SOCK_* as IntEnum (AddressFamily/SocketKind); this spec anchors IPPROTO_*/SOL_SOCKET as plain 'int' objects — a key architectural difference."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int')
# socket.IPPROTO_UDP.__class__.__name__.__eq__('int')
# socket.IPPROTO_IP.__class__.__name__.__eq__('int')
# socket.IPPROTO_ICMP.__class__.__name__.__eq__('int')
# socket.IPPROTO_IPV6.__class__.__name__.__eq__('int')
#
# Wave 268 theme: IPPROTO_* constants are plain 'int' objects (not IntEnum).
#
# IPPROTO_TCP, IPPROTO_UDP, IPPROTO_IP, IPPROTO_ICMP, and IPPROTO_IPV6 are
# plain Python int objects (not IntEnum like AF_INET or SOCK_STREAM). Their
# __class__.__name__ is 'int'. This contrasts with AddressFamily/SocketKind
# IntEnum members (extra96/extra105). No prior socket spec anchors IPPROTO_*
# __class__.__name__ as a grouped table under sockproto106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra106.IPPROTO_class_names:
  description: "IPPROTO_TCP.__class__.__name__.__eq__('int')==True / IPPROTO_UDP.__class__.__name__.__eq__('int')==True / IPPROTO_IP.__class__.__name__.__eq__('int')==True / IPPROTO_ICMP.__class__.__name__.__eq__('int')==True / IPPROTO_IPV6.__class__.__name__.__eq__('int')==True — all IPPROTO_* constants are plain 'int' (not IntEnum like AF_*/SOCK_*); __class__.__module__=='builtins'; contrasts with AddressFamily/SocketKind IntEnum members; no prior socket spec anchors IPPROTO class names; first sockproto106 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockproto106

  columns: [id, function, args, expected, description]
  rows:
    - [ipproto_tcp_class,   "IPPROTO_TCP.__class__.__name__.__eq__",   ["int"], true, "IPPROTO_TCP.__class__.__name__ is 'int' (plain int, not IntEnum like AF_INET)"]
    - [ipproto_udp_class,   "IPPROTO_UDP.__class__.__name__.__eq__",   ["int"], true, "IPPROTO_UDP.__class__.__name__ is 'int' (plain int, not IntEnum)"]
    - [ipproto_ip_class,    "IPPROTO_IP.__class__.__name__.__eq__",    ["int"], true, "IPPROTO_IP.__class__.__name__ is 'int' (plain int; value 0 is dummy for IP level)"]
    - [ipproto_icmp_class,  "IPPROTO_ICMP.__class__.__name__.__eq__",  ["int"], true, "IPPROTO_ICMP.__class__.__name__ is 'int' (plain int; ICMP protocol level)"]
    - [ipproto_ipv6_class,  "IPPROTO_IPV6.__class__.__name__.__eq__",  ["int"], true, "IPPROTO_IPV6.__class__.__name__ is 'int' (plain int; IPv6 protocol level)"]

# ---------------------------------------------------------------------------
# int(socket.IPPROTO_TCP).__eq__(6)
# int(socket.IPPROTO_UDP).__eq__(17)
# int(socket.IPPROTO_IP).__eq__(0)
# int(socket.IPPROTO_ICMP).__eq__(1)
# int(socket.IPPROTO_IPV6).__eq__(41)
#
# Wave 268 theme: IPPROTO_* integer values (IANA protocol numbers).
#
# IPPROTO_TCP=6, IPPROTO_UDP=17, IPPROTO_IP=0, IPPROTO_ICMP=1,
# IPPROTO_IPV6=41 are the IANA protocol numbers for TCP, UDP, IP, ICMP,
# and IPv6 respectively. These match the values in /etc/protocols and
# the IANA protocol number registry. IPPROTO_IPV6=41 is the macOS/Darwin
# value (same as Linux). No prior socket spec anchors IPPROTO_* integer
# values as a grouped table under sockproto106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra106.IPPROTO_int_values:
  description: "int(IPPROTO_TCP).__eq__(6)==True / int(IPPROTO_UDP).__eq__(17)==True / int(IPPROTO_IP).__eq__(0)==True / int(IPPROTO_ICMP).__eq__(1)==True / int(IPPROTO_IPV6).__eq__(41)==True — IANA protocol numbers: TCP=6, UDP=17, IP=0 (dummy), ICMP=1, IPv6=41; match /etc/protocols on macOS/Darwin 25.4.0; IPPROTO_IPV6=41 same on macOS and Linux; no prior socket spec anchors IPPROTO integer values; first sockproto106 anchor"
  kind: python_call_eq
  category: constant_values
  id_prefix: sockproto106

  columns: [id, function, args, expected, description]
  rows:
    - [ipproto_tcp_val,   "IPPROTO_TCP.__int__",   [],  6,  "int(IPPROTO_TCP)==6 — TCP protocol number per IANA (Transmission Control Protocol)"]
    - [ipproto_udp_val,   "IPPROTO_UDP.__int__",   [], 17,  "int(IPPROTO_UDP)==17 — UDP protocol number per IANA (User Datagram Protocol)"]
    - [ipproto_ip_val,    "IPPROTO_IP.__int__",    [],  0,  "int(IPPROTO_IP)==0 — IP protocol number (dummy; used as 'any IP protocol' in setsockopt)"]
    - [ipproto_icmp_val,  "IPPROTO_ICMP.__int__",  [],  1,  "int(IPPROTO_ICMP)==1 — ICMP protocol number per IANA (Internet Control Message Protocol)"]
    - [ipproto_ipv6_val,  "IPPROTO_IPV6.__int__",  [], 41,  "int(IPPROTO_IPV6)==41 — IPv6 protocol number per IANA (macOS/Darwin 25.4.0 value)"]

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET.__class__.__name__.__eq__('int')
# int(socket.SOL_SOCKET).__eq__(65535)
# socket.IPPROTO_TCP.__class__.__module__.__eq__('builtins')
# socket.IPPROTO_TCP.__class__.__bases__[0].__name__.__eq__('object')
# socket.SOL_SOCKET.__class__.__module__.__eq__('builtins')
#
# Wave 268 theme: SOL_SOCKET class name and value; IPPROTO class module/bases.
#
# SOL_SOCKET is a plain 'int' constant with value 65535 (0xFFFF) on macOS/
# Darwin. It is used as the level argument to getsockopt/setsockopt to operate
# on socket-level options (not protocol-level). IPPROTO_TCP.__class__.__module__
# is 'builtins' (it is a plain int from the builtins module). The base class
# of 'int' is 'object'. No prior socket spec anchors SOL_SOCKET class name
# or value as a grouped table under sockproto106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra106.SOL_SOCKET_and_IPPROTO_module_bases:
  description: "SOL_SOCKET.__class__.__name__.__eq__('int')==True / int(SOL_SOCKET).__eq__(65535)==True / IPPROTO_TCP.__class__.__module__.__eq__('builtins')==True / IPPROTO_TCP.__class__.__bases__[0].__name__.__eq__('object')==True / SOL_SOCKET.__class__.__module__.__eq__('builtins')==True — SOL_SOCKET is plain int=65535 (0xFFFF) on macOS (Linux uses 1); IPPROTO_* and SOL_SOCKET have __class__.__module__=='builtins' (plain int); int.__bases__[0]=='object'; no prior socket spec anchors SOL_SOCKET class/value or IPPROTO module/bases; first sockproto106 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockproto106

  columns: [id, function, args, expected, description]
  rows:
    - [sol_socket_class,      "SOL_SOCKET.__class__.__name__.__eq__",             ["int"],     true,  "SOL_SOCKET.__class__.__name__ is 'int' (plain int constant for socket-level option operations)"]
    - [sol_socket_val,        "SOL_SOCKET.__int__",                               [],          65535, "int(SOL_SOCKET)==65535 (0xFFFF on macOS/Darwin; Linux uses SOL_SOCKET==1)"]
    - [ipproto_tcp_mod,       "IPPROTO_TCP.__class__.__module__.__eq__",          ["builtins"], true, "IPPROTO_TCP.__class__.__module__ is 'builtins' (plain int from Python builtins)"]
    - [ipproto_tcp_base,      "IPPROTO_TCP.__class__.__bases__[0].__name__.__eq__", ["object"], true, "IPPROTO_TCP.__class__.__bases__[0].__name__ is 'object' (int directly inherits from object)"]
    - [sol_socket_mod,        "SOL_SOCKET.__class__.__module__.__eq__",           ["builtins"], true, "SOL_SOCKET.__class__.__module__ is 'builtins' (plain int constant)"]

# ---------------------------------------------------------------------------
# int(socket.IPPROTO_TCP).__eq__(6) — standalone
#
# int(socket.IPPROTO_TCP) is 6. TCP (Transmission Control Protocol) is
# protocol number 6 in the IANA protocol number registry. This value is
# used as the protocol argument in socket.socket(AF_INET, SOCK_STREAM, 6)
# and as the level argument to getsockopt/setsockopt for TCP-level options
# (e.g., TCP_NODELAY). The value 6 is universal across all POSIX platforms.
# No prior socket spec anchors IPPROTO_TCP's integer value as a standalone
# under sockproto106. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra106.IPPROTO_TCP_val_6:
  description: "int(socket.IPPROTO_TCP) == 6 — TCP is IANA protocol number 6; used as protocol arg in socket() and level arg in getsockopt/setsockopt for TCP_NODELAY etc.; universal POSIX value; no prior socket spec anchors IPPROTO_TCP value as standalone; first standalone under sockproto106"
  category: constant_values
  kind: python_call_eq
  function: "IPPROTO_TCP.__int__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# int(socket.IPPROTO_UDP).__eq__(17) — standalone
#
# int(socket.IPPROTO_UDP) is 17. UDP (User Datagram Protocol) is protocol
# number 17 in the IANA protocol number registry. This value is used when
# creating UDP sockets: socket.socket(AF_INET, SOCK_DGRAM, 17). It is also
# used to set protocol-level socket options via getsockopt/setsockopt.
# The value 17 is universal across all POSIX platforms. No prior socket spec
# anchors IPPROTO_UDP's integer value as a standalone under sockproto106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra106.IPPROTO_UDP_val_17:
  description: "int(socket.IPPROTO_UDP) == 17 — UDP is IANA protocol number 17; used as protocol arg for socket(AF_INET, SOCK_DGRAM, 17); universal POSIX value; no prior socket spec anchors IPPROTO_UDP value as standalone; first standalone under sockproto106"
  category: constant_values
  kind: python_call_eq
  function: "IPPROTO_UDP.__int__"
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# int(socket.SOL_SOCKET).__eq__(65535) — standalone
#
# int(socket.SOL_SOCKET) is 65535 (0xFFFF) on macOS/Darwin 25.4.0.
# SOL_SOCKET is the socket-level option constant used as the level argument
# to getsockopt() and setsockopt() for socket-level options like SO_REUSEADDR,
# SO_KEEPALIVE, SO_SNDBUF, etc. The value 65535 is macOS/Darwin-specific;
# Linux uses SOL_SOCKET=1. This platform difference is a notable portability
# concern. No prior socket spec anchors SOL_SOCKET's value as a standalone
# under sockproto106. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra106.SOL_SOCKET_val_65535:
  description: "int(socket.SOL_SOCKET) == 65535 — SOL_SOCKET is 65535 (0xFFFF) on macOS/Darwin 25.4.0; used as level arg in getsockopt/setsockopt for SO_REUSEADDR/SO_KEEPALIVE/SO_SNDBUF etc.; macOS-specific value (Linux uses SOL_SOCKET==1); portability concern; no prior socket spec anchors SOL_SOCKET value as standalone; first standalone under sockproto106"
  category: constant_values
  kind: python_call_eq
  function: "SOL_SOCKET.__int__"
  args: []
  expected: 65535

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int') — standalone
#
# socket.IPPROTO_TCP.__class__.__name__ is 'int'. IPPROTO_TCP is a plain
# Python int constant, not an IntEnum member like AF_INET (AddressFamily) or
# SOCK_STREAM (SocketKind). This is an important distinction: AF_*/SOCK_*
# constants have rich enum semantics and a 6-deep MRO, while IPPROTO_*
# constants are bare ints with a 2-deep MRO (int, object). socket_extra96
# anchors AF_*/SOCK_* as AddressFamily/SocketKind; no prior socket spec
# anchors IPPROTO_TCP.__class__.__name__ as a standalone under sockproto106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra106.IPPROTO_TCP_class_name_int:
  description: "socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True — IPPROTO_TCP is a plain int (not IntEnum like AF_INET/SOCK_STREAM); bare int with 2-deep MRO (int, object) vs IntEnum's 6-deep MRO; extra96 anchors AF_*/SOCK_* as IntEnum; first standalone contrasting IPPROTO class name under sockproto106"
  category: type_identity
  kind: python_call_eq
  function: "IPPROTO_TCP.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# int(socket.IPPROTO_IPV6).__eq__(41) — standalone
#
# int(socket.IPPROTO_IPV6) is 41 on macOS/Darwin 25.4.0. IPv6 is IANA
# protocol number 41. This value is used as the level argument to
# getsockopt/setsockopt for IPv6-level socket options (e.g., IPV6_V6ONLY,
# IPV6_HOPLIMIT). IPPROTO_IPV6=41 is consistent across macOS and Linux,
# unlike SOL_SOCKET which differs between platforms. No prior socket spec
# anchors IPPROTO_IPV6's value as a standalone under sockproto106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra106.IPPROTO_IPV6_val_41:
  description: "int(socket.IPPROTO_IPV6) == 41 — IPv6 is IANA protocol number 41; used as level arg for IPV6_V6ONLY/IPV6_HOPLIMIT etc. in getsockopt/setsockopt; consistent across macOS and Linux (unlike SOL_SOCKET); no prior socket spec anchors IPPROTO_IPV6 value as standalone; first standalone under sockproto106"
  category: constant_values
  kind: python_call_eq
  function: "IPPROTO_IPV6.__int__"
  args: []
  expected: 41
