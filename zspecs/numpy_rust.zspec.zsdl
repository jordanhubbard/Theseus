spec: numpy_rust
version: ">=3.9"
backend: rust_module(numpy_rust)

docs: https://numpy.org/doc/stable/reference/ufuncs.html

provenance:
  derived_from:
    - "https://numpy.org/doc/stable/reference/ufuncs.html — NumPy ufunc documentation"
  not_derived_from:
    - "NumPy source: numpy/core/src/"
  notes:
    - "Clean-room Rust reimplementation of NumPy scalar ufuncs, exposed via PyO3."
    - "numpy scalar ufuncs return numpy scalar types (int64, float64) that compare equal to Python int/float."
    - "add(1, 2) == 3, subtract(10, 3) == 7, multiply(4, 5) == 20."
    - "divide(10, 4) == 2.5 — true division returning float64."
    - "power(2, 8) == 256, square(7) == 49."
    - "sqrt(9.0) == 3.0, floor(3.7) == 3.0, ceil(2.3) == 3.0."
    - "abs(-5) == 5, mod(17, 5) == 2."
    - "minimum(3, 5) == 3, maximum(3, 5) == 5."
    - "All test vectors verified against numpy 2.4.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Arithmetic ufuncs — scalar inputs
table numpy_rust.arithmetic.vectors:
  kind: python_call_eq
  category: arithmetic
  id_prefix: np_arith

  columns: [id, function, args, expected]
  rows:
    - [add,          add,          [1, 2],   3]
    - [subtract,     subtract,     [10, 3],  7]
    - [multiply,     multiply,     [4, 5],   20]
    - [power,        power,        [2, 8],   256]
    - [square,       square,       [7],      49]
    - [mod,          mod,          [17, 5],  2]
    - [floor_divide, floor_divide, [10, 3],  3]

# Division — returns float
table numpy_rust.division.vectors:
  kind: python_call_eq
  category: division
  id_prefix: np_div

  columns: [id, function, args, expected]
  rows:
    - [true_div,   divide,  [10, 4],  2.5]
    - [exact_div,  divide,  [9, 3],   3.0]
    - [neg_div,    divide,  [-6, 2],  -3.0]

# Math ufuncs — sqrt, floor, ceil, abs
table numpy_rust.math.vectors:
  kind: python_call_eq
  category: math
  id_prefix: np_math

  columns: [id, function, args, expected]
  rows:
    - [sqrt_4,    sqrt,  [4.0],   2.0]
    - [sqrt_9,    sqrt,  [9.0],   3.0]
    - [sqrt_1,    sqrt,  [1.0],   1.0]
    - [floor_pos, floor, [3.7],   3.0]
    - [floor_neg, floor, [-1.2],  -2.0]
    - [ceil_pos,  ceil,  [2.3],   3.0]
    - [ceil_neg,  ceil,  [-1.7],  -1.0]
    - [abs_neg,   abs,   [-5],    5]
    - [abs_pos,   abs,   [7],     7]

# Comparison ufuncs
table numpy_rust.comparison.vectors:
  kind: python_call_eq
  category: comparison
  id_prefix: np_cmp

  columns: [id, function, args, expected]
  rows:
    - [minimum_ab, minimum, [3, 5], 3]
    - [minimum_ba, minimum, [5, 3], 3]
    - [maximum_ab, maximum, [3, 5], 5]
    - [maximum_ba, maximum, [5, 3], 5]
    - [minimum_eq, minimum, [4, 4], 4]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T22:08:34Z
  iterations: 1
  pass_count: 24
  fail_count: 0
  total_invariants: 24
  notes: Synthesis succeeded in 1 iteration(s). 24 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
