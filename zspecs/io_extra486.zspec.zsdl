spec: io_extra486
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io.StringIO and io.BytesIO method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks that StringIO and BytesIO class-level method __name__ attributes match expected strings"
    - "Method identity is stable across Python 3.9+"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra486.stringio_method_names:
  description: "io.StringIO class-level method __name__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: sio

  columns: [id, function, args, expected]
  rows:
    - [sio001, io.StringIO.read.__name__.__eq__,     ["read"],     true]
    - [sio002, io.StringIO.write.__name__.__eq__,    ["write"],    true]
    - [sio003, io.StringIO.getvalue.__name__.__eq__, ["getvalue"], true]
    - [sio004, io.StringIO.seek.__name__.__eq__,     ["seek"],     true]
    - [sio005, io.StringIO.tell.__name__.__eq__,     ["tell"],     true]
    - [sio006, io.StringIO.truncate.__name__.__eq__, ["truncate"], true]
    - [sio007, io.StringIO.close.__name__.__eq__,    ["close"],    true]

table io_extra486.bytesio_method_names:
  description: "io.BytesIO class-level method __name__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: bio

  columns: [id, function, args, expected]
  rows:
    - [bio001, io.BytesIO.read.__name__.__eq__,      ["read"],      true]
    - [bio002, io.BytesIO.write.__name__.__eq__,     ["write"],     true]
    - [bio003, io.BytesIO.getvalue.__name__.__eq__,  ["getvalue"],  true]
    - [bio004, io.BytesIO.seek.__name__.__eq__,      ["seek"],      true]
    - [bio005, io.BytesIO.tell.__name__.__eq__,      ["tell"],      true]
    - [bio006, io.BytesIO.getbuffer.__name__.__eq__, ["getbuffer"], true]
