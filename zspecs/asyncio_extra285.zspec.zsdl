spec: asyncio_extra285
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio exception class hierarchy and module membership"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
  notes:
    - "In Python 3.8+ asyncio.CancelledError inherits directly from BaseException, not Exception"
    - "In Python 3.11+ asyncio.TimeoutError is an alias for builtins.TimeoutError with __module__ == 'builtins'"
    - "asyncio.SendfileNotAvailableError.__module__ == 'asyncio.exceptions' (verified)"
    - "asyncio.AsyncResult is not part of asyncio; pool aliases verified separately"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra285.exception_names:
  description: "asyncio exception class __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: aio285n

  columns: [id, function, args, expected, description]
  rows:
    - [aio285n001, asyncio.InvalidStateError.__name__.__eq__, ["InvalidStateError"], true, "InvalidStateError __name__"]
    - [aio285n002, asyncio.CancelledError.__name__.__eq__, ["CancelledError"], true, "CancelledError __name__"]
    - [aio285n003, asyncio.IncompleteReadError.__name__.__eq__, ["IncompleteReadError"], true, "IncompleteReadError __name__"]
    - [aio285n004, asyncio.LimitOverrunError.__name__.__eq__, ["LimitOverrunError"], true, "LimitOverrunError __name__"]
    - [aio285n005, asyncio.SendfileNotAvailableError.__name__.__eq__, ["SendfileNotAvailableError"], true, "SendfileNotAvailableError __name__"]

table asyncio_extra285.exception_modules:
  description: "asyncio exception class __module__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: aio285m

  columns: [id, function, args, expected, description]
  rows:
    - [aio285m001, asyncio.InvalidStateError.__module__.__eq__, ["asyncio.exceptions"], true, "InvalidStateError __module__"]
    - [aio285m002, asyncio.CancelledError.__module__.__eq__, ["asyncio.exceptions"], true, "CancelledError __module__"]
    - [aio285m003, asyncio.IncompleteReadError.__module__.__eq__, ["asyncio.exceptions"], true, "IncompleteReadError __module__"]
    - [aio285m004, asyncio.LimitOverrunError.__module__.__eq__, ["asyncio.exceptions"], true, "LimitOverrunError __module__"]

invariant asyncio_extra285.invalid_state_base:
  description: "InvalidStateError base class is Exception"
  category: identity
  kind: python_call_eq
  function: asyncio.InvalidStateError.__bases__[0].__name__.__eq__
  args: ["Exception"]
  expected: true

invariant asyncio_extra285.cancelled_error_base:
  description: "CancelledError base class is BaseException in Python 3.8+"
  category: identity
  kind: python_call_eq
  function: asyncio.CancelledError.__bases__[0].__name__.__eq__
  args: ["BaseException"]
  expected: true

invariant asyncio_extra285.incomplete_read_base:
  description: "IncompleteReadError base class is EOFError"
  category: identity
  kind: python_call_eq
  function: asyncio.IncompleteReadError.__bases__[0].__name__.__eq__
  args: ["EOFError"]
  expected: true

invariant asyncio_extra285.limit_overrun_base:
  description: "LimitOverrunError base class is Exception"
  category: identity
  kind: python_call_eq
  function: asyncio.LimitOverrunError.__bases__[0].__name__.__eq__
  args: ["Exception"]
  expected: true

invariant asyncio_extra285.sendfile_base:
  description: "SendfileNotAvailableError base class is RuntimeError"
  category: identity
  kind: python_call_eq
  function: asyncio.SendfileNotAvailableError.__bases__[0].__name__.__eq__
  args: ["RuntimeError"]
  expected: true

invariant asyncio_extra285.timeout_error_module:
  description: "In Python 3.11+ asyncio.TimeoutError is builtins.TimeoutError with __module__ == 'builtins'"
  category: identity
  kind: python_call_eq
  function: asyncio.TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra285.timeout_error_name:
  description: "asyncio.TimeoutError.__name__ is TimeoutError"
  category: identity
  kind: python_call_eq
  function: asyncio.TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant asyncio_extra285.sendfile_module:
  description: "SendfileNotAvailableError __module__ is asyncio.exceptions"
  category: identity
  kind: python_call_eq
  function: asyncio.SendfileNotAvailableError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true
