spec: pprint_extra2
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
    - "pprint.zspec.zsdl — covers PrettyPrinter instantiation and pprint() call"
    - "pprint_extra.zspec.zsdl — covers PrettyPrinter.__name__, PrettyPrinter.__module__, pformat/pprint/isreadable/isrecursive/saferepr __name__, pformat(42), pformat('hello'), pformat([1,2,3]), isreadable(42), isrecursive({})"
  notes:
    - "This spec adds additional coverage for pformat, isreadable, and isrecursive not in pprint.zspec.zsdl or pprint_extra.zspec.zsdl."
    - "pformat([1,2,3]) == '[1, 2, 3]' — a short list fits on one line with default width=80."
    - "isreadable([1,2,3]) == True — a plain list of integers is always readable."
    - "isrecursive([1,2,3]) == False — a plain list contains no recursive references."
    - "isreadable({}) == True — an empty dict is readable."
    - "isrecursive([]) == False — an empty list has no recursive references."
    - "pformat({}) == '{}' — an empty dict formats as '{}'."
    - "pformat('') == \"''\" — an empty string formats as two single-quotes."
    - "All expected values verified by running Python 3.12 pprint module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pformat() — additional test vectors
#
# pprint_extra covers pformat(42), pformat('hello'), pformat([1, 2, 3]).
# We add: pformat({}), pformat(''), pformat([1, 2, 3]) with explicit check.
# ---------------------------------------------------------------------------

invariant pprint_extra2.pformat.list_123:
  description: "pformat([1, 2, 3]) == '[1, 2, 3]'"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [[1, 2, 3]]
  expected: "[1, 2, 3]"

invariant pprint_extra2.pformat.empty_dict:
  description: "pformat({}) == '{}'"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [{}]
  expected: "{}"

invariant pprint_extra2.pformat.empty_string:
  description: "pformat('') == \"''\""
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [""]
  expected: "''"

# ---------------------------------------------------------------------------
# isreadable() — additional test vectors
#
# pprint_extra covers isreadable(42).
# We add isreadable([1,2,3]) and isreadable({}).
# ---------------------------------------------------------------------------

invariant pprint_extra2.isreadable.list_123:
  description: "isreadable([1, 2, 3]) == True — a plain list is always readable"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [[1, 2, 3]]
  expected: true

invariant pprint_extra2.isreadable.empty_dict:
  description: "isreadable({}) == True — an empty dict is readable"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [{}]
  expected: true

# ---------------------------------------------------------------------------
# isrecursive() — additional test vectors
#
# pprint_extra covers isrecursive({}).
# We add isrecursive([1,2,3]) and isrecursive([]).
# ---------------------------------------------------------------------------

invariant pprint_extra2.isrecursive.list_123:
  description: "isrecursive([1, 2, 3]) == False — a plain list has no recursive references"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: [[1, 2, 3]]
  expected: false

invariant pprint_extra2.isrecursive.empty_list:
  description: "isrecursive([]) == False — an empty list has no recursive references"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: [[]]
  expected: false
