spec: decimal_extra25
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra25.zspec.zsdl."
    - "Prior specs covered: Decimal class, arithmetic operations, context, rounding modes, signals, __name__/__module__/__qualname__, bases, getcontext/setcontext/localcontext, ROUND_* constants, Decimal.__bases__, DecimalException.__name__, various math operations, exception qualnames, function qualnames, rounding constant class modules."
    - "This spec covers: Decimal.__init__.__name__, Context.__name__, Context.__module__, Context.__qualname__, Context.__bases__[0].__name__ (already in extra24 as standalone invariant), DefaultContext/__BasicContext/ExtendedContext __class__.__name__, ROUND_HALF_EVEN and ROUND_UP __class__.__name__."
    - "DefaultContext, BasicContext, ExtendedContext are all instances of Context — their __class__.__name__ == 'Context'."
    - "ROUND_HALF_EVEN and ROUND_UP are plain str constants — their __class__.__name__ == 'str'."
    - "Decimal.__init__.__name__ == '__init__' — the dunder name for the initializer."
    - "Context.__module__ == 'decimal' — Context is defined in the decimal module."
    - "Context.__qualname__ == 'Context' — Context is a top-level class, not nested."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.__init__.__name__
#
# No prior spec records Decimal.__init__.__name__.
# The __init__ method of Decimal carries the standard dunder name '__init__'.
# ---------------------------------------------------------------------------

invariant decimal_extra25.Decimal.init_name:
  description: "decimal.Decimal.__init__.__name__ == '__init__'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant decimal_extra25.Decimal.init_name_len:
  description: "len(decimal.Decimal.__init__.__name__) == 8 — '__init__' is 8 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__init__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Context class identity: __name__, __module__, __qualname__
#
# No prior spec records Context.__name__, Context.__module__, or
# Context.__qualname__ as standalone invariants (extra24 only covers
# Context.__bases__[0].__name__).
# Context is a top-level class defined in the decimal module.
# ---------------------------------------------------------------------------

invariant decimal_extra25.Context.name:
  description: "decimal.Context.__name__ == 'Context'"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra25.Context.name_len:
  description: "len(decimal.Context.__name__) == 7 — 'Context' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra25.Context.module:
  description: "decimal.Context.__module__ == 'decimal'"
  category: class_identity
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra25.Context.module_len:
  description: "len(decimal.Context.__module__) == 7 — 'decimal' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Context.__module__.__len__
  args: []
  expected: 7

invariant decimal_extra25.Context.qualname:
  description: "decimal.Context.__qualname__ == 'Context' — Context is a top-level class"
  category: class_identity
  kind: python_call_eq
  function: Context.__qualname__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra25.Context.qualname_len:
  description: "len(decimal.Context.__qualname__) == 7 — 'Context' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Context.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Context.__bases__[0].__name__
#
# decimal_extra24 covers this as a standalone invariant already.
# Included here for narrative completeness — not duplicated as invariant.
# See decimal_extra24.Context.base_name.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Pre-built Context instance __class__.__name__
#
# No prior spec records __class__.__name__ for DefaultContext, BasicContext,
# or ExtendedContext.  Each is a pre-constructed Context instance exported by
# the decimal module; all three have __class__.__name__ == 'Context'.
# ---------------------------------------------------------------------------

table decimal_extra25.prebuilt_context_class_names:
  kind: python_call_eq
  category: type_identity
  id_prefix: class_name

  columns: [id, function, args, expected, description]
  rows:
    - [default,   DefaultContext.__class__.__name__.__eq__,   ["Context"], true, "decimal.DefaultContext.__class__.__name__ == 'Context'"]
    - [basic,     BasicContext.__class__.__name__.__eq__,     ["Context"], true, "decimal.BasicContext.__class__.__name__ == 'Context'"]
    - [extended,  ExtendedContext.__class__.__name__.__eq__,  ["Context"], true, "decimal.ExtendedContext.__class__.__name__ == 'Context'"]

# ---------------------------------------------------------------------------
# Pre-built Context instance __class__.__name__ length
# ---------------------------------------------------------------------------

invariant decimal_extra25.prebuilt_context_class_name_len:
  description: "len(decimal.DefaultContext.__class__.__name__) == 7 — 'Context' is 7 chars"
  category: type_identity
  kind: python_call_eq
  function: DefaultContext.__class__.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Rounding constant __class__.__name__
#
# No prior spec records __class__.__name__ for ROUND_HALF_EVEN or ROUND_UP.
# All rounding constants are plain str instances; their __class__.__name__ == 'str'.
# (decimal_extra24 records __class__.__module__ for these constants, not __class__.__name__.)
# ---------------------------------------------------------------------------

table decimal_extra25.rounding_constant_class_names:
  kind: python_call_eq
  category: type_identity
  id_prefix: class_name

  columns: [id, function, args, expected, description]
  rows:
    - [half_even, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true, "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str'"]
    - [up,        ROUND_UP.__class__.__name__.__eq__,        ["str"], true, "decimal.ROUND_UP.__class__.__name__ == 'str'"]
    - [down,      ROUND_DOWN.__class__.__name__.__eq__,      ["str"], true, "decimal.ROUND_DOWN.__class__.__name__ == 'str'"]
    - [ceiling,   ROUND_CEILING.__class__.__name__.__eq__,   ["str"], true, "decimal.ROUND_CEILING.__class__.__name__ == 'str'"]
    - [floor,     ROUND_FLOOR.__class__.__name__.__eq__,     ["str"], true, "decimal.ROUND_FLOOR.__class__.__name__ == 'str'"]
    - [half_up,   ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true, "decimal.ROUND_HALF_UP.__class__.__name__ == 'str'"]

# ---------------------------------------------------------------------------
# Rounding constant __class__.__name__ length invariant
# ---------------------------------------------------------------------------

invariant decimal_extra25.rounding_constant_class_name_len:
  description: "len(decimal.ROUND_HALF_EVEN.__class__.__name__) == 3 — 'str' is 3 chars"
  category: type_identity
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__class__.__name__.__len__
  args: []
  expected: 3
