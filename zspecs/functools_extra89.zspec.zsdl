spec: functools_extra89
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra88

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra88.zspec.zsdl."
    - "This spec covers: functools partial __call__/__new__ slot wrapper __class__.__name__ + WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES tuple lengths + singledispatchmethod __dict__ membership (Wave 248)."
    - "partial.__call__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper. Verified with Python 3.14.3."
    - "partial.__new__.__class__.__name__ == 'builtin_function_or_method' — C built-in. Verified with Python 3.14.3."
    - "partial.__repr__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper. Verified with Python 3.14.3."
    - "partial.__reduce__.__class__.__name__ == 'method_descriptor' — C method descriptor. Verified with Python 3.14.3."
    - "partial.__setstate__.__class__.__name__ == 'method_descriptor' — C method descriptor. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — a plain tuple constant. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — a plain tuple constant. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__len__() == 1 — only '__dict__'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — six entries in Python 3.14. Verified with Python 3.14.3."
    - "singledispatchmethod.__dict__.__contains__('__init__') == True. Verified with Python 3.14.3."
    - "singledispatchmethod.__dict__.__contains__('__get__') == True. Verified with Python 3.14.3."
    - "singledispatchmethod.__dict__.__contains__('register') == True. Verified with Python 3.14.3."
    - "singledispatchmethod.__dict__.__class__.__name__ == 'mappingproxy'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial C-type slot __class__.__name__ — __call__/__new__/__repr__ — extra89
#
# Wave 248 theme: partial slot/descriptor __class__.__name__ strings.
#
# functools.partial.__call__.__class__.__name__  == 'wrapper_descriptor'
# functools.partial.__new__.__class__.__name__   == 'builtin_function_or_method'
# functools.partial.__repr__.__class__.__name__  == 'wrapper_descriptor'
# functools.partial.__reduce__.__class__.__name__ == 'method_descriptor'
#
# No prior functools spec checks partial C-type slot __class__.__name__ via functoolsextra89. New to extra89.
# ---------------------------------------------------------------------------

table functools_extra89.partial_slot_class_names_group1:
  description: "partial.__call__/__new__/__repr__/__reduce__ __class__.__name__ values; wave 248 partial C-type slot class names; new to extra89"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra89

  columns: [id, function, args, expected, description]
  rows:
    - [partial_call_class_name_eq_wrapper_descriptor,
       partial.__call__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial is a C extension type; __call__ is a slot wrapper; its __class__.__name__ is 'wrapper_descriptor' (18 chars); str.__eq__('wrapper_descriptor') returns True; no prior functools spec checks partial.__call__.__class__.__name__ via functoolsextra89; new to extra89"]
    - [partial_new_class_name_eq_builtin_function_or_method,
       partial.__new__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.partial.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — partial is a C extension type; __new__ is a built-in function; its __class__.__name__ is 'builtin_function_or_method' (26 chars); str.__eq__('builtin_function_or_method') returns True; no prior functools spec checks partial.__new__.__class__.__name__ via functoolsextra89; new to extra89"]
    - [partial_repr_class_name_eq_wrapper_descriptor,
       partial.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "functools.partial.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial is a C extension type; __repr__ is a slot wrapper; its __class__.__name__ is 'wrapper_descriptor' (18 chars); str.__eq__('wrapper_descriptor') returns True; no prior functools spec checks partial.__repr__.__class__.__name__ via functoolsextra89; new to extra89"]
    - [partial_reduce_class_name_eq_method_descriptor,
       partial.__reduce__.__class__.__name__.__eq__,
       ["method_descriptor"],
       true,
       "functools.partial.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — partial is a C extension type; __reduce__ is a method descriptor; its __class__.__name__ is 'method_descriptor' (17 chars); str.__eq__('method_descriptor') returns True; no prior functools spec checks partial.__reduce__.__class__.__name__ via functoolsextra89; new to extra89"]

# ---------------------------------------------------------------------------
# partial.__setstate__ and WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES — extra89
#
# Wave 248 theme: partial.__setstate__ class name + wrapper tuple class names.
#
# functools.partial.__setstate__.__class__.__name__     == 'method_descriptor'
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__      == 'tuple'
# functools.WRAPPER_UPDATES.__class__.__name__          == 'tuple'
# functools.WRAPPER_UPDATES.__len__()                   == 1
#
# No prior functools spec checks these via functoolsextra89. New to extra89.
# ---------------------------------------------------------------------------

table functools_extra89.partial_setstate_and_wrapper_tuples:
  description: "partial.__setstate__ class name; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES class names; WRAPPER_UPDATES len; wave 248; new to extra89"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra89

  columns: [id, function, args, expected, description]
  rows:
    - [partial_setstate_class_name_eq_method_descriptor,
       partial.__setstate__.__class__.__name__.__eq__,
       ["method_descriptor"],
       true,
       "functools.partial.__setstate__.__class__.__name__.__eq__('method_descriptor') == True — partial is a C extension type; __setstate__ is a method descriptor; its __class__.__name__ is 'method_descriptor' (17 chars); str.__eq__('method_descriptor') returns True; no prior functools spec checks partial.__setstate__.__class__.__name__ via functoolsextra89; new to extra89"]
    - [WRAPPER_ASSIGNMENTS_class_name_eq_tuple,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py; its __class__.__name__ is 'tuple' (5 chars); str.__eq__('tuple') returns True; no prior functools spec checks WRAPPER_ASSIGNMENTS.__class__.__name__ via functoolsextra89; new to extra89"]
    - [WRAPPER_UPDATES_class_name_eq_tuple,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple constant in Lib/functools.py containing '__dict__'; its __class__.__name__ is 'tuple' (5 chars); str.__eq__('tuple') returns True; no prior functools spec checks WRAPPER_UPDATES.__class__.__name__ via functoolsextra89; new to extra89"]
    - [WRAPPER_UPDATES_len_eq_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is a tuple containing exactly one element: '__dict__'; tuple.__len__() returns 1; no prior functools spec checks WRAPPER_UPDATES.__len__ via functoolsextra89; new to extra89"]

# ---------------------------------------------------------------------------
# functools.WRAPPER_ASSIGNMENTS.__len__() and singledispatchmethod __dict__ — extra89
#
# Wave 248 theme: WRAPPER_ASSIGNMENTS length + singledispatchmethod dict membership.
#
# functools.WRAPPER_ASSIGNMENTS.__len__()                            == 6
# functools.singledispatchmethod.__dict__.__contains__('__init__')  == True
# functools.singledispatchmethod.__dict__.__contains__('__get__')   == True
# functools.singledispatchmethod.__dict__.__contains__('register')  == True
#
# No prior functools spec checks these via functoolsextra89. New to extra89.
# ---------------------------------------------------------------------------

table functools_extra89.wrapper_assignments_len_and_singledispatchmethod_dict:
  description: "WRAPPER_ASSIGNMENTS len==6; singledispatchmethod dict contains __init__/__get__/register; wave 248; new to extra89"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra89

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_len_eq_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS is a tuple of six attribute names: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; tuple.__len__() returns 6 in Python 3.14; no prior functools spec checks WRAPPER_ASSIGNMENTS.__len__ via functoolsextra89; new to extra89"]
    - [singledispatchmethod_dict_contains_init,
       singledispatchmethod.__dict__.__contains__,
       ["__init__"],
       true,
       "functools.singledispatchmethod.__dict__.__contains__('__init__') == True — singledispatchmethod is a pure-Python descriptor class defined in Lib/functools.py; it defines __init__ in its own class namespace; __dict__.__contains__('__init__') returns True; no prior functools spec checks singledispatchmethod.__dict__.__contains__('__init__') via functoolsextra89; new to extra89"]
    - [singledispatchmethod_dict_contains_get,
       singledispatchmethod.__dict__.__contains__,
       ["__get__"],
       true,
       "functools.singledispatchmethod.__dict__.__contains__('__get__') == True — singledispatchmethod is a pure-Python descriptor class; it defines __get__ to implement the descriptor protocol; __dict__.__contains__('__get__') returns True; no prior functools spec checks singledispatchmethod.__dict__.__contains__('__get__') via functoolsextra89; new to extra89"]
    - [singledispatchmethod_dict_contains_register,
       singledispatchmethod.__dict__.__contains__,
       ["register"],
       true,
       "functools.singledispatchmethod.__dict__.__contains__('register') == True — singledispatchmethod is a pure-Python descriptor class; it defines register() to allow adding implementations; __dict__.__contains__('register') returns True; no prior functools spec checks singledispatchmethod.__dict__.__contains__('register') via functoolsextra89; new to extra89"]

# ---------------------------------------------------------------------------
# singledispatchmethod __dict__ class name — extra89
#
# Wave 248 theme: singledispatchmethod __dict__ class name.
#
# functools.singledispatchmethod.__dict__.__class__.__name__ == 'mappingproxy'
#
# No prior functools spec checks singledispatchmethod.__dict__.__class__.__name__ via functoolsextra89. New to extra89.
# ---------------------------------------------------------------------------

table functools_extra89.singledispatchmethod_dict_class_name:
  description: "singledispatchmethod.__dict__.__class__.__name__=='mappingproxy'; wave 248 singledispatchmethod dict class name; new to extra89"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra89

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatchmethod_dict_class_name_eq_mappingproxy,
       singledispatchmethod.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.singledispatchmethod.__dict__.__class__.__name__.__eq__('mappingproxy') == True — singledispatchmethod is a pure-Python class; its __dict__ is a types.MappingProxyType (mappingproxy) wrapping the class namespace; __class__.__name__ is 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior functools spec checks singledispatchmethod.__dict__.__class__.__name__ via functoolsextra89; new to extra89"]
    - [partial_call_class_name_is_not_slot_wrapper,
       partial.__call__.__class__.__name__.__eq__,
       ["slot_wrapper"],
       false,
       "functools.partial.__call__.__class__.__name__.__eq__('slot_wrapper') == False — partial.__call__ is a wrapper_descriptor, not a slot_wrapper; CPython uses 'wrapper_descriptor' for slot methods on extension types; str.__eq__('slot_wrapper') returns False; verifies the correct class name; new to extra89"]
    - [WRAPPER_ASSIGNMENTS_len_gt_5,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — double-confirms 6 entries; Python 3.11 had 5; Python 3.14 added '__annotate__' and '__type_params__' bringing count to 6; returns 6; new to extra89"]
    - [singledispatchmethod_dict_class_is_mappingproxy_len,
       singledispatchmethod.__dict__.__class__.__name__.__len__,
       [],
       12,
       "functools.singledispatchmethod.__dict__.__class__.__name__.__len__() == 12 — the string 'mappingproxy' has 12 characters: m,a,p,p,i,n,g,p,r,o,x,y; str.__len__() returns 12; no prior functools spec checks this length via functoolsextra89; new to extra89"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra89
# ---------------------------------------------------------------------------

invariant functools_extra89.partial_call_class_name:
  description: "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial C-type slot __call__ is a wrapper_descriptor; wave 248; new to extra89"
  kind: python_call_eq
  function: partial.__call__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra89.partial_new_class_name:
  description: "functools.partial.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — partial.__new__ is a builtin_function_or_method; wave 248; new to extra89"
  kind: python_call_eq
  function: partial.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra89.WRAPPER_UPDATES_len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains only '__dict__'; wave 248; new to extra89"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra89.WRAPPER_ASSIGNMENTS_len:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — six wrapper assignment attrs in Python 3.14; wave 248; new to extra89"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra89.singledispatchmethod_dict_contains_get:
  description: "functools.singledispatchmethod.__dict__.__contains__('__get__') == True — singledispatchmethod descriptor defines __get__; wave 248; new to extra89"
  kind: python_call_eq
  function: singledispatchmethod.__dict__.__contains__
  args: ["__get__"]
  expected: true
