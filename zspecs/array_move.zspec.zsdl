spec: array_move
version: ">=4.0.0"
backend: node(array-move)

docs: https://www.npmjs.com/package/array-move

provenance:
  derived_from:
    - "array-move README — https://www.npmjs.com/package/array-move"
    - "Test vectors verified with array-move via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-move source"
  notes:
    - "array-move is an npm package. Install: npm install array-move"
    - "arrayMoveImmutable(arr, fromIndex, toIndex) returns a new array with the element moved."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array with the specified element moved to a new position."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_move.arrayMoveImmutable:
  kind: node_module_call_eq
  function: arrayMoveImmutable
  category: transform
  id_prefix: arrmove

  columns: [id, args, expected]
  rows:
    - [move_front, [["a", "b", "c", "d"], 0, 2], ["b", "c", "a", "d"]]
    - [move_back,  [[1, 2, 3, 4], 1, 3],          [1, 3, 4, 2]]

