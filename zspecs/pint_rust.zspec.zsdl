spec: pint_rust
version: ">=3.9"
backend: rust_module(pint_rust)

docs: https://pint.readthedocs.io/

provenance:
  derived_from:
    - "https://pint.readthedocs.io/ — Pint library documentation"
  not_derived_from:
    - "pint source: pint/quantity.py"
  notes:
    - "Pint is a Python package for units of measurement."
    - "ureg = pint.UnitRegistry(); Q_ = ureg.Quantity."
    - "Expose meters_to_km(val) -> float: (val * ureg.meter).to(ureg.kilometer).magnitude."
    - "Expose km_to_meters(val) -> float: (val * ureg.kilometer).to(ureg.meter).magnitude."
    - "Expose kg_to_grams(val) -> float: (val * ureg.kilogram).to(ureg.gram).magnitude."
    - "Expose celsius_to_kelvin(val) -> float: (val * ureg.degC).to(ureg.kelvin).magnitude."
    - "Expose quantity_magnitude(val, unit) -> float: (val * ureg[unit]).magnitude."
    - "1000 meters == 1 km: meters_to_km(1000) == 1.0."
    - "1 km == 1000 meters: km_to_meters(1) == 1000.0."
    - "1 kg == 1000 grams: kg_to_grams(1) == 1000.0."
    - "0 degC == 273.15 K: celsius_to_kelvin(0) == 273.15."
    - "All test vectors verified against pint 0.24.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# length conversions
table pint_rust.length.conversions:
  kind: python_call_eq
  category: length
  id_prefix: pint_len
  function: meters_to_km

  columns: [id, args, expected]
  rows:
    - [thousand,   [1000], 1.0]
    - [half,       [500],  0.5]
    - [zero,       [0],    0.0]

table pint_rust.length.km_to_m:
  kind: python_call_eq
  category: length
  id_prefix: pint_km
  function: km_to_meters

  columns: [id, args, expected]
  rows:
    - [one,   [1],   1000.0]
    - [two,   [2],   2000.0]
    - [half,  [0.5], 500.0]

# mass conversion
invariant pint_rust.mass.kg_to_grams:
  description: "1 kg == 1000 grams"
  category: mass
  kind: python_call_eq
  function: kg_to_grams
  args: [1]
  expected: 1000.0

invariant pint_rust.mass.two_kg:
  description: "2 kg == 2000 grams"
  category: mass
  kind: python_call_eq
  function: kg_to_grams
  args: [2]
  expected: 2000.0

# temperature conversion
invariant pint_rust.temperature.zero_celsius:
  description: "0°C == 273.15 K"
  category: temperature
  kind: python_call_eq
  function: celsius_to_kelvin
  args: [0]
  expected: 273.15

invariant pint_rust.temperature.hundred_celsius:
  description: "100°C == 373.15 K"
  category: temperature
  kind: python_call_eq
  function: celsius_to_kelvin
  args: [100]
  expected: 373.15

