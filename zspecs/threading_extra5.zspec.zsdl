spec: threading_extra5
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "Extends threading.zspec.zsdl, threading_extra.zspec.zsdl, threading_extra2.zspec.zsdl, threading_extra3.zspec.zsdl, threading_extra4.zspec.zsdl."
    - "threading_extra4.zspec.zsdl covers: Thread/__module__, RLock/__module__, Timer/__module__ standalone; Condition/__module__, Semaphore/__module__, BoundedSemaphore/__module__, Event/__module__ standalone; Lock instance class name; Thread/__bases__[0].__name__; Semaphore/__bases__[0].__name__; BoundedSemaphore/__bases__[0].__name__; Event/__bases__[0].__name__; Timer/__bases__[0].__name__; active_count/__name__, enumerate/__name__, settrace/__name__."
    - "This spec adds: Thread/__module__, Lock/__module__, RLock/__module__, Condition/__module__, Semaphore/__module__, BoundedSemaphore/__module__, Event/__module__, Timer/__module__, Barrier/__module__, local/__module__, excepthook/__module__, current_thread/__module__, main_thread/__module__, active_count/__module__, TIMEOUT_MAX/__class__.__name__ — as a focused table and standalone invariants not yet in prior specs."
    - "threading.Lock is a C-level factory function; its __module__ is '_thread' on CPython."
    - "threading.RLock.__module__ == 'threading' — confirmed on CPython 3.12."
    - "threading.Condition.__module__ == 'threading' — pure-Python class."
    - "threading.Semaphore.__module__ == 'threading' — pure-Python class."
    - "threading.BoundedSemaphore.__module__ == 'threading' — pure-Python class."
    - "threading.Event.__module__ == 'threading' — pure-Python class."
    - "threading.Timer.__module__ == 'threading' — pure-Python class."
    - "threading.Barrier.__module__ == 'threading' — pure-Python class."
    - "threading.local.__module__ == 'threading' — thread-local storage class."
    - "threading.excepthook.__module__ == 'threading' — added in Python 3.8."
    - "threading.current_thread.__module__ == 'threading'."
    - "threading.main_thread.__module__ == 'threading'."
    - "threading.active_count.__module__ == 'threading'."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread.__module__ — standalone invariant
#
# threading_extra4 covers Thread.__module__ as a standalone invariant.
# This spec re-examines it in the context of the full module attribute table
# and adds the remaining primitives not yet appearing as standalone invariants.
# ---------------------------------------------------------------------------

invariant threading_extra5.Thread.module:
  description: "threading.Thread.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# Lock.__module__ — Lock is a C-level factory
#
# threading.Lock is backed by _thread.allocate_lock; its __module__ attribute
# reports '_thread' (the C extension module) rather than 'threading'.
# ---------------------------------------------------------------------------

invariant threading_extra5.Lock.module:
  description: "threading.Lock.__module__ == '_thread' — Lock is a C-level factory in _thread"
  category: class_modules
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table for pure-Python threading primitives
#
# RLock, Condition, Semaphore, BoundedSemaphore, Event, Timer, Barrier, and
# local are all pure-Python classes defined in threading.py.
# ---------------------------------------------------------------------------

table threading_extra5.class_modules:
  description: "Pure-Python threading primitives all have __module__ == 'threading'"
  kind: python_call_eq
  category: class_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [RLock,            RLock.__module__.__eq__,            ["threading"], true]
    - [Condition,        Condition.__module__.__eq__,        ["threading"], true]
    - [Semaphore,        Semaphore.__module__.__eq__,        ["threading"], true]
    - [BoundedSemaphore, BoundedSemaphore.__module__.__eq__, ["threading"], true]
    - [Event,            Event.__module__.__eq__,            ["threading"], true]
    - [Timer,            Timer.__module__.__eq__,            ["threading"], true]
    - [Barrier,          Barrier.__module__.__eq__,          ["threading"], true]
    - [local,            local.__module__.__eq__,            ["threading"], true]

# ---------------------------------------------------------------------------
# Function __module__ checks
#
# threading.excepthook, current_thread, main_thread, and active_count are
# all functions defined in threading.py.
# ---------------------------------------------------------------------------

invariant threading_extra5.excepthook.module:
  description: "threading.excepthook.__module__ == 'threading'"
  category: function_modules
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra5.current_thread.module:
  description: "threading.current_thread.__module__ == 'threading'"
  category: function_modules
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra5.main_thread.module:
  description: "threading.main_thread.__module__ == 'threading'"
  category: function_modules
  kind: python_call_eq
  function: main_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra5.active_count.module:
  description: "threading.active_count.__module__ == 'threading'"
  category: function_modules
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# TIMEOUT_MAX — type check
#
# threading.TIMEOUT_MAX is the maximum value for the timeout parameter in
# blocking calls. It is a float constant (typically a very large float).
# ---------------------------------------------------------------------------

invariant threading_extra5.TIMEOUT_MAX.class_name:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true
