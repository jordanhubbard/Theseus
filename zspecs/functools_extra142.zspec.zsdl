spec: functools_extra142
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial C extension slot and method qualnames — __call__, __new__, __repr__, __reduce__, __setstate__, and __init__ (Wave 265)."
    - "functools.partial.__call__.__qualname__ == 'partial.__call__' (len 16) — wrapper_descriptor for the C slot tp_call. Verified with Python 3.14.3."
    - "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' (len 18). Verified with Python 3.14.3."
    - "functools.partial.__new__.__qualname__ == 'partial.__new__' (len 15) — builtin_function_or_method for tp_new. Verified with Python 3.14.3."
    - "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' (len 26). Verified with Python 3.14.3."
    - "functools.partial.__repr__.__qualname__ == 'partial.__repr__' (len 16) — wrapper_descriptor for tp_repr. Verified with Python 3.14.3."
    - "functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor' (len 18). Verified with Python 3.14.3."
    - "functools.partial.__init__.__qualname__ == 'object.__init__' (len 15) — partial.__init__ is inherited from object; its qualname is 'object.__init__'. Verified with Python 3.14.3."
    - "functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor' (len 18). Verified with Python 3.14.3."
    - "functools.partial.__reduce__.__qualname__ == 'partial.__reduce__' (len 18) — method_descriptor. Verified with Python 3.14.3."
    - "functools.partial.__reduce__.__class__.__name__ == 'method_descriptor' (len 17). Verified with Python 3.14.3."
    - "functools.partial.__setstate__.__qualname__ == 'partial.__setstate__' (len 20) — method_descriptor. Verified with Python 3.14.3."
    - "functools.partial.__setstate__.__class__.__name__ == 'method_descriptor' (len 17). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial.__call__ and __repr__ — wrapper_descriptor slots
#
# Wave 265 theme: functools.partial C slot qualnames and class names.
#
# functools.partial.__call__.__qualname__ == 'partial.__call__' (len 16)
# functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' (len 18)
# functools.partial.__repr__.__qualname__ == 'partial.__repr__' (len 16)
# functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor' (len 18)
#
# Both are wrapper_descriptor objects exposing C slot functions. New to extra142.
# ---------------------------------------------------------------------------

table functools_extra142.partial_call_repr_slots:
  description: "functools.partial.__call__ and __repr__: wrapper_descriptor slots, qualnames len 16, class len 18; wave 265; new to extra142"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialcall142

  columns: [id, function, args, expected, description]
  rows:
    - [partial_call_qualname_eq,
       "partial.__call__.__qualname__.__eq__",
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True — partial.__call__ is a wrapper_descriptor exposing the C tp_call slot; its __qualname__ is 'partial.__call__'; str.__eq__('partial.__call__') returns True; new to extra142"]
    - [partial_call_qualname_len_eq_16,
       "partial.__call__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__call__.__qualname__.__len__() == 16 — __qualname__ is 'partial.__call__' which has 16 characters; len('partial.__call__') == 16; new to extra142"]
    - [partial_call_class_name_eq,
       "partial.__call__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__call__ is a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra142"]
    - [partial_call_class_name_len_eq_18,
       "partial.__call__.__class__.__name__.__len__",
       [],
       18,
       "functools.partial.__call__.__class__.__name__.__len__() == 18 — __class__.__name__ is 'wrapper_descriptor' which has 18 characters; len('wrapper_descriptor') == 18; new to extra142"]
    - [partial_repr_qualname_eq,
       "partial.__repr__.__qualname__.__eq__",
       ["partial.__repr__"],
       true,
       "functools.partial.__repr__.__qualname__.__eq__('partial.__repr__') == True — partial.__repr__ is a wrapper_descriptor exposing the C tp_repr slot; its __qualname__ is 'partial.__repr__'; str.__eq__('partial.__repr__') returns True; new to extra142"]
    - [partial_repr_qualname_len_eq_16,
       "partial.__repr__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__repr__.__qualname__.__len__() == 16 — __qualname__ is 'partial.__repr__' which has 16 characters; len('partial.__repr__') == 16; new to extra142"]
    - [partial_repr_class_name_eq,
       "partial.__repr__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__repr__ is a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra142"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial.__new__ — builtin_function_or_method
#
# Wave 265 theme: functools.partial.__new__ qualname and class name.
#
# functools.partial.__new__.__qualname__ == 'partial.__new__' (len 15)
# functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' (len 26)
#
# partial.__new__ is a builtin_function_or_method exposing tp_new. New to extra142.
# ---------------------------------------------------------------------------

table functools_extra142.partial_new_slot:
  description: "functools.partial.__new__: builtin_function_or_method, qualname=='partial.__new__' len 15, class name len 26; wave 265; new to extra142"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialnew142

  columns: [id, function, args, expected, description]
  rows:
    - [partial_new_qualname_eq,
       "partial.__new__.__qualname__.__eq__",
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — partial.__new__ is a builtin_function_or_method exposing the C tp_new slot; its __qualname__ is 'partial.__new__'; str.__eq__('partial.__new__') returns True; new to extra142"]
    - [partial_new_qualname_len_eq_15,
       "partial.__new__.__qualname__.__len__",
       [],
       15,
       "functools.partial.__new__.__qualname__.__len__() == 15 — __qualname__ is 'partial.__new__' which has 15 characters; len('partial.__new__') == 15; new to extra142"]
    - [partial_new_class_name_eq,
       "partial.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — partial.__new__ is a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra142"]
    - [partial_new_class_name_len_eq_26,
       "partial.__new__.__class__.__name__.__len__",
       [],
       26,
       "functools.partial.__new__.__class__.__name__.__len__() == 26 — __class__.__name__ is 'builtin_function_or_method' which has 26 characters; len('builtin_function_or_method') == 26; new to extra142"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial.__init__ — inherited from object
#
# Wave 265 theme: functools.partial.__init__ qualname — a surprising result.
#
# functools.partial.__init__.__qualname__ == 'object.__init__' (len 15)
# functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor' (len 18)
#
# partial does not define its own __init__; it inherits object.__init__.
# The qualname reflects the defining class: 'object.__init__'. New to extra142.
# ---------------------------------------------------------------------------

table functools_extra142.partial_init_inherited:
  description: "functools.partial.__init__: inherited from object; qualname=='object.__init__' len 15, class=='wrapper_descriptor' len 18; wave 265; new to extra142"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialinit142

  columns: [id, function, args, expected, description]
  rows:
    - [partial_init_qualname_eq,
       "partial.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "functools.partial.__init__.__qualname__.__eq__('object.__init__') == True — partial does not define its own __init__; it inherits object.__init__; the qualname is 'object.__init__' reflecting the defining class; str.__eq__('object.__init__') returns True; new to extra142"]
    - [partial_init_qualname_len_eq_15,
       "partial.__init__.__qualname__.__len__",
       [],
       15,
       "functools.partial.__init__.__qualname__.__len__() == 15 — __qualname__ is 'object.__init__' which has 15 characters; len('object.__init__') == 15; new to extra142"]
    - [partial_init_class_name_eq,
       "partial.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — the inherited object.__init__ is a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra142"]
    - [partial_reduce_qualname_eq,
       "partial.__reduce__.__qualname__.__eq__",
       ["partial.__reduce__"],
       true,
       "functools.partial.__reduce__.__qualname__.__eq__('partial.__reduce__') == True — partial.__reduce__ is a method_descriptor for pickle support; its __qualname__ is 'partial.__reduce__'; str.__eq__('partial.__reduce__') returns True; new to extra142"]
    - [partial_reduce_qualname_len_eq_18,
       "partial.__reduce__.__qualname__.__len__",
       [],
       18,
       "functools.partial.__reduce__.__qualname__.__len__() == 18 — __qualname__ is 'partial.__reduce__' which has 18 characters; len('partial.__reduce__') == 18; new to extra142"]
    - [partial_reduce_class_name_eq,
       "partial.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — partial.__reduce__ is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra142"]
    - [partial_setstate_qualname_eq,
       "partial.__setstate__.__qualname__.__eq__",
       ["partial.__setstate__"],
       true,
       "functools.partial.__setstate__.__qualname__.__eq__('partial.__setstate__') == True — partial.__setstate__ is a method_descriptor for pickle restore; its __qualname__ is 'partial.__setstate__'; str.__eq__('partial.__setstate__') returns True; new to extra142"]
    - [partial_setstate_qualname_len_eq_20,
       "partial.__setstate__.__qualname__.__len__",
       [],
       20,
       "functools.partial.__setstate__.__qualname__.__len__() == 20 — __qualname__ is 'partial.__setstate__' which has 20 characters; len('partial.__setstate__') == 20; new to extra142"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra142
# ---------------------------------------------------------------------------

invariant functools_extra142.partial_call_qualname_len:
  description: "len(functools.partial.__call__.__qualname__) == 16 — __qualname__ is 'partial.__call__'; wave 265; new to extra142"
  kind: python_call_eq
  function: partial.__call__.__qualname__.__len__
  args: []
  expected: 16

invariant functools_extra142.partial_call_is_wrapper_descriptor:
  description: "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' — partial.__call__ exposes the C tp_call slot; wave 265; new to extra142"
  kind: python_call_eq
  function: partial.__call__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra142.partial_new_qualname_len:
  description: "len(functools.partial.__new__.__qualname__) == 15 — __qualname__ is 'partial.__new__'; wave 265; new to extra142"
  kind: python_call_eq
  function: partial.__new__.__qualname__.__len__
  args: []
  expected: 15

invariant functools_extra142.partial_init_is_inherited_from_object:
  description: "functools.partial.__init__.__qualname__ == 'object.__init__' — partial does not define its own __init__; wave 265; new to extra142"
  kind: python_call_eq
  function: partial.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

invariant functools_extra142.partial_setstate_qualname_len:
  description: "len(functools.partial.__setstate__.__qualname__) == 20 — __qualname__ is 'partial.__setstate__'; wave 265; new to extra142"
  kind: python_call_eq
  function: partial.__setstate__.__qualname__.__len__
  args: []
  expected: 20
