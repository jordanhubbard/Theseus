spec: asyncio_extra1756
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "Theme: which asyncio stdlib types define __add__, __sub__, __mul__, __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__."
    - "asyncio.Future: async computation result container; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "asyncio.Task: subclass of Future for coroutine execution; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "asyncio.Lock: asyncio mutual-exclusion lock; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "asyncio.Event: asyncio event flag; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "asyncio.Semaphore: asyncio counting semaphore; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "asyncio.Queue: asyncio FIFO queue; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "Rationale: asyncio types model async execution state and synchronization, not numeric quantities."
    - "Complementary checks: asyncio.Future.__dict__.__contains__('set_result') -> True; asyncio.Future.__dict__.__contains__('add_done_callback') -> True; asyncio.iscoroutine.__class__.__name__ -> 'function'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for asyncio types
#
# Wave 564 theme: which asyncio types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# asyncio.Future: tracks the state and result of an asynchronous operation
#   submitted to an event loop. It holds references to callbacks and to a
#   single result value (or exception). It is not a numeric type and has no
#   arithmetic operators in its own __dict__.
# asyncio.Task: wraps a coroutine in the event loop, inheriting from Future.
#   It adds coroutine scheduling semantics but no arithmetic operators.
# asyncio.Lock, asyncio.Event, asyncio.Semaphore, asyncio.Queue: synchronization
#   primitives modelled after their threading counterparts; purely boolean/
#   counter semantics, no arithmetic operators in __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra1756.arithmetic_operators:
  description: "asyncio types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1756

  columns: [id, function, args, expected]
  rows:
    - ["as1756001", "asyncio.Future.__dict__.__contains__",    ["__add__"],      false]
    - ["as1756002", "asyncio.Future.__dict__.__contains__",    ["__sub__"],      false]
    - ["as1756003", "asyncio.Future.__dict__.__contains__",    ["__mul__"],      false]
    - ["as1756004", "asyncio.Future.__dict__.__contains__",    ["__truediv__"],  false]
    - ["as1756005", "asyncio.Future.__dict__.__contains__",    ["__floordiv__"], false]
    - ["as1756006", "asyncio.Future.__dict__.__contains__",    ["__pow__"],      false]
    - ["as1756007", "asyncio.Future.__dict__.__contains__",    ["__neg__"],      false]
    - ["as1756008", "asyncio.Future.__dict__.__contains__",    ["__pos__"],      false]
    - ["as1756009", "asyncio.Task.__dict__.__contains__",      ["__add__"],      false]
    - ["as1756010", "asyncio.Task.__dict__.__contains__",      ["__sub__"],      false]
    - ["as1756011", "asyncio.Task.__dict__.__contains__",      ["__mul__"],      false]
    - ["as1756012", "asyncio.Task.__dict__.__contains__",      ["__neg__"],      false]
    - ["as1756013", "asyncio.Lock.__dict__.__contains__",      ["__add__"],      false]
    - ["as1756014", "asyncio.Lock.__dict__.__contains__",      ["__mul__"],      false]
    - ["as1756015", "asyncio.Event.__dict__.__contains__",     ["__add__"],      false]
    - ["as1756016", "asyncio.Semaphore.__dict__.__contains__", ["__add__"],      false]
    - ["as1756017", "asyncio.Queue.__dict__.__contains__",     ["__add__"],      false]
    - ["as1756018", "asyncio.Task.__dict__.__contains__",      ["__truediv__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for asyncio Future methods and module functions
#
# The arithmetic theme is all-False for asyncio types. These complementary
# checks confirm genuine asyncio-specific attributes:
# - asyncio.Future.__dict__ contains 'set_result' (core method for resolving
#   a Future with a value from outside the coroutine machinery).
# - asyncio.Future.__dict__ contains 'add_done_callback' (register a callback
#   to be invoked when the Future transitions to a done state).
# - asyncio.iscoroutine is a plain Python function (not a builtin_function_or_method),
#   confirmed by __class__.__name__ == 'function'.
# - asyncio.Task.__dict__ contains 'cancel' (Task-specific cancellation hook).
# - asyncio.Task.__dict__ contains 'get_coro' (Task-specific; returns wrapped coro).
# These checks are distinct from all prior asyncio wave specs and provide
# meaningful signal about asyncio's public API surface.
# ---------------------------------------------------------------------------

table asyncio_extra1756.complementary_checks:
  description: "asyncio Future method presence and iscoroutine class name — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1756

  columns: [id, function, args, expected]
  rows:
    - ["as1756019", "asyncio.Future.__dict__.__contains__",            ["set_result"],        true]
    - ["as1756020", "asyncio.Future.__dict__.__contains__",            ["add_done_callback"], true]
    - ["as1756021", "asyncio.iscoroutine.__class__.__name__.__eq__",   ["function"],          true]
    - ["as1756022", "asyncio.Task.__dict__.__contains__",              ["cancel"],            true]
    - ["as1756023", "asyncio.Task.__dict__.__contains__",              ["get_coro"],          true]
    - ["as1756024", "asyncio.Future.__dict__.__contains__",            ["__floordiv__"],      false]
    - ["as1756025", "asyncio.Semaphore.__dict__.__contains__",         ["__pow__"],           false]
