spec: uu_extra2
version: ">=3.9,<3.13"
backend: python_module(uu)

docs: https://docs.python.org/3/library/uu.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uu.html — Python uu documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uu.py"
  notes:
    - "This spec extends uu.zspec.zsdl and uu_extra.zspec.zsdl."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — encode, decode, Error
# ---------------------------------------------------------------------------

invariant uu_extra2.encode.qualname:
  description: "uu.encode.__qualname__ == 'encode'"
  category: function_names
  kind: python_call_eq
  function: encode.__qualname__.__eq__
  args: ["encode"]
  expected: true

invariant uu_extra2.decode.qualname:
  description: "uu.decode.__qualname__ == 'decode'"
  category: function_names
  kind: python_call_eq
  function: decode.__qualname__.__eq__
  args: ["decode"]
  expected: true

invariant uu_extra2.Error.qualname:
  description: "uu.Error.__qualname__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# Error.__module__ — Error is defined in the uu namespace
# (complements uu.Error.module in uu.zspec.zsdl and uu_extra.zspec.zsdl
#  by verifying via __qualname__ that no nesting exists)
# ---------------------------------------------------------------------------

invariant uu_extra2.Error.module_via_qualname:
  description: "uu.Error.__qualname__ has no dots — Error is a top-level class in uu"
  category: classnames
  kind: python_call_eq
  function: Error.__qualname__.__contains__
  args: ["."]
  expected: false

# ---------------------------------------------------------------------------
# Error.__bases__[0].__name__ == 'Exception'
# (different approach: check via __bases__.__len__ == 1 — single direct base)
# ---------------------------------------------------------------------------

invariant uu_extra2.Error.bases_length:
  description: "uu.Error.__bases__ has exactly one entry — Error has a single direct base"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Error.__bases__[0].__name__ via __qualname__ — qualname of parent is 'Exception'
# ---------------------------------------------------------------------------

invariant uu_extra2.Error.base_qualname:
  description: "uu.Error.__bases__[0].__qualname__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __qualname__
  method_args: []
  expected: "Exception"
