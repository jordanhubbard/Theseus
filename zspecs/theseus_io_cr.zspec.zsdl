spec: theseus_io_cr
version: ">=3.0"
backend: python_cleanroom(theseus_io_cr)
blocks: io

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "Clean-room io module. Do NOT import io."

error_model: python_exceptions

invariant theseus_io_cr.io2_bytesio:
  description: "BytesIO read/write works"
  category: behavior
  kind: python_call_eq
  function: io2_bytesio
  args: []
  expected: true

invariant theseus_io_cr.io2_stringio:
  description: "StringIO read/write works"
  category: behavior
  kind: python_call_eq
  function: io2_stringio
  args: []
  expected: true

invariant theseus_io_cr.io2_open:
  description: "open() creates file objects"
  category: behavior
  kind: python_call_eq
  function: io2_open
  args: []
  expected: true
