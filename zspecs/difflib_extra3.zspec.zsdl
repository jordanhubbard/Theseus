spec: difflib_extra3
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "Python 3 difflib documentation — https://docs.python.org/3/library/difflib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "Extends difflib.zspec.zsdl, difflib_extra.zspec.zsdl, and difflib_extra2.zspec.zsdl."
    - "difflib.zspec.zsdl covers: SequenceMatcher ratio/find_longest tables, get_close_matches table (appel/xyz/apple/orange vectors), IS_CHARACTER_JUNK table, IS_LINE_JUNK table, Differ/unified_diff/context_diff/ndiff/restore function names, get_close_matches high-cutoff, SequenceMatcher get_matching_blocks/get_opcodes, Differ/__name__, HtmlDiff/__name__."
    - "difflib_extra.zspec.zsdl covers: SequenceMatcher/__name__/__module__, Differ/__name__, HtmlDiff/__name__, unified_diff/__name__, context_diff/__name__, ndiff/__name__, get_close_matches/__name__, behavioral get_close_matches vectors."
    - "difflib_extra2.zspec.zsdl covers: SequenceMatcher/Differ/HtmlDiff __name__ table, base class checks (all subclass object), function_modules table (unified_diff/ndiff/context_diff/get_close_matches __module__), unified_diff first line, ndiff identical line prefix, IS_LINE_JUNK/__name__, IS_CHARACTER_JUNK/__name__, SequenceMatcher.ratio_identical."
    - "This spec adds: __qualname__ for SequenceMatcher/Differ/HtmlDiff/ndiff/unified_diff/context_diff/get_close_matches/restore, __module__ standalone invariants for SequenceMatcher and get_close_matches, and get_close_matches('appel',['ape','apple','peach','puppy'])==['apple','ape']."
    - "difflib.get_close_matches('appel', ['ape', 'apple', 'peach', 'puppy']) — word list includes 'ape' which was NOT in the base spec's ['apple','peach','puppy']. Result is ['apple','ape'] (n=3 default, cutoff=0.6 default)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table — classes: SequenceMatcher, Differ, HtmlDiff
#
# Module-level classes have __qualname__ equal to __name__.
# No existing difflib spec covers __qualname__ for any class or function.
# ---------------------------------------------------------------------------

table difflib_extra3.qualnames.classes:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [SequenceMatcher, SequenceMatcher.__qualname__.__eq__, ["SequenceMatcher"], true]
    - [Differ,          Differ.__qualname__.__eq__,          ["Differ"],          true]
    - [HtmlDiff,        HtmlDiff.__qualname__.__eq__,        ["HtmlDiff"],        true]

# ---------------------------------------------------------------------------
# __qualname__ table — functions: ndiff, unified_diff, context_diff,
#                                 get_close_matches, restore
#
# Module-level generator functions and plain functions all have __qualname__
# equal to their simple name.
# ---------------------------------------------------------------------------

table difflib_extra3.qualnames.functions:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ndiff,             ndiff.__qualname__.__eq__,             ["ndiff"],             true]
    - [unified_diff,      unified_diff.__qualname__.__eq__,      ["unified_diff"],      true]
    - [context_diff,      context_diff.__qualname__.__eq__,      ["context_diff"],      true]
    - [get_close_matches, get_close_matches.__qualname__.__eq__, ["get_close_matches"], true]
    - [restore,           restore.__qualname__.__eq__,           ["restore"],           true]

# ---------------------------------------------------------------------------
# __module__ standalone invariants
#
# difflib_extra covers SequenceMatcher.__module__ as a standalone invariant.
# difflib_extra2 covers get_close_matches.__module__ in a table.
# We add standalone invariants here under the extra3 spec prefix.
# ---------------------------------------------------------------------------

invariant difflib_extra3.SequenceMatcher.module:
  description: "difflib.SequenceMatcher.__module__ == 'difflib'"
  category: modules
  kind: python_call_eq
  function: SequenceMatcher.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra3.get_close_matches.module:
  description: "difflib.get_close_matches.__module__ == 'difflib'"
  category: modules
  kind: python_call_eq
  function: get_close_matches.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral: get_close_matches('appel', ['ape', 'apple', 'peach', 'puppy'])
#
# The word list includes 'ape' which was NOT in difflib.zspec.zsdl's vector
# ['apple', 'peach', 'puppy']. With default n=3 and cutoff=0.6, both 'apple'
# and 'ape' score above the cutoff; 'apple' ranks higher than 'ape'.
# Result is ['apple', 'ape'].
# ---------------------------------------------------------------------------

invariant difflib_extra3.get_close_matches.appel_with_ape:
  description: "get_close_matches('appel', ['ape', 'apple', 'peach', 'puppy']) == ['apple', 'ape']"
  category: close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["appel", ["ape", "apple", "peach", "puppy"]]
  expected: ["apple", "ape"]
