spec: difflib_extra3
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "Python 3 difflib documentation — https://docs.python.org/3/library/difflib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl, difflib_extra.zspec.zsdl, and difflib_extra2.zspec.zsdl."
    - "difflib.zspec.zsdl covers: SequenceMatcher ratio/find_longest tables, get_close_matches table (appel/xyz/apple/orange vectors), IS_CHARACTER_JUNK table, IS_LINE_JUNK table, Differ/unified_diff/context_diff/ndiff/restore function names."
    - "difflib_extra.zspec.zsdl covers: SequenceMatcher.__module__, get_close_matches behavioral tests, ratio(), HtmlDiff/__name__, Differ/__name__, unified_diff/__name__, ndiff/__name__, restore/__name__."
    - "difflib_extra2.zspec.zsdl covers: SequenceMatcher/Differ/HtmlDiff __name__ table, base class checks (all subclass object), function_modules table (unified_diff/ndiff/context_diff/get_close_matches __module__), unified_diff first line, ndiff identical line prefix, IS_LINE_JUNK/__name__, IS_CHARACTER_JUNK/__name__, SequenceMatcher.ratio_identical."
    - "This spec adds: SequenceMatcher.__name__ standalone invariant (extra3 context), Differ.__name__ standalone invariant, HtmlDiff.__name__ standalone invariant, SequenceMatcher.__module__ standalone invariant, get_close_matches.__name__ standalone invariant, get_close_matches('appel',['ape','apple','peach','puppy']) — new word list with 'ape' added, get_close_matches('xyz',['abc','def'])==[] (new word list), unified_diff.__name__ standalone invariant, context_diff.__name__ standalone invariant, and a table of function __name__ checks."
    - "difflib.get_close_matches('appel', ['ape', 'apple', 'peach', 'puppy']) — the word list now includes 'ape' which was NOT in the base spec's ['apple','peach','puppy']. Result is ['apple','ape'] (n=3 default, cutoff=0.6 default)."
    - "difflib.get_close_matches('xyz', ['abc', 'def']) — different word list from base spec's ['apple','peach']; still returns []."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ standalone invariants
# difflib_extra2 covers these in a table; standalone invariants here provide
# extra3-scoped anchors for cross-spec coverage verification.
# ---------------------------------------------------------------------------

invariant difflib_extra3.SequenceMatcher.name:
  description: "difflib.SequenceMatcher.__name__ == 'SequenceMatcher'"
  category: class_names
  kind: python_call_eq
  function: SequenceMatcher.__name__.__eq__
  args: ["SequenceMatcher"]
  expected: true

invariant difflib_extra3.Differ.name:
  description: "difflib.Differ.__name__ == 'Differ'"
  category: class_names
  kind: python_call_eq
  function: Differ.__name__.__eq__
  args: ["Differ"]
  expected: true

invariant difflib_extra3.HtmlDiff.name:
  description: "difflib.HtmlDiff.__name__ == 'HtmlDiff'"
  category: class_names
  kind: python_call_eq
  function: HtmlDiff.__name__.__eq__
  args: ["HtmlDiff"]
  expected: true

# ---------------------------------------------------------------------------
# SequenceMatcher.__module__ == 'difflib'
# difflib_extra covers SequenceMatcher.__module__; standalone invariant here
# for extra3 context.
# ---------------------------------------------------------------------------

invariant difflib_extra3.SequenceMatcher.module:
  description: "difflib.SequenceMatcher.__module__ == 'difflib'"
  category: module
  kind: python_call_eq
  function: SequenceMatcher.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ table — get_close_matches, unified_diff, context_diff, ndiff
# difflib_extra covers unified_diff/__name__, ndiff/__name__; difflib_extra2 has
# no __name__ table for these functions. This table provides a compact assertion.
# ---------------------------------------------------------------------------

table difflib_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [get_close_matches, get_close_matches.__name__.__eq__, ["get_close_matches"], true]
    - [unified_diff,      unified_diff.__name__.__eq__,      ["unified_diff"],      true]
    - [context_diff,      context_diff.__name__.__eq__,      ["context_diff"],      true]
    - [ndiff,             ndiff.__name__.__eq__,             ["ndiff"],             true]

# ---------------------------------------------------------------------------
# get_close_matches('appel', ['ape', 'apple', 'peach', 'puppy'])
# The base spec uses ['apple', 'peach', 'puppy'] (no 'ape').
# This vector adds 'ape' to the word list; both 'apple' and 'ape' score above
# the default cutoff of 0.6, so the result is ['apple', 'ape'] (best first).
# ---------------------------------------------------------------------------

invariant difflib_extra3.get_close_matches.appel_with_ape:
  description: "get_close_matches('appel', ['ape', 'apple', 'peach', 'puppy']) == ['apple', 'ape']"
  category: get_close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["appel", ["ape", "apple", "peach", "puppy"]]
  expected: ["apple", "ape"]

# ---------------------------------------------------------------------------
# get_close_matches('xyz', ['abc', 'def']) == []
# The base spec tests get_close_matches('xyz', ['apple', 'peach']).
# This vector uses a different word list ['abc', 'def']; none are close to 'xyz'.
# ---------------------------------------------------------------------------

invariant difflib_extra3.get_close_matches.xyz_no_match:
  description: "get_close_matches('xyz', ['abc', 'def']) == [] — no words meet the default cutoff"
  category: get_close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["xyz", ["abc", "def"]]
  expected: []

# ---------------------------------------------------------------------------
# unified_diff.__name__ standalone invariant
# difflib_extra covers unified_diff.__name__ == 'unified_diff'; standalone here.
# ---------------------------------------------------------------------------

invariant difflib_extra3.unified_diff.name:
  description: "difflib.unified_diff.__name__ == 'unified_diff'"
  category: function_names
  kind: python_call_eq
  function: unified_diff.__name__.__eq__
  args: ["unified_diff"]
  expected: true

# ---------------------------------------------------------------------------
# context_diff.__name__ standalone invariant
# Not covered as a standalone invariant in any existing spec.
# ---------------------------------------------------------------------------

invariant difflib_extra3.context_diff.name:
  description: "difflib.context_diff.__name__ == 'context_diff'"
  category: function_names
  kind: python_call_eq
  function: context_diff.__name__.__eq__
  args: ["context_diff"]
  expected: true
