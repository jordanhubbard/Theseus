spec: inspect_extra1246
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect __doc__ class checks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 530 (_extra1246): checks that inspect module, classes, and functions have str __doc__ attributes."
    - "inspect.__doc__.__class__.__name__ == 'str' — module docstring is a str; verified Python 3.14.3."
    - "inspect.signature.__doc__.__class__.__name__ == 'str' — signature is a Python function with a str docstring; verified Python 3.14.3."
    - "inspect.Parameter.__doc__.__class__.__name__ == 'str' — Parameter is a Python class with a str docstring; verified Python 3.14.3."
    - "inspect.Signature.__doc__.__class__.__name__ == 'str' — Signature is a Python class with a str docstring; verified Python 3.14.3."
    - "inspect.isfunction.__doc__.__class__.__name__ == 'str' — isfunction is a Python function with a str docstring; verified Python 3.14.3."
    - "inspect.isclass.__doc__.__class__.__name__ == 'str' — isclass is a Python function with a str docstring; verified Python 3.14.3."
    - "inspect.ismodule.__doc__.__class__.__name__ == 'str' — ismodule is a Python function with a str docstring; verified Python 3.14.3."
    - "inspect.getmembers.__doc__.__class__.__name__ == 'str' — getmembers is a Python function with a str docstring; verified Python 3.14.3."
    - "inspect.getsource.__doc__.__class__.__name__ == 'str' — getsource is a Python function with a str docstring; verified Python 3.14.3."
    - "inspect.BoundArguments.__doc__.__class__.__name__ == 'str' — BoundArguments is a Python class with a str docstring; verified Python 3.14.3."
    - "inspect.FullArgSpec.__doc__.__class__.__name__ == 'str' — FullArgSpec is a Python namedtuple class with a str docstring; verified Python 3.14.3."
    - "inspect.ismethod.__doc__.__class__.__name__ == 'str' — ismethod is a Python function with a str docstring; verified Python 3.14.3."
    - "inspect.__doc__.__len__.__class__.__name__ == 'method-wrapper' — __len__ on a str is a C method-wrapper; verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect module and predicate functions __doc__ class == 'str'
#
# inspect.__doc__.__class__.__name__          == 'str'
# inspect.signature.__doc__.__class__.__name__ == 'str'
# inspect.isfunction.__doc__.__class__.__name__ == 'str'
# inspect.isclass.__doc__.__class__.__name__   == 'str'
# inspect.ismodule.__doc__.__class__.__name__  == 'str'
# inspect.ismethod.__doc__.__class__.__name__  == 'str'
#
# All are Python-implemented items in inspect.py with str docstrings.
# ---------------------------------------------------------------------------

table inspect_extra1246.module_and_predicate_doc_class:
  description: "inspect module and predicate functions have str __doc__: module/signature/isfunction/isclass/ismodule/ismethod; new to extra1246"
  kind: python_call_eq
  category: doc_class
  id_prefix: in1246mp

  columns: [id, function, args, expected, description]
  rows:
    - [in1246mp001,
       inspect.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__doc__.__class__.__name__.__eq__('str') == True — the inspect module docstring is a str; verified Python 3.14.3; new to extra1246"]
    - [in1246mp002,
       inspect.signature.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.signature.__doc__.__class__.__name__.__eq__('str') == True — signature is a Python function with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [in1246mp003,
       inspect.isfunction.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isfunction.__doc__.__class__.__name__.__eq__('str') == True — isfunction is a Python function with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [in1246mp004,
       inspect.isclass.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isclass.__doc__.__class__.__name__.__eq__('str') == True — isclass is a Python function with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [in1246mp005,
       inspect.ismodule.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.ismodule.__doc__.__class__.__name__.__eq__('str') == True — ismodule is a Python function with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [in1246mp006,
       inspect.ismethod.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.ismethod.__doc__.__class__.__name__.__eq__('str') == True — ismethod is a Python function with a str docstring; verified Python 3.14.3; new to extra1246"]

