# ---------------------------------------------------------------------------
# Table 3: inspect __doc__.__len__ structural class checks
#
# inspect.__doc__.__len__.__class__.__name__            == 'method-wrapper'
# inspect.signature.__doc__.__len__.__class__.__name__  == 'method-wrapper'
# inspect.Parameter.__doc__.__len__.__class__.__name__  == 'method-wrapper'
# inspect.Signature.__doc__.__len__.__class__.__name__  == 'method-wrapper'
# inspect.isfunction.__doc__.__len__.__class__.__name__ == 'method-wrapper'
# inspect.getsource.__doc__.__len__.__class__.__name__  == 'method-wrapper'
#
# str.__len__ is always a C method-wrapper. Verifies the structural class of
# the __len__ bound method on str docstrings, a wave-530 distinctive axis.
# ---------------------------------------------------------------------------

table inspect_extra1246.doc_len_method_class:
  description: "inspect __doc__.__len__.__class__.__name__ == 'method-wrapper' for module and key items; new to extra1246"
  kind: python_call_eq
  category: doc_len_class
  id_prefix: in1246dl

  columns: [id, function, args, expected, description]
  rows:
    - [in1246dl001,
       inspect.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "inspect.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — __len__ on a str instance is a C method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [in1246dl002,
       inspect.signature.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "inspect.signature.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — signature docstring __len__ is a method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [in1246dl003,
       inspect.Parameter.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "inspect.Parameter.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — Parameter docstring __len__ is a method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [in1246dl004,
       inspect.Signature.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "inspect.Signature.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — Signature docstring __len__ is a method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [in1246dl005,
       inspect.isfunction.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "inspect.isfunction.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — isfunction docstring __len__ is a method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [in1246dl006,
       inspect.getsource.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
