spec: decimal_extra270
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal.Clamped.__name__ == 'Clamped' and __module__ == 'decimal'."
    - "decimal.Clamped.__bases__[0].__name__ == 'DecimalException' — Clamped inherits directly from DecimalException."
    - "decimal.Inexact.__name__ == 'Inexact' and __module__ == 'decimal'."
    - "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact inherits directly from DecimalException."
    - "decimal.Rounded.__name__ == 'Rounded' and __module__ == 'decimal'."
    - "decimal.Rounded.__bases__[0].__name__ == 'DecimalException' — Rounded inherits directly from DecimalException."
    - "decimal.Subnormal.__name__ == 'Subnormal' and __module__ == 'decimal'."
    - "decimal.Subnormal.__bases__[0].__name__ == 'DecimalException' — Subnormal inherits directly from DecimalException."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — the root decimal exception inherits from ArithmeticError."
    - "All four exception classes (Clamped, Inexact, Rounded, Subnormal) have __class__.__name__ == 'type' — plain Python types."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: decimal.Clamped and decimal.Inexact class identity
# ---------------------------------------------------------------------------

table decimal_extra270.clamped_inexact_class_identity:
  description: "decimal.Clamped and decimal.Inexact __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: dci

  columns: [id, function, args, expected, description]
  rows:
    - [clamped_name,    Clamped.__name__.__eq__,                   ["Clamped"],          true, "decimal.Clamped.__name__ == 'Clamped'"]
    - [clamped_module,  Clamped.__module__.__eq__,                 ["decimal"],          true, "decimal.Clamped.__module__ == 'decimal'"]
    - [clamped_base,    "Clamped.__bases__[0].__name__.__eq__",    ["DecimalException"], true, "decimal.Clamped.__bases__[0].__name__ == 'DecimalException'"]
    - [clamped_meta,    Clamped.__class__.__name__.__eq__,         ["type"],             true, "decimal.Clamped.__class__.__name__ == 'type' — plain Python type"]
    - [inexact_name,    Inexact.__name__.__eq__,                   ["Inexact"],          true, "decimal.Inexact.__name__ == 'Inexact'"]
    - [inexact_module,  Inexact.__module__.__eq__,                 ["decimal"],          true, "decimal.Inexact.__module__ == 'decimal'"]
    - [inexact_base,    "Inexact.__bases__[0].__name__.__eq__",    ["DecimalException"], true, "decimal.Inexact.__bases__[0].__name__ == 'DecimalException'"]
    - [inexact_meta,    Inexact.__class__.__name__.__eq__,         ["type"],             true, "decimal.Inexact.__class__.__name__ == 'type' — plain Python type"]

# ---------------------------------------------------------------------------
# Table: decimal.Rounded and decimal.Subnormal class identity
# ---------------------------------------------------------------------------

table decimal_extra270.rounded_subnormal_class_identity:
  description: "decimal.Rounded and decimal.Subnormal __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: drs

  columns: [id, function, args, expected, description]
  rows:
    - [rounded_name,     Rounded.__name__.__eq__,                   ["Rounded"],          true, "decimal.Rounded.__name__ == 'Rounded'"]
    - [rounded_module,   Rounded.__module__.__eq__,                 ["decimal"],          true, "decimal.Rounded.__module__ == 'decimal'"]
    - [rounded_base,     "Rounded.__bases__[0].__name__.__eq__",    ["DecimalException"], true, "decimal.Rounded.__bases__[0].__name__ == 'DecimalException'"]
    - [rounded_meta,     Rounded.__class__.__name__.__eq__,         ["type"],             true, "decimal.Rounded.__class__.__name__ == 'type' — plain Python type"]
    - [subnorm_name,     Subnormal.__name__.__eq__,                 ["Subnormal"],        true, "decimal.Subnormal.__name__ == 'Subnormal'"]
    - [subnorm_module,   Subnormal.__module__.__eq__,               ["decimal"],          true, "decimal.Subnormal.__module__ == 'decimal'"]
    - [subnorm_base,     "Subnormal.__bases__[0].__name__.__eq__",  ["DecimalException"], true, "decimal.Subnormal.__bases__[0].__name__ == 'DecimalException'"]
    - [subnorm_meta,     Subnormal.__class__.__name__.__eq__,       ["type"],             true, "decimal.Subnormal.__class__.__name__ == 'type' — plain Python type"]

# ---------------------------------------------------------------------------
# Standalone invariants: DecimalException root and exception identity
# ---------------------------------------------------------------------------

invariant decimal_extra270.DecimalException.name:
  description: "decimal.DecimalException.__name__ == 'DecimalException'"
  category: identity
  kind: python_call_eq
  function: DecimalException.__name__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra270.DecimalException.module:
  description: "decimal.DecimalException.__module__ == 'decimal'"
  category: identity
  kind: python_call_eq
  function: DecimalException.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra270.DecimalException.base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — the root decimal exception inherits from ArithmeticError"
  category: identity
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra270.Clamped.name:
  description: "decimal.Clamped.__name__ == 'Clamped'"
  category: identity
  kind: python_call_eq
  function: Clamped.__name__.__eq__
  args: ["Clamped"]
  expected: true

invariant decimal_extra270.Clamped.base_is_DecimalException:
  description: "decimal.Clamped.__bases__[0].__name__ == 'DecimalException' — Clamped signals a value clamped to an exponent bound"
  category: identity
  kind: python_call_eq
  function: "Clamped.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra270.Inexact.base_is_DecimalException:
  description: "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact signals that a result was rounded"
  category: identity
  kind: python_call_eq
  function: "Inexact.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra270.Rounded.base_is_DecimalException:
  description: "decimal.Rounded.__bases__[0].__name__ == 'DecimalException' — Rounded signals that a result was rounded (possibly no information lost)"
  category: identity
  kind: python_call_eq
  function: "Rounded.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra270.Subnormal.base_is_DecimalException:
  description: "decimal.Subnormal.__bases__[0].__name__ == 'DecimalException' — Subnormal signals an exponent lower than Emin before rounding"
  category: identity
  kind: python_call_eq
  function: "Subnormal.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true
