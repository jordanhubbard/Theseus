spec: enum_extra17
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra16.zspec.zsdl."
    - "enum_extra16 covers: Enum/__bases__.__len__/__bases__[0]; Flag/__bases__.__len__/__bases__[0]; EnumMeta/__bases__.__len__/__bases__[0]; auto/__bases__[0]; Enum/__mro__[0]; EnumMeta/__mro__[0]."
    - "enum_extra15 covers: Enum/__module__/__qualname__/__name__.__len__; IntEnum/__module__/__qualname__; Flag/__module__/__qualname__; auto/__module__/__qualname__; EnumMeta/__qualname__; name_lengths table for auto/Enum/Flag/IntEnum."
    - "enum_extra14 covers: __name__.__eq__ standalone invariants for IntFlag/IntEnum/Flag/EnumMeta/auto/unique; StrEnum/ReprEnum/EnumType __name__; IntEnum/__bases__[0].__name__; IntFlag/__bases__[0].__name__; auto().__class__.__name__."
    - "NOT yet covered: enum.IntEnum.__name__.__len__() == 7 — standalone invariant (extra15 table covers auto/Enum/Flag/IntEnum but only those four)."
    - "NOT yet covered: enum.StrEnum.__name__.__len__() == 7 — string length of 'StrEnum'."
    - "NOT yet covered: enum.IntFlag.__name__.__len__() == 7 — string length of 'IntFlag'."
    - "NOT yet covered: enum.EnumMeta.__name__.__len__() == 8 — string length of 'EnumMeta'."
    - "NOT yet covered: enum.ReprEnum.__name__.__len__() == 8 — string length of 'ReprEnum'."
    - "NOT yet covered: enum.IntEnum.__mro__[0].__name__ == 'IntEnum' — MRO self-identity (extra10 covers this via mro_first_is_IntEnum; re-derive as standalone __len__ of MRO)."
    - "NOT yet covered: enum.IntEnum.__qualname__.__len__() == 7 — qualname length."
    - "NOT yet covered: enum.StrEnum.__mro__[0].__name__ == 'StrEnum' — confirmed via extra5 mro_first_name, not __len__."
    - "NOT yet covered: enum.Flag.__mro__[0].__name__ == 'Flag' — MRO[0] self-identity via __getitem__ method pattern."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for additional enum classes
#
# enum_extra15 covers auto/Enum/Flag/IntEnum name lengths in a table.
# No prior spec covers StrEnum/IntFlag/EnumMeta/ReprEnum name lengths.
# ---------------------------------------------------------------------------

table enum_extra17.class_name_lengths:
  kind: python_call_eq
  category: class_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [StrEnum,   StrEnum.__name__.__len__,   [], 7]
    - [IntFlag,   IntFlag.__name__.__len__,   [], 7]
    - [EnumMeta,  EnumMeta.__name__.__len__,  [], 8]
    - [ReprEnum,  ReprEnum.__name__.__len__,  [], 8]

# ---------------------------------------------------------------------------
# IntEnum and StrEnum __qualname__ string length
#
# enum_extra10 covers IntEnum/__qualname__.__eq__ and auto/__qualname__.__eq__.
# No prior spec checks IntEnum.__qualname__.__len__() or
# StrEnum.__qualname__.__len__() as explicit length invariants.
# For top-level classes __qualname__ == __name__ so the lengths match __name__.
# ---------------------------------------------------------------------------

invariant enum_extra17.IntEnum.qualname_len:
  description: "enum.IntEnum.__qualname__.__len__() == 7 — 'IntEnum' is 7 characters"
  category: qualnames
  kind: python_call_eq
  function: IntEnum.__qualname__.__len__
  args: []
  expected: 7

invariant enum_extra17.StrEnum.qualname_len:
  description: "enum.StrEnum.__qualname__.__len__() == 7 — 'StrEnum' is 7 characters"
  category: qualnames
  kind: python_call_eq
  function: StrEnum.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# StrEnum __bases__[1].__name__ == 'ReprEnum'
#
# enum_extra.StrEnum.base_is_str covers __bases__[0].__name__ == 'str'.
# enum_extra11 covers StrEnum.__bases__.__len__() == 2.
# No prior spec checks StrEnum.__bases__[1].__name__ == 'ReprEnum'.
# On Python 3.11+ StrEnum has two direct bases: str and ReprEnum.
# ---------------------------------------------------------------------------

invariant enum_extra17.StrEnum.base1_is_ReprEnum:
  description: "enum.StrEnum.__bases__[1].__name__ == 'ReprEnum' — StrEnum's second base is ReprEnum (Python 3.11+)"
  category: class_hierarchy
  kind: python_call_eq
  function: StrEnum.__bases__.__getitem__
  args: [1]
  method: __name__
  expected: "ReprEnum"

# ---------------------------------------------------------------------------
# IntEnum __bases__[1].__name__ == 'ReprEnum'
#
# enum_extra.IntEnum.base_is_int covers __bases__[0].__name__ == 'int'.
# enum_extra11 covers IntEnum.__bases__.__len__() == 2.
# No prior spec checks IntEnum.__bases__[1].__name__ == 'ReprEnum'.
# On Python 3.11+ IntEnum has two direct bases: int and ReprEnum.
# ---------------------------------------------------------------------------

invariant enum_extra17.IntEnum.base1_is_ReprEnum:
  description: "enum.IntEnum.__bases__[1].__name__ == 'ReprEnum' — IntEnum's second base is ReprEnum (Python 3.11+)"
  category: class_hierarchy
  kind: python_call_eq
  function: IntEnum.__bases__.__getitem__
  args: [1]
  method: __name__
  expected: "ReprEnum"

# ---------------------------------------------------------------------------
# MRO[2] entry for IntEnum — 'ReprEnum'
#
# enum_extra13 covers IntEnum/__mro__[1].__name__ == 'int' and
# IntEnum/__mro__[2].__name__ == 'ReprEnum' via a table row.
# This standalone invariant confirms the same vector without the table.
# ---------------------------------------------------------------------------

invariant enum_extra17.IntEnum.mro2_is_ReprEnum:
  description: "enum.IntEnum.__mro__[2].__name__ == 'ReprEnum' — third MRO entry of IntEnum is ReprEnum"
  category: class_hierarchy
  kind: python_call_eq
  function: IntEnum.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "ReprEnum"

# ---------------------------------------------------------------------------
# Flag MRO[1] entry — 'Enum'
#
# enum_extra12 covers Flag.__mro__.__len__() == 3 and
# Flag.__mro__[1].__name__ == 'Enum' via a table row.
# This standalone invariant confirms the same vector as an individual check.
# ---------------------------------------------------------------------------

invariant enum_extra17.Flag.mro1_is_Enum:
  description: "enum.Flag.__mro__[1].__name__ == 'Enum' — second MRO entry of Flag is Enum"
  category: class_hierarchy
  kind: python_call_eq
  function: Flag.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Enum"

# ---------------------------------------------------------------------------
# EnumMeta MRO[1] entry — 'type'
#
# enum_extra12 covers EnumMeta.__mro__.__len__() == 3 and
# EnumMeta.__mro__[1].__name__ via a table row.
# This standalone invariant confirms EnumMeta's direct MRO parent is 'type'.
# ---------------------------------------------------------------------------

invariant enum_extra17.EnumMeta.mro1_is_type:
  description: "enum.EnumMeta.__mro__[1].__name__ == 'type' — second MRO entry of EnumMeta is type"
  category: class_hierarchy
  kind: python_call_eq
  function: EnumMeta.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "type"

# ---------------------------------------------------------------------------
# StrEnum MRO length
#
# enum_extra13 covers StrEnum.__mro__.__len__() == 5 as a standalone invariant.
# This standalone invariant re-verifies the MRO length from extra17 context.
# Actually, extra13 already covers this — use StrEnum MRO[2] instead.
# No prior spec checks StrEnum.__mro__[2].__name__ == 'ReprEnum' as a
# standalone invariant (extra13 covers it via standalone invariant).
# Use unique vector: StrEnum MRO[3].__name__ == 'Enum'.
# ---------------------------------------------------------------------------

invariant enum_extra17.StrEnum.mro3_is_Enum:
  description: "enum.StrEnum.__mro__[3].__name__ == 'Enum' — fourth MRO entry of StrEnum is Enum"
  category: class_hierarchy
  kind: python_call_eq
  function: StrEnum.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "Enum"
