spec: audioop_extra
version: ">=3.9,<3.13"
backend: python_module(audioop)

docs: https://docs.python.org/3/library/audioop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/audioop.html — Python audioop module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/audioop.c"
    - "audioop.zspec.zsdl — covers error.__name__, error.__module__, error.__bases__[0].__name__, max/__name__, avg/__name__, rms/__name__, bias/__name__, reverse/__name__, and silent-fragment behavioral checks"
  notes:
    - "This spec extends audioop.zspec.zsdl."
    - "Deprecated since Python 3.11; removed in Python 3.13. Version constraint: >=3.9,<3.13."
    - "Focus: __qualname__ checks for audioop functions not yet covered, and __module__ for max."
    - "audioop is a C extension module; for C builtin_function_or_method objects, __qualname__ == __name__."
    - "audioop.zspec.zsdl covers __name__ for max/avg/rms/bias/reverse and error.__module__ and error base."
    - "New axes: __qualname__ for max, min, avg, add, mul, error; __module__ for max."
    - "audioop.min, audioop.add, audioop.mul are C extension functions not yet touched by any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "audioop.error is raised when arguments are invalid (e.g. wrong fragment size, bad width). It is a direct subclass of Exception."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# __qualname__ checks for audioop functions and error class
# audioop.zspec.zsdl covers __name__; __qualname__ is a distinct attribute.
# For C extension functions, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table audioop_extra.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [max, max.__qualname__.__eq__, ["max"], true]
    - [min, min.__qualname__.__eq__, ["min"], true]
    - [avg, avg.__qualname__.__eq__, ["avg"], true]
    - [add, add.__qualname__.__eq__, ["add"], true]
    - [mul, mul.__qualname__.__eq__, ["mul"], true]

invariant audioop_extra.error.qualname:
  description: "audioop.error.__qualname__ == 'error'"
  category: qualnames
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for max — confirms it is defined in the audioop C extension
# audioop.zspec.zsdl covers error.__module__; max.__module__ is not yet covered.
# ---------------------------------------------------------------------------

invariant audioop_extra.max.module:
  description: "audioop.max.__module__ == 'audioop'"
  category: modules
  kind: python_call_eq
  function: max.__module__.__eq__
  args: ["audioop"]
  expected: true
