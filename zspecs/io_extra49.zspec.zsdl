spec: io_extra49
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra48.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __mro__.__len__(); FileIO/BytesIO/StringIO __bases__[0].__name__."
    - "io_extra47.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__/__module__/__bases__[0].__name__."
    - "io_extra46.zspec.zsdl — covers BufferedWriter/__name__=='BufferedWriter'/__module__=='_io'; BufferedReader/__name__=='BufferedReader'/__module__=='_io'."
    - "io_extra36.zspec.zsdl — covers __mro__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/StringIO/BytesIO in a table."
    - "io_extra25.zspec.zsdl — covers FileIO/__bases__[0].__name__=='_RawIOBase'; StringIO/__bases__[0].__name__=='_TextIOBase'; BytesIO/__bases__[0].__name__=='_BufferedIOBase'."
    - "io_extra3.zspec.zsdl — covers FileIO/StringIO/BytesIO __bases__[0].__name__ equality."
  notes:
    - "This spec extends io_extra48.zspec.zsdl."
    - "Prior specs collectively covered: IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__/__module__/__bases__[0].__name__ and __mro__.__len__(); FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader __name__/__module__/__bases__[0].__name__; __qualname__ for none of the io classes was previously covered as a standalone equality check."
    - "This spec covers: io.IOBase.__qualname__=='IOBase' (NOVEL — no prior io spec checks IOBase.__qualname__; novel equality anchor in io_extra49 namespace); io.RawIOBase.__qualname__=='RawIOBase' (NOVEL); io.BufferedIOBase.__qualname__=='BufferedIOBase' (NOVEL); io.TextIOBase.__qualname__=='TextIOBase' (NOVEL); io.FileIO.__qualname__=='FileIO' (NOVEL); io.BytesIO.__qualname__=='BytesIO' (NOVEL); io.StringIO.__qualname__=='StringIO' (NOVEL); io.BufferedWriter.__qualname__=='BufferedWriter' (NOVEL); io.BufferedReader.__qualname__=='BufferedReader' (NOVEL)."
    - "io.IOBase.__qualname__ == 'IOBase'. The abstract base class for all I/O classes. __qualname__ equals the bare class name (no module prefix) for top-level classes. No prior io spec checks any io class __qualname__. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__qualname__ == 'RawIOBase'. Abstract base for raw binary I/O. __qualname__ == 'RawIOBase'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__qualname__ == 'BufferedIOBase'. Abstract base for buffered binary I/O. __qualname__ == 'BufferedIOBase'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__qualname__ == 'TextIOBase'. Abstract base for text I/O. __qualname__ == 'TextIOBase'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.__qualname__ == 'FileIO'. Concrete raw binary file I/O class. __qualname__ == 'FileIO'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.__qualname__ == 'BytesIO'. Concrete in-memory binary stream class. __qualname__ == 'BytesIO'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.__qualname__ == 'StringIO'. Concrete in-memory text stream class. __qualname__ == 'StringIO'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter'. Buffered binary write stream. __qualname__ == 'BufferedWriter'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__qualname__ == 'BufferedReader'. Buffered binary read stream. __qualname__ == 'BufferedReader'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __qualname__ attributes
#
# All top-level classes in the io module have __qualname__ equal to their
# bare class name (no module prefix). This is the standard behavior for
# classes defined at module scope.
#
# __qualname__ differs from __name__ only for nested classes or functions
# defined inside other classes/functions. For all io public classes, they
# are equivalent.
#
#   IOBase.__qualname__        == 'IOBase'
#   RawIOBase.__qualname__     == 'RawIOBase'
#   BufferedIOBase.__qualname__== 'BufferedIOBase'
#   TextIOBase.__qualname__    == 'TextIOBase'
#   FileIO.__qualname__        == 'FileIO'
#   BytesIO.__qualname__       == 'BytesIO'
#   StringIO.__qualname__      == 'StringIO'
#   BufferedWriter.__qualname__== 'BufferedWriter'
#   BufferedReader.__qualname__== 'BufferedReader'
#
# No prior io spec covers any io class __qualname__. All nine are novel
# equality anchors in the io_extra49 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra49.class_qualnames:
  description: "io class __qualname__ attributes: IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader — __qualname__ equals bare class name for all top-level io classes; no prior io spec checks any io class __qualname__; all nine novel equality anchors in io_extra49 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: icq49

  columns: [id, function, args, expected]
  rows:
    - [IOBase_qualname,        IOBase.__qualname__.__eq__,        ["IOBase"],         true]
    - [RawIOBase_qualname,     RawIOBase.__qualname__.__eq__,     ["RawIOBase"],      true]
    - [BufferedIOBase_qualname,BufferedIOBase.__qualname__.__eq__,["BufferedIOBase"], true]
    - [TextIOBase_qualname,    TextIOBase.__qualname__.__eq__,    ["TextIOBase"],     true]
    - [FileIO_qualname,        FileIO.__qualname__.__eq__,        ["FileIO"],         true]
    - [BytesIO_qualname,       BytesIO.__qualname__.__eq__,       ["BytesIO"],        true]
    - [StringIO_qualname,      StringIO.__qualname__.__eq__,      ["StringIO"],       true]
    - [BufferedWriter_qualname,BufferedWriter.__qualname__.__eq__,["BufferedWriter"], true]
    - [BufferedReader_qualname,BufferedReader.__qualname__.__eq__,["BufferedReader"], true]
