spec: abc_extra95
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra94

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra94.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc.ABCMeta method __qualname__ lengths and abc module-level function identities. NEW in extra95: ABCMeta.register.__qualname__=='ABCMeta.register' (len=16); ABCMeta._dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22); ABCMeta.__subclasshook__.__qualname__=='ABCMeta.__subclasshook__' (len=24); ABCMeta.__subclasshook__.__class__.__name__=='builtin_function_or_method' (C-level classmethod from _abc C extension); ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20); ABC.__subclasshook__.__class__.__name__=='builtin_function_or_method'; abc.abstractmethod.__qualname__=='abstractmethod' (len=14); abc.update_abstractmethods.__qualname__=='update_abstractmethods' (len=22); abc.update_abstractmethods.__class__.__name__=='function'; abc.get_cache_token.__qualname__=='get_cache_token' (len=15); abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (C-level from _abc extension); ABCMeta.__module__=='abc'; ABCMeta.__mro__.__len__()==3; ABC.__module__=='abc'; ABC.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. ABCMeta.__subclasshook__ is a C-level classmethod defined in Modules/_abc.c, unlike ABCMeta.register and ABCMeta._dump_registry which are Python functions defined in Lib/abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'. get_cache_token is a C-level function from Modules/_abc.c (module='_abc'), not a Python function from Lib/abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__mro__.__len__() == 3. ABCMeta's MRO is [ABCMeta, type, object] — ABCMeta is a metaclass that inherits from type. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta method __qualname__ lengths — extra95
#
# Wave 254 theme: abc.ABCMeta method qualname lengths and __subclasshook__
#                 C-level classmethod identity.
#
# ABCMeta.register.__qualname__          == 'ABCMeta.register'          (len=16)
# ABCMeta._dump_registry.__qualname__    == 'ABCMeta._dump_registry'    (len=22)
# ABCMeta.__subclasshook__.__qualname__  == 'ABCMeta.__subclasshook__'  (len=24)
# ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table abc_extra95.abc_abcmeta_qualname_lengths:
  description: "abc.ABCMeta method __qualname__ length checks in abcabcmetaqn95 namespace — wave 254 theme: ABCMeta method qualname lengths; ABCMeta is defined in Lib/abc.py with metaclass=type (ABCMeta.__bases__[0].__name__=='type', ABCMeta.__mro__.__len__()==3: [ABCMeta, type, object]); ABCMeta.register.__qualname__.__eq__('ABCMeta.register')==True (len=16: 'ABCMeta.'=8 + 'register'=8); ABCMeta.register.__qualname__.__len__()==16; ABCMeta._dump_registry.__qualname__.__eq__('ABCMeta._dump_registry')==True (len=22: 'ABCMeta.'=8 + '_dump_registry'=14); ABCMeta._dump_registry.__qualname__.__len__()==22; ABCMeta.__subclasshook__.__qualname__.__eq__('ABCMeta.__subclasshook__')==True (len=24: 'ABCMeta.'=8 + '__subclasshook__'=16); ABCMeta.__subclasshook__.__qualname__.__len__()==24; ABCMeta.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True (C-level classmethod from Modules/_abc.c, unlike register and _dump_registry which are Python functions with class='function'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmetaqn95

  columns: [id, function, args, expected, description]
  rows:
    - [reg_qeq,       "ABCMeta.register.__qualname__.__eq__",              ["ABCMeta.register"],         true, "ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); verified with Python 3.14.3"]
    - [reg_qlen,      "ABCMeta.register.__qualname__.__len__",             [],                           16,   "ABCMeta.register.__qualname__.__len__() == 16 ('ABCMeta.'=8 + 'register'=8); verified with Python 3.14.3"]
    - [dump_qeq,      "ABCMeta._dump_registry.__qualname__.__eq__",        ["ABCMeta._dump_registry"],   true, "ABCMeta._dump_registry.__qualname__ == 'ABCMeta._dump_registry' (len=22); verified with Python 3.14.3"]
    - [dump_qlen,     "ABCMeta._dump_registry.__qualname__.__len__",       [],                           22,   "ABCMeta._dump_registry.__qualname__.__len__() == 22 ('ABCMeta.'=8 + '_dump_registry'=14); verified with Python 3.14.3"]
    - [hook_qeq,      "ABCMeta.__subclasshook__.__qualname__.__eq__",      ["ABCMeta.__subclasshook__"], true, "ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24); verified with Python 3.14.3"]
    - [hook_qlen,     "ABCMeta.__subclasshook__.__qualname__.__len__",     [],                           24,   "ABCMeta.__subclasshook__.__qualname__.__len__() == 24 ('ABCMeta.'=8 + '__subclasshook__'=16); verified with Python 3.14.3"]
    - [hook_cls,      "ABCMeta.__subclasshook__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-level from _abc; verified with Python 3.14.3"]
    - [reg_cls,       "ABCMeta.register.__class__.__name__.__eq__",        ["function"],                 true, "ABCMeta.register.__class__.__name__ == 'function' — Python function in Lib/abc.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC class identity and __subclasshook__ — extra95
#
# ABC.__module__ == 'abc'
# ABC.__bases__[0].__name__ == 'object'
# ABC.__mro__.__len__() == 2    [ABC, object]
# ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20)
# ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table abc_extra95.abc_ABC_identity_subclasshook:
  description: "abc.ABC class identity and __subclasshook__ checks in abcabcmetaqn95 namespace — wave 254 theme: abc.ABC is the simple helper class that users inherit from to create ABCs without explicitly using ABCMeta; ABC.__module__.__eq__('abc')==True (defined in Lib/abc.py); ABC.__bases__[0].__name__.__eq__('object')==True (ABC inherits directly from object — it is a minimal stub class whose metaclass is ABCMeta); ABC.__mro__.__len__()==2 (MRO is [ABC, object], minimal depth — contrasts with ABCMeta.__mro__.__len__()==3 which includes type); ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__')==True (len=20: 'ABC.'=4 + '__subclasshook__'=16; 4 chars shorter than ABCMeta.__subclasshook__.__qualname__.__len__()==24 because 'ABC.'=4 vs 'ABCMeta.'=8); ABC.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True (same C-level classmethod from _abc as ABCMeta.__subclasshook__); ABC.__subclasshook__.__module__ is None (C-level, no Python module); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmetaqn95a

  columns: [id, function, args, expected, description]
  rows:
    - [abc_module,       "ABC.__module__.__eq__",                             ["abc"],                       true, "abc.ABC.__module__ == 'abc' — defined in Lib/abc.py; verified with Python 3.14.3"]
    - [abc_base0,        "ABC.__bases__[0].__name__.__eq__",                  ["object"],                    true, "abc.ABC.__bases__[0].__name__ == 'object' — inherits directly from object; verified with Python 3.14.3"]
    - [abc_mro_len,      "ABC.__mro__.__len__",                               [],                            2,    "abc.ABC.__mro__.__len__() == 2 — MRO is [ABC, object]; verified with Python 3.14.3"]
    - [abc_hook_qeq,     "ABC.__subclasshook__.__qualname__.__eq__",          ["ABC.__subclasshook__"],      true, "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20); verified with Python 3.14.3"]
    - [abc_hook_qlen,    "ABC.__subclasshook__.__qualname__.__len__",         [],                            20,   "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 (4 shorter than ABCMeta's len=24 because 'ABC.'=4 vs 'ABCMeta.'=8); verified with Python 3.14.3"]
    - [abc_hook_cls,     "ABC.__subclasshook__.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "abc.ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-level classmethod; verified with Python 3.14.3"]
    - [abcm_module,      "ABCMeta.__module__.__eq__",                         ["abc"],                       true, "abc.ABCMeta.__module__ == 'abc' — defined in Lib/abc.py; verified with Python 3.14.3"]
    - [abcm_mro_len,     "ABCMeta.__mro__.__len__",                           [],                            3,    "abc.ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module-level function qualnames — extra95
#
# abstractmethod.__qualname__          == 'abstractmethod'          (len=14)
# update_abstractmethods.__qualname__  == 'update_abstractmethods'  (len=22)
# get_cache_token.__qualname__         == 'get_cache_token'         (len=15)
# get_cache_token.__class__.__name__   == 'builtin_function_or_method'  (C-level)
# update_abstractmethods.__class__.__name__ == 'function'  (Python)
# ---------------------------------------------------------------------------

table abc_extra95.abc_module_function_qualnames:
  description: "abc module-level function qualname and class name checks in abcabcmetaqn95 namespace — wave 254 theme: abc module-level function identity; abc has a mix of Python functions (defined in Lib/abc.py) and C-level builtins (from Modules/_abc.c); abstractmethod is a Python function: abstractmethod.__qualname__.__eq__('abstractmethod')==True (len=14; module-level so qualname equals name); abstractmethod.__qualname__.__len__()==14; update_abstractmethods is a Python function (added in Python 3.10): update_abstractmethods.__qualname__.__eq__('update_abstractmethods')==True (len=22; same length as ABCMeta._dump_registry.__qualname__ at 22); update_abstractmethods.__class__.__name__.__eq__('function')==True (pure-Python function in Lib/abc.py); get_cache_token is a C-level function from _abc extension: get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15); get_cache_token.__class__.__name__.__eq__('builtin_function_or_method')==True (C-level, module='_abc', not 'abc'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmetaqn95b

  columns: [id, function, args, expected, description]
  rows:
    - [am_qeq,       "abc.abstractmethod.__qualname__.__eq__",            ["abstractmethod"],          true, "abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_qlen,      "abc.abstractmethod.__qualname__.__len__",           [],                          14,   "abc.abstractmethod.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [uam_qeq,      "abc.update_abstractmethods.__qualname__.__eq__",    ["update_abstractmethods"],  true, "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22); verified with Python 3.14.3"]
    - [uam_qlen,     "abc.update_abstractmethods.__qualname__.__len__",   [],                          22,   "abc.update_abstractmethods.__qualname__.__len__() == 22 (same as ABCMeta._dump_registry.__qualname__.__len__()); verified with Python 3.14.3"]
    - [uam_cls,      "abc.update_abstractmethods.__class__.__name__.__eq__", ["function"],             true, "abc.update_abstractmethods.__class__.__name__ == 'function' — Python function in Lib/abc.py; verified with Python 3.14.3"]
    - [gct_qeq,      "abc.get_cache_token.__qualname__.__eq__",           ["get_cache_token"],         true, "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_qlen,     "abc.get_cache_token.__qualname__.__len__",          [],                          15,   "abc.get_cache_token.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [gct_cls,      "abc.get_cache_token.__class__.__name__.__eq__",     ["builtin_function_or_method"], true, "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — C-level from _abc; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra95
# ---------------------------------------------------------------------------

invariant abc_extra95.ABCMeta_register_qualname_len_16:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — ABCMeta.register.__qualname__ is 'ABCMeta.register' (16 characters: 'ABCMeta.'=8 + 'register'=8); register is a Python function defined in Lib/abc.py (class='function'); register allows registering a class as a virtual subclass of an ABC; the 8+8 split makes register.__qualname__ a palindrome in terms of segment lengths; ABCMeta.register.__module__ is 'abc'; compare qualname lengths for ABCMeta methods: register=16 (both segments equal 8), _dump_registry=22, __subclasshook__=24; NEW in extra95: first standalone ABCMeta.register qualname length invariant in abcabcmetaqn95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.register.__qualname__.__len__"
  args: []
  expected: 16

invariant abc_extra95.ABCMeta_subclasshook_is_builtin:
  description: "abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') returns True — ABCMeta.__subclasshook__ is a C-level classmethod defined in Modules/_abc.c (the '_abc' C extension), unlike ABCMeta.register and ABCMeta._dump_registry which are Python functions (class='function') defined in Lib/abc.py; ABCMeta.__subclasshook__ is called by ABCMeta.__subclasscheck__ to allow ABCs to override the issubclass() builtin; ABCMeta.__subclasshook__.__qualname__ is 'ABCMeta.__subclasshook__' (len=24, the longest ABCMeta method qualname); ABCMeta.__subclasshook__.__module__ is None (C-level, no Python module); ABC.__subclasshook__ is the same C-level classmethod (qualname='ABC.__subclasshook__', len=20); NEW in extra95: first standalone ABCMeta.__subclasshook__ class name invariant in abcabcmetaqn95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__subclasshook__.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra95.ABC_subclasshook_qualname_len_20:
  description: "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 — ABC.__subclasshook__.__qualname__ is 'ABC.__subclasshook__' (20 characters: 'ABC.'=4 + '__subclasshook__'=16); this is 4 chars shorter than ABCMeta.__subclasshook__.__qualname__.__len__()==24 because 'ABC.' is 4 chars vs 'ABCMeta.' is 8 chars; ABC is the simple user-facing base class (module='abc', MRO=[ABC, object], depth=2) while ABCMeta is the metaclass (module='abc', MRO=[ABCMeta, type, object], depth=3); ABC.__subclasshook__.__class__.__name__ is 'builtin_function_or_method' (same C-level implementation as ABCMeta.__subclasshook__); ABC.__subclasshook__.__module__ is None; NEW in extra95: first standalone ABC.__subclasshook__ qualname length invariant in abcabcmetaqn95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABC.__subclasshook__.__qualname__.__len__"
  args: []
  expected: 20

invariant abc_extra95.get_cache_token_is_builtin:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — abc.get_cache_token is a C-level function from the '_abc' C extension (Modules/_abc.c); its module is '_abc' (with underscore prefix), NOT 'abc' (the public module); this parallels asyncio.Task.__module__=='_asyncio' (the C extension with underscore prefix vs the public 'asyncio' package); get_cache_token.__qualname__ is 'get_cache_token' (len=15); get_cache_token returns an opaque token that changes every time an ABC's class hierarchy is modified (used for invalidating issubclass() caches); in contrast, abc.update_abstractmethods has class='function' (pure-Python, module='abc', not '_abc'); NEW in extra95: first standalone get_cache_token class name invariant in abcabcmetaqn95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.get_cache_token.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra95.update_abstractmethods_qualname_len_22:
  description: "abc.update_abstractmethods.__qualname__.__len__() == 22 — abc.update_abstractmethods.__qualname__ is 'update_abstractmethods' (22 characters); this is a module-level Python function so its qualname equals its name; update_abstractmethods.__class__.__name__ is 'function' (pure-Python, defined in Lib/abc.py); len('update_abstractmethods')==22, the same length as ABCMeta._dump_registry.__qualname__.__len__()==22 ('ABCMeta._dump_registry'); update_abstractmethods (added in Python 3.10) recalculates a class's __abstractmethods__ frozenset to reflect any concrete implementations added after class creation; update_abstractmethods.__module__ is 'abc'; contrasts with get_cache_token which is a C-level builtin from '_abc'; NEW in extra95: first standalone update_abstractmethods qualname length invariant in abcabcmetaqn95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.update_abstractmethods.__qualname__.__len__"
  args: []
  expected: 22
