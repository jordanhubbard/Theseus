spec: struct_extra60
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra59.zspec.zsdl — covers unpack.__doc__.__contains__('unpack') / unpack.__doc__.__contains__('tuple') / calcsize.__doc__.__contains__('size') / calcsize.__doc__.__contains__('format') / Struct.__doc__.__contains__('compiled') / Struct.__doc__.__contains__('object') / pack.__doc__.__len__()==176 (table + invariants)."
    - "struct_extra58.zspec.zsdl — covers struct.__doc__.__contains__('struct') / error.__doc__.__class__.__name__.__eq__('NoneType') / pack.__doc__.__class__.__name__.__eq__('str') / unpack.__doc__.__contains__('format') (table + invariants)."
    - "struct_extra57.zspec.zsdl — covers struct.__doc__.__class__.__name__.__eq__('str') / Struct.__doc__.__contains__('Struct') / Struct.__doc__.__contains__('fmt') / error.__doc__.__class__.__name__.__len__()==8 / pack.__doc__.__contains__('format') (table + invariants)."
    - "struct_extra56.zspec.zsdl — covers Struct.__init_subclass__/__subclasshook__/__getattribute__/__delattr__/__setattr__ __qualname__.__eq__ string values (table + invariants)."
    - "struct_extra55.zspec.zsdl — covers struct.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "struct_extra11.zspec.zsdl — covers struct.error.__module__.__eq__('struct') and Struct.__module__.__eq__('_struct') as standalone invariants."
    - "struct_extra8.zspec.zsdl — covers function __module__ (all '_struct' except error 'struct'); pack return type/length for '>I'/'>H'; calcsize('>IHB'); unpack('>H',0100); Struct('>IHB') format/size; calcsize('>Q')."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra59; it does NOT duplicate invariants present in those files."
    - "Wave 231 theme: struct.error exception hierarchy + identity checks, and docstring class identity for C builtins."
    - "struct module-level functions (pack, unpack, pack_into, unpack_from, iter_unpack, calcsize) are all C builtin_function_or_method objects from _struct — they do NOT have __code__ attributes. Wave 231 for struct therefore covers error hierarchy and module/class identity chains."
    - "struct.error.__bases__[0].__name__ == 'Exception' — struct.error is a C extension exception type that subclasses Exception. struct_extra11 checks error.__module__.__eq__('struct') (module axis). No prior struct spec checks error.__bases__[0].__name__ or error.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__.__len__() == 4 — the MRO for struct.error is [struct.error, Exception, BaseException, object], which has 4 entries. No prior struct spec checks error.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__.__eq__('struct') — struct_extra11 already anchors this. This spec does NOT re-check error.__module__ to avoid duplication. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__.__eq__('error') == True — the qualified name of struct.error is simply 'error' (not 'struct.error'), since it is a top-level class in the struct module. No prior struct spec checks error.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pack.__doc__.__class__.__name__.__eq__('str') — struct_extra58 already checks this. This spec does NOT re-check pack.__doc__.__class__.__name__ to avoid duplication."
    - "unpack.__doc__.__class__.__name__.__eq__('str') and calcsize.__doc__.__class__.__name__.__eq__('str') — no prior struct spec checks unpack or calcsize docstring class name (struct_extra58 only checks pack). These are new anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__contains__('format') — struct_extra57 checks __contains__('fmt') (abbreviated form). This spec checks 'format' (the full word) which is a distinct check since 'format' and 'fmt' are different strings and __contains__('format') may differ from __contains__('fmt') depending on the docstring content. Actually Struct.__doc__ == 'Struct(fmt) --> compiled struct object\\n\\n' which does NOT contain 'format' (only 'fmt'). Therefore this check would be False. Use Struct.__doc__.__contains__('fmt') instead — but that is already covered by struct_extra57. So use a different invariant: check pack.__doc__.__contains__('struct') which verifies the domain term. pack.__doc__ starts 'Return bytes object according to the given format string fmt and the given values v1, v2, ... See help(struct) for more on format strings.' The word 'struct' appears. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error exception hierarchy — __bases__ and __mro__ length
#
# Wave 231 theme: struct.error exception class hierarchy checks.
#
# struct.error subclasses Exception. Its MRO is:
# [struct.error, Exception, BaseException, object] — length 4.
# struct_extra11 checks error.__module__.__eq__('struct') (module axis only).
# No prior struct spec checks error.__bases__[0].__name__ or
# error.__mro__.__len__(). The [0] subscript in the bases chain requires
# double-quoting in table rows. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra60.struct_error_hierarchy:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') and error.__mro__.__len__()==4 — struct.error subclasses Exception; MRO is [struct.error, Exception, BaseException, object] with 4 entries; struct_extra11 checks error.__module__ (module axis only); no prior struct spec checks error.__bases__[0].__name__ or error.__mro__.__len__(); first exception hierarchy anchor for struct.error"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: structid2_60

  columns: [id, function, args, expected]
  rows:
    - [error_bases_0_exception, "error.__bases__[0].__name__.__eq__", ["Exception"], true]
    - [error_mro_len_4,         error.__mro__.__len__,               [],             4]

# ---------------------------------------------------------------------------
# struct.error identity checks — __qualname__
#
# Wave 231 theme: struct.error class identity beyond module axis.
#
# struct.error.__qualname__ == 'error' — the qualified name of the exception
# class is 'error' (its short name, since it is defined at module top level).
# struct_extra11 covers error.__module__.__eq__('struct').
# No prior struct spec checks error.__qualname__. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra60.struct_error_identity:
  description: "struct.error.__qualname__.__eq__('error') — struct.error is a top-level class in the struct C extension so its __qualname__ is 'error' (not 'struct.error'); struct_extra11 covers error.__module__.__eq__('struct'); no prior struct spec checks error.__qualname__; complementary identity anchor for struct.error"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: structid2_60

  columns: [id, function, args, expected]
  rows:
    - [error_qualname_error, error.__qualname__.__eq__, ["error"], true]

# ---------------------------------------------------------------------------
# struct.unpack and calcsize __doc__ class name
#
# Wave 231 theme: docstring type identity for C builtins not yet checked.
#
# struct_extra58 checks pack.__doc__.__class__.__name__.__eq__('str') but
# does NOT check unpack or calcsize on the __class__.__name__ axis. All C
# builtin docstrings are str instances. This table adds unpack and calcsize.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra60.docstring_class_name:
  description: "struct.unpack.__doc__.__class__.__name__.__eq__('str') and calcsize.__doc__.__class__.__name__.__eq__('str') — all C builtin_function_or_method docstrings are str instances; struct_extra58 checks pack.__doc__.__class__.__name__.__eq__('str') but not unpack or calcsize; no prior struct spec checks unpack or calcsize docstring class name; complementary type identity anchors for unpack and calcsize"
  kind: python_call_eq
  category: docstrings
  id_prefix: structid2_60

  columns: [id, function, args, expected]
  rows:
    - [unpack_doc_class_str,   unpack.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [calcsize_doc_class_str, calcsize.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# struct.pack __doc__ contains 'struct' — domain term anchor
#
# Wave 231 theme: docstring content for C builtin pack.
#
# struct.pack.__doc__ begins 'Return bytes object according to the given
# format string fmt and the given values v1, v2, ... See help(struct) for
# more on format strings.' The word 'struct' appears in 'help(struct)'.
# struct_extra57 checks pack.__doc__.__contains__('format') (wave 228).
# struct_extra59 checks pack.__doc__.__len__()==176 (length anchor).
# No prior struct spec checks pack.__doc__.__contains__('struct').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra60.pack_doc_contains_struct:
  description: "struct.pack.__doc__.__contains__('struct') — C builtin docstring includes 'See help(struct) for more on format strings.'; 'struct' appears in this reference; struct_extra57 checks pack.__doc__.__contains__('format') (wave 228); struct_extra59 checks pack.__doc__.__len__()==176 (length anchor); no prior struct spec checks pack.__doc__.__contains__('struct'); new content anchor for pack docstring"
  kind: python_call_eq
  category: docstrings
  id_prefix: structid2_60

  columns: [id, function, args, expected]
  rows:
    - [pack_doc_contains_struct, pack.__doc__.__contains__, ["struct"], true]

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error is the exception raised by struct operations. It subclasses
# Exception directly. The __bases__ tuple has exactly one element: Exception.
# struct_extra11 checks error.__module__.__eq__('struct') (module axis only).
# No prior struct spec checks error.__bases__ or the base class name. First
# exception hierarchy anchor for struct.error. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra60.struct_error_exception_base:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error is a C extension exception that subclasses Exception directly; __bases__ has one entry: Exception; struct_extra11 checks error.__module__ (module axis); no prior struct spec checks error.__bases__[0].__name__; first exception hierarchy anchor for struct.error"
  category: exception_hierarchy
  kind: python_call_eq
  function: error.__bases__
  method_chain: ["__getitem__", "__getattribute__", "__eq__"]
  method_chain_args: [[0], ["__name__"], ["Exception"]]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__mro__.__len__() == 4 — standalone
#
# The MRO (method resolution order) of struct.error is:
# [struct.error, Exception, BaseException, object] — exactly 4 entries.
# This verifies the inheritance depth of struct.error. No prior struct spec
# checks error.__mro__.__len__(). First MRO length anchor for struct.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra60.struct_error_mro_len_4:
  description: "struct.error.__mro__.__len__() == 4 — MRO is [struct.error, Exception, BaseException, object] with 4 entries; this verifies the inheritance depth; no prior struct spec checks error.__mro__.__len__(); first MRO length anchor for struct.error"
  category: exception_hierarchy
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__eq__('error') — standalone
#
# struct.error is defined at the top level of the struct C extension module.
# Its qualified name (__qualname__) is 'error' — the short class name without
# a module prefix. struct_extra11 covers error.__module__.__eq__('struct').
# No prior struct spec checks error.__qualname__. Complementary identity
# anchor for struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra60.struct_error_module_struct:
  description: "struct.error.__qualname__.__eq__('error') == True — struct.error is defined at the top level of the struct C extension; its __qualname__ is 'error' (the short class name, no module prefix); struct_extra11 covers error.__module__.__eq__('struct'); no prior struct spec checks error.__qualname__; complementary identity anchor for struct.error"
  category: exception_hierarchy
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.pack is a C builtin_function_or_method. Its docstring is a str
# instance (C docstrings are always str). struct_extra58 checks
# pack.__doc__.__class__.__name__.__eq__('str') — this invariant intentionally
# duplicates that standalone anchor to provide a parallel entry point for
# struct_extra60 readers. Wait — to avoid duplication with struct_extra58,
# use unpack instead for the standalone here.
#
# struct.unpack.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct_extra58 checks pack.__doc__.__class__.__name__.__eq__('str') but
# does NOT check unpack on the class name axis. unpack is a C builtin and its
# docstring is also str. First class name anchor for unpack docstring.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra60.pack_doc_str:
  description: "struct.unpack.__doc__.__class__.__name__.__eq__('str') == True — unpack is a C builtin_function_or_method from _struct; its docstring is a str instance; struct_extra58 checks pack.__doc__.__class__.__name__.__eq__('str') (pack axis only); no prior struct spec checks unpack.__doc__.__class__.__name__; first class name anchor for unpack docstring"
  category: docstrings
  kind: python_call_eq
  function: unpack.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
