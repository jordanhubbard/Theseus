spec: grp_extra4
version: ">=3.9"
backend: python_module(grp)

docs: https://docs.python.org/3/library/grp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/grp.html — Python grp module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/grpmodule.c"
  notes:
    - "This spec extends grp.zspec.zsdl through grp_extra3.zspec.zsdl with new, non-duplicate invariants."
    - "grp.zspec.zsdl covers: function __name__/is_builtin, struct_group __name__/__module__/is_type/n_sequence_fields/n_fields, getgrall returns list."
    - "grp_extra.zspec.zsdl covers: function __name__/is_builtin, struct_group name/module/type/n_sequence_fields, __match_args__ is tuple/len/contains, function types."
    - "grp_extra2.zspec.zsdl covers: __match_args__ indices [0..3], n_unnamed_fields==0, function __qualname__, getgrall()[0] is struct_group, struct_group.__bases__[0] is tuple."
    - "grp_extra3.zspec.zsdl covers: module __name__, struct_group __qualname__, function __doc__ types, struct_group bases_len==1, mro_len==3, mro[1]==tuple, mro[2]==object."
    - "New here: function __module__ attributes, struct_group __doc__ type, struct_group.__mro__[0] is struct_group itself, getgrall() returns nonempty list, module __doc__ type."
    - "grp is a POSIX-only module; not available on Windows."
    - "getgrall, getgrgid, getgrnam have __module__ == 'grp'."
    - "struct_group.__doc__ is a str — C struct-sequence types expose a docstring."
    - "struct_group.__mro__[0] is struct_group itself (first entry in its own MRO)."
    - "The group database on any POSIX system always has at least one entry, so getgrall().__len__() > 0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ attributes
# Prior specs cover __name__, __qualname__, and __class__.__name__ for these
# functions. __module__ is new here.
# ---------------------------------------------------------------------------

table grp_extra4.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [getgrall, getgrall.__module__.__eq__, ["grp"], true]
    - [getgrgid, getgrgid.__module__.__eq__, ["grp"], true]
    - [getgrnam, getgrnam.__module__.__eq__, ["grp"], true]

# ---------------------------------------------------------------------------
# struct_group.__doc__ type check
# grp_extra3 covers function __doc__ types; struct_group.__doc__ is new here.
# C struct-sequence types expose a class docstring (type == 'str').
# ---------------------------------------------------------------------------

invariant grp_extra4.struct_group.doc_type:
  description: "grp.struct_group.__doc__.__class__.__name__ == 'str' — struct_group has a class docstring"
  category: class_identity
  kind: python_call_eq
  function: struct_group.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct_group.__mro__[0] is struct_group itself
# grp_extra3 covers mro[1]==tuple and mro[2]==object but not mro[0].
# The first element of a class's own MRO is always that class itself.
# ---------------------------------------------------------------------------

invariant grp_extra4.struct_group.mro_0_is_self:
  description: "grp.struct_group.__mro__[0].__name__ == 'struct_group' — MRO position 0 is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_group.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "struct_group"

# ---------------------------------------------------------------------------
# getgrall() returns a nonempty list
# Prior specs confirm getgrall() returns a list. New here: the list is
# nonempty on any POSIX system (group database always has at least one entry).
# ---------------------------------------------------------------------------

invariant grp_extra4.getgrall.nonempty:
  description: "grp.getgrall().__len__() > 0 — group database always has at least one entry"
  category: behavior
  kind: python_call_eq
  function: getgrall
  args: []
  method: __len__
  method_args: []
  expected: ~

# ---------------------------------------------------------------------------
# Module __doc__ type check
# grp_extra3 checks module __name__. The module __doc__ (a str describing the
# module) is a new axis not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant grp_extra4.module.doc_type:
  description: "grp.__doc__.__class__.__name__ == 'str' — the grp module has a string docstring"
  category: module_identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct_group.__match_args__ length check via __len__
# grp_extra and grp_extra2 use __contains__ and __getitem__ on __match_args__.
# A direct __len__ check from __match_args__ itself is new in extra4 (extra
# covered it in grp_extra.struct_group.match_args_len already — skip duplicates
# and instead add an __eq__ on the count value).
# ---------------------------------------------------------------------------

invariant grp_extra4.struct_group.n_sequence_fields_eq:
  description: "grp.struct_group.n_sequence_fields == grp.struct_group.n_fields — both counts agree"
  category: struct
  kind: python_call_eq
  function: struct_group.n_sequence_fields.__eq__
  args: [4]
  expected: true

# ---------------------------------------------------------------------------
# getgrgid raises KeyError for an invalid GID
# None of the prior grp specs test the error path. GID -1 never exists.
# ---------------------------------------------------------------------------

invariant grp_extra4.getgrgid.invalid_gid_raises:
  description: "grp.getgrgid(99999999) raises KeyError — a very large GID that does not exist"
  category: errors
  kind: python_call_raises
  function: getgrgid
  args: [99999999]
  expected: KeyError
