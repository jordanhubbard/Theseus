spec: multiprocessing_extra83
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra82.zspec.zsdl."
    - "This spec covers: wave 246 theme — multiprocessing Process __qualname__ and exception __qualname__ equality. NEW in extra83: Process.__qualname__.__eq__('Process')==True; Process.__name__.__eq__('Process')==True; ProcessError.__qualname__.__eq__('ProcessError')==True; AuthenticationError.__qualname__.__eq__('AuthenticationError')==True; BufferTooShort.__qualname__.__eq__('BufferTooShort')==True; TimeoutError.__qualname__.__eq__('TimeoutError')==True; ProcessError.__name__.__eq__('ProcessError')==True; AuthenticationError.__name__.__eq__('AuthenticationError')==True; BufferTooShort.__name__.__eq__('BufferTooShort')==True; TimeoutError.__name__.__eq__('TimeoutError')==True; Process.__module__.__eq__('multiprocessing.context')==True; ProcessError.__module__.__eq__('multiprocessing.context')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__qualname__.__eq__('Process') == True. Process has a simple top-level qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__name__.__eq__('Process') == True. Process has a simple top-level name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__qualname__.__eq__('ProcessError') == True. ProcessError has a simple top-level qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__qualname__.__eq__('AuthenticationError') == True. AuthenticationError has a simple top-level qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__qualname__.__eq__('BufferTooShort') == True. BufferTooShort has a simple top-level qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__qualname__.__eq__('TimeoutError') == True. TimeoutError has a simple top-level qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__module__.__eq__('multiprocessing.context') == True. ProcessError is defined in multiprocessing.context. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process __qualname__ equality — extra83
#
# Wave 246 theme: multiprocessing Process __qualname__ and exception __qualname__ equality.
#
# Process.__qualname__.__eq__('Process') == True
# Process.__name__.__eq__('Process') == True
# ProcessError.__qualname__.__eq__('ProcessError') == True
# ProcessError.__name__.__eq__('ProcessError') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra83.Process_qualname_equality:
  description: "multiprocessing Process __qualname__ and __name__ equality checks in mpextra83 namespace — wave 246 theme: multiprocessing Process __qualname__ and exception __qualname__ equality; Process.__qualname__.__eq__('Process')==True; Process.__name__.__eq__('Process')==True; ProcessError.__qualname__.__eq__('ProcessError')==True; ProcessError.__name__.__eq__('ProcessError')==True; all are simple top-level class names with no enclosing scope; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra83

  columns: [id, function, args, expected, description]
  rows:
    - [proc_qualname_eq,  Process.__qualname__.__eq__,      ["Process"],      true, "Process.__qualname__.__eq__('Process') == True — simple top-level class qualname; verified with Python 3.14.3"]
    - [proc_name_eq,      Process.__name__.__eq__,          ["Process"],      true, "Process.__name__.__eq__('Process') == True — simple top-level class name; verified with Python 3.14.3"]
    - [pe_qualname_eq,    ProcessError.__qualname__.__eq__,  ["ProcessError"], true, "ProcessError.__qualname__.__eq__('ProcessError') == True — simple top-level exception qualname; verified with Python 3.14.3"]
    - [pe_name_eq,        ProcessError.__name__.__eq__,     ["ProcessError"], true, "ProcessError.__name__.__eq__('ProcessError') == True — simple top-level exception name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
