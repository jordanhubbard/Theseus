table multiprocessing_extra83.exception_qualname_equality:
  description: "multiprocessing exception __qualname__ equality checks in mpextra83 namespace — wave 246 theme: multiprocessing exception __qualname__ equality; AuthenticationError.__qualname__.__eq__('AuthenticationError')==True; BufferTooShort.__qualname__.__eq__('BufferTooShort')==True; TimeoutError.__qualname__.__eq__('TimeoutError')==True; AuthenticationError.__name__.__eq__('AuthenticationError')==True; all exception classes have simple top-level qualnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra83a

  columns: [id, function, args, expected, description]
  rows:
    - [auth_qualname_eq,    AuthenticationError.__qualname__.__eq__, ["AuthenticationError"], true, "AuthenticationError.__qualname__.__eq__('AuthenticationError') == True — simple top-level exception qualname; verified with Python 3.14.3"]
    - [buf_qualname_eq,     BufferTooShort.__qualname__.__eq__,      ["BufferTooShort"],      true, "BufferTooShort.__qualname__.__eq__('BufferTooShort') == True — simple top-level exception qualname; verified with Python 3.14.3"]
    - [timeout_qualname_eq, TimeoutError.__qualname__.__eq__,        ["TimeoutError"],        true, "TimeoutError.__qualname__.__eq__('TimeoutError') == True — simple top-level exception qualname; verified with Python 3.14.3"]
    - [auth_name_eq,        AuthenticationError.__name__.__eq__,     ["AuthenticationError"], true, "AuthenticationError.__name__.__eq__('AuthenticationError') == True — simple top-level exception name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing exception __name__ equality — extra83
#
# BufferTooShort.__name__.__eq__('BufferTooShort') == True
# TimeoutError.__name__.__eq__('TimeoutError') == True
