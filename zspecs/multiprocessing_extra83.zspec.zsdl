table multiprocessing_extra83.exception_name_equality:
  description: "multiprocessing exception __name__ equality and module checks in mpextra83 namespace — wave 246 theme: multiprocessing Process __qualname__ and exception __qualname__ equality; BufferTooShort.__name__.__eq__('BufferTooShort')==True; TimeoutError.__name__.__eq__('TimeoutError')==True; ProcessError.__module__.__eq__('multiprocessing.context')==True (ProcessError is defined in multiprocessing.context); Process.__module__.__eq__('multiprocessing.context')==True (cross-check from prior spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra83b

  columns: [id, function, args, expected, description]
  rows:
    - [buf_name_eq,       BufferTooShort.__name__.__eq__,  ["BufferTooShort"],           true, "BufferTooShort.__name__.__eq__('BufferTooShort') == True — simple top-level exception name; verified with Python 3.14.3"]
    - [timeout_name_eq,   TimeoutError.__name__.__eq__,    ["TimeoutError"],             true, "TimeoutError.__name__.__eq__('TimeoutError') == True — simple top-level exception name; verified with Python 3.14.3"]
    - [pe_module_eq,      ProcessError.__module__.__eq__,  ["multiprocessing.context"],  true, "ProcessError.__module__.__eq__('multiprocessing.context') == True — ProcessError is defined in multiprocessing.context; verified with Python 3.14.3"]
    - [proc_module_cross, Process.__module__.__eq__,       ["multiprocessing.context"],  true, "Process.__module__.__eq__('multiprocessing.context') == True — cross-check from prior spec; verified with Python 3.14.3"]

