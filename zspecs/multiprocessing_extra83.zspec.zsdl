    - [timeout_qual_cross, TimeoutError.__qualname__.__eq__,        ["TimeoutError"],         true, "TimeoutError.__qualname__.__eq__('TimeoutError') == True — cross-check; verified with Python 3.14.3"]
    - [pe_mod_cross,       ProcessError.__module__.__eq__,          ["multiprocessing.context"], true, "ProcessError.__module__.__eq__('multiprocessing.context') == True — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra83
# ---------------------------------------------------------------------------

invariant multiprocessing_extra83.Process_qualname_eq:
  description: "multiprocessing.Process.__qualname__.__eq__('Process') returns True — Process is a top-level class and its __qualname__ equals its simple class name; NEW in extra83: first standalone __qualname__ equality invariant for Process in mpextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__qualname__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra83.ProcessError_qualname_eq:
  description: "multiprocessing.ProcessError.__qualname__.__eq__('ProcessError') returns True — ProcessError is a top-level exception class and its __qualname__ equals its simple class name; NEW in extra83: first standalone __qualname__ equality invariant for ProcessError in mpextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessError.__qualname__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra83.AuthenticationError_qualname_eq:
  description: "multiprocessing.AuthenticationError.__qualname__.__eq__('AuthenticationError') returns True — AuthenticationError is a top-level exception class in multiprocessing; its __qualname__ equals its simple class name; NEW in extra83: first standalone __qualname__ equality invariant for AuthenticationError in mpextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra83.BufferTooShort_qualname_eq:
  description: "multiprocessing.BufferTooShort.__qualname__.__eq__('BufferTooShort') returns True — BufferTooShort is a top-level exception class in multiprocessing used when a buffer is too small; its __qualname__ equals its simple class name; NEW in extra83: first standalone __qualname__ equality invariant for BufferTooShort in mpextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BufferTooShort.__qualname__.__eq__
  args: ["BufferTooShort"]
  expected: true

invariant multiprocessing_extra83.ProcessError_module_eq:
  description: "multiprocessing.ProcessError.__module__.__eq__('multiprocessing.context') returns True — ProcessError is defined in the multiprocessing.context submodule; NEW in extra83: first standalone __module__ equality invariant for ProcessError in mpextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true
