# New to multiprocessing_extra200.
# ---------------------------------------------------------------------------

table multiprocessing_extra200.baseprocess_dict_close_and_len:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__ for close/interrupt and __len__ in mpshared200 namespace; close added Python 3.7+; dict has 27 entries; new to multiprocessing_extra200"
  kind: python_call_eq
  category: dict_membership
  id_prefix: mpshared200

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_close2,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["close"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('close') == True — close() added in Python 3.7; new to multiprocessing_extra200; verified Python 3.14.3"]
    - [bp_has_interrupt,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["interrupt"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('interrupt') == True — interrupt() sends SIGINT on Unix; new to multiprocessing_extra200; verified Python 3.14.3"]
    - [bp_dict_len2,
       multiprocessing.process.BaseProcess.__dict__.__len__,
       [],
       27,
       "multiprocessing.process.BaseProcess.__dict__.__len__() == 27 — 27 entries confirmed in close/len context; new to multiprocessing_extra200; verified Python 3.14.3"]
    - [bp_has_start2,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["start"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('start') == True — cross-check; start is among the 27 entries; new to multiprocessing_extra200; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra200
# ---------------------------------------------------------------------------

invariant multiprocessing_extra200.bp_dict_has_start:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('start') == True — BaseProcess.start() spawns the child process; start() can only be called once per process object; new to multiprocessing_extra200; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["start"]
  expected: true

invariant multiprocessing_extra200.bp_dict_has_run:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('run') == True — BaseProcess.run() is the method that executes in the child process; default implementation calls the target callable; new to multiprocessing_extra200; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["run"]
  expected: true

invariant multiprocessing_extra200.bp_dict_has_join:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('join') == True — BaseProcess.join(timeout=None) blocks the calling thread until the child process terminates or timeout expires; new to multiprocessing_extra200; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["join"]
  expected: true

invariant multiprocessing_extra200.bp_dict_has_terminate:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('terminate') == True — BaseProcess.terminate() sends SIGTERM (Unix) or TerminateProcess (Windows); new to multiprocessing_extra200; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["terminate"]
  expected: true

invariant multiprocessing_extra200.bp_dict_has_kill:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('kill') == True — BaseProcess.kill() sends SIGKILL on Unix (Python 3.7+); same as terminate() on Windows; new to multiprocessing_extra200; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["kill"]
  expected: true

invariant multiprocessing_extra200.bp_dict_has_close:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('close') == True — BaseProcess.close() releases multiprocessing resources; added in Python 3.7; new to multiprocessing_extra200; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["close"]
  expected: true

invariant multiprocessing_extra200.bp_dict_len:
  description: "multiprocessing.process.BaseProcess.__dict__.__len__() == 27 — BaseProcess.__dict__ has 27 entries including all lifecycle methods plus properties and private members; new to multiprocessing_extra200; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__len__
  args: []
  expected: 27

invariant multiprocessing_extra200.bp_dict_has_is_alive:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('is_alive') == True — BaseProcess.is_alive() returns True if the process has started and not yet terminated; uses a sentinel file descriptor; new to multiprocessing_extra200; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["is_alive"]
  expected: true

