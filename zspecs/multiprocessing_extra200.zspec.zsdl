spec: multiprocessing_extra200
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec covers multiprocessing.process.BaseProcess.__dict__ membership for all six lifecycle management methods."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('start') == True — BaseProcess.start() spawns the child process; can only be called once. Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('run') == True — BaseProcess.run() is the method to override in subclasses; calls the target function. Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('join') == True — BaseProcess.join(timeout=None) blocks until child exits or timeout expires. Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('terminate') == True — BaseProcess.terminate() sends SIGTERM on Unix; TerminateProcess on Windows. Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('kill') == True — BaseProcess.kill() sends SIGKILL on Unix (Python 3.7+); same as terminate() on Windows. Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('close') == True — BaseProcess.close() releases resources (Python 3.7+); must not be called before join(). Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__dict__.__len__() == 27 — 27 total entries in BaseProcess.__dict__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.process.BaseProcess.__dict__ start/run/join membership
#
# multiprocessing.process.BaseProcess.__dict__.__contains__('start') == True
# multiprocessing.process.BaseProcess.__dict__.__contains__('run')   == True
# multiprocessing.process.BaseProcess.__dict__.__contains__('join')  == True
#
# The three primary lifecycle initiation methods are all defined on BaseProcess.
# New to multiprocessing_extra200.
# ---------------------------------------------------------------------------

table multiprocessing_extra200.baseprocess_dict_start_run_join:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__ checks for start/run/join in mpshared200 namespace — three primary lifecycle methods; new to multiprocessing_extra200"
  kind: python_call_eq
  category: dict_membership
  id_prefix: mpshared200

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_start,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["start"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('start') == True — start() spawns the child process; new to multiprocessing_extra200; verified Python 3.14.3"]
    - [bp_has_run,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["run"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('run') == True — run() is overridden in subclasses to define process behavior; new to multiprocessing_extra200; verified Python 3.14.3"]
    - [bp_has_join,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["join"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('join') == True — join(timeout=None) blocks until child exits; new to multiprocessing_extra200; verified Python 3.14.3"]
    - [bp_dict_len,
       multiprocessing.process.BaseProcess.__dict__.__len__,
       [],
       27,
       "multiprocessing.process.BaseProcess.__dict__.__len__() == 27 — 27 total entries in BaseProcess.__dict__; new to multiprocessing_extra200; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.process.BaseProcess.__dict__ terminate/kill membership
#
# multiprocessing.process.BaseProcess.__dict__.__contains__('terminate') == True
# multiprocessing.process.BaseProcess.__dict__.__contains__('kill')      == True
#
# terminate() sends SIGTERM; kill() sends SIGKILL (Unix) or TerminateProcess (Windows).
# New to multiprocessing_extra200.
# ---------------------------------------------------------------------------

table multiprocessing_extra200.baseprocess_dict_terminate_kill:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__ checks for terminate/kill in mpshared200 namespace — forced-stop methods; new to multiprocessing_extra200"
  kind: python_call_eq
  category: dict_membership
  id_prefix: mpshared200

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_terminate,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["terminate"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('terminate') == True — terminate() sends SIGTERM; new to multiprocessing_extra200; verified Python 3.14.3"]
    - [bp_has_kill,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["kill"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('kill') == True — kill() sends SIGKILL on Unix (Python 3.7+); new to multiprocessing_extra200; verified Python 3.14.3"]
    - [bp_has_is_alive,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["is_alive"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('is_alive') == True — is_alive() returns True if process started and not yet terminated; new to multiprocessing_extra200; verified Python 3.14.3"]
    - [bp_has_close,
       multiprocessing.process.BaseProcess.__dict__.__contains__,
       ["close"],
       true,
       "multiprocessing.process.BaseProcess.__dict__.__contains__('close') == True — close() releases resources (Python 3.7+); new to multiprocessing_extra200; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
