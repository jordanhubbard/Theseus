spec: re_extra1906
version: ">=3.9"
backend: python_module(re)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "re.Pattern and re.Match are C-level types implemented in _sre; their __qualname__ values are 'Pattern' and 'Match' respectively."
    - "re.error is an alias for re.PatternError in Python 3.13+; re.error.__qualname__ == 'PatternError'."
    - "re.RegexFlag is a Python IntFlag enum; its __qualname__ == 'RegexFlag'."
    - "None of re.Pattern, re.Match, re.error, re.RegexFlag define __reversed__, __missing__, or __match_args__ in their __dict__."
    - "re.Pattern.__module__ == 're', re.Match.__module__ == 're', re.error.__module__ == 're', re.RegexFlag.__module__ == 're'."
    - "re.Pattern.__qualname__ == 'Pattern' — C-level type exposed via re module."
    - "re.Match.__qualname__ == 'Match' — C-level type exposed via re module."
    - "re.error.__qualname__ == 'PatternError' — Python exception class (re.error is re.PatternError alias in 3.13+)."
    - "re.RegexFlag.__qualname__ == 'RegexFlag' — Python IntFlag subclass."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table re_extra1906.reversed_protocol:
  description: "re types __reversed__ dict-presence checks"
  kind: python_call_eq
  category: reversed_protocol
  id_prefix: re1906

  columns: [id, function, args, expected]
  rows:
    - ["re1906001", "re.Pattern.__dict__.__contains__", ["__reversed__"], false]
    - ["re1906002", "re.Match.__dict__.__contains__", ["__reversed__"], false]
    - ["re1906003", "re.error.__dict__.__contains__", ["__reversed__"], false]
    - ["re1906004", "re.RegexFlag.__dict__.__contains__", ["__reversed__"], false]
    - ["re1906005", "re.Pattern.__dict__.__contains__", ["__missing__"], false]
    - ["re1906006", "re.Match.__dict__.__contains__", ["__missing__"], false]
    - ["re1906007", "re.error.__dict__.__contains__", ["__missing__"], false]
    - ["re1906008", "re.RegexFlag.__dict__.__contains__", ["__missing__"], false]

