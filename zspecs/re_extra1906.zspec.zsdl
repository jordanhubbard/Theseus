    - ["re1906012", "re.Match.__dict__.__contains__", ["__match_args__"], false]
    - ["re1906013", "re.error.__dict__.__contains__", ["__match_args__"], false]
    - ["re1906014", "re.RegexFlag.__dict__.__contains__", ["__match_args__"], false]
    - ["re1906015", "re.Pattern.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["re1906016", "re.Match.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["re1906017", "re.error.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["re1906018", "re.Pattern.__dict__.__contains__", ["__type_params__"], false]
