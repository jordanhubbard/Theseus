spec: socket_extra218
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol (TCP)"
  - "RFC 768 — User Datagram Protocol (UDP)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'; socket.AF_INET.value == 2 (POSIX AF_INET)."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily'; socket.AF_INET6.value == 30 on macOS (differs from Linux value of 10)."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int'; int(socket.IPPROTO_TCP) == 6 (IANA protocol number)."
    - "socket.IPPROTO_UDP == 17 (IANA protocol number for UDP)."
    - "socket.gethostname.__name__ == 'gethostname'; __module__ == '_socket' (C extension)."
    - "socket.getfqdn.__name__ == 'getfqdn'; __module__ == 'socket' (Python-level wrapper)."
    - "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout'; __module__ == '_socket'."
    - "socket.getdefaulttimeout.__name__ == 'getdefaulttimeout'; __module__ == '_socket'."
    - "NOTE: AF_INET6.value == 30 on macOS/Darwin; on Linux it is 10. This spec is macOS-specific."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket address family constants
#
# socket.AF_INET.__class__.__name__  == 'AddressFamily'
# socket.AF_INET.value               == 2
# socket.AF_INET6.__class__.__name__ == 'AddressFamily'
# socket.AF_INET6.value              == 30  (macOS; Linux is 10)
# ---------------------------------------------------------------------------

table socket_extra218.address_family_constants:
  description: "socket.AF_INET and socket.AF_INET6 address family constant checks in socketeq218 namespace — wave 218 theme: AF_INET is enum AddressFamily value 2 (POSIX constant AF_INET); AF_INET6 is AddressFamily value 30 on macOS (different from Linux value 10); both are IntEnum members of socket.AddressFamily; verified with Python 3.14.3 on macOS"
  kind: python_call_eq
  category: constants
  id_prefix: socketeq218

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_class,   "socket.AF_INET.__class__.__name__.__eq__",  ["AddressFamily"], true, "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum member of socket.AddressFamily"]
    - [af_inet_value,   "socket.AF_INET.value.__eq__",               [2],               true, "socket.AF_INET.value == 2 — POSIX AF_INET constant value is 2 on all POSIX platforms"]
    - [af_inet6_class,  "socket.AF_INET6.__class__.__name__.__eq__", ["AddressFamily"], true, "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — AF_INET6 is an IntEnum member of socket.AddressFamily"]
    - [af_inet6_value,  "socket.AF_INET6.value.__eq__",              [30],              true, "socket.AF_INET6.value == 30 — AF_INET6 value on macOS/Darwin; note: Linux uses 10, this is platform-specific"]

# ---------------------------------------------------------------------------
# socket IP protocol constants (IANA)
#
# socket.IPPROTO_TCP.__class__.__name__ == 'int'
# int(socket.IPPROTO_TCP) == 6
# int(socket.IPPROTO_UDP) == 17
# ---------------------------------------------------------------------------

table socket_extra218.ipproto_constants:
  description: "socket.IPPROTO_TCP and socket.IPPROTO_UDP protocol number checks in socketeq218a namespace — wave 218 theme: IPPROTO_TCP is plain int value 6 (IANA assigned protocol number for TCP per RFC 793); IPPROTO_UDP is plain int value 17 (IANA assigned for UDP per RFC 768); both are plain int not enum on macOS; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: socketeq218a

  columns: [id, function, args, expected, description]
  rows:
    - [tcp_class,  "socket.IPPROTO_TCP.__class__.__name__.__eq__", ["int"], true, "socket.IPPROTO_TCP.__class__.__name__ == 'int' — IPPROTO_TCP is a plain int on macOS Python 3.14.3"]
    - [tcp_value,  "socket.IPPROTO_TCP.__eq__",                   [6],     true, "socket.IPPROTO_TCP == 6 — IANA protocol number for TCP per RFC 793"]
    - [udp_value,  "socket.IPPROTO_UDP.__eq__",                   [17],    true, "socket.IPPROTO_UDP == 17 — IANA protocol number for UDP per RFC 768"]

# ---------------------------------------------------------------------------
# socket module function __name__ and __module__ checks
#
# socket.gethostname.__name__        == 'gethostname'
# socket.gethostname.__module__      == '_socket'
# socket.getfqdn.__name__            == 'getfqdn'
# socket.getfqdn.__module__          == 'socket'
# socket.setdefaulttimeout.__name__  == 'setdefaulttimeout'
# socket.setdefaulttimeout.__module__ == '_socket'
# socket.getdefaulttimeout.__name__  == 'getdefaulttimeout'
# socket.getdefaulttimeout.__module__ == '_socket'
# ---------------------------------------------------------------------------

table socket_extra218.socket_function_identity:
  description: "socket module function __name__ and __module__ checks in socketeq218b namespace — wave 218 theme: gethostname/setdefaulttimeout/getdefaulttimeout are C extension functions in _socket; getfqdn is a Python-level function in the socket module wrapper; the __module__ difference between 'socket' and '_socket' distinguishes Python vs C implementation; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketeq218b

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_name,           "socket.gethostname.__name__.__eq__",           ["gethostname"],        true, "socket.gethostname.__name__ == 'gethostname' — C extension function in _socket module"]
    - [gethostname_module,         "socket.gethostname.__module__.__eq__",         ["_socket"],            true, "socket.gethostname.__module__ == '_socket' — implemented in the _socket C extension"]
    - [getfqdn_name,               "socket.getfqdn.__name__.__eq__",               ["getfqdn"],            true, "socket.getfqdn.__name__ == 'getfqdn' — Python-level wrapper function"]
    - [getfqdn_module,             "socket.getfqdn.__module__.__eq__",             ["socket"],             true, "socket.getfqdn.__module__ == 'socket' — defined in the Python-level socket module"]
    - [setdefaulttimeout_name,     "socket.setdefaulttimeout.__name__.__eq__",     ["setdefaulttimeout"],  true, "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout' — C extension function"]
    - [setdefaulttimeout_module,   "socket.setdefaulttimeout.__module__.__eq__",   ["_socket"],            true, "socket.setdefaulttimeout.__module__ == '_socket' — implemented in the _socket C extension"]
    - [getdefaulttimeout_name,     "socket.getdefaulttimeout.__name__.__eq__",     ["getdefaulttimeout"],  true, "socket.getdefaulttimeout.__name__ == 'getdefaulttimeout' — C extension function"]
    - [getdefaulttimeout_module,   "socket.getdefaulttimeout.__module__.__eq__",   ["_socket"],            true, "socket.getdefaulttimeout.__module__ == '_socket' — implemented in the _socket C extension"]
