spec: theseus_functools_cr
version: ">=3.9"
backend: python_cleanroom(theseus_functools_cr)
blocks: functools

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
  notes:
    - "Clean-room functools utilities. Do NOT import functools."
    - "reduce(fn, iterable[, initializer]): left-fold; reduce(lambda a,b: a+b, [1,2,3,4]) == 10."
    - "partial(fn, *args, **kwargs): return new callable with pre-filled args."
    - "partial(int, base=2)('101') == 5."
    - "lru_cache: memoize with LRU eviction; cached fn with same args returns same result."
    - "Export: reduce(function, iterable[, initializer]), partial(func, *args, **kw)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_functools_cr.reduce_sum:
  description: "reduce(add, [1,2,3,4]) == 10"
  category: reduce
  kind: python_call_eq
  function: functools_reduce_sum
  args: []
  expected: 10

invariant theseus_functools_cr.partial_base2:
  description: "partial(int, base=2)('101') == 5"
  category: partial
  kind: python_call_eq
  function: functools_partial_base2
  args: []
  expected: 5

invariant theseus_functools_cr.reduce_product:
  description: "reduce(mul, [1,2,3,4,5]) == 120"
  category: reduce
  kind: python_call_eq
  function: functools_reduce_product
  args: []
  expected: 120
