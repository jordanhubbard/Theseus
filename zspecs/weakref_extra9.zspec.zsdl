spec: weakref_extra9
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref.zspec.zsdl through weakref_extra8.zspec.zsdl."
    - "weakref_extra8 covers WeakSet/finalize mro_len, WeakMethod mro_len and mro[1], WeakValueDictionary/WeakKeyDictionary mro[1], mro[-1] table, getweakrefcount/getweakrefs __class__.__name__."
    - "weakref_extra4 covers ref/__name__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __name__ and __module__."
    - "weakref_extra6 covers ProxyType/CallableProxyType __qualname__/__module__, WeakMethod __qualname__/__module__, getweakrefcount/getweakrefs __qualname__."
    - "NOT yet covered: weakref.ref.__name__.__eq__('weakref') via standalone invariant (class-level attribute __name__ vs function)."
    - "NOT yet covered: weakref.proxy.__name__.__eq__('proxy') via __eq__ method chain."
    - "NOT yet covered: weakref.WeakSet.__name__.__eq__('WeakSet') via __eq__ method chain."
    - "NOT yet covered: weakref.WeakKeyDictionary.__name__.__eq__('WeakKeyDictionary') via __eq__ method chain."
    - "NOT yet covered: weakref.WeakValueDictionary.__name__.__eq__('WeakValueDictionary') via __eq__ method chain."
    - "NOT yet covered: weakref.WeakMethod.__name__.__eq__('WeakMethod') via __eq__ method chain."
    - "NOT yet covered: weakref.finalize.__name__.__eq__('finalize') via __eq__ method chain."
    - "NOT yet covered: weakref.ReferenceType.__name__.__eq__('weakref') via __eq__ method chain."
    - "NOT yet covered: weakref.ProxyType.__name__.__eq__('weakproxy') via __eq__ method chain."
    - "NOT yet covered: weakref.CallableProxyType.__name__.__eq__('weakcallableproxy') via __eq__ method chain."
    - "NOT yet covered: weakref.ref.__module__.__eq__('weakref') via __eq__ method chain (prior specs used __module__ attribute direct access)."
    - "NOT yet covered: weakref.WeakSet.__module__.__eq__('weakref') via __eq__ method chain."
    - "NOT yet covered: weakref.finalize.__module__.__eq__('weakref') via __eq__ method chain."
    - "weakref.ref.__name__ == 'weakref' — the C-level type name is 'weakref', not 'ref'."
    - "weakref.proxy.__name__ == 'proxy' — C-level proxy type."
    - "weakref.WeakSet.__name__ == 'WeakSet' — pure-Python class."
    - "weakref.WeakKeyDictionary.__name__ == 'WeakKeyDictionary' — pure-Python class."
    - "weakref.WeakValueDictionary.__name__ == 'WeakValueDictionary' — pure-Python class."
    - "weakref.WeakMethod.__name__ == 'WeakMethod' — pure-Python class."
    - "weakref.finalize.__name__ == 'finalize' — C-level type."
    - "weakref.ReferenceType.__name__ == 'weakref' — ReferenceType is an alias for ref; same C type."
    - "weakref.ProxyType.__name__ == 'weakproxy' — C-level non-callable proxy type."
    - "weakref.CallableProxyType.__name__ == 'weakcallableproxy' — C-level callable proxy type."
    - "weakref.ref.__module__ == 'builtins' — C-level type __module__ is 'builtins'."
    - "weakref.WeakSet.__module__ == 'weakref' — pure-Python class defined in weakref."
    - "weakref.finalize.__module__ == 'weakref' — C type re-exported with module set to 'weakref'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — all major weakref public names via __eq__ chain
#
# Prior specs (weakref_extra, weakref_extra4) record __name__ values via
# direct attribute reads. This spec asserts each via __name__.__eq__(expected)
# so the invariant is checkable as a boolean python_call_eq contract.
# ---------------------------------------------------------------------------

invariant weakref_extra9.ref.name:
  description: "weakref.ref.__name__.__eq__('weakref') == True — C-level type name is 'weakref'"
  category: class_names
  kind: python_call_eq
  function: ref.__name__.__eq__
  args: ["weakref"]
  expected: true

invariant weakref_extra9.proxy.name:
  description: "weakref.proxy.__name__.__eq__('proxy') == True — C-level proxy type name"
  category: class_names
  kind: python_call_eq
  function: proxy.__name__.__eq__
  args: ["proxy"]
  expected: true

invariant weakref_extra9.WeakSet.name:
  description: "weakref.WeakSet.__name__.__eq__('WeakSet') == True"
  category: class_names
  kind: python_call_eq
  function: WeakSet.__name__.__eq__
  args: ["WeakSet"]
  expected: true

invariant weakref_extra9.WeakKeyDictionary.name:
  description: "weakref.WeakKeyDictionary.__name__.__eq__('WeakKeyDictionary') == True"
  category: class_names
  kind: python_call_eq
  function: WeakKeyDictionary.__name__.__eq__
  args: ["WeakKeyDictionary"]
  expected: true

invariant weakref_extra9.WeakValueDictionary.name:
  description: "weakref.WeakValueDictionary.__name__.__eq__('WeakValueDictionary') == True"
  category: class_names
  kind: python_call_eq
  function: WeakValueDictionary.__name__.__eq__
  args: ["WeakValueDictionary"]
  expected: true

invariant weakref_extra9.WeakMethod.name:
  description: "weakref.WeakMethod.__name__.__eq__('WeakMethod') == True"
  category: class_names
  kind: python_call_eq
  function: WeakMethod.__name__.__eq__
  args: ["WeakMethod"]
  expected: true

invariant weakref_extra9.finalize.name:
  description: "weakref.finalize.__name__.__eq__('finalize') == True"
  category: class_names
  kind: python_call_eq
  function: finalize.__name__.__eq__
  args: ["finalize"]
  expected: true

invariant weakref_extra9.ReferenceType.name:
  description: "weakref.ReferenceType.__name__.__eq__('weakref') == True — ReferenceType is an alias for ref"
  category: class_names
  kind: python_call_eq
  function: ReferenceType.__name__.__eq__
  args: ["weakref"]
  expected: true

invariant weakref_extra9.ProxyType.name:
  description: "weakref.ProxyType.__name__.__eq__('weakproxy') == True — non-callable proxy type"
  category: class_names
  kind: python_call_eq
  function: ProxyType.__name__.__eq__
  args: ["weakproxy"]
  expected: true

invariant weakref_extra9.CallableProxyType.name:
  description: "weakref.CallableProxyType.__name__.__eq__('weakcallableproxy') == True — callable proxy type"
  category: class_names
  kind: python_call_eq
  function: CallableProxyType.__name__.__eq__
  args: ["weakcallableproxy"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation checks — ref, WeakSet, finalize via __eq__ chain
#
# weakref_extra4 records __module__ for WeakValueDictionary/WeakKeyDictionary/
# WeakSet/finalize and proxy via attribute reads. No prior spec checks these
# via __module__.__eq__ method chain in standalone invariants for ref, WeakSet,
# and finalize. Note: ref (ReferenceType) is a C type whose __module__ is
# 'builtins', while WeakSet and finalize live in the 'weakref' module.
# ---------------------------------------------------------------------------

invariant weakref_extra9.ref.module:
  description: "weakref.ref.__module__.__eq__('builtins') == True — C-level type __module__ is 'builtins'"
  category: module
  kind: python_call_eq
  function: ref.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant weakref_extra9.WeakSet.module:
  description: "weakref.WeakSet.__module__.__eq__('weakref') == True — pure-Python class defined in weakref"
  category: module
  kind: python_call_eq
  function: WeakSet.__module__.__eq__
  args: ["weakref"]
  expected: true

invariant weakref_extra9.finalize.module:
  description: "weakref.finalize.__module__.__eq__('weakref') == True — C type exported from weakref"
  category: module
  kind: python_call_eq
  function: finalize.__module__.__eq__
  args: ["weakref"]
  expected: true
