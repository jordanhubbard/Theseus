spec: pathlib_extra18
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "This spec extends pathlib.zspec.zsdl through pathlib_extra17.zspec.zsdl."
    - "pathlib_extra17 covers PurePath method __name__/__qualname__ and behavioral vectors for with_name/with_suffix/relative_to/is_relative_to."
    - "pathlib_extra16 covers MRO lengths (mro().__len__) for all six public classes; PureWindowsPath.__name__ standalone."
    - "pathlib_extra6 covers Path.__mro__[1].__name__ == 'PosixPath' via Path.__mro__.__getitem__(1).__name__."
    - "NOT yet covered: PurePath.__mro__[1].__name__ == 'object' via __mro__.__getitem__."
    - "NOT yet covered: PosixPath.__mro__[1].__name__ == 'Path' via __mro__.__getitem__."
    - "NOT yet covered: PurePosixPath.__mro__[1].__name__ == 'PurePath' via __mro__.__getitem__."
    - "NOT yet covered: PurePosixPath('/').parts length == 1 (root-only path)."
    - "NOT yet covered: PurePosixPath('/a/b').parts length == 3 (two-component absolute path)."
    - "NOT yet covered: PurePosixPath('/a/b/c.txt').name == 'c.txt' as a standalone (name includes extension)."
    - "NOT yet covered: PurePosixPath('/').root == '/' as a standalone."
    - "NOT yet covered: PurePosixPath('/').anchor == '/'."
    - "PurePath.__mro__[1].__name__ == 'object' — PurePath's only base is object."
    - "PosixPath.__mro__[1].__name__ == 'Path' — PosixPath's direct parent is Path."
    - "PurePosixPath.__mro__[1].__name__ == 'PurePath' — PurePosixPath's direct parent is PurePath."
    - "PurePosixPath('/').parts == ('/',) — root-only path has exactly one part."
    - "PurePosixPath('/a/b').parts == ('/', 'a', 'b') — three-element tuple."
    - "PurePosixPath('/a/b/c.txt').name == 'c.txt' — name includes the extension."
    - "PurePosixPath('/').root == '/' — root attribute of the root path."
    - "PurePosixPath('/').anchor == '/' — anchor equals root for POSIX absolute paths."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__[1].__name__ for PurePath, PosixPath, PurePosixPath
#
# pathlib_extra6 covers Path.__mro__[1].__name__ == 'PosixPath'.
# No prior spec records mro[1] for PurePath, PosixPath, or PurePosixPath.
# PurePath's only parent is object; PosixPath's direct parent is Path;
# PurePosixPath's direct parent is PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra18.mro_index1_names:
  description: "pathlib class __mro__[1].__name__ — immediate parent in MRO"
  kind: python_call_eq
  category: mro
  id_prefix: mro1

  columns: [id, function, args, expected, method]
  rows:
    - [PurePath,      PurePath.__mro__.__getitem__,      [1], "object",    __name__]
    - [PosixPath,     PosixPath.__mro__.__getitem__,     [1], "Path",      __name__]
    - [PurePosixPath, PurePosixPath.__mro__.__getitem__, [1], "PurePath",  __name__]

# ---------------------------------------------------------------------------
# PurePosixPath('/').parts — root-only path
#
# pathlib_extra14 covers PurePosixPath('/a/b/c').parts == ('/', 'a', 'b', 'c').
# pathlib_extra12 covers parts.__len__ and parts[0] for /a/b/c.
# pathlib_extra13 covers relative-path parts len.
# No prior spec checks parts for the root path '/' which has only one element.
# ---------------------------------------------------------------------------

invariant pathlib_extra18.PurePosixPath.root_parts_len:
  description: "pathlib.PurePosixPath('/').parts has length 1 — only the root separator"
  category: parts
  kind: python_call_eq
  function: PurePosixPath
  args: ["/"]
  method: parts.__len__
  expected: 1

invariant pathlib_extra18.PurePosixPath.root_parts_tuple:
  description: "pathlib.PurePosixPath('/').parts == ('/',) — root-only tuple"
  category: parts
  kind: python_call_eq
  function: PurePosixPath
  args: ["/"]
  method: parts
  expected: ["/"]

# ---------------------------------------------------------------------------
# PurePosixPath('/a/b').parts — two-component absolute path
#
# No prior spec checks parts for '/a/b' (two components after root).
# pathlib_extra14 covers '/a/b/c' (three components); pathlib_extra13 covers
# the relative 'a/b/c'. The '/a/b' two-component case is a distinct axis.
# ---------------------------------------------------------------------------

invariant pathlib_extra18.PurePosixPath.two_component_parts_len:
  description: "pathlib.PurePosixPath('/a/b').parts length == 3: ('/', 'a', 'b')"
  category: parts
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: parts.__len__
  expected: 3

invariant pathlib_extra18.PurePosixPath.two_component_parts_tuple:
  description: "pathlib.PurePosixPath('/a/b').parts == ('/', 'a', 'b')"
  category: parts
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: parts
  expected: ["/", "a", "b"]

# ---------------------------------------------------------------------------
# PurePosixPath('/a/b/c.txt').name — name attribute includes extension
#
# pathlib_extra9 covers PurePosixPath('/a/b/c').name == 'c' (no extension).
# pathlib_extra13 covers PurePosixPath('hello.py').name == 'hello.py'.
# No prior spec checks '/a/b/c.txt' where name must equal 'c.txt'.
# ---------------------------------------------------------------------------

invariant pathlib_extra18.PurePosixPath.name_with_extension:
  description: "pathlib.PurePosixPath('/a/b/c.txt').name == 'c.txt' — name includes suffix"
  category: name
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: name.__eq__
  method_args: ["c.txt"]
  expected: true

# ---------------------------------------------------------------------------
# PurePosixPath('/').root and .anchor
#
# No prior pathlib spec checks .root or .anchor on the root path '/'.
# pathlib_extra9 covers .root for '/a/b/c' (== '/'); pathlib_extra13 covers
# .anchor for a relative path. Root path '/' is a distinct boundary case.
# ---------------------------------------------------------------------------

invariant pathlib_extra18.PurePosixPath.root_path_root:
  description: "pathlib.PurePosixPath('/').root == '/'"
  category: root
  kind: python_call_eq
  function: PurePosixPath
  args: ["/"]
  method: root.__eq__
  method_args: ["/"]
  expected: true

invariant pathlib_extra18.PurePosixPath.root_path_anchor:
  description: "pathlib.PurePosixPath('/').anchor == '/' — anchor equals root for POSIX absolute paths"
  category: anchor
  kind: python_call_eq
  function: PurePosixPath
  args: ["/"]
  method: anchor.__eq__
  method_args: ["/"]
  expected: true
