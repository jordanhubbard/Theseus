spec: decimal_extra24
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra through decimal_extra23."
    - "decimal_extra23 covers Context method qualnames, rounding constant class names, DecimalException qualname/base/module, and InvalidOperation module."
    - "No prior spec covers Decimal.__module__ or Decimal.__bases__[0].__name__."
    - "No prior spec covers Context.__bases__[0].__name__."
    - "No prior spec covers InvalidOperation.__bases__[0].__name__."
    - "No prior spec covers __qualname__ for Overflow, Underflow, DivisionByZero, Clamped as standalone invariants."
    - "No prior spec covers __qualname__ for the module-level functions getcontext, setcontext, localcontext."
    - "No prior spec covers ROUND_HALF_UP.__class__.__module__ (builtins — str is a builtin type)."
    - "Decimal.__bases__[0].__name__ == 'object' — Decimal does not inherit from a numeric ABC."
    - "Context.__bases__[0].__name__ == 'object' — Context is a standalone class."
    - "getcontext, setcontext, localcontext are module-level callables; their __qualname__ equals their simple name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal class identity: __module__ and base class name
#
# No prior spec records Decimal.__module__ or Decimal.__bases__[0].__name__.
# Decimal is defined at the top of the decimal module and inherits directly
# from object — it does not subclass any numeric ABC.
# ---------------------------------------------------------------------------

invariant decimal_extra24.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal'"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra24.Decimal.module_len:
  description: "len(decimal.Decimal.__module__) == 7 — 'decimal' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__len__
  args: []
  expected: 7

invariant decimal_extra24.Decimal.base_name:
  description: "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal inherits directly from object"
  category: class_identity
  kind: python_call_eq
  function: "Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Context class base
#
# No prior spec records Context.__bases__[0].__name__.
# Context is also a standalone class inheriting from object.
# ---------------------------------------------------------------------------

invariant decimal_extra24.Context.base_name:
  description: "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object"
  category: class_identity
  kind: python_call_eq
  function: "Context.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# InvalidOperation base class name
#
# decimal_extra23 records InvalidOperation.__module__ but not
# InvalidOperation.__bases__[0].__name__.
# InvalidOperation inherits from DecimalException.
# ---------------------------------------------------------------------------

invariant decimal_extra24.InvalidOperation.base_name:
  description: "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — InvalidOperation inherits from DecimalException"
  category: class_identity
  kind: python_call_eq
  function: "InvalidOperation.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

# ---------------------------------------------------------------------------
# Exception subclass __qualname__ values
#
# No prior spec records __qualname__ for Overflow, Underflow, DivisionByZero,
# or Clamped as standalone invariants.  Each is a top-level class in the
# decimal module; qualname equals the simple class name.
# ---------------------------------------------------------------------------

table decimal_extra24.exception_qualnames:
  kind: python_call_eq
  category: class_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [Overflow,         Overflow.__qualname__.__eq__,         ["Overflow"],         true, "decimal.Overflow.__qualname__ == 'Overflow'"]
    - [Underflow,        Underflow.__qualname__.__eq__,        ["Underflow"],        true, "decimal.Underflow.__qualname__ == 'Underflow'"]
    - [DivisionByZero,   DivisionByZero.__qualname__.__eq__,   ["DivisionByZero"],   true, "decimal.DivisionByZero.__qualname__ == 'DivisionByZero'"]
    - [Clamped,          Clamped.__qualname__.__eq__,          ["Clamped"],          true, "decimal.Clamped.__qualname__ == 'Clamped'"]

# ---------------------------------------------------------------------------
# Exception subclass __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant decimal_extra24.Overflow.qualname_len:
  description: "len(decimal.Overflow.__qualname__) == 8 — 'Overflow' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Overflow.__qualname__.__len__
  args: []
  expected: 8

invariant decimal_extra24.Underflow.qualname_len:
  description: "len(decimal.Underflow.__qualname__) == 9 — 'Underflow' is 9 chars"
  category: class_identity
  kind: python_call_eq
  function: Underflow.__qualname__.__len__
  args: []
  expected: 9

invariant decimal_extra24.DivisionByZero.qualname_len:
  description: "len(decimal.DivisionByZero.__qualname__) == 13 — 'DivisionByZero' is 13 chars"
  category: class_identity
  kind: python_call_eq
  function: DivisionByZero.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# Module-level function __qualname__ values
#
# No prior spec records __qualname__ for getcontext, setcontext, or
# localcontext.  These are module-level callables; their __qualname__ equals
# their simple name (no enclosing class scope).
# ---------------------------------------------------------------------------

table decimal_extra24.module_function_qualnames:
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [getcontext,   getcontext.__qualname__.__eq__,   ["getcontext"],   true, "decimal.getcontext.__qualname__ == 'getcontext'"]
    - [setcontext,   setcontext.__qualname__.__eq__,   ["setcontext"],   true, "decimal.setcontext.__qualname__ == 'setcontext'"]
    - [localcontext, localcontext.__qualname__.__eq__, ["localcontext"], true, "decimal.localcontext.__qualname__ == 'localcontext'"]

# ---------------------------------------------------------------------------
# Module-level function __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant decimal_extra24.getcontext.qualname_len:
  description: "len(decimal.getcontext.__qualname__) == 10 — 'getcontext' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: getcontext.__qualname__.__len__
  args: []
  expected: 10

invariant decimal_extra24.setcontext.qualname_len:
  description: "len(decimal.setcontext.__qualname__) == 10 — 'setcontext' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: setcontext.__qualname__.__len__
  args: []
  expected: 10

invariant decimal_extra24.localcontext.qualname_len:
  description: "len(decimal.localcontext.__qualname__) == 12 — 'localcontext' is 12 chars"
  category: function_identity
  kind: python_call_eq
  function: localcontext.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Rounding constant __class__.__module__
#
# No prior spec records __class__.__module__ for rounding constants.
# They are plain str instances; str is a builtin type, so __module__ == 'builtins'.
# ---------------------------------------------------------------------------

table decimal_extra24.rounding_constant_class_module:
  kind: python_call_eq
  category: type_identity
  id_prefix: class_module

  columns: [id, function, args, expected, description]
  rows:
    - [half_up,   ROUND_HALF_UP.__class__.__module__.__eq__,   ["builtins"], true, "decimal.ROUND_HALF_UP.__class__.__module__ == 'builtins'"]
    - [down,      ROUND_DOWN.__class__.__module__.__eq__,      ["builtins"], true, "decimal.ROUND_DOWN.__class__.__module__ == 'builtins'"]
    - [ceiling,   ROUND_CEILING.__class__.__module__.__eq__,   ["builtins"], true, "decimal.ROUND_CEILING.__class__.__module__ == 'builtins'"]
    - [floor,     ROUND_FLOOR.__class__.__module__.__eq__,     ["builtins"], true, "decimal.ROUND_FLOOR.__class__.__module__ == 'builtins'"]
    - [half_even, ROUND_HALF_EVEN.__class__.__module__.__eq__, ["builtins"], true, "decimal.ROUND_HALF_EVEN.__class__.__module__ == 'builtins'"]
