spec: theseus_msvcrt_cr
version: ">=3.0"
backend: python_cleanroom(theseus_msvcrt_cr)
blocks: msvcrt

docs: https://docs.python.org/3/library/msvcrt.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/msvcrt.html"
  not_derived_from:
    - "CPython source: Modules/msvcrtmodule.c"
  notes:
    - "Clean-room msvcrt stub. Do NOT import msvcrt."
    - "Windows-only module; stubs raise OSError on non-Windows."

error_model: python_exceptions

invariant theseus_msvcrt_cr.msvcrt2_constants:
  description: "msvcrt constants have correct types"
  category: behavior
  kind: python_call_eq
  function: msvcrt2_constants
  args: []
  expected: true

invariant theseus_msvcrt_cr.msvcrt2_platform:
  description: "msvcrt stubs correctly reflect platform"
  category: behavior
  kind: python_call_eq
  function: msvcrt2_platform
  args: []
  expected: true

invariant theseus_msvcrt_cr.msvcrt2_functions:
  description: "msvcrt function stubs are callable"
  category: behavior
  kind: python_call_eq
  function: msvcrt2_functions
  args: []
  expected: true
