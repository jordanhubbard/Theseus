spec: smol_toml
version: ">=1.0.0"
backend: node(smol-toml)

docs: https://github.com/squirrelchat/smol-toml#readme

provenance:
  derived_from:
    - "smol-toml README — https://github.com/squirrelchat/smol-toml#readme"
    - "TOML 1.0.0 specification — https://toml.io/en/v1.0.0"
    - "Test vectors verified with smol-toml via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "smol-toml source"
  notes:
    - "Compact TOML 1.0 parser/serializer — alternative to @iarna/toml."
    - "Install: npm install smol-toml"
    - "v1 ESM only; named exports parse / stringify."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "parse() throws TomlError on invalid syntax."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant smol_toml.parse_simple_int:
  description: "parse('x = 1').x is 1"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["x = 1"]
  chain:
    - {get: x}
  expected: 1

invariant smol_toml.parse_string_value:
  description: "parse('name = \"alice\"').name is 'alice'"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["name = \"alice\""]
  chain:
    - {get: name}
  expected: "alice"

invariant smol_toml.parse_array_value:
  description: "parse('arr = [1, 2, 3]').arr is [1,2,3]"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["arr = [1, 2, 3]"]
  chain:
    - {get: arr}
  expected: [1, 2, 3]

invariant smol_toml.parse_section_table:
  description: "[user] section becomes a nested object"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["name = \"alice\"\nage = 30\n[user]\nname = \"bob\"\n"]
  chain:
    - {get: "user.name"}
  expected: "bob"

invariant smol_toml.parse_top_level_preserved:
  description: "Top-level keys are preserved when section comes after"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["name = \"alice\"\nage = 30\n[user]\nname = \"bob\"\n"]
  chain:
    - {get: name}
  expected: "alice"

invariant smol_toml.parse_boolean_true:
  description: "parse('x = true').x is true"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["x = true"]
  chain:
    - {get: x}
  expected: true

invariant smol_toml.parse_float_value:
  description: "parse('pi = 3.14').pi is 3.14"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["pi = 3.14"]
  chain:
    - {get: pi}
  expected: 3.14

# Round-trip: stringify({title:'doc', value:42}) → 'title = "doc"\nvalue = 42\n'
invariant smol_toml.stringify_string_and_int:
  description: "stringify({title:'doc', value:42}) emits expected TOML"
  category: stringify
  kind: node_chain_eq
  entry: named
  function: stringify
  entry_args: [{title: "doc", value: 42}]
  chain: []
  expected: "title = \"doc\"\nvalue = 42\n"
