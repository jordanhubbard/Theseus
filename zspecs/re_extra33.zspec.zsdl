spec: re_extra33
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra31.zspec.zsdl — covers split/findall/finditer/purge/escape __module__.__len__()==2; __name__.__len__() for same; Pattern/__name__.__len__()==7; Match/__name__.__len__()==5; Pattern/__qualname__.__len__()==7; Match/__qualname__.__len__()==5"
    - "re_extra32.zspec.zsdl — covers Pattern method __qualname__.__len__() for match/search/findall/sub/split/fullmatch/finditer/subn; Match method __qualname__.__len__() for group/groups/span/start/end"
  notes:
    - "This spec extends re_extra32.zspec.zsdl."
    - "Prior specs covered: re.compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge __name__/__module__/__qualname__, Pattern/Match/__name__/__module__/__qualname__/__bases__[0].__name__, re.error/__name__/__module__, re.IGNORECASE/MULTILINE/DOTALL/VERBOSE values, all public function __module__.__len__()==2 and __name__.__len__(), Pattern/__name__.__len__()==7, Match/__name__.__len__()==5, Pattern/__qualname__.__len__()==7, Match/__qualname__.__len__()==5, Pattern/__mro__.__len__()==2, Match/__mro__.__len__()==2, error/__mro__.__len__()==4, Pattern/__bases__[0].__name__=='object', Match/__bases__[0].__name__=='object', Pattern/Match method __qualname__.__len__() for all main methods."
    - "This spec covers: re.__all__.__len__() and re.__all__.__class__.__name__; re.error.__dict__.__class__.__name__.__len__()==12 for error/Pattern/Match/RegexFlag; re.error.__reduce__.__name__.__len__()==10 for error/Pattern/Match/RegexFlag; re.error.__init_subclass__.__qualname__.__len__() for error/Pattern/Match/RegexFlag; re.IGNORECASE.__class__.__name__.__len__()==9 ('RegexFlag'); int(re.IGNORECASE)==2, int(re.MULTILINE)==8, int(re.DOTALL)==16."
    - "re.__all__ has 31 entries (list): match, fullmatch, search, sub, subn, split, findall, finditer, compile, purge, escape, error, Pattern, Match, A, I, L, M, S, X, U, ASCII, IGNORECASE, LOCALE, MULTILINE, DOTALL, VERBOSE, UNICODE, NOFLAG, RegexFlag, PatternError. Verified Python 3.12."
    - "re.__all__.__class__.__name__ == 'list' — len('list') == 4. Verified Python 3.12."
    - "re.error.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Same for Pattern, Match, RegexFlag. Verified Python 3.12."
    - "re.error.__reduce__.__name__ == '__reduce__' — len 10. Same for Pattern, Match, RegexFlag. Verified Python 3.12."
    - "re.error.__init_subclass__.__qualname__ == 'PatternError.__init_subclass__' — len 30. Note: re.error is an alias for re.PatternError in Python 3.12+. Verified Python 3.12."
    - "re.Pattern.__init_subclass__.__qualname__ == 'Pattern.__init_subclass__' — len 25. Verified Python 3.12."
    - "re.Match.__init_subclass__.__qualname__ == 'Match.__init_subclass__' — len 23. Verified Python 3.12."
    - "re.RegexFlag.__init_subclass__.__qualname__ == 'RegexFlag.__init_subclass__' — len 27. Verified Python 3.12."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — len 9. In Python 3.11+ flags are RegexFlag (IntFlag subclass). Verified Python 3.12."
    - "int(re.IGNORECASE) == 2, int(re.MULTILINE) == 8, int(re.DOTALL) == 16. Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__all__.__len__() and __all__.__class__.__name__.__len__()
#
# re.__all__ is a list of 31 public names including all public functions,
# Pattern, Match, RegexFlag, PatternError, all flag aliases and full names.
# __all__.__class__.__name__ == 'list' (len 4).
# No prior re spec checks __all__.__len__() or __all__.__class__.__name__.
# ---------------------------------------------------------------------------

invariant re_extra33.all.len:
  description: "re.__all__.__len__() == 31 — thirty-one public names exported including all functions, Pattern, Match, RegexFlag, PatternError, and all flag names and aliases"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 31

invariant re_extra33.all.class_name_len:
  description: "re.__all__.__class__.__name__.__len__() == 4 — __all__ is a list; len('list') == 4"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# SomeClass.__dict__.__class__.__name__.__len__() == 12 for re classes
#
# Every Python class exposes its namespace as a types.MappingProxyType whose
# __class__.__name__ is 'mappingproxy' (len 12). No prior re spec checks
# __dict__.__class__.__name__.__len__() for any re class.
# ---------------------------------------------------------------------------

table re_extra33.class_dict_proxy_name_len:
  description: "SomeClass.__dict__.__class__.__name__.__len__() == 12 for re.error, re.Pattern, re.Match, re.RegexFlag — 'mappingproxy' has 12 characters"
  kind: python_call_eq
  category: class_introspection
  id_prefix: rmp33

  columns: [id, function, args, expected]
  rows:
    - [error,     error.__dict__.__class__.__name__.__len__,     [], 12]
    - [Pattern,   Pattern.__dict__.__class__.__name__.__len__,   [], 12]
    - [Match,     Match.__dict__.__class__.__name__.__len__,     [], 12]
    - [RegexFlag, RegexFlag.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# SomeClass.__reduce__.__name__.__len__() == 10 for re classes
#
# '__reduce__' is 10 characters (2+6+2 dunder pair). Inherited slot wrapper.
# No prior re spec checks __reduce__.__name__ for any re class.
# ---------------------------------------------------------------------------

table re_extra33.class_reduce_name_len:
  description: "SomeClass.__reduce__.__name__.__len__() == 10 for re.error, re.Pattern, re.Match, re.RegexFlag — '__reduce__' has 10 characters"
  kind: python_call_eq
  category: class_introspection
  id_prefix: rrn33

  columns: [id, function, args, expected]
  rows:
    - [error,     error.__reduce__.__name__.__len__,     [], 10]
    - [Pattern,   Pattern.__reduce__.__name__.__len__,   [], 10]
    - [Match,     Match.__reduce__.__name__.__len__,     [], 10]
    - [RegexFlag, RegexFlag.__reduce__.__name__.__len__, [], 10]

# ---------------------------------------------------------------------------
# SomeClass.__init_subclass__.__qualname__.__len__() for re classes
#
# __init_subclass__ qualname takes the form 'ClassName.__init_subclass__';
# length = len(class_name) + 18. Note that re.error is an alias for
# re.PatternError in Python 3.12+, so the qualname prefix is 'PatternError':
#   re.Match.__init_subclass__       -> 'Match.__init_subclass__'        -> 23
#   re.Pattern.__init_subclass__     -> 'Pattern.__init_subclass__'      -> 25
#   re.RegexFlag.__init_subclass__   -> 'RegexFlag.__init_subclass__'    -> 27
#   re.error.__init_subclass__       -> 'PatternError.__init_subclass__' -> 30
# No prior re spec checks __init_subclass__.__qualname__.__len__() for any re class.
# ---------------------------------------------------------------------------

invariant re_extra33.Match.init_subclass_qualname_len:
  description: "re.Match.__init_subclass__.__qualname__.__len__() == 23 — 'Match.__init_subclass__' has 23 characters"
  category: class_introspection
  kind: python_call_eq
  function: Match.__init_subclass__.__qualname__.__len__
  args: []
  expected: 23

invariant re_extra33.error.init_subclass_qualname_len:
  description: "re.error.__init_subclass__.__qualname__.__len__() == 30 — 'PatternError.__init_subclass__' has 30 characters; re.error is an alias for re.PatternError in Python 3.12+"
  category: class_introspection
  kind: python_call_eq
  function: error.__init_subclass__.__qualname__.__len__
  args: []
  expected: 30

table re_extra33.class_init_subclass_qualname_lens:
  description: "__init_subclass__.__qualname__.__len__() for Pattern (25) and RegexFlag (27) — novel invariants"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ris33

  columns: [id, function, args, expected]
  rows:
    - [Pattern,   Pattern.__init_subclass__.__qualname__.__len__,   [], 25]
    - [RegexFlag, RegexFlag.__init_subclass__.__qualname__.__len__, [], 27]

# ---------------------------------------------------------------------------
# re.IGNORECASE class name and re flag integer values
#
# In Python 3.11+, re flags are re.RegexFlag (an IntFlag subclass), not plain
# int. re.IGNORECASE.__class__.__name__ == 'RegexFlag' (len 9).
# int(re.IGNORECASE) == 2, int(re.MULTILINE) == 8, int(re.DOTALL) == 16.
# No prior re spec checks IGNORECASE.__class__.__name__.__len__() or the
# integer values of MULTILINE and DOTALL via int() conversion.
# ---------------------------------------------------------------------------

invariant re_extra33.IGNORECASE.class_name_len:
  description: "re.IGNORECASE.__class__.__name__.__len__() == 9 — IGNORECASE is a RegexFlag instance; len('RegexFlag') == 9"
  category: constants
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__len__
  args: []
  expected: 9

invariant re_extra33.RegexFlag.dict_proxy_name_len:
  description: "re.RegexFlag.__dict__.__class__.__name__.__len__() == 12 — RegexFlag class dict is a mappingproxy; len('mappingproxy') == 12"
  category: class_introspection
  kind: python_call_eq
  function: RegexFlag.__dict__.__class__.__name__.__len__
  args: []
  expected: 12
