spec: itertools_extra146
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.__spec__ (ModuleSpec) — __class__.__name__ 'ModuleSpec', name 'itertools' len 9; itertools.tee (C builtin_function_or_method) — __class__.__name__ 'builtin_function_or_method', __qualname__ 'tee' len 3, __doc__ len 43, __module__ 'itertools'; itertools C-type __new__.__class__.__name__ == 'builtin_function_or_method' for count/cycle/repeat/accumulate/groupby; itertools.islice (C type) — __name__ 'islice' len 6, __doc__ len 453, MRO len 2; itertools.starmap (C type) — __name__ 'starmap' len 7, __doc__ len 126, MRO len 2; itertools.accumulate (C type) — __name__ 'accumulate' len 10, __doc__ len 69, MRO len 2 (Wave 274)."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec'; __spec__.name == 'itertools' (len 9). Verified with Python 3.14.3."
    - "itertools.tee is a builtin_function_or_method (C function, not a type); __qualname__ == 'tee' (len 3); __module__ == 'itertools'; __doc__ len == 43. Verified with Python 3.14.3."
    - "itertools.count/cycle/repeat/accumulate/groupby are C types; their __new__ attribute is a builtin_function_or_method. Verified with Python 3.14.3."
    - "itertools.islice: __name__ == 'islice' (len 6); __qualname__ == 'islice'; __doc__ len == 453; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.starmap: __name__ == 'starmap' (len 7); __doc__ len == 126; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.accumulate: __name__ == 'accumulate' (len 10); __doc__ len == 69; MRO len == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__spec__ — ModuleSpec identity
#
# Wave 274 theme: itertools module spec attributes.
#
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__spec__.name == 'itertools' (len 9)
#
# __spec__ is set on every module by the import machinery. For C extension
# modules like itertools, the ModuleSpec is created from the module's
# __name__ and __file__. New to extra146.
# ---------------------------------------------------------------------------

table itertools_extra146.module_spec_attrs:
  description: "itertools.__spec__: ModuleSpec, __class__.__name__=='ModuleSpec', name=='itertools' len 9; wave 274; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsspec146

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_eq_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is set by the import machinery; its class is importlib.machinery.ModuleSpec; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra146"]
    - [spec_name_eq_itertools,
       "__spec__.name.__eq__",
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — the ModuleSpec name attribute is the fully-qualified module name 'itertools'; str.__eq__('itertools') returns True; new to extra146"]
    - [spec_name_len_eq_9,
       "__spec__.name.__len__",
       [],
       9,
       "itertools.__spec__.name.__len__() == 9 — __spec__.name is 'itertools' which has 9 characters; len('itertools') == 9; new to extra146"]
    - [spec_class_name_len_eq_10,
       "__spec__.__class__.__name__.__len__",
       [],
       10,
       "itertools.__spec__.__class__.__name__.__len__() == 10 — __class__.__name__ is 'ModuleSpec' which has 10 characters; len('ModuleSpec') == 10; new to extra146"]

# ---------------------------------------------------------------------------
# Table 2: itertools.tee — C builtin_function_or_method identity
#
# Wave 274 theme: itertools.tee — the C function that returns n independent
# iterators from a single iterable.
#
# itertools.tee.__class__.__name__ == 'builtin_function_or_method'
# itertools.tee.__qualname__ == 'tee' (len 3)
# itertools.tee.__module__ == 'itertools' (len 9)
# len(itertools.tee.__doc__) == 43
#
# tee is a C function (not a type); it returns multiple iterators over the
# same iterable. New to extra146.
# ---------------------------------------------------------------------------

table itertools_extra146.tee_identity:
  description: "itertools.tee: C builtin_function_or_method, __qualname__ 'tee' len 3, __module__ 'itertools', __doc__ len 43; wave 274; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolstee146

  columns: [id, function, args, expected, description]
  rows:
    - [tee_class_eq_builtin,
       "tee.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.tee.__class__.__name__.__eq__('builtin_function_or_method') == True — tee is a C function in itertoolsmodule.c, not a type; __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra146"]
    - [tee_qualname_eq,
       "tee.__qualname__.__eq__",
       ["tee"],
       true,
       "itertools.tee.__qualname__.__eq__('tee') == True — the C function's __qualname__ is 'tee'; str.__eq__('tee') returns True; new to extra146"]
    - [tee_qualname_len_eq_3,
       "tee.__qualname__.__len__",
       [],
       3,
       "itertools.tee.__qualname__.__len__() == 3 — __qualname__ is 'tee' which has 3 characters; len('tee') == 3; new to extra146"]
    - [tee_module_eq_itertools,
       "tee.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.tee.__module__.__eq__('itertools') == True — tee is defined in itertoolsmodule.c; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra146"]
    - [tee_doc_len_eq_43,
       "tee.__doc__.__len__",
       [],
       43,
       "itertools.tee.__doc__.__len__() == 43 — the tee docstring has 43 characters; len(__doc__) == 43; verified with Python 3.14.3; new to extra146"]

# ---------------------------------------------------------------------------
# Table 3: itertools C-type __new__.__class__.__name__ — builtin_function_or_method
#
# Wave 274 theme: itertools C types all expose __new__ as a builtin_function_or_method.
#
# itertools.count.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.cycle.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.repeat.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.accumulate.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.groupby.__new__.__class__.__name__ == 'builtin_function_or_method'
#
# The __new__ slot on C extension types is exposed as a builtin_function_or_method.
# This is a universal property of C types in CPython. New to extra146.
# ---------------------------------------------------------------------------

table itertools_extra146.ctype_new_class_names:
  description: "itertools C types: count/cycle/repeat/accumulate/groupby __new__.__class__.__name__=='builtin_function_or_method'; wave 274; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolstypenew146

  columns: [id, function, args, expected, description]
  rows:
    - [count_new_class_eq_builtin,
       "count.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.count.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — count is a C extension type; its __new__ slot is exposed as a builtin_function_or_method; str.__eq__ returns True; new to extra146"]
    - [cycle_new_class_eq_builtin,
       "cycle.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.cycle.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — cycle is a C extension type; its __new__ slot is exposed as a builtin_function_or_method; str.__eq__ returns True; new to extra146"]
    - [repeat_new_class_eq_builtin,
       "repeat.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.repeat.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — repeat is a C extension type; its __new__ slot is exposed as a builtin_function_or_method; str.__eq__ returns True; new to extra146"]
    - [accumulate_new_class_eq_builtin,
       "accumulate.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.accumulate.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — accumulate is a C extension type; its __new__ slot is exposed as a builtin_function_or_method; str.__eq__ returns True; new to extra146"]
    - [groupby_new_class_eq_builtin,
       "groupby.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.groupby.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — groupby is a C extension type; its __new__ slot is exposed as a builtin_function_or_method; str.__eq__ returns True; new to extra146"]

# ---------------------------------------------------------------------------
# Table 4: itertools.islice, itertools.starmap, itertools.accumulate — C type attrs
#
# Wave 274 theme: islice, starmap, accumulate — lesser-visited itertools C types.
#
# itertools.islice.__name__ == 'islice' (len 6)
# len(itertools.islice.__doc__) == 453
# len(itertools.islice.__mro__) == 2
# itertools.starmap.__name__ == 'starmap' (len 7)
