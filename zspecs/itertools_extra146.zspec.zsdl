# itertools.accumulate.__name__ == 'accumulate' (len 10)
# len(itertools.accumulate.__doc__) == 69
# len(itertools.accumulate.__mro__) == 2
#
# islice returns selected elements from an iterable; starmap applies a function
# using arguments from an iterable of tuples; accumulate yields running totals.
# New to extra146.
# ---------------------------------------------------------------------------

