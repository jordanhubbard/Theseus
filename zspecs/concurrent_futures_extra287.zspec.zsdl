spec: concurrent_futures_extra287
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "concurrent.futures.__name__ is 'concurrent.futures'"
    - "concurrent.futures.__package__ is 'concurrent.futures'"
    - "concurrent.__name__ is 'concurrent'"
    - "concurrent.__package__ is 'concurrent'"
    - "concurrent.futures.__spec__.__class__.__name__ is 'ModuleSpec'"
    - "concurrent.futures.__loader__.__class__.__name__ is 'SourceFileLoader'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra287.module_identity:
  description: "concurrent.futures module identity attributes"
  kind: python_call_eq
  category: identity
  id_prefix: cf287

  columns: [id, function, args, expected, description]
  rows:
    - [cf287_001, concurrent.futures.__name__.__eq__, ["concurrent.futures"], true, "concurrent.futures __name__ is 'concurrent.futures'"]
    - [cf287_002, concurrent.futures.__package__.__eq__, ["concurrent.futures"], true, "concurrent.futures __package__ is 'concurrent.futures'"]
    - [cf287_003, concurrent.futures.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "__spec__ class is ModuleSpec"]
    - [cf287_004, concurrent.futures.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "__loader__ class is SourceFileLoader"]

table concurrent_futures_extra287.concurrent_package_identity:
  description: "concurrent package and concurrent.futures extra identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: cf287p

  columns: [id, function, args, expected, description]
  rows:
    - [cf287p_001, concurrent.__name__.__eq__, ["concurrent"], true, "concurrent __name__ is 'concurrent'"]
    - [cf287p_002, concurrent.__package__.__eq__, ["concurrent"], true, "concurrent __package__ is 'concurrent'"]
    - [cf287p_003, concurrent.futures.__file__.__class__.__name__.__eq__, ["str"], true, "__file__ is a str"]
    - [cf287p_004, concurrent.futures.__spec__.__name__.__eq__, ["concurrent.futures"], true, "__spec__.name is 'concurrent.futures'"]

invariant concurrent_futures_extra287.futures_name:
  description: "concurrent.futures.__name__ equals 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.__name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra287.futures_package:
  description: "concurrent.futures.__package__ equals 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.__package__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra287.concurrent_name:
  description: "concurrent.__name__ equals 'concurrent'"
  category: identity
  kind: python_call_eq
  function: concurrent.__name__.__eq__
  args: ["concurrent"]
  expected: true
