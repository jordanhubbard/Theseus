spec: uuid_extra87
version: ">=3.9"
backend: python_module(uuid)
extends: uuid_extra86

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra86.zspec.zsdl — covers uuid.UUID/__init__/__code__/co_name.__eq__('__init__') / co_argcount.__eq__(7) / __qualname__.__eq__('UUID.__init__') / uuid1/uuid4/uuid3/uuid5/getnode __qualname__, __module__, co_argcount (table + invariants)."
    - "uuid_extra85.zspec.zsdl — covers uuid.UUID/__dict__ membership for dunder methods and property names / UUID and SafeUUID __dict__ class names (table + invariants)."
    - "uuid_extra84.zspec.zsdl — covers uuid.UUID/__name__/__module__/__qualname__/__class__.__name__ / UUID/__bases__/__mro__ / SafeUUID class identity (table + invariants)."
    - "uuid_extra83.zspec.zsdl — covers UUID dunder method __qualname__ lengths / UUID string and numeric property fget __qualname__ lengths (table + invariants)."
    - "uuid_extra82.zspec.zsdl — covers uuid.SafeUUID enum member class identity / uuid module identity (table + invariants)."
    - "uuid_extra79.zspec.zsdl — covers UUID dunder method __qualname__.__eq__ / uuid1/uuid3/uuid4/uuid5 __qualname__.__eq__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra86; it does NOT duplicate invariants present in those files."
    - "Wave 258 theme: uuid.UUID __setattr__ and __delattr__ class names + UUID field property class names + UUID.__repr__/__str__ code attrs + UUID property fget __qualname__ equality."
    - "uuid.UUID.__setattr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__delattr__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__code__.co_name == '__setattr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__code__.co_argcount == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__qualname__ == 'UUID.__setattr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_low.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_mid.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_hi_version.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_hi_variant.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_low.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__code__.co_name == '__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_name == '__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_low.fget.__qualname__ == 'UUID.time_low'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__qualname__ == 'UUID.node'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__qualname__ == 'UUID.time'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.fget.__qualname__ == 'UUID.clock_seq'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.__setattr__ is a pure-Python override that raises TypeError for immutability; UUID.__delattr__ falls through to object's slot wrapper."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__class__.__name__.__eq__('function')
# uuid.UUID.__delattr__.__class__.__name__.__eq__('wrapper_descriptor')
# uuid.UUID.__setattr__.__code__.co_name.__eq__('__setattr__')
# uuid.UUID.__setattr__.__code__.co_argcount.__eq__(3)
#
# Wave 258 theme: UUID.__setattr__ and __delattr__ class names.
#
# UUID is an immutable class — attempting to set an attribute raises TypeError.
# UUID.__setattr__ is a pure-Python function (class 'function') that raises
# TypeError unconditionally. UUID.__delattr__ is a 'wrapper_descriptor'
# inherited from object's C slot (UUID does not override __delattr__).
# UUID.__setattr__.__code__.co_name is '__setattr__' and co_argcount is 3
# (self + name + value). No prior uuid spec anchors these together under
# uuidimmutable87. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra87.uuid_UUID_setattr_delattr_class_names:
  description: "uuid.UUID.__setattr__/__class__.__name__.__eq__('function')==True / UUID.__delattr__/__class__.__name__.__eq__('wrapper_descriptor')==True / UUID.__setattr__/__code__/co_name.__eq__('__setattr__')==True / UUID.__setattr__/__code__/co_argcount.__eq__(3)==True — UUID.__setattr__ is a pure-Python function raising TypeError (immutability); UUID.__delattr__ is object's slot wrapper_descriptor (not overridden); co_name=='__setattr__', co_argcount==3 (self+name+value); no prior uuid spec anchors these together; first uuidimmutable87 anchor for UUID setattr/delattr class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidimmutable87

  columns: [id, function, args, expected]
  rows:
    - [setattr_class,      "UUID.__setattr__.__class__.__name__.__eq__",    ["function"],          true]
    - [delattr_class,      "UUID.__delattr__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - [setattr_co_name,    "UUID.__setattr__.__code__.co_name.__eq__",      ["__setattr__"],        true]
    - [setattr_co_argcount, "UUID.__setattr__.__code__.co_argcount.__eq__", [3],                   true]

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.__class__.__name__.__eq__('property')
# uuid.UUID.time_mid.__class__.__name__.__eq__('property')
# uuid.UUID.time_hi_version.__class__.__name__.__eq__('property')
# uuid.UUID.clock_seq_hi_variant.__class__.__name__.__eq__('property')
# uuid.UUID.clock_seq_low.__class__.__name__.__eq__('property')
# uuid.UUID.node.__class__.__name__.__eq__('property')
# uuid.UUID.time.__class__.__name__.__eq__('property')
# uuid.UUID.clock_seq.__class__.__name__.__eq__('property')
#
# Wave 258 theme: UUID field properties __class__.__name__ == 'property'.
#
# UUID exposes the internal 128-bit integer as named fields through Python
# properties: time_low, time_mid, time_hi_version, clock_seq_hi_variant,
# clock_seq_low, node, time, and clock_seq. Each is a pure-Python property
# object (class 'property') with a fget function. No prior uuid spec anchors
# these eight property class names together under uuidimmutable87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra87.uuid_UUID_field_property_class_names:
  description: "uuid.UUID.time_low/__class__.__name__.__eq__('property')==True / time_mid/__class__.__name__.__eq__==True / time_hi_version/__class__.__name__.__eq__==True / clock_seq_hi_variant/__class__.__name__.__eq__==True / clock_seq_low/__class__.__name__.__eq__==True / node/__class__.__name__.__eq__==True / time/__class__.__name__.__eq__==True / clock_seq/__class__.__name__.__eq__==True — all eight UUID field accessors are pure-Python property objects (class 'property') with fget functions; no prior uuid spec anchors these eight together; first uuidimmutable87 anchor for UUID field property class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidimmutable87

  columns: [id, function, args, expected]
  rows:
    - [time_low_prop,           "UUID.time_low.__class__.__name__.__eq__",           ["property"], true]
    - [time_mid_prop,           "UUID.time_mid.__class__.__name__.__eq__",           ["property"], true]
    - [time_hi_version_prop,    "UUID.time_hi_version.__class__.__name__.__eq__",    ["property"], true]
    - [clock_seq_hi_variant_prop, "UUID.clock_seq_hi_variant.__class__.__name__.__eq__", ["property"], true]
    - [clock_seq_low_prop,      "UUID.clock_seq_low.__class__.__name__.__eq__",      ["property"], true]
    - [node_prop,               "UUID.node.__class__.__name__.__eq__",               ["property"], true]
    - [time_prop,               "UUID.time.__class__.__name__.__eq__",               ["property"], true]
    - [clock_seq_prop,          "UUID.clock_seq.__class__.__name__.__eq__",          ["property"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_name.__eq__('__repr__')
# uuid.UUID.__repr__.__code__.co_argcount.__eq__(1)
# uuid.UUID.__str__.__code__.co_name.__eq__('__str__')
# uuid.UUID.__str__.__code__.co_argcount.__eq__(1)
#
# Wave 258 theme: UUID.__repr__ and __str__ code attrs.
#
# Both UUID.__repr__ and UUID.__str__ are pure-Python functions (class
# 'function'). Their __code__.co_name matches their function name, and
# co_argcount is 1 (only self). __repr__ returns a string of the form
# 'UUID("...")', while __str__ returns the canonical hyphenated hex form.
# No prior uuid spec anchors these four code attrs together under uuidimmutable87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra87.uuid_UUID_repr_str_code_attrs:
  description: "uuid.UUID.__repr__/__code__/co_name.__eq__('__repr__')==True / __repr__/__code__/co_argcount.__eq__(1)==True / __str__/__code__/co_name.__eq__('__str__')==True / __str__/__code__/co_argcount.__eq__(1)==True — both UUID.__repr__ and __str__ are pure-Python functions; co_name matches the function name; co_argcount==1 (self only); no prior uuid spec anchors these four code attrs together; first uuidimmutable87 anchor for UUID.__repr__ and __str__ code attrs"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidimmutable87

  columns: [id, function, args, expected]
  rows:
    - [repr_co_name,    "UUID.__repr__.__code__.co_name.__eq__",    ["__repr__"], true]
    - [repr_co_argcount, "UUID.__repr__.__code__.co_argcount.__eq__", [1],        true]
    - [str_co_name,     "UUID.__str__.__code__.co_name.__eq__",     ["__str__"],  true]
    - [str_co_argcount, "UUID.__str__.__code__.co_argcount.__eq__",  [1],         true]

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.fget.__qualname__.__eq__('UUID.time_low')
# uuid.UUID.node.fget.__qualname__.__eq__('UUID.node')
# uuid.UUID.time.fget.__qualname__.__eq__('UUID.time')
# uuid.UUID.clock_seq.fget.__qualname__.__eq__('UUID.clock_seq')
#
# Wave 258 theme: UUID property fget __qualname__ equality.
#
# The fget function of each UUID property has a __qualname__ of the form
# 'UUID.<property_name>'. This confirms each property getter is a method
# defined inside the UUID class body. No prior uuid spec anchors these four
# fget __qualname__ checks together under uuidimmutable87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra87.uuid_UUID_property_fget_qualname:
  description: "uuid.UUID.time_low/fget/__qualname__.__eq__('UUID.time_low')==True / node/fget/__qualname__.__eq__('UUID.node')==True / time/fget/__qualname__.__eq__('UUID.time')==True / clock_seq/fget/__qualname__.__eq__('UUID.clock_seq')==True — each property's fget has __qualname__ of the form 'UUID.<name>', confirming it is a method defined inside the UUID class body; no prior uuid spec anchors these four fget __qualname__ checks together; first uuidimmutable87 anchor for UUID property fget __qualname__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidimmutable87

  columns: [id, function, args, expected]
  rows:
    - [time_low_fget_qualname,  "UUID.time_low.fget.__qualname__.__eq__",  ["UUID.time_low"],  true]
    - [node_fget_qualname,      "UUID.node.fget.__qualname__.__eq__",      ["UUID.node"],      true]
    - [time_fget_qualname,      "UUID.time.fget.__qualname__.__eq__",      ["UUID.time"],      true]
    - [clock_seq_fget_qualname, "UUID.clock_seq.fget.__qualname__.__eq__", ["UUID.clock_seq"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__class__.__name__.__eq__('function') — standalone
#
# uuid.UUID.__setattr__ is a pure-Python function (class 'function'). UUID
# overrides __setattr__ to raise TypeError, making UUID instances immutable.
# This is different from most Python classes where __setattr__ is a
# slot wrapper inherited from object. No prior uuid spec anchors
# UUID.__setattr__.__class__.__name__.__eq__('function') as a standalone
# under uuidimmutable87. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra87.setattr_class_function:
  description: "uuid.UUID.__setattr__.__class__.__name__.__eq__('function') == True — UUID overrides __setattr__ with a pure-Python function that raises TypeError, making instances immutable; unlike most classes, UUID's __setattr__ is 'function' not 'slot wrapper'; no prior uuid spec anchors this as a standalone; first standalone for UUID.__setattr__ class name under uuidimmutable87"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__setattr__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__delattr__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# uuid.UUID.__delattr__ is a 'wrapper_descriptor'. UUID does not override
# __delattr__, so it inherits object's C-level slot wrapper. Attempting to
# delete a UUID attribute also raises TypeError (through the immutability
# mechanism), but via the inherited C slot rather than a Python override.
# No prior uuid spec anchors UUID.__delattr__.__class__.__name__.__eq__ as a
# standalone under uuidimmutable87. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra87.delattr_class_wrapper_descriptor:
  description: "uuid.UUID.__delattr__.__class__.__name__.__eq__('wrapper_descriptor') == True — UUID does not override __delattr__; it inherits object's C-level slot wrapper_descriptor; no prior uuid spec anchors this as a standalone; first standalone for UUID.__delattr__ class name under uuidimmutable87"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__delattr__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.__class__.__name__.__eq__('property') — standalone
#
# uuid.UUID.time_low is a Python property. It extracts the time_low field
# (bits 0-31 of the UUID time_low component) from the internal 128-bit
# integer. Being a property allows the UUID class to provide named access
# to UUID fields while remaining immutable (no setter is defined). No prior
# uuid spec anchors UUID.time_low.__class__.__name__.__eq__ as a standalone
# under uuidimmutable87. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra87.time_low_property:
  description: "uuid.UUID.time_low.__class__.__name__.__eq__('property') == True — UUID.time_low is a Python property extracting bits 0-31 of the UUID time_low component from the internal int; no setter is defined, preserving immutability; no prior uuid spec anchors this as a standalone; first standalone for UUID.time_low class name under uuidimmutable87"
  category: type_identity
  kind: python_call_eq
  function: "UUID.time_low.__class__.__name__.__eq__"
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_argcount.__eq__(1) — standalone
#
# uuid.UUID.__repr__.__code__.co_argcount is 1. UUID.__repr__ is a pure-Python
# function that takes only self (co_argcount==1) and returns a string of the
# form UUID('xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'). This confirms __repr__
# is a unary method with no additional parameters. No prior uuid spec anchors
# UUID.__repr__.__code__.co_argcount.__eq__(1) as a standalone under
# uuidimmutable87. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra87.repr_co_argcount:
  description: "uuid.UUID.__repr__.__code__.co_argcount.__eq__(1) == True — UUID.__repr__ is a pure-Python function taking only self (co_argcount==1); it returns UUID('xxxx...') format string; no prior uuid spec anchors this as a standalone; first standalone for UUID.__repr__ co_argcount under uuidimmutable87"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__repr__.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.node.fget.__qualname__.__eq__('UUID.node') — standalone
#
# uuid.UUID.node.fget.__qualname__ is 'UUID.node'. The node property getter
# extracts the last 48 bits of the UUID (the IEEE 802 MAC address or random
# node component). Its fget __qualname__ is 'UUID.node', confirming it is a
# method defined inside the UUID class body. No prior uuid spec anchors
# UUID.node.fget.__qualname__.__eq__ as a standalone under uuidimmutable87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra87.node_fget_qualname:
  description: "uuid.UUID.node.fget.__qualname__.__eq__('UUID.node') == True — UUID.node.fget extracts the last 48 bits (IEEE 802 MAC / random node); its __qualname__ is 'UUID.node', confirming it is a UUID class method; no prior uuid spec anchors this as a standalone; first standalone for UUID.node fget __qualname__ under uuidimmutable87"
  category: type_identity
  kind: python_call_eq
  function: "UUID.node.fget.__qualname__.__eq__"
  args: ["UUID.node"]
  expected: true
