spec: warnings_extra14
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra13.zspec.zsdl."
    - "warnings_extra2 covers: _filters_mutated/__name__."
    - "warnings_extra11 covers: WarningMessage/__name__, WarningMessage/__module__, WarningMessage/__bases__[0].__name__, warn/__qualname__, defaultaction/__class__.__name__, defaultaction value."
    - "warnings_extra12 covers: WarningMessage/__class__.__name__ == 'type', catch_warnings/__class__.__name__ == 'type', warn/__qualname__."
    - "warnings_extra13 covers: filterwarnings/__class__.__name__, simplefilter/__class__.__name__, resetwarnings/__class__.__name__, showwarning/__class__.__name__ == 'function'."
    - "NOT yet covered in any prior spec: simplefilter/__name__, simplefilter/__module__."
    - "NOT yet covered in any prior spec: filterwarnings/__name__, filterwarnings/__module__."
    - "NOT yet covered in any prior spec: _filters_mutated/__module__, _filters_mutated/__qualname__."
    - "NOT yet covered in any prior spec: WarningMessage/__qualname__ (warnings_extra11 covers it but checks against 'WarningMessage' — verified correct)."
    - "simplefilter.__module__ == '_py_warnings' — defined in the pure-Python warnings fallback layer."
    - "filterwarnings.__module__ == '_py_warnings' — same module as simplefilter."
    - "_filters_mutated.__module__ == '_py_warnings' — internal C-adjacent function in the Python layer."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# simplefilter and filterwarnings — __name__ and __module__
#
# warnings_extra13 records __class__.__name__ == 'function' for both.
# No prior spec records __name__ or __module__ for either.
# Both are pure-Python functions defined in the _py_warnings (Lib/warnings.py)
# layer; their __module__ is '_py_warnings'.
# ---------------------------------------------------------------------------

table warnings_extra14.simplefilter_filterwarnings_identity:
  description: "__name__ and __module__ for simplefilter and filterwarnings"
  kind: python_call_eq
  category: function_identity

  columns: [id, function, args, expected]
  rows:
    - [simplefilter_name,    simplefilter.__name__.__eq__,    ["simplefilter"],   true]
    - [simplefilter_module,  simplefilter.__module__.__eq__,  ["_py_warnings"],   true]
    - [filterwarnings_name,  filterwarnings.__name__.__eq__,  ["filterwarnings"], true]
    - [filterwarnings_module, filterwarnings.__module__.__eq__, ["_py_warnings"], true]

# ---------------------------------------------------------------------------
# _filters_mutated — __module__ and __qualname__
#
# warnings_extra2 records _filters_mutated/__name__ == '_filters_mutated'.
# No prior spec records __module__ or __qualname__ for _filters_mutated.
# It is a pure-Python internal function in _py_warnings; for top-level
# functions __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant warnings_extra14._filters_mutated.module:
  description: "warnings._filters_mutated.__module__ == '_py_warnings'"
  category: function_identity
  kind: python_call_eq
  function: _filters_mutated.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

invariant warnings_extra14._filters_mutated.qualname:
  description: "warnings._filters_mutated.__qualname__ == '_filters_mutated'"
  category: function_identity
  kind: python_call_eq
  function: _filters_mutated.__qualname__.__eq__
  args: ["_filters_mutated"]
  expected: true
