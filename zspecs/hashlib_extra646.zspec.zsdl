spec: hashlib_extra646
version: ">=3.9"
backend: python_module(hashlib)
docs: "Behavioral spec for hashlib blake2 and sha2 function __name__, __module__, and __qualname__ identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib: Secure hashes and message digests"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __module__ identity for md5, sha1, sha256, sha512; __class__.__name__ and __doc__ class for sha224, sha384; blake2b/blake2s __qualname__ for __init__ and update."
  created_at: "2026-04-12T00:00:00Z"

table hashlib_extra646.sha_module_identity:
  description: "Verifies that sha and md5 constructors report _hashlib as their __module__."
  kind: python_call_eq
  category: module_identity
  id_prefix: hl646b2
  columns: [id, function, args, expected]
  rows:
    - [hl646b2001, hashlib.md5.__module__.__eq__, ["_hashlib"], true]
    - [hl646b2002, hashlib.sha1.__module__.__eq__, ["_hashlib"], true]
    - [hl646b2003, hashlib.sha256.__module__.__eq__, ["_hashlib"], true]
    - [hl646b2004, hashlib.sha512.__module__.__eq__, ["_hashlib"], true]

table hashlib_extra646.sha224_sha384_class_identity:
  description: "Verifies __class__.__name__ and __doc__.__class__.__name__ for sha224 and sha384."
  kind: python_call_eq
  category: class_identity
  id_prefix: hl646sh
  columns: [id, function, args, expected]
  rows:
    - [hl646sh001, hashlib.sha224.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl646sh002, hashlib.sha224.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl646sh003, hashlib.sha384.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl646sh004, hashlib.sha384.__doc__.__class__.__name__.__eq__, ["str"], true]

table hashlib_extra646.blake2_qualname_identity:
  description: "Verifies __qualname__ for blake2b and blake2s __init__ and update methods."
  kind: python_call_eq
  category: qualname_identity
  id_prefix: hl646bq
  columns: [id, function, args, expected]
  rows:
    - [hl646bq001, hashlib.blake2b.__init__.__qualname__.__eq__, ["blake2b.__init__"], true]
    - [hl646bq002, hashlib.blake2b.update.__qualname__.__eq__, ["blake2b.update"], true]
    - [hl646bq003, hashlib.blake2s.__init__.__qualname__.__eq__, ["blake2s.__init__"], true]
    - [hl646bq004, hashlib.blake2s.update.__qualname__.__eq__, ["blake2s.update"], true]
