spec: socket_extra123
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra122.zspec.zsdl — covers socket Python-level function __code__ attributes (co_name, co_argcount) for getaddrinfo/create_connection/getfqdn/has_dualstack_ipv6/create_server (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC __class__.__name__.__eq__ ('AddressFamily') / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW __class__.__name__.__eq__('SocketKind') (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra122; it does NOT duplicate invariants present in those files."
    - "Wave 292 theme: socket AF_*/SOCK_* enum member class module and qualname identity — extra96 anchors __class__.__name__ equality for AF_INET/AF_INET6/AF_UNIX/AF_UNSPEC/SOCK_STREAM/SOCK_DGRAM/SOCK_RAW; NOT YET covered: __class__.__module__ / __class__.__qualname__ / __class__.__name__.__len__() / .name (str attribute) lengths / .value (int attribute) equality for SOCK_STREAM/SOCK_DGRAM/SOCK_RAW."
    - "socket.AF_INET.__class__.__module__ == 'socket'. Both AddressFamily and SocketKind enums are defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__module__ == 'socket'. SocketKind is also defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__qualname__ == 'AddressFamily'. The qualname equals the name for a top-level class (no nesting prefix). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__qualname__ == 'SocketKind'. Same as __name__ for top-level class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__.__len__() == 13. len('AddressFamily')==13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__.__len__() == 10. len('SocketKind')==10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.value == 1. SOCK_STREAM is the stream socket type (TCP). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.value == 2. SOCK_DGRAM is the datagram socket type (UDP). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.value == 3. SOCK_RAW is the raw socket type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.value == 2. AF_INET is the IPv4 address family. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: AddressFamily and SocketKind are IntEnum subclasses defined in Lib/socket.py. Their __class__.__module__ is 'socket' (the Python-level module, not the C socketmodule.c). The __class__.__qualname__ equals __class__.__name__ for these top-level enum classes (no nested class prefix). extra96 anchors __class__.__name__ (as equality to string); no prior socket spec anchors __class__.__module__ or __class__.__qualname__ for any AF_* or SOCK_* constant. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__module__.__eq__('socket')
# socket.AF_INET6.__class__.__module__.__eq__('socket')
# socket.SOCK_STREAM.__class__.__module__.__eq__('socket')
# socket.SOCK_DGRAM.__class__.__module__.__eq__('socket')
# socket.AF_INET.__class__.__qualname__.__eq__('AddressFamily')
#
# Wave 292 theme: AF_*/SOCK_* enum class module and qualname.
#
# AddressFamily and SocketKind are both defined in Lib/socket.py (the Python-level
# socket module), so their __module__ is 'socket'. Their __qualname__ equals
# their __name__ because they are top-level (non-nested) enum classes. extra96
# anchors __class__.__name__.__eq__ for AF_INET/AF_INET6/AF_UNIX/SOCK_STREAM/
# SOCK_DGRAM/SOCK_RAW; no prior socket spec anchors __class__.__module__ or
# __class__.__qualname__ for any AF_* or SOCK_* constant under sockaddr123.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra123.AF_SOCK_class_module_and_qualname:
  description: "AF_INET.__class__.__module__.__eq__('socket')==True / AF_INET6.__class__.__module__.__eq__('socket')==True / SOCK_STREAM.__class__.__module__.__eq__('socket')==True / SOCK_DGRAM.__class__.__module__.__eq__('socket')==True / AF_INET.__class__.__qualname__.__eq__('AddressFamily')==True — AddressFamily and SocketKind are defined in Lib/socket.py so __module__=='socket'; __qualname__ equals __name__ for top-level enum classes; extra96 anchors __class__.__name__ equality; no prior spec anchors __class__.__module__ or __class__.__qualname__ for any AF_*/SOCK_*; first sockaddr123 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockaddr123

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_module,    "AF_INET.__class__.__module__.__eq__",    ["socket"], true, "AF_INET.__class__.__module__ is 'socket' (AddressFamily enum defined in Lib/socket.py; not socketmodule.c; extra96 anchors __class__.__name__; no prior spec anchors __class__.__module__)"]
    - [af_inet6_module,   "AF_INET6.__class__.__module__.__eq__",   ["socket"], true, "AF_INET6.__class__.__module__ is 'socket' (same as AF_INET — all AF_* members belong to AddressFamily which is defined in Lib/socket.py)"]
    - [sock_stream_mod,   "SOCK_STREAM.__class__.__module__.__eq__", ["socket"], true, "SOCK_STREAM.__class__.__module__ is 'socket' (SocketKind enum also defined in Lib/socket.py; same module as AddressFamily)"]
    - [sock_dgram_mod,    "SOCK_DGRAM.__class__.__module__.__eq__",  ["socket"], true, "SOCK_DGRAM.__class__.__module__ is 'socket' (all SOCK_* members belong to SocketKind from Lib/socket.py)"]
    - [af_inet_qualname,  "AF_INET.__class__.__qualname__.__eq__",  ["AddressFamily"], true, "AF_INET.__class__.__qualname__ is 'AddressFamily' (equals __name__ for top-level class; no nested class prefix; extra96 anchors __name__.__eq__; no prior spec anchors __qualname__)"]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind')
# socket.AF_INET.__class__.__name__.__len__()==13
# socket.SOCK_STREAM.__class__.__name__.__len__()==10
# socket.AF_UNIX.__class__.__module__.__eq__('socket')
# socket.SOCK_RAW.__class__.__module__.__eq__('socket')
#
# Wave 292 theme: SocketKind qualname, class name lengths, AF_UNIX and SOCK_RAW module.
#
# SOCK_STREAM.__class__.__qualname__ is 'SocketKind' (same as __name__, top-level class).
# AF_INET.__class__.__name__.__len__() is 13 (len('AddressFamily')==13).
# SOCK_STREAM.__class__.__name__.__len__() is 10 (len('SocketKind')==10).
# AF_UNIX and SOCK_RAW also have __class__.__module__=='socket'.
# No prior socket spec anchors any class name length or SocketKind qualname.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra123.class_qualname_and_name_lengths:
  description: "SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind')==True / AF_INET.__class__.__name__.__len__()==13 / SOCK_STREAM.__class__.__name__.__len__()==10 / AF_UNIX.__class__.__module__.__eq__('socket')==True / SOCK_RAW.__class__.__module__.__eq__('socket')==True — SocketKind __qualname__ equals __name__ (top-level class); len('AddressFamily')==13; len('SocketKind')==10; AF_UNIX and SOCK_RAW complete the module cross-check; extra96 anchors __class__.__name__ equality; no prior spec anchors class name lengths; first sockaddr123 length anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockaddr123

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_qual,   "SOCK_STREAM.__class__.__qualname__.__eq__", ["SocketKind"], true, "SOCK_STREAM.__class__.__qualname__ is 'SocketKind' (equals __name__ for top-level class; no nested class prefix; extra96 anchors __name__.__eq__('SocketKind'); no prior spec anchors SocketKind qualname)"]
    - [af_inet_name_len,   "AF_INET.__class__.__name__.__len__",        [],             13,   "AF_INET.__class__.__name__.__len__() is 13 (len('AddressFamily')==13; 'Address'=7 + 'Family'=6; no prior spec anchors AddressFamily class name length)"]
    - [sock_kind_name_len, "SOCK_STREAM.__class__.__name__.__len__",    [],             10,   "SOCK_STREAM.__class__.__name__.__len__() is 10 (len('SocketKind')==10; 'Socket'=6 + 'Kind'=4; shorter than AddressFamily at 13 chars; no prior spec anchors SocketKind class name length)"]
    - [af_unix_module,     "AF_UNIX.__class__.__module__.__eq__",       ["socket"],     true, "AF_UNIX.__class__.__module__ is 'socket' (AF_UNIX is a member of AddressFamily; defined in Lib/socket.py; completes AF_* module cross-check with AF_INET and AF_INET6)"]
    - [sock_raw_module,    "SOCK_RAW.__class__.__module__.__eq__",      ["socket"],     true, "SOCK_RAW.__class__.__module__ is 'socket' (SOCK_RAW is a member of SocketKind; completes SOCK_* module cross-check with SOCK_STREAM and SOCK_DGRAM)"]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.value.__eq__(1)
# socket.SOCK_DGRAM.value.__eq__(2)
# socket.SOCK_RAW.value.__eq__(3)
# socket.AF_INET.value.__eq__(2)
# socket.AF_INET6.value.__eq__(30)
#
# Wave 292 theme: AF_*/SOCK_* enum member .value equality.
#
# SOCK_STREAM.value is 1 (the integer value for TCP stream sockets).
# SOCK_DGRAM.value is 2 (UDP datagram sockets). SOCK_RAW.value is 3 (raw sockets).
# AF_INET.value is 2 (IPv4). AF_INET6.value is 30 (IPv6 on macOS/Darwin).
# extra95 anchors enum member .name string values but NOT .value integers.
# No prior socket spec anchors .value for any AF_* or SOCK_* constant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra123.sock_AF_values:
  description: "SOCK_STREAM.value.__eq__(1)==True / SOCK_DGRAM.value.__eq__(2)==True / SOCK_RAW.value.__eq__(3)==True / AF_INET.value.__eq__(2)==True / AF_INET6.value.__eq__(30)==True — SOCK_STREAM=1 (TCP), SOCK_DGRAM=2 (UDP), SOCK_RAW=3 (raw); AF_INET=2 (IPv4), AF_INET6=30 (IPv6 on macOS); extra95 anchors .name string values but NOT .value integers; no prior socket spec anchors .value for any AF_*/SOCK_*; first sockaddr123 value anchor"
  kind: python_call_eq
  category: numeric_values
  id_prefix: sockaddr123

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_val, "SOCK_STREAM.value.__eq__", [1],  true, "SOCK_STREAM.value is 1 (TCP stream socket; the TCP protocol is identified by socket type SOCK_STREAM==1; extra95 anchors SOCK_STREAM.name=='SOCK_STREAM')"]
    - [sock_dgram_val,  "SOCK_DGRAM.value.__eq__",  [2],  true, "SOCK_DGRAM.value is 2 (UDP datagram socket; SOCK_DGRAM==2; extra95 anchors SOCK_DGRAM.name=='SOCK_DGRAM')"]
    - [sock_raw_val,    "SOCK_RAW.value.__eq__",    [3],  true, "SOCK_RAW.value is 3 (raw socket giving direct access to IP layer; SOCK_RAW==3; extra95 anchors SOCK_RAW.name=='SOCK_RAW')"]
    - [af_inet_val,     "AF_INET.value.__eq__",     [2],  true, "AF_INET.value is 2 (IPv4 address family; AF_INET==2 is the same integer value as SOCK_DGRAM==2, a coincidence of the POSIX constant numbering)"]
    - [af_inet6_val,    "AF_INET6.value.__eq__",    [30], true, "AF_INET6.value is 30 (IPv6 address family on macOS/Darwin 25.4.0; value 30 is platform-specific: macOS uses 30, Linux uses 10)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__module__.__eq__('socket') — standalone
#
# socket.AF_INET.__class__.__module__ is 'socket'. AddressFamily is defined
# in Lib/socket.py — the Python-level socket module — not in socketmodule.c
# (the C extension). The enum class inherits from IntEnum and is constructed
# via Python code in Lib/socket.py. Since it is a Python-level class, its
# __module__ reflects the Python module ('socket') rather than the C module
# ('_socket'). No prior socket spec anchors AF_INET.__class__.__module__ in
# any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra123.AF_INET_class_module_socket:
  description: "socket.AF_INET.__class__.__module__.__eq__('socket') == True — AddressFamily is defined in Lib/socket.py (the Python-level module, not socketmodule.c); since it is a Python-level IntEnum class, __module__ is 'socket' (not '_socket' the C extension); extra96 anchors __class__.__name__.__eq__('AddressFamily'); no prior socket spec anchors AF_INET.__class__.__module__ in any form; first standalone under sockaddr123"
  category: type_identity
  kind: python_call_eq
  function: "AF_INET.__class__.__module__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__class__.__module__.__eq__('socket') — standalone
#
# socket.SOCK_STREAM.__class__.__module__ is 'socket'. SocketKind is defined
# in Lib/socket.py alongside AddressFamily. Both are IntEnum subclasses created
# in Python code. Their common __module__ ('socket') distinguishes them from
# C-level socket types (like the socket.socket class itself, which is a C
# extension type with __module__=='socket' too, but implemented in socketmodule.c).
# No prior socket spec anchors SOCK_STREAM.__class__.__module__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra123.SOCK_STREAM_class_module_socket:
  description: "socket.SOCK_STREAM.__class__.__module__.__eq__('socket') == True — SocketKind is defined in Lib/socket.py as an IntEnum subclass; __module__=='socket' for the Python-level SocketKind class; extra96 anchors __class__.__name__.__eq__('SocketKind'); no prior socket spec anchors SOCK_STREAM.__class__.__module__ in any form; first SOCK_STREAM module standalone under sockaddr123"
  category: type_identity
  kind: python_call_eq
  function: "SOCK_STREAM.__class__.__module__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__qualname__.__eq__('AddressFamily') — standalone
#
# socket.AF_INET.__class__.__qualname__ is 'AddressFamily'. AddressFamily is a
# top-level class defined in Lib/socket.py (not nested inside another class), so
# its __qualname__ is simply 'AddressFamily' — the same as its __name__. This
# contrasts with nested classes where __qualname__ would be 'Outer.Inner'. The
# qualname 'AddressFamily' has 13 chars. No prior socket spec anchors
# AF_INET.__class__.__qualname__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra123.AF_INET_class_qualname_AddressFamily:
  description: "socket.AF_INET.__class__.__qualname__.__eq__('AddressFamily') == True — AddressFamily is a top-level class in Lib/socket.py; __qualname__ equals __name__ ('AddressFamily', 13 chars) because it is not nested inside another class; contrasts with nested classes where __qualname__ would have 'Outer.Inner' format; extra96 anchors __class__.__name__.__eq__('AddressFamily'); no prior socket spec anchors AF_INET.__class__.__qualname__ in any form; first standalone under sockaddr123"
  category: type_identity
  kind: python_call_eq
  function: "AF_INET.__class__.__qualname__.__eq__"
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.value.__eq__(1) — standalone
#
# socket.SOCK_STREAM.value is 1. SOCK_STREAM is the socket type for TCP
# (stream-oriented, connection-based, reliable). The integer value 1 comes from
# the POSIX socket API (defined in <sys/socket.h>). SOCK_STREAM is the most
# commonly used socket type for TCP network programming. extra95 anchors
# SOCK_STREAM.name=='SOCK_STREAM'; no prior socket spec anchors SOCK_STREAM.value
# in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra123.SOCK_STREAM_value_1:
  description: "socket.SOCK_STREAM.value.__eq__(1) == True — SOCK_STREAM is the TCP stream socket type; integer value 1 from POSIX <sys/socket.h>; most commonly used socket type for TCP network programming; extra95 anchors SOCK_STREAM.name=='SOCK_STREAM'; no prior socket spec anchors SOCK_STREAM.value in any form; first standalone under sockaddr123"
  category: numeric_values
  kind: python_call_eq
  function: "SOCK_STREAM.value.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__len__()==13 — standalone
#
# socket.AF_INET.__class__.__name__.__len__() is 13. 'AddressFamily' has 13 chars:
# 'Address'=7 + 'Family'=6. This 13-char class name is longer than 'SocketKind'
# (10 chars). 'AddressFamily' was chosen to reflect the POSIX concept of an
# address family (AF_*), which specifies the communication domain (IPv4, IPv6,
# Unix domain, etc.). No prior socket spec anchors AddressFamily class name
# length in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra123.AF_INET_class_name_len_13:
  description: "socket.AF_INET.__class__.__name__.__len__() == 13 — len('AddressFamily')==13 ('Address'=7 + 'Family'=6; longer than SocketKind at 10 chars); 'AddressFamily' reflects the POSIX AF_* address family concept (IPv4, IPv6, Unix domain, etc.); extra96 anchors __class__.__name__.__eq__('AddressFamily'); no prior socket spec anchors AddressFamily class name length; first standalone under sockaddr123"
  category: type_identity
  kind: python_call_eq
  function: "AF_INET.__class__.__name__.__len__"
  args: []
  expected: 13
