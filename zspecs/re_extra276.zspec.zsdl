spec: re_extra276
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.IGNORECASE == 2 — the numeric value of the IGNORECASE flag in Python 3.x."
    - "re.MULTILINE == 8 — the numeric value of the MULTILINE flag."
    - "re.DOTALL == 16 — the numeric value of the DOTALL flag."
    - "re.VERBOSE == 64 — the numeric value of the VERBOSE flag."
    - "re.UNICODE == 32 — the numeric value of the UNICODE flag."
    - "re.ASCII == 256 — the numeric value of the ASCII flag."
    - "re.NOFLAG == 0 — the null flag value introduced in Python 3.11."
    - "re.RegexFlag.__name__ == 'RegexFlag' and __module__ == 're'."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag is an IntFlag enum."
    - "re.RegexFlag.__class__.__name__ == 'EnumType' — RegexFlag metaclass is EnumType."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: re flag constant integer values
# ---------------------------------------------------------------------------

table re_extra276.flag_integer_values:
  description: "re.IGNORECASE, re.MULTILINE, re.DOTALL, re.VERBOSE, re.UNICODE, re.ASCII integer values"
  kind: python_call_eq
  category: flags
  id_prefix: rfiv

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase, IGNORECASE.__eq__,  [2],   true, "re.IGNORECASE == 2"]
    - [multiline,  MULTILINE.__eq__,   [8],   true, "re.MULTILINE == 8"]
    - [dotall,     DOTALL.__eq__,      [16],  true, "re.DOTALL == 16"]
    - [verbose,    VERBOSE.__eq__,     [64],  true, "re.VERBOSE == 64"]
    - [unicode,    UNICODE.__eq__,     [32],  true, "re.UNICODE == 32"]
    - [ascii_flag, ASCII.__eq__,       [256], true, "re.ASCII == 256"]

# ---------------------------------------------------------------------------
# Table: re.RegexFlag class identity
# ---------------------------------------------------------------------------

table re_extra276.regexflag_class_identity:
  description: "re.RegexFlag __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: rfci

  columns: [id, function, args, expected, description]
  rows:
    - [rf_name,    RegexFlag.__name__.__eq__,                   ["RegexFlag"], true, "re.RegexFlag.__name__ == 'RegexFlag'"]
    - [rf_module,  RegexFlag.__module__.__eq__,                 ["re"],        true, "re.RegexFlag.__module__ == 're'"]
    - [rf_base,    "RegexFlag.__bases__[0].__name__.__eq__",    ["IntFlag"],   true, "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag is an IntFlag enum"]
    - [rf_meta,    RegexFlag.__class__.__name__.__eq__,         ["EnumType"],  true, "re.RegexFlag.__class__.__name__ == 'EnumType' — RegexFlag metaclass is EnumType"]

# ---------------------------------------------------------------------------
# Standalone invariants: flag values and RegexFlag identity
# ---------------------------------------------------------------------------

invariant re_extra276.IGNORECASE.value:
  description: "re.IGNORECASE == 2 — the canonical integer value for case-insensitive matching"
  category: flags
  kind: python_call_eq
  function: IGNORECASE.__eq__
  args: [2]
  expected: true

invariant re_extra276.MULTILINE.value:
  description: "re.MULTILINE == 8 — the canonical integer value for multi-line mode"
  category: flags
  kind: python_call_eq
  function: MULTILINE.__eq__
  args: [8]
  expected: true

invariant re_extra276.DOTALL.value:
  description: "re.DOTALL == 16 — the canonical integer value for dot-matches-newline mode"
  category: flags
  kind: python_call_eq
  function: DOTALL.__eq__
  args: [16]
  expected: true

invariant re_extra276.VERBOSE.value:
  description: "re.VERBOSE == 64 — the canonical integer value for verbose (free-spacing) mode"
  category: flags
  kind: python_call_eq
  function: VERBOSE.__eq__
  args: [64]
  expected: true

invariant re_extra276.RegexFlag.name:
  description: "re.RegexFlag.__name__ == 'RegexFlag'"
  category: identity
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra276.RegexFlag.module:
  description: "re.RegexFlag.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra276.RegexFlag.base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag extends IntFlag, making each flag value an int"
  category: identity
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra276.RegexFlag.metaclass_is_EnumType:
  description: "re.RegexFlag.__class__.__name__ == 'EnumType' — RegexFlag is created by the EnumType metaclass"
  category: identity
  kind: python_call_eq
  function: RegexFlag.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true
