# ---------------------------------------------------------------------------
# Table 1: itertools module doc string
#
# Wave 267 theme: itertools.__doc__ — the module-level docstring.
#
# itertools.__doc__.__class__.__name__ == 'str'
# len(itertools.__doc__) == 1386
#
# The itertools module is a C extension (itertoolsmodule.c) but its docstring
# is exposed as a Python str. New to extra139.
# ---------------------------------------------------------------------------

table itertools_extra139.module_doc:
  description: "itertools.__doc__: class str, len 1386; wave 267; new to extra139"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdoc139

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_eq_str,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — the itertools module docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra139"]
    - [doc_class_len_eq_3,
       "__doc__.__class__.__name__.__len__",
       [],
       3,
       "itertools.__doc__.__class__.__name__.__len__() == 3 — __class__.__name__ is 'str' which has 3 characters; len('str') == 3; new to extra139"]
    - [doc_len_eq_1386,
       "__doc__.__len__",
       [],
       1386,
       "itertools.__doc__.__len__() == 1386 — the itertools module docstring has 1386 characters; len(__doc__) == 1386; verified with Python 3.14.3; new to extra139"]

