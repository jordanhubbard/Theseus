# ---------------------------------------------------------------------------
# Table 3: itertools.__spec__ — ModuleSpec attributes
#
# Wave 267 theme: itertools.__spec__ from _frozen_importlib.
#
# itertools.__spec__.__class__.__name__ == 'ModuleSpec' (len 10)
