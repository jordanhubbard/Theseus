# itertools.__spec__.name == 'itertools' (len 9)
# itertools.__spec__.origin == 'built-in' (len 8)
#
# The import machinery stores a ModuleSpec on each module. For itertools,
# a built-in C extension, the origin is 'built-in'. New to extra139.
# ---------------------------------------------------------------------------

