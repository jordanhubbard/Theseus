spec: itertools_extra304
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All itertools types listed here are C-level types; __module__ == 'itertools' and __bases__[0].__name__ == 'object' for each."
    - "itertools.pairwise was added in Python 3.10; __name__ == 'pairwise', __module__ == 'itertools'."
    - "itertools.batched was added in Python 3.12; __name__ == 'batched', __module__ == 'itertools'."
    - "accumulate, starmap, takewhile, dropwhile, compress, filterfalse all have __bases__[0].__name__ == 'object'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# accumulate identity
#
# itertools.accumulate is a C-level type.
# __name__ == 'accumulate', __module__ == 'itertools', __bases__[0] == object.
# ---------------------------------------------------------------------------

invariant itertools_extra304.accumulate_name:
  description: "itertools.accumulate.__name__ == 'accumulate'"
  category: identity
  kind: python_call_eq
  function: accumulate.__name__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra304.accumulate_module:
  description: "itertools.accumulate.__module__ == 'itertools'"
  category: identity
  kind: python_call_eq
  function: accumulate.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra304.accumulate_base_is_object:
  description: "itertools.accumulate.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: accumulate.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

