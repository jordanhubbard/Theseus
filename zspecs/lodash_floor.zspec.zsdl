spec: lodash_floor
version: ">=4.0.0"
backend: node(lodash.floor)

docs: https://lodash.com/docs/#floor

provenance:
  derived_from:
    - "lodash.floor README — https://www.npmjs.com/package/lodash.floor"
    - "Test vectors verified with lodash.floor@4.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.floor exports the _.floor function directly as module.exports."
    - "floor(number, precision) rounds number down to the given decimal precision."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a floored number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_floor.floor:
  kind: node_module_call_eq
  function: ~
  category: floor
  id_prefix: lflr

  columns: [id, args, expected]
  rows:
    - [two_places,  [4.567, 2],  4.56]
    - [one_place,   [4.567, 1],  4.5]
    - [integer,     [4.9, 0],    4]
    - [negative,    [-4.1, 0],   -5]
