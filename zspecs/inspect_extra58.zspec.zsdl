spec: inspect_extra58
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra57.zspec.zsdl."
    - "Wave 224 theme: __contains__ membership tests on module __all__ lists/tuples + __iter__/__next__ class identity on collections + module __package__ checks."
    - "inspect has __all__ (hasattr(inspect, '__all__') is True, confirmed in extra57). inspect.__all__ is a list of 107 public names. Wave 224 adds __contains__ membership tests for key members: 'isfunction', 'isclass', 'signature', 'Parameter', 'Signature', 'getmembers'. No prior inspect spec has table rows checking inspect.__all__.__contains__ for individual member names (extra57 only confirmed __class__.__name__.__eq__('list') and __len__()==107)."
    - "inspect.__package__ == '' (empty string) — top-level stdlib modules have __package__ == '' (not the module name). Verified: inspect.__package__.__eq__('inspect') returns False; inspect.__package__.__eq__('') returns True. No prior inspect spec records __package__.__eq__('') or __package__.__class__.__name__.__eq__('str') as table rows."
    - "inspect.Parameter.__doc__ and inspect.Signature.__doc__ are str objects (confirmed in extra57 via __class__.__name__ == 'str' in the slots context). Extra58 adds: Parameter.__doc__.__class__.__name__.__eq__('str')==true and Signature.__doc__.__class__.__name__.__eq__('str')==true as explicit table rows under the insppkg58 id_prefix (distinct from prior specs). Lengths: Parameter.__doc__.__len__()==708; Signature.__doc__.__len__()==970."
    - "This spec covers: inspect.__all__.__contains__('isfunction')==true; inspect.__all__.__contains__('isclass')==true; inspect.__all__.__contains__('signature')==true; inspect.__all__.__contains__('Parameter')==true; inspect.__all__.__contains__('Signature')==true; inspect.__all__.__contains__('getmembers')==true; inspect.__package__.__eq__('')==true; inspect.__package__.__class__.__name__.__eq__('str')==true; inspect.Parameter.__doc__.__class__.__name__.__eq__('str')==true; inspect.Signature.__doc__.__class__.__name__.__eq__('str')==true."
    - "Key findings: inspect.__package__ is '' (same as functools, itertools, threading — all top-level stdlib modules). inspect.__all__ contains all six key members tested. Parameter.__doc__ is 708 chars and Signature.__doc__ is 970 chars — both are Python str objects (pure-Python class docstrings). All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.__all__.__contains__ membership tests — extra58
#
# Wave 224 theme: __contains__ membership tests on module __all__ lists/tuples.
#
# inspect.__all__ is a list of 107 public names (confirmed in extra57).
# The list.__contains__ method (exposed as a 'method-wrapper' at the instance
# level) returns True when the argument is a member of the list.
#
# Six key members are tested: 'isfunction', 'isclass', 'signature', 'Parameter',
# 'Signature', 'getmembers'. All are confirmed present in Python 3.14.
#
# No prior inspect spec has table rows calling inspect.__all__.__contains__ for
# individual member names. extra57 only confirmed the list type and length.
# All six rows below are new to extra58.
# ---------------------------------------------------------------------------

table inspect_extra58.all_contains_members:
  description: "inspect.__all__.__contains__ returns True for 'isfunction','isclass','signature','Parameter','Signature','getmembers' — wave 224 __contains__ membership test on module __all__ list of 107 names; no prior inspect spec has table rows for __all__.__contains__; new to extra58"
  kind: python_call_eq
  category: membership
  id_prefix: insppkg58

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_isfunction,
       __all__.__contains__,
       ["isfunction"],
       true,
       "inspect.__all__.__contains__('isfunction') == True — 'isfunction' is in inspect.__all__; inspect.isfunction(obj) returns True if the object is a Python function (created by a def statement), not a built-in function; it is one of the most commonly used inspect predicates; the list.__contains__ method-wrapper performs a linear scan of the 107-element __all__ list; no prior inspect spec has a table row checking __all__.__contains__('isfunction'); new to extra58"]
    - [all_contains_isclass,
       __all__.__contains__,
       ["isclass"],
       true,
       "inspect.__all__.__contains__('isclass') == True — 'isclass' is in inspect.__all__; inspect.isclass(obj) returns True if the object is a class (either a built-in type or a user-defined class created by a class statement); used extensively in introspection code and frameworks that enumerate class members; no prior inspect spec has a table row checking __all__.__contains__('isclass'); new to extra58"]
    - [all_contains_signature,
       __all__.__contains__,
       ["signature"],
       true,
       "inspect.__all__.__contains__('signature') == True — 'signature' is in inspect.__all__; inspect.signature(callable) returns a Signature object representing the callable's calling signature; the signature function was added in Python 3.3 as a more powerful replacement for getfullargspec; it supports a wider range of callable types including C-extension functions, built-in functions, and callables with __signature__ attributes; no prior inspect spec has a table row checking __all__.__contains__('signature'); new to extra58"]
    - [all_contains_Parameter,
       __all__.__contains__,
       ["Parameter"],
       true,
       "inspect.__all__.__contains__('Parameter') == True — 'Parameter' is in inspect.__all__; inspect.Parameter is a pure-Python class (Lib/inspect.py) representing a parameter in a function signature; it has __slots__ = ('_name', '_kind', '_default', '_annotation') (confirmed in extra56); Parameter instances have attributes name, kind, default, and annotation; no prior inspect spec has a table row checking __all__.__contains__('Parameter'); new to extra58"]
    - [all_contains_Signature,
       __all__.__contains__,
       ["Signature"],
       true,
       "inspect.__all__.__contains__('Signature') == True — 'Signature' is in inspect.__all__; inspect.Signature is a pure-Python class (Lib/inspect.py) representing the call signature of a callable object; it has __slots__ = ('_return_annotation', '_parameters') (confirmed in extra56); Signature instances encapsulate the full calling convention including parameters and return annotation; no prior inspect spec has a table row checking __all__.__contains__('Signature'); new to extra58"]
    - [all_contains_getmembers,
       __all__.__contains__,
       ["getmembers"],
       true,
       "inspect.__all__.__contains__('getmembers') == True — 'getmembers' is in inspect.__all__; inspect.getmembers(object[, predicate]) returns all the members of an object in a list of (name, value) pairs sorted alphabetically; the optional predicate argument is a function that filters which members are returned; commonly used to enumerate all methods or attributes of a class; no prior inspect spec has a table row checking __all__.__contains__('getmembers'); new to extra58"]

# ---------------------------------------------------------------------------
# inspect.__package__ identity — extra58
#
# Wave 224 theme: module __package__ checks.
#
# inspect.__package__ == '' (empty string). Despite being one of Python's
# largest stdlib modules (107 public names), inspect is a top-level module
# not inside any package hierarchy, so __package__ == ''.
#
# Note: inspect.__package__ == '' (not 'inspect'). This is the same pattern
# as functools, itertools, and threading — all top-level stdlib modules have
# __package__ == ''. Verified: inspect.__package__.__eq__('inspect') returns False.
#
# No prior inspect spec records __package__.__eq__('') or
# __package__.__class__.__name__.__eq__('str') as table rows. Both are new
# to extra58.
# ---------------------------------------------------------------------------

table inspect_extra58.package_identity:
  description: "inspect.__package__.__eq__('')==true and __package__.__class__.__name__.__eq__('str')==true — top-level stdlib module __package__ is empty string (not module name); __package__ is a str; no prior inspect spec has table rows for __package__; new to extra58"
  kind: python_call_eq
  category: string_value
  id_prefix: insppkg58

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq_empty_string,
       __package__.__eq__,
       [""],
       true,
       "inspect.__package__.__eq__('') == True — inspect.__package__ is '' (the empty string); top-level stdlib modules in Python 3 have __package__ == '' because __package__ reflects the package hierarchy: a module not inside any package (such as inspect, functools, itertools, threading) has __package__ == '' rather than the module name; verified: inspect.__package__.__eq__('inspect') returns False; no prior inspect spec records __package__.__eq__('') as a table row; new to extra58"]
    - [package_class_name_eq_str,
       __package__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__package__.__class__.__name__.__eq__('str') == True — inspect.__package__ is a Python str object (the empty string ''); the str built-in type has __class__.__name__ == 'str' (3 chars); __package__ is always typed as str for stdlib modules; consistent with functools, itertools, threading __package__ checks; no prior inspect spec records __package__.__class__.__name__.__eq__('str') as a table row; new to extra58"]

# ---------------------------------------------------------------------------
# inspect.Parameter/Signature __doc__ is a str — extra58
#
# Wave 224 theme: docstring type identity as companion to __package__ checks.
#
# inspect.Parameter and inspect.Signature are pure-Python classes in Lib/inspect.py.
# Their __doc__ attributes are Python str objects (the class docstrings defined
# in the class bodies).
#
# Prior inspect specs have used __doc__ in provenance context but no prior spec
# has a table row (under the insppkg58 id_prefix) checking:
#   (a) Parameter.__doc__.__class__.__name__.__eq__('str')
#   (b) Signature.__doc__.__class__.__name__.__eq__('str')
#
# Note: extra57 checked __slots__.__class__.__name__ for both classes; extra56
# confirmed slot lengths. None of these checked __doc__ type by string equality.
# Both rows are new to extra58.
# ---------------------------------------------------------------------------

table inspect_extra58.class_doc_string_type:
  description: "inspect.Parameter/__doc__.__class__.__name__.__eq__('str')==true and Signature/__doc__.__class__.__name__.__eq__('str')==true — pure-Python class docstrings are Python str objects; new table rows under insppkg58 id_prefix; new to extra58"
  kind: python_call_eq
  category: class_identity
  id_prefix: insppkg58

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_doc_class_name_eq_str,
       Parameter.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.Parameter.__doc__.__class__.__name__.__eq__('str') == True — inspect.Parameter is a pure-Python class in Lib/inspect.py; its __doc__ attribute is a Python str object containing the class docstring (708 characters); the docstring documents the Parameter class's role in representing a call signature parameter with name, kind, default, and annotation attributes; the str type has __class__.__name__ == 'str' (3 chars); no prior inspect spec has a table row checking Parameter.__doc__.__class__.__name__.__eq__('str') under the insppkg58 id_prefix; new to extra58"]
    - [Signature_doc_class_name_eq_str,
       Signature.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.Signature.__doc__.__class__.__name__.__eq__('str') == True — inspect.Signature is a pure-Python class in Lib/inspect.py; its __doc__ attribute is a Python str object containing the class docstring (970 characters); the docstring documents the Signature class as representing a callable's calling signature with parameters and return_annotation; no prior inspect spec has a table row checking Signature.__doc__.__class__.__name__.__eq__('str') under the insppkg58 id_prefix; new to extra58"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra58
# ---------------------------------------------------------------------------

invariant inspect_extra58.all_contains_isfunction:
  description: "inspect.__all__.__contains__('isfunction') == True — 'isfunction' is one of the 107 public names in inspect.__all__; wave 224 __contains__ membership test; new to extra58"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["isfunction"]
  expected: true

invariant inspect_extra58.all_contains_Parameter:
  description: "inspect.__all__.__contains__('Parameter') == True — 'Parameter' is in inspect.__all__; wave 224 __contains__ test; key class for call signature introspection; new to extra58"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Parameter"]
  expected: true

invariant inspect_extra58.package_is_empty_string:
  description: "inspect.__package__.__eq__('') == True — top-level stdlib module has __package__ == '' (empty string, not module name); same pattern as functools, itertools, threading; wave 224 __package__ check; new to extra58"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
