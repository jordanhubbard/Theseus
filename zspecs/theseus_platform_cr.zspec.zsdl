spec: theseus_platform_cr
version: ">=3.9"
backend: python_cleanroom(theseus_platform_cr)
blocks: platform

docs: https://docs.python.org/3/library/platform.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/platform.html"
  notes:
    - "Clean-room platform detection utilities. Do NOT import platform, os, or sys."
    - "machine() returns CPU architecture string: 'x86_64', 'arm64', etc."
    - "python_version_tuple() returns (major, minor, micro) strings."
    - "architecture() returns tuple like ('64bit', '') or ('32bit', '')."
    - "Use struct module packing to detect pointer size and thus 32/64-bit."
    - "platform_machine_nonempty(): machine() returns non-empty string."
    - "platform_arch_valid(): architecture()[0] in ('32bit', '64bit')."
    - "platform_version_tuple_len(): len(python_version_tuple()) == 3."
    - "Export: machine() -> str, architecture() -> tuple, python_version_tuple() -> tuple."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_platform_cr.machine_nonempty:
  description: "machine() returns non-empty string"
  category: machine
  kind: python_call_eq
  function: platform_machine_nonempty
  args: []
  expected: true

invariant theseus_platform_cr.arch_valid:
  description: "architecture()[0] in ('32bit', '64bit')"
  category: arch
  kind: python_call_eq
  function: platform_arch_valid
  args: []
  expected: true

invariant theseus_platform_cr.version_tuple_len:
  description: "len(python_version_tuple()) == 3"
  category: version
  kind: python_call_eq
  function: platform_version_tuple_len
  args: []
  expected: 3
