    - [str_module,      UUID.__str__.__module__.__eq__,            ["uuid"],         true, "uuid.UUID.__str__.__module__ == 'uuid' (pure-Python method in Lib/uuid.py)"]
    - [str_class_name,  UUID.__str__.__class__.__name__.__eq__,    ["function"],     true, "uuid.UUID.__str__.__class__.__name__ == 'function' (ordinary Python function)"]

