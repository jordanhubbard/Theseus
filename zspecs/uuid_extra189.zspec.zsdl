spec: uuid_extra189
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' (len=12) — __str__ is defined directly on UUID in Lib/uuid.py."
    - "uuid.UUID.__str__.__module__ == 'uuid' (len=4) — pure-Python method belonging to the uuid module."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (len=13) — one character longer than __str__ qualname."
    - "uuid.UUID.__repr__.__module__ == 'uuid' (len=4) — same module as __str__."
    - "uuid.UUID.__int__.__qualname__ == 'UUID.__int__' (len=12) — same length as __str__ qualname."
    - "uuid.UUID.__int__.__module__ == 'uuid' (len=4) — all three methods belong to the uuid module."
    - "uuid.UUID.__str__.__class__.__name__ == 'function' (len=8) — __str__, __repr__, __int__ are ordinary Python functions."
    - "uuid.UUID.__repr__.__class__.__name__ == 'function' (len=8) — same class name as __str__."
    - "Qualname length ordering: __str__==__int__(12) < __repr__(13); all three modules equal 'uuid' (len=4)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

