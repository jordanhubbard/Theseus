    - [repr_module,     UUID.__repr__.__module__.__eq__,           ["uuid"],          true, "uuid.UUID.__repr__.__module__ == 'uuid' (pure-Python method in Lib/uuid.py)"]
    - [repr_class_name, UUID.__repr__.__class__.__name__.__eq__,   ["function"],      true, "uuid.UUID.__repr__.__class__.__name__ == 'function' (ordinary Python function, same as __str__)"]

