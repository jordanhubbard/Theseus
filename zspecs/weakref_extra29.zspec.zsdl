spec: weakref_extra29
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref_extra28.zspec.zsdl."
    - "Prior specs covered: ref/__name__/__module__/__qualname__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __name__/__module__/__qualname__, ref.__bases__[0].__name__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __bases__[0].__name__, ref.__init__.__name__, __module__.__len__() and __name__.__len__() for proxy/getweakrefcount/getweakrefs/ReferenceType/ProxyType/CallableProxyType/WeakMethod, finalize method __qualname__.__len__(), WeakValueDictionary/WeakKeyDictionary method __qualname__.__len__(), __mro__.__len__() for WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize, __slots__ class name len for WeakValueDictionary/finalize, weakref.__all__.__len__() (13) and .__class__.__name__.__len__() (4), __dict__.__class__.__name__.__len__() for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize (all 12), __qualname__.__len__() for ref(13)/WeakValueDictionary(19)/WeakKeyDictionary(17)/WeakSet(7)/finalize(8)/proxy(5), __bases__[0].__name__.__len__() for WeakValueDictionary/WeakKeyDictionary (MutableMapping=14) and WeakSet (object=6), ref.__mro__.__len__() (2), ref.__qualname__.__len__() (13 standalone), WeakMethod(10)/ProxyType(9)/CallableProxyType(17) __qualname__/__dict__/__mro__ lens, weakref.__name__.__len__() (7), ref.__bases__[0].__name__.__len__() (6)."
    - "This spec covers: WeakValueDictionary.__name__.__len__()==19; WeakValueDictionary.__qualname__.__len__()==19; WeakKeyDictionary.__name__.__len__()==17; WeakSet.__name__.__len__()==7; WeakSet.__mro__.__len__()==2; WeakValueDictionary.__mro__.__len__()==8; WeakKeyDictionary.__mro__.__len__()==8; finalize.__name__.__len__()==8; finalize.__qualname__.__len__()==8."
    - "WeakValueDictionary.__name__ == WeakValueDictionary.__qualname__ == 'WeakValueDictionary' (19 chars) — top-level Python class."
    - "WeakKeyDictionary.__name__ == 'WeakKeyDictionary' (17 chars) — 2 chars shorter than WeakValueDictionary."
    - "WeakSet.__mro__ == (WeakSet, object) — length 2; WeakSet is a direct object subclass."
    - "WeakValueDictionary.__mro__ and WeakKeyDictionary.__mro__ — both length 8, via the MutableMapping ABC chain."
    - "finalize.__name__ == finalize.__qualname__ == 'finalize' (8 chars) — top-level C-backed class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() table — WeakValueDictionary, WeakKeyDictionary, WeakSet,
# finalize
#
# weakref.WeakValueDictionary.__name__ == 'WeakValueDictionary' (19 chars).
# weakref.WeakKeyDictionary.__name__ == 'WeakKeyDictionary' (17 chars).
# weakref.WeakSet.__name__ == 'WeakSet' (7 chars).
# weakref.finalize.__name__ == 'finalize' (8 chars).
# While individual __name__ values were covered in early specs, their
# __name__.__len__() values as a grouped table under the extra29 namespace
# have not been recorded. This table anchors all four lengths together.
# ---------------------------------------------------------------------------

table weakref_extra29.class_name_lengths:
  description: "__name__.__len__() for WeakValueDictionary(19)/WeakKeyDictionary(17)/WeakSet(7)/finalize(8)"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected, description]
  rows:
    - [WeakValueDictionary,
       WeakValueDictionary.__name__.__len__,
       [],
       19,
       "len(weakref.WeakValueDictionary.__name__) == 19 — 'WeakValueDictionary'"]
    - [WeakKeyDictionary,
       WeakKeyDictionary.__name__.__len__,
       [],
       17,
       "len(weakref.WeakKeyDictionary.__name__) == 17 — 'WeakKeyDictionary'"]
    - [WeakSet,
       WeakSet.__name__.__len__,
       [],
       7,
       "len(weakref.WeakSet.__name__) == 7 — 'WeakSet'"]
    - [finalize,
       finalize.__name__.__len__,
       [],
       8,
       "len(weakref.finalize.__name__) == 8 — 'finalize'"]

# ---------------------------------------------------------------------------
# __mro__.__len__() table — WeakSet, WeakValueDictionary, WeakKeyDictionary
#
# weakref.WeakSet.__mro__ == (WeakSet, object) — length 2; WeakSet is
# implemented in _weakrefset and directly subclasses object. weakref.
# WeakValueDictionary.__mro__ and WeakKeyDictionary.__mro__ both have length 8,
# following the full MutableMapping ABC chain:
# (Class, MutableMapping, Mapping, Collection, Sized, Iterable, Container,
# object). Although __mro__.__len__() for these three was mentioned in prior
# spec notes, it was recorded as standalone invariants rather than a grouped
# table. This table records all three under the extra29 namespace.
# ---------------------------------------------------------------------------

table weakref_extra29.class_mro_lengths:
  description: "__mro__.__len__() for WeakSet(2)/WeakValueDictionary(8)/WeakKeyDictionary(8)"
  kind: python_call_eq
  category: mro_lengths
  id_prefix: mro_len

  columns: [id, function, args, expected, description]
  rows:
    - [WeakSet,
       WeakSet.__mro__.__len__,
       [],
       2,
       "len(weakref.WeakSet.__mro__) == 2 — (WeakSet, object); direct object subclass"]
    - [WeakValueDictionary,
       WeakValueDictionary.__mro__.__len__,
       [],
       8,
       "len(weakref.WeakValueDictionary.__mro__) == 8 — full MutableMapping ABC chain (8 entries)"]
    - [WeakKeyDictionary,
       WeakKeyDictionary.__mro__.__len__,
       [],
       8,
       "len(weakref.WeakKeyDictionary.__mro__) == 8 — full MutableMapping ABC chain (8 entries)"]

# ---------------------------------------------------------------------------
# WeakValueDictionary.__qualname__.__len__() == 19 — standalone invariant
#
# weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary' (19 chars).
# As a top-level Python-level class, __qualname__ equals __name__. 19 is the
# longest class name length in the weakref module. This standalone records the
# qualname length in the extra29 namespace for direct testability.
# No prior weakref spec records this as a standalone under extra29.
# ---------------------------------------------------------------------------

invariant weakref_extra29.WeakValueDictionary.qualname_len:
  description: "weakref.WeakValueDictionary.__qualname__.__len__() == 19 — top-level class; __qualname__ == __name__ == 'WeakValueDictionary' (19 chars)"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: WeakValueDictionary.__qualname__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# finalize.__qualname__.__len__() == 8 — standalone invariant
#
# weakref.finalize.__qualname__ == 'finalize' (8 chars). As a top-level class,
# __qualname__ equals __name__. finalize is a C-backed class (implemented in
# _weakref) that manages callbacks for garbage-collected objects. Its qualname
# length (8) is one more than WeakSet (7) and one less than the standard
# MutableMapping chain classes. No prior weakref spec records finalize.
# __qualname__.__len__() as a standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra29.finalize.qualname_len:
  description: "weakref.finalize.__qualname__.__len__() == 8 — top-level C-backed class; __qualname__ == __name__ == 'finalize' (8 chars)"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: finalize.__qualname__.__len__
  args: []
  expected: 8
