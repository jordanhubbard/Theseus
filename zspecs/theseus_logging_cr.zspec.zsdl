spec: theseus_logging_cr
version: ">=3.9"
backend: python_cleanroom(theseus_logging_cr)
blocks: logging

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html"
  notes:
    - "Clean-room logging framework. Do NOT import logging."
    - "Logger(name): logger with debug/info/warning/error/critical methods."
    - "Handler with emit(record) receives log records."
    - "LogRecord: name, level, message, timestamp."
    - "Level constants: DEBUG=10, INFO=20, WARNING=30, ERROR=40, CRITICAL=50."
    - "logging_level_constants(): DEBUG == 10, INFO == 20."
    - "logging_handler_receives(): handler.emit() called when log level >= handler level."
    - "logging_format_message(): format log record into string."
    - "Export: Logger, Handler, LogRecord, DEBUG, INFO, WARNING, ERROR, CRITICAL."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_logging_cr.level_constants:
  description: "DEBUG == 10 and INFO == 20"
  category: levels
  kind: python_call_eq
  function: logging_level_constants
  args: []
  expected: true

invariant theseus_logging_cr.handler_receives:
  description: "log message is captured by attached handler"
  category: handler
  kind: python_call_eq
  function: logging_handler_receives
  args: []
  expected: "test message"

invariant theseus_logging_cr.logger_name:
  description: "Logger('myapp').name == 'myapp'"
  category: logger
  kind: python_call_eq
  function: logging_logger_name
  args: []
  expected: "myapp"
