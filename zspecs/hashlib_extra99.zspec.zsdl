spec: hashlib_extra99
version: ">=3.9"
backend: python_module(hashlib)
extends: hashlib_extra98

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / algorithms_available membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers hashlib.algorithms_available/algorithms_guaranteed set class identity and membership / sha256/sha512/sha1/md5 constructor __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra98; it does NOT duplicate invariants present in those files."
    - "Wave 259 theme: hashlib algorithm identity — md5/sha1/sha224/sha256/sha384/sha512 constructor __name__ and __class__.__name__ / blake2b and blake2s class identity / new function __class__.__name__ / algorithms_guaranteed length."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__name__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__name__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__name__ == 'openssl_sha224'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__name__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__name__ == 'openssl_sha384'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__name__ == 'openssl_sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__qualname__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: blake2b and blake2s are exposed as 'type' (a class) not 'builtin_function_or_method' because they are C-extension type objects from the _blake2 module, not function-style constructors."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha1.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha224.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha384.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha512.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 259 theme: md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__ cross-check.
#
# The six core SHA-family constructors exposed by hashlib are all OpenSSL-backed
# C builtins from the _hashlib extension. hashlib_extra94 first anchors the
# builtin_function_or_method class name for md5/sha1/sha256/sha512; this table
# groups all six together including sha224/sha384 for a complete cross-check.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra99.sha_constructor_class_names:
  description: "hashlib.md5/__class__.__name__.__eq__('builtin_function_or_method')==True / sha1/__class__.__name__.__eq__==True / sha224/__class__.__name__.__eq__==True / sha256/__class__.__name__.__eq__==True / sha384/__class__.__name__.__eq__==True / sha512/__class__.__name__.__eq__==True — all six core SHA-family constructors are OpenSSL-backed C builtins from _hashlib; hashlib_extra94 first anchors md5/sha1/sha256/sha512; this table groups all six together; first hashlibident99 anchor for sha224 and sha384 __class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibident99

  columns: [id, function, args, expected]
  rows:
    - [md5_class,    md5.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [sha1_class,   sha1.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [sha224_class, sha224.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha256_class, sha256.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha384_class, sha384.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha512_class, sha512.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.md5.__name__.__eq__('openssl_md5')
# hashlib.sha1.__name__.__eq__('openssl_sha1')
# hashlib.sha224.__name__.__eq__('openssl_sha224')
# hashlib.sha256.__name__.__eq__('openssl_sha256')
# hashlib.sha384.__name__.__eq__('openssl_sha384')
# hashlib.sha512.__name__.__eq__('openssl_sha512')
#
# Wave 259 theme: md5/sha1/sha224/sha256/sha384/sha512 __name__ equality.
#
# The __name__ attribute of a C builtin function equals its __qualname__ for
# top-level functions. All six constructors carry the 'openssl_' prefix in
# both __name__ and __qualname__, identifying them as OpenSSL implementations.
# No prior hashlib spec anchors __name__ equality for these six functions
# together under hashlibident99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra99.sha_constructor_names:
  description: "hashlib.md5/__name__.__eq__('openssl_md5')==True / sha1/__name__.__eq__('openssl_sha1')==True / sha224/__name__.__eq__('openssl_sha224')==True / sha256/__name__.__eq__('openssl_sha256')==True / sha384/__name__.__eq__('openssl_sha384')==True / sha512/__name__.__eq__('openssl_sha512')==True — the __name__ of each OpenSSL-backed constructor equals its __qualname__ and carries the 'openssl_' prefix; no prior hashlib spec anchors __name__ equality for these six; first hashlibident99 anchor for SHA constructor __name__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibident99

  columns: [id, function, args, expected]
  rows:
    - [md5_name,    md5.__name__.__eq__,    ["openssl_md5"],    true]
    - [sha1_name,   sha1.__name__.__eq__,   ["openssl_sha1"],   true]
    - [sha224_name, sha224.__name__.__eq__,  ["openssl_sha224"], true]
    - [sha256_name, sha256.__name__.__eq__,  ["openssl_sha256"], true]
    - [sha384_name, sha384.__name__.__eq__,  ["openssl_sha384"], true]
    - [sha512_name, sha512.__name__.__eq__,  ["openssl_sha512"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__class__.__name__.__eq__('type')
# hashlib.blake2s.__class__.__name__.__eq__('type')
# hashlib.blake2b.__module__.__eq__('_blake2')
# hashlib.blake2s.__module__.__eq__('_blake2')
# hashlib.blake2b.__qualname__.__eq__('blake2b')
# hashlib.blake2s.__qualname__.__eq__('blake2s')
# hashlib.new.__class__.__name__.__eq__('function')
# hashlib.algorithms_guaranteed.__len__() == 14
#
# Wave 259 theme: blake2b/blake2s class identity and module / new function class / algorithms_guaranteed length.
#
# Unlike md5/sha256 which are 'builtin_function_or_method', blake2b and blake2s
# are exposed as C-extension type objects (class 'type') from the _blake2 module.
# Their __qualname__ ('blake2b' / 'blake2s') lacks the 'openssl_' prefix.
# hashlib.new is a pure-Python function (class 'function').
# algorithms_guaranteed has exactly 14 members on Python 3.14.3.
# No prior hashlib spec anchors these together under hashlibident99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra99.blake2_and_new_identity:
  description: "hashlib.blake2b/__class__.__name__.__eq__('type')==True / blake2s/__class__.__name__.__eq__('type')==True / blake2b/__module__.__eq__('_blake2')==True / blake2s/__module__.__eq__('_blake2')==True / blake2b/__qualname__.__eq__('blake2b')==True / blake2s/__qualname__.__eq__('blake2s')==True / new/__class__.__name__.__eq__('function')==True / algorithms_guaranteed/__len__()==14 — blake2b/blake2s are C-extension type objects (not builtin_function_or_method) from the _blake2 module; __qualname__ lacks 'openssl_' prefix; new is a pure-Python function; algorithms_guaranteed has 14 entries on Python 3.14.3; no prior hashlib spec anchors these together; first hashlibident99 anchor for blake2 class identity and new function class"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibident99

  columns: [id, function, args, expected]
  rows:
    - [blake2b_class,            blake2b.__class__.__name__.__eq__,              ["type"],     true]
    - [blake2s_class,            blake2s.__class__.__name__.__eq__,              ["type"],     true]
    - [blake2b_module,           blake2b.__module__.__eq__,                      ["_blake2"],  true]
    - [blake2s_module,           blake2s.__module__.__eq__,                      ["_blake2"],  true]
    - [blake2b_qualname,         blake2b.__qualname__.__eq__,                    ["blake2b"],  true]
    - [blake2s_qualname,         blake2s.__qualname__.__eq__,                    ["blake2s"],  true]
    - [new_class,                new.__class__.__name__.__eq__,                  ["function"], true]
    - [algorithms_guaranteed_len, algorithms_guaranteed.__len__,                 [],           14]

# ---------------------------------------------------------------------------
# hashlib.md5.__name__.__eq__('openssl_md5') — standalone
#
# hashlib.md5.__name__ is 'openssl_md5'. The __name__ of a C builtin function
# (builtin_function_or_method) equals its __qualname__ for top-level functions.
# For OpenSSL-backed constructors, the 'openssl_' prefix in __name__ identifies
# the implementation as coming from OpenSSL via the _hashlib C extension, not a
# pure-Python fallback. No prior hashlib spec anchors md5.__name__.__eq__ as a
# standalone under hashlibident99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra99.md5_name_openssl_md5:
  description: "hashlib.md5.__name__.__eq__('openssl_md5') == True — md5 is an OpenSSL-backed C builtin from _hashlib; its __name__ is 'openssl_md5', carrying the 'openssl_' prefix; __name__ equals __qualname__ for top-level C builtins; no prior hashlib spec anchors this as a standalone; first standalone for md5 __name__ under hashlibident99"
  category: type_identity
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__class__.__name__.__eq__('type') — standalone
#
# hashlib.blake2b.__class__.__name__ is 'type'. Unlike md5/sha256 which are
# exposed as 'builtin_function_or_method', blake2b is a C-extension class
# (its class is 'type', the metaclass of all classes). blake2b comes from the
# _blake2 C extension (not _hashlib), and is a class you can instantiate
# directly. No prior hashlib spec anchors blake2b.__class__.__name__.__eq__('type')
# as a standalone under hashlibident99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra99.blake2b_class_type:
  description: "hashlib.blake2b.__class__.__name__.__eq__('type') == True — blake2b is a C-extension class object from _blake2 (not _hashlib); its __class__.__name__ is 'type' (the metaclass), distinguishing it from the builtin_function_or_method OpenSSL constructors; no prior hashlib spec anchors this as a standalone; first standalone for blake2b __class__.__name__ under hashlibident99"
  category: type_identity
  kind: python_call_eq
  function: blake2b.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__eq__('_blake2') — standalone
#
# hashlib.blake2b.__module__ is '_blake2'. The blake2b and blake2s constructors
# are defined in the _blake2 C extension (separate from _hashlib). This reflects
# the two-extension architecture: _hashlib wraps OpenSSL algorithms, while _blake2
# wraps the reference BLAKE2 implementation. No prior hashlib spec anchors
# blake2b.__module__.__eq__('_blake2') as a standalone under hashlibident99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra99.blake2b_module_blake2:
  description: "hashlib.blake2b.__module__.__eq__('_blake2') == True — blake2b lives in the _blake2 C extension (separate from _hashlib which wraps OpenSSL); this two-extension architecture separates OpenSSL-backed hashes from the reference BLAKE2 implementation; no prior hashlib spec anchors this as a standalone; first standalone for blake2b __module__ under hashlibident99"
  category: type_identity
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__() == 14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. The set contains:
# blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256,
# sha3_384, sha3_512, sha512, shake_128, shake_256. These 14 algorithms are
# guaranteed to be available in any Python 3.x installation. No prior hashlib
# spec anchors algorithms_guaranteed.__len__()==14 as a standalone under
# hashlibident99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra99.algorithms_guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — algorithms_guaranteed contains 14 algorithms (blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256) guaranteed available in any Python 3.x installation; no prior hashlib spec anchors this as a standalone; first standalone for algorithms_guaranteed length under hashlibident99"
  category: type_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__name__.__eq__('function') — standalone
#
# hashlib.new.__class__.__name__ is 'function'. hashlib.new is a pure-Python
# function (defined in Lib/hashlib.py) that wraps C builtins, providing a
# unified constructor interface. It is class 'function' (not
# 'builtin_function_or_method'), distinguishing it from the OpenSSL constructors.
# No prior hashlib spec anchors new.__class__.__name__.__eq__('function') as a
# standalone under hashlibident99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra99.new_class_function:
  description: "hashlib.new.__class__.__name__.__eq__('function') == True — hashlib.new is a pure-Python wrapper function (Lib/hashlib.py) providing a unified constructor interface; it is class 'function' (not 'builtin_function_or_method'), distinguishing it from the OpenSSL C builtins; no prior hashlib spec anchors this as a standalone; first standalone for new __class__.__name__ under hashlibident99"
  category: type_identity
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true
