spec: decimal_extra269
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal.Context.__name__ == 'Context' and __module__ == 'decimal'."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object."
    - "decimal.Context.__class__.__name__ == 'type' — Context is a plain Python class."
    - "decimal.getcontext().__class__.__name__ == 'Context' — getcontext() returns a Context instance."
    - "decimal.getcontext().__class__.__module__ == 'decimal'."
    - "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — rounding mode constants are plain str objects."
    - "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — default rounding mode of getcontext()."
    - "decimal.ROUND_UP == 'ROUND_UP' and decimal.ROUND_DOWN == 'ROUND_DOWN'."
    - "decimal.Decimal.__name__ == 'Decimal' and __module__ == 'decimal'."
    - "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal inherits directly from object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: decimal.Context class identity
# ---------------------------------------------------------------------------

table decimal_extra269.context_class_identity:
  description: "decimal.Context __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cci

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_name,    Context.__name__.__eq__,                   ["Context"],   true, "decimal.Context.__name__ == 'Context'"]
    - [ctx_module,  Context.__module__.__eq__,                 ["decimal"],   true, "decimal.Context.__module__ == 'decimal'"]
    - [ctx_base,    "Context.__bases__[0].__name__.__eq__",    ["object"],    true, "decimal.Context.__bases__[0].__name__ == 'object'"]
    - [ctx_meta,    Context.__class__.__name__.__eq__,         ["type"],      true, "decimal.Context.__class__.__name__ == 'type'"]

# ---------------------------------------------------------------------------
# Table: decimal rounding mode constants
# ---------------------------------------------------------------------------

table decimal_extra269.rounding_mode_values:
  description: "decimal ROUND_* constants are plain str objects whose value equals their own name"
  kind: python_call_eq
  category: rounding_modes
  id_prefix: rmv

  columns: [id, function, args, expected, description]
  rows:
    - [half_up,    ROUND_HALF_UP.__eq__,    ["ROUND_HALF_UP"],    true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'"]
    - [half_even,  ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"],  true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN'"]
    - [round_up,   ROUND_UP.__eq__,         ["ROUND_UP"],         true, "decimal.ROUND_UP == 'ROUND_UP'"]
    - [round_down, ROUND_DOWN.__eq__,       ["ROUND_DOWN"],       true, "decimal.ROUND_DOWN == 'ROUND_DOWN'"]
    - [half_up_type,   ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true, "type(decimal.ROUND_HALF_UP).__name__ == 'str'"]
    - [half_even_type, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true, "type(decimal.ROUND_HALF_EVEN).__name__ == 'str'"]

# ---------------------------------------------------------------------------
# Standalone invariants: getcontext() instance identity and Decimal class
# ---------------------------------------------------------------------------

invariant decimal_extra269.getcontext.instance_class_name:
  description: "decimal.getcontext().__class__.__name__ == 'Context' — getcontext() returns a Context instance"
  category: identity
  kind: python_call_eq
  function: getcontext.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant decimal_extra269.Context.name:
  description: "decimal.Context.__name__ == 'Context'"
  category: identity
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra269.Context.module:
  description: "decimal.Context.__module__ == 'decimal'"
  category: identity
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra269.Context.base_is_object:
  description: "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object"
  category: identity
  kind: python_call_eq
  function: "Context.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra269.Decimal.name:
  description: "decimal.Decimal.__name__ == 'Decimal'"
  category: identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra269.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal'"
  category: identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra269.Decimal.base_is_object:
  description: "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal inherits directly from object"
  category: identity
  kind: python_call_eq
  function: "Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra269.ROUND_HALF_UP.value:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'"
  category: rounding_modes
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra269.ROUND_HALF_EVEN.value:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — the default rounding mode"
  category: rounding_modes
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true
