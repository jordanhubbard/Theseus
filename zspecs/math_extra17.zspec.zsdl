spec: math_extra17
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra16.zspec.zsdl."
    - "No prior spec covers math.log(1) == 0.0 (natural log of 1 is zero)."
    - "No prior spec covers math.log(1, 10) == 0.0 (log base 10 of 1 via two-arg form)."
    - "No prior spec covers math.log10(1) == 0.0, log10(10) == 1.0, log10(100) == 2.0."
    - "No prior spec covers math.log2(1) == 0.0, log2(2) == 1.0, log2(4) == 2.0, log2(8) == 3.0."
    - "No prior spec covers math.exp(0) == 1.0 (exponential at zero)."
    - "No prior spec covers math.sqrt(0) == 0.0, sqrt(1) == 1.0, sqrt(4) == 2.0, sqrt(9) == 3.0, sqrt(16) == 4.0."
    - "No prior spec covers math.pow(2, 0) == 1.0, pow(2, 3) == 8.0, pow(10, 2) == 100.0."
    - "math.log(1) == 0.0 — natural logarithm of 1 is zero."
    - "math.log(1, 10) == 0.0 — log base 10 of 1 via two-argument form is zero."
    - "math.log10(1) == 0.0 — log base 10 of 1 is zero."
    - "math.log10(10) == 1.0 — log base 10 of 10 is exactly 1."
    - "math.log10(100) == 2.0 — log base 10 of 100 is exactly 2."
    - "math.log2(1) == 0.0 — log base 2 of 1 is zero."
    - "math.log2(2) == 1.0 — log base 2 of 2 is exactly 1."
    - "math.log2(4) == 2.0 — log base 2 of 4 is exactly 2."
    - "math.log2(8) == 3.0 — log base 2 of 8 is exactly 3."
    - "math.exp(0) == 1.0 — e^0 is exactly 1."
    - "math.sqrt(0) == 0.0, sqrt(1) == 1.0, sqrt(4) == 2.0, sqrt(9) == 3.0, sqrt(16) == 4.0."
    - "math.pow(2, 0) == 1.0 — math.pow always returns float; any base to the zero power is 1."
    - "math.pow(2, 3) == 8.0 — 2 cubed is 8."
    - "math.pow(10, 2) == 100.0 — 10 squared is 100."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Logarithm functions — log, log2, log10
#
# All integer-exact results: log of a power of its base is an integer.
# log(1) == 0.0 for all bases (any base raised to 0 is 1).
# ---------------------------------------------------------------------------

table math_extra17.logarithms:
  kind: python_call_eq
  category: logarithm
  id_prefix: log

  columns: [id, function, args, expected]
  rows:
    - [log_one,        log,        [1],        0.0]
    - [log_one_base10, log,        [1, 10],    0.0]
    - [log10_one,      log10,      [1],        0.0]
    - [log10_ten,      log10,      [10],       1.0]
    - [log10_hundred,  log10,      [100],      2.0]
    - [log2_one,       log2,       [1],        0.0]
    - [log2_two,       log2,       [2],        1.0]
    - [log2_four,      log2,       [4],        2.0]
    - [log2_eight,     log2,       [8],        3.0]

# ---------------------------------------------------------------------------
# sqrt, exp, pow — square root, exponential, and power functions
#
# math.sqrt always returns a float. math.pow always returns a float.
# exp(0) == 1.0: e^0 = 1 exactly.
# ---------------------------------------------------------------------------

table math_extra17.sqrt_exp_pow:
  kind: python_call_eq
  category: exponents
  id_prefix: sep

  columns: [id, function, args, expected]
  rows:
    - [exp_zero,    exp,  [0],       1.0]
    - [sqrt_zero,   sqrt, [0],       0.0]
    - [sqrt_one,    sqrt, [1],       1.0]
    - [sqrt_four,   sqrt, [4],       2.0]
    - [sqrt_nine,   sqrt, [9],       3.0]
    - [sqrt_sixteen, sqrt, [16],     4.0]
    - [pow_two_zero, pow, [2, 0],    1.0]
    - [pow_two_three, pow, [2, 3],   8.0]
    - [pow_ten_two,  pow, [10, 2],  100.0]
