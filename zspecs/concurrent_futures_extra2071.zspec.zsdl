spec: concurrent_futures_extra2071
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "concurrent.futures types (Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor) are concurrency primitives, not numeric or copy-protocol types."
    - "Executor is an abstract base class; ThreadPoolExecutor and ProcessPoolExecutor extend it."
    - "None of these types define __pos__, __neg__, __getattribute__, __reduce__, __reduce_ex__, __copy__, or __deepcopy__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2071.unary_sign_protocol:
  description: "concurrent.futures types __pos__/__neg__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2071

  columns: [id, function, args, expected]
  rows:
    - ["cf2071001", "concurrent.futures.Future.__dict__.__contains__", ["__pos__"], false]
    - ["cf2071002", "concurrent.futures.Future.__dict__.__contains__", ["__neg__"], false]
    - ["cf2071003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__pos__"], false]
    - ["cf2071004", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__neg__"], false]
    - ["cf2071005", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__pos__"], false]
    - ["cf2071006", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__neg__"], false]
    - ["cf2071007", "concurrent.futures.Executor.__dict__.__contains__", ["__pos__"], false]
    - ["cf2071008", "concurrent.futures.Executor.__dict__.__contains__", ["__neg__"], false]

