spec: pickle_extra24
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle_extra23.zspec.zsdl."
    - "Prior specs covered: Pickler/Unpickler __name__/__module__/__qualname__/__bases__[0].__name__, PickleError/PicklingError/UnpicklingError __name__/__module__/__bases__, pickle.dumps/loads/dump/load __name__/__module__/__qualname__, Pickler/Unpickler __init__.__name__, DEFAULT_PROTOCOL/HIGHEST_PROTOCOL type, class and method __qualname__.__len__() for Pickler/Unpickler/error classes and Pickler.dump/persistent_id/Unpickler.load."
    - "This spec covers: __mro__.__len__() for Pickler, Unpickler, PickleError, PicklingError, UnpicklingError; __bases__[0].__name__.__len__() for PickleError, PicklingError, UnpicklingError; __qualname__.__len__() for Pickler.clear_memo and Unpickler.find_class methods; DEFAULT_PROTOCOL.__class__.__name__.__len__()."
    - "No prior pickle spec checks pickle.Pickler.__mro__.__len__()."
    - "No prior pickle spec checks pickle.Unpickler.__mro__.__len__()."
    - "No prior pickle spec checks pickle.PickleError.__mro__.__len__()."
    - "No prior pickle spec checks pickle.PicklingError.__mro__.__len__()."
    - "No prior pickle spec checks pickle.UnpicklingError.__mro__.__len__()."
    - "No prior pickle spec checks pickle.PickleError.__bases__[0].__name__.__len__()."
    - "No prior pickle spec checks pickle.PicklingError.__bases__[0].__name__.__len__()."
    - "No prior pickle spec checks pickle.UnpicklingError.__bases__[0].__name__.__len__()."
    - "No prior pickle spec checks pickle.Pickler.clear_memo.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.Unpickler.find_class.__qualname__.__len__()."
    - "No prior pickle spec checks pickle.DEFAULT_PROTOCOL.__class__.__name__.__len__()."
    - "pickle.Pickler.__mro__ == [Pickler, object] — len 2."
    - "pickle.Unpickler.__mro__ == [Unpickler, object] — len 2."
    - "pickle.PickleError.__mro__ == [PickleError, Exception, BaseException, object] — len 4."
    - "pickle.PicklingError.__mro__ == [PicklingError, PickleError, Exception, BaseException, object] — len 5."
    - "pickle.UnpicklingError.__mro__ == [UnpicklingError, PickleError, Exception, BaseException, object] — len 5."
    - "pickle.PickleError.__bases__[0].__name__ == 'Exception' — len 9."
    - "pickle.PicklingError.__bases__[0].__name__ == 'PickleError' — len 11."
    - "pickle.UnpicklingError.__bases__[0].__name__ == 'PickleError' — len 11."
    - "pickle.Pickler.clear_memo.__qualname__ == 'Pickler.clear_memo' — len 18."
    - "pickle.Unpickler.find_class.__qualname__ == 'Unpickler.find_class' — len 20."
    - "pickle.DEFAULT_PROTOCOL.__class__.__name__ == 'int' — len 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for Pickler, Unpickler, PickleError, PicklingError,
# UnpicklingError
#
# Pickler and Unpickler are implemented in C (_pickle) and inherit directly
# from object (MRO depth 2). The exception hierarchy is deeper:
#   PickleError      -> Exception -> BaseException -> object          (len 4)
#   PicklingError    -> PickleError -> Exception -> BaseException -> object (len 5)
#   UnpicklingError  -> PickleError -> Exception -> BaseException -> object (len 5)
# No prior pickle spec checks any class's MRO depth.
# ---------------------------------------------------------------------------

invariant pickle_extra24.Pickler.mro_len:
  description: "pickle.Pickler.__mro__.__len__() == 2 — MRO: Pickler, object (flat C-extension class)"
  category: class_hierarchy
  kind: python_call_eq
  function: Pickler.__mro__.__len__
  args: []
  expected: 2

invariant pickle_extra24.Unpickler.mro_len:
  description: "pickle.Unpickler.__mro__.__len__() == 2 — MRO: Unpickler, object (flat C-extension class)"
  category: class_hierarchy
  kind: python_call_eq
  function: Unpickler.__mro__.__len__
  args: []
  expected: 2

invariant pickle_extra24.PickleError.mro_len:
  description: "pickle.PickleError.__mro__.__len__() == 4 — MRO: PickleError, Exception, BaseException, object"
  category: class_hierarchy
  kind: python_call_eq
  function: PickleError.__mro__.__len__
  args: []
  expected: 4

invariant pickle_extra24.PicklingError.mro_len:
  description: "pickle.PicklingError.__mro__.__len__() == 5 — MRO: PicklingError, PickleError, Exception, BaseException, object"
  category: class_hierarchy
  kind: python_call_eq
  function: PicklingError.__mro__.__len__
  args: []
  expected: 5

invariant pickle_extra24.UnpicklingError.mro_len:
  description: "pickle.UnpicklingError.__mro__.__len__() == 5 — MRO: UnpicklingError, PickleError, Exception, BaseException, object"
  category: class_hierarchy
  kind: python_call_eq
  function: UnpicklingError.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for PickleError, PicklingError,
# UnpicklingError
#
# PickleError's direct base is Exception (len 9).
# PicklingError and UnpicklingError both have PickleError as their direct
# base (len 11). No prior pickle spec checks the string length of any
# exception class's first base name.
# ---------------------------------------------------------------------------

invariant pickle_extra24.PickleError.bases0_name_len:
  description: "pickle.PickleError.__bases__[0].__name__.__len__() == 9 — first base is 'Exception' (9 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PickleError.__bases__[0].__name__.__len__"
  args: []
  expected: 9

invariant pickle_extra24.PicklingError.bases0_name_len:
  description: "pickle.PicklingError.__bases__[0].__name__.__len__() == 11 — first base is 'PickleError' (11 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PicklingError.__bases__[0].__name__.__len__"
  args: []
  expected: 11

invariant pickle_extra24.UnpicklingError.bases0_name_len:
  description: "pickle.UnpicklingError.__bases__[0].__name__.__len__() == 11 — first base is 'PickleError' (11 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "UnpicklingError.__bases__[0].__name__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Pickler.clear_memo and Unpickler.find_class
#
# These two methods extend coverage beyond the Pickler.dump/persistent_id
# and Unpickler.load methods covered in pickle_extra23.
#   Pickler.clear_memo    -> 'Pickler.clear_memo'    -> 18
#   Unpickler.find_class  -> 'Unpickler.find_class'  -> 20
# No prior pickle spec checks either method's __qualname__ length.
# ---------------------------------------------------------------------------

invariant pickle_extra24.Pickler.clear_memo.qualname_len:
  description: "pickle.Pickler.clear_memo.__qualname__.__len__() == 18 — 'Pickler.clear_memo' has 18 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Pickler.clear_memo.__qualname__.__len__"
  args: []
  expected: 18

invariant pickle_extra24.Unpickler.find_class.qualname_len:
  description: "pickle.Unpickler.find_class.__qualname__.__len__() == 20 — 'Unpickler.find_class' has 20 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Unpickler.find_class.__qualname__.__len__"
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# pickle.DEFAULT_PROTOCOL.__class__.__name__.__len__()
#
# DEFAULT_PROTOCOL is an integer constant; its __class__.__name__ is 'int'
# (len 3). No prior pickle spec checks the length of this type name string.
# ---------------------------------------------------------------------------

invariant pickle_extra24.DEFAULT_PROTOCOL.class_name_len:
  description: "pickle.DEFAULT_PROTOCOL.__class__.__name__.__len__() == 3 — class name 'int' has 3 characters"
  category: constant_types
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Consolidated table — MRO depths for all five pickle classes
#
# Pickler/Unpickler are C-extension stubs with depth 2.
# PickleError is depth 4; PicklingError and UnpicklingError are depth 5.
# All are first covered in this spec (pickle_extra24).
# ---------------------------------------------------------------------------

table pickle_extra24.class_mro_lengths:
  description: "pickle class __mro__.__len__() — Pickler (2), Unpickler (2), PickleError (4), PicklingError (5), UnpicklingError (5)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pfa24a

  columns: [id, function, args, expected]
  rows:
    - [Pickler_mro_len,         Pickler.__mro__.__len__,         [], 2]
    - [Unpickler_mro_len,       Unpickler.__mro__.__len__,       [], 2]
    - [PickleError_mro_len,     PickleError.__mro__.__len__,     [], 4]
    - [PicklingError_mro_len,   PicklingError.__mro__.__len__,   [], 5]
    - [UnpicklingError_mro_len, UnpicklingError.__mro__.__len__, [], 5]

# ---------------------------------------------------------------------------
# Consolidated table — __bases__[0].__name__.__len__() and additional method
# __qualname__ lengths
#
# Groups exception base-name lengths with the two new method qualname lengths
# and the DEFAULT_PROTOCOL class-name length.
# ---------------------------------------------------------------------------

table pickle_extra24.bases_and_method_lengths:
  description: "pickle __bases__[0].__name__.__len__() for exception classes and Pickler.clear_memo/Unpickler.find_class qualname lengths"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pfa24b

  columns: [id, function, args, expected]
  rows:
    - [PickleError_bases0_name_len,     "PickleError.__bases__[0].__name__.__len__",     [],  9]
    - [PicklingError_bases0_name_len,   "PicklingError.__bases__[0].__name__.__len__",   [], 11]
    - [UnpicklingError_bases0_name_len, "UnpicklingError.__bases__[0].__name__.__len__", [], 11]
    - [Pickler_clear_memo_qualname_len, "Pickler.clear_memo.__qualname__.__len__",       [], 18]
    - [Unpickler_find_class_qualname_len, "Unpickler.find_class.__qualname__.__len__",   [], 20]
    - [DEFAULT_PROTOCOL_class_name_len, DEFAULT_PROTOCOL.__class__.__name__.__len__,     [],  3]
