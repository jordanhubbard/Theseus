    - ["mp3451016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__setitem__"], false]

# ---------------------------------------------------------------------------
# __delitem__ dict-presence — operator.contains(Cls.__dict__, '__delitem__')
#
# All 8 multiprocessing classes return false for __delitem__.
# del obj[key] delegates to __delitem__ when defined in the class's own __dict__.
# None of the 8 multiprocessing classes define a Python-level __delitem__
#   in their own __dict__.
# managers._BaseDictProxy key note: _BaseDictProxy relays key deletion to the
#   managed server process via IPC proxy dispatch, but __delitem__ is NOT defined
#   in _BaseDictProxy.__dict__ at the Python class level.
# managers.BaseListProxy: proxies list indexed deletion via proxy dispatch;
#   __delitem__ is not in BaseListProxy.__dict__.
# managers._BaseSetProxy: sets do not support item deletion by key;
#   __delitem__ is absent from its own __dict__.
# multiprocessing.Process: no __delitem__ defined; processes are not subscriptable.
# pool.Pool/AsyncResult/MapResult/SyncManager: no __delitem__ in their own
#   __dict__; item deletion is not part of the pool or result-handle API.
# ---------------------------------------------------------------------------

