    - ["mp3451002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__getitem__"], false]
    - ["mp3451003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__getitem__"], false]
    - ["mp3451004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__getitem__"], false]
    - ["mp3451005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__getitem__"], false]
    - ["mp3451006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__getitem__"], false]
    - ["mp3451007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__getitem__"], false]
    - ["mp3451008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__getitem__"], false]

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# All 8 multiprocessing classes return false for __setitem__.
# obj[key]=val delegates to __setitem__ when defined in the class's own __dict__.
# multiprocessing types do not define __setitem__ in their own __dict__; item
#   assignment falls back to proxy dispatch or raises TypeError at runtime.
# managers._BaseDictProxy: relays item assignment to the managed server process
#   via IPC proxy dispatch, but does not define __setitem__ in its own __dict__.
# managers.BaseListProxy: relays indexed assignment via proxy dispatch; no
#   __setitem__ in its own __dict__.
# managers._BaseSetProxy: sets do not support item assignment; __setitem__ is
#   absent from its own __dict__.
# multiprocessing.Process: __setitem__ is absent from Process.__dict__.
# pool.Pool/AsyncResult/MapResult/SyncManager: no __setitem__ customization
#   in their own __dict__.
# ---------------------------------------------------------------------------

