spec: decimal_extra187
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers decimal.Decimal class identity — __name__, __module__, __bases__[0].__name__, __class__.__name__, __init__.__qualname__, __str__.__qualname__, __add__.__qualname__, and __mul__.__qualname__."
    - "decimal.Decimal.__name__ == 'Decimal' (len=7); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__module__ == 'decimal' (len=7) — the public module name, not '_decimal'; CPython deliberately sets the module attribute to the public name so that instances pickle and repr correctly; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal inherits directly from object; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__init__.__qualname__ == 'object.__init__' (len=15) — Decimal does not define its own __init__; it inherits __init__ from object, so the qualname reflects object's __init__; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' (len=15: 'Decimal.'=8+'__str__'=7=15); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15: 'Decimal.'=8+'__add__'=7=15); same length as __str__; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (len=15: 'Decimal.'=8+'__mul__'=7=15); same length as __str__ and __add__; confirmed Python 3.14.3 macOS."
    - "Qualname length ordering: object.__init__=15 == Decimal.__str__=15 == Decimal.__add__=15 == Decimal.__mul__=15; all four qualnames share length 15; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal method __qualname__ equality
# object.__init__(15), Decimal.__str__(15), Decimal.__add__(15), Decimal.__mul__(15)
# ---------------------------------------------------------------------------

table decimal_extra187.decimal_method_qualnames:
  description: "decimal.Decimal method __qualname__ values: __init__='object.__init__'(15), __str__='Decimal.__str__'(15), __add__='Decimal.__add__'(15), __mul__='Decimal.__mul__'(15); all four qualnames share length 15"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldecimal187

  columns: [id, function, args, expected, description]
  rows:
    - [init_qn_eq, decimal.Decimal.__init__.__qualname__.__eq__, ["object.__init__"], true, "decimal.Decimal.__init__.__qualname__ == 'object.__init__' (len=15); Decimal inherits __init__ from object; confirmed Python 3.14.3 macOS"]
    - [str_qn_eq,  decimal.Decimal.__str__.__qualname__.__eq__,  ["Decimal.__str__"],  true, "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' (len=15); confirmed Python 3.14.3 macOS"]
    - [add_qn_eq,  decimal.Decimal.__add__.__qualname__.__eq__,  ["Decimal.__add__"],  true, "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15); confirmed Python 3.14.3 macOS"]
    - [mul_qn_eq,  decimal.Decimal.__mul__.__qualname__.__eq__,  ["Decimal.__mul__"],  true, "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (len=15); confirmed Python 3.14.3 macOS"]
    - [str_qn_len, decimal.Decimal.__str__.__qualname__.__len__, [],                   15,   "decimal.Decimal.__str__.__qualname__.__len__() == 15 ('Decimal.'=8+'__str__'=7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal method __qualname__ lengths
# All four method qualnames have length 15
# ---------------------------------------------------------------------------

table decimal_extra187.decimal_method_qualname_lengths:
  description: "decimal.Decimal method __qualname__ lengths: __init__=15, __str__=15, __add__=15, __mul__=15; all four qualnames are equal in length"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldecimal187

  columns: [id, function, args, expected, description]
  rows:
    - [init_qn_len, decimal.Decimal.__init__.__qualname__.__len__, [], 15, "decimal.Decimal.__init__.__qualname__.__len__() == 15 ('object.__init__'=15: 'object.'=7+'__init__'=8=15); confirmed Python 3.14.3 macOS"]
    - [str_qn_len,  decimal.Decimal.__str__.__qualname__.__len__,  [], 15, "decimal.Decimal.__str__.__qualname__.__len__() == 15 ('Decimal.__str__'=15: 'Decimal.'=8+'__str__'=7=15); confirmed Python 3.14.3 macOS"]
    - [add_qn_len,  decimal.Decimal.__add__.__qualname__.__len__,  [], 15, "decimal.Decimal.__add__.__qualname__.__len__() == 15 ('Decimal.__add__'=15: 'Decimal.'=8+'__add__'=7=15); confirmed Python 3.14.3 macOS"]
    - [mul_qn_len,  decimal.Decimal.__mul__.__qualname__.__len__,  [], 15, "decimal.Decimal.__mul__.__qualname__.__len__() == 15 ('Decimal.__mul__'=15: 'Decimal.'=8+'__mul__'=7=15); confirmed Python 3.14.3 macOS"]
    - [name_len,    decimal.Decimal.__name__.__len__,              [], 7,  "decimal.Decimal.__name__.__len__() == 7 — D(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal class-level identity attributes
# __name__(Decimal,7), __module__(decimal,7), __bases__[0].__name__(object), __class__(type)
# ---------------------------------------------------------------------------

table decimal_extra187.decimal_class_identity:
  description: "decimal.Decimal class-level identity: __name__='Decimal'(7), __module__='decimal'(7), __bases__[0].__name__='object', __class__.__name__='type'"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldecimal187

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      decimal.Decimal.__name__.__eq__,                             ["Decimal"],  true, "decimal.Decimal.__name__ == 'Decimal' (len=7); confirmed Python 3.14.3 macOS"]
    - [module_eq,    decimal.Decimal.__module__.__eq__,                           ["decimal"],  true, "decimal.Decimal.__module__ == 'decimal' (len=7, public module name not '_decimal'); confirmed Python 3.14.3 macOS"]
    - [base_eq,      "decimal.Decimal.__bases__[0].__name__.__eq__",              ["object"],   true, "decimal.Decimal.__bases__[0].__name__ == 'object'; Decimal directly subclasses object; confirmed Python 3.14.3 macOS"]
    - [class_name_eq, decimal.Decimal.__class__.__name__.__eq__,                  ["type"],     true, "decimal.Decimal.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS"]
    - [module_len,   decimal.Decimal.__module__.__len__,                          [],           7,    "decimal.Decimal.__module__.__len__() == 7 — d(1)e(2)c(3)i(4)m(5)a(6)l(7); same length as __name__ 'Decimal'=7; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra187.decimal_name_eq:
  description: "decimal.Decimal.__name__ == 'Decimal' — class name string length 7 ('Decimal'); decimal.Decimal is the fixed-precision decimal number class; its __name__ is the plain class name without module prefix; note that __name__ length (7) equals __module__ length ('decimal'=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra187.decimal_module_eq:
  description: "decimal.Decimal.__module__ == 'decimal' — the public module name is used (len=7), not '_decimal'; CPython's C-accelerated decimal module deliberately sets __module__ to 'decimal' so that instances pickle and repr correctly against the high-level API; this is the same pattern used by _datetime, _io, and other C-accelerated modules; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra187.decimal_base_eq:
  description: "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal directly inherits from object (the root of all Python classes); Decimal does not inherit from any numeric tower abstract base class (int, float, etc.) — it is its own separate numeric type for fixed-precision arithmetic; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra187.decimal_class_name_type:
  description: "decimal.Decimal.__class__.__name__ == 'type' — Decimal's metaclass is the plain 'type'; Decimal is a C-level extension type but its metaclass is the standard 'type', not a custom metaclass; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra187.decimal_init_qualname_eq:
  description: "decimal.Decimal.__init__.__qualname__ == 'object.__init__' — Decimal does not define its own __init__ method; it inherits __init__ from object; as a result the qualname reflects object's __init__ rather than 'Decimal.__init__'; the qualname length is 15 ('object.__init__': 'object.'=7+'__init__'=8=15); this contrasts with __str__, __add__, and __mul__ which Decimal does define and whose qualnames are 'Decimal.XXX'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

invariant decimal_extra187.decimal_str_qualname_eq:
  description: "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' — Decimal defines its own __str__ method; the qualname is 'Decimal.__str__' (len=15: 'Decimal.'=8+'__str__'=7=15); __str__ returns the string representation of the decimal number; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__str__.__qualname__.__eq__
  args: ["Decimal.__str__"]
  expected: true

invariant decimal_extra187.decimal_add_qualname_eq:
  description: "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' — Decimal defines its own __add__ method for decimal addition; the qualname is 'Decimal.__add__' (len=15: 'Decimal.'=8+'__add__'=7=15); same length as __str__ and __mul__ qualnames; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__add__.__qualname__.__eq__
  args: ["Decimal.__add__"]
  expected: true

invariant decimal_extra187.decimal_mul_qualname_eq:
  description: "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' — Decimal defines its own __mul__ method for decimal multiplication; the qualname is 'Decimal.__mul__' (len=15: 'Decimal.'=8+'__mul__'=7=15); same length as __str__ and __add__ qualnames; all three operator method qualnames share length 15; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__mul__.__qualname__.__eq__
  args: ["Decimal.__mul__"]
  expected: true
