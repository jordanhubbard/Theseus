spec: inspect_extra2506
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: __add__, __sub__, and __mul__ dict-presence checks for inspect module classes."
    - "Theme: arithmetic operator dict-presence — checking whether classes define arithmetic operators in their class __dict__."
    - "inspect.Parameter, Signature, BoundArguments, FrameInfo, FullArgSpec, Attribute, ClosureVars — none define __add__, __sub__, or __mul__."
    - "inspect.Parameter represents a single parameter in a function signature; it is a structured record class with attributes like name, kind, and default — not a numeric type. Verified with Python 3.14."
    - "inspect.Signature is an immutable record of a callable's full signature; it provides a .parameters mapping for iteration but is not itself a numeric type. Verified with Python 3.14."
    - "inspect.BoundArguments holds the result of binding arguments to a Signature; it exposes an .arguments OrderedDict but BoundArguments itself is not numeric and defines no arithmetic operators. Verified with Python 3.14."
    - "inspect.FrameInfo, FullArgSpec, Attribute, ClosureVars are lightweight named-tuple subclasses or dataclasses that return structured introspection results; none carry numeric semantics. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from inspect.Parameter.__dict__.
# Parameter is a structured record representing a single function parameter
# with attributes name, kind, default, and annotation. It is an introspection
# record, not a numeric type, and defines no arithmetic protocol.
# ---------------------------------------------------------------------------

table inspect_extra2506.parameter_arithmetic:
  description: "__add__, __sub__, __mul__ absent from inspect.Parameter.__dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2506

  columns: [id, function, args, expected]
  rows:
    - ["in2506-001", "Parameter.__dict__.__contains__", ["__add__"], false]
    - ["in2506-002", "Parameter.__dict__.__contains__", ["__sub__"], false]
    - ["in2506-003", "Parameter.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature and inspect.BoundArguments — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from Signature and BoundArguments.
# Signature is an immutable callable-signature record; BoundArguments is
# produced by Signature.bind() and holds matched argument values.
# Neither is a numeric type; neither defines arithmetic operators.
# ---------------------------------------------------------------------------

table inspect_extra2506.signature_boundargs_arithmetic:
  description: "__add__, __sub__, __mul__ absent from inspect.Signature and inspect.BoundArguments __dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2506

  columns: [id, function, args, expected]
  rows:
    - ["in2506-004", "Signature.__dict__.__contains__", ["__add__"], false]
    - ["in2506-005", "Signature.__dict__.__contains__", ["__sub__"], false]
    - ["in2506-006", "Signature.__dict__.__contains__", ["__mul__"], false]
    - ["in2506-007", "BoundArguments.__dict__.__contains__", ["__add__"], false]
    - ["in2506-008", "BoundArguments.__dict__.__contains__", ["__sub__"], false]
    - ["in2506-009", "BoundArguments.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 3: inspect structured result classes — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from FrameInfo, FullArgSpec,
# Attribute, and ClosureVars.
# These are named-tuple subclasses or dataclasses returned by inspect
# introspection functions; they are data-carrying records with no numeric
# semantics and no arithmetic protocol.
# ---------------------------------------------------------------------------

table inspect_extra2506.result_types_arithmetic:
  description: "__add__, __sub__, __mul__ absent from inspect.FrameInfo, FullArgSpec, Attribute, ClosureVars __dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2506

  columns: [id, function, args, expected]
  rows:
    - ["in2506-010", "FrameInfo.__dict__.__contains__", ["__add__"], false]
    - ["in2506-011", "FrameInfo.__dict__.__contains__", ["__sub__"], false]
    - ["in2506-012", "FrameInfo.__dict__.__contains__", ["__mul__"], false]
    - ["in2506-013", "FullArgSpec.__dict__.__contains__", ["__add__"], false]
    - ["in2506-014", "FullArgSpec.__dict__.__contains__", ["__sub__"], false]
    - ["in2506-015", "FullArgSpec.__dict__.__contains__", ["__mul__"], false]
    - ["in2506-016", "Attribute.__dict__.__contains__", ["__add__"], false]
    - ["in2506-017", "Attribute.__dict__.__contains__", ["__sub__"], false]
    - ["in2506-018", "Attribute.__dict__.__contains__", ["__mul__"], false]
    - ["in2506-019", "ClosureVars.__dict__.__contains__", ["__add__"], false]
    - ["in2506-020", "ClosureVars.__dict__.__contains__", ["__sub__"], false]
    - ["in2506-021", "ClosureVars.__dict__.__contains__", ["__mul__"], false]
