spec: hashlib_extra184
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
  notes:
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — verified Python 3.14.3 macOS/Darwin 25.4.0; the task brief listed 'frozenset' but Python 3.14.3 returns 'set'."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — both algorithm sets are plain sets."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is guaranteed on all platforms."
    - "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is guaranteed on all platforms."
    - "hashlib.algorithms_guaranteed.__contains__('sha1') == True — sha1 is guaranteed on all platforms."
    - "hashlib.algorithms_guaranteed.__contains__('sha512') == True — sha512 is guaranteed on all platforms."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 is guaranteed since Python 3.6."
    - "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is guaranteed since Python 3.6."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: algorithms_guaranteed and algorithms_available — class identity
#
# hashlib.algorithms_guaranteed.__class__.__name__ == 'set'
# hashlib.algorithms_available.__class__.__name__  == 'set'
#
# Both attributes are plain Python sets. algorithms_guaranteed is the set of
# hash names that are present on all platforms. algorithms_available is a
# (typically larger) set of names accepted by hashlib.new() on the current
# platform. New to extra184.
# ---------------------------------------------------------------------------

table hashlib_extra184.algorithm_set_class_identity:
  description: "algorithms_guaranteed and algorithms_available are both 'set' instances; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibalgos184

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_class_set,
       "algorithms_guaranteed.__class__.__name__.__eq__",
       ["set"],
       true,
       "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — algorithms_guaranteed is a plain Python set; verified Python 3.14.3 macOS/Darwin 25.4.0; new to extra184"]
    - [available_class_set,
       "algorithms_available.__class__.__name__.__eq__",
       ["set"],
       true,
       "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain Python set; new to extra184"]
    - [guaranteed_class_not_frozenset,
       "algorithms_guaranteed.__class__.__name__.__eq__",
       ["frozenset"],
       false,
       "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('frozenset') == False — algorithms_guaranteed is a set, not a frozenset; verified Python 3.14.3 macOS/Darwin 25.4.0; new to extra184"]
    - [available_class_not_frozenset,
       "algorithms_available.__class__.__name__.__eq__",
       ["frozenset"],
       false,
       "hashlib.algorithms_available.__class__.__name__.__eq__('frozenset') == False — algorithms_available is a set, not a frozenset; new to extra184"]

# ---------------------------------------------------------------------------
# Table 2: algorithms_guaranteed membership — SHA family
#
# hashlib.algorithms_guaranteed.__contains__('sha256') == True
# hashlib.algorithms_guaranteed.__contains__('sha1')   == True
# hashlib.algorithms_guaranteed.__contains__('sha512') == True
# hashlib.algorithms_guaranteed.__contains__('sha3_256') == True
#
# The SHA algorithms listed here are mandated by the hashlib specification
# to be present on every compliant Python platform. New to extra184.
# ---------------------------------------------------------------------------

table hashlib_extra184.guaranteed_sha_algorithms:
  description: "sha256, sha1, sha512, sha3_256 are all in algorithms_guaranteed; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibalgos184

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["sha256"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is guaranteed on all platforms; new to extra184"]
    - [sha1_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["sha1"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha1') == True — sha1 is guaranteed on all platforms; new to extra184"]
    - [sha512_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["sha512"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha512') == True — sha512 is guaranteed on all platforms; new to extra184"]
    - [sha3_256_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["sha3_256"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 (SHA-3 family) is guaranteed since Python 3.6; new to extra184"]

# ---------------------------------------------------------------------------
# Table 3: algorithms_guaranteed membership — MD5 and BLAKE2
#
# hashlib.algorithms_guaranteed.__contains__('md5')    == True
# hashlib.algorithms_guaranteed.__contains__('blake2b') == True
#
# MD5, while cryptographically broken, remains in algorithms_guaranteed for
# legacy compatibility. BLAKE2b is a modern high-speed hash added in Python
# 3.6. New to extra184.
# ---------------------------------------------------------------------------

table hashlib_extra184.guaranteed_md5_blake2_algorithms:
  description: "md5 and blake2b are in algorithms_guaranteed; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibalgos184

  columns: [id, function, args, expected, description]
  rows:
    - [md5_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["md5"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is guaranteed on all platforms despite being cryptographically broken; new to extra184"]
    - [blake2b_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["blake2b"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is guaranteed since Python 3.6; new to extra184"]
    - [md5_not_absent,
       "algorithms_guaranteed.__contains__",
       ["md5"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 membership confirmed; new to extra184"]
    - [nonexistent_not_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["nonexistent_hash_xyz"],
       false,
       "hashlib.algorithms_guaranteed.__contains__('nonexistent_hash_xyz') == False — unknown algorithm names are not in the guaranteed set; new to extra184"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra184
# ---------------------------------------------------------------------------

invariant hashlib_extra184.guaranteed_class_is_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — both algorithm sets are plain Python sets; verified Python 3.14.3 macOS/Darwin 25.4.0; new to extra184"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra184.available_class_is_set:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is a plain set; new to extra184"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra184.sha256_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is guaranteed on all Python platforms; new to extra184"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

invariant hashlib_extra184.md5_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is guaranteed for legacy compatibility; new to extra184"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["md5"]
  expected: true

invariant hashlib_extra184.sha1_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('sha1') == True — sha1 is guaranteed on all platforms; new to extra184"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha1"]
  expected: true

invariant hashlib_extra184.sha512_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('sha512') == True — sha512 is guaranteed on all platforms; new to extra184"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha512"]
  expected: true

invariant hashlib_extra184.sha3_256_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 is guaranteed since Python 3.6; new to extra184"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_256"]
  expected: true

invariant hashlib_extra184.blake2b_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is guaranteed since Python 3.6; new to extra184"
  category: identity
  kind: python_call_eq
