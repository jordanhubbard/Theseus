spec: pathlib_extra276
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.Path query methods (is_mount, is_symlink, is_block_device, is_char_device, is_fifo, is_socket) are plain Python functions."
    - "pathlib.Path.expanduser, resolve, absolute are also plain Python functions."
    - "All Path query method __class__.__name__ == 'function'."
    - "Path method qualnames follow 'Path.<method_name>' pattern."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: Path query method __name__ identity
# ---------------------------------------------------------------------------

table pathlib_extra276.path_query_method_names:
  description: "pathlib.Path query method __name__ for is_mount, is_symlink, is_block_device, is_char_device, is_fifo, is_socket, expanduser, resolve, absolute"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [is_mount_name,        Path.is_mount.__name__.__eq__,        ["is_mount"],        true, "pathlib.Path.is_mount.__name__ == 'is_mount'"]
    - [is_symlink_name,      Path.is_symlink.__name__.__eq__,      ["is_symlink"],      true, "pathlib.Path.is_symlink.__name__ == 'is_symlink'"]
    - [is_block_device_name, Path.is_block_device.__name__.__eq__, ["is_block_device"], true, "pathlib.Path.is_block_device.__name__ == 'is_block_device'"]
    - [is_char_device_name,  Path.is_char_device.__name__.__eq__,  ["is_char_device"],  true, "pathlib.Path.is_char_device.__name__ == 'is_char_device'"]
    - [is_fifo_name,         Path.is_fifo.__name__.__eq__,         ["is_fifo"],         true, "pathlib.Path.is_fifo.__name__ == 'is_fifo'"]
    - [is_socket_name,       Path.is_socket.__name__.__eq__,       ["is_socket"],       true, "pathlib.Path.is_socket.__name__ == 'is_socket'"]
    - [expanduser_name,      Path.expanduser.__name__.__eq__,      ["expanduser"],      true, "pathlib.Path.expanduser.__name__ == 'expanduser'"]
    - [resolve_name,         Path.resolve.__name__.__eq__,         ["resolve"],         true, "pathlib.Path.resolve.__name__ == 'resolve'"]
    - [absolute_name,        Path.absolute.__name__.__eq__,        ["absolute"],        true, "pathlib.Path.absolute.__name__ == 'absolute'"]

# ---------------------------------------------------------------------------
# Table: Path query method __class__.__name__ (all 'function')
# ---------------------------------------------------------------------------

table pathlib_extra276.path_query_method_classes:
  description: "pathlib.Path query method __class__.__name__ for is_mount, is_symlink, is_block_device, is_char_device, is_fifo, is_socket, expanduser, resolve, absolute (all 'function')"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [is_mount_class,        Path.is_mount.__class__.__name__.__eq__,        ["function"], true, "pathlib.Path.is_mount.__class__.__name__ == 'function'"]
    - [is_symlink_class,      Path.is_symlink.__class__.__name__.__eq__,      ["function"], true, "pathlib.Path.is_symlink.__class__.__name__ == 'function'"]
    - [is_block_device_class, Path.is_block_device.__class__.__name__.__eq__, ["function"], true, "pathlib.Path.is_block_device.__class__.__name__ == 'function'"]
    - [is_char_device_class,  Path.is_char_device.__class__.__name__.__eq__,  ["function"], true, "pathlib.Path.is_char_device.__class__.__name__ == 'function'"]
    - [is_fifo_class,         Path.is_fifo.__class__.__name__.__eq__,         ["function"], true, "pathlib.Path.is_fifo.__class__.__name__ == 'function'"]
    - [is_socket_class,       Path.is_socket.__class__.__name__.__eq__,       ["function"], true, "pathlib.Path.is_socket.__class__.__name__ == 'function'"]
    - [expanduser_class,      Path.expanduser.__class__.__name__.__eq__,      ["function"], true, "pathlib.Path.expanduser.__class__.__name__ == 'function'"]
    - [resolve_class,         Path.resolve.__class__.__name__.__eq__,         ["function"], true, "pathlib.Path.resolve.__class__.__name__ == 'function'"]
    - [absolute_class,        Path.absolute.__class__.__name__.__eq__,        ["function"], true, "pathlib.Path.absolute.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# Standalone invariants: qualnames
# ---------------------------------------------------------------------------

invariant pathlib_extra276.Path.is_mount.qualname:
  description: "pathlib.Path.is_mount.__qualname__ == 'Path.is_mount'"
  category: identity
  kind: python_call_eq
  function: Path.is_mount.__qualname__.__eq__
  args: ["Path.is_mount"]
  expected: true

invariant pathlib_extra276.Path.is_symlink.qualname:
  description: "pathlib.Path.is_symlink.__qualname__ == 'Path.is_symlink'"
  category: identity
  kind: python_call_eq
  function: Path.is_symlink.__qualname__.__eq__
  args: ["Path.is_symlink"]
  expected: true

invariant pathlib_extra276.Path.is_block_device.qualname:
  description: "pathlib.Path.is_block_device.__qualname__ == 'Path.is_block_device'"
  category: identity
  kind: python_call_eq
  function: Path.is_block_device.__qualname__.__eq__
  args: ["Path.is_block_device"]
  expected: true

invariant pathlib_extra276.Path.is_fifo.qualname:
  description: "pathlib.Path.is_fifo.__qualname__ == 'Path.is_fifo'"
  category: identity
  kind: python_call_eq
  function: Path.is_fifo.__qualname__.__eq__
  args: ["Path.is_fifo"]
  expected: true

invariant pathlib_extra276.Path.resolve.qualname:
  description: "pathlib.Path.resolve.__qualname__ == 'Path.resolve'"
  category: identity
  kind: python_call_eq
  function: Path.resolve.__qualname__.__eq__
  args: ["Path.resolve"]
  expected: true

invariant pathlib_extra276.Path.expanduser.qualname:
  description: "pathlib.Path.expanduser.__qualname__ == 'Path.expanduser'"
  category: identity
  kind: python_call_eq
  function: Path.expanduser.__qualname__.__eq__
  args: ["Path.expanduser"]
  expected: true
