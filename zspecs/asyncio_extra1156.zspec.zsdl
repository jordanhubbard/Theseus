    - [as1156ex010, asyncio.CancelledError.__qualname__.__eq__,               ["CancelledError"],     true]
    - [as1156ex011, asyncio.sleep.__class__.__name__.__eq__,                  ["function"],           true]
    - [as1156ex012, asyncio.Lock.__class__.__name__.__eq__,                   ["type"],               true]
    - [as1156ex013, asyncio.Event.__class__.__name__.__eq__,                  ["type"],               true]
    - [as1156ex014, asyncio.Semaphore.__class__.__name__.__eq__,              ["type"],               true]
    - [as1156ex015, asyncio.Condition.__class__.__name__.__eq__,              ["type"],               true]
    - [as1156ex016, asyncio.BoundedSemaphore.__class__.__name__.__eq__,       ["type"],               true]
