spec: asyncio_extra1156
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio.__package__/__loader__ class name, asyncio.__all__ class name, asyncio.Lock/Event/Semaphore/Condition module identity, asyncio.BoundedSemaphore module identity, asyncio.sleep/__class__ identity, asyncio.InvalidStateError/TimeoutError/CancelledError module identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.__package__/__loader__ class name, asyncio.__all__ class name, asyncio.Lock/Event/Semaphore/Condition/BoundedSemaphore module identity, asyncio.sleep class identity, asyncio.InvalidStateError/TimeoutError/CancelledError module identity — behaviors not covered by extra1126 or extra1141"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1156.package_loader_all_identity:
  description: "asyncio.__package__/__loader__ class name and asyncio.__all__ class name identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: as1156pl
  columns: [id, function, args, expected]
  rows:
    - [as1156pl001, asyncio.__package__.__class__.__name__.__eq__,      ["str"],              true]
    - [as1156pl002, asyncio.__package__.__eq__,                          ["asyncio"],          true]
    - [as1156pl003, asyncio.__loader__.__class__.__name__.__eq__,        ["SourceFileLoader"], true]
    - [as1156pl004, asyncio.__loader__.__name__.__eq__,                  ["asyncio"],          true]
    - [as1156pl005, asyncio.__all__.__class__.__name__.__eq__,           ["list"],             true]
    - [as1156pl006, asyncio.__spec__.submodule_search_locations.__class__.__name__.__eq__, ["_NamespacePath"], true]
    - [as1156pl007, asyncio.__spec__.origin.__class__.__name__.__eq__,   ["str"],              true]

table asyncio_extra1156.lock_event_semaphore_module:
  description: "asyncio.Lock/Event/Semaphore/Condition/BoundedSemaphore module identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: as1156ls
  columns: [id, function, args, expected]
  rows:
    - [as1156ls001, asyncio.Lock.__module__.__eq__,              ["asyncio.locks"],  true]
    - [as1156ls002, asyncio.Lock.__name__.__eq__,                ["Lock"],           true]
    - [as1156ls003, asyncio.Lock.__qualname__.__eq__,            ["Lock"],           true]
    - [as1156ls004, asyncio.Event.__module__.__eq__,             ["asyncio.locks"],  true]
    - [as1156ls005, asyncio.Event.__name__.__eq__,               ["Event"],          true]
    - [as1156ls006, asyncio.Event.__qualname__.__eq__,           ["Event"],          true]
    - [as1156ls007, asyncio.Semaphore.__module__.__eq__,         ["asyncio.locks"],  true]
    - [as1156ls008, asyncio.Semaphore.__name__.__eq__,           ["Semaphore"],      true]
    - [as1156ls009, asyncio.Semaphore.__qualname__.__eq__,       ["Semaphore"],      true]
    - [as1156ls010, asyncio.Condition.__module__.__eq__,         ["asyncio.locks"],  true]
    - [as1156ls011, asyncio.Condition.__name__.__eq__,           ["Condition"],      true]
    - [as1156ls012, asyncio.Condition.__qualname__.__eq__,       ["Condition"],      true]
    - [as1156ls013, asyncio.BoundedSemaphore.__module__.__eq__,  ["asyncio.locks"],  true]
    - [as1156ls014, asyncio.BoundedSemaphore.__name__.__eq__,    ["BoundedSemaphore"], true]
    - [as1156ls015, asyncio.BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true]

table asyncio_extra1156.exception_class_identity:
  description: "asyncio.InvalidStateError, asyncio.TimeoutError, and asyncio.CancelledError module and class identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: as1156ex
  columns: [id, function, args, expected]
  rows:
    - [as1156ex001, asyncio.InvalidStateError.__module__.__eq__,              ["asyncio.exceptions"], true]
    - [as1156ex002, asyncio.InvalidStateError.__name__.__eq__,                ["InvalidStateError"],  true]
    - [as1156ex003, asyncio.InvalidStateError.__qualname__.__eq__,            ["InvalidStateError"],  true]
    - [as1156ex004, asyncio.InvalidStateError.__class__.__name__.__eq__,      ["type"],               true]
    - [as1156ex005, asyncio.TimeoutError.__module__.__eq__,                   ["asyncio.exceptions"], true]
    - [as1156ex006, asyncio.TimeoutError.__name__.__eq__,                     ["TimeoutError"],       true]
    - [as1156ex007, asyncio.TimeoutError.__qualname__.__eq__,                 ["TimeoutError"],       true]
    - [as1156ex008, asyncio.CancelledError.__module__.__eq__,                 ["asyncio.exceptions"], true]
