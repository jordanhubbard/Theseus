spec: isobject
version: ">=4.0.0"
backend: node(isobject)

docs: https://www.npmjs.com/package/isobject

provenance:
  derived_from:
    - "isobject README — https://www.npmjs.com/package/isobject"
    - "Test vectors verified with isobject via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "isobject source"
  notes:
    - "isobject is an npm package. Install: npm install isobject"
    - "Returns true if the value is a plain object (not an array, not null)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table isobject.isObject:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: isobj

  columns: [id, args, expected]
  rows:
    - [plain_obj,  [{}],         true]
    - [with_key,   [{"a": 1}],   true]
    - [array,      [[1, 2, 3]],  false]
    - [null_val,   [null],       false]
    - [string,     ["foo"],      false]

