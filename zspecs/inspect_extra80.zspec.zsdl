spec: inspect_extra80
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra79.zspec.zsdl."
    - "This spec covers: inspect Parameter class constant values — _ParameterKind class name checks, integer values, and empty/doc class checks (Wave 245)."
    - "Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — POSITIONAL_ONLY is an enum member. Verified with Python 3.14.3."
    - "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — verified with Python 3.14.3."
    - "Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind' — verified with Python 3.14.3."
    - "Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — verified with Python 3.14.3."
    - "Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind' — verified with Python 3.14.3."
    - "Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is a sentinel class object (inspect._empty); its __class__ is type. Verified with Python 3.14.3."
    - "Parameter.POSITIONAL_ONLY integer value == 0 — _ParameterKind enum starts at 0. Verified with Python 3.14.3."
    - "Parameter.POSITIONAL_OR_KEYWORD integer value == 1 — verified with Python 3.14.3."
    - "Parameter.VAR_POSITIONAL integer value == 2 — verified with Python 3.14.3."
    - "Parameter.KEYWORD_ONLY integer value == 3 — verified with Python 3.14.3."
    - "Parameter.VAR_KEYWORD integer value == 4 — verified with Python 3.14.3."
    - "Parameter.POSITIONAL_ONLY.__doc__ == None — _ParameterKind enum members have no docstring; __doc__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Parameter kind constants __class__.__name__ — extra80
#
# Wave 245 theme: inspect.Parameter kind constants are _ParameterKind enum members.
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__      == '_ParameterKind'
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_POSITIONAL.__class__.__name__       == '_ParameterKind'
# inspect.Parameter.KEYWORD_ONLY.__class__.__name__         == '_ParameterKind'
# inspect.Parameter.VAR_KEYWORD.__class__.__name__          == '_ParameterKind'
#
# No prior inspect spec checks Parameter kind constant __class__.__name__ via inspectextra80. New to extra80.
# ---------------------------------------------------------------------------

table inspect_extra80.Parameter_kind_class_names:
  description: "Parameter.POSITIONAL_ONLY/POSITIONAL_OR_KEYWORD/VAR_POSITIONAL/KEYWORD_ONLY/VAR_KEYWORD __class__.__name__=='_ParameterKind'; wave 245 Parameter kind constant class names; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra80

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_POSITIONAL_ONLY_class_name_eq__ParameterKind,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — Parameter.POSITIONAL_ONLY is a member of the _ParameterKind enum class defined in Lib/inspect.py; the member's __class__ is _ParameterKind and its __name__ is '_ParameterKind' (14 chars); str.__eq__('_ParameterKind') returns True; no prior inspect spec checks Parameter.POSITIONAL_ONLY.__class__.__name__ via inspectextra80; new to extra80"]
    - [Parameter_POSITIONAL_OR_KEYWORD_class_name_eq__ParameterKind,
       Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — Parameter.POSITIONAL_OR_KEYWORD is a member of the _ParameterKind enum class; the member's __class__.__name__ is '_ParameterKind' (14 chars); str.__eq__('_ParameterKind') returns True; no prior inspect spec checks Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ via inspectextra80; new to extra80"]
    - [Parameter_VAR_POSITIONAL_class_name_eq__ParameterKind,
       Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — Parameter.VAR_POSITIONAL is a member of the _ParameterKind enum class; the member's __class__.__name__ is '_ParameterKind' (14 chars); str.__eq__('_ParameterKind') returns True; no prior inspect spec checks Parameter.VAR_POSITIONAL.__class__.__name__ via inspectextra80; new to extra80"]
    - [Parameter_KEYWORD_ONLY_class_name_eq__ParameterKind,
       Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — Parameter.KEYWORD_ONLY is a member of the _ParameterKind enum class; the member's __class__.__name__ is '_ParameterKind' (14 chars); str.__eq__('_ParameterKind') returns True; no prior inspect spec checks Parameter.KEYWORD_ONLY.__class__.__name__ via inspectextra80; new to extra80"]
    - [Parameter_VAR_KEYWORD_class_name_eq__ParameterKind,
       Parameter.VAR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — Parameter.VAR_KEYWORD is a member of the _ParameterKind enum class; the member's __class__.__name__ is '_ParameterKind' (14 chars); str.__eq__('_ParameterKind') returns True; no prior inspect spec checks Parameter.VAR_KEYWORD.__class__.__name__ via inspectextra80; new to extra80"]

# ---------------------------------------------------------------------------
# Parameter.empty and POSITIONAL_ONLY.__doc__ class names — extra80
#
# Wave 245 theme: Parameter.empty is a sentinel class (type); __doc__ is NoneType.
#
# inspect.Parameter.empty.__class__.__name__                       == 'type'
# inspect.Parameter.POSITIONAL_ONLY.__doc__.__class__.__name__     == 'NoneType'
#
# No prior inspect spec checks Parameter.empty/__doc__ class names via inspectextra80. New to extra80.
# ---------------------------------------------------------------------------

table inspect_extra80.Parameter_empty_and_doc:
  description: "Parameter.empty.__class__.__name__=='type'; Parameter.POSITIONAL_ONLY.__doc__.__class__.__name__=='NoneType'; wave 245 Parameter sentinel and doc class names; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra80

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_empty_class_name_eq_type,
       Parameter.empty.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a sentinel value that is the class inspect._empty (a class object, not an instance); its __class__ is type (the metaclass of all regular classes) and __class__.__name__ is 'type' (4 chars); str.__eq__('type') returns True; no prior inspect spec checks Parameter.empty.__class__.__name__ via inspectextra80; new to extra80"]
    - [Parameter_POSITIONAL_ONLY_doc_class_name_eq_NoneType,
       Parameter.POSITIONAL_ONLY.__doc__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__doc__.__class__.__name__.__eq__('NoneType') == True — _ParameterKind enum members have no individual docstring; Parameter.POSITIONAL_ONLY.__doc__ is None; None.__class__.__name__ is 'NoneType' (8 chars); str.__eq__('NoneType') returns True; no prior inspect spec checks Parameter.POSITIONAL_ONLY.__doc__.__class__.__name__ via inspectextra80; new to extra80"]

# ---------------------------------------------------------------------------
# Parameter kind integer values (POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL) — extra80
#
# Wave 245 theme: _ParameterKind enum integer values (first three).
#
# inspect.Parameter.POSITIONAL_ONLY.__eq__(0)      == True
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True
# inspect.Parameter.VAR_POSITIONAL.__eq__(2)        == True
#
# No prior inspect spec checks Parameter kind integer values via inspectextra80. New to extra80.
# ---------------------------------------------------------------------------

table inspect_extra80.Parameter_kind_int_values_low:
  description: "Parameter.POSITIONAL_ONLY==0; POSITIONAL_OR_KEYWORD==1; VAR_POSITIONAL==2; wave 245 Parameter kind integer values; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra80

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_POSITIONAL_ONLY_eq_0,
       Parameter.POSITIONAL_ONLY.__eq__,
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — _ParameterKind is an IntEnum starting at 0; POSITIONAL_ONLY is the first member with integer value 0; IntEnum.__eq__(0) returns True; no prior inspect spec checks Parameter.POSITIONAL_ONLY integer value via inspectextra80; new to extra80"]
    - [Parameter_POSITIONAL_OR_KEYWORD_eq_1,
       Parameter.POSITIONAL_OR_KEYWORD.__eq__,
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — _ParameterKind is an IntEnum; POSITIONAL_OR_KEYWORD is the second member with integer value 1; IntEnum.__eq__(1) returns True; no prior inspect spec checks Parameter.POSITIONAL_OR_KEYWORD integer value via inspectextra80; new to extra80"]
    - [Parameter_VAR_POSITIONAL_eq_2,
       Parameter.VAR_POSITIONAL.__eq__,
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — _ParameterKind is an IntEnum; VAR_POSITIONAL is the third member with integer value 2; IntEnum.__eq__(2) returns True; no prior inspect spec checks Parameter.VAR_POSITIONAL integer value via inspectextra80; new to extra80"]

# ---------------------------------------------------------------------------
# Parameter kind integer values (KEYWORD_ONLY, VAR_KEYWORD) — extra80
#
# Wave 245 theme: _ParameterKind enum integer values (last two).
#
# inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True
# inspect.Parameter.VAR_KEYWORD.__eq__(4)  == True
#
# No prior inspect spec checks Parameter.KEYWORD_ONLY/VAR_KEYWORD integer values via inspectextra80. New to extra80.
# ---------------------------------------------------------------------------

table inspect_extra80.Parameter_kind_int_values_high:
  description: "Parameter.KEYWORD_ONLY==3; VAR_KEYWORD==4; wave 245 Parameter kind integer values; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra80

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_KEYWORD_ONLY_eq_3,
       Parameter.KEYWORD_ONLY.__eq__,
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — _ParameterKind is an IntEnum; KEYWORD_ONLY is the fourth member with integer value 3; IntEnum.__eq__(3) returns True; no prior inspect spec checks Parameter.KEYWORD_ONLY integer value via inspectextra80; new to extra80"]
    - [Parameter_VAR_KEYWORD_eq_4,
       Parameter.VAR_KEYWORD.__eq__,
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.__eq__(4) == True — _ParameterKind is an IntEnum; VAR_KEYWORD is the fifth and final member with integer value 4; IntEnum.__eq__(4) returns True; no prior inspect spec checks Parameter.VAR_KEYWORD integer value via inspectextra80; new to extra80"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra80
# ---------------------------------------------------------------------------

invariant inspect_extra80.Parameter_POSITIONAL_ONLY_class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is a _ParameterKind enum member; wave 245 Parameter kind constant class names; new to extra80"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra80.Parameter_VAR_KEYWORD_class_name:
  description: "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD is a _ParameterKind enum member; wave 245 Parameter kind constant class names; new to extra80"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra80.Parameter_empty_class_name:
  description: "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is the sentinel class inspect._empty whose __class__ is type; wave 245 Parameter sentinel class name; new to extra80"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra80.Parameter_POSITIONAL_ONLY_int_value:
  description: "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — POSITIONAL_ONLY has integer value 0 in the _ParameterKind IntEnum; wave 245 Parameter kind integer values; new to extra80"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__eq__
  args: [0]
  expected: true

invariant inspect_extra80.Parameter_VAR_KEYWORD_int_value:
  description: "inspect.Parameter.VAR_KEYWORD.__eq__(4) == True — VAR_KEYWORD has integer value 4 in the _ParameterKind IntEnum; wave 245 Parameter kind integer values; new to extra80"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__eq__
  args: [4]
  expected: true
