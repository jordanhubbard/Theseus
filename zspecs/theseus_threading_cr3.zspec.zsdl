spec: theseus_threading_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_threading_cr3)
blocks: threading

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
  notes:
    - "Clean-room extended threading primitives. Do NOT import threading."
    - "Semaphore(value=1): counting semaphore; acquire() decrements, release() increments."
    - "Condition(lock=None): condition variable; acquire/release, wait/notify."
    - "Event(): thread synchronization; set()/clear()/is_set()/wait()."
    - "threading3_semaphore(): Semaphore(2) acquire twice then release — returns True."
    - "threading3_condition(): Condition() acquire and release without deadlock — returns True."
    - "threading3_event(): Event() set/clear/is_set cycle — returns True."
    - "Zero-arg invariant signatures — def threading3_semaphore(): return bool"
    - "Semaphore: internal counter; acquire() blocks if counter is 0; release() increments."
    - "Condition: wraps a lock; acquire/release forward to the lock."
    - "Event: internal flag; set() makes flag True; clear() makes it False; is_set() reads it."
    - "May use _thread module internally for locks."
    - "Export: Semaphore, BoundedSemaphore, Condition, Event, Barrier, Thread, Lock, RLock."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_threading_cr3.semaphore:
  description: "Semaphore(2) supports acquire and release"
  category: Semaphore
  kind: python_call_eq
  function: threading3_semaphore
  args: []
  expected: true

invariant theseus_threading_cr3.condition:
  description: "Condition() supports acquire and release"
  category: Condition
  kind: python_call_eq
  function: threading3_condition
  args: []
  expected: true

invariant theseus_threading_cr3.event:
  description: "Event() set/clear/is_set cycle works correctly"
  category: Event
  kind: python_call_eq
  function: threading3_event
  args: []
  expected: true
