spec: io_extra88
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra87."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ and key method membership; BytesIO/StringIO/FileIO __dict__.__class__.__name__ and membership; UnsupportedOperation identity, bases, MRO; DEFAULT_BUFFER_SIZE and SEEK_* constants class and value; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO; RawIOBase/BufferedIOBase/TextIOBase/IOBase class identity and hierarchy; io.open/__class__/__module__/__qualname__; io.open_code identity; io.DEFAULT_BUFFER_SIZE value; io.UnsupportedOperation hierarchy."
    - "This spec covers: io.BufferedReader.__name__; io.BufferedReader.__module__; io.BufferedReader.__bases__[0].__name__; io.BufferedReader.__mro__.__len__(); io.BufferedReader.__qualname__; io.BufferedReader.__qualname__.__len__(); io.BufferedWriter.__name__; io.BufferedWriter.__module__; io.BufferedWriter.__bases__[0].__name__; io.BufferedWriter.__mro__.__len__(); io.BufferedWriter.__qualname__; io.BufferedWriter.__qualname__.__len__(); io.BufferedRandom.__name__; io.BufferedRandom.__module__; io.BufferedRandom.__mro__.__len__(); io.RawIOBase.__mro__.__len__()."
    - "io.BufferedReader.__name__ == 'BufferedReader' — the C type name."
    - "io.BufferedReader.__module__ == '_io' — defined in the C extension module _io."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — the C-level abstract base."
    - "io.BufferedReader.__mro__.__len__() == 4 — [BufferedReader, _BufferedIOBase, _IOBase, object]."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — length 14."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' — the C type name."
    - "io.BufferedWriter.__module__ == '_io' — defined in the C extension module _io."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — the C-level abstract base."
    - "io.BufferedWriter.__mro__.__len__() == 4 — [BufferedWriter, _BufferedIOBase, _IOBase, object]."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — length 14."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' — the C type name."
    - "io.BufferedRandom.__module__ == '_io' — defined in the C extension module _io."
    - "io.BufferedRandom.__mro__.__len__() == 4 — same depth as BufferedReader/BufferedWriter."
    - "io.RawIOBase.__mro__.__len__() == 5 — [RawIOBase, _RawIOBase, IOBase, _IOBase, object] (anchor)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader identity: __name__, __module__, __bases__[0].__name__, __mro__.__len__()
# BufferedReader is a C type in _io; bases[0] is the C-level _BufferedIOBase; MRO length 4.
# Function values with [ must be double-quoted.
# Not covered in any prior io spec at this level.
# ---------------------------------------------------------------------------

table io_extra88.BufferedReader_identity:
  description: "BufferedReader __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra88

  columns: [id, function, args, expected]
  rows:
    - [br_name,    BufferedReader.__name__.__eq__,                  ["BufferedReader"],  true]
    - [br_module,  BufferedReader.__module__.__eq__,                ["_io"],             true]
    - [br_base0,   "BufferedReader.__bases__[0].__name__.__eq__",   ["_BufferedIOBase"], true]
    - [br_mro_len, BufferedReader.__mro__.__len__,                  [],                  4]

# ---------------------------------------------------------------------------
# io.BufferedWriter identity: __name__, __module__, __bases__[0].__name__, __mro__.__len__()
# BufferedWriter is a C type in _io; bases[0] is _BufferedIOBase; MRO length 4.
# Function values with [ must be double-quoted.
# Not covered in any prior io spec at this level.
# ---------------------------------------------------------------------------

table io_extra88.BufferedWriter_identity:
  description: "BufferedWriter __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra88

  columns: [id, function, args, expected]
  rows:
    - [bw_name,    BufferedWriter.__name__.__eq__,                  ["BufferedWriter"],  true]
    - [bw_module,  BufferedWriter.__module__.__eq__,                ["_io"],             true]
    - [bw_base0,   "BufferedWriter.__bases__[0].__name__.__eq__",   ["_BufferedIOBase"], true]
    - [bw_mro_len, BufferedWriter.__mro__.__len__,                  [],                  4]

# ---------------------------------------------------------------------------
# io.BufferedRandom identity and io.RawIOBase MRO anchor
# BufferedRandom: __name__ == 'BufferedRandom', __module__ == '_io', MRO length 4.
# RawIOBase: MRO length 5 (anchor for cross-spec consistency).
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra88.BufferedRandom_and_RawIOBase:
  description: "BufferedRandom __name__, __module__, __mro__.__len__(); RawIOBase __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra88

  columns: [id, function, args, expected]
  rows:
    - [bran_name,    BufferedRandom.__name__.__eq__,   ["BufferedRandom"], true]
    - [bran_module,  BufferedRandom.__module__.__eq__, ["_io"],            true]
    - [bran_mro_len, BufferedRandom.__mro__.__len__,   [],                 4]
    - [raw_mro_len,  RawIOBase.__mro__.__len__,         [],                 5]

# ---------------------------------------------------------------------------
# io.BufferedReader and io.BufferedWriter __qualname__ identity and length
# Both have __qualname__ == their class name; both are 14 characters long.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra88.BufferedReader_BufferedWriter_qualname:
  description: "BufferedReader and BufferedWriter __qualname__ values and __qualname__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra88

  columns: [id, function, args, expected]
  rows:
    - [br_qualname,     BufferedReader.__qualname__.__eq__,      ["BufferedReader"], true]
    - [br_qualname_len, BufferedReader.__qualname__.__len__,     [],                 14]
    - [bw_qualname,     BufferedWriter.__qualname__.__eq__,      ["BufferedWriter"], true]
    - [bw_qualname_len, BufferedWriter.__qualname__.__len__,     [],                 14]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra88.BufferedReader.name:
  description: "io.BufferedReader.__name__ == 'BufferedReader' (C type name in _io)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra88.BufferedReader.module:
  description: "io.BufferedReader.__module__ == '_io' (defined in the C extension module)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra88.BufferedReader.mro_len:
  description: "io.BufferedReader.__mro__.__len__() == 4 ([BufferedReader, _BufferedIOBase, _IOBase, object])"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__mro__.__len__
  args: []
  expected: 4

invariant io_extra88.BufferedWriter.mro_len:
  description: "io.BufferedWriter.__mro__.__len__() == 4 ([BufferedWriter, _BufferedIOBase, _IOBase, object])"
  category: class_identity
  kind: python_call_eq
  function: BufferedWriter.__mro__.__len__
  args: []
  expected: 4

invariant io_extra88.BufferedReader.qualname_len:
  description: "io.BufferedReader.__qualname__.__len__() == 14 ('BufferedReader' has 14 chars)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__qualname__.__len__
  args: []
  expected: 14
