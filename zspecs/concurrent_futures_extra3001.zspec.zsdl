    - ["di_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__delitem__"], false]
    - ["di_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__delitem__"], false]
