    - ["si_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__setitem__"], false]
    - ["si_CancelledError",      operator.contains, [CancelledError.__dict__,      "__setitem__"], false]
    - ["si_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__setitem__"], false]
    - ["si_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__setitem__"], false]
    - ["si_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__setitem__"], false]

