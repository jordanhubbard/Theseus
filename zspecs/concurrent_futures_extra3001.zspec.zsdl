# ---------------------------------------------------------------------------
# combined — all three item-access operators across a cross-class sample
#
# Spot-checks __getitem__, __setitem__, __delitem__ absence across
# concurrent.futures classes in a single table.
# 8 subjects x 3 operators = 24 rows.
# ---------------------------------------------------------------------------

table cf3001.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Future_gi",              operator.contains, [Future.__dict__,              "__getitem__"], false]
    - ["comb_Future_si",              operator.contains, [Future.__dict__,              "__setitem__"], false]
    - ["comb_Future_di",              operator.contains, [Future.__dict__,              "__delitem__"], false]
    - ["comb_ThreadPool_gi",          operator.contains, [ThreadPoolExecutor.__dict__,  "__getitem__"], false]
    - ["comb_ThreadPool_si",          operator.contains, [ThreadPoolExecutor.__dict__,  "__setitem__"], false]
    - ["comb_ThreadPool_di",          operator.contains, [ThreadPoolExecutor.__dict__,  "__delitem__"], false]
    - ["comb_ProcessPool_gi",         operator.contains, [ProcessPoolExecutor.__dict__, "__getitem__"], false]
    - ["comb_ProcessPool_si",         operator.contains, [ProcessPoolExecutor.__dict__, "__setitem__"], false]
    - ["comb_ProcessPool_di",         operator.contains, [ProcessPoolExecutor.__dict__, "__delitem__"], false]
    - ["comb_CancelledError_gi",      operator.contains, [CancelledError.__dict__,      "__getitem__"], false]
    - ["comb_CancelledError_si",      operator.contains, [CancelledError.__dict__,      "__setitem__"], false]
    - ["comb_CancelledError_di",      operator.contains, [CancelledError.__dict__,      "__delitem__"], false]
    - ["comb_TimeoutError_gi",        operator.contains, [TimeoutError.__dict__,        "__getitem__"], false]
    - ["comb_TimeoutError_si",        operator.contains, [TimeoutError.__dict__,        "__setitem__"], false]
    - ["comb_TimeoutError_di",        operator.contains, [TimeoutError.__dict__,        "__delitem__"], false]
    - ["comb_BrokenExecutor_gi",      operator.contains, [BrokenExecutor.__dict__,      "__getitem__"], false]
    - ["comb_BrokenExecutor_si",      operator.contains, [BrokenExecutor.__dict__,      "__setitem__"], false]
    - ["comb_BrokenExecutor_di",      operator.contains, [BrokenExecutor.__dict__,      "__delitem__"], false]
    - ["comb_InvalidStateError_gi",   operator.contains, [InvalidStateError.__dict__,   "__getitem__"], false]
    - ["comb_InvalidStateError_si",   operator.contains, [InvalidStateError.__dict__,   "__setitem__"], false]
    - ["comb_InvalidStateError_di",   operator.contains, [InvalidStateError.__dict__,   "__delitem__"], false]
    - ["comb_Future_class_gi",        operator.contains, [Future.__class__.__dict__,    "__getitem__"], false]
    - ["comb_Future_class_si",        operator.contains, [Future.__class__.__dict__,    "__setitem__"], false]
    - ["comb_Future_class_di",        operator.contains, [Future.__class__.__dict__,    "__delitem__"], false]
