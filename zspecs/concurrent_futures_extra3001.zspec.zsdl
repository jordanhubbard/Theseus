spec: cf3001
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 647 — theme: __getitem__, __setitem__, __delitem__ dict-presence (item access/mutation protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__getitem__') etc. for concurrent.futures classes."
    - "Classes covered: Future, ThreadPoolExecutor, ProcessPoolExecutor, CancelledError, TimeoutError, BrokenExecutor, InvalidStateError."
    - "None of these classes define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "Executor classes manage work queues internally but do not expose item-access protocol to callers."
    - "Exception subclasses (CancelledError, TimeoutError, BrokenExecutor, InvalidStateError) inherit from standard exception hierarchy with no item-access slots."
    - "concurrent.futures.Future is a result-holder, not a mapping or sequence; it has no item protocol."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# None of the concurrent.futures classes define __getitem__; all false.
# ---------------------------------------------------------------------------

table cf3001.getitem:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_getitem
  id_prefix: gi

  columns: [id, function, args, expected]
  rows:
    - ["gi_Future",              operator.contains, [Future.__dict__,              "__getitem__"], false]
    - ["gi_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__getitem__"], false]
    - ["gi_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__getitem__"], false]
    - ["gi_CancelledError",      operator.contains, [CancelledError.__dict__,      "__getitem__"], false]
    - ["gi_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__getitem__"], false]
    - ["gi_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__getitem__"], false]
    - ["gi_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__getitem__"], false]

