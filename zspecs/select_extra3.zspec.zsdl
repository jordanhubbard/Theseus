spec: select_extra3
version: ">=3.9"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/select.html — Python select module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "Extends select.zspec.zsdl, select_extra.zspec.zsdl, and select_extra2.zspec.zsdl."
    - "select.zspec.zsdl covers: select.__name__; poll.__name__; kqueue.__name__; kevent.__name__; POLLIN/POLLOUT/POLLERR is_int; KQ_FILTER_READ/KQ_FILTER_WRITE is_int; kqueue()/poll() instance class."
    - "select_extra.zspec.zsdl covers: error.__name__ == 'error'; error.__bases__[0].__name__ == 'OSError'; select.__name__; select.__module__."
    - "select_extra2.zspec.zsdl covers: select.__name__; select.__module__; error.__name__ == 'OSError'; error.__bases__[0].__name__ == 'Exception'; POLLIN/POLLOUT is_int and value; KQ_FILTER_READ/KQ_FILTER_WRITE value; KQ_EV_ADD/DELETE/ENABLE/DISABLE table."
    - "This spec adds: select module-level __name__ attribute; POLLERR >= 1 (value bound); POLLHUP and POLLNVAL integer class and value; poll.__module__; error.__module__."
    - "POLLERR == 8 on macOS/Darwin; POLLHUP == 16 on macOS/Darwin; POLLNVAL == 32 on macOS/Darwin — values verified with Python 3.12."
    - "poll.__module__ == 'select' — the poll class is implemented in the C select module."
    - "select.error.__module__ == 'builtins' — select.error is OSError, a builtin exception."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# select module-level __name__ attribute
# select_extra covers select.select.__name__; this tests the module's __name__.
# ---------------------------------------------------------------------------

invariant select_extra3.module.name:
  description: "select module's __name__ attribute == 'select'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["select"]
  expected: true

# ---------------------------------------------------------------------------
# poll class — __module__ attribute
# select.zspec.zsdl and select_extra cover poll.__name__; __module__ is new.
# ---------------------------------------------------------------------------

invariant select_extra3.poll.module:
  description: "select.poll.__module__ == 'select' — poll is defined in the C select extension"
  category: functions
  kind: python_call_eq
  function: poll.__module__.__eq__
  args: ["select"]
  expected: true

# ---------------------------------------------------------------------------
# select.error __module__ — select.error is OSError, a builtin exception
# ---------------------------------------------------------------------------

invariant select_extra3.error.module:
  description: "select.error.__module__ == 'builtins' — select.error is OSError, a builtin"
  category: exceptions
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# POLLERR — value bound
# select.zspec.zsdl covers POLLERR is_int.
# select_extra2 covers POLLIN==1 and POLLOUT==4 values; POLLERR value is new.
# POLLERR == 8 on macOS/Darwin (verified with Python 3.12).
# ---------------------------------------------------------------------------

invariant select_extra3.POLLERR.ge_1:
  description: "select.POLLERR >= 1 — POLLERR is a positive nonzero constant on all POSIX platforms"
  category: constants
  kind: python_call_eq
  function: POLLERR.__ge__
  args: [1]
  expected: true

invariant select_extra3.POLLERR.value:
  description: "select.POLLERR == 8 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: POLLERR.__eq__
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# POLLHUP — hang-up event flag (macOS/Darwin value: 16)
# Not mentioned in any prior select spec; present on macOS and Linux.
# ---------------------------------------------------------------------------

invariant select_extra3.POLLHUP.is_int:
  description: "select.POLLHUP.__class__.__name__ == 'int' — POLLHUP is an integer constant"
  category: constants
  kind: python_call_eq
  function: POLLHUP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra3.POLLHUP.value:
  description: "select.POLLHUP == 16 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: POLLHUP.__eq__
  args: [16]
  expected: true

# ---------------------------------------------------------------------------
# POLLNVAL — invalid request flag (macOS/Darwin value: 32)
# Not mentioned in any prior select spec.
# ---------------------------------------------------------------------------

invariant select_extra3.POLLNVAL.is_int:
  description: "select.POLLNVAL.__class__.__name__ == 'int' — POLLNVAL is an integer constant"
  category: constants
  kind: python_call_eq
  function: POLLNVAL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra3.POLLNVAL.value:
  description: "select.POLLNVAL == 32 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: POLLNVAL.__eq__
  args: [32]
  expected: true
