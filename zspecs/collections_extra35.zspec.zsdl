spec: collections_extra35
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra34.zspec.zsdl."
    - "Prior specs covered: all class __name__/__module__/__qualname__/__bases__, __mro__.__len__ for all core classes, __bases__[0].__name__ for all eight classes, __qualname__.__len__ for all nine top-level symbols, deque/Counter/OrderedDict method qualname lengths, __dict__.__class__.__name__ for all major classes (== 'mappingproxy', len=12), collections.__all__.__len__()==9, __all__.__class__.__name__.__len__()==4, OrderedDict.__reversed__.__qualname__.__len__()==24, ChainMap.new_child.__qualname__.__len__()==18, defaultdict.__bases__[0].__name__.__len__()==4, UserDict/UserList/UserString __bases__[0].__name__.__len__()==14/15/8."
    - "This spec covers: __mro__.__len__() for OrderedDict/defaultdict/Counter (3 each), deque (2), ChainMap/UserDict (8 each), UserList (9), UserString (8); __bases__[0].__name__.__len__() for OrderedDict/Counter (4, 'dict'), deque (6, 'object'), ChainMap (14, 'MutableMapping'); collections.__name__.__len__()==11; Counter.most_common.__qualname__.__len__()==19; collections.namedtuple.__qualname__.__len__()==10; UserDict.update.__qualname__.__len__()==21 (inherited from MutableMapping)."
    - "Surprise: ChainMap.__mro__.__len__() == 8 (NOT 3 as a simple read might suggest). ChainMap, UserDict, and UserString all traverse 8 MRO entries because MutableMapping and Mapping both implement multiple ABC mixins (Sized, Iterable, Container, Collection). UserList is even longer at 9 MRO entries due to MutableSequence → Sequence → Reversible."
    - "OrderedDict.__mro__.__len__() == 3 (OrderedDict → dict → object); Counter.__mro__.__len__() == 3 (Counter → dict → object); defaultdict.__mro__.__len__() == 3 (defaultdict → dict → object)."
    - "deque.__mro__.__len__() == 2 (deque → object) — deque is a C-level type with no Python-visible ABC ancestry."
    - "Counter.__bases__[0].__name__ == 'dict' (len=4); OrderedDict.__bases__[0].__name__ == 'dict' (len=4)."
    - "deque.__bases__[0].__name__ == 'object' (len=6); ChainMap.__bases__[0].__name__ == 'MutableMapping' (len=14)."
    - "Counter.most_common.__qualname__ == 'Counter.most_common' (len=19)."
    - "collections.namedtuple.__qualname__ == 'namedtuple' (len=10) — top-level factory function."
    - "UserDict.update.__qualname__ == 'MutableMapping.update' (len=21) — inherited from the ABC, so qualname carries the MutableMapping prefix."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for dict-backed collection classes (extra35 namespace)
#
# OrderedDict, defaultdict, and Counter all directly subclass dict, giving each
# a short MRO of length 3 (self → dict → object). deque is a C-level type with
# no Python-visible ABC ancestry, so its MRO has length 2 (deque → object).
# No prior collections spec records these four MRO lengths together in the
# extra35 namespace.
# ---------------------------------------------------------------------------

table collections_extra35.dict_backed_mro_lens:
  description: "__mro__.__len__() for dict-backed classes: OrderedDict/defaultdict/Counter==3, deque==2"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_len

  columns: [id, function, args, expected]
  rows:
    - [OrderedDict, OrderedDict.__mro__.__len__, [], 3]
    - [defaultdict, defaultdict.__mro__.__len__, [], 3]
    - [Counter,     Counter.__mro__.__len__,     [], 3]
    - [deque,       deque.__mro__.__len__,        [], 2]

# ---------------------------------------------------------------------------
# __mro__.__len__() for ABC-backed wrapper classes (extra35 namespace)
#
# ChainMap, UserDict, UserList, and UserString inherit from MutableMapping or
# MutableSequence ABCs, which themselves expand into long MRO chains via
# collection.abc mixin classes (Sized, Iterable, Container, Collection, etc.):
#   ChainMap  -> MutableMapping chain -> 8 entries
#   UserDict  -> MutableMapping chain -> 8 entries
#   UserList  -> MutableSequence chain -> 9 entries (Reversible adds one step)
#   UserString -> Sequence chain -> 8 entries
# No prior collections spec records these MRO lengths in the extra35 namespace.
# ---------------------------------------------------------------------------

table collections_extra35.abc_backed_mro_lens:
  description: "__mro__.__len__() for ABC-backed classes: ChainMap/UserDict/UserString==8, UserList==9"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_len

  columns: [id, function, args, expected]
  rows:
    - [ChainMap,   ChainMap.__mro__.__len__,   [], 8]
    - [UserDict,   UserDict.__mro__.__len__,    [], 8]
    - [UserList,   UserList.__mro__.__len__,    [], 9]
    - [UserString, UserString.__mro__.__len__,  [], 8]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for dict-backed and C-level classes
# (extra35 namespace)
#
# OrderedDict and Counter both have 'dict' as their direct base (len=4).
# deque has 'object' as its direct base (len=6) — it is a pure C-level type
# with no intermediate Python superclass. ChainMap has 'MutableMapping' as its
# direct base (len=14) — ChainMap is the only core collection class that
# directly names an ABC as its single explicit base. No prior collections spec
# records these four base name lengths together in the extra35 namespace.
# ---------------------------------------------------------------------------

table collections_extra35.base_name_lens:
  description: "__bases__[0].__name__.__len__() for OrderedDict/Counter (4), deque (6), ChainMap (14)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base_name_len

  columns: [id, function, args, expected]
  rows:
    - [OrderedDict, "OrderedDict.__bases__[0].__name__.__len__",  [], 4]
    - [Counter,     "Counter.__bases__[0].__name__.__len__",      [], 4]
    - [deque,       "deque.__bases__[0].__name__.__len__",        [], 6]
    - [ChainMap,    "ChainMap.__bases__[0].__name__.__len__",     [], 14]

# ---------------------------------------------------------------------------
# collections.__name__.__len__() == 11 — standalone (extra35 namespace)
#
# The module's own __name__ is 'collections' — 11 characters. No prior
# collections spec records this standalone in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra35.module_name_len:
  description: "collections.__name__.__len__() == 11 — the module name 'collections' has 11 characters"
  category: module_attrs
  kind: python_call_eq
  function: collections.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# Counter.most_common.__qualname__.__len__() == 19 — standalone
# (extra35 namespace)
#
# 'Counter.most_common' has 19 characters: 7 (Counter) + 1 (.) + 11
# (most_common) = 19. most_common(n=None) returns the n most common elements
# and their counts. Its qualname length (19) equals asynccontextmanager's
# qualname length in the contextlib module — a coincidental match. No prior
# collections spec records this standalone in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra35.Counter.most_common.qualname_len:
  description: "len(collections.Counter.most_common.__qualname__) == 19 — 'Counter.most_common' is 7+1+11=19 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Counter.most_common.__qualname__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# collections.namedtuple.__qualname__.__len__() == 10 — standalone
# (extra35 namespace)
#
# collections.namedtuple is a top-level factory function; its __qualname__
# equals its __name__: 'namedtuple' (10 characters). namedtuple is the only
# function (vs class) in collections.__all__ whose name length is 10.
# No prior collections spec records this standalone in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra35.namedtuple.qualname_len:
  description: "len(collections.namedtuple.__qualname__) == 10 — 'namedtuple' is 10 chars; __qualname__ == __name__ for top-level factory"
  category: qualname_attrs
  kind: python_call_eq
  function: namedtuple.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# UserDict.update.__qualname__.__len__() == 21 — standalone
# (extra35 namespace)
#
# UserDict.update is inherited from MutableMapping (the ABC), so its
# __qualname__ is 'MutableMapping.update' (21 characters): 14 (MutableMapping)
# + 1 (.) + 6 (update) = 21. This illustrates how ABC inheritance causes
# method qualnames to carry the defining class's name rather than the
# inheriting class's name. No prior collections spec records this standalone
# in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra35.UserDict.update.qualname_len:
  description: "len(collections.UserDict.update.__qualname__) == 21 — inherited from MutableMapping: 'MutableMapping.update' is 14+1+6=21 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: UserDict.update.__qualname__.__len__
  args: []
  expected: 21
