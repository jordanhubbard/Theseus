spec: secrets_extra13
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra12.zspec.zsdl — covers __qualname__.__len__() for token_bytes/hex/urlsafe/choice/randbelow/randbits/SystemRandom."
    - "secrets_extra11.zspec.zsdl — covers __module__.__len__() for token_bytes/hex/urlsafe/choice/randbelow; __class__.__name__.__len__() for token_bytes and choice."
    - "secrets_extra10.zspec.zsdl — covers token_bytes/hex/urlsafe/choice/randbelow __name__ standalone; token_bytes(16).__class__.__name__; token_hex(8).__class__.__name__."
    - "secrets_extra4.zspec.zsdl — covers __qualname__.__eq__ for all callables; DEFAULT_ENTROPY == 32."
    - "secrets_extra3.zspec.zsdl — covers DEFAULT_ENTROPY.__class__.__name__ == 'int' via __eq__; DEFAULT_ENTROPY >= 16."
    - "secrets_extra2.zspec.zsdl — covers function __name__ table; SystemRandom __name__/__module__/__bases__."
  notes:
    - "This spec extends the secrets chain through secrets_extra12; it does NOT duplicate invariants present in any prior spec."
    - "Focus: __class__.__name__.__eq__ for secrets callables themselves (not their return values). secrets_extra11 covers __class__.__name__.__len__() for token_bytes and choice only; no prior spec covers __class__.__name__.__eq__ for any secrets callable. Also covers DEFAULT_ENTROPY.__class__.__qualname__.__eq__ (not checked by any prior spec)."
    - "secrets.token_bytes.__class__.__name__ == 'function': plain Python function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_hex.__class__.__name__ == 'function': plain Python function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe.__class__.__name__ == 'function': plain Python function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.choice.__class__.__name__ == 'method': bound method on SystemRandom instance. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbelow.__class__.__name__ == 'function': plain function alias. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbits.__class__.__name__ == 'method': bound method on SystemRandom instance. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.DEFAULT_ENTROPY.__class__.__qualname__ == 'int': qualname of the int type; equals __name__ for builtins. No prior spec checks __class__.__qualname__ for DEFAULT_ENTROPY. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# secrets callable __class__.__name__.__eq__ table
#
# No prior spec covers __class__.__name__.__eq__ for secrets callables
# themselves (as opposed to their return values).
# secrets_extra11 covers __class__.__name__.__len__() for token_bytes and
# choice only; this spec covers all six via __eq__.
# Plain functions: token_bytes, token_hex, token_urlsafe, randbelow => 'function'
# Bound methods: choice (Random), randbits (SystemRandom) => 'method'
# ---------------------------------------------------------------------------

table secrets_extra13.callable_class_names:
  description: "secrets callable __class__.__name__ values — distinguishes functions from bound methods"
  kind: python_call_eq
  category: type_metadata
  id_prefix: seccn13

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__class__.__name__.__eq__,   ["function"], true]
    - [token_hex,     token_hex.__class__.__name__.__eq__,     ["function"], true]
    - [token_urlsafe, token_urlsafe.__class__.__name__.__eq__, ["function"], true]
    - [choice,        choice.__class__.__name__.__eq__,        ["method"],   true]
    - [randbelow,     randbelow.__class__.__name__.__eq__,     ["function"], true]
    - [randbits,      randbits.__class__.__name__.__eq__,      ["method"],   true]

# ---------------------------------------------------------------------------
# DEFAULT_ENTROPY.__class__.__qualname__
#
# secrets_extra3 covers DEFAULT_ENTROPY.__class__.__name__ == 'int' via __eq__.
# No prior spec checks __class__.__qualname__ for DEFAULT_ENTROPY.
# On CPython, int.__qualname__ == 'int' == int.__name__ for builtin types.
# ---------------------------------------------------------------------------

invariant secrets_extra13.DEFAULT_ENTROPY.class_qualname:
  description: "secrets.DEFAULT_ENTROPY.__class__.__qualname__ == 'int' — builtin type qualname equals name"
  category: type_metadata
  kind: python_call_eq
  function: DEFAULT_ENTROPY.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true
