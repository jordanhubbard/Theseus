spec: theseus_plistlib_cr
version: ">=3.9"
backend: python_cleanroom(theseus_plistlib_cr)
blocks: plistlib

docs: https://docs.python.org/3/library/plistlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/plistlib.html"
    - "Apple Property List XML format"
    - "https://www.apple.com/DTDs/PropertyList-1.0.dtd"
  notes:
    - "Clean-room plistlib. Do NOT import plistlib."
    - "dumps(value, fmt=FMT_XML): serialize Python object to plist bytes (XML format)."
    - "loads(data): parse plist bytes and return Python object."
    - "plistlib_dumps_type(): dumps({'k': 'v'}) returns bytes — returns True."
    - "plistlib_roundtrip(): loads(dumps({'key': 'value'}))['key'] == 'value'."
    - "plistlib_loads_int(): loads(dumps({'n': 42}))['n'] == 42."
    - "Zero-arg invariant signatures — def plistlib_dumps_type(): return bool"
    - "XML plist format: <?xml version...><plist version='1.0'><dict>...</dict></plist>."
    - "Key-value pairs in dict: <key>k</key><string>v</string> or <integer>n</integer>."
    - "Supported types: str -> <string>, int -> <integer>, float -> <real>, bool -> <true>/<false>, bytes -> <data>, dict -> <dict>, list -> <array>."
    - "Export: dumps(value), loads(data), FMT_XML, FMT_BINARY (FMT_BINARY may raise NotImplementedError)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_plistlib_cr.dumps_type:
  description: "dumps({'k': 'v'}) returns bytes"
  category: dumps
  kind: python_call_eq
  function: plistlib_dumps_type
  args: []
  expected: true

invariant theseus_plistlib_cr.roundtrip:
  description: "loads(dumps({'key': 'value'}))['key'] == 'value'"
  category: roundtrip
  kind: python_call_eq
  function: plistlib_roundtrip
  args: []
  expected: "value"

invariant theseus_plistlib_cr.loads_int:
  description: "loads(dumps({'n': 42}))['n'] == 42"
  category: loads
  kind: python_call_eq
  function: plistlib_loads_int
  args: []
  expected: 42
