spec: re_extra418
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern.__name__ == 'Pattern', __qualname__ == 'Pattern', __module__ == 're'"
    - "re.Match.__name__ == 'Match', __qualname__ == 'Match', __module__ == 're'"
    - "Both re.Pattern.__doc__ and re.Match.__doc__ are plain str objects"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern class identity attributes
# ---------------------------------------------------------------------------

table re_extra418.pattern_class_identity:
  description: "re.Pattern class identity attributes — __name__, __qualname__, __module__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: repatternid418

  columns: [id, function, args, expected]
  rows:
    - [pattern_name,     re.Pattern.__name__.__eq__,     ["Pattern"], true]
    - [pattern_qualname, re.Pattern.__qualname__.__eq__,  ["Pattern"], true]
    - [pattern_module,   re.Pattern.__module__.__eq__,    ["re"],      true]

# ---------------------------------------------------------------------------
# re.Match class identity attributes
# ---------------------------------------------------------------------------

table re_extra418.match_class_identity:
  description: "re.Match class identity attributes — __name__, __qualname__, __module__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: rematchid418

  columns: [id, function, args, expected]
  rows:
    - [match_name,     re.Match.__name__.__eq__,     ["Match"], true]
    - [match_qualname, re.Match.__qualname__.__eq__,  ["Match"], true]
    - [match_module,   re.Match.__module__.__eq__,    ["re"],    true]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __doc__ class name
# ---------------------------------------------------------------------------

table re_extra418.class_doc_type:
  description: "re.Pattern and re.Match __doc__ attribute is a plain str; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: reclsdoc418

  columns: [id, function, args, expected]
  rows:
    - [pattern_doc_class, re.Pattern.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [match_doc_class,   re.Match.__doc__.__class__.__name__.__eq__,   ["str"], true]
