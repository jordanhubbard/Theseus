spec: pathlib_extra167
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePosixPath and pathlib.PureWindowsPath class identity attributes."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (len=13)."
    - "pathlib.PurePosixPath.__module__ == 'pathlib' (len=7)."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (len=8)."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (len=15)."
    - "pathlib.PureWindowsPath.__module__ == 'pathlib' (len=7)."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (len=8)."
    - "Both PurePosixPath and PureWindowsPath share the same first base: PurePath (len=8)."
    - "Both classes have __module__ == 'pathlib' (len=7) — the public module, same for both."
    - "PureWindowsPath.__name__ (15) is exactly 2 characters longer than PurePosixPath.__name__ (13) because 'Windows' (7 chars) > 'Posix' (5 chars) by 2 characters."
    - "Name length comparison: PurePath (8) < PurePosixPath (13) < PureWindowsPath (15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath class identity attributes
# __name__ = 'PurePosixPath' (len=13), __module__ = 'pathlib' (len=7)
# __bases__[0].__name__ = 'PurePath' (len=8)
# PurePosixPath is the pure path class for POSIX (Unix-like) filesystem semantics.
# ---------------------------------------------------------------------------

table pathlib_extra167.PurePosixPath_class_identity:
  description: "pathlib.PurePosixPath class identity: __name__='PurePosixPath' (len=13), __module__='pathlib' (len=7), __bases__[0].__name__='PurePath' (len=8); PurePosixPath is a pure (no I/O) POSIX path class"
  kind: python_call_eq
  category: identity
  id_prefix: posixpath167

  columns: [id, function, args, expected, description]
  rows:
    - [posix_name,     PurePosixPath.__name__.__eq__,                   ["PurePosixPath"],  true, "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (PurePosixPath is the pure path class for POSIX filesystem semantics — it handles Unix-style paths with forward slashes as separators and case-sensitive components; 'Pure' signals no filesystem I/O, 'Posix' signals the target OS convention, 'Path' signals it is a path type; 'PurePosixPath' has 13 characters: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13; PurePosixPath can be used on any OS including Windows to manipulate POSIX-style paths without touching the filesystem)"]
    - [posix_mod,      PurePosixPath.__module__.__eq__,                  ["pathlib"],        true, "pathlib.PurePosixPath.__module__ == 'pathlib' (PurePosixPath's module is the public 'pathlib' namespace; 'pathlib' has 7 characters: 'path' (4) + 'lib' (3) = 7; both PurePosixPath and PureWindowsPath share the same __module__ == 'pathlib' — the public module name is consistent across all pure and concrete path classes; compare with io.FileIO.__module__ == '_io' which uses a private module; pathlib classes are defined in the public 'pathlib' module without a private C-extension counterpart distinction)"]
    - [posix_base0,    "PurePosixPath.__bases__[0].__name__.__eq__",     ["PurePath"],       true, "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (PurePosixPath's first base class is PurePath — the abstract pure path base from which both PurePosixPath and PureWindowsPath inherit; 'PurePath' has 8 characters: 'Pure' (4) + 'Path' (4) = 8; PurePath defines the common interface for pure path operations (parsing, joining, suffix extraction) without any OS-specific behavior; PurePosixPath adds POSIX-specific behavior on top of PurePath, such as case-sensitive name comparison and forward-slash separator)"]
    - [posix_name_len, PurePosixPath.__name__.__len__,                   [],                13,   "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13; name length 13 is longer than the base class 'PurePath' (8) by 5 characters — the 'Posix' infix contributes 5 extra characters; PurePosixPath (13) is 2 shorter than PureWindowsPath (15) because 'Posix' (5 chars) < 'Windows' (7 chars) by 2 characters; the name follows the pattern: 'Pure' + OS-name + 'Path' where the OS-name length determines the full class name length)"]

# ---------------------------------------------------------------------------
# pathlib.PureWindowsPath class identity attributes
# __name__ = 'PureWindowsPath' (len=15), __module__ = 'pathlib' (len=7)
# __bases__[0].__name__ = 'PurePath' (len=8)
# PureWindowsPath is the pure path class for Windows filesystem semantics.
# ---------------------------------------------------------------------------

table pathlib_extra167.PureWindowsPath_class_identity:
  description: "pathlib.PureWindowsPath class identity: __name__='PureWindowsPath' (len=15), __module__='pathlib' (len=7), __bases__[0].__name__='PurePath' (len=8); PureWindowsPath is a pure (no I/O) Windows path class"
  kind: python_call_eq
  category: identity
  id_prefix: winpath167

  columns: [id, function, args, expected, description]
  rows:
    - [win_name,     PureWindowsPath.__name__.__eq__,                   ["PureWindowsPath"],  true, "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (PureWindowsPath is the pure path class for Windows filesystem semantics — it handles Windows-style paths with backslash or forward slash as separators and case-insensitive components; 'PureWindowsPath' has 15 characters: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15; PureWindowsPath can be used on any OS to manipulate Windows-style paths without filesystem I/O; it is 2 characters longer than PurePosixPath (13) because 'Windows' (7) is 2 longer than 'Posix' (5))"]
    - [win_mod,      PureWindowsPath.__module__.__eq__,                  ["pathlib"],           true, "pathlib.PureWindowsPath.__module__ == 'pathlib' (PureWindowsPath's module is the public 'pathlib' namespace; 'pathlib' has 7 characters; PureWindowsPath and PurePosixPath both have __module__ == 'pathlib' — the module attribute is identical for both pure path subclasses; this consistency reflects that all pathlib path classes are defined in and exported from the same public 'pathlib' module; the shared 'pathlib' module (7 chars) is longer than re.__module__ 're' (2 chars) or io.__module__ 'io' (2 chars))"]
    - [win_base0,    "PureWindowsPath.__bases__[0].__name__.__eq__",     ["PurePath"],          true, "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (PureWindowsPath's first base class is PurePath — the same base as PurePosixPath; both PurePosixPath and PureWindowsPath inherit from PurePath, which provides the common pure path interface; 'PurePath' has 8 characters: 'Pure' (4) + 'Path' (4) = 8; this shared base class 'PurePath' is the common ancestor for all pure path classes in pathlib; the base class name 'PurePath' (8 chars) is shorter than both PurePosixPath (13) and PureWindowsPath (15))"]
    - [win_name_len, PureWindowsPath.__name__.__len__,                   [],                   15,   "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15; the longest class name in this spec; PureWindowsPath (15) > PurePosixPath (13) > PurePath (8); the 2-character difference between PureWindowsPath and PurePosixPath comes from 'Windows' (7 chars) vs 'Posix' (5 chars); 'PureWindowsPath' (15) matches 'Path.write_text' qualname length (15) established in pathlib_extra166 — a coincidental equality of a class name and a method qualname)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra167.PurePosixPath_name_len_13:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 — 'PurePosixPath' has 13 characters: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13; the name length 13 is determined by the 'Posix' OS infix (5 chars); the name pattern is 'Pure' + OS + 'Path' where OS is the differentiating component; PurePosixPath (13) < PureWindowsPath (15) because 'Posix' (5) < 'Windows' (7) by 2; both pure path classes share the 'Pure' (4) prefix and 'Path' (4) suffix; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__len__
  args: []
  expected: 13

invariant pathlib_extra167.PureWindowsPath_name_len_15:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 — 'PureWindowsPath' has 15 characters: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15; PureWindowsPath is the longest class name in this spec; PureWindowsPath (15) > PurePosixPath (13) > PurePath (8); 'Windows' (7 chars) is the OS infix that adds the extra length; PureWindowsPath can be constructed on any OS to represent Windows-style paths; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PureWindowsPath.__name__.__len__
  args: []
  expected: 15

invariant pathlib_extra167.both_pure_paths_share_PurePath_base:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath and PureWindowsPath both have 'PurePath' as their first base class name (len=8); this shared base 'PurePath' provides the common pure path interface implemented differently by POSIX (case-sensitive, forward-slash) and Windows (case-insensitive, backslash) variants; 'PurePath' (8 chars) is shorter than both subclasses (PurePosixPath=13, PureWindowsPath=15); the base class is the abstract root and the subclasses add OS-specific behavior; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra167.both_pure_paths_module_is_pathlib:
  description: "pathlib.PureWindowsPath.__module__ == 'pathlib' — PureWindowsPath's __module__ is 'pathlib' (7 chars), the same public module as PurePosixPath; all pathlib path classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath) share __module__ == 'pathlib'; this uniform module attribution contrasts with the io module where some classes like FileIO have __module__ == '_io' (the private C extension) while others like RawIOBase have __module__ == 'io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PureWindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

