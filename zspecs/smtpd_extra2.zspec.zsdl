spec: smtpd_extra2
version: ">=3.9,<3.12"
backend: python_module(smtpd)

docs: https://docs.python.org/3/library/smtpd.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/smtpd.html — Python smtpd documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/smtpd.py"
  notes:
    - "This spec extends smtpd.zspec.zsdl and prior extras."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "smtpd raises no module-specific exception class; network errors propagate from asyncore."
  stderr: "null"
  stickiness: "N/A — class-level structural checks only."
  codes: {}

# ---------------------------------------------------------------------------
# SMTPServer class — qualname
# ---------------------------------------------------------------------------

invariant smtpd_extra2.SMTPServer_qualname:
  description: "SMTPServer.__qualname__ == 'SMTPServer'"
  category: classnames
  kind: python_call_eq
  function: SMTPServer.__qualname__.__eq__
  args: ["SMTPServer"]
  expected: true

# ---------------------------------------------------------------------------
# SMTPChannel class — qualname
# ---------------------------------------------------------------------------

invariant smtpd_extra2.SMTPChannel_qualname:
  description: "SMTPChannel.__qualname__ == 'SMTPChannel'"
  category: classnames
  kind: python_call_eq
  function: SMTPChannel.__qualname__.__eq__
  args: ["SMTPChannel"]
  expected: true

# ---------------------------------------------------------------------------
# DebuggingServer class — module and qualname
# ---------------------------------------------------------------------------

invariant smtpd_extra2.DebuggingServer_module:
  description: "DebuggingServer.__module__ == 'smtpd'"
  category: classnames
  kind: python_call_eq
  function: DebuggingServer.__module__.__eq__
  args: ["smtpd"]
  expected: true

invariant smtpd_extra2.DebuggingServer_qualname:
  description: "DebuggingServer.__qualname__ == 'DebuggingServer'"
  category: classnames
  kind: python_call_eq
  function: DebuggingServer.__qualname__.__eq__
  args: ["DebuggingServer"]
  expected: true

# ---------------------------------------------------------------------------
# PureProxy class — module and qualname
# ---------------------------------------------------------------------------

invariant smtpd_extra2.PureProxy_module:
  description: "PureProxy.__module__ == 'smtpd'"
  category: classnames
  kind: python_call_eq
  function: PureProxy.__module__.__eq__
  args: ["smtpd"]
  expected: true

invariant smtpd_extra2.PureProxy_qualname:
  description: "PureProxy.__qualname__ == 'PureProxy'"
  category: classnames
  kind: python_call_eq
  function: PureProxy.__qualname__.__eq__
  args: ["PureProxy"]
  expected: true
