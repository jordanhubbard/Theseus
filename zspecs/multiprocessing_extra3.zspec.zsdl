spec: multiprocessing_extra3
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Extends multiprocessing.zspec.zsdl, multiprocessing_extra.zspec.zsdl, multiprocessing_extra2.zspec.zsdl."
    - "multiprocessing.zspec.zsdl covers: class/factory __name__ (Process/Pool/Queue/Lock/RLock/Semaphore/Event/Value/Array/Manager), exception __name__ (ProcessError/AuthenticationError/BufferTooShort/TimeoutError), function __name__ (cpu_count/current_process/active_children/get_start_method/get_context/parent_process), cpu_count>=1, current_process behavior, active_children, get_start_method."
    - "multiprocessing_extra.zspec.zsdl covers: Process.__module__ == 'multiprocessing.process', Process.__name__, Process.__bases__[0], Queue.__name__, Pipe.__name__, Pool/Lock/Event/Semaphore/Value/Array/Manager __name__ table, AuthenticationError.__name__/__bases__[0], Process/__pool metaclass."
    - "multiprocessing_extra2.zspec.zsdl covers: Pool/Lock/Event/Semaphore/Value/Array/Manager/Pipe/Queue __module__ == 'multiprocessing.context' table; Process.__module__ == 'multiprocessing.context'; BoundedSemaphore/Barrier/Condition/RLock __name__ and __module__ tables."
    - "This spec adds: Process.__module__ == 'multiprocessing.process' standalone; Pool.__module__ == 'multiprocessing.pool' standalone (note: Pool class itself is in multiprocessing.pool, but the top-level binding's __module__ is 'multiprocessing.context' per extra2; here we verify the underlying class via Pool.__class__.__module__); Queue().__class__.__name__ == 'Queue'; Pipe.__module__ standalone; Lock.__module__ standalone; Event.__module__ standalone; Value.__module__ standalone; Array.__module__ standalone; cpu_count.__name__ standalone; AuthenticationError.__name__ standalone; ProcessError.__name__ standalone; BufferTooShort.__name__ standalone."
    - "multiprocessing.Queue at the top level is a bound method factory; Queue().__class__.__name__ == 'Queue' verifies the returned instance's class name."
    - "multiprocessing.cpu_count.__name__ == 'cpu_count' — confirmed on CPython 3.12."
    - "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError' — confirmed on CPython 3.12."
    - "multiprocessing.ProcessError.__name__ == 'ProcessError' — confirmed on CPython 3.12."
    - "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort' — confirmed on CPython 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Process — __module__ standalone (multiprocessing.process submodule)
#
# multiprocessing_extra covers Process.__module__ == 'multiprocessing.process'.
# multiprocessing_extra2 covers Process.__module__ == 'multiprocessing.context'.
# These two specs exposed an inconsistency depending on the Python version.
# This spec adds a cross-check: Process.__name__ is always 'Process'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.Process.name_standalone:
  description: "multiprocessing.Process.__name__ == 'Process'"
  category: process
  kind: python_call_eq
  function: Process.__name__.__eq__
  args: ["Process"]
  expected: true

# ---------------------------------------------------------------------------
# Queue — instance class name
#
# multiprocessing.Queue at the top level is a bound method factory returning
# a Queue instance. We verify the returned object's class name is 'Queue'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.Queue.instance_class:
  description: "multiprocessing.Queue().__class__.__name__ == 'Queue' — factory returns a Queue instance"
  category: factories
  kind: python_call_eq
  function: Queue
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Queue"]
  expected: true

# ---------------------------------------------------------------------------
# Pipe — __module__ standalone
#
# multiprocessing_extra2 covers Pipe.__module__ == 'multiprocessing.context' in a
# table. This spec adds it as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.Pipe.module:
  description: "multiprocessing.Pipe.__module__ == 'multiprocessing.context'"
  category: factory_modules
  kind: python_call_eq
  function: Pipe.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

# ---------------------------------------------------------------------------
# Lock, Event, Value, Array — __module__ standalone invariants
#
# multiprocessing_extra2 covers these in a table. This spec adds them as
# standalone named invariants for individual traceability.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.Lock.module:
  description: "multiprocessing.Lock.__module__ == 'multiprocessing.context'"
  category: factory_modules
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra3.Event.module:
  description: "multiprocessing.Event.__module__ == 'multiprocessing.context'"
  category: factory_modules
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra3.Value.module:
  description: "multiprocessing.Value.__module__ == 'multiprocessing.context'"
  category: factory_modules
  kind: python_call_eq
  function: Value.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra3.Array.module:
  description: "multiprocessing.Array.__module__ == 'multiprocessing.context'"
  category: factory_modules
  kind: python_call_eq
  function: Array.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

# ---------------------------------------------------------------------------
# cpu_count — __name__ standalone invariant
#
# multiprocessing.zspec.zsdl covers cpu_count.__name__ in a table.
# This spec adds it as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.cpu_count.name:
  description: "multiprocessing.cpu_count.__name__ == 'cpu_count'"
  category: function_names
  kind: python_call_eq
  function: cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

# ---------------------------------------------------------------------------
# AuthenticationError — __name__ standalone invariant
#
# multiprocessing.zspec.zsdl and multiprocessing_extra both cover this.
# This spec adds it as a standalone invariant confirming the exception name.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.AuthenticationError.name:
  description: "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError'"
  category: exception_names
  kind: python_call_eq
  function: AuthenticationError.__name__.__eq__
  args: ["AuthenticationError"]
  expected: true

# ---------------------------------------------------------------------------
# ProcessError — __name__ standalone invariant
#
# multiprocessing.zspec.zsdl covers ProcessError.__name__ in a table.
# This spec adds it as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.ProcessError.name:
  description: "multiprocessing.ProcessError.__name__ == 'ProcessError'"
  category: exception_names
  kind: python_call_eq
  function: ProcessError.__name__.__eq__
  args: ["ProcessError"]
  expected: true

# ---------------------------------------------------------------------------
# BufferTooShort — __name__ standalone invariant
#
# multiprocessing.zspec.zsdl covers BufferTooShort.__name__ in a table.
# This spec adds it as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.BufferTooShort.name:
  description: "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'"
  category: exception_names
  kind: python_call_eq
  function: BufferTooShort.__name__.__eq__
  args: ["BufferTooShort"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — ProcessError, AuthenticationError, BufferTooShort
#
# ProcessError is the root of the multiprocessing exception hierarchy.
# AuthenticationError and BufferTooShort are direct ProcessError subclasses.
# multiprocessing_extra confirms AuthenticationError.__bases__[0].__name__==
# 'ProcessError'. This spec adds ProcessError and BufferTooShort hierarchy.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.ProcessError.base:
  description: "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: ProcessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant multiprocessing_extra3.BufferTooShort.base:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: BufferTooShort.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ProcessError"

# ---------------------------------------------------------------------------
# cpu_count() — return type is int
#
# cpu_count() returns a platform-dependent integer. This spec verifies the
# return type name is 'int', complementing the >= 1 check in the base spec.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra3.cpu_count.returns_int:
  description: "multiprocessing.cpu_count().__class__.__name__ == 'int'"
  category: cpu_count
  kind: python_call_eq
  function: cpu_count
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true
