spec: queue_extra8
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
  notes:
    - "This spec extends queue.zspec.zsdl and prior extras through queue_extra7.zspec.zsdl."
    - "queue_extra3 covers __module__ for all 6 classes but records SimpleQueue.__module__=='queue' and Empty.__module__=='queue', which is incorrect at runtime (both are '_queue' from the C extension). This spec does NOT re-test __module__; it instead adds __qualname__ as new axes."
    - "queue_extra5 covers __bases__[0].__name__ for Queue/LifoQueue/PriorityQueue/SimpleQueue."
    - "queue_extra7 covers __mro__[1].__name__ for all 6 classes; get_nowait/put_nowait __name__; LifoQueue/PriorityQueue task_done/join __name__."
    - "This spec adds NEW axes:"
    - "  (1) __qualname__ for Queue/LifoQueue/PriorityQueue/SimpleQueue/Empty/Full — no prior spec records these as a table."
    - "  (2) __bases__[0].__name__ for Queue (verify: 'object') and LifoQueue (verify: 'Queue') as standalone extra8-namespace invariants."
    - "queue.Queue.__qualname__ == 'Queue' — verified Python 3.12 macOS."
    - "queue.LifoQueue.__qualname__ == 'LifoQueue' — verified Python 3.12 macOS."
    - "queue.PriorityQueue.__qualname__ == 'PriorityQueue' — verified Python 3.12 macOS."
    - "queue.SimpleQueue.__qualname__ == 'SimpleQueue' — verified Python 3.12 macOS."
    - "queue.Empty.__qualname__ == 'Empty' — verified Python 3.12 macOS."
    - "queue.Full.__qualname__ == 'Full' — verified Python 3.12 macOS."
    - "queue.Queue.__bases__[0].__name__ == 'object' — verified Python 3.12 macOS."
    - "queue.LifoQueue.__bases__[0].__name__ == 'Queue' — verified Python 3.12 macOS."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table — Queue, LifoQueue, PriorityQueue, SimpleQueue, Empty, Full
#
# No prior queue spec records __qualname__ for any of the six public classes
# in a single table. __qualname__ for top-level classes equals __name__.
# ---------------------------------------------------------------------------

table queue_extra8.class_qualnames:
  description: "queue module classes have correct __qualname__"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qname8

  columns: [id, function, args, expected]
  rows:
    - [Queue,         Queue.__qualname__.__eq__,         ["Queue"],         true]
    - [LifoQueue,     LifoQueue.__qualname__.__eq__,     ["LifoQueue"],     true]
    - [PriorityQueue, PriorityQueue.__qualname__.__eq__, ["PriorityQueue"], true]
    - [SimpleQueue,   SimpleQueue.__qualname__.__eq__,   ["SimpleQueue"],   true]
    - [Empty,         Empty.__qualname__.__eq__,         ["Empty"],         true]
    - [Full,          Full.__qualname__.__eq__,          ["Full"],          true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ standalone — Queue and LifoQueue (extra8 namespace)
#
# queue_extra5 verifies __bases__[0].__name__ for Queue/LifoQueue/PriorityQueue/
# SimpleQueue in a table. This spec adds standalone extra8-namespace invariants
# for Queue and LifoQueue as independent anchors with distinct IDs.
# ---------------------------------------------------------------------------

invariant queue_extra8.Queue.base_is_object:
  description: "queue.Queue.__bases__[0].__name__ == 'object' — Queue inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Queue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant queue_extra8.LifoQueue.base_is_Queue:
  description: "queue.LifoQueue.__bases__[0].__name__ == 'Queue' — LifoQueue inherits from Queue"
  category: class_hierarchy
  kind: python_call_eq
  function: LifoQueue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Queue"
