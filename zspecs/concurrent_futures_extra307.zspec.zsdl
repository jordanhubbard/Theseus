spec: concurrent_futures_extra307
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "concurrent.futures.Future is a pure-Python class defined in concurrent.futures._base."
    - "A freshly constructed Future() is in pending state: done()==False, running()==False, cancelled()==False."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object' — Future inherits directly from object."
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base' — defined in the _base submodule."
    - "Future instances inherit __module__ from the class; it is not set on the instance dict."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — class-level identity
#
# The Future class itself is defined in concurrent.futures._base.
# It inherits directly from object.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra307.Future.class_module:
  description: "concurrent.futures.Future.__module__ == 'concurrent.futures._base'"
  category: future_class_identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra307.Future.base_is_object:
  description: "concurrent.futures.Future.__bases__[0].__name__ == 'object' — Future inherits from object"
  category: future_class_identity
  kind: python_call_eq
  function: Future.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# concurrent.futures.Future() — instance class name
#
# A fresh Future() instance has __class__.__name__ == 'Future'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra307.Future.instance_class_name:
  description: "concurrent.futures.Future().__class__.__name__ == 'Future'"
  category: future_instance_identity
  kind: python_call_eq
  function: Future
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Future"]
  expected: true

invariant concurrent_futures_extra307.Future.instance_module:
  description: "concurrent.futures.Future().__class__.__module__ == 'concurrent.futures._base'"
  category: future_instance_identity
  kind: python_call_eq
  function: Future
  args: []
  method: __class__
  method_chain: __module__.__eq__
  method_chain_args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures.Future() — pending state checks
#
# A freshly constructed Future has not been scheduled, completed, or cancelled.
# All three state predicate methods return False.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra307.Future.done_is_false:
  description: "concurrent.futures.Future().done() == False — fresh Future is not done"
  category: future_state
  kind: python_call_eq
  function: Future
  args: []
  method: done
  expected: false

invariant concurrent_futures_extra307.Future.running_is_false:
  description: "concurrent.futures.Future().running() == False — fresh Future is not running"
  category: future_state
  kind: python_call_eq
  function: Future
  args: []
  method: running
  expected: false

invariant concurrent_futures_extra307.Future.cancelled_is_false:
  description: "concurrent.futures.Future().cancelled() == False — fresh Future has not been cancelled"
  category: future_state
  kind: python_call_eq
  function: Future
  args: []
  method: cancelled
  expected: false
