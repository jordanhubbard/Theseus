spec: pickle_extra26
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
    - "pickle_extra25.zspec.zsdl — covers __all__ len (82), HIGHEST/DEFAULT_PROTOCOL (both 5 and class name len 3), PickleBuffer/__dict__/__reduce__/__bases__[0] introspection, PickleError.__reduce__ qualname (24), Pickler/Unpickler/PickleError/PickleBuffer __dict__.__class__.__name__.__len__()==12."
    - "pickle_extra24.zspec.zsdl — covers __mro__.__len__() for Pickler/Unpickler/PickleError/PicklingError/UnpicklingError; __bases__[0].__name__.__len__() for exception classes; Pickler.clear_memo/Unpickler.find_class __qualname__.__len__(); DEFAULT_PROTOCOL.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends pickle_extra25.zspec.zsdl."
    - "Prior specs covered: Pickler/Unpickler/PickleError/PicklingError/UnpicklingError __name__/__module__/__qualname__/__bases__[0].__name__, class MRO depths, Pickler.clear_memo (18) and Unpickler.find_class (20) qualname lengths, __all__ (82), HIGHEST_PROTOCOL (5), DEFAULT_PROTOCOL (5), PickleBuffer introspection."
    - "This spec covers NEW angles: Pickler.__qualname__.__len__()==7; Unpickler.__qualname__.__len__()==9; pickle.dumps/loads qualname lens (both 5); pickle.dump/load qualname lens (both 4); pickle.__name__.__len__()==6; PickleError.__bases__[0].__name__.__len__()==9 ('Exception'); PicklingError.__dict__.__class__.__name__.__len__()==12; UnpicklingError.__dict__.__class__.__name__.__len__()==12; Pickler.persistent_id (21), Pickler.dump (12), Pickler.__init__ (16), Pickler.__new__ (15) qualname lengths; Unpickler.persistent_load (25), Unpickler.load (14), Unpickler.__init__ (18) qualname lengths."
    - "Pickler.__qualname__ == 'Pickler' (len 7); Unpickler.__qualname__ == 'Unpickler' (len 9)."
    - "pickle.dump.__qualname__ == 'dump' (len 4); pickle.load.__qualname__ == 'load' (len 4); pickle.dumps.__qualname__ == 'dumps' (len 5); pickle.loads.__qualname__ == 'loads' (len 5) — all module-level functions have flat qualnames equal to their names."
    - "pickle.__name__ == 'pickle' (len 6)."
    - "PickleError.__bases__[0].__name__ == 'Exception' (len 9) — recorded as standalone; PicklingError/UnpicklingError.__bases__[0].__name__ == 'PickleError' (len 11) — already covered in extra24."
    - "Unpickler.persistent_load (25) is the longest Unpickler method qualname in the series."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __qualname__.__len__() for dump/load/dumps/loads
#
# These four are the primary public API entry points. They are pure-Python
# thin wrappers; each has a flat qualname equal to its __name__:
#   dump   -> 'dump'   (4)
#   load   -> 'load'   (4)
#   dumps  -> 'dumps'  (5)
#   loads  -> 'loads'  (5)
# No prior pickle spec records any of these qualname lengths.
# ---------------------------------------------------------------------------

table pickle_extra26.toplevel_function_qualname_lens:
  description: "__qualname__.__len__() for pickle.dump (4), load (4), dumps (5), loads (5)"
  kind: python_call_eq
  category: function_identity
  id_prefix: pfa26_fn

  columns: [id, function, args, expected]
  rows:
    - [dump,  dump.__qualname__.__len__,  [], 4]
    - [load,  load.__qualname__.__len__,  [], 4]
    - [dumps, dumps.__qualname__.__len__, [], 5]
    - [loads, loads.__qualname__.__len__, [], 5]

# ---------------------------------------------------------------------------
# Pickler method __qualname__.__len__() — previously uncovered methods
#
# clear_memo was covered in extra24. The following Pickler methods are new:
#   persistent_id -> 'Pickler.persistent_id' (21) — longest Pickler method
#   __init__      -> 'Pickler.__init__'       (16)
#   __new__       -> 'Pickler.__new__'        (15)
#   dump          -> 'Pickler.dump'           (12)
# ---------------------------------------------------------------------------

table pickle_extra26.Pickler_method_qualname_lens:
  description: "__qualname__.__len__() for Pickler.persistent_id (21), __init__ (16), __new__ (15), dump (12)"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: pfa26_pkl

  columns: [id, function, args, expected]
  rows:
    - [persistent_id, Pickler.persistent_id.__qualname__.__len__, [], 21]
    - [init,          Pickler.__init__.__qualname__.__len__,       [], 16]
    - [new,           Pickler.__new__.__qualname__.__len__,        [], 15]
    - [dump,          Pickler.dump.__qualname__.__len__,           [], 12]

# ---------------------------------------------------------------------------
# Unpickler method __qualname__.__len__() — previously uncovered methods
#
# find_class was covered in extra24. The following Unpickler methods are new:
#   persistent_load -> 'Unpickler.persistent_load' (25) — longest Unpickler method
#   __init__        -> 'Unpickler.__init__'         (18)
#   load            -> 'Unpickler.load'             (14)
# ---------------------------------------------------------------------------

table pickle_extra26.Unpickler_method_qualname_lens:
  description: "__qualname__.__len__() for Unpickler.persistent_load (25), __init__ (18), load (14)"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: pfa26_upkl

  columns: [id, function, args, expected]
  rows:
    - [persistent_load, Unpickler.persistent_load.__qualname__.__len__, [], 25]
    - [init,            Unpickler.__init__.__qualname__.__len__,         [], 18]
    - [load,            Unpickler.load.__qualname__.__len__,             [], 14]

# ---------------------------------------------------------------------------
# PicklingError and UnpicklingError __dict__.__class__.__name__.__len__()
#
# Pickler/Unpickler/PickleError/PickleBuffer were covered in extra25.
# PicklingError and UnpicklingError were not. Both have mappingproxy as their
# __dict__ type (len 12).
# ---------------------------------------------------------------------------

invariant pickle_extra26.PicklingError.dict_class_name_len:
  description: "pickle.PicklingError.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is 'mappingproxy'"
  category: class_introspection
  kind: python_call_eq
  function: PicklingError.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant pickle_extra26.UnpicklingError.dict_class_name_len:
  description: "pickle.UnpicklingError.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is 'mappingproxy'"
  category: class_introspection
  kind: python_call_eq
  function: UnpicklingError.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# pickle.__name__.__len__() == 6 — standalone (extra26 namespace)
#
# The pickle module's __name__ attribute is 'pickle' (6 characters). This is
# the fully-qualified module name used in reprs and error messages. No prior
# pickle spec records this value.
# ---------------------------------------------------------------------------

invariant pickle_extra26.module_name_len:
  description: "pickle.__name__.__len__() == 6 — module name 'pickle' has 6 characters"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Pickler.__qualname__.__len__() == 7 — standalone (extra26 namespace)
#
# Pickler's class qualname is 'Pickler' (7 characters). No prior pickle spec
# records this class-level qualname length.
# ---------------------------------------------------------------------------

invariant pickle_extra26.Pickler.qualname_len:
  description: "pickle.Pickler.__qualname__.__len__() == 7 — class qualname 'Pickler' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Pickler.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Unpickler.__qualname__.__len__() == 9 — standalone (extra26 namespace)
#
# Unpickler's class qualname is 'Unpickler' (9 characters). No prior pickle
# spec records this class-level qualname length.
# ---------------------------------------------------------------------------

invariant pickle_extra26.Unpickler.qualname_len:
  description: "pickle.Unpickler.__qualname__.__len__() == 9 — class qualname 'Unpickler' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: Unpickler.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# PickleError.__bases__[0].__name__.__len__() == 9 — standalone
# (extra26 namespace)
#
# PickleError inherits directly from Exception. 'Exception' has 9 characters.
# PicklingError and UnpicklingError both inherit from PickleError (len 11) —
# already covered in extra24. This records the PickleError→Exception link.
# ---------------------------------------------------------------------------

invariant pickle_extra26.PickleError.base_name_len:
  description: "pickle.PickleError.__bases__[0].__name__.__len__() == 9 — base class is 'Exception' (9 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PickleError.__bases__[0].__name__.__len__"
  args: []
  expected: 9
