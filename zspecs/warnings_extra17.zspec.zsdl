spec: warnings_extra17
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra16.zspec.zsdl."
    - "warnings_extra16 covers: WarningMessage/catch_warnings MRO lengths; catch_warnings __bases__[0].__name__; __mro__[-1].__name__ == 'object' for WarningMessage/catch_warnings/deprecated."
    - "warnings_extra13 covers: filterwarnings/simplefilter/resetwarnings/showwarning __class__.__name__ == 'function'."
    - "warnings_extra12 covers: WarningMessage/catch_warnings __class__.__name__ == 'type'."
    - "NOT yet covered in any prior spec: warnings.__name__ == 'warnings' as a module identity invariant."
    - "NOT yet covered in any prior spec: warnings.__package__ == '' as a module identity invariant."
    - "NOT yet covered in any prior spec: WarningMessage.__mro__[0].__name__ == 'WarningMessage' by index as a standalone invariant."
    - "NOT yet covered in any prior spec: WarningMessage.__mro__[1].__name__ == 'object' by index as a standalone invariant."
    - "NOT yet covered in any prior spec: catch_warnings.__mro__[0].__name__ == 'catch_warnings' by index as a standalone invariant."
    - "NOT yet covered in any prior spec: catch_warnings.__mro__[1].__name__ == 'object' by index as a standalone invariant."
    - "NOT yet covered in any prior spec: deprecated.__mro__[0].__name__ == 'deprecated' by index as a standalone invariant."
    - "NOT yet covered in any prior spec: deprecated.__mro__[1].__name__ == 'object' by index as a standalone invariant."
    - "warnings is a top-level stdlib module; its __package__ is the empty string."
    - "WarningMessage, catch_warnings, and deprecated each have MRO of length 2: [class, object]. The [-1] form is covered in extra16; this spec covers explicit [0] and [1] index forms."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings module identity — __name__ and __package__
#
# No prior warnings spec records the module-level __name__ or __package__
# attributes as invariants. warnings is a top-level stdlib module;
# its __package__ is the empty string.
# ---------------------------------------------------------------------------

invariant warnings_extra17.module.name:
  description: "warnings.__name__ == 'warnings' — module self-identifies by its own name"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["warnings"]
  expected: true

invariant warnings_extra17.module.package:
  description: "warnings.__package__ == '' — top-level module has empty package string"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# WarningMessage MRO entries by explicit index
#
# warnings_extra16 records WarningMessage.__mro__[-1].__name__ == 'object'
# and __mro__.__len__() == 2. No prior spec records the MRO entries by
# explicit non-negative index. WarningMessage MRO is [WarningMessage, object];
# __mro__[0].__name__ == 'WarningMessage', __mro__[1].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant warnings_extra17.WarningMessage.mro_index0:
  description: "warnings.WarningMessage.__mro__[0].__name__ == 'WarningMessage' — self at MRO[0]"
  category: class_hierarchy
  kind: python_call_eq
  function: "WarningMessage.__mro__[0].__name__.__eq__"
  args: ["WarningMessage"]
  expected: true

invariant warnings_extra17.WarningMessage.mro_index1:
  description: "warnings.WarningMessage.__mro__[1].__name__ == 'object' — direct base at MRO[1]"
  category: class_hierarchy
  kind: python_call_eq
  function: "WarningMessage.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# catch_warnings MRO entries by explicit index
#
# warnings_extra16 records catch_warnings __mro__[-1].__name__ and __mro__.__len__() == 2.
# No prior spec records MRO entries by explicit non-negative index for catch_warnings.
# catch_warnings MRO is [catch_warnings, object].
# ---------------------------------------------------------------------------

invariant warnings_extra17.catch_warnings.mro_index0:
  description: "warnings.catch_warnings.__mro__[0].__name__ == 'catch_warnings' — self at MRO[0]"
  category: class_hierarchy
  kind: python_call_eq
  function: "catch_warnings.__mro__[0].__name__.__eq__"
  args: ["catch_warnings"]
  expected: true

invariant warnings_extra17.catch_warnings.mro_index1:
  description: "warnings.catch_warnings.__mro__[1].__name__ == 'object' — direct base at MRO[1]"
  category: class_hierarchy
  kind: python_call_eq
  function: "catch_warnings.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# deprecated MRO entries by explicit index
#
# warnings_extra16 records deprecated.__mro__[-1].__name__ == 'object'.
# warnings_extra12 records deprecated __name__/__qualname__/__module__/
# __class__.__name__/__bases__[0].__name__ and __mro__.__len__() == 2.
# No prior spec records deprecated MRO entries by explicit non-negative index.
# deprecated MRO is [deprecated, object].
# ---------------------------------------------------------------------------

invariant warnings_extra17.deprecated.mro_index0:
  description: "warnings.deprecated.__mro__[0].__name__ == 'deprecated' — self at MRO[0]"
  category: class_hierarchy
  kind: python_call_eq
  function: "deprecated.__mro__[0].__name__.__eq__"
  args: ["deprecated"]
  expected: true

invariant warnings_extra17.deprecated.mro_index1:
  description: "warnings.deprecated.__mro__[1].__name__ == 'object' — direct base at MRO[1]"
  category: class_hierarchy
  kind: python_call_eq
  function: "deprecated.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# MRO index table — WarningMessage, catch_warnings, deprecated
#
# Consolidates the MRO[0] and MRO[1] checks for all three warnings classes
# in a single table. All three have MRO length 2; MRO[0] is the class itself
# and MRO[1] is object.
# ---------------------------------------------------------------------------

table warnings_extra17.class_mro_index_names:
  description: "MRO[0] (self) and MRO[1] (object) for WarningMessage, catch_warnings, deprecated"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected]
  rows:
    - [WarningMessage_0,  "WarningMessage.__mro__[0].__name__.__eq__",  ["WarningMessage"],   true]
    - [WarningMessage_1,  "WarningMessage.__mro__[1].__name__.__eq__",  ["object"],           true]
    - [catch_warnings_0,  "catch_warnings.__mro__[0].__name__.__eq__",  ["catch_warnings"],   true]
    - [catch_warnings_1,  "catch_warnings.__mro__[1].__name__.__eq__",  ["object"],           true]
    - [deprecated_0,      "deprecated.__mro__[0].__name__.__eq__",      ["deprecated"],       true]
    - [deprecated_1,      "deprecated.__mro__[1].__name__.__eq__",      ["object"],           true]
