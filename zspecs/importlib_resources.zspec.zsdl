spec: importlib_resources
version: ">=3.9"
backend: python_module(importlib.resources)

docs: https://docs.python.org/3/library/importlib.resources.html

provenance:
  derived_from:
    - "Python 3 importlib.resources documentation — https://docs.python.org/3/library/importlib.resources.html"
    - "PEP 302 — New Import Hooks"
    - "PEP 451 — A ModuleSpec Type for the Import System"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/resources/__init__.py"
    - "CPython source: Lib/importlib/resources/_common.py"
    - "CPython source: Lib/importlib/resources/_adapters.py"
  notes:
    - "importlib.resources.files() was added in Python 3.9 and is the preferred modern API."
    - "importlib.resources.as_file() was added in Python 3.9."
    - "The legacy functions (open_binary, read_binary, open_text, read_text, path, contents) are present in Python 3.9–3.12 but deprecated in 3.11 and may be removed in a future release. This spec covers only the stable 3.9+ surface."
    - "files() is a function; as_file() is also a function (context manager wrapper)."
    - "files.__module__ may be 'importlib.resources' or 'importlib.resources._common' depending on Python version; only the public module is checked here."
    - "open_binary, read_binary, open_text, read_text, path, contents are present as module attributes in 3.9-3.12."
    - "All __name__ checks access the function attribute directly (no call is performed)."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# function names — stable 3.9+ API
# ---------------------------------------------------------------------------

invariant importlib_resources.function_names.files:
  description: "importlib.resources.files.__name__ == 'files'"
  category: functions
  kind: python_call_eq
  function: files.__name__.__eq__
  args: ["files"]
  expected: true

invariant importlib_resources.function_names.as_file:
  description: "importlib.resources.as_file.__name__ == 'as_file'"
  category: functions
  kind: python_call_eq
  function: as_file.__name__.__eq__
  args: ["as_file"]
  expected: true

# ---------------------------------------------------------------------------
# function names — legacy 3.9+ API (present but deprecated in 3.11+)
# ---------------------------------------------------------------------------

invariant importlib_resources.function_names.open_binary:
  description: "importlib.resources.open_binary.__name__ == 'open_binary'"
  category: functions
  kind: python_call_eq
  function: open_binary.__name__.__eq__
  args: ["open_binary"]
  expected: true

invariant importlib_resources.function_names.read_binary:
  description: "importlib.resources.read_binary.__name__ == 'read_binary'"
  category: functions
  kind: python_call_eq
  function: read_binary.__name__.__eq__
  args: ["read_binary"]
  expected: true

invariant importlib_resources.function_names.open_text:
  description: "importlib.resources.open_text.__name__ == 'open_text'"
  category: functions
  kind: python_call_eq
  function: open_text.__name__.__eq__
  args: ["open_text"]
  expected: true

invariant importlib_resources.function_names.read_text:
  description: "importlib.resources.read_text.__name__ == 'read_text'"
  category: functions
  kind: python_call_eq
  function: read_text.__name__.__eq__
  args: ["read_text"]
  expected: true

invariant importlib_resources.function_names.path:
  description: "importlib.resources.path.__name__ == 'path'"
  category: functions
  kind: python_call_eq
  function: path.__name__.__eq__
  args: ["path"]
  expected: true

invariant importlib_resources.function_names.contents:
  description: "importlib.resources.contents.__name__ == 'contents'"
  category: functions
  kind: python_call_eq
  function: contents.__name__.__eq__
  args: ["contents"]
  expected: true

# ---------------------------------------------------------------------------
# callable types — files and as_file are functions
# ---------------------------------------------------------------------------

invariant importlib_resources.types.files_is_function:
  description: "files.__class__.__name__ == 'function' — importlib.resources.files is a plain function"
  category: types
  kind: python_call_eq
  function: files.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant importlib_resources.types.as_file_is_function:
  description: "as_file.__class__.__name__ == 'function' — importlib.resources.as_file is a plain function"
  category: types
  kind: python_call_eq
  function: as_file.__class__.__name__.__eq__
  args: ["function"]
  expected: true

