spec: itertools_extra271
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "All itertools C types inherit directly from object — __mro__ has exactly 2 entries: (type, object)."
    - "Every checked itertools type has len(__mro__) == 2 and __mro__[1].__name__ == 'object'."
    - "Types checked: chain, count, cycle, repeat, product, combinations, permutations, accumulate, compress, filterfalse, groupby, islice."
    - "The __mro__ tuple itself contains '[' in access expressions; any such access uses __getitem__ in dotted form."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools C type __mro__ lengths — first 6 types
#
# chain, count, cycle, repeat, product, combinations — all have MRO length 2.
# Each type's __mro__[1].__name__ == 'object' (direct object subclass).
# ---------------------------------------------------------------------------

table itertools_extra271.mro_lengths_first_six:
  description: "itertools C types __mro__ lengths (first 6): chain(2), count(2), cycle(2), repeat(2), product(2), combinations(2) — all inherit directly from object; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex271m1

  columns: [id, function, args, expected, description]
  rows:
    - [ch_mro_len,             chain.__mro__.__len__,                       [],                             2,    "itertools.chain.__mro__.__len__() == 2 — chain inherits directly from object; verified with Python 3.14.3"]
    - [ch_mro1_eq,             chain.__mro__.__getitem__(1).__name__.__eq__, ["object"],                    true, "itertools.chain.__mro__[1].__name__ == 'object' — second MRO entry is object; verified with Python 3.14.3"]
    - [co_mro_len,             count.__mro__.__len__,                       [],                             2,    "itertools.count.__mro__.__len__() == 2 — count inherits directly from object; verified with Python 3.14.3"]
    - [co_mro1_eq,             count.__mro__.__getitem__(1).__name__.__eq__, ["object"],                    true, "itertools.count.__mro__[1].__name__ == 'object'; verified with Python 3.14.3"]
    - [cy_mro_len,             cycle.__mro__.__len__,                       [],                             2,    "itertools.cycle.__mro__.__len__() == 2 — cycle inherits directly from object; verified with Python 3.14.3"]
    - [cy_mro1_eq,             cycle.__mro__.__getitem__(1).__name__.__eq__, ["object"],                    true, "itertools.cycle.__mro__[1].__name__ == 'object'; verified with Python 3.14.3"]
    - [re_mro_len,             repeat.__mro__.__len__,                      [],                             2,    "itertools.repeat.__mro__.__len__() == 2 — repeat inherits directly from object; verified with Python 3.14.3"]
    - [re_mro1_eq,             repeat.__mro__.__getitem__(1).__name__.__eq__, ["object"],                   true, "itertools.repeat.__mro__[1].__name__ == 'object'; verified with Python 3.14.3"]
    - [pr_mro_len,             product.__mro__.__len__,                     [],                             2,    "itertools.product.__mro__.__len__() == 2 — product inherits directly from object; verified with Python 3.14.3"]
    - [pr_mro1_eq,             product.__mro__.__getitem__(1).__name__.__eq__, ["object"],                  true, "itertools.product.__mro__[1].__name__ == 'object'; verified with Python 3.14.3"]
    - [cb_mro_len,             combinations.__mro__.__len__,                [],                             2,    "itertools.combinations.__mro__.__len__() == 2 — combinations inherits directly from object; verified with Python 3.14.3"]
    - [cb_mro1_eq,             combinations.__mro__.__getitem__(1).__name__.__eq__, ["object"],             true, "itertools.combinations.__mro__[1].__name__ == 'object'; verified with Python 3.14.3"]

