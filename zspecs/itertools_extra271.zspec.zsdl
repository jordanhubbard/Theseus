# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra271
# ---------------------------------------------------------------------------

invariant itertools_extra271.chain_mro_len_is_two:
  description: "itertools.chain.__mro__.__len__() == 2 — chain is a direct subclass of object with no intermediate base classes"
  category: identity
  kind: python_call_eq
  function: chain.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra271.chain_mro_second_is_object:
  description: "itertools.chain.__mro__[1].__name__ == 'object' — second entry in chain MRO is always object"
  category: identity
  kind: python_call_eq
  function: chain.__mro__.__getitem__(1).__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra271.combinations_mro_len_is_two:
  description: "itertools.combinations.__mro__.__len__() == 2 — combinations is a direct subclass of object"
  category: identity
  kind: python_call_eq
  function: combinations.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra271.filterfalse_mro_len_is_two:
  description: "itertools.filterfalse.__mro__.__len__() == 2 — filterfalse is a direct subclass of object"
