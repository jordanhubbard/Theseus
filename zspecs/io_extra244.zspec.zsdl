spec: io_extra244
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/stringio.c"
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io_extra.zspec.zsdl — covers StringIO getvalue, tell, read, readable, seekable"
  notes:
    - "This spec covers: io.StringIO class identity contracts — __name__, __module__, __qualname__, __bases__, __class__, and method name/qualname checks."
    - "io.StringIO is the C class for in-memory text I/O; its __module__ is '_io' (C extension), not 'io'."
    - "io.StringIO.__name__ == 'StringIO' — the class name is 8 characters; verified Python 3.14.3 macOS."
    - "io.StringIO.__module__ == '_io' — defined in the C extension _io, length 3; verified Python 3.14.3 macOS."
    - "io.StringIO.__qualname__ == 'StringIO' — matches __name__ for a top-level class; verified Python 3.14.3 macOS."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — the immediate base class; length 11; verified Python 3.14.3 macOS."
    - "io.StringIO.__class__.__name__ == 'type' — StringIO is a class object; verified Python 3.14.3 macOS."
    - "io.StringIO.getvalue.__name__ == 'getvalue' — length 8; verified Python 3.14.3 macOS."
    - "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' — length 17; verified Python 3.14.3 macOS."
    - "io.StringIO.truncate.__name__ == 'truncate' — length 8; verified Python 3.14.3 macOS."
    - "io.StringIO.truncate.__qualname__ == 'StringIO.truncate' — length 17; verified Python 3.14.3 macOS."
    - "io.StringIO.seek.__name__ == 'seek' — length 4; verified Python 3.14.3 macOS."
    - "io.StringIO.seek.__qualname__ == 'StringIO.seek' — length 13; verified Python 3.14.3 macOS."
    - "io.StringIO.tell.__name__ == 'tell' — length 4; verified Python 3.14.3 macOS."
    - "io.StringIO.tell.__qualname__ == 'StringIO.tell' — length 13; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO class name and module identity contracts
# These verify the class object's identity attributes from the io module.
# io.StringIO is re-exported from _io (C extension).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra244.StringIO.name_eq:
  description: "io.StringIO.__name__ == 'StringIO' — C class name is 'StringIO'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra244.StringIO.name_len:
  description: "len(io.StringIO.__name__) == 8 — 'StringIO' has 8 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__name__.__len__
  args: []
  expected: 8

invariant io_extra244.StringIO.module_eq:
  description: "io.StringIO.__module__ == '_io' — StringIO is defined in the C extension _io, not in io.py; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra244.StringIO.module_len:
  description: "len(io.StringIO.__module__) == 3 — '_io' has 3 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__module__.__len__
  args: []
  expected: 3

invariant io_extra244.StringIO.qualname_eq:
  description: "io.StringIO.__qualname__ == 'StringIO' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra244.StringIO.qualname_len:
  description: "len(io.StringIO.__qualname__) == 8 — 'StringIO' has 8 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__qualname__.__len__
  args: []
  expected: 8

invariant io_extra244.StringIO.class_is_type:
  description: "io.StringIO.__class__.__name__ == 'type' — StringIO is a class object (its metaclass is type); verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# io.StringIO.__bases__[0].__name__ identity contract
# The immediate base class of StringIO is _TextIOBase.
# Accessed via __bases__.__getitem__(0).__name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra244.StringIO.base_name:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — immediate base class of StringIO; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_TextIOBase"

invariant io_extra244.StringIO.base_name_len:
  description: "len(io.StringIO.__bases__[0].__name__) == 11 — '_TextIOBase' has 11 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_chain: __len__
  expected: 11

# ---------------------------------------------------------------------------
# io.StringIO method name identity contracts
# getvalue, truncate, seek, tell are key StringIO methods.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra244.StringIO.getvalue.name_eq:
  description: "io.StringIO.getvalue.__name__ == 'getvalue' — method name is 'getvalue'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: StringIO.getvalue.__name__.__eq__
  args: ["getvalue"]
  expected: true

invariant io_extra244.StringIO.getvalue.qualname_eq:
  description: "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' — qualname is 'StringIO.getvalue'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: StringIO.getvalue.__qualname__.__eq__
  args: ["StringIO.getvalue"]
  expected: true

invariant io_extra244.StringIO.truncate.name_eq:
  description: "io.StringIO.truncate.__name__ == 'truncate' — method name is 'truncate'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: StringIO.truncate.__name__.__eq__
  args: ["truncate"]
  expected: true

invariant io_extra244.StringIO.truncate.qualname_eq:
  description: "io.StringIO.truncate.__qualname__ == 'StringIO.truncate' — qualname is 'StringIO.truncate'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: StringIO.truncate.__qualname__.__eq__
  args: ["StringIO.truncate"]
  expected: true

invariant io_extra244.StringIO.seek.name_eq:
  description: "io.StringIO.seek.__name__ == 'seek' — method name is 'seek'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: StringIO.seek.__name__.__eq__
  args: ["seek"]
  expected: true

invariant io_extra244.StringIO.tell.name_eq:
  description: "io.StringIO.tell.__name__ == 'tell' — method name is 'tell'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: StringIO.tell.__name__.__eq__
  args: ["tell"]
  expected: true

# ---------------------------------------------------------------------------
# io.StringIO method name and qualname length spot-checks
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra244.StringIO_method_name_lengths:
  description: "io.StringIO method __name__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: iostrio244

  columns: [id, function, args, expected]
  rows:
    - [getvalue_name_len,  StringIO.getvalue.__name__.__len__,  [], 8]
    - [truncate_name_len,  StringIO.truncate.__name__.__len__,  [], 8]
    - [seek_name_len,      StringIO.seek.__name__.__len__,      [], 4]
    - [tell_name_len,      StringIO.tell.__name__.__len__,      [], 4]

table io_extra244.StringIO_method_qualname_lengths:
  description: "io.StringIO method __qualname__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: iostriom244

  columns: [id, function, args, expected]
  rows:
    - [getvalue_qualname_len,  StringIO.getvalue.__qualname__.__len__,  [], 17]
    - [truncate_qualname_len,  StringIO.truncate.__qualname__.__len__,  [], 17]
    - [seek_qualname_len,      StringIO.seek.__qualname__.__len__,      [], 13]
    - [tell_qualname_len,      StringIO.tell.__qualname__.__len__,      [], 13]
