spec: bcrypt_rust
version: ">=3.9"
backend: rust_module(bcrypt_rust)

docs: https://github.com/pyca/bcrypt/

provenance:
  derived_from:
    - "https://github.com/pyca/bcrypt/ — bcrypt password hashing"
  notes:
    - "bcrypt provides password hashing."
    - "bcrypt.hashpw(b'password', bcrypt.gensalt()) returns bytes."
    - "bcrypt.checkpw(b'password', hashed) is True."
    - "bcrypt.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant bcrypt_rust.hashpw_returns_bytes:
  description: "bcrypt.hashpw(b'pw', bcrypt.gensalt()) returns bytes"
  category: hashpw
  kind: python_call_eq
  function: bcrypt_hashpw_is_bytes
  args: []
  expected: true

invariant bcrypt_rust.checkpw_correct:
  description: "bcrypt.checkpw(b'pw', hashed) is True for correct password"
  category: checkpw
  kind: python_call_eq
  function: bcrypt_checkpw_correct
  args: []
  expected: true

invariant bcrypt_rust.version_nonempty:
  description: "bcrypt.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: bcrypt_version_nonempty
  args: []
  expected: true

