spec: socket_extra212
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All __doc__ contains checks verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__doc__ contains 'socket' and 'makefile'."
    - "socket.getaddrinfo.__doc__ contains 'address', 'host', 'port'."
    - "socket.gethostname.__doc__ contains 'host' and 'name'."
    - "socket.gethostbyname.__doc__ contains 'host' and 'IP'."
    - "socket.create_connection.__doc__ contains 'address' and 'timeout'."
    - "socket.setdefaulttimeout.__doc__ contains 'timeout' and 'seconds'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — __doc__ contains checks
#
# socket.socket.__doc__ contains 'socket', 'makefile'
# ---------------------------------------------------------------------------

table socket_extra212.socket_class_doc_contains:
  description: "socket.socket class __doc__ contains checks in socketdoc212 namespace — wave 259 theme: socket.socket.__doc__.__contains__('socket')==True; socket.socket.__doc__.__contains__('makefile')==True; socket.socket's doc reads 'A subclass of _socket.socket adding the makefile() method'; the doc is brief but contains both 'socket' and 'makefile'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socketdoc212

  columns: [id, function, args, expected, description]
  rows:
    - [socket_doc_has_socket,   socket.socket.__doc__.__contains__,   ["socket"],   true, "socket.socket.__doc__ contains 'socket'; class name in doc; verified with Python 3.14.3"]
    - [socket_doc_has_makefile, socket.socket.__doc__.__contains__,   ["makefile"], true, "socket.socket.__doc__ contains 'makefile'; adds makefile() method; verified with Python 3.14.3"]
    - [socket_doc_not_bind,     socket.socket.__doc__.__contains__,   ["bind"],     false, "socket.socket.__doc__ does not contain 'bind'; brief doc only mentions makefile; verified with Python 3.14.3"]
    - [socket_doc_not_connect,  socket.socket.__doc__.__contains__,   ["connect"],  false, "socket.socket.__doc__ does not contain 'connect'; brief doc only mentions makefile; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.getaddrinfo and socket.gethostname — __doc__ contains checks
#
# socket.getaddrinfo.__doc__ contains 'address', 'host', 'port'
# socket.gethostname.__doc__ contains 'host', 'name'
# ---------------------------------------------------------------------------

table socket_extra212.getaddrinfo_gethostname_doc_contains:
  description: "socket.getaddrinfo and socket.gethostname __doc__ contains checks in socketdoc212a namespace — wave 259 theme: socket.getaddrinfo.__doc__.__contains__('address')==True; socket.getaddrinfo.__doc__.__contains__('host')==True; socket.getaddrinfo.__doc__.__contains__('port')==True; socket.gethostname.__doc__.__contains__('host')==True; socket.gethostname.__doc__.__contains__('name')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socketdoc212a

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_doc_has_address, socket.getaddrinfo.__doc__.__contains__, ["address"], true, "socket.getaddrinfo.__doc__ contains 'address'; resolves host/port to address info; verified with Python 3.14.3"]
    - [getaddrinfo_doc_has_host,    socket.getaddrinfo.__doc__.__contains__, ["host"],    true, "socket.getaddrinfo.__doc__ contains 'host'; takes host as argument; verified with Python 3.14.3"]
    - [getaddrinfo_doc_has_port,    socket.getaddrinfo.__doc__.__contains__, ["port"],    true, "socket.getaddrinfo.__doc__ contains 'port'; takes port as argument; verified with Python 3.14.3"]
    - [gethostname_doc_has_host,    socket.gethostname.__doc__.__contains__, ["host"],    true, "socket.gethostname.__doc__ contains 'host'; returns current host name; verified with Python 3.14.3"]
    - [gethostname_doc_has_name,    socket.gethostname.__doc__.__contains__, ["name"],    true, "socket.gethostname.__doc__ contains 'name'; returns host name string; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.gethostbyname, socket.create_connection, socket.setdefaulttimeout
# — __doc__ contains checks
#
# socket.gethostbyname.__doc__ contains 'host', 'IP'
# socket.create_connection.__doc__ contains 'address', 'timeout'
# socket.setdefaulttimeout.__doc__ contains 'timeout', 'seconds'
# ---------------------------------------------------------------------------

table socket_extra212.gethostbyname_create_conn_timeout_doc_contains:
  description: "socket.gethostbyname, socket.create_connection, socket.setdefaulttimeout __doc__ contains checks in socketdoc212b namespace — wave 259 theme: socket.gethostbyname.__doc__.__contains__('host')==True; socket.gethostbyname.__doc__.__contains__('IP')==True; socket.create_connection.__doc__.__contains__('address')==True; socket.create_connection.__doc__.__contains__('timeout')==True; socket.setdefaulttimeout.__doc__.__contains__('timeout')==True; socket.setdefaulttimeout.__doc__.__contains__('seconds')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socketdoc212b

  columns: [id, function, args, expected, description]
  rows:
    - [gethostbyname_doc_has_host,      socket.gethostbyname.__doc__.__contains__,      ["host"],    true, "socket.gethostbyname.__doc__ contains 'host'; resolves host name to IP; verified with Python 3.14.3"]
    - [gethostbyname_doc_has_IP,        socket.gethostbyname.__doc__.__contains__,      ["IP"],      true, "socket.gethostbyname.__doc__ contains 'IP'; returns the IP address; verified with Python 3.14.3"]
    - [create_conn_doc_has_address,     socket.create_connection.__doc__.__contains__,  ["address"], true, "socket.create_connection.__doc__ contains 'address'; connects to address tuple; verified with Python 3.14.3"]
    - [create_conn_doc_has_timeout,     socket.create_connection.__doc__.__contains__,  ["timeout"], true, "socket.create_connection.__doc__ contains 'timeout'; supports optional timeout; verified with Python 3.14.3"]
    - [setdefaulttimeout_doc_has_timeout, socket.setdefaulttimeout.__doc__.__contains__, ["timeout"], true, "socket.setdefaulttimeout.__doc__ contains 'timeout'; sets default socket timeout; verified with Python 3.14.3"]
    - [setdefaulttimeout_doc_has_seconds, socket.setdefaulttimeout.__doc__.__contains__, ["seconds"], true, "socket.setdefaulttimeout.__doc__ contains 'seconds'; timeout measured in seconds; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — socket_extra212
# ---------------------------------------------------------------------------

invariant socket_extra212.socket_doc_contains_socket:
  description: "socket.socket.__doc__.__contains__('socket') returns True — socket.socket's docstring reads 'A subclass of _socket.socket adding the makefile() method'; the word 'socket' appears twice: once in 'subclass of _socket.socket' and implicitly in the class context; socket.socket is the Python-level socket class defined in Lib/socket.py; it subclasses _socket.socket (the C extension class in Modules/socketmodule.c) and adds the makefile() method which returns a file-like object wrapping the socket; NEW in socket_extra212: first standalone socket.__doc__.__contains__('socket') invariant in socketdoc212 namespace; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.socket.__doc__.__contains__
  args: ["socket"]
  expected: true

invariant socket_extra212.socket_doc_contains_makefile:
  description: "socket.socket.__doc__.__contains__('makefile') returns True — socket.socket's docstring reads 'A subclass of _socket.socket adding the makefile() method'; 'makefile' is the sole new method mentioned in the class docstring; socket.socket.makefile() returns an io.BufferedReader or io.BufferedWriter wrapping the socket for file-like I/O; the C-level _socket.socket does not have makefile(); the Python subclass socket.socket adds it; the brevity of the doc (one sentence) means 'makefile' is the entire description of what distinguishes socket.socket from _socket.socket; NEW in socket_extra212: first standalone socket.__doc__.__contains__('makefile') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.socket.__doc__.__contains__
  args: ["makefile"]
  expected: true

invariant socket_extra212.getaddrinfo_doc_contains_address:
  description: "socket.getaddrinfo.__doc__.__contains__('address') returns True — socket.getaddrinfo's docstring reads 'Resolve host and port into list of address info entries. Translate the host/port argument into a sequence of 5-tuples that contain all the necessary arguments for creating a socket connected to that service'; the word 'address' appears multiple times as the core concept; getaddrinfo returns a list of (family, type, proto, canonname, sockaddr) 5-tuples where sockaddr is the socket address; the function resolves hostnames/ports to structured address information; NEW in socket_extra212: first standalone getaddrinfo.__doc__.__contains__('address') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.getaddrinfo.__doc__.__contains__
  args: ["address"]
  expected: true

invariant socket_extra212.gethostname_doc_contains_host:
  description: "socket.gethostname.__doc__.__contains__('host') returns True — socket.gethostname's docstring reads 'gethostname() -> string — Return the current host name'; the word 'host' appears in 'host name' which is the return value; gethostname() calls the POSIX gethostname(3) system call to retrieve the machine's configured hostname; the hostname is the short name by which the machine is known on the network; compare: socket.getfqdn() returns the fully qualified domain name; NEW in socket_extra212: first standalone gethostname.__doc__.__contains__('host') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.gethostname.__doc__.__contains__
  args: ["host"]
  expected: true

invariant socket_extra212.gethostbyname_doc_contains_IP:
  description: "socket.gethostbyname.__doc__.__contains__('IP') returns True — socket.gethostbyname's docstring reads 'gethostbyname(host) -> address — Return the IP address (a string of the form ''255.255.255.255'') for a host'; 'IP' (all caps) appears as the return type description; gethostbyname() performs a DNS lookup and returns the IPv4 address as a dotted-decimal string; __contains__ is case-sensitive so 'IP' (all caps) matches; 'ip' (lowercase) would return False since the doc uses the all-caps abbreviation; compare: socket.getaddrinfo supports both IPv4 and IPv6; NEW in socket_extra212: first standalone gethostbyname.__doc__.__contains__('IP') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.gethostbyname.__doc__.__contains__
  args: ["IP"]
  expected: true

invariant socket_extra212.create_connection_doc_contains_address:
  description: "socket.create_connection.__doc__.__contains__('address') returns True — socket.create_connection's docstring reads 'Connect to *address* and return the socket object. Convenience function. Connect to *address* (a 2-tuple ``(host, port)``) and return the socket object'; the word 'address' is the primary argument name and appears multiple times in the doc; create_connection is a higher-level convenience function that resolves the address and connects in one step; the address must be a (host, port) 2-tuple; NEW in socket_extra212: first standalone create_connection.__doc__.__contains__('address') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.create_connection.__doc__.__contains__
  args: ["address"]
  expected: true

invariant socket_extra212.setdefaulttimeout_doc_contains_seconds:
  description: "socket.setdefaulttimeout.__doc__.__contains__('seconds') returns True — socket.setdefaulttimeout's docstring reads 'Set the default timeout in seconds (float) for new socket objects'; the word 'seconds' specifies the unit of the timeout parameter; setdefaulttimeout affects all new sockets created after the call; the timeout value is a float measured in seconds; a value of None disables the timeout (blocking mode); compare: socket.getdefaulttimeout() retrieves the current default; NEW in socket_extra212: first standalone setdefaulttimeout.__doc__.__contains__('seconds') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.setdefaulttimeout.__doc__.__contains__
  args: ["seconds"]
  expected: true
