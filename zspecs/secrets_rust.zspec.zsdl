spec: secrets_rust
version: ">=3.9"
backend: rust_module(secrets_rust)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
  notes:
    - "Clean-room Rust reimplementation of Python secrets module, exposed via PyO3."
    - "Uses OS-provided CSPRNG (e.g. getrandom crate or OsRng from rand_core)."
    - "Exact values are unpredictable; invariants test structural properties only."
    - "token_bytes(n) returns exactly n bytes."
    - "token_hex(n) returns a string of exactly 2*n hex characters."
    - "token_urlsafe(n) returns a base64url string; 16 bytes -> 22 chars (no padding)."
    - "token_urlsafe(0) returns ''."
    - "choice([x]) always returns x when the list has only one element."
    - "randbelow(1) always returns 0 — the only non-negative integer less than 1."
    - "All test vectors verified against Python 3.14.3 secrets module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# token_bytes() — length checks
invariant secrets_rust.token_bytes.len_1:
  description: "token_bytes(1).__len__() == 1"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [1]
  method: __len__
  expected: 1

invariant secrets_rust.token_bytes.len_16:
  description: "token_bytes(16).__len__() == 16"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __len__
  expected: 16

invariant secrets_rust.token_bytes.len_32:
  description: "token_bytes(32).__len__() == 32"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [32]
  method: __len__
  expected: 32

invariant secrets_rust.token_bytes.type_is_bytes:
  description: "token_bytes(16).hex().__len__() == 32 — hex() confirms bytes return type"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: hex
  method_chain: __len__
  expected: 32

# token_hex() — length checks (2*n hex chars per n bytes)
invariant secrets_rust.token_hex.len_8:
  description: "token_hex(8).__len__() == 16 — 8 bytes encode to 16 hex chars"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [8]
  method: __len__
  expected: 16

invariant secrets_rust.token_hex.len_16:
  description: "token_hex(16).__len__() == 32 — 16 bytes encode to 32 hex chars"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [16]
  method: __len__
  expected: 32

invariant secrets_rust.token_hex.type_is_str:
  description: "token_hex(16).upper().__len__() == 32 — upper() confirms str return type"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [16]
  method: upper
  method_chain: __len__
  expected: 32

# token_urlsafe() — base64url length checks
invariant secrets_rust.token_urlsafe.len_0:
  description: "token_urlsafe(0).__len__() == 0"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [0]
  method: __len__
  expected: 0

invariant secrets_rust.token_urlsafe.len_16:
  description: "token_urlsafe(16).__len__() == 22 — 16 bytes in base64url is 22 chars"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [16]
  method: __len__
  expected: 22

# choice() — single-element list is deterministic
invariant secrets_rust.choice.single_element_99:
  description: "choice([99]) == 99"
  category: choice
  kind: python_call_eq
  function: choice
  args: [[99]]
  expected: 99

invariant secrets_rust.choice.single_element_42:
  description: "choice([42]) == 42"
  category: choice
  kind: python_call_eq
  function: choice
  args: [[42]]
  expected: 42

# randbelow() — deterministic edge case and type
invariant secrets_rust.randbelow.zero_below_one:
  description: "randbelow(1) == 0 — only non-negative integer less than 1"
  category: randbelow
  kind: python_call_eq
  function: randbelow
  args: [1]
  expected: 0

invariant secrets_rust.randbelow.type_is_int:
  description: "randbelow(1).bit_length() == 0 — confirms return type is int"
  category: randbelow
  kind: python_call_eq
  function: randbelow
  args: [1]
  method: bit_length
  expected: 0

