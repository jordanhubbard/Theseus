  category: descriptor_type
  id_prefix: sk1606mt

  columns: [id, function, args, expected]
  rows:
    - ["sk1606mt001", "type(socket.socket.__dict__['accept']).__name__.__eq__",           ["function"], true]
    - ["sk1606mt002", "type(socket.socket.__dict__['close']).__name__.__eq__",            ["function"], true]
