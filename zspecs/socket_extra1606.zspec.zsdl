    - ["sk1606mt010", "type(socket.socket.__dict__['__repr__']).__name__.__eq__",         ["function"], true]
    - ["sk1606mt011", "type(socket.socket.__dict__['__enter__']).__name__.__eq__",        ["function"], true]
    - ["sk1606mt012", "type(socket.socket.__dict__['__exit__']).__name__.__eq__",         ["function"], true]
    - ["sk1606mt013", "type(socket.socket.__dict__['family']).__name__.__eq__",           ["property"], true]
    - ["sk1606mt014", "type(socket.socket.__dict__['type']).__name__.__eq__",             ["property"], true]
    - ["sk1606mt015", "socket.socket.__dict__.__contains__",                              ["sendfile"],    true]
    - ["sk1606mt016", "socket.socket.__dict__.__contains__",                              ["makefile"],    true]
    - ["sk1606mt017", "socket.socket.__dict__.__contains__",                              ["detach"],      true]
    - ["sk1606mt018", "socket.socket.__dict__.__contains__",                              ["__getstate__"], true]
    - ["sk1606mt019", "type(socket.socket.__dict__['__getstate__']).__name__.__eq__",     ["function"],    true]
    - ["sk1606mt020", "type(socket.AddressFamily).__name__.__eq__",                       ["EnumType"],    true]
    - ["sk1606mt021", "type(socket.SocketKind).__name__.__eq__",                          ["EnumType"],    true]
    - ["sk1606mt022", "issubclass(socket.AddressFamily, int).__eq__",                     [true],          true]
    - ["sk1606mt023", "issubclass(socket.SocketKind, int).__eq__",                        [true],          true]
    - ["sk1606mt024", "socket.AddressFamily.__dict__.__contains__",                       ["__slots__"],   false]
    - ["sk1606mt025", "socket.SocketKind.__dict__.__contains__",                          ["__slots__"],   false]

table socket_extra1606.socket_exceptions_no_slots:
  description: "socket exception types (gaierror, herror) have no __slots__; socket.error is OSError; socket.timeout is TimeoutError"
  kind: python_call_eq
  category: exception_class
  id_prefix: sk1606ex

  columns: [id, function, args, expected]
  rows:
    - ["sk1606ex001", "socket.error.__dict__.__contains__",                 ["__slots__"],   false]
    - ["sk1606ex002", "socket.timeout.__dict__.__contains__",               ["__slots__"],   false]
    - ["sk1606ex003", "socket.gaierror.__dict__.__contains__",              ["__slots__"],   false]
    - ["sk1606ex004", "socket.herror.__dict__.__contains__",                ["__slots__"],   false]
    - ["sk1606ex005", "socket.gaierror.__dict__.__contains__",              ["__weakref__"], true]
    - ["sk1606ex006", "socket.herror.__dict__.__contains__",                ["__weakref__"], true]
    - ["sk1606ex007", "socket.gaierror.__dict__.__contains__",              ["__doc__"],     true]
    - ["sk1606ex008", "socket.herror.__dict__.__contains__",                ["__doc__"],     true]
    - ["sk1606ex009", "socket.gaierror.__dict__.__contains__",              ["__module__"],  true]
    - ["sk1606ex010", "socket.herror.__dict__.__contains__",                ["__module__"],  true]
    - ["sk1606ex011", "issubclass(socket.gaierror, OSError).__eq__",        [true],          true]
    - ["sk1606ex012", "issubclass(socket.herror, OSError).__eq__",          [true],          true]
    - ["sk1606ex013", "socket.gaierror.__name__.__eq__",                    ["gaierror"],    true]
    - ["sk1606ex014", "socket.herror.__name__.__eq__",                      ["herror"],      true]
    - ["sk1606ex015", "socket.gaierror.__module__.__eq__",                  ["socket"],      true]
    - ["sk1606ex016", "socket.herror.__module__.__eq__",                    ["socket"],      true]
    - ["sk1606ex017", "socket.gaierror.__bases__.__len__",                  [],              1]
    - ["sk1606ex018", "socket.herror.__bases__.__len__",                    [],              1]
    - ["sk1606ex019", "socket.gaierror.__bases__.__contains__",             [OSError],       true]
    - ["sk1606ex020", "socket.herror.__bases__.__contains__",               [OSError],       true]
    - ["sk1606ex021", "socket.timeout.__name__.__eq__",                     ["TimeoutError"], true]
    - ["sk1606ex022", "socket.timeout.__module__.__eq__",                   ["builtins"],    true]
    - ["sk1606ex023", "type(socket.gaierror.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["sk1606ex024", "type(socket.herror.__dict__['__weakref__']).__name__.__eq__",  ["getset_descriptor"], true]
    - ["sk1606ex025", "socket.gaierror.__dict__.__contains__",              ["__dict__"],    false]
