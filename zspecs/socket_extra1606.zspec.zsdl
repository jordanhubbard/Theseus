spec: socket_extra1606
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "socket.socket is a pure Python wrapper class (Lib/socket.py) around the C type _socket.socket"
    - "socket.socket DOES define __slots__ = ['__weakref__', '_io_refs', '_closed'] (a list, not a tuple)"
    - "socket.socket.__dict__ does NOT contain '__dict__' — instances have no per-instance __dict__"
    - "_io_refs and _closed appear as member_descriptor in socket.socket.__dict__"
    - "__weakref__ appears as getset_descriptor in socket.socket.__dict__"
    - "socket.socket instances DO support weakref via the __weakref__ slot"
    - "Public methods (accept, close, detach, dup, etc.) are plain Python functions in socket.socket.__dict__"
    - "Properties (family, type) appear as property objects in socket.socket.__dict__"
    - "socket.error is OSError (same object); socket.timeout is TimeoutError (same object)"
    - "socket.gaierror and socket.herror subclass OSError directly; they have no __slots__"
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses with no __slots__"
    - "_socket.socket is the C extension type; it has no __slots__ key in its __dict__"
  created_at: "2026-04-12"
error_model: python_exceptions

table socket_extra1606.socket_class_slots:
  description: "socket.socket defines __slots__ as a list with three entries; instances have no per-instance __dict__; slot descriptors for _io_refs and _closed are member_descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1606sc

  columns: [id, function, args, expected]
  rows:
    - ["sk1606sc001", "socket.socket.__dict__.__contains__",                   ["__slots__"],    true]
    - ["sk1606sc002", "socket.socket.__dict__.__contains__",                   ["__dict__"],     false]
    - ["sk1606sc003", "socket.socket.__dict__.__contains__",                   ["__weakref__"],  true]
    - ["sk1606sc004", "socket.socket.__dict__.__contains__",                   ["_io_refs"],     true]
    - ["sk1606sc005", "socket.socket.__dict__.__contains__",                   ["_closed"],      true]
    - ["sk1606sc006", "type(socket.socket.__dict__['__slots__']).__name__.__eq__", ["list"],     true]
    - ["sk1606sc007", "len(socket.socket.__slots__).__eq__",                   [3],              true]
    - ["sk1606sc008", "socket.socket.__slots__.__contains__",                  ["__weakref__"],  true]
    - ["sk1606sc009", "socket.socket.__slots__.__contains__",                  ["_io_refs"],     true]
    - ["sk1606sc010", "socket.socket.__slots__.__contains__",                  ["_closed"],      true]
    - ["sk1606sc011", "type(socket.socket.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["sk1606sc012", "type(socket.socket.__dict__['_io_refs']).__name__.__eq__",    ["member_descriptor"], true]
    - ["sk1606sc013", "type(socket.socket.__dict__['_closed']).__name__.__eq__",     ["member_descriptor"], true]
    - ["sk1606sc014", "socket.socket.__name__.__eq__",                         ["socket"],       true]
    - ["sk1606sc015", "socket.socket.__module__.__eq__",                       ["socket"],       true]
    - ["sk1606sc016", "socket.socket.__dict__.__class__.__name__.__eq__",      ["mappingproxy"], true]
    - ["sk1606sc017", "socket.socket.__dict__.__contains__",                   ["family"],       true]
    - ["sk1606sc018", "socket.socket.__dict__.__contains__",                   ["type"],         true]
    - ["sk1606sc019", "type(socket.socket.__dict__['family']).__name__.__eq__", ["property"],    true]
    - ["sk1606sc020", "type(socket.socket.__dict__['type']).__name__.__eq__",   ["property"],    true]
    - ["sk1606sc021", "issubclass(socket.socket, _socket.socket).__eq__",      [true],           true]
    - ["sk1606sc022", "_socket.socket.__dict__.__contains__",                  ["__slots__"],    false]
    - ["sk1606sc023", "_socket.socket.__name__.__eq__",                        ["socket"],       true]
    - ["sk1606sc024", "socket.socket.__dict__.__contains__",                   ["accept"],       true]
    - ["sk1606sc025", "socket.socket.__dict__.__contains__",                   ["close"],        true]

table socket_extra1606.socket_method_types:
  description: "Methods in socket.socket.__dict__ are plain Python functions; properties (family, type) are property objects"
