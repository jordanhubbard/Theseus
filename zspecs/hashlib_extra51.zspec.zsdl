spec: hashlib_extra51
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra50.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __class__.__qualname__.__eq__ and __class__.__module__.__eq__('builtins')."
    - "hashlib_extra49.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256 __class__.__name__.__eq__('builtin_function_or_method') and new __class__.__name__.__eq__('function')."
    - "hashlib_extra44.zspec.zsdl — covers blake2b/blake2s __class__.__name__.__eq__('type')."
    - "hashlib_extra18.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/new __name__.__eq__ and __qualname__.__eq__ string values."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new/pbkdf2_hmac __name__.__eq__ string values."
    - "hashlib_extra6.zspec.zsdl — covers blake2b/blake2s __module__.__eq__('_blake2')."
  notes:
    - "This spec extends hashlib through hashlib_extra50; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior hashlib spec checks __name__.__class__.__name__.__eq__('str') for sha256, md5, sha1, pbkdf2_hmac, sha3_256, new, blake2b, or blake2s. Prior specs check the string VALUE of __name__ (e.g., sha256.__name__.__eq__('openssl_sha256')), but no prior spec checks that the TYPE of __name__ is 'str'. The __name__.__class__.__name__ axis is distinct from the __name__ string-value axis and provides an independent structural regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__name__.__class__.__name__ == 'str'. The __name__ attribute of a builtin_function_or_method is always a Python str; its class's __name__ is 'str'. No prior spec checks sha256.__name__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.md5.__name__.__class__.__name__ == 'str'. The __name__ attribute of any hashlib callable is a Python str. No prior spec checks md5.__name__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__name__.__class__.__name__ == 'str'. Same pattern as sha256 and md5. No prior spec checks sha1.__name__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__name__.__class__.__name__ == 'str'. pbkdf2_hmac is a C builtin; its __name__ is a str. No prior spec checks pbkdf2_hmac.__name__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__.__class__.__name__ == 'str'. sha3_256 is an OpenSSL-backed builtin function; its __name__ is a str. No prior spec checks sha3_256.__name__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__.__class__.__name__ == 'str'. new is a Python wrapper function; its __name__ attribute is a str. No prior spec checks new.__name__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__.__class__.__name__ == 'str'. blake2b is a C extension type; its __name__ attribute is a str (the class name string). No prior spec checks blake2b.__name__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__.__class__.__name__ == 'str'. Same pattern as blake2b. No prior spec checks blake2s.__name__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module-level callable __name__.__class__.__name__.__eq__('str')
#
# Prior specs check the string VALUE of hashlib callable __name__ attributes
# (e.g., extra18/extra20 cover __name__.__eq__('openssl_sha256') etc.), but
# no prior spec checks that the TYPE of the __name__ attribute is 'str'.
# For all hashlib callables — C builtins, Python functions, and C types —
# the __name__ attribute is always a Python str object whose class __name__
# is 'str'. This table covers all 8 key hashlib callables on this novel axis.
# ---------------------------------------------------------------------------

table hashlib_extra51.callable_name_type:
  description: "hashlib sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __name__.__class__.__name__.__eq__('str') — verifies that the __name__ attribute of each hashlib callable is a Python str; novel __name__.__class__.__name__ axis; no prior hashlib spec checks __name__.__class__.__name__ for any callable"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibnametype51

  columns: [id, function, args, expected]
  rows:
    - [sha256_name_class_name_eq,     sha256.__name__.__class__.__name__.__eq__,     ["str"], true]
    - [md5_name_class_name_eq,        md5.__name__.__class__.__name__.__eq__,        ["str"], true]
    - [sha1_name_class_name_eq,       sha1.__name__.__class__.__name__.__eq__,       ["str"], true]
    - [pbkdf2_hmac_name_class_name_eq, pbkdf2_hmac.__name__.__class__.__name__.__eq__, ["str"], true]
    - [sha3_256_name_class_name_eq,   sha3_256.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [new_name_class_name_eq,        new.__name__.__class__.__name__.__eq__,        ["str"], true]
    - [blake2b_name_class_name_eq,    blake2b.__name__.__class__.__name__.__eq__,    ["str"], true]
    - [blake2s_name_class_name_eq,    blake2s.__name__.__class__.__name__.__eq__,    ["str"], true]
