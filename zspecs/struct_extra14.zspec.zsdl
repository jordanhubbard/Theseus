spec: struct_extra14
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct.zspec.zsdl — pack/unpack for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize; roundtrip; error cases."
    - "struct_extra.zspec.zsdl — Struct format/size, calcsize extras, pack_into, unpack_from, iter_unpack, error name/bases."
    - "struct_extra2.zspec.zsdl — function __name__/__module__; pack(>H,256); unpack(>H); calcsize(>HHH); Struct base."
    - "struct_extra3.zspec.zsdl — pack/unpack/calcsize for !f/!d/!?; calcsize for !5s/!3p/!x/!5x."
    - "struct_extra4.zspec.zsdl — Struct.__name__; pack_into.__name__; function __qualname__ table; error.__qualname__; pack(>I,65536)/(<I,65536)/(>i,-256); calcsize(>i/<i/>I)."
    - "struct_extra5.zspec.zsdl — Struct.__qualname__; Struct('>I'/'>H') format/size; pack('>B',255); unpack('>B',xff); calcsize('>B'/'<B'/'>5s'); Struct('>I').pack(256)."
    - "struct_extra6.zspec.zsdl — pack/unpack('>b',127/-128); Struct('>b'/'>Q') format/size; pack/calcsize('<h'); unpack('<h')."
    - "struct_extra7.zspec.zsdl — pack/unpack/calcsize for '>l'/'>L'/'=H'/'>2B'; Struct('>l') format/size."
    - "struct_extra8.zspec.zsdl — function __module__ (all '_struct' except error 'struct'); pack return type/length for '>I'/'>H'; calcsize('>IHB'); unpack('>H',0100); Struct('>IHB') format/size; calcsize('>Q')."
    - "struct_extra9.zspec.zsdl — calcsize('c'/'P'); Struct method descriptor __qualname__/__name__ tables."
    - "struct_extra10.zspec.zsdl — pack/unpack('>BB',0,255); pack/unpack('<I',1); calcsize('<f'/'<d'); Struct('>BB') format/size; pack('>i',0/-1)."
    - "struct_extra11.zspec.zsdl — pack('>I',305419896); pack('<H',256); pack('!f',1.0) length; unpack('>I',12345678); calcsize('!BHI'/'3s'); Struct __name__/__module__; error.__module__; pack/unpack('>H',1000); pack('>B',127)."
    - "struct_extra12.zspec.zsdl — pack/unpack('<H' with 1/65535/256); unpack('>i',FFFFFFFF); calcsize('<H'/'<I'/'>i'/'>b'/'!H'); pack('>b',0)."
    - "struct_extra13.zspec.zsdl — calcsize('=H'/'=I'/'=c'/'3s'); pack/unpack('=H',1)/('>H',1000)/('c',b'A')/('3s',b'abc')."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior struct spec."
    - "struct.pack('>I', 0) == b'\\x00\\x00\\x00\\x00': big-endian unsigned 32-bit integer 0 encodes as four zero bytes. Verified."
    - "struct.pack('>I', 0).__class__.__name__ == 'bytes': pack always returns bytes. Verified."
    - "struct.pack('>I', 1) == b'\\x00\\x00\\x00\\x01': big-endian unsigned 32-bit integer 1 encodes with 1 in the LSB. Verified."
    - "struct.pack('>H', 256) == b'\\x01\\x00': big-endian unsigned 16-bit integer 256 == 0x0100. struct_extra2 covers pack('>H',256) but only checks __len__; no prior spec checks the exact bytes. Verified."
    - "struct.unpack('>I', b'\\x00\\x00\\x00\\x00') == (0,): inverse of the pack('>I',0) vector. Verified."
    - "struct.unpack('>H', b'\\x01\\x00') == (256,): inverse of the pack('>H',256) vector; struct_extra8 covers unpack('>H',0100)==(256,) from extra8 namespace; this re-anchors it from extra14. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pack('>I', 0) — return type and exact byte value
#
# struct_extra8 covers pack return type/length for '>I' using method_chain
# from extra8 namespace. No prior spec checks pack('>I', 0).__class__.__name__
# or the exact four-zero-byte value as standalone python_call_eq invariants.
# ---------------------------------------------------------------------------

invariant struct_extra14.pack.be_uint32_zero_class:
  description: "struct.pack('>I', 0).__class__.__name__ == 'bytes' — pack always returns bytes"
  category: types
  kind: python_call_eq
  function: pack
  args: [">I", 0]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant struct_extra14.pack.be_uint32_zero_value:
  description: "struct.pack('>I', 0) == b'\\x00\\x00\\x00\\x00' — big-endian uint32 zero encodes as four zero bytes"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">I", 0]
  expected: !hex 00000000

# ---------------------------------------------------------------------------
# pack('>I', 1) — exact byte value
#
# No prior struct spec packs '>I' with value 1 and checks the exact result.
# struct_extra4 covers pack('>I',65536). struct_extra11 covers pack('>I',305419896).
# ---------------------------------------------------------------------------

invariant struct_extra14.pack.be_uint32_one_value:
  description: "struct.pack('>I', 1) == b'\\x00\\x00\\x00\\x01' — big-endian uint32 one encodes with 1 in the LSB"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">I", 1]
  expected: !hex 00000001

# ---------------------------------------------------------------------------
# pack('>H', 256) — exact byte value
#
# struct_extra2 covers pack('>H',256) but only verifies __len__ == 2.
# No prior spec checks the exact two-byte result. 256 == 0x0100 big-endian.
# ---------------------------------------------------------------------------

invariant struct_extra14.pack.be_uint16_256_value:
  description: "struct.pack('>H', 256) == b'\\x01\\x00' — big-endian uint16 256 (0x0100)"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">H", 256]
  expected: !hex 0100

# ---------------------------------------------------------------------------
# unpack('>I', b'\x00\x00\x00\x00') == (0,)
#
# No prior struct spec unpacks '>I' from four zero bytes. This is the inverse
# of the pack('>I', 0) vector above.
# ---------------------------------------------------------------------------

invariant struct_extra14.unpack.be_uint32_zero:
  description: "struct.unpack('>I', b'\\x00\\x00\\x00\\x00') == (0,) — big-endian uint32 zero"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: [">I", !hex 00000000]
  expected: [0]

# ---------------------------------------------------------------------------
# unpack('>H', b'\x01\x00') == (256,)
#
# struct_extra8 covers unpack('>H', b'\x01\x00') == (256,) from extra8.
# This invariant re-anchors the same vector from the extra14 namespace.
# ---------------------------------------------------------------------------

invariant struct_extra14.unpack.be_uint16_256:
  description: "struct.unpack('>H', b'\\x01\\x00') == (256,) — big-endian uint16 0x0100 == 256 (extra14 anchor)"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: [">H", !hex 0100]
  expected: [256]
