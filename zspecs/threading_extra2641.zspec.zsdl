spec: threading_extra2641
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 623 (_extra2641): __copy__, __deepcopy__, and __sizeof__ dict-presence checks for threading module types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__copy__ supports copy.copy() shallow copying. None of the threading types (Thread, Lock, Event, Condition, Semaphore, BoundedSemaphore, Timer, Barrier, local) define __copy__ in their class __dict__ — all False."
    - "__deepcopy__ supports copy.deepcopy() deep copying. None of the threading types define __deepcopy__ in their class __dict__ — all False."
    - "__sizeof__ is used by sys.getsizeof() for memory introspection. None of the threading types define __sizeof__ in their class __dict__ — all False."
    - "threading.Lock is actually _thread.lock at runtime (a C-implemented type from the _thread module); threading.Lock.__name__ == 'lock'."
    - "threading.local is actually _thread._local at runtime; threading.local is the canonical public reference."
    - "Synchronization primitives (Lock, Event, Condition, Semaphore, BoundedSemaphore, Barrier) and thread-management types (Thread, Timer, local) are not copyable objects by design; shallow or deep copying threading primitives is not a supported operation."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __copy__ dict-presence for threading synchronization types
#
# __copy__ is the hook for copy.copy() shallow copying. Threading types
# (Thread, Lock, Event, Condition, Semaphore, BoundedSemaphore, Timer,
# Barrier, local) are synchronization and utility objects. None define
# __copy__ in their own class __dict__ — all False.
# ---------------------------------------------------------------------------

table threading_extra2641.copy_absent:
  description: "threading types do not define __copy__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2641

  columns: [id, function, args, expected]
  rows:
    - ["th2641001", "threading.Thread.__dict__.__contains__",           ["__copy__"], false]
    - ["th2641002", "threading.Lock.__dict__.__contains__",             ["__copy__"], false]
    - ["th2641003", "threading.Event.__dict__.__contains__",            ["__copy__"], false]
    - ["th2641004", "threading.Condition.__dict__.__contains__",        ["__copy__"], false]
    - ["th2641005", "threading.Semaphore.__dict__.__contains__",        ["__copy__"], false]
    - ["th2641006", "threading.BoundedSemaphore.__dict__.__contains__", ["__copy__"], false]
    - ["th2641007", "threading.Timer.__dict__.__contains__",            ["__copy__"], false]
    - ["th2641008", "threading.Barrier.__dict__.__contains__",          ["__copy__"], false]
    - ["th2641009", "threading.local.__dict__.__contains__",            ["__copy__"], false]

# ---------------------------------------------------------------------------
# Table 2: __deepcopy__ dict-presence for threading synchronization types
#
# __deepcopy__ is the hook for copy.deepcopy() deep copying. None of the
# threading types define __deepcopy__ in their own class __dict__. Deep
# copying of live synchronization primitives is not supported — all False.
# ---------------------------------------------------------------------------

table threading_extra2641.deepcopy_absent:
  description: "threading types do not define __deepcopy__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2641

  columns: [id, function, args, expected]
  rows:
    - ["th2641010", "threading.Thread.__dict__.__contains__",           ["__deepcopy__"], false]
    - ["th2641011", "threading.Lock.__dict__.__contains__",             ["__deepcopy__"], false]
    - ["th2641012", "threading.Event.__dict__.__contains__",            ["__deepcopy__"], false]
    - ["th2641013", "threading.Condition.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["th2641014", "threading.Semaphore.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["th2641015", "threading.BoundedSemaphore.__dict__.__contains__", ["__deepcopy__"], false]
    - ["th2641016", "threading.Timer.__dict__.__contains__",            ["__deepcopy__"], false]
    - ["th2641017", "threading.Barrier.__dict__.__contains__",          ["__deepcopy__"], false]
    - ["th2641018", "threading.local.__dict__.__contains__",            ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: __sizeof__ dict-presence for threading synchronization types
#
# __sizeof__ is called by sys.getsizeof() to obtain the memory footprint of
# an object in bytes. None of the threading types define a custom __sizeof__
# in their own class __dict__ — all False. sys.getsizeof() falls back to
# the default object sizing provided by CPython's runtime.
# ---------------------------------------------------------------------------

table threading_extra2641.sizeof_absent:
  description: "threading types do not define __sizeof__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2641

  columns: [id, function, args, expected]
  rows:
    - ["th2641019", "threading.Thread.__dict__.__contains__",           ["__sizeof__"], false]
    - ["th2641020", "threading.Lock.__dict__.__contains__",             ["__sizeof__"], false]
    - ["th2641021", "threading.Event.__dict__.__contains__",            ["__sizeof__"], false]
    - ["th2641022", "threading.Condition.__dict__.__contains__",        ["__sizeof__"], false]
    - ["th2641023", "threading.Semaphore.__dict__.__contains__",        ["__sizeof__"], false]
    - ["th2641024", "threading.BoundedSemaphore.__dict__.__contains__", ["__sizeof__"], false]
    - ["th2641025", "threading.Timer.__dict__.__contains__",            ["__sizeof__"], false]
    - ["th2641026", "threading.Barrier.__dict__.__contains__",          ["__sizeof__"], false]
    - ["th2641027", "threading.local.__dict__.__contains__",            ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Table 4: Combined absence summary — all three dunders absent from all types
#
# Cross-check confirming that none of the nine threading types define any of
# __copy__, __deepcopy__, or __sizeof__ in their own class __dict__. Assigns
# a unique dunder per type in a first pass, then cross-checks additional
# combinations to confirm the full absence pattern.
# ---------------------------------------------------------------------------

table threading_extra2641.copy_sizeof_absent_summary:
  description: "threading types define none of __copy__, __deepcopy__, __sizeof__ — cross-type summary"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2641

  columns: [id, function, args, expected]
  rows:
    - ["th2641028", "threading.Thread.__dict__.__contains__",           ["__copy__"],     false]
    - ["th2641029", "threading.Lock.__dict__.__contains__",             ["__deepcopy__"], false]
    - ["th2641030", "threading.Event.__dict__.__contains__",            ["__sizeof__"],   false]
    - ["th2641031", "threading.Condition.__dict__.__contains__",        ["__copy__"],     false]
    - ["th2641032", "threading.Semaphore.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["th2641033", "threading.BoundedSemaphore.__dict__.__contains__", ["__sizeof__"],   false]
    - ["th2641034", "threading.Timer.__dict__.__contains__",            ["__copy__"],     false]
    - ["th2641035", "threading.Barrier.__dict__.__contains__",          ["__deepcopy__"], false]
    - ["th2641036", "threading.local.__dict__.__contains__",            ["__sizeof__"],   false]
