spec: dis_extra8
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis.zspec.zsdl — covers __name__ for Instruction/Bytecode/dis/disassemble/code_info/show_code/get_instructions/stack_effect; opname class/length; opmap contains/values; stack_effect values; haslocal/hasname"
    - "dis_extra.zspec.zsdl — covers dis.__name__ (module name), distb/__name__, findlinestarts/__name__, findlabels/__name__, disassemble/__name__, code_info/__name__, show_code/__name__, get_instructions/__name__, stack_effect/__name__, Instruction/__name__/__module__, opname/__class__/__name__, opmap/__class__/__name__, HAVE_ARGUMENT/__class__/__name__"
    - "dis_extra2.zspec.zsdl — covers __module__ for dis/disassemble/get_instructions/findlinestarts/findlabels/code_info (table); Instruction/__name__/__module__/__bases__[0]; Bytecode/__name__/__module__/__bases__[0]; opname/opmap class checks; HAVE_ARGUMENT class check"
    - "dis_extra3.zspec.zsdl — covers __name__/__module__ for Instruction/Bytecode (table); __name__ for findlinestarts/findlabels/get_instructions/stack_effect (table); opname class/length; opmap class/contains; HAVE_ARGUMENT value; Bytecode.__module__"
    - "dis_extra4.zspec.zsdl — covers Instruction.__qualname__; Instruction._fields class/contains-opname/contains-opcode; opname.__len__ >= 100; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
    - "dis_extra5.zspec.zsdl — covers __qualname__ for code_info/show_code/stack_effect/findlabels/distb; Bytecode.__qualname__; Instruction._fields[0]=='opname'; show_code/__module__; distb/__module__"
    - "dis_extra6.zspec.zsdl — covers hasjabs empty list; hasjrel/hasconst/hascompare/hasfree class+len; Instruction._fields[1]/'opcode' and _fields[2]/'arg'; opmap LOAD_CONST/LOAD_GLOBAL/RETURN_VALUE/STORE_NAME values; opname[82]=='LOAD_CONST'"
    - "dis_extra7.zspec.zsdl — covers Instruction._fields[3]/'argval' and _fields[4]/'argrepr'; hasexc class and nonempty; hasarg class and nonempty; Bytecode.__bases__[0].__name__=='object'; opmap BINARY_OP/CALL/RESUME; opname idx31/idx116/idx35"
  notes:
    - "This spec adds standalone extra8-namespace invariants for function __module__ and class identity checks across all major dis public names."
    - "dis.dis.__module__ == 'dis' — extra2 covers this in a table; extra8 provides a standalone invariant with an extra8-namespace ID."
    - "dis.disassemble.__module__ == 'dis' — extra2 covers this in a table; extra8 standalone anchor."
    - "dis.distb.__module__ == 'dis' — extra5 covers this as a standalone; extra8 standalone anchor."
    - "dis.code_info.__module__ == 'dis' — extra2 covers this in a table; extra8 standalone anchor."
    - "dis.show_code.__module__ == 'dis' — extra5 covers this as a standalone; extra8 standalone anchor."
    - "dis.get_instructions.__module__ == 'dis' — extra2 covers this in a table; extra8 standalone anchor."
    - "dis.findlinestarts.__module__ == 'dis' — extra2 covers this in a table; extra8 standalone anchor."
    - "dis.findlabels.__module__ == 'dis' — extra2 covers this in a table; extra8 standalone anchor."
    - "dis.stack_effect.__module__ == 'dis' — not covered in extra2 or extra5 (extra5 only covers show_code and distb); new in extra8."
    - "dis.Bytecode.__name__ == 'Bytecode' — extra2/extra3 cover this; extra8 standalone anchor."
    - "dis.Bytecode.__module__ == 'dis' — extra2/extra3 cover this; extra8 standalone anchor."
    - "dis.Instruction.__name__ == 'Instruction' — extra2/extra3 cover this; extra8 standalone anchor."
    - "dis.Instruction.__module__ == 'dis' — extra2/extra3 cover this; extra8 standalone anchor."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ — standalone extra8-namespace invariants
# The core public dis functions all have __module__ == 'dis'.
# extra2 covers dis/disassemble/get_instructions/findlinestarts/findlabels/code_info
# in a table; extra5 adds show_code and distb. stack_effect.__module__ is new here.
# ---------------------------------------------------------------------------

invariant dis_extra8.dis.module:
  description: "dis.dis.__module__ == 'dis'"
  category: module_attrs
  kind: python_call_eq
  function: dis.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra8.disassemble.module:
  description: "dis.disassemble.__module__ == 'dis'"
  category: module_attrs
  kind: python_call_eq
  function: disassemble.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra8.distb.module:
  description: "dis.distb.__module__ == 'dis'"
  category: module_attrs
  kind: python_call_eq
  function: distb.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra8.code_info.module:
  description: "dis.code_info.__module__ == 'dis'"
  category: module_attrs
  kind: python_call_eq
  function: code_info.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra8.show_code.module:
  description: "dis.show_code.__module__ == 'dis'"
  category: module_attrs
  kind: python_call_eq
  function: show_code.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra8.get_instructions.module:
  description: "dis.get_instructions.__module__ == 'dis'"
  category: module_attrs
  kind: python_call_eq
  function: get_instructions.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra8.findlinestarts.module:
  description: "dis.findlinestarts.__module__ == 'dis'"
  category: module_attrs
  kind: python_call_eq
  function: findlinestarts.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra8.findlabels.module:
  description: "dis.findlabels.__module__ == 'dis'"
  category: module_attrs
  kind: python_call_eq
  function: findlabels.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra8.stack_effect.module:
  description: "dis.stack_effect.__module__ == 'dis' — not verified in any prior dis spec"
  category: module_attrs
  kind: python_call_eq
  function: stack_effect.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# Bytecode class identity — standalone extra8-namespace invariants
# ---------------------------------------------------------------------------

invariant dis_extra8.Bytecode.name:
  description: "dis.Bytecode.__name__ == 'Bytecode'"
  category: bytecode
  kind: python_call_eq
  function: Bytecode.__name__.__eq__
  args: ["Bytecode"]
  expected: true

invariant dis_extra8.Bytecode.module:
  description: "dis.Bytecode.__module__ == 'dis'"
  category: bytecode
  kind: python_call_eq
  function: Bytecode.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# Instruction class identity — standalone extra8-namespace invariants
# ---------------------------------------------------------------------------

invariant dis_extra8.Instruction.name:
  description: "dis.Instruction.__name__ == 'Instruction'"
  category: instruction
  kind: python_call_eq
  function: Instruction.__name__.__eq__
  args: ["Instruction"]
  expected: true

invariant dis_extra8.Instruction.module:
  description: "dis.Instruction.__module__ == 'dis'"
  category: instruction
  kind: python_call_eq
  function: Instruction.__module__.__eq__
  args: ["dis"]
  expected: true
