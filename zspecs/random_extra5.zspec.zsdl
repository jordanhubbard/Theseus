spec: random_extra5
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl, random_extra.zspec.zsdl, random_extra2.zspec.zsdl, random_extra3.zspec.zsdl, and random_extra4.zspec.zsdl."
    - "random_extra3 covers: Random.__name__, SystemRandom.__name__, SystemRandom.__module__, Random.__bases__[0].__name__=='object', randint/choice/shuffle/sample/seed/uniform/triangular/choices/gauss/expovariate/betavariate __name__."
    - "random_extra4 covers: seed/sample/shuffle/choices/gauss/uniform __name__ (table), Random/__name__/SystemRandom __name__ (table), Random.__module__, SystemRandom.__module__, sample returns_list/length, choices returns_list, BPF==53."
    - "This spec adds: Random.__qualname__, SystemRandom.__qualname__, Random.__bases__[0].__name__ (as 'object' via invariant form), SystemRandom.__bases__[0].__name__=='Random', distribution function __name__ table for gammavariate/lognormvariate/normalvariate not individually covered as invariants."
    - "random.Random.__qualname__ == 'Random' — qualname matches name for a top-level class."
    - "random.SystemRandom.__qualname__ == 'SystemRandom' — qualname matches name for a top-level class."
    - "random.SystemRandom.__bases__[0].__name__ == 'Random' — SystemRandom inherits from Random."
    - "random.gammavariate.__name__ == 'gammavariate' — gamma distribution function."
    - "random.lognormvariate.__name__ == 'lognormvariate' — log-normal distribution function."
    - "random.normalvariate.__name__ == 'normalvariate' — normal distribution (uses Box-Muller)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Random.__qualname__ and SystemRandom.__qualname__
# Not covered in prior specs (which only check __name__ and __module__).
# ---------------------------------------------------------------------------

invariant random_extra5.Random.qualname:
  description: "random.Random.__qualname__ == 'Random' — top-level class qualname matches name"
  category: class_metadata
  kind: python_call_eq
  function: Random.__qualname__.__eq__
  args: ["Random"]
  expected: true

invariant random_extra5.SystemRandom.qualname:
  description: "random.SystemRandom.__qualname__ == 'SystemRandom' — top-level class qualname matches name"
  category: class_metadata
  kind: python_call_eq
  function: SystemRandom.__qualname__.__eq__
  args: ["SystemRandom"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — SystemRandom.__bases__[0].__name__ == 'Random'
# random_extra3 covers Random.__bases__[0].__name__ == 'object'.
# This spec adds the complementary check: SystemRandom inherits from Random.
# ---------------------------------------------------------------------------

invariant random_extra5.SystemRandom.base_is_Random:
  description: "random.SystemRandom.__bases__[0].__name__ == 'Random' — SystemRandom inherits from Random"
  category: hierarchy
  kind: python_call_eq
  function: SystemRandom.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Random"

# ---------------------------------------------------------------------------
# Distribution function __name__ table
# random_extra3 and random_extra4 cover: gauss, expovariate, betavariate,
# triangular, normalvariate (random_extra: normalvariate), seed, etc.
# This table groups the remaining distribution functions not covered as
# standalone invariants: gammavariate, lognormvariate.
# Also adds normalvariate as a standalone invariant for traceability.
# ---------------------------------------------------------------------------

table random_extra5.distribution_function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: dist_fname

  columns: [id, function, args, expected]
  rows:
    - [gammavariate,   gammavariate.__name__.__eq__,   ["gammavariate"],   true]
    - [lognormvariate, lognormvariate.__name__.__eq__, ["lognormvariate"], true]
    - [normalvariate,  normalvariate.__name__.__eq__,  ["normalvariate"],  true]

# ---------------------------------------------------------------------------
# __module__ checks for distribution functions not covered in prior specs
# random_extra4 covers gauss/uniform/choices/etc. modules via table only
# if present; random_extra3 focuses on name checks. We add __module__ for
# the less-commonly-tested distribution functions.
# ---------------------------------------------------------------------------

invariant random_extra5.gammavariate.module:
  description: "random.gammavariate.__module__ == 'random'"
  category: function_modules
  kind: python_call_eq
  function: gammavariate.__module__.__eq__
  args: ["random"]
  expected: true

invariant random_extra5.lognormvariate.module:
  description: "random.lognormvariate.__module__ == 'random'"
  category: function_modules
  kind: python_call_eq
  function: lognormvariate.__module__.__eq__
  args: ["random"]
  expected: true

invariant random_extra5.normalvariate.module:
  description: "random.normalvariate.__module__ == 'random'"
  category: function_modules
  kind: python_call_eq
  function: normalvariate.__module__.__eq__
  args: ["random"]
  expected: true

# ---------------------------------------------------------------------------
# Random.__module__ as invariant (random_extra4 covers this in table form;
# this adds an explicit invariant for individual traceability).
# Actually random_extra4 already has an invariant — skip to avoid dup.
# Instead, add __qualname__ for gauss/expovariate/betavariate.
# ---------------------------------------------------------------------------

invariant random_extra5.gauss.qualname:
  description: "random.gauss.__qualname__ == 'gauss'"
  category: function_metadata
  kind: python_call_eq
  function: gauss.__qualname__.__eq__
  args: ["gauss"]
  expected: true

invariant random_extra5.expovariate.qualname:
  description: "random.expovariate.__qualname__ == 'expovariate'"
  category: function_metadata
  kind: python_call_eq
  function: expovariate.__qualname__.__eq__
  args: ["expovariate"]
  expected: true

invariant random_extra5.betavariate.qualname:
  description: "random.betavariate.__qualname__ == 'betavariate'"
  category: function_metadata
  kind: python_call_eq
  function: betavariate.__qualname__.__eq__
  args: ["betavariate"]
  expected: true
