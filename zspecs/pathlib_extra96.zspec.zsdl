spec: pathlib_extra96
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra95

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra95."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount; PurePath/__name__/__module__/__bases__/__mro__; PosixPath identity; Path/__init__/__new__ co_name and co_argcount; Path.is_dir/is_file/is_symlink/etc __code__ attributes; Path/__dict__.__contains__; Path/__qualname__/__name__/__module__; Path method __qualname__ string equality; Path method __qualname__ string lengths."
    - "This spec covers: pathlib.Path class hierarchy — __bases__[0].__name__, __mro__.__len__(), and PurePath identity checks. In Python 3.12+, Path inherits directly from PurePath (no intermediate PurePosixPath/PureWindowsPath in the MRO for Path itself)."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath inherits directly from object."
    - "pathlib.PurePath.__mro__.__len__() == 2 — MRO: [PurePath, object]."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath inherits from PurePath."
    - "pathlib.PurePosixPath.__mro__.__len__() == 3 — MRO: [PurePosixPath, PurePath, object]."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — In Python 3.12+, Path inherits from PurePath directly."
    - "pathlib.Path.__mro__.__len__() == 3 — MRO: [Path, PurePath, object]."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits from Path."
    - "pathlib.PosixPath.__mro__.__len__() == 5 — MRO: [PosixPath, Path, PurePosixPath, PurePath, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath hierarchy: __name__, __module__, __bases__[0].__name__, __mro__.__len__()
# PurePath is the root of the pathlib hierarchy; it inherits from object.
# PurePath.__mro__ == [PurePath, object], so __mro__.__len__() == 2.
# ---------------------------------------------------------------------------

table pathlib_extra96.PurePath_hierarchy:
  description: "pathlib.PurePath __name__/__module__/__bases__[0].__name__/__mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibhier96

  columns: [id, function, args, expected]
  rows:
    - [purepath_name,        PurePath.__name__.__eq__,                 ["PurePath"], true]
    - [purepath_module,      PurePath.__module__.__eq__,               ["pathlib"],  true]
    - [purepath_base0,       "PurePath.__bases__[0].__name__.__eq__",  ["object"],   true]
    - [purepath_mro_len,     PurePath.__mro__.__len__,                 [],           2]

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath hierarchy: __bases__[0].__name__ and __mro__.__len__()
# PurePosixPath inherits from PurePath; MRO: [PurePosixPath, PurePath, object].
# ---------------------------------------------------------------------------

table pathlib_extra96.PurePosixPath_hierarchy:
  description: "pathlib.PurePosixPath __bases__[0].__name__ and __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibhier96

  columns: [id, function, args, expected]
  rows:
    - [pureposix_name,       PurePosixPath.__name__.__eq__,                ["PurePosixPath"], true]
    - [pureposix_module,     PurePosixPath.__module__.__eq__,              ["pathlib"],        true]
    - [pureposix_base0,      "PurePosixPath.__bases__[0].__name__.__eq__", ["PurePath"],       true]
    - [pureposix_mro_len,    PurePosixPath.__mro__.__len__,                [],                 3]

# ---------------------------------------------------------------------------
# pathlib.Path hierarchy: __bases__[0].__name__ and __mro__.__len__()
# In Python 3.12+, Path inherits directly from PurePath (no OS-specific base).
# MRO: [Path, PurePath, object], so __mro__.__len__() == 3.
# ---------------------------------------------------------------------------

table pathlib_extra96.Path_hierarchy:
  description: "pathlib.Path __bases__[0].__name__ and __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibhier96

  columns: [id, function, args, expected]
  rows:
    - [path_name,            Path.__name__.__eq__,                ["Path"],     true]
    - [path_module,          Path.__module__.__eq__,              ["pathlib"],  true]
    - [path_base0,           "Path.__bases__[0].__name__.__eq__", ["PurePath"], true]
    - [path_mro_len,         Path.__mro__.__len__,                [],           3]

# ---------------------------------------------------------------------------
# pathlib.PosixPath hierarchy: __bases__[0].__name__ and __mro__.__len__()
# PosixPath inherits from Path; MRO: [PosixPath, Path, PurePosixPath, PurePath, object].
# __mro__.__len__() == 5.
# ---------------------------------------------------------------------------

table pathlib_extra96.PosixPath_hierarchy:
  description: "pathlib.PosixPath __bases__[0].__name__ and __mro__.__len__(); cross-checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibhier96

  columns: [id, function, args, expected]
  rows:
    - [posixpath_name,       PosixPath.__name__.__eq__,                ["PosixPath"], true]
    - [posixpath_module,     PosixPath.__module__.__eq__,              ["pathlib"],   true]
    - [posixpath_base0,      "PosixPath.__bases__[0].__name__.__eq__", ["Path"],      true]
    - [posixpath_mro_len,    PosixPath.__mro__.__len__,                [],            5]
    - [purepath_mro_lt_path, PurePath.__mro__.__len__,                 [],            2]
    - [path_mro_lt_posix,    Path.__mro__.__len__,                     [],            3]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra96.PurePath.base0_name:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' (PurePath is the root; inherits directly from object)"
  category: class_identity
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra96.PurePath.mro_len:
  description: "pathlib.PurePath.__mro__.__len__() == 2 (MRO: [PurePath, object])"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra96.Path.base0_name:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' (Python 3.12+: Path inherits from PurePath directly)"
  category: class_identity
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra96.Path.mro_len:
  description: "pathlib.Path.__mro__.__len__() == 3 (MRO: [Path, PurePath, object])"
  category: class_identity
  kind: python_call_eq
  function: Path.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra96.PosixPath.mro_len:
  description: "pathlib.PosixPath.__mro__.__len__() == 5 (MRO: [PosixPath, Path, PurePosixPath, PurePath, object])"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__mro__.__len__
  args: []
  expected: 5
