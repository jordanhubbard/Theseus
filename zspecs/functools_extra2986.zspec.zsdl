spec: ft2986
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (ft2986): __len__, __length_hint__, __contains__ dict-presence checks for functools types."
    - "functools classes are not container or sequence types — none define len, length_hint, or contains (container/sequence protocol) operators."
    - "Verified types: functools.partial, functools.partialmethod, functools.cached_property, functools._lru_cache_wrapper, functools._CacheInfo, functools.singledispatch."
    - "functools._lru_cache_wrapper is the C-level wrapper type produced by functools.lru_cache()."
    - "functools._CacheInfo is the namedtuple class for lru_cache statistics; namedtuples inherit __len__ and __contains__ from tuple but do not define them in their own __dict__."
    - "functools.singledispatch is the dispatch decorator function; its __dict__ is that of a plain function."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft2986.len:
  description: "functools types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2986
  columns: [id, function, args, expected]
  rows:
    - ["ft2986001", operator.contains, [functools.partial.__dict__,              "__len__"], false]
    - ["ft2986002", operator.contains, [functools.partialmethod.__dict__,        "__len__"], false]
    - ["ft2986003", operator.contains, [functools.cached_property.__dict__,      "__len__"], false]
    - ["ft2986004", operator.contains, [functools._lru_cache_wrapper.__dict__,   "__len__"], false]
    - ["ft2986005", operator.contains, [functools._CacheInfo.__dict__,           "__len__"], false]
    - ["ft2986006", operator.contains, [functools.singledispatch.__dict__,       "__len__"], false]

