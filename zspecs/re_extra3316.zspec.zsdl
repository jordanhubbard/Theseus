spec: re3316
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (re3316): __ipow__, __ilshift__, __irshift__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __ipow__, __ilshift__, __irshift__ dict-presence (in-place **=, <<=, >>=)."
    - "No re class defines __ipow__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; exponentiation has no meaning for them."
    - "No re class defines __ilshift__ in its own __dict__: re types are not numeric or bitwise operands; in-place left-shift is not defined on any re type."
    - "No re class defines __irshift__ in its own __dict__: in-place right-shift is not defined on any re type."
    - "re.RegexFlag is defined as class RegexFlag(enum.IntFlag): the in-place augmented assignment methods __ipow__, __ilshift__, __irshift__ are not defined in re.RegexFlag.__dict__ itself; flag composition uses | not **= or <<= or >>=."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with waves 666/667 pattern: all in-place arithmetic/bitwise operators absent from re class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — operator.contains(Cls.__dict__, '__ipow__')
#
# No re class defines __ipow__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but in-place exponentiation is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3316.ipow:
  description: "re types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3316

  columns: [id, function, args, expected]
  rows:
    - ["re3316001", operator.contains, [re.Pattern.__dict__,   "__ipow__"], false]
    - ["re3316002", operator.contains, [re.Match.__dict__,     "__ipow__"], false]
    - ["re3316003", operator.contains, [re.RegexFlag.__dict__, "__ipow__"], false]

# ---------------------------------------------------------------------------
# __ilshift__ dict-presence — operator.contains(Cls.__dict__, '__ilshift__')
#
# No re class defines __ilshift__ in its own __dict__; all false.
# re types are not numeric or bitwise operands; in-place left-shift is not part
# of the re type protocol. re.RegexFlag (IntFlag) does not define __ilshift__
# in its own __dict__.
# ---------------------------------------------------------------------------

