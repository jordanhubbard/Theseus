spec: pathlib_extra9
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "This spec extends pathlib.zspec.zsdl through pathlib_extra8.zspec.zsdl."
    - "Focus: __qualname__ attributes for pathlib classes and additional PurePosixPath property vectors."
    - "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath'."
    - "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath'."
    - "pathlib.PosixPath.__qualname__ == 'PosixPath'."
    - "pathlib.Path.__qualname__ == 'Path'."
    - "pathlib.PurePath.__qualname__ == 'PurePath'."
    - "pathlib.PurePosixPath('/a/b/c').name == 'c'."
    - "pathlib.PurePosixPath('/a/b/c').stem == 'c'."
    - "pathlib.PurePosixPath('/a/b/c.txt').suffix == '.txt'."
    - "pathlib.PurePosixPath('/a/b/c.tar.gz').suffixes == ['.tar', '.gz']."
    - "pathlib.PurePosixPath('/a/b/c').root == '/'."
    - "pathlib.PurePosixPath('/a/b/c').drive == '' (no drive letter on POSIX paths)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for pathlib classes
# Prior specs cover __name__ and __module__; this covers __qualname__.
# ---------------------------------------------------------------------------

table pathlib_extra9.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [PurePath,        PurePath.__qualname__.__eq__,        ["PurePath"],        true]
    - [PurePosixPath,   PurePosixPath.__qualname__.__eq__,   ["PurePosixPath"],   true]
    - [PureWindowsPath, PureWindowsPath.__qualname__.__eq__, ["PureWindowsPath"], true]
    - [PosixPath,       PosixPath.__qualname__.__eq__,       ["PosixPath"],       true]
    - [Path,            Path.__qualname__.__eq__,            ["Path"],            true]

# ---------------------------------------------------------------------------
# PurePosixPath('/a/b/c') — .name, .stem, .root, .drive properties
# ---------------------------------------------------------------------------

invariant pathlib_extra9.PurePosixPath.name_no_ext:
  description: "pathlib.PurePosixPath('/a/b/c').name == 'c'"
  category: PurePosixPath_properties
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: name.__eq__
  method_args: ["c"]
  expected: true

invariant pathlib_extra9.PurePosixPath.stem_no_ext:
  description: "pathlib.PurePosixPath('/a/b/c').stem == 'c'"
  category: PurePosixPath_properties
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: stem.__eq__
  method_args: ["c"]
  expected: true

invariant pathlib_extra9.PurePosixPath.root_slash:
  description: "pathlib.PurePosixPath('/a/b/c').root == '/'"
  category: PurePosixPath_properties
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: root.__eq__
  method_args: ["/"]
  expected: true

invariant pathlib_extra9.PurePosixPath.drive_empty:
  description: "pathlib.PurePosixPath('/a/b/c').drive == '' — no drive letter on POSIX paths"
  category: PurePosixPath_properties
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: drive.__eq__
  method_args: [""]
  expected: true

# ---------------------------------------------------------------------------
# PurePosixPath('/a/b/c.txt') — .suffix
# ---------------------------------------------------------------------------

invariant pathlib_extra9.PurePosixPath.suffix_txt:
  description: "pathlib.PurePosixPath('/a/b/c.txt').suffix == '.txt'"
  category: PurePosixPath_properties
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: suffix.__eq__
  method_args: [".txt"]
  expected: true

# ---------------------------------------------------------------------------
# PurePosixPath('/a/b/c.tar.gz') — .suffixes list
# ---------------------------------------------------------------------------

invariant pathlib_extra9.PurePosixPath.suffixes_tar_gz:
  description: "pathlib.PurePosixPath('/a/b/c.tar.gz').suffixes == ['.tar', '.gz']"
  category: PurePosixPath_properties
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.tar.gz"]
  method: suffixes.__eq__
  method_args: [[".tar", ".gz"]]
  expected: true
