spec: functools_extra1996
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "functools.partial, functools.partialmethod, functools.cached_property are not numeric types — none define integer or float conversion protocols."
    - "None of the functools classes define __index__ — they are not integer-like types."
    - "None of the functools classes define __complex__ or __float__ — no numeric conversion protocols."
    - "None of the functools classes define __round__ or __abs__ — no rounding or absolute value protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra1996.index_protocol:
  description: "functools types __index__ dict-presence checks — none define integer conversion protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft1996
  columns: [id, function, args, expected]
  rows:
    - ["ft1996001", "functools.partial.__dict__.__contains__",         ["__index__"], false]
    - ["ft1996002", "functools.partialmethod.__dict__.__contains__",   ["__index__"], false]
    - ["ft1996003", "functools.cached_property.__dict__.__contains__", ["__index__"], false]

