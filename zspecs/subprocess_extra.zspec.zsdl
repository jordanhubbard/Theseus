spec: subprocess_extra
version: ">=3.5"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/subprocess.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "subprocess source: internal platform-specific Popen implementation details"
    - "subprocess.zspec.zsdl — covers class names, function names, PIPE/STDOUT/DEVNULL values, run(), check_output(), exception hierarchy via __mro__"
    - "subprocess_popen.zspec.zsdl — covers CompletedProcess/TimeoutExpired constructor semantics, Popen live attributes"
  notes:
    - "This spec extends subprocess.zspec.zsdl and subprocess_popen.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "subprocess.zspec.zsdl covers: class names (__name__), function names (__name__), PIPE/STDOUT/DEVNULL integer values, run()/check_output() execution, CalledProcessError/TimeoutExpired MRO via __mro__[1]."
    - "subprocess_popen.zspec.zsdl covers: CompletedProcess constructor attrs, TimeoutExpired constructor attrs, Popen pid/returncode/wait."
    - "CompletedProcess.__module__ == 'subprocess' — it is a pure-Python class defined in subprocess.py."
    - "SubprocessError.__bases__[0].__name__ == 'Exception' — SubprocessError is a direct Exception subclass."
    - "CalledProcessError.__bases__[0].__name__ == 'SubprocessError' — direct subclass relationship."
    - "TimeoutExpired.__bases__[0].__name__ == 'SubprocessError' — direct subclass relationship."
    - "PIPE == -1, STDOUT == -2, DEVNULL == -3 are plain ints; __class__.__name__ == 'int'."
    - "subprocess.run, call, check_call, check_output, getoutput, getstatusoutput are plain functions; __class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Functions raise subprocess.CalledProcessError on non-zero exit when check=True, subprocess.TimeoutExpired on timeout, and OSError/FileNotFoundError if the executable is not found."
  stderr: "null"
  stickiness: "N/A — class and constant checks are stateless attribute reads."
  codes: {}

# ---------------------------------------------------------------------------
# Module checks — CompletedProcess is a pure-Python class in subprocess
# subprocess.zspec.zsdl tests __name__ but not __module__
# ---------------------------------------------------------------------------

invariant subprocess_extra.CompletedProcess.module:
  description: "subprocess.CompletedProcess.__module__ == 'subprocess'"
  category: modules
  kind: python_call_eq
  function: CompletedProcess.__module__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra.SubprocessError.module:
  description: "subprocess.SubprocessError.__module__ == 'subprocess'"
  category: modules
  kind: python_call_eq
  function: SubprocessError.__module__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra.CalledProcessError.module:
  description: "subprocess.CalledProcessError.__module__ == 'subprocess'"
  category: modules
  kind: python_call_eq
  function: CalledProcessError.__module__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra.TimeoutExpired.module:
  description: "subprocess.TimeoutExpired.__module__ == 'subprocess'"
  category: modules
  kind: python_call_eq
  function: TimeoutExpired.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — direct __bases__[0] checks
# subprocess.zspec.zsdl tests hierarchy via __mro__[1]; this spec uses
# __bases__.__getitem__(0) for the same relationships (orthogonal approach).
# ---------------------------------------------------------------------------

invariant subprocess_extra.SubprocessError.base:
  description: "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: SubprocessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant subprocess_extra.CalledProcessError.base:
  description: "subprocess.CalledProcessError.__bases__[0].__name__ == 'SubprocessError'"
  category: hierarchy
  kind: python_call_eq
  function: CalledProcessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SubprocessError"

invariant subprocess_extra.TimeoutExpired.base:
  description: "subprocess.TimeoutExpired.__bases__[0].__name__ == 'SubprocessError'"
  category: hierarchy
  kind: python_call_eq
  function: TimeoutExpired.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SubprocessError"

# ---------------------------------------------------------------------------
# PIPE, STDOUT, DEVNULL — class name checks
# subprocess.zspec.zsdl tests their integer values (-1, -2, -3);
# this spec verifies their Python type name is 'int'.
# ---------------------------------------------------------------------------

table subprocess_extra.sentinel_class_names:
  kind: python_call_eq
  category: constants
  id_prefix: sentinel_class

  columns: [id, function, args, expected]
  rows:
    - [pipe,    PIPE.__class__.__name__.__eq__,    ["int"], true]
    - [stdout,  STDOUT.__class__.__name__.__eq__,  ["int"], true]
    - [devnull, DEVNULL.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# Top-level function type checks — verify these are plain Python functions
# subprocess.zspec.zsdl verifies __name__; this spec verifies __class__.__name__
# ---------------------------------------------------------------------------

table subprocess_extra.function_class_names:
  kind: python_call_eq
  category: function_types
  id_prefix: functype

  columns: [id, function, args, expected]
  rows:
    - [run,              run.__class__.__name__.__eq__,              ["function"], true]
    - [call,             call.__class__.__name__.__eq__,             ["function"], true]
    - [check_call,       check_call.__class__.__name__.__eq__,       ["function"], true]
    - [check_output,     check_output.__class__.__name__.__eq__,     ["function"], true]
    - [getoutput,        getoutput.__class__.__name__.__eq__,        ["function"], true]
    - [getstatusoutput,  getstatusoutput.__class__.__name__.__eq__,  ["function"], true]
