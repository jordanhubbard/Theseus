spec: abc_extra378
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "abc.ABCMeta lives in module abc and derives from type"
    - "abc.ABC lives in module abc and derives from object"
    - "abc.abstractmethod lives in module abc"
    - "abc.abstractclassmethod lives in module abc (deprecated since Python 3.3 but still present in 3.14)"
    - "abc.get_cache_token lives in module _abc (C extension)"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra378.class_names:
  description: "Verify __name__ attribute of abc.ABCMeta and abc.ABC"
  kind: python_call_eq
  category: identity
  id_prefix: abc378n

  columns: [id, function, args, expected]
  rows:
    - [abc378n001, abc.ABCMeta.__name__.__eq__, ["ABCMeta"], true]
    - [abc378n002, abc.ABC.__name__.__eq__, ["ABC"], true]

table abc_extra378.class_modules:
  description: "Verify __module__ attribute of abc.ABCMeta and abc.ABC"
  kind: python_call_eq
  category: identity
  id_prefix: abc378m

  columns: [id, function, args, expected]
  rows:
    - [abc378m001, abc.ABCMeta.__module__.__eq__, ["abc"], true]
    - [abc378m002, abc.ABC.__module__.__eq__, ["abc"], true]

table abc_extra378.class_bases:
  description: "Verify __bases__[0].__name__ (first immediate base class name) of abc.ABCMeta and abc.ABC"
  kind: python_call_eq
  category: identity
  id_prefix: abc378b

  columns: [id, function, args, expected]
  rows:
    - ["abc378b001", "abc.ABCMeta.__bases__[0].__name__.__eq__", ["type"], true]
    - ["abc378b002", "abc.ABC.__bases__[0].__name__.__eq__", ["object"], true]

table abc_extra378.function_names:
  description: "Verify __name__ attribute of abc module functions and decorators"
  kind: python_call_eq
  category: identity
  id_prefix: abc378fn

  columns: [id, function, args, expected]
  rows:
    - [abc378fn001, abc.abstractmethod.__name__.__eq__, ["abstractmethod"], true]
    - [abc378fn002, abc.abstractclassmethod.__name__.__eq__, ["abstractclassmethod"], true]
    - [abc378fn003, abc.get_cache_token.__name__.__eq__, ["get_cache_token"], true]

table abc_extra378.function_modules:
  description: "Verify __module__ attribute of abc module functions and decorators"
  kind: python_call_eq
  category: identity
  id_prefix: abc378fm

  columns: [id, function, args, expected]
  rows:
    - [abc378fm001, abc.abstractmethod.__module__.__eq__, ["abc"], true]
    - [abc378fm002, abc.abstractclassmethod.__module__.__eq__, ["abc"], true]
    - [abc378fm003, abc.get_cache_token.__module__.__eq__, ["_abc"], true]
