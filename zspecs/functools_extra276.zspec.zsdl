spec: functools_extra276
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.update_wrapper and functools.wraps are pure-Python functions defined in Lib/functools.py."
    - "update_wrapper.__name__=='update_wrapper'(16 longest); wraps.__name__=='wraps'(5 shortest); singledispatch.__name__=='singledispatch'(14)."
    - "functools.reduce.__module__ == '_functools' (C extension); all other checked functions have __module__ == 'functools'."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key'; functools.singledispatch.__qualname__ == 'singledispatch'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools @wraps and @update_wrapper — function attribute identity (part 1)
#
# update_wrapper(16) and wraps(5) are pure-Python functions in functools.
# reduce.__module__ == '_functools' (C extension module).
# All four (update_wrapper, wraps, reduce, cmp_to_key) are 'function' class.
# ---------------------------------------------------------------------------

table functools_extra276.wraps_update_wrapper_identity:
  description: "functools.update_wrapper and functools.wraps function identity — __name__, __module__, __class__.__name__, __qualname__; reduce.__module__ == '_functools' (C ext); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex276wu

  columns: [id, function, args, expected, description]
  rows:
    - [uw_name_eq,             update_wrapper.__name__.__eq__,              ["update_wrapper"],             true, "functools.update_wrapper.__name__ == 'update_wrapper' (len=16 — longest name in table); verified with Python 3.14.3"]
    - [uw_name_len,            update_wrapper.__name__.__len__,             [],                             16,   "functools.update_wrapper.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [uw_mod_eq,              update_wrapper.__module__.__eq__,            ["functools"],                  true, "functools.update_wrapper.__module__ == 'functools'; verified with Python 3.14.3"]
    - [uw_cls_eq,              update_wrapper.__class__.__name__.__eq__,    ["function"],                   true, "functools.update_wrapper.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [uw_qn_eq,               update_wrapper.__qualname__.__eq__,          ["update_wrapper"],             true, "functools.update_wrapper.__qualname__ == 'update_wrapper'; verified with Python 3.14.3"]
    - [wr_name_eq,             wraps.__name__.__eq__,                       ["wraps"],                      true, "functools.wraps.__name__ == 'wraps' (len=5 — shortest name in table); verified with Python 3.14.3"]
    - [wr_name_len,            wraps.__name__.__len__,                      [],                             5,    "functools.wraps.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [wr_mod_eq,              wraps.__module__.__eq__,                     ["functools"],                  true, "functools.wraps.__module__ == 'functools'; verified with Python 3.14.3"]
    - [wr_cls_eq,              wraps.__class__.__name__.__eq__,             ["function"],                   true, "functools.wraps.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [wr_qn_eq,               wraps.__qualname__.__eq__,                   ["wraps"],                      true, "functools.wraps.__qualname__ == 'wraps'; verified with Python 3.14.3"]
    - [rd_mod_eq,              reduce.__module__.__eq__,                    ["_functools"],                 true, "functools.reduce.__module__ == '_functools' (C extension module, not 'functools'); verified with Python 3.14.3"]
    - [rd_mod_len,             reduce.__module__.__len__,                   [],                             10,   "functools.reduce.__module__.__len__() == 10 — '_functools' has 10 chars; verified with Python 3.14.3"]
    - [rd_qn_eq,               reduce.__qualname__.__eq__,                  ["reduce"],                     true, "functools.reduce.__qualname__ == 'reduce'; verified with Python 3.14.3"]
    - [ck_qn_eq,               cmp_to_key.__qualname__.__eq__,              ["cmp_to_key"],                 true, "functools.cmp_to_key.__qualname__ == 'cmp_to_key'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools singledispatch identity
#
# singledispatch.__qualname__ == 'singledispatch' (len=14);
# singledispatch.__module__ == 'functools';
# singledispatch.__class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table functools_extra276.singledispatch_identity:
  description: "functools.singledispatch function identity — __name__, __module__, __qualname__, __class__.__name__; name len=14; module is 'functools'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex276sd

  columns: [id, function, args, expected, description]
  rows:
    - [sd_name_eq,             singledispatch.__name__.__eq__,              ["singledispatch"],             true, "functools.singledispatch.__name__ == 'singledispatch' (len=14); verified with Python 3.14.3"]
    - [sd_name_len,            singledispatch.__name__.__len__,             [],                             14,   "functools.singledispatch.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [sd_mod_eq,              singledispatch.__module__.__eq__,            ["functools"],                  true, "functools.singledispatch.__module__ == 'functools'; verified with Python 3.14.3"]
    - [sd_cls_eq,              singledispatch.__class__.__name__.__eq__,    ["function"],                   true, "functools.singledispatch.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [sd_qn_eq,               singledispatch.__qualname__.__eq__,          ["singledispatch"],             true, "functools.singledispatch.__qualname__ == 'singledispatch'; verified with Python 3.14.3"]
    - [sd_qn_len,              singledispatch.__qualname__.__len__,         [],                             14,   "functools.singledispatch.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [uw_name_len_is_longest, update_wrapper.__name__.__len__,             [],                             16,   "functools.update_wrapper.__name__.__len__() == 16 — longer than singledispatch(14) and cmp_to_key(10); verified with Python 3.14.3"]
    - [ck_name_len,            cmp_to_key.__name__.__len__,                 [],                             10,   "functools.cmp_to_key.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ck_mod_eq,              cmp_to_key.__module__.__eq__,                ["functools"],                  true, "functools.cmp_to_key.__module__ == 'functools'; verified with Python 3.14.3"]
    - [ck_cls_eq,              cmp_to_key.__class__.__name__.__eq__,        ["function"],                   true, "functools.cmp_to_key.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra276
# ---------------------------------------------------------------------------

invariant functools_extra276.update_wrapper_name_is_update_wrapper:
  description: "functools.update_wrapper.__name__ == 'update_wrapper' (len=16) — function name matches export name"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra276.update_wrapper_module_is_functools:
  description: "functools.update_wrapper.__module__ == 'functools' — defined in the pure-Python functools module"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra276.update_wrapper_class_is_function:
  description: "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is a pure-Python function"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra276.wraps_name_is_wraps:
  description: "functools.wraps.__name__ == 'wraps' (len=5) — function name matches export name"
  category: identity
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra276.reduce_module_is_c_functools:
  description: "functools.reduce.__module__ == '_functools' — reduce is implemented in the C extension _functools, not the pure-Python functools"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra276.singledispatch_module_is_functools:
  description: "functools.singledispatch.__module__ == 'functools' — singledispatch is defined in pure-Python functools"
  category: identity
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra276.singledispatch_qualname_is_singledispatch:
  description: "functools.singledispatch.__qualname__ == 'singledispatch' (len=14) — qualname matches simple name for module-level function"
  category: identity
  kind: python_call_eq
  function: singledispatch.__qualname__.__eq__
  args: ["singledispatch"]
  expected: true
