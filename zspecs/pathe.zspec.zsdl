spec: pathe
version: ">=2.0.0"
backend: node(pathe)

docs: https://github.com/unjs/pathe#readme

provenance:
  derived_from:
    - "pathe README — https://github.com/unjs/pathe#readme"
    - "Node.js path module documentation — https://nodejs.org/api/path.html"
    - "Test vectors verified with pathe via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "pathe source"
  notes:
    - "Universal path module — like Node's 'path' but always uses forward slashes (POSIX style) regardless of OS."
    - "Install: npm install pathe"
    - "v2 ESM only; named exports basename / dirname / extname / join / resolve / normalize / parse / format / relative / isAbsolute."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; throw on non-string inputs."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant pathe.join_simple:
  description: "join('/foo', 'bar') is '/foo/bar'"
  category: join
  kind: node_chain_eq
  entry: named
  function: join
  entry_args: ["/foo", "bar"]
  chain: []
  expected: "/foo/bar"

invariant pathe.basename_with_ext:
  description: "basename('/foo/bar.txt') is 'bar.txt'"
  category: basename
  kind: node_chain_eq
  entry: named
  function: basename
  entry_args: ["/foo/bar.txt"]
  chain: []
  expected: "bar.txt"

invariant pathe.dirname_simple:
  description: "dirname('/foo/bar.txt') is '/foo'"
  category: dirname
  kind: node_chain_eq
  entry: named
  function: dirname
  entry_args: ["/foo/bar.txt"]
  chain: []
  expected: "/foo"

invariant pathe.extname_simple:
  description: "extname('foo.txt') is '.txt'"
  category: extname
  kind: node_chain_eq
  entry: named
  function: extname
  entry_args: ["foo.txt"]
  chain: []
  expected: ".txt"

invariant pathe.normalize_windows_to_forward:
  description: "Windows-style backslashes converted to forward (POSIX) — pathe core feature"
  category: normalize
  kind: node_chain_eq
  entry: named
  function: normalize
  entry_args: ["C:\\Users\\foo"]
  chain: []
  expected: "C:/Users/foo"

invariant pathe.normalize_relative_collapse:
  description: "normalize('./a/../b') collapses to 'b'"
  category: normalize
  kind: node_chain_eq
  entry: named
  function: normalize
  entry_args: ["./a/../b"]
  chain: []
  expected: "b"

invariant pathe.isAbsolute_true:
  description: "isAbsolute('/foo') is true"
  category: isAbsolute
  kind: node_chain_eq
  entry: named
  function: isAbsolute
  entry_args: ["/foo"]
  chain: []
  expected: true

invariant pathe.isAbsolute_false:
  description: "isAbsolute('foo') is false"
  category: isAbsolute
  kind: node_chain_eq
  entry: named
  function: isAbsolute
  entry_args: ["foo"]
  chain: []
  expected: false

invariant pathe.parse_returns_components:
  description: "parse('/foo/bar.txt').name is 'bar' (extension stripped)"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["/foo/bar.txt"]
  chain:
    - {get: name}
  expected: "bar"

invariant pathe.parse_root:
  description: "parse('/foo/bar.txt').root is '/'"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["/foo/bar.txt"]
  chain:
    - {get: root}
  expected: "/"

invariant pathe.format_round_trip:
  description: "format({dir,name,ext}) reconstructs path"
  category: format
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: [{dir: "/foo", name: "bar", ext: ".txt"}]
  chain: []
  expected: "/foo/bar.txt"
