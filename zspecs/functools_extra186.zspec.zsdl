spec: functools_extra186
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.cache and functools.cached_property identity attributes — functools.cache.__name__=='cache' (len=5); functools.cache.__module__=='functools'; functools.cache.__qualname__=='cache' (len=5; equals __name__); functools.cached_property.__name__=='cached_property' (len=15); functools.cached_property.__module__=='functools'; functools.cached_property.__qualname__=='cached_property' (len=15; equals __name__); functools.lru_cache.__name__=='lru_cache' (len=9); functools.lru_cache.__qualname__=='lru_cache'."
    - "functools.cache.__name__ == 'cache' — cache is a simple unbounded LRU cache wrapper introduced in Python 3.9 (equivalent to lru_cache(maxsize=None)); it is a Python function defined in Lib/functools.py with __name__ 'cache', 5 characters. Verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools' — cache is defined in the pure-Python functools module (Lib/functools.py); its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache' — cache is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'cache', 5 characters. Verified with Python 3.14.3."
    - "functools.cached_property.__name__ == 'cached_property' — cached_property is a descriptor class in Lib/functools.py that computes the property once and caches the result in the instance __dict__; its __name__ is 'cached_property', 15 characters. Verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools' — cached_property is defined in the pure-Python functools module; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__ == 'cached_property' — cached_property is a module-level class (not nested), so __qualname__ equals __name__ 'cached_property', 15 characters. Verified with Python 3.14.3."
    - "functools.lru_cache.__name__ == 'lru_cache' — lru_cache is a Python decorator in Lib/functools.py providing a least-recently-used cache; its __name__ is 'lru_cache', 9 characters. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' — lru_cache is a module-level Python function so __qualname__ equals __name__ 'lru_cache'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

