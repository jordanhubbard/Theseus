spec: calendar_extra5
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec extends calendar.zspec.zsdl and calendar_extra through calendar_extra4.zspec.zsdl."
    - "calendar.zspec.zsdl covers: isleap table (2000/2024/1900/2100/2023/2026), weekday(2026-04-08/2024-01-01/2024-02-29), leapdays(2000-2025/2000-2001/1900-1901), month_name[1/6/12], month_abbr[1/12], day_name[0/4/6], day_abbr[0/6], constants MONDAY/WEDNESDAY/SUNDAY/JANUARY/DECEMBER."
    - "calendar_extra covers: Calendar/__name__/__module__, TextCalendar/__name__/__bases__, HTMLCalendar/__name__/__bases__, isleap/__name__ and selected values, leapdays(2000,2024)==6, month_name class, weekheader, MONDAY/SUNDAY constants."
    - "calendar_extra2 covers: Calendar/__name__, TextCalendar/__name__, HTMLCalendar/__name__, MONDAY/SUNDAY values, month_name class, isleap(2000)/isleap(1900), leapdays(2000,2001)."
    - "calendar_extra3 covers: __qualname__ for Calendar/TextCalendar/HTMLCalendar/LocaleTextCalendar/isleap/monthrange/weekday, MONDAY/SUNDAY class base is int, __module__ for isleap and Calendar, isleap(2024)/isleap(2023), monthrange(2024,1)[0]==0."
    - "calendar_extra4 covers: Calendar/__name__/__module__/__qualname__ anchors, TextCalendar/__name__, HTMLCalendar/__name__, LocaleTextCalendar/__name__, LocaleHTMLCalendar/__name__."
    - "Focus: new day constants (TUESDAY/THURSDAY/SATURDAY), new month names (February/April/September abbreviation), monthrange Feb 2024 leap-year results, weekday(2000,1,1) and (2026,4,9), leapdays(2020,2025), isleap(1996)."
    - "calendar.TUESDAY == 1 — IntEnum Day value for Tuesday (not in any prior spec)."
    - "calendar.THURSDAY == 3 — IntEnum Day value for Thursday."
    - "calendar.SATURDAY == 5 — IntEnum Day value for Saturday."
    - "calendar.month_name[2] == 'February' and month_name[4] == 'April' — not in any prior spec."
    - "calendar.month_abbr[9] == 'Sep' — not in any prior spec."
    - "calendar.monthrange(2024, 2) — Feb in a leap year: first weekday Thursday (3), 29 days."
    - "calendar.monthrange(2023, 2)[1] == 28 — Feb in a non-leap year has 28 days."
    - "calendar.weekday(2000, 1, 1) == 5 — January 1, 2000 was a Saturday."
    - "calendar.weekday(2026, 4, 9) == 3 — April 9, 2026 is a Thursday."
    - "calendar.leapdays(2020, 2025) == 2 — leap years 2020 and 2024 in range [2020, 2025)."
    - "calendar.isleap(1996) == True — 1996 divisible by 4 and not by 100."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Constants — TUESDAY, THURSDAY, SATURDAY
#
# calendar.zspec.zsdl covers MONDAY(0), WEDNESDAY(2), SUNDAY(6).
# No prior spec covers TUESDAY, THURSDAY, or SATURDAY.
# ---------------------------------------------------------------------------

table calendar_extra5.constants.day_values:
  kind: python_call_eq
  category: constants
  id_prefix: dayval

  columns: [id, function, args, expected]
  rows:
    - [TUESDAY,  TUESDAY.__eq__,  [1], true]
    - [THURSDAY, THURSDAY.__eq__, [3], true]
    - [SATURDAY, SATURDAY.__eq__, [5], true]

# ---------------------------------------------------------------------------
# month_name — February, April
#
# calendar.zspec.zsdl covers month_name[1](January), [6](June), [12](December).
# No prior spec covers indices 2 or 4.
# ---------------------------------------------------------------------------

invariant calendar_extra5.month_name.february:
  description: "calendar.month_name[2] == 'February'"
  category: month_name
  kind: python_call_eq
  function: month_name.__getitem__
  args: [2]
  expected: "February"

invariant calendar_extra5.month_name.april:
  description: "calendar.month_name[4] == 'April'"
  category: month_name
  kind: python_call_eq
  function: month_name.__getitem__
  args: [4]
  expected: "April"

# ---------------------------------------------------------------------------
# month_abbr — Sep
#
# calendar.zspec.zsdl covers month_abbr[1](Jan) and [12](Dec).
# No prior spec covers index 9.
# ---------------------------------------------------------------------------

invariant calendar_extra5.month_abbr.sep:
  description: "calendar.month_abbr[9] == 'Sep'"
  category: month_abbr
  kind: python_call_eq
  function: month_abbr.__getitem__
  args: [9]
  expected: "Sep"

# ---------------------------------------------------------------------------
# monthrange — February in leap and non-leap year
#
# calendar_extra3 covers monthrange(2024,1)[0]==0 (January 2024 first weekday).
# No prior spec checks February month ranges.
# Feb 2024 (leap year): starts Thursday (3), 29 days.
# Feb 2023 (non-leap year): 28 days.
# ---------------------------------------------------------------------------

invariant calendar_extra5.monthrange.feb_2024_first_weekday:
  description: "calendar.monthrange(2024, 2)[0] == 3 — Feb 2024 starts on Thursday (leap year)"
  category: monthrange
  kind: python_call_eq
  function: monthrange
  args: [2024, 2]
  method: __getitem__
  method_args: [0]
  expected: 3

invariant calendar_extra5.monthrange.feb_2024_days:
  description: "calendar.monthrange(2024, 2)[1] == 29 — Feb 2024 has 29 days (leap year)"
  category: monthrange
  kind: python_call_eq
  function: monthrange
  args: [2024, 2]
  method: __getitem__
  method_args: [1]
  expected: 29

invariant calendar_extra5.monthrange.feb_2023_days:
  description: "calendar.monthrange(2023, 2)[1] == 28 — Feb 2023 has 28 days (non-leap year)"
  category: monthrange
  kind: python_call_eq
  function: monthrange
  args: [2023, 2]
  method: __getitem__
  method_args: [1]
  expected: 28

# ---------------------------------------------------------------------------
# weekday — additional date vectors
#
# calendar.zspec.zsdl covers weekday(2026,4,8)==2, (2024,1,1)==0, (2024,2,29)==3.
# We add: weekday(2000,1,1)==5 (Saturday) and weekday(2026,4,9)==3 (Thursday).
# ---------------------------------------------------------------------------

invariant calendar_extra5.weekday.saturday_2000_01_01:
  description: "calendar.weekday(2000, 1, 1) == 5 — January 1, 2000 was a Saturday"
  category: weekday
  kind: python_call_eq
  function: weekday
  args: [2000, 1, 1]
  expected: 5

invariant calendar_extra5.weekday.thursday_2026_04_09:
  description: "calendar.weekday(2026, 4, 9) == 3 — April 9, 2026 is a Thursday"
  category: weekday
  kind: python_call_eq
  function: weekday
  args: [2026, 4, 9]
  expected: 3

# ---------------------------------------------------------------------------
# leapdays(2020, 2025) and isleap(1996)
#
# calendar.zspec.zsdl covers leapdays(2000,2025)==7, (2000,2001)==1, (1900,1901)==0.
# calendar_extra covers leapdays(2000,2024)==6.
# We add: leapdays(2020,2025)==2 and isleap(1996)==True.
# ---------------------------------------------------------------------------

invariant calendar_extra5.leapdays.2020_to_2025:
  description: "calendar.leapdays(2020, 2025) == 2 — leap years 2020 and 2024 in [2020,2025)"
  category: leapdays
  kind: python_call_eq
  function: leapdays
  args: [2020, 2025]
  expected: 2

invariant calendar_extra5.isleap.1996_true:
  description: "calendar.isleap(1996) == True — 1996 is divisible by 4 and not by 100"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [1996]
  expected: true
