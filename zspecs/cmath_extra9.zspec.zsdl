spec: cmath_extra9
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmath.html — Python cmath module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl and prior extras through cmath_extra8.zspec.zsdl."
    - "cmath_extra/cmath_extra2: phase/polar/rect/isclose/isfinite/isinf/isnan __name__ already covered."
    - "cmath_extra3: __qualname__ for sqrt/exp/log/sin/cos/tan/phase/polar/rect/isnan/isinf/isfinite/isclose."
    - "cmath_extra6: sqrt/__module__ already covered."
    - "cmath_extra7: polar/__module__ and rect/__module__ already covered."
    - "cmath_extra8: exp/__name__, log/__name__, sin/__name__, cos/__name__, sqrt/__name__, phase/__name__, polar/__name__, rect/__name__ all covered."
    - "No prior spec covers __module__ for exp/log/sin/cos/tan/asin/acos/atan/sinh/cosh/tanh/isinf/isnan/isfinite."
    - "No prior spec covers __qualname__ for asin/acos/atan/sinh/cosh/tanh."
    - "No prior spec covers __name__ for asin/acos/atan/sinh/cosh/tanh."
    - "cmath.asin.__name__ == 'asin' — inverse sine for complex numbers."
    - "cmath.acos.__name__ == 'acos' — inverse cosine for complex numbers."
    - "cmath.atan.__name__ == 'atan' — inverse tangent for complex numbers."
    - "cmath.sinh.__name__ == 'sinh' — hyperbolic sine for complex numbers."
    - "cmath.cosh.__name__ == 'cosh' — hyperbolic cosine for complex numbers."
    - "cmath.tanh.__name__ == 'tanh' — hyperbolic tangent for complex numbers."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Inverse trig and hyperbolic function __name__ attributes
#
# cmath_extra/cmath_extra2/cmath_extra8 cover __name__ for
# phase/polar/rect/isclose/isfinite/isinf/isnan/sqrt/exp/log/sin/cos.
# No prior spec checks asin/acos/atan/sinh/cosh/tanh __name__.
# ---------------------------------------------------------------------------

invariant cmath_extra9.asin.name:
  description: "cmath.asin.__name__ == 'asin' — inverse sine function name"
  category: function_identity
  kind: python_call_eq
  function: asin.__name__.__eq__
  args: ["asin"]
  expected: true

invariant cmath_extra9.sinh.name:
  description: "cmath.sinh.__name__ == 'sinh' — hyperbolic sine function name"
  category: function_identity
  kind: python_call_eq
  function: sinh.__name__.__eq__
  args: ["sinh"]
  expected: true

invariant cmath_extra9.cosh.name:
  description: "cmath.cosh.__name__ == 'cosh' — hyperbolic cosine function name"
  category: function_identity
  kind: python_call_eq
  function: cosh.__name__.__eq__
  args: ["cosh"]
  expected: true

# ---------------------------------------------------------------------------
# Inverse trig and hyperbolic function __module__ table
#
# phase/__module__ was covered in cmath_extra2. sqrt/polar/rect/__module__
# covered in cmath_extra6/cmath_extra7. No prior spec covers __module__ for
# exp/log/sin/cos/tan/asin/acos/atan/sinh/cosh/tanh/isinf/isnan/isfinite.
# All cmath C builtins have __module__ == 'cmath'.
# ---------------------------------------------------------------------------

table cmath_extra9.function_modules:
  description: "__module__ == 'cmath' for trig, inverse trig, and hyperbolic functions"
  kind: python_call_eq
  category: function_metadata
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [exp,      exp.__module__.__eq__,      ["cmath"], true]
    - [log,      log.__module__.__eq__,      ["cmath"], true]
    - [sin,      sin.__module__.__eq__,      ["cmath"], true]
    - [cos,      cos.__module__.__eq__,      ["cmath"], true]
    - [tan,      tan.__module__.__eq__,      ["cmath"], true]
    - [asin,     asin.__module__.__eq__,     ["cmath"], true]
    - [acos,     acos.__module__.__eq__,     ["cmath"], true]
    - [atan,     atan.__module__.__eq__,     ["cmath"], true]
    - [sinh,     sinh.__module__.__eq__,     ["cmath"], true]
    - [cosh,     cosh.__module__.__eq__,     ["cmath"], true]
    - [tanh,     tanh.__module__.__eq__,     ["cmath"], true]
    - [isinf,    isinf.__module__.__eq__,    ["cmath"], true]
    - [isnan,    isnan.__module__.__eq__,    ["cmath"], true]
    - [isfinite, isfinite.__module__.__eq__, ["cmath"], true]
