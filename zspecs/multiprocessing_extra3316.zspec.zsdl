spec: mp3316
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (mp3316): __ipow__, __ilshift__, __irshift__ dict-presence (in-place **=, <<=, >>=) for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding (__ipow__): all 8 multiprocessing classes return false for __ipow__. In-place exponentiation (__ipow__, **=) is the augmented assignment variant of __pow__. multiprocessing.Process manages a subprocess lifecycle (start/join/terminate/kill); in-place exponentiation is undefined for process objects. pool.Pool dispatches work to worker processes; pool **= n is not a defined Python expression. pool.AsyncResult and pool.MapResult are result handles; in-place exponentiation is absent. managers.BaseListProxy: proxies list — list defines no __pow__ or __ipow__ (lists are not numeric types). managers._BaseDictProxy: proxies dict — dict defines no __pow__ or __ipow__. managers._BaseSetProxy: proxies set — set defines no __pow__ or __ipow__. managers.SyncManager: server process hosting shared objects; no in-place exponentiation defined."
    - "Key finding (__ilshift__): all 8 multiprocessing classes return false for __ilshift__. In-place left shift (__ilshift__, <<=) is the augmented assignment variant of __lshift__. No multiprocessing type defines __lshift__ (confirmed false in wave 660), so __ilshift__ is equally absent. managers._BaseDictProxy proxies dict — dict defines no __lshift__ or __ilshift__. managers._BaseSetProxy proxies set — set defines no __lshift__ or __ilshift__ (note: set does define __and__, __or__, __xor__, __sub__ for set algebra, but not bit-shift operators). managers.BaseListProxy proxies list — list defines no __lshift__ or __ilshift__. Process/Pool/AsyncResult/MapResult/SyncManager: no left-shift or in-place left-shift semantics of any kind."
    - "Key finding (__irshift__): all 8 multiprocessing classes return false for __irshift__. In-place right shift (__irshift__, >>=) is the augmented assignment variant of __rshift__. No multiprocessing type defines __rshift__ (confirmed false in wave 660), so __irshift__ is equally absent. managers._BaseDictProxy: dict defines no __rshift__ or __irshift__. managers._BaseSetProxy: set defines no __rshift__ or __irshift__. managers.BaseListProxy: list defines no __rshift__ or __irshift__. Note: integers define __rshift__ for bit manipulation, but none of the proxied collection types (list, dict, set) inherit or implement bitwise shift protocols. Process/Pool/AsyncResult/MapResult/SyncManager: no right-shift or in-place right-shift semantics of any kind."
    - "All 24 values in this wave are false. multiprocessing is a process-based concurrency library; its entire API is expressed through explicit method calls, subprocess lifecycle management, and IPC — never through Python's in-place augmented assignment operators."
    - "Cross-wave summary for mp subjects:"
    - "  Wave 658 (mp3166): __add__/__sub__/__mul__ — BaseListProxy __add__=true, __mul__=true; others false."
    - "  Wave 659 (mp3181): __truediv__/__floordiv__/__mod__ — all false for all 8."
    - "  Wave 660 (mp3196): __pow__/__lshift__/__rshift__ — all false for all 8."
    - "  Wave 661 (mp3211): __and__/__or__/__xor__ — all false for all 8."
    - "  Wave 662 (mp3226): __radd__/__rsub__/__rmul__ — all false for all 8."
    - "  Wave 663 (mp3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 8."
    - "  Wave 664 (mp3256): __rpow__/__rlshift__/__rrshift__ — all false for all 8."
    - "  Wave 665 (mp3271): __rand__/__ror__/__rxor__ — all false for all 8."
    - "  Wave 666 (mp3286): __iadd__/__isub__/__imul__ — all false for all 8."
    - "  Wave 667 (mp3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 8."
    - "  Wave 668 (mp3316): __ipow__/__ilshift__/__irshift__ — all false for all 8."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — operator.contains(Cls.__dict__, '__ipow__')
#
# All 8 multiprocessing classes return false for __ipow__.
# In-place exponentiation (__ipow__, **=) is the augmented assignment variant
#   of __pow__. No multiprocessing type defines __pow__ (wave 660), so
#   __ipow__ is equally absent.
# Process/Pool/AsyncResult/MapResult: process-management and result-handle
#   types; in-place exponentiation is not defined for any of them.
# managers.BaseListProxy: proxies list — list defines no __pow__ or __ipow__.
#   Lists are sequence types, not numeric types; **= has never been defined
#   for list objects.
# managers._BaseDictProxy: proxies dict — dict defines no __pow__ or __ipow__.
# managers._BaseSetProxy: proxies set — set defines no __pow__ or __ipow__.
# managers.SyncManager: server process; no in-place exponentiation defined.
# ---------------------------------------------------------------------------

table mp3316.ipow:
  description: "multiprocessing types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3316

  columns: [id, function, args, expected]
  rows:
    - ["mp3316001", operator.contains, [multiprocessing.Process.__dict__,                 "__ipow__"], false]
    - ["mp3316002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__ipow__"], false]
    - ["mp3316003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__ipow__"], false]
    - ["mp3316004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__ipow__"], false]
    - ["mp3316005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__ipow__"], false]
    - ["mp3316006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__ipow__"], false]
    - ["mp3316007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__ipow__"], false]
    - ["mp3316008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__ipow__"], false]

# ---------------------------------------------------------------------------
# __ilshift__ dict-presence — operator.contains(Cls.__dict__, '__ilshift__')
#
# All 8 multiprocessing classes return false for __ilshift__.
# In-place left shift (__ilshift__, <<=) is the augmented assignment variant
#   of __lshift__. No multiprocessing type defines __lshift__ (wave 660 all
#   false), so __ilshift__ is equally absent.
# managers._BaseSetProxy key note: set defines __and__, __or__, __xor__, and
#   __sub__ for set algebra, but does not define __lshift__ or __ilshift__.
#   Bitwise shift is an integer operator, not a set operator.
# managers._BaseDictProxy: dict defines no __lshift__ or __ilshift__.
# managers.BaseListProxy: list defines no __lshift__ or __ilshift__.
# Process/Pool/AsyncResult/MapResult/SyncManager: no left-shift or in-place
#   left-shift semantics of any kind.
# ---------------------------------------------------------------------------

table mp3316.ilshift:
  description: "multiprocessing types __ilshift__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3316

  columns: [id, function, args, expected]
  rows:
    - ["mp3316009",  operator.contains, [multiprocessing.Process.__dict__,                 "__ilshift__"], false]
    - ["mp3316010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__ilshift__"], false]
    - ["mp3316011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__ilshift__"], false]
    - ["mp3316012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__ilshift__"], false]
    - ["mp3316013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__ilshift__"], false]
    - ["mp3316014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__ilshift__"], false]
    - ["mp3316015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__ilshift__"], false]
    - ["mp3316016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__ilshift__"], false]

# ---------------------------------------------------------------------------
# __irshift__ dict-presence — operator.contains(Cls.__dict__, '__irshift__')
#
# All 8 multiprocessing classes return false for __irshift__.
# In-place right shift (__irshift__, >>=) is the augmented assignment variant
#   of __rshift__. No multiprocessing type defines __rshift__ (wave 660 all
#   false), so __irshift__ is equally absent.
# managers.BaseListProxy key note: list defines no __rshift__ or __irshift__.
#   Lists are sequence types; the >> operator is not defined for list objects.
#   Integers define __rshift__ for bit manipulation, but list/dict/set do not.
# managers._BaseDictProxy: dict defines no __rshift__ or __irshift__.
# managers._BaseSetProxy: set defines no __rshift__ or __irshift__.
# Process/Pool/AsyncResult/MapResult/SyncManager: no right-shift or in-place
#   right-shift semantics of any kind.
# ---------------------------------------------------------------------------

