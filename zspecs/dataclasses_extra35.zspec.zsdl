spec: dataclasses_extra35
version: ">=3.10"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra34.zspec.zsdl."
    - "Prior specs covered: all function/class __name__/__module__/__qualname__/__bases__; FrozenInstanceError/__mro__.__len__()==5; InitVar/__mro__.__len__()==2; Field method __qualname__.__len__(); KW_ONLY/__class__.__qualname__.__len__()==13; MISSING/__class__.__qualname__.__len__()==13; make_dataclass/__qualname__.__len__()==14; InitVar/__qualname__.__len__()==7; __dict__.__class__.__name__.__len__()==12 for Field/FrozenInstanceError/InitVar; module-level function __qualname__.__len__() for all 8 functions; dataclasses.__all__.__len__()==13; __all__.__class__.__name__.__len__()==4; FrozenInstanceError.__bases__[0].__name__.__len__()==14; MISSING/__class__.__name__.__len__()==13; KW_ONLY/__class__.__name__.__len__()==13; Field/InitVar __mro__.__len__()==2; FrozenInstanceError.__mro__.__len__()==5; Field/InitVar __bases__[0].__name__.__len__()==6; Field/__name__/__qualname__.__len__()==5; InitVar/__name__/__qualname__.__len__()==7; FrozenInstanceError.__name__/__qualname__.__len__()==19; dataclasses.__name__.__len__()==11; Field.__slots__.__len__()==12."
    - "This spec covers: __name__.__len__() for the eight module-level functions: dataclass (9), field (5), fields (6), asdict (6), astuple (7), make_dataclass (14), replace (7), is_dataclass (12); __qualname__.__len__() for dataclass (9); KW_ONLY.__class__.__name__.__len__()==13."
    - "dataclass.__name__ == 'dataclass' (9 chars). Its __qualname__ is also 'dataclass' (9 chars) since it is a top-level function."
    - "field.__name__ == 'field' (5 chars) — shortest function name in the module, matching deque.__name__.__len__() in collections."
    - "fields.__name__ == 'fields' (6 chars); asdict.__name__ == 'asdict' (6 chars) — tied at 6 chars."
    - "astuple.__name__ == 'astuple' (7 chars); replace.__name__ == 'replace' (7 chars) — tied at 7 chars."
    - "make_dataclass.__name__ == 'make_dataclass' (14 chars) — longest function name in the module."
    - "is_dataclass.__name__ == 'is_dataclass' (12 chars) — second-longest function name."
    - "KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' (13 chars). The KW_ONLY sentinel is a singleton instance of the private _KW_ONLY_TYPE class. len('_KW_ONLY_TYPE') == 13, matching MISSING.__class__.__name__.__len__() also recorded as 13 in prior specs."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for the short-name module-level functions (extra35 namespace)
#
# The dataclasses module exports 8 public functions. Four of them have names
# of 9 characters or fewer:
#   dataclass.__name__ == 'dataclass' (9 chars) — the primary decorator
#   field.__name__     == 'field'     (5 chars) — the factory for Field objects
#   fields.__name__    == 'fields'    (6 chars) — returns all Field objects
#   asdict.__name__    == 'asdict'    (6 chars) — converts instance to dict
# field (5) is the shortest; dataclass (9) is the longest in this group.
# No prior dataclasses spec records these four __name__ lengths together in
# the extra35 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra35.short_func_name_lens:
  description: "__name__.__len__() for dataclass (9), field (5), fields (6), asdict (6)"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [dataclass, dataclass.__name__.__len__, [], 9]
    - [field,     field.__name__.__len__,     [], 5]
    - [fields,    fields.__name__.__len__,    [], 6]
    - [asdict,    asdict.__name__.__len__,    [], 6]

# ---------------------------------------------------------------------------
# __name__.__len__() for the longer-name module-level functions (extra35 namespace)
#
# The remaining four public functions have names ranging from 7 to 14 characters:
#   astuple.__name__        == 'astuple'        ( 7 chars)
#   replace.__name__        == 'replace'        ( 7 chars) — tied with astuple
#   is_dataclass.__name__   == 'is_dataclass'   (12 chars)
#   make_dataclass.__name__ == 'make_dataclass' (14 chars) — longest in module
# make_dataclass (14) matches contextlib.contextmanager.__name__.__len__() —
# a coincidental cross-module tie. No prior dataclasses spec records these four
# __name__ lengths together in the extra35 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra35.longer_func_name_lens:
  description: "__name__.__len__() for astuple/replace (7 each), is_dataclass (12), make_dataclass (14)"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [astuple,        astuple.__name__.__len__,        [], 7]
    - [replace,        replace.__name__.__len__,        [], 7]
    - [is_dataclass,   is_dataclass.__name__.__len__,   [], 12]
    - [make_dataclass, make_dataclass.__name__.__len__, [], 14]

# ---------------------------------------------------------------------------
# dataclass.__qualname__.__len__() == 9 — standalone (extra35 namespace)
#
# dataclasses.dataclass is defined at module top level, so its __qualname__
# equals its __name__: 'dataclass' (9 characters). This is the primary public
# API of the dataclasses module — the @dataclass decorator that transforms a
# plain class into a dataclass by generating __init__, __repr__, __eq__, etc.
# No prior dataclasses spec records dataclass.__qualname__.__len__() as a
# standalone in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra35.dataclass.qualname_len:
  description: "len(dataclasses.dataclass.__qualname__) == 9 — 'dataclass' is 9 chars; __qualname__ == __name__ for this top-level decorator"
  category: qualname_attrs
  kind: python_call_eq
  function: dataclass.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# KW_ONLY.__class__.__name__.__len__() == 13 — standalone (extra35 namespace)
#
# dataclasses.KW_ONLY is a singleton sentinel object. Its class is the private
# '_KW_ONLY_TYPE' class, whose __name__ has 13 characters. This matches
# MISSING.__class__.__name__.__len__() (also 13 from prior specs) — both
# sentinel objects in the dataclasses module have private class names of exactly
# 13 characters. KW_ONLY signals (since Python 3.10) that all following fields
# in a dataclass are keyword-only. No prior dataclasses spec records this
# standalone in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra35.KW_ONLY.class_name_len:
  description: "len(dataclasses.KW_ONLY.__class__.__name__) == 13 — KW_ONLY's class is '_KW_ONLY_TYPE' (13 chars), matching MISSING.__class__.__name__.__len__()"
  category: sentinel_attrs
  kind: python_call_eq
  function: "KW_ONLY.__class__.__name__.__len__"
  args: []
  expected: 13
