spec: uuid_extra190
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "uuid.__name__ == 'uuid' (len=4) — the module's own __name__ attribute."
    - "uuid.UUID.__name__ == 'UUID' (len=4) — the UUID class name; same length as module name."
    - "uuid.SafeUUID.__name__ == 'SafeUUID' (len=8) — the SafeUUID enum class name."
    - "uuid.uuid1.__name__ == 'uuid1' (len=5) — uuid1 function name."
    - "uuid.uuid4.__name__ == 'uuid4' (len=5) — uuid4 function name; same length as uuid1."
    - "uuid.uuid5.__name__ == 'uuid5' (len=5) — uuid5 function name; same length as uuid1 and uuid4."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' (len=4) — NAMESPACE_DNS is an instance of UUID class."
    - "uuid.RFC_4122.__class__.__name__ == 'str' (len=3) — RFC_4122 is a plain str constant."
    - "Name length ordering: str(3) < uuid/UUID/NAMESPACE_DNS(4) < uuid1/uuid4/uuid5(5) < SafeUUID(8)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module and class name lengths — group A
# uuid.__name__, uuid.UUID.__name__, uuid.SafeUUID.__name__
# ---------------------------------------------------------------------------

table uuidnamelens190.module_and_class_names_a:
  kind: python_call_eq
  category: name_lengths
  id_prefix: uuidnamelens190

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len,    __name__.__len__,              [], 4, "uuid.__name__.__len__() == 4 ('uuid' has 4 characters)"]
    - [UUID_name_len,      UUID.__name__.__len__,         [], 4, "uuid.UUID.__name__.__len__() == 4 ('UUID' has 4 characters, same length as module name)"]
    - [SafeUUID_name_len,  SafeUUID.__name__.__len__,     [], 8, "uuid.SafeUUID.__name__.__len__() == 8 ('SafeUUID' has 8 characters, longest class name here)"]

# ---------------------------------------------------------------------------
# uuid function name lengths — group B
# uuid.uuid1.__name__, uuid.uuid4.__name__, uuid.uuid5.__name__
# ---------------------------------------------------------------------------

table uuidnamelens190.function_names_b:
  kind: python_call_eq
  category: name_lengths
  id_prefix: uuidnamelens190

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_name_len,     uuid1.__name__.__len__,        [], 5, "uuid.uuid1.__name__.__len__() == 5 ('uuid1' has 5 characters)"]
    - [uuid4_name_len,     uuid4.__name__.__len__,        [], 5, "uuid.uuid4.__name__.__len__() == 5 ('uuid4' has 5 characters, same length as uuid1)"]
    - [uuid5_name_len,     uuid5.__name__.__len__,        [], 5, "uuid.uuid5.__name__.__len__() == 5 ('uuid5' has 5 characters, same length as uuid1 and uuid4)"]

# ---------------------------------------------------------------------------
# uuid constant class name lengths — group C
# uuid.NAMESPACE_DNS.__class__.__name__, uuid.RFC_4122.__class__.__name__
# ---------------------------------------------------------------------------

table uuidnamelens190.constant_class_names_c:
  kind: python_call_eq
  category: name_lengths
  id_prefix: uuidnamelens190

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_class_len,   NAMESPACE_DNS.__class__.__name__.__len__,  [], 4, "uuid.NAMESPACE_DNS.__class__.__name__.__len__() == 4 ('UUID' has 4 characters; NAMESPACE_DNS is a UUID instance)"]
    - [rfc4122_class_len,  RFC_4122.__class__.__name__.__len__,       [], 3, "uuid.RFC_4122.__class__.__name__.__len__() == 3 ('str' has 3 characters; RFC_4122 is a str constant)"]
    - [module_name_eq,     __name__.__eq__,                           ["uuid"], true, "uuid.__name__ == 'uuid' (the module's canonical name)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuidnamelens190.uuid_module_name_len:
  description: "uuid.__name__.__len__() == 4 — 'uuid' has exactly 4 characters"
  category: name_lengths
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 4

invariant uuidnamelens190.UUID_class_name_len:
  description: "uuid.UUID.__name__.__len__() == 4 — 'UUID' has 4 characters, same length as the module name 'uuid'"
  category: name_lengths
  kind: python_call_eq
  function: UUID.__name__.__len__
  args: []
  expected: 4

invariant uuidnamelens190.SafeUUID_name_len:
  description: "uuid.SafeUUID.__name__.__len__() == 8 — 'SafeUUID' has 8 characters; longest class/function name covered in this spec"
  category: name_lengths
  kind: python_call_eq
  function: SafeUUID.__name__.__len__
  args: []
  expected: 8

invariant uuidnamelens190.uuid1_name_len:
  description: "uuid.uuid1.__name__.__len__() == 5 — 'uuid1' has 5 characters"
  category: name_lengths
  kind: python_call_eq
  function: uuid1.__name__.__len__
  args: []
  expected: 5

invariant uuidnamelens190.uuid4_name_len:
  description: "uuid.uuid4.__name__.__len__() == 5 — 'uuid4' has 5 characters, same length as uuid1 and uuid5"
  category: name_lengths
  kind: python_call_eq
  function: uuid4.__name__.__len__
  args: []
  expected: 5

invariant uuidnamelens190.uuid5_name_len:
  description: "uuid.uuid5.__name__.__len__() == 5 — 'uuid5' has 5 characters, same length as uuid1 and uuid4"
  category: name_lengths
  kind: python_call_eq
  function: uuid5.__name__.__len__
  args: []
  expected: 5

invariant uuidnamelens190.NAMESPACE_DNS_class_name_len:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__len__() == 4 — 'UUID' has 4 characters; NAMESPACE_DNS is an instance of the UUID class"
  category: name_lengths
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__len__
  args: []
  expected: 4

invariant uuidnamelens190.RFC_4122_class_name_len:
  description: "uuid.RFC_4122.__class__.__name__.__len__() == 3 — 'str' has 3 characters; RFC_4122 is a plain string constant, shortest type name in this spec"
  category: name_lengths
  kind: python_call_eq
  function: RFC_4122.__class__.__name__.__len__
  args: []
  expected: 3

