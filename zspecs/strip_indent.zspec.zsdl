spec: strip_indent
version: ">=4.1.1"
backend: node(strip-indent)

docs: https://www.npmjs.com/package/strip-indent

provenance:
  derived_from:
    - "strip-indent README — https://www.npmjs.com/package/strip-indent"
    - "Test vectors verified with strip-indent via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "strip-indent source"
  notes:
    - "strip-indent is an npm package. Install: npm install strip-indent"
    - "Strips the minimum leading whitespace from all lines in a string."
    - "ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table strip_indent.stripIndent:
  kind: node_module_call_eq
  function: "default"
  category: string
  id_prefix: strindent

  columns: [id, args, expected]
  rows:
    - [equal_indent,  ["  hello\n  world"],  "hello\nworld"]
    - [mixed_indent,  ["    a\n  b"],        "  a\nb"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:25:55Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
