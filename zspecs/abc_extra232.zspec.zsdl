spec: abc_extra232
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html#abc.ABC

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html#abc.ABC — abc.ABC class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.ABC.__name__ == 'ABC' — 3 characters; module is 'abc' (3 chars); verified with Python 3.14.3."
    - "abc.ABC.__bases__[0].__name__ == 'object' — ABC inherits directly from object; verified with Python 3.14.3."
    - "abc.ABC.__init_subclass__.__name__ == '__init_subclass__' — 17 characters; qualname is 'ABC.__init_subclass__' (21 chars); verified with Python 3.14.3."
    - "abc.ABC.__subclasshook__.__name__ == '__subclasshook__' — 16 characters; qualname is 'ABC.__subclasshook__' (20 chars); verified with Python 3.14.3."
    - "abc.abstractmethod.__name__ == 'abstractmethod' — 14 characters; qualname is 'abstractmethod' (14 chars); module is 'abc'; verified with Python 3.14.3."
    - "abc.get_cache_token.__name__ == 'get_cache_token' — 15 characters; qualname is 'get_cache_token'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC class identity contracts — extra232 namespace
#
# ABC.__name__ == 'ABC' (3 chars); module 'abc' (3 chars).
# ABC.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

table abc_extra232.abc_class_identity:
  description: "abc.ABC class __name__ and __module__ contracts in abc232aci namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc232aci

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,      ABC.__name__.__eq__,    ["ABC"], true, "abc.ABC.__name__ == 'ABC'; verified with Python 3.14.3"]
    - [abc_name_len_3,   ABC.__name__.__len__,   [],      3,    "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters; verified with Python 3.14.3"]
    - [abc_module_eq,    ABC.__module__.__eq__,  ["abc"], true, "abc.ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abc_module_len_3, ABC.__module__.__len__, [],      3,    "abc.ABC.__module__.__len__() == 3 — 'abc' has 3 characters; verified with Python 3.14.3"]

