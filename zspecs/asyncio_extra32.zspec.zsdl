spec: asyncio_extra32
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec extends asyncio_extra31.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__() (C extension), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), Event/Semaphore/Condition method __qualname__.__len__(), create_task/run_coroutine_threadsafe __qualname__.__len__(), class __dict__.__class__.__name__.__len__() for Event/Semaphore/Condition/AbstractEventLoop/BaseEventLoop/Task/Lock/Queue, __all__.__len__() == 95."
    - "NEW in this spec: Queue/__mro__.__len__() == 3 (not 2 as the flat hierarchy suggests — Queue extends _LoopBoundMixin); PriorityQueue/__mro__.__len__() == 4; LifoQueue/__mro__.__len__() == 4; QueueEmpty/__mro__.__len__() == 4; QueueFull/__mro__.__len__() == 4; BoundedSemaphore/__mro__.__len__() == 5; AbstractEventLoop/__mro__.__len__() == 2; PriorityQueue/__bases__[0].__name__.__len__() == 5 (Queue); LifoQueue/__bases__[0].__name__.__len__() == 5 (Queue); QueueEmpty/__bases__[0].__name__.__len__() == 9 (Exception); QueueFull/__bases__[0].__name__.__len__() == 9 (Exception); BoundedSemaphore/__bases__[0].__name__.__len__() == 9 (Semaphore); AbstractEventLoop/__bases__[0].__name__.__len__() == 6 (object); class __dict__.__class__.__name__.__len__() for PriorityQueue/LifoQueue/QueueEmpty/QueueFull/BoundedSemaphore/AbstractEventLoop; Queue method __qualname__.__len__() for put/get/put_nowait/get_nowait/empty/full/qsize."
    - "SURPRISE: asyncio.Queue has MRO depth 3, not 2 — Queue extends _LoopBoundMixin (15 chars), not object directly."
    - "SURPRISE: asyncio.BoundedSemaphore has MRO depth 5 — BoundedSemaphore -> Semaphore -> _ContextManagerMixin -> _LoopBoundMixin -> object."
    - "SURPRISE: asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (15 chars), not 'object'."
    - "asyncio.PriorityQueue and asyncio.LifoQueue both inherit from Queue, giving MRO depth 4."
    - "asyncio.QueueEmpty and asyncio.QueueFull both inherit from Exception, giving MRO depth 4."
    - "Queue.put and Queue.get share the same qualname length (9)."
    - "Queue.put_nowait and Queue.get_nowait share the same qualname length (16)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __mro__.__len__() table — extra32 namespace
#
# asyncio queue and related classes have surprising MRO depths due to mixin
# classes introduced in Python 3.10+:
#   Queue.__mro__.__len__()             == 3 — [Queue, _LoopBoundMixin, object]
#   PriorityQueue.__mro__.__len__()     == 4 — [PriorityQueue, Queue, _LoopBoundMixin, object]
#   LifoQueue.__mro__.__len__()         == 4 — [LifoQueue, Queue, _LoopBoundMixin, object]
#   QueueEmpty.__mro__.__len__()        == 4 — [QueueEmpty, Exception, BaseException, object]
#   QueueFull.__mro__.__len__()         == 4 — [QueueFull, Exception, BaseException, object]
#   BoundedSemaphore.__mro__.__len__()  == 5 — [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]
#   AbstractEventLoop.__mro__.__len__() == 2 — [AbstractEventLoop, object]
# Note that Queue has MRO depth 3 (not 2) — it mixes in _LoopBoundMixin.
# No prior spec has measured __mro__.__len__() for any of these classes.
# ---------------------------------------------------------------------------

table asyncio_extra32.class_mro_lengths:
  description: "asyncio class __mro__.__len__() for queue and sync classes in extra32 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: clsmrolen32

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [Queue,             Queue.__mro__,             [], !ascii "", __len__, [], "Queue MRO depth == 3 (inherits _LoopBoundMixin)"]
    - [PriorityQueue,     PriorityQueue.__mro__,     [], !ascii "", __len__, [], "PriorityQueue MRO depth == 4"]
    - [LifoQueue,         LifoQueue.__mro__,         [], !ascii "", __len__, [], "LifoQueue MRO depth == 4"]
    - [QueueEmpty,        QueueEmpty.__mro__,        [], !ascii "", __len__, [], "QueueEmpty MRO depth == 4 (Exception chain)"]
    - [QueueFull,         QueueFull.__mro__,         [], !ascii "", __len__, [], "QueueFull MRO depth == 4 (Exception chain)"]
    - [BoundedSemaphore,  BoundedSemaphore.__mro__,  [], !ascii "", __len__, [], "BoundedSemaphore MRO depth == 5"]
    - [AbstractEventLoop, AbstractEventLoop.__mro__,  [], !ascii "", __len__, [], "AbstractEventLoop MRO depth == 2"]

# ---------------------------------------------------------------------------
# Class __bases__[0].__name__.__len__() table — extra32 namespace
#
# Direct base class name lengths for asyncio queue/sync/event classes:
#   PriorityQueue.__bases__[0].__name__ == 'Queue'     (5 chars)
#   LifoQueue.__bases__[0].__name__     == 'Queue'     (5 chars)
#   QueueEmpty.__bases__[0].__name__    == 'Exception' (9 chars)
#   QueueFull.__bases__[0].__name__     == 'Exception' (9 chars)
#   BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' (9 chars)
#   AbstractEventLoop.__bases__[0].__name__ == 'object'  (6 chars)
# Note: Queue.__bases__[0].__name__ == '_LoopBoundMixin' (15 chars) — not
# included here as it is a private mixin, but its MRO presence is noted above.
# No prior spec has measured these base class name lengths for asyncio.
# ---------------------------------------------------------------------------

table asyncio_extra32.class_base_name_lengths:
  description: "asyncio class __bases__[0].__name__.__len__() for queue/sync classes in extra32 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: clsbasenamelen32

  columns: [id, function, args, expected]
  rows:
    - [PriorityQueue,     "PriorityQueue.__bases__[0].__name__.__len__",     [], 5]
    - [LifoQueue,         "LifoQueue.__bases__[0].__name__.__len__",         [], 5]
    - [QueueEmpty,        "QueueEmpty.__bases__[0].__name__.__len__",        [], 9]
    - [QueueFull,         "QueueFull.__bases__[0].__name__.__len__",         [], 9]
    - [BoundedSemaphore,  "BoundedSemaphore.__bases__[0].__name__.__len__",  [], 9]
    - [AbstractEventLoop, "AbstractEventLoop.__bases__[0].__name__.__len__", [], 6]

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() table — extra32 namespace
#
# All pure-Python asyncio classes have __dict__ of type mappingproxy —
# 'mappingproxy' has 12 characters. This table adds six classes not yet
# measured in extra31: PriorityQueue, LifoQueue, QueueEmpty, QueueFull,
# BoundedSemaphore, AbstractEventLoop.
# ---------------------------------------------------------------------------

table asyncio_extra32.class_dict_class_name_lengths:
  description: "asyncio class __dict__.__class__.__name__.__len__() for queue/sync classes in extra32 namespace — all equal 12 (mappingproxy)"
  kind: python_call_eq
  category: class_structure
  id_prefix: classdictnamelen32

  columns: [id, function, args, expected]
  rows:
    - [PriorityQueue,     PriorityQueue.__dict__.__class__.__name__.__len__,     [], 12]
    - [LifoQueue,         LifoQueue.__dict__.__class__.__name__.__len__,         [], 12]
    - [QueueEmpty,        QueueEmpty.__dict__.__class__.__name__.__len__,        [], 12]
    - [QueueFull,         QueueFull.__dict__.__class__.__name__.__len__,         [], 12]
    - [BoundedSemaphore,  BoundedSemaphore.__dict__.__class__.__name__.__len__,  [], 12]
    - [AbstractEventLoop, AbstractEventLoop.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Queue method __qualname__ length table — extra32 namespace
#
# asyncio.Queue methods carry 'Queue.' as their __qualname__ prefix:
#   Queue.put.__qualname__       == 'Queue.put'       (9)
#   Queue.get.__qualname__       == 'Queue.get'       (9)
#   Queue.put_nowait.__qualname__ == 'Queue.put_nowait' (16)
#   Queue.get_nowait.__qualname__ == 'Queue.get_nowait' (16)
#   Queue.empty.__qualname__     == 'Queue.empty'     (11)
#   Queue.full.__qualname__      == 'Queue.full'      (10)
#   Queue.qsize.__qualname__     == 'Queue.qsize'     (11)
# put/get share length 9; put_nowait/get_nowait share length 16;
# empty/qsize share length 11. Prior spec extra31 covered Lock and Queue
# methods at a different level — these specific methods were not measured.
# ---------------------------------------------------------------------------

table asyncio_extra32.queue_method_qualname_lengths:
  description: "asyncio.Queue method __qualname__ lengths for put/get/put_nowait/get_nowait/empty/full/qsize in extra32 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: queuemqualnamelen32

  columns: [id, function, args, expected]
  rows:
    - [put,       Queue.put.__qualname__.__len__,       [], 9]
    - [get,       Queue.get.__qualname__.__len__,       [], 9]
    - [put_nowait, Queue.put_nowait.__qualname__.__len__, [], 16]
    - [get_nowait, Queue.get_nowait.__qualname__.__len__, [], 16]
    - [empty,     Queue.empty.__qualname__.__len__,     [], 11]
    - [full,      Queue.full.__qualname__.__len__,      [], 10]
    - [qsize,     Queue.qsize.__qualname__.__len__,     [], 11]

# ---------------------------------------------------------------------------
# asyncio.Queue MRO depth standalone invariant — extra32
#
# asyncio.Queue.__mro__.__len__() == 3, not 2 as one might expect for a
# 'simple' class. Queue inherits from _LoopBoundMixin, which itself inherits
# from object, giving the three-element MRO. This is distinct from the
# _LoopBoundMixin.__bases__[0].__name__ fact captured in the table.
# ---------------------------------------------------------------------------

invariant asyncio_extra32.Queue_mro_len:
  description: "asyncio.Queue.__mro__.__len__() == 3 — Queue extends _LoopBoundMixin, not object directly"
  category: class_hierarchy
  kind: python_call_eq
  function: Queue.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra32.AbstractEventLoop_mro_len:
  description: "asyncio.AbstractEventLoop.__mro__.__len__() == 2 — AbstractEventLoop inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: AbstractEventLoop.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra32.BoundedSemaphore_mro_len:
  description: "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — deepest asyncio sync class MRO due to multiple mixin layers"
  category: class_hierarchy
  kind: python_call_eq
  function: BoundedSemaphore.__mro__.__len__
  args: []
  expected: 5
