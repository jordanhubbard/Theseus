spec: abc_extra179
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers abc module name-length invariants for ABCMeta, ABC, and abstractmethod. abc.ABCMeta.__mro__ has len=3 (ABCMeta, type, object). Name lengths: ABC.__name__ len=3, ABCMeta.__name__ len=7, abstractmethod.__name__ len=14. Length ordering: ABC(3) < ABCMeta(7) < abstractmethod(14). All three have __module__=='abc' (len=3)."
    - "abc.ABCMeta.__mro__.__len__() == 3. The MRO of ABCMeta is (ABCMeta, type, object) — ABCMeta is a metaclass that inherits from type. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__name__.__len__() == 7: A-B-C-M-e-t-a. abc.ABC.__name__.__len__() == 3: A-B-C. abc.abstractmethod.__name__.__len__() == 14: a-b-s-t-r-a-c-t-m-e-t-h-o-d. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Length ordering ABC(3) < ABCMeta(7) < abstractmethod(14) holds. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All three items have __module__=='abc' (len=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc module name lengths — ABCMeta, ABC, abstractmethod
#
# abc.ABCMeta.__name__.__len__().__eq__(7) == True
# abc.ABC.__name__.__len__().__eq__(3) == True
# abc.abstractmethod.__name__.__len__().__eq__(14) == True
#
# Length ordering: ABC(3) < ABCMeta(7) < abstractmethod(14)
# ---------------------------------------------------------------------------

table abc_extra179.name_lengths:
  description: "abc module name lengths: ABC.__name__ len==3, ABCMeta.__name__ len==7, abstractmethod.__name__ len==14; ordering: ABC(3)<ABCMeta(7)<abstractmethod(14); new to abc_extra179"
  kind: python_call_eq
  category: identity
  id_prefix: abclengths179

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_len_3,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters: A-B-C; NAME LENGTHS: ABC=3 < ABCMeta=7 < abstractmethod=14; shortest name among the three; str.__len__() returns 3; new to abc_extra179"]
    - [abcmeta_name_len_7,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters: A-B-C-M-e-t-a; NAME LENGTHS: ABC=3 < ABCMeta=7 < abstractmethod=14; str.__len__() returns 7; new to abc_extra179"]
    - [am_name_len_14,
       abstractmethod.__name__.__len__,
       [],
       14,
       "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters: a-b-s-t-r-a-c-t-m-e-t-h-o-d; NAME LENGTHS: ABC=3 < ABCMeta=7 < abstractmethod=14; longest name; str.__len__() returns 14; new to abc_extra179"]
    - [abc_name_len_eq_3,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — ABC is the helper class for abstract base classes using ABCMeta; its name 'ABC' has 3 chars; str.__len__() returns 3; new to abc_extra179"]
    - [abcmeta_name_len_eq_7,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — ABCMeta is the metaclass for defining abstract base classes; name 'ABCMeta' has 7 chars; str.__len__() returns 7; new to abc_extra179"]

# ---------------------------------------------------------------------------
# Table 2: abc module __module__ lengths — all three are 'abc' (len=3)
#
# abc.ABCMeta.__module__.__len__().__eq__(3) == True
# abc.ABC.__module__.__len__().__eq__(3) == True
# abc.abstractmethod.__module__.__len__().__eq__(3) == True
# ---------------------------------------------------------------------------

table abc_extra179.module_lengths:
  description: "abc.ABCMeta, ABC, abstractmethod all have __module__=='abc'(len=3); new to abc_extra179"
  kind: python_call_eq
  category: identity
  id_prefix: abclengths179

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_module_len_3,
       ABCMeta.__module__.__len__,
       [],
       3,
       "abc.ABCMeta.__module__.__len__() == 3 — ABCMeta.__module__ is 'abc' which has 3 characters: a-b-c; str.__len__() returns 3; new to abc_extra179"]
    - [abc_module_len_3,
       ABC.__module__.__len__,
       [],
       3,
       "abc.ABC.__module__.__len__() == 3 — ABC.__module__ is 'abc' which has 3 characters: a-b-c; str.__len__() returns 3; new to abc_extra179"]
    - [am_module_len_3,
       abstractmethod.__module__.__len__,
       [],
       3,
       "abc.abstractmethod.__module__.__len__() == 3 — abstractmethod.__module__ is 'abc' which has 3 characters: a-b-c; str.__len__() returns 3; new to abc_extra179"]
    - [abcmeta_module_eq,
       ABCMeta.__module__.__eq__,
       ["abc"],
       true,
       "abc.ABCMeta.__module__.__eq__('abc') == True — ABCMeta is defined in the abc module; str.__eq__('abc') returns True; new to abc_extra179"]
    - [abc_module_eq,
       ABC.__module__.__eq__,
       ["abc"],
       true,
       "abc.ABC.__module__.__eq__('abc') == True — ABC is defined in the abc module; str.__eq__('abc') returns True; new to abc_extra179"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABCMeta MRO length and name length equality checks
#
# abc.ABCMeta.__mro__.__len__() == 3  (ABCMeta, type, object)
# abc.ABCMeta.__name__.__len__().__eq__(7) == True
# abc.ABC.__name__.__len__().__eq__(3) == True
# abc.abstractmethod.__name__.__len__().__eq__(14) == True
# ---------------------------------------------------------------------------

table abc_extra179.mro_and_len_eq:
  description: "abc.ABCMeta.__mro__ len==3 (ABCMeta,type,object); name len equality checks; new to abc_extra179"
  kind: python_call_eq
  category: identity
  id_prefix: abclengths179

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_mro_len_3,
       ABCMeta.__mro__.__len__,
       [],
       3,
       "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta's MRO is (ABCMeta, type, object): ABCMeta is a metaclass subclassing type which subclasses object; tuple.__len__() returns 3; new to abc_extra179"]
    - [abcmeta_name_len_eq_7,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has exactly 7 characters; int result 7; str.__len__() returns 7; new to abc_extra179"]
    - [abc_name_len_eq_3,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — 'ABC' has exactly 3 characters; int result 3; str.__len__() returns 3; new to abc_extra179"]
    - [am_name_len_eq_14,
       abstractmethod.__name__.__len__,
       [],
       14,
       "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has exactly 14 characters; int result 14; str.__len__() returns 14; new to abc_extra179"]
    - [am_module_eq,
       abstractmethod.__module__.__eq__,
       ["abc"],
       true,
       "abc.abstractmethod.__module__.__eq__('abc') == True — abstractmethod is defined in the abc module; str.__eq__('abc') returns True; new to abc_extra179"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra179
# ---------------------------------------------------------------------------

invariant abc_extra179.abcmeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — MRO is (ABCMeta, type, object); ABCMeta is a metaclass inheriting from type; new to abc_extra179"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra179.abcmeta_name_len_7:
  description: "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 chars; NAME LENGTHS: ABC(3) < ABCMeta(7) < abstractmethod(14); new to abc_extra179"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__name__.__len__
  args: []
  expected: 7

invariant abc_extra179.abc_name_len_3:
  description: "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 chars; shortest name in the abc module trio; new to abc_extra179"
  category: identity
  kind: python_call_eq
  function: ABC.__name__.__len__
  args: []
  expected: 3

invariant abc_extra179.abstractmethod_name_len_14:
  description: "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 chars; longest name in the abc module trio; new to abc_extra179"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__name__.__len__
  args: []
  expected: 14

invariant abc_extra179.abcmeta_module_len_3:
  description: "abc.ABCMeta.__module__.__len__() == 3 — 'abc' has 3 chars; all three abc items share the same module length; new to abc_extra179"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__module__.__len__
  args: []
  expected: 3

invariant abc_extra179.abc_module_len_3:
  description: "abc.ABC.__module__.__len__() == 3 — 'abc' has 3 chars; same as ABCMeta and abstractmethod; new to abc_extra179"
  category: identity
  kind: python_call_eq
  function: ABC.__module__.__len__
  args: []
  expected: 3

invariant abc_extra179.abstractmethod_module_len_3:
  description: "abc.abstractmethod.__module__.__len__() == 3 — 'abc' has 3 chars; all three abc module items have module length 3; new to abc_extra179"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__module__.__len__
  args: []
  expected: 3

invariant abc_extra179.name_length_ordering:
  description: "abc.ABC.__name__.__len__() == 3 — ordering anchor: ABC(3) < ABCMeta(7) < abstractmethod(14); ABC is the smallest; new to abc_extra179"
  category: identity
  kind: python_call_eq
  function: ABC.__name__.__len__
  args: []
  expected: 3
