spec: pathlib_extra1006
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib.Path method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.Path I/O, existence, and filesystem operation method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1006.path_io_qualnames:
  description: "pathlib.Path I/O method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pl1006io
  columns: [id, function, args, expected]
  rows:
    - [pl1006io001, pathlib.Path.open.__qualname__.__eq__,        ["Path.open"],        true]
    - [pl1006io002, pathlib.Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true]
    - [pl1006io003, pathlib.Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"],  true]
    - [pl1006io004, pathlib.Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true]
    - [pl1006io005, pathlib.Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true]
    - [pl1006io006, pathlib.Path.touch.__qualname__.__eq__,       ["Path.touch"],       true]

table pathlib_extra1006.path_existence_qualnames:
  description: "pathlib.Path existence and type-check method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pl1006ex
  columns: [id, function, args, expected]
  rows:
    - [pl1006ex001, pathlib.Path.exists.__qualname__.__eq__,   ["Path.exists"],   true]
    - [pl1006ex002, pathlib.Path.is_file.__qualname__.__eq__,  ["Path.is_file"],  true]
    - [pl1006ex003, pathlib.Path.is_dir.__qualname__.__eq__,   ["Path.is_dir"],   true]
    - [pl1006ex004, pathlib.Path.is_symlink.__qualname__.__eq__, ["Path.is_symlink"], true]
    - [pl1006ex005, pathlib.Path.is_mount.__qualname__.__eq__, ["Path.is_mount"], true]

table pathlib_extra1006.path_fs_qualnames:
  description: "pathlib.Path filesystem mutation method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pl1006fs
  columns: [id, function, args, expected]
  rows:
    - [pl1006fs001, pathlib.Path.mkdir.__qualname__.__eq__,    ["Path.mkdir"],    true]
    - [pl1006fs002, pathlib.Path.unlink.__qualname__.__eq__,   ["Path.unlink"],   true]
    - [pl1006fs003, pathlib.Path.rmdir.__qualname__.__eq__,    ["Path.rmdir"],    true]
    - [pl1006fs004, pathlib.Path.rename.__qualname__.__eq__,   ["Path.rename"],   true]
    - [pl1006fs005, pathlib.Path.replace.__qualname__.__eq__,  ["Path.replace"],  true]
