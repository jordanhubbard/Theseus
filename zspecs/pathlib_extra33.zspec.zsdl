spec: pathlib_extra33
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra4.zspec.zsdl — covers __name__ for Path/PurePath methods"
    - "pathlib_extra28.zspec.zsdl — covers __qualname__ for Path.read_text/write_text/resolve/iterdir/is_absolute"
    - "pathlib_extra29.zspec.zsdl — covers __qualname__ for Path.stat/chmod/exists/is_file/is_dir/mkdir/rename/unlink/open"
    - "pathlib_extra30.zspec.zsdl — covers __qualname__ for Path.read_bytes/write_bytes/glob/rglob/absolute"
    - "pathlib_extra31.zspec.zsdl — covers PurePosixPath/__qualname__/__module__; PureWindowsPath/__qualname__/__module__; PosixPath/__qualname__/__module__; PurePath/__bases__[0].__name__; PurePath properties fget.__qualname__"
    - "pathlib_extra32.zspec.zsdl — covers PurePath.parent/parents/suffixes/drive/root/anchor fget.__qualname__/__module__"
  notes:
    - "This spec extends pathlib_extra32.zspec.zsdl."
    - "NEW in extra33 — Axis 1: PurePosixPath/__qualname__, PureWindowsPath/__qualname__, PosixPath/__qualname__, WindowsPath/__qualname__ as extra33-namespace standalone invariants (values verified: all flat, matching class __name__)."
    - "NEW in extra33 — Axis 2: PosixPath/__bases__[0].__name__ and WindowsPath/__bases__[0].__name__ — both inherit directly from Path."
    - "NEW in extra33 — Axis 3: Path.__init__.__qualname__ — Path inherits __init__ from PurePath; __qualname__ resolves to 'PurePath.__init__'."
    - "NEW in extra33 — Axis 4: PurePath.__init__.__name__ and PurePath.__init__.__qualname__ — the __init__ method is defined on PurePath; __name__ is '__init__', __qualname__ is 'PurePath.__init__'."
    - "NEW in extra33 — Axis 5: Path.__truediv__.__name__ and Path.__truediv__.__qualname__ — the / operator is defined on PurePath; Path inherits it. __qualname__ is 'PurePath.__truediv__'."
    - "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath' — flat qualname; verified Python 3.12."
    - "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath' — flat qualname; verified Python 3.12."
    - "pathlib.PosixPath.__qualname__ == 'PosixPath' — flat qualname; verified Python 3.12."
    - "pathlib.WindowsPath.__qualname__ == 'WindowsPath' — flat qualname; verified Python 3.12."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits directly from Path."
    - "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath inherits directly from Path."
    - "pathlib.Path.__init__.__qualname__ == 'PurePath.__init__' — Path inherits __init__ from PurePath without override."
    - "pathlib.PurePath.__init__.__name__ == '__init__' — verified Python 3.12."
    - "pathlib.PurePath.__init__.__qualname__ == 'PurePath.__init__' — dotted qualname on the defining class."
    - "pathlib.Path.__truediv__.__name__ == '__truediv__' — the division operator method; verified Python 3.12."
    - "pathlib.Path.__truediv__.__qualname__ == 'PurePath.__truediv__' — Path inherits __truediv__ from PurePath without override."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePosixPath, PureWindowsPath, PosixPath, WindowsPath — __qualname__
#
# These four platform-specific path classes all have flat __qualname__ values
# (equal to __name__). pathlib_extra31 covers PurePosixPath/PureWindowsPath/
# PosixPath in a table and as standalone invariants. WindowsPath was omitted
# from extra31 (it is not instantiable on POSIX). These invariants establish
# all four __qualname__ values in the extra33 namespace.
# ---------------------------------------------------------------------------

table pathlib_extra33.platform_class_qualnames:
  description: "__qualname__ for PurePosixPath, PureWindowsPath, PosixPath, WindowsPath — all flat"
  kind: python_call_eq
  category: class_identity
  id_prefix: pcq33

  columns: [id, function, args, expected]
  rows:
    - [PurePosixPath,   PurePosixPath.__qualname__.__eq__,   ["PurePosixPath"],   true]
    - [PureWindowsPath, PureWindowsPath.__qualname__.__eq__, ["PureWindowsPath"], true]
    - [PosixPath,       PosixPath.__qualname__.__eq__,       ["PosixPath"],       true]
    - [WindowsPath,     WindowsPath.__qualname__.__eq__,     ["WindowsPath"],     true]

# ---------------------------------------------------------------------------
# PosixPath and WindowsPath — __bases__[0].__name__
#
# PosixPath and WindowsPath are the two concrete platform path classes.
# Each inherits directly from Path (not from PurePosixPath/PureWindowsPath).
# This reflects the inheritance structure: PosixPath(Path) and WindowsPath(Path).
# No prior pathlib spec records __bases__[0].__name__ for these two classes.
# ---------------------------------------------------------------------------

table pathlib_extra33.concrete_path_bases:
  description: "__bases__[0].__name__ for PosixPath and WindowsPath — both inherit directly from Path"
  kind: python_call_eq
  category: class_identity
  id_prefix: cpb33

  columns: [id, function, args, expected]
  rows:
    - [PosixPath,   "PosixPath.__bases__[0].__name__.__eq__",   ["Path"], true]
    - [WindowsPath, "WindowsPath.__bases__[0].__name__.__eq__", ["Path"], true]

# ---------------------------------------------------------------------------
# Path.__init__ — __qualname__ (inherited from PurePath)
#
# Path does not define its own __init__; it inherits the constructor from
# PurePath. As a result, Path.__init__.__qualname__ resolves to the dotted
# form 'PurePath.__init__' (the qualname of the defining class, not the
# accessing class). This is analogous to how TextCalendar.__init__.__qualname__
# resolves to 'Calendar.__init__' in the calendar module. No prior pathlib
# spec records Path.__init__.__qualname__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant pathlib_extra33.Path.init.qualname:
  description: "pathlib.Path.__init__.__qualname__ == 'PurePath.__init__' — Path inherits __init__ from PurePath without override"
  category: method_identity
  kind: python_call_eq
  function: "Path.__init__.__qualname__.__eq__"
  args: ["PurePath.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# PurePath.__init__ — __name__ and __qualname__
#
# PurePath is the root class of the pathlib hierarchy and defines __init__.
# Its __name__ is the bare '__init__' and its __qualname__ is the dotted
# 'PurePath.__init__'. No prior pathlib spec anchors both attributes as
# standalone extra33-namespace invariants.
# ---------------------------------------------------------------------------

invariant pathlib_extra33.PurePath.init.name:
  description: "pathlib.PurePath.__init__.__name__ == '__init__' — bare method name for the PurePath constructor"
  category: method_identity
  kind: python_call_eq
  function: "PurePath.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant pathlib_extra33.PurePath.init.qualname:
  description: "pathlib.PurePath.__init__.__qualname__ == 'PurePath.__init__' — dotted qualname anchored on the defining class"
  category: method_identity
  kind: python_call_eq
  function: "PurePath.__init__.__qualname__.__eq__"
  args: ["PurePath.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Path.__truediv__ — __name__ and __qualname__
#
# The / operator for pathlib is implemented as __truediv__ on PurePath.
# Path inherits this method without override, so Path.__truediv__.__qualname__
# resolves to 'PurePath.__truediv__' (the qualname of the defining class).
# The __name__ is the bare dunder '__truediv__'. No prior pathlib spec anchors
# these two attributes as standalone extra33-namespace invariants.
# ---------------------------------------------------------------------------

invariant pathlib_extra33.Path.truediv.name:
  description: "pathlib.Path.__truediv__.__name__ == '__truediv__' — bare method name for the path division operator"
  category: method_identity
  kind: python_call_eq
  function: "Path.__truediv__.__name__.__eq__"
  args: ["__truediv__"]
  expected: true

invariant pathlib_extra33.Path.truediv.qualname:
  description: "pathlib.Path.__truediv__.__qualname__ == 'PurePath.__truediv__' — Path inherits __truediv__ from PurePath without override"
  category: method_identity
  kind: python_call_eq
  function: "Path.__truediv__.__qualname__.__eq__"
  args: ["PurePath.__truediv__"]
  expected: true
