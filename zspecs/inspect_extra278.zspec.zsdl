spec: inspect_extra278
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.Attribute is a namedtuple: __bases__[0].__name__ == 'tuple', __module__ == 'inspect'."
    - "Attribute.__name__ == 'Attribute' (9 chars)."
    - "inspect.FullArgSpec is a namedtuple: __bases__[0].__name__ == 'tuple', __module__ == 'inspect'."
    - "FullArgSpec.__name__ == 'FullArgSpec' (11 chars)."
    - "inspect.getattr_static is a pure-Python function: __module__ == 'inspect', __class__.__name__ == 'function'."
    - "getattr_static.__name__ == 'getattr_static' (14 chars); __qualname__ == 'getattr_static' (top-level)."
    - "inspect.ClosureVars is a namedtuple: __bases__[0].__name__ == 'tuple', __module__ == 'inspect'."
    - "ClosureVars.__name__ == 'ClosureVars' (11 chars)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Attribute and inspect.FullArgSpec — namedtuple identity
#
# Both are namedtuples: __bases__[0].__name__ == 'tuple'.
# Attribute.__name__ == 'Attribute' (9 chars); __module__ == 'inspect'.
# FullArgSpec.__name__ == 'FullArgSpec' (11 chars); __module__ == 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra278.attribute_fullargspec_identity:
  description: "inspect.Attribute and FullArgSpec namedtuple identity — __name__, __module__, __bases__[0].__name__; name lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex278af

  columns: [id, function, args, expected, description]
  rows:
    - [at_name_eq,  Attribute.__name__.__eq__,                    ["Attribute"],  true, "inspect.Attribute.__name__ == 'Attribute'; verified with Python 3.14.3"]
    - [at_name_len, Attribute.__name__.__len__,                    [],            9,    "inspect.Attribute.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [at_mod_eq,   Attribute.__module__.__eq__,                   ["inspect"],   true, "inspect.Attribute.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [at_base_eq,  "Attribute.__bases__[0].__name__.__eq__",      ["tuple"],     true, "inspect.Attribute.__bases__[0].__name__ == 'tuple' (namedtuple base); verified with Python 3.14.3"]
    - [fa_name_eq,  FullArgSpec.__name__.__eq__,                   ["FullArgSpec"], true, "inspect.FullArgSpec.__name__ == 'FullArgSpec'; verified with Python 3.14.3"]
    - [fa_name_len, FullArgSpec.__name__.__len__,                   [],           11,   "inspect.FullArgSpec.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [fa_mod_eq,   FullArgSpec.__module__.__eq__,                  ["inspect"],  true, "inspect.FullArgSpec.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [fa_base_eq,  "FullArgSpec.__bases__[0].__name__.__eq__",     ["tuple"],    true, "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' (namedtuple base); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.getattr_static — pure-Python function identity
#
# getattr_static is a pure-Python function in the inspect module.
# __name__ == 'getattr_static' (14 chars); __qualname__ == 'getattr_static'.
# __module__ == 'inspect'; __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table inspect_extra278.getattr_static_identity:
  description: "inspect.getattr_static function identity — __name__, __module__, __qualname__, __class__.__name__; name length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex278gs

  columns: [id, function, args, expected, description]
  rows:
    - [gs_name_eq,  getattr_static.__name__.__eq__,           ["getattr_static"], true, "inspect.getattr_static.__name__ == 'getattr_static'; verified with Python 3.14.3"]
    - [gs_name_len, getattr_static.__name__.__len__,           [],               14,   "inspect.getattr_static.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [gs_mod_eq,   getattr_static.__module__.__eq__,          ["inspect"],       true, "inspect.getattr_static.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gs_qn_eq,    getattr_static.__qualname__.__eq__,        ["getattr_static"], true, "inspect.getattr_static.__qualname__ == 'getattr_static' (top-level function); verified with Python 3.14.3"]
    - [gs_cls_eq,   getattr_static.__class__.__name__.__eq__,  ["function"],      true, "inspect.getattr_static.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra278
# ---------------------------------------------------------------------------

invariant inspect_extra278.attribute_is_namedtuple:
  description: "inspect.Attribute.__bases__[0].__name__ == 'tuple' — Attribute is a namedtuple whose sole base class is tuple"
  category: identity
  kind: python_call_eq
  function: "Attribute.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant inspect_extra278.attribute_module_is_inspect:
  description: "inspect.Attribute.__module__ == 'inspect' — Attribute namedtuple is defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: Attribute.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra278.attribute_name_length_is_9:
  description: "inspect.Attribute.__name__.__len__() == 9 — 'Attribute' has 9 characters"
  category: identity
  kind: python_call_eq
  function: Attribute.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra278.fullargspec_is_namedtuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple whose sole base class is tuple"
  category: identity
  kind: python_call_eq
  function: "FullArgSpec.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant inspect_extra278.fullargspec_name_length_is_11:
  description: "inspect.FullArgSpec.__name__.__len__() == 11 — 'FullArgSpec' has 11 characters"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__name__.__len__
  args: []
  expected: 11

invariant inspect_extra278.getattr_static_module_is_inspect:
  description: "inspect.getattr_static.__module__ == 'inspect' — pure-Python function defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: getattr_static.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra278.getattr_static_is_function:
  description: "inspect.getattr_static.__class__.__name__ == 'function' — getattr_static is a pure-Python function"
  category: identity
  kind: python_call_eq
  function: getattr_static.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra278.getattr_static_name_length_is_14:
  description: "inspect.getattr_static.__name__.__len__() == 14 — 'getattr_static' has 14 characters"
  category: identity
  kind: python_call_eq
  function: getattr_static.__name__.__len__
  args: []
  expected: 14
