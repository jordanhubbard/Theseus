spec: inspect_extra251
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.isfunction, inspect.isbuiltin, inspect.isclass, and inspect.ismodule predicate function identity behavioral contracts."
    - "inspect.isfunction.__name__ == 'isfunction' — isfunction is a pure-Python predicate function; __name__ is 'isfunction'. Verified with Python 3.14.3."
    - "inspect.isfunction.__module__ == 'inspect' — isfunction is defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.isfunction.__class__.__name__ == 'function' — isfunction is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__name__ == 'isbuiltin' — isbuiltin is a pure-Python predicate function; __name__ is 'isbuiltin'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__module__ == 'inspect' — isbuiltin is defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__class__.__name__ == 'function' — isbuiltin is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "inspect.isclass.__name__ == 'isclass' — isclass is a pure-Python predicate function; __name__ is 'isclass'. Verified with Python 3.14.3."
    - "inspect.isclass.__module__ == 'inspect' — isclass is defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.isclass.__class__.__name__ == 'function' — isclass is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "inspect.ismodule.__name__ == 'ismodule' — ismodule is a pure-Python predicate function; __name__ is 'ismodule'. Verified with Python 3.14.3."
    - "inspect.ismodule.__module__ == 'inspect' — ismodule is defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.ismodule.__class__.__name__ == 'function' — ismodule is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "All predicate functions take a single object argument and return bool; lambda/instance arguments cannot be expressed in ZSDL, so only identity contracts are covered here."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isfunction predicate function identity
#
# inspect.isfunction.__name__ == 'isfunction'
# inspect.isfunction.__module__ == 'inspect'
# inspect.isfunction.__class__.__name__ == 'function'
#
# isfunction returns True if the object is a Python function created by a
# def statement. It is a pure-Python predicate defined in inspect.
# New to extra251.
# ---------------------------------------------------------------------------

table inspect_extra251.isfunction_identity:
  description: "inspect.isfunction __name__, __module__, __class__.__name__ identity contracts; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: isfunc251

  columns: [id, function, args, expected, description]
  rows:
    - [isfunc_name_eq,
       isfunction.__name__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — isfunction is a pure-Python predicate; __name__ is 'isfunction'; new to extra251"]
    - [isfunc_module_eq,
       isfunction.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — isfunction is defined in the inspect module; __module__ is 'inspect'; new to extra251"]
    - [isfunc_class_name_eq,
       isfunction.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isfunction.__class__.__name__.__eq__('function') == True — isfunction is a plain Python function; __class__.__name__ is 'function'; new to extra251"]
    - [isfunc_name_len_10,
       isfunction.__name__.__len__,
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters; new to extra251"]
    - [isfunc_module_len_7,
       isfunction.__module__.__len__,
       [],
       7,
       "inspect.isfunction.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra251"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isbuiltin predicate function identity
#
# inspect.isbuiltin.__name__ == 'isbuiltin'
# inspect.isbuiltin.__module__ == 'inspect'
# inspect.isbuiltin.__class__.__name__ == 'function'
#
# isbuiltin returns True if the object is a built-in function or bound
# built-in method. It is a pure-Python predicate defined in inspect.
# New to extra251.
# ---------------------------------------------------------------------------

table inspect_extra251.isbuiltin_identity:
  description: "inspect.isbuiltin __name__, __module__, __class__.__name__ identity contracts; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: isbuiltin251

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_name_eq,
       isbuiltin.__name__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — isbuiltin is a pure-Python predicate; __name__ is 'isbuiltin'; new to extra251"]
    - [isbuiltin_module_eq,
       isbuiltin.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is defined in the inspect module; __module__ is 'inspect'; new to extra251"]
    - [isbuiltin_class_name_eq,
       isbuiltin.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isbuiltin.__class__.__name__.__eq__('function') == True — isbuiltin is a plain Python function; __class__.__name__ is 'function'; new to extra251"]
    - [isbuiltin_name_len_9,
       isbuiltin.__name__.__len__,
       [],
       9,
       "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has 9 characters; new to extra251"]
    - [isbuiltin_module_len_7,
       isbuiltin.__module__.__len__,
       [],
       7,
       "inspect.isbuiltin.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra251"]

# ---------------------------------------------------------------------------
# Table 3: inspect.isclass and inspect.ismodule predicate function identity
#
# inspect.isclass.__name__ == 'isclass'
# inspect.isclass.__module__ == 'inspect'
# inspect.isclass.__class__.__name__ == 'function'
# inspect.ismodule.__name__ == 'ismodule'
# inspect.ismodule.__module__ == 'inspect'
# inspect.ismodule.__class__.__name__ == 'function'
#
# isclass returns True if the object is a class. ismodule returns True if
# the object is a module. Both are pure-Python predicates in inspect.
# New to extra251.
# ---------------------------------------------------------------------------

table inspect_extra251.isclass_ismodule_identity:
  description: "inspect.isclass and inspect.ismodule __name__, __module__, __class__.__name__ identity contracts; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: isclassmod251

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — isclass is a pure-Python predicate; __name__ is 'isclass'; new to extra251"]
    - [isclass_module_eq,
       isclass.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is defined in the inspect module; __module__ is 'inspect'; new to extra251"]
    - [isclass_class_name_eq,
       isclass.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isclass.__class__.__name__.__eq__('function') == True — isclass is a plain Python function; __class__.__name__ is 'function'; new to extra251"]
    - [ismodule_name_eq,
       ismodule.__name__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__name__.__eq__('ismodule') == True — ismodule is a pure-Python predicate; __name__ is 'ismodule'; new to extra251"]
    - [ismodule_module_eq,
       ismodule.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismodule.__module__.__eq__('inspect') == True — ismodule is defined in the inspect module; __module__ is 'inspect'; new to extra251"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra251
# ---------------------------------------------------------------------------

invariant inspect_extra251.isfunction.name_eq:
  description: "inspect.isfunction.__name__ == 'isfunction' — pure-Python predicate for Python functions; new to extra251"
  category: identity
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra251.isfunction.module_eq:
  description: "inspect.isfunction.__module__ == 'inspect' — defined in the inspect module; new to extra251"
  category: identity
  kind: python_call_eq
  function: isfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra251.isfunction.class_is_function:
  description: "inspect.isfunction.__class__.__name__ == 'function' — isfunction is a plain Python function; new to extra251"
  category: identity
  kind: python_call_eq
  function: isfunction.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra251.isfunction.name_len_10:
  description: "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters; new to extra251"
  category: identity
  kind: python_call_eq
  function: isfunction.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra251.isbuiltin.name_eq:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin' — pure-Python predicate for built-in functions; new to extra251"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra251.isbuiltin.module_eq:
  description: "inspect.isbuiltin.__module__ == 'inspect' — defined in the inspect module; new to extra251"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra251.isbuiltin.class_is_function:
  description: "inspect.isbuiltin.__class__.__name__ == 'function' — isbuiltin is a plain Python function; new to extra251"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra251.isbuiltin.name_len_9:
  description: "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has 9 characters; new to extra251"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra251.isclass.name_eq:
  description: "inspect.isclass.__name__ == 'isclass' — pure-Python predicate returning True for class objects; new to extra251"
  category: identity
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra251.isclass.module_eq:
  description: "inspect.isclass.__module__ == 'inspect' — defined in the inspect module; new to extra251"
  category: identity
  kind: python_call_eq
  function: isclass.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra251.isclass.class_is_function:
  description: "inspect.isclass.__class__.__name__ == 'function' — isclass is a plain Python function; new to extra251"
  category: identity
  kind: python_call_eq
  function: isclass.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra251.ismodule.name_eq:
  description: "inspect.ismodule.__name__ == 'ismodule' — pure-Python predicate returning True for module objects; new to extra251"
  category: identity
  kind: python_call_eq
  function: ismodule.__name__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra251.ismodule.module_eq:
  description: "inspect.ismodule.__module__ == 'inspect' — defined in the inspect module; new to extra251"
  category: identity
  kind: python_call_eq
  function: ismodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra251.ismodule.class_is_function:
  description: "inspect.ismodule.__class__.__name__ == 'function' — ismodule is a plain Python function; new to extra251"
  category: identity
  kind: python_call_eq
  function: ismodule.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra251.ismodule.name_len_8:
  description: "inspect.ismodule.__name__.__len__() == 8 — 'ismodule' has 8 characters; new to extra251"
  category: identity
  kind: python_call_eq
  function: ismodule.__name__.__len__
  args: []
  expected: 8
