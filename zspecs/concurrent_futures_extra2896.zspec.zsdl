spec: cf2896
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [concurrent.futures source, Python docs, https://docs.python.org/3/library/concurrent.futures.html]
  not_derived_from: [any external dataset, concurrent_futures_extra2881.zspec.zsdl — covers __iadd__/__isub__/__imul__ dict-presence, concurrent_futures_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence, concurrent_futures_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence]
  notes: [Wave 640 theme — __itruediv__/__ifloordiv__/__imod__ dict-presence checks for concurrent.futures types. In-place divide, floor-divide, and modulo operators. Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor/CancelledError/TimeoutError/BrokenExecutor/InvalidStateError are concurrency primitives not numeric types — none define these dunders. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

