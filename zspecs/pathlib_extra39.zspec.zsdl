spec: pathlib_extra39
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra38.zspec.zsdl — covers PureWindowsPath/__mro__.__len__()==3; UnsupportedOperation/__mro__.__len__()==6; PurePosixPath/PureWindowsPath/__bases__[0].__name__=='PurePath'; PosixPath/WindowsPath/__bases__[0].__name__.__len__()==4; Path.read_bytes/write_bytes/is_file/is_dir __qualname__.__len__(); PurePath.as_posix/joinpath/with_name/with_suffix __qualname__.__len__()."
  notes:
    - "This spec extends pathlib_extra38.zspec.zsdl."
    - "Prior specs collectively covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__ and lengths; MRO depths for all six classes and UnsupportedOperation; __bases__[0].__name__ for all six classes; Path methods open/read_text/write_text/read_bytes/write_bytes/mkdir/exists/stat/rename/unlink/rmdir/chmod/symlink_to/iterdir/glob/rglob/resolve/absolute/is_file/is_dir __qualname__.__len__(); PurePath methods as_posix/joinpath/with_name/with_suffix __qualname__.__len__(); PurePath.__reduce__.__qualname__."
    - "This spec covers NEW angles: PurePath.name/__qualname__.__len__()==13; PurePath.parent/__qualname__.__len__()==15; PurePath.suffix/__qualname__.__len__()==15; PurePath.stem/__qualname__.__len__()==13; PurePath.parts/__qualname__.__len__()==14; Path.is_symlink/__qualname__.__len__()==15; Path.is_mount/__qualname__.__len__()==13; Path.touch/__qualname__.__len__()==10; Path.cwd/__qualname__.__len__()==8; Path.home/__qualname__.__len__()==9; Path.expanduser/__qualname__.__len__()==15; Path.samefile/__qualname__.__len__()==13; Path.lstat/__qualname__.__len__()==10; PurePath.relative_to/__qualname__.__len__()==20; PurePath.is_relative_to/__qualname__.__len__()==23; PurePath.match/__qualname__.__len__()==14; PurePath.__str__/__qualname__.__len__()==16; PurePath.__fspath__/__qualname__.__len__()==19."
    - "PurePath.name.fget.__qualname__ == 'PurePath.name' — len 13. parent == 'PurePath.parent' — len 15. suffix == 'PurePath.suffix' — len 15. stem == 'PurePath.stem' — len 13. parts == 'PurePath.parts' — len 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Path.is_symlink.__qualname__ == 'Path.is_symlink' — len 15. is_mount == 'Path.is_mount' — len 13. touch == 'Path.touch' — len 10. cwd == 'Path.cwd' — len 8. home == 'Path.home' — len 9. expanduser == 'Path.expanduser' — len 15. samefile == 'Path.samefile' — len 13. lstat == 'Path.lstat' — len 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "PurePath.relative_to.__qualname__ == 'PurePath.relative_to' — len 20. is_relative_to == 'PurePath.is_relative_to' — len 23. match == 'PurePath.match' — len 14. __str__ == 'PurePath.__str__' — len 16. __fspath__ == 'PurePath.__fspath__' — len 19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath property __qualname__.__len__() — name, parent, suffix, stem, parts
#
# PurePath exposes name/parent/suffix/stem/parts as properties.
# Their fget qualnames follow the pattern 'PurePath.PROP'.
# No prior pathlib spec checks __qualname__.__len__() for any PurePath property.
# name   -> 'PurePath.name'   (13)
# parent -> 'PurePath.parent' (15)
# suffix -> 'PurePath.suffix' (15)
# stem   -> 'PurePath.stem'   (13)
# parts  -> 'PurePath.parts'  (14)
# ---------------------------------------------------------------------------

table pathlib_extra39.PurePath_property_qualname_lens:
  description: "pathlib.PurePath property fget __qualname__.__len__() — name(13)/parent(15)/suffix(15)/stem(13)/parts(14)"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: ppp39

  columns: [id, function, args, expected]
  rows:
    - [name,   "PurePath.name.fget.__qualname__.__len__",   [], 13]
    - [parent, "PurePath.parent.fget.__qualname__.__len__", [], 15]
    - [suffix, "PurePath.suffix.fget.__qualname__.__len__", [], 15]
    - [stem,   "PurePath.stem.fget.__qualname__.__len__",   [], 13]
    - [parts,  "PurePath.parts.fget.__qualname__.__len__",  [], 14]

# ---------------------------------------------------------------------------
# Path method __qualname__.__len__() — is_symlink, is_mount, touch, cwd, home
#
# No prior pathlib spec checks __qualname__.__len__() for any of these methods.
# is_symlink -> 'Path.is_symlink' (15)
# is_mount   -> 'Path.is_mount'   (13)
# touch      -> 'Path.touch'      (10)
# cwd        -> 'Path.cwd'        (8)
# home       -> 'Path.home'       (9)
# ---------------------------------------------------------------------------

table pathlib_extra39.Path_utility_method_qualname_lens:
  description: "pathlib.Path method __qualname__.__len__() — is_symlink(15)/is_mount(13)/touch(10)/cwd(8)/home(9)"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: pum39

  columns: [id, function, args, expected]
  rows:
    - [is_symlink, "Path.is_symlink.__qualname__.__len__", [], 15]
    - [is_mount,   "Path.is_mount.__qualname__.__len__",   [], 13]
    - [touch,      "Path.touch.__qualname__.__len__",      [], 10]
    - [cwd,        "Path.cwd.__qualname__.__len__",        [], 8]
    - [home,       "Path.home.__qualname__.__len__",       [], 9]

# ---------------------------------------------------------------------------
# Path method __qualname__.__len__() — expanduser, samefile, lstat
#
# No prior pathlib spec checks __qualname__.__len__() for expanduser, samefile, or lstat.
# expanduser -> 'Path.expanduser' (15)
# samefile   -> 'Path.samefile'   (13)
# lstat      -> 'Path.lstat'      (10)
# ---------------------------------------------------------------------------

invariant pathlib_extra39.Path_expanduser_qualname_len:
  description: "len(pathlib.Path.expanduser.__qualname__) == 15 — len('Path.expanduser') == 15"
  category: function_qualnames
  kind: python_call_eq
  function: "Path.expanduser.__qualname__.__len__"
  args: []
  expected: 15

invariant pathlib_extra39.Path_samefile_qualname_len:
  description: "len(pathlib.Path.samefile.__qualname__) == 13 — len('Path.samefile') == 13"
  category: function_qualnames
  kind: python_call_eq
  function: "Path.samefile.__qualname__.__len__"
  args: []
  expected: 13

invariant pathlib_extra39.Path_lstat_qualname_len:
  description: "len(pathlib.Path.lstat.__qualname__) == 10 — len('Path.lstat') == 10"
  category: function_qualnames
  kind: python_call_eq
  function: "Path.lstat.__qualname__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# PurePath method __qualname__.__len__() — relative_to, is_relative_to, match,
# __str__, __fspath__
#
# No prior pathlib spec checks __qualname__.__len__() for any of these methods.
# pathlib_extra38 covered as_posix/joinpath/with_name/with_suffix.
# relative_to      -> 'PurePath.relative_to'      (20)
# is_relative_to   -> 'PurePath.is_relative_to'   (23)
# match            -> 'PurePath.match'             (14)
# __str__          -> 'PurePath.__str__'           (16)
# __fspath__       -> 'PurePath.__fspath__'        (19)
# ---------------------------------------------------------------------------

table pathlib_extra39.PurePath_method_qualname_lens:
  description: "pathlib.PurePath method __qualname__.__len__() — relative_to(20)/is_relative_to(23)/match(14)/__str__(16)/__fspath__(19)"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: ppm39

  columns: [id, function, args, expected]
  rows:
    - [relative_to,    "PurePath.relative_to.__qualname__.__len__",    [], 20]
    - [is_relative_to, "PurePath.is_relative_to.__qualname__.__len__", [], 23]
    - [match,          "PurePath.match.__qualname__.__len__",          [], 14]
    - [dunder_str,     "PurePath.__str__.__qualname__.__len__",        [], 16]
    - [dunder_fspath,  "PurePath.__fspath__.__qualname__.__len__",     [], 19]
