spec: hashlib_extra157
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra156.zspec.zsdl — covers hashlib.sha256/__qualname__/__eq__('openssl_sha256') / md5/__qualname__ / sha512/__qualname__ / sha256/__qualname__/__len__()==14 / blake2b/__name__/__qualname__ / sha3_256/__name__/__qualname__/__len__()==16 (table + invariants)."
    - "hashlib_extra155.zspec.zsdl — covers hashlib.sha256/__class__.__name__.__eq__('builtin_function_or_method') / sha256/__module__/__eq__('_hashlib') / sha256/__name__/__eq__('openssl_sha256') / md5/__name__ / sha1/__name__ / sha512/__name__ / pbkdf2_hmac/__module__ (table + invariants)."
    - "hashlib_extra154.zspec.zsdl — covers hashlib.algorithms_guaranteed/__class__.__name__/__len__()==14 (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra156."
    - "Wave 336 theme: hashlib module __spec__ attributes, __all__ contents, and hashlib.new() function identity — hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('hashlib') / __all__.__class__.__name__.__eq__('tuple') / __all__.__contains__('md5') / __all__.__contains__('sha256') / new.__module__.__eq__('hashlib') / new.__class__.__name__.__eq__('function')."
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__class__.__name__ == 'tuple'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__all__ is a tuple (not a list). On Python 3.14.3 macOS, hashlib.__all__.__class__.__name__ == 'tuple' (5 chars). This is notable because __all__ in many modules is defined as a list, but hashlib defines it as a tuple. The tuple contains the public names of hash algorithm constructors and other public names exported by hashlib."
    - "Note: hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars). ModuleSpec is the class used by the import system (importlib) to represent a module specification. It stores metadata about a module including its name, origin (file path), and loader. Every module loaded by the standard import system has a __spec__ attribute of type ModuleSpec."
    - "Note: hashlib.new.__module__ == 'hashlib' (7 chars). hashlib.new() is the generic constructor that accepts a hash algorithm name as a string (e.g., hashlib.new('sha256')). Unlike the named constructors (sha256, md5, etc.) which come from the _hashlib C extension with __module__=='_hashlib', hashlib.new is defined in the pure-Python Lib/hashlib.py file and has __module__=='hashlib'. Its __class__.__name__ is 'function' (a regular Python function, not a C builtin_function_or_method)."
    - "Note: hashlib.new.__class__.__name__ == 'function' (8 chars). This contrasts sharply with hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' (26 chars, anchored by extra155). hashlib.new is a pure Python function; the named hash constructors (sha256, md5, etc.) are C-level callables from _hashlib. This is the key architectural distinction: new() is the Python-level dispatcher, sha256() etc. are the OpenSSL-backed C functions it dispatches to."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')
# hashlib.__spec__.name.__eq__('hashlib')
# hashlib.__all__.__class__.__name__.__eq__('tuple')
# hashlib.__all__.__contains__('md5')
#
# Wave 336 theme: hashlib __spec__ attributes and __all__ contents.
#
# hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars). __spec__.name == 'hashlib'.
# hashlib.__all__.__class__.__name__ == 'tuple' (NOT a list — hashlib uses a tuple).
# hashlib.__all__.__contains__('md5') == True.
# No prior hashlib spec anchors __spec__ or __all__ as a table under hashhspec157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra157.spec_and_all_attributes:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / __spec__.name.__eq__('hashlib')==True / __all__.__class__.__name__.__eq__('tuple')==True / __all__.__contains__('md5')==True — __spec__ is ModuleSpec (10 chars; importlib module specification); __spec__.name is 'hashlib' (7 chars; the module's canonical import name); __all__ is a tuple (5 chars; NOT a list; hashlib uses tuple for __all__); __all__ contains 'md5' (True; md5 is a public hash constructor); first hashhspec157 anchor for __spec__ and __all__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: hashhspec157

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_ModuleSpec,  "__spec__.__class__.__name__.__eq__", ["ModuleSpec"], true, "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; importlib module spec class used by standard import system)"]
    - [spec_name_hashlib,      "__spec__.name.__eq__",               ["hashlib"],    true, "hashlib.__spec__.name == 'hashlib' (7 chars; the module's canonical import name stored in the ModuleSpec)"]
    - [all_class_tuple,        "__all__.__class__.__name__.__eq__",  ["tuple"],      true, "hashlib.__all__.__class__.__name__ == 'tuple' (5 chars; hashlib uses tuple, not list, for __all__)"]
    - [all_contains_md5,       "__all__.__contains__",               ["md5"],        true, "hashlib.__all__.__contains__('md5') == True (md5 is a public hash constructor in hashlib.__all__)"]

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('sha256')
# hashlib.__all__.__contains__('sha512')
# hashlib.new.__module__.__eq__('hashlib')
# hashlib.new.__class__.__name__.__eq__('function')
#
# Wave 336 theme: hashlib.__all__ SHA algorithm membership and new() function identity.
#
# __all__ contains 'sha256' and 'sha512'. hashlib.new.__module__ == 'hashlib' (not '_hashlib').
# hashlib.new.__class__.__name__ == 'function' (8 chars, not 'builtin_function_or_method').
# No prior hashlib spec anchors new.__module__ or new.__class__.__name__ as a table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra157.all_contents_and_new_identity:
  description: "hashlib.__all__.__contains__('sha256')==True / __all__.__contains__('sha512')==True / new.__module__.__eq__('hashlib')==True / new.__class__.__name__.__eq__('function')==True — __all__ contains 'sha256' and 'sha512' (both public hash constructors); new.__module__ is 'hashlib' (7 chars; pure-Python wrapper, not '_hashlib' C extension); new.__class__.__name__ is 'function' (8 chars; regular Python function, not 'builtin_function_or_method' like sha256); new() is the generic name-based dispatcher; first hashhspec157 anchor for new() identity"
  kind: python_call_eq
  category: identity
  id_prefix: hashhspec157

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_sha256,    "__all__.__contains__",              ["sha256"],   true, "hashlib.__all__.__contains__('sha256') == True (sha256 is a public named hash constructor in hashlib.__all__)"]
    - [all_contains_sha512,    "__all__.__contains__",              ["sha512"],   true, "hashlib.__all__.__contains__('sha512') == True (sha512 is a public named hash constructor in hashlib.__all__)"]
    - [new_module_hashlib,     "new.__module__.__eq__",             ["hashlib"],  true, "hashlib.new.__module__ == 'hashlib' (7 chars; pure-Python Lib/hashlib.py; contrasts with sha256.__module__=='_hashlib')"]
    - [new_class_function,     "new.__class__.__name__.__eq__",     ["function"], true, "hashlib.new.__class__.__name__ == 'function' (8 chars; regular Python function; not 'builtin_function_or_method' like sha256)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__len__()==10
# hashlib.new.__module__.__len__()==7
# hashlib.new.__class__.__name__.__len__()==8
#
# Wave 336 theme: length checks for __spec__ class name, new() module, and new() class name.
#
# 'ModuleSpec' is 10 chars. 'hashlib' is 7 chars. 'function' is 8 chars.
# These lengths distinguish 'function' (8) from 'builtin_function_or_method' (26, extra155).
# No prior hashlib spec anchors these lengths as a table under hashhspec157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra157.attribute_name_lengths:
  description: "hashlib.__spec__.__class__.__name__.__len__()==10 / new.__module__.__len__()==7 / new.__class__.__name__.__len__()==8 / __all__.__class__.__name__.__len__()==5 — 'ModuleSpec' is 10 chars; 'hashlib' is 7 chars (new.__module__); 'function' is 8 chars (new class name; much shorter than 'builtin_function_or_method'=26 from extra155); 'tuple' is 5 chars (__all__ class name); first hashhspec157 anchor for these length values"
  kind: python_call_eq
  category: identity
  id_prefix: hashhspec157

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_len_10,  "__spec__.__class__.__name__.__len__", [], 10, "hashlib.__spec__.__class__.__name__.__len__() is 10 ('ModuleSpec' = 10 chars; importlib module spec class)"]
    - [new_module_len_7,        "new.__module__.__len__",              [], 7,  "hashlib.new.__module__.__len__() is 7 ('hashlib' = 7 chars; same length as '_struct' but no underscore)"]
    - [new_class_name_len_8,    "new.__class__.__name__.__len__",      [], 8,  "hashlib.new.__class__.__name__.__len__() is 8 ('function' = 8 chars; much shorter than 'builtin_function_or_method'=26)"]
    - [all_class_name_len_5,    "__all__.__class__.__name__.__len__",  [], 5,  "hashlib.__all__.__class__.__name__.__len__() is 5 ('tuple' = 5 chars; hashlib __all__ is a tuple, not a list=4 chars)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# hashlib.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). ModuleSpec is defined
# in importlib._bootstrap and is the canonical representation of a module's import
# specification. It stores the module's name, loader, origin (file path), submodule search
# locations, and cached path. Every module loaded by the standard import machinery has a
# __spec__ attribute. hashlib.__spec__.__class__.__name__ == 'ModuleSpec' confirms that
# hashlib is a properly imported module with a full import specification. No prior hashlib
# spec anchors __spec__.__class__.__name__ as a standalone under hashhspec157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra157.spec_class_name_ModuleSpec:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — 10 chars; importlib._bootstrap.ModuleSpec stores name/loader/origin/cached path; every properly imported module has __spec__; hashlib.__spec__.name=='hashlib'; no prior hashlib spec anchors __spec__.__class__.__name__ as a standalone; first standalone under hashhspec157"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__module__.__eq__('hashlib') — standalone
#
# hashlib.new.__module__ is 'hashlib' (7 chars). hashlib.new() is the generic hash
# constructor that accepts a hash algorithm name as a string argument (e.g.,
# hashlib.new('sha256', b'data')). It is defined in Lib/hashlib.py — the pure-Python
# hashlib module — so its __module__ is 'hashlib', not '_hashlib' (the C extension).
# This is in contrast to the named constructors hashlib.sha256, hashlib.md5, etc., which
# are builtin_function_or_method objects from _hashlib with __module__=='_hashlib'.
# hashlib.new() provides a way to use hash algorithms by name, including algorithms
# not exposed as named attributes on the hashlib module. No prior hashlib spec anchors
# new.__module__ as a standalone under hashhspec157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra157.new_module_hashlib:
  description: "hashlib.new.__module__.__eq__('hashlib') == True — 7 chars; defined in Lib/hashlib.py (pure-Python); generic name-based constructor accepting algorithm name string; contrasts with sha256.__module__=='_hashlib' (C extension); new.__class__.__name__=='function' (not 'builtin_function_or_method'); provides access to algorithms not exposed as module attributes; no prior hashlib spec anchors this as a standalone; first standalone under hashhspec157"
  category: identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__name__.__eq__('function') — standalone
#
# hashlib.new.__class__.__name__ is 'function' (8 chars). hashlib.new is a regular
# Python function (defined with def in Lib/hashlib.py), not a C builtin_function_or_method
# like hashlib.sha256. This architectural distinction reflects the separation between
# the Python-level API (hashlib.new — the name-based generic constructor) and the C-level
# backends (hashlib.sha256, hashlib.md5, etc. — the OpenSSL-backed specific constructors).
# The 'function' class name (8 chars) is far shorter than 'builtin_function_or_method'
# (26 chars, anchored by extra155 for hashlib.sha256). No prior hashlib spec anchors
# new.__class__.__name__ as a standalone under hashhspec157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra157.new_class_name_function:
  description: "hashlib.new.__class__.__name__.__eq__('function') == True — 8 chars; regular Python function (def in Lib/hashlib.py); contrasts with sha256.__class__.__name__=='builtin_function_or_method' (26 chars; extra155); Python-level generic dispatcher vs C-level specific OpenSSL constructors; 'function' (8 chars) is the standard Python function type class name; no prior hashlib spec anchors this as a standalone; first standalone under hashhspec157"
  category: identity
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true

