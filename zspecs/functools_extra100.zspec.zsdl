spec: functools_extra100
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra99

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra99.zspec.zsdl."
    - "This spec covers: functools reduce and cmp_to_key C-function identity — __qualname__, __module__, __doc__ class name; partial and partialmethod class identity (Wave 254)."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C built-in function from _functools. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce'. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — the underlying C module. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C built-in. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools'. Verified with Python 3.14.3."
    - "functools.partial.__class__.__name__ == 'type' — partial is a C extension type. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "functools.partial.__mro__.__len__() == 2 — mro is [partial, object]. Verified with Python 3.14.3."
    - "functools.partialmethod.__name__ == 'partialmethod'. Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.partialmethod.__qualname__ == 'partialmethod'. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "functools.partialmethod.__mro__.__len__() == 2 — mro is [partialmethod, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: reduce and cmp_to_key __qualname__ and __module__
#
# Wave 254 theme: C built-in function identity — qualname and module.
#
# functools.reduce.__qualname__.__eq__('reduce') == True
# functools.reduce.__module__.__eq__('_functools') == True
# functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True
# functools.cmp_to_key.__module__.__eq__('_functools') == True
#
# Both reduce and cmp_to_key are C built-ins from _functoolsmodule.c; their
# __module__ reflects the underlying C module '_functools', not 'functools'.
# New to extra100.
# ---------------------------------------------------------------------------

table functools_extra100.reduce_cmp_to_key_qualname_module:
  description: "functools.reduce and cmp_to_key __qualname__ and __module__; C built-ins from _functools; wave 254; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsreducecmpkey100

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_eq_reduce,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a C built-in function from Modules/_functoolsmodule.c; its __qualname__ is the simple name 'reduce' with no enclosing scope prefix; str.__eq__('reduce') returns True; new to extra100"]
    - [reduce_module_eq_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in Modules/_functoolsmodule.c and belongs to the C extension module '_functools'; even though functools re-exports it, __module__ reflects the C origin '_functools'; str.__eq__('_functools') returns True; new to extra100"]
    - [cmp_to_key_qualname_eq,
       "cmp_to_key.__qualname__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — cmp_to_key is a C built-in function from Modules/_functoolsmodule.c; __qualname__ is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra100"]
    - [cmp_to_key_module_eq_functools_c,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in Modules/_functoolsmodule.c; __module__ is '_functools' (the underlying C extension module); str.__eq__('_functools') returns True; new to extra100"]

# ---------------------------------------------------------------------------
# Table 2: partial class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__())
#
# Wave 254 theme: functools.partial C extension type identity.
#
# functools.partial.__name__.__eq__('partial') == True
# functools.partial.__module__.__eq__('functools') == True
# functools.partial.__qualname__.__eq__('partial') == True
# functools.partial.__bases__[0].__name__.__eq__('object') == True
# functools.partial.__mro__.__len__().__eq__(2) == True
#
# partial is a C extension type; it inherits directly from object; mro length is 2.
# New to extra100.
# ---------------------------------------------------------------------------

table functools_extra100.partial_class_identity:
  description: "functools.partial __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(); C extension type; wave 254; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsreducecmpkey100

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq_partial,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a C extension type defined in Modules/_functoolsmodule.c and exposed as functools.partial; __name__ is 'partial'; str.__eq__('partial') returns True; new to extra100"]
    - [partial_module_eq_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — despite being implemented in _functoolsmodule.c, the partial type has its __module__ set to 'functools' (not '_functools'); str.__eq__('functools') returns True; new to extra100"]
    - [partial_qualname_eq_partial,
       "partial.__qualname__.__eq__",
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is defined at module scope; its __qualname__ is the simple type name 'partial'; str.__eq__('partial') returns True; new to extra100"]
    - ["partial_bases0_eq_object",
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial is a C extension type with no custom base class; __bases__[0] is <class 'object'>; __name__ is 'object'; str.__eq__('object') returns True; new to extra100"]
    - [partial_mro_len_eq_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial's mro is [partial, object]; it has no intermediate base classes; tuple.__len__() returns 2; new to extra100"]

# ---------------------------------------------------------------------------
# Table 3: partialmethod class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__())
#
# Wave 254 theme: functools.partialmethod pure-Python class identity.
#
# functools.partialmethod.__name__.__eq__('partialmethod') == True
# functools.partialmethod.__module__.__eq__('functools') == True
# functools.partialmethod.__qualname__.__eq__('partialmethod') == True
# functools.partialmethod.__bases__[0].__name__.__eq__('object') == True
# functools.partialmethod.__mro__.__len__().__eq__(2) == True
#
# partialmethod is a pure-Python class; inherits from object; mro length is 2.
# New to extra100.
# ---------------------------------------------------------------------------

table functools_extra100.partialmethod_class_identity:
  description: "functools.partialmethod __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(); pure-Python class; wave 254; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsreducecmpkey100

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_eq,
       "partialmethod.__name__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod is a pure-Python class defined with 'class partialmethod:' in Lib/functools.py; __name__ is 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra100"]
    - [partialmethod_module_eq_functools,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra100"]
    - [partialmethod_qualname_eq,
       "partialmethod.__qualname__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — partialmethod is defined at module scope in Lib/functools.py; its __qualname__ is the simple class name 'partialmethod' with no enclosing scope prefix; str.__eq__('partialmethod') returns True; new to extra100"]
    - ["partialmethod_bases0_eq_object",
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod has no explicit base class in Lib/functools.py; it inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra100"]
    - [partialmethod_mro_len_eq_2,
       "partialmethod.__mro__.__len__",
       [],
       2,
       "functools.partialmethod.__mro__.__len__() == 2 — partialmethod's mro is [partialmethod, object]; no intermediate base classes; tuple.__len__() returns 2; new to extra100"]

# ---------------------------------------------------------------------------
# Table 4: Cross-checks — reduce/cmp_to_key __class__.__name__ equality
#
# Wave 254 theme: C built-in function __class__.__name__ cross-check.
#
# functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True
# functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True
# functools.reduce.__doc__.__class__.__name__.__eq__('str') == True
# functools.reduce.__class__.__name__.__eq__(functools.cmp_to_key.__class__.__name__) — same class
#
# Both reduce and cmp_to_key are 'builtin_function_or_method'; cross-checking
# via __eq__ confirms they share the same C function type. New to extra100.
# ---------------------------------------------------------------------------

table functools_extra100.reduce_cmp_to_key_class_names:
  description: "functools.reduce and cmp_to_key __class__.__name__ both 'builtin_function_or_method'; reduce __doc__ class name; cross-checks; wave 254; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsreducecmpkey100

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_eq_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C built-in function from Modules/_functoolsmodule.c; its __class__ is <class 'builtin_function_or_method'>; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra100"]
    - [cmp_to_key_class_name_eq_builtin,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is a C built-in function from Modules/_functoolsmodule.c; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; both reduce and cmp_to_key share this type; new to extra100"]
    - [reduce_doc_class_name_eq_str,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce has a C-defined docstring; the __doc__ attribute is a plain Python string; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra100"]
    - [partial_class_name_eq_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type (not a function); its __class__ is <class 'type'>; __class__.__name__ is 'type'; this cross-checks that partial differs from reduce/cmp_to_key in type identity; str.__eq__('type') returns True; new to extra100"]

