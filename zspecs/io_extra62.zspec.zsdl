spec: io_extra62
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra61.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __class__.__module__.__eq__('builtins'); IOBase/RawIOBase/BufferedIOBase/TextIOBase __class__.__module__.__eq__('abc'); io.__spec__.name.__eq__('io') and io.__spec__.name.__len__()==2."
    - "io_extra60.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); io module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "io_extra59.zspec.zsdl — covers DEFAULT_BUFFER_SIZE __class__.__module__.__eq__('builtins') and __class__.__module__.__len__()==8; BufferedIOBase/TextIOBase __module__ equality/length."
    - "io_extra58.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __module__.__eq__('_io'); IOBase/RawIOBase __module__.__eq__('io'); open __module__.__eq__('_io')."
    - "io_extra57.zspec.zsdl — covers BytesIO/StringIO method qualname equality for read/write/seek/tell/getvalue."
    - "io_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname for io classes and module."
    - "io_extra37.zspec.zsdl — covers __dict__.__class__.__name__.__len__()==12 for StringIO/BytesIO/IOBase/FileIO/RawIOBase/BufferedReader/TextIOWrapper."
  notes:
    - "This spec extends io_extra61.zspec.zsdl."
    - "Prior specs collectively covered: io_extra56 covers __doc__.__class__.__name__/qualname; io_extra61 covers __spec__.name.__eq__('io') and __spec__.name.__len__()==2 and __class__.__module__ for BytesIO/StringIO/etc. NOT YET COVERED: BytesIO/StringIO/TextIOWrapper/IOBase/RawIOBase __repr__.__class__.__name__.__eq__('wrapper_descriptor') — no prior io spec checks __repr__.__class__.__name__ for any io class; novel; io.__spec__.__class__.__name__.__eq__('ModuleSpec') — io_extra61 covers __spec__.name but not __spec__.__class__.__name__; novel; io.__spec__.name.__class__.__name__.__eq__('str') — io_extra61 covers the name value itself but not the type of the name attribute; novel; BytesIO/StringIO __hash__.__class__.__name__.__eq__('wrapper_descriptor') — no prior io spec checks __hash__.__class__.__name__ for any io class; novel."
    - "This spec covers: io.BytesIO.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — BytesIO is a C-extension type; __repr__ is inherited from object as a 'wrapper_descriptor'; no prior io spec checks __repr__.__class__.__name__; novel in iorepr62 namespace); io.StringIO.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL); io.TextIOWrapper.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — TextIOWrapper defines its own __repr__ in its __dict__ as a wrapper_descriptor slot wrapper); io.IOBase.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL); io.RawIOBase.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL); io.__spec__.__class__.__name__.__eq__('ModuleSpec') (NOVEL — the io module's __spec__ attribute is an instance of importlib.machinery.ModuleSpec; io_extra61 covers __spec__.name but not __spec__.__class__.__name__; novel module-spec type anchor in iorepr62 namespace); io.__spec__.name.__class__.__name__.__eq__('str') (NOVEL — io_extra61 covers io.__spec__.name.__eq__('io') and __len__()==2 but not the type of the name attribute; the .name attribute is a str; novel); io.BytesIO.__hash__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — BytesIO inherits __hash__ from object; object.__hash__ is a wrapper_descriptor; BytesIO is not unhashable (defines no __eq__); no prior io spec checks __hash__.__class__.__name__ for any io class; novel in iorepr62 namespace); io.StringIO.__hash__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL)."
    - "io.BytesIO.__repr__.__class__.__name__ == 'wrapper_descriptor'. BytesIO is a C-extension type. __repr__ is NOT in BytesIO.__dict__ (BytesIO does not define its own __repr__); it inherits object.__repr__, which is a wrapper_descriptor. The actual type name in Python 3.14.3 is 'wrapper_descriptor', not 'slot_wrapper'. No prior io spec checks __repr__.__class__.__name__ for BytesIO. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.StringIO.__repr__.__class__.__name__ == 'wrapper_descriptor'. Same as BytesIO — __repr__ is not in StringIO.__dict__; inherits from object. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.__repr__.__class__.__name__ == 'wrapper_descriptor'. TextIOWrapper DOES define __repr__ in its own __dict__ as a slot wrapper for '_io.TextIOWrapper' objects. The class name is still 'wrapper_descriptor'. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.IOBase.__repr__.__class__.__name__ == 'wrapper_descriptor'. IOBase is an ABC; __repr__ is not in IOBase.__dict__; inherits from object. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__repr__.__class__.__name__ == 'wrapper_descriptor'. RawIOBase is an ABC; same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__spec__.__class__.__name__ == 'ModuleSpec'. The io module's __spec__ attribute holds an importlib.machinery.ModuleSpec instance. The ModuleSpec class name is 'ModuleSpec'. io_extra61 covers io.__spec__.name (the name attribute value) but not the type of the __spec__ object itself. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__spec__.name.__class__.__name__ == 'str'. The .name attribute of a ModuleSpec is a plain Python str. io_extra61 covers the value io.__spec__.name.__eq__('io') and __len__()==2, but not the type of the name attribute. Novel type anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.BytesIO.__hash__.__class__.__name__ == 'wrapper_descriptor'. BytesIO inherits __hash__ from object (object.__hash__ is a wrapper_descriptor). BytesIO does not define __eq__, so it is hashable and inherits object.__hash__. No prior io spec checks __hash__.__class__.__name__ for any io class. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.StringIO.__hash__.__class__.__name__ == 'wrapper_descriptor'. Same as BytesIO — inherits object.__hash__ as a wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io C-extension and ABC class __repr__.__class__.__name__ == 'wrapper_descriptor'
#
# For C-extension io types (BytesIO, StringIO, TextIOWrapper) and abstract base
# classes (IOBase, RawIOBase), the __repr__ special method is a 'wrapper_descriptor'
# object. BytesIO and StringIO inherit __repr__ from object (not in their own
# __dict__). TextIOWrapper defines its own __repr__ in its __dict__ but it is
# still a wrapper_descriptor (a C-level slot wrapper for '_io.TextIOWrapper'
# objects). IOBase and RawIOBase are ABCs that also inherit __repr__ from object.
#
# Note: In Python 3.14.3, the class name is 'wrapper_descriptor', not 'slot_wrapper'.
# 'slot_wrapper' does not appear as a type name in this Python version.
#
#   BytesIO.__repr__.__class__.__name__     == 'wrapper_descriptor'
#   StringIO.__repr__.__class__.__name__    == 'wrapper_descriptor'
#   TextIOWrapper.__repr__.__class__.__name__ == 'wrapper_descriptor'
#   IOBase.__repr__.__class__.__name__      == 'wrapper_descriptor'
#   RawIOBase.__repr__.__class__.__name__   == 'wrapper_descriptor'
#
# No prior io spec checks __repr__.__class__.__name__ for any io class.
# All five anchors are novel in the iorepr62 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra62.repr_class_name_eq:
  description: "io class __repr__.__class__.__name__.__eq__('wrapper_descriptor') for BytesIO/StringIO/TextIOWrapper/IOBase/RawIOBase — C-extension and ABC io types' __repr__ is a wrapper_descriptor slot; BytesIO/StringIO/IOBase/RawIOBase inherit from object; TextIOWrapper defines its own __repr__ in its __dict__; no prior io spec checks __repr__.__class__.__name__; all five novel anchors in iorepr62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iorepr62repr

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_repr_class_name,      "BytesIO.__repr__.__class__.__name__.__eq__",      ["wrapper_descriptor"], true]
    - [StringIO_repr_class_name,     "StringIO.__repr__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true]
    - [TextIOWrapper_repr_class_name, "TextIOWrapper.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - [IOBase_repr_class_name,       "IOBase.__repr__.__class__.__name__.__eq__",       ["wrapper_descriptor"], true]
    - [RawIOBase_repr_class_name,    "RawIOBase.__repr__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# io module __spec__ object type identity
#
# The io module's __spec__ attribute is an importlib.machinery.ModuleSpec
# instance. Its __class__.__name__ is 'ModuleSpec'. The .name attribute of
# the ModuleSpec is a plain str. io_extra61 covers io.__spec__.name.__eq__('io')
# and io.__spec__.name.__len__()==2 but does NOT check the type of the __spec__
# object itself or the type of its .name attribute.
#
#   io.__spec__.__class__.__name__    == 'ModuleSpec'
#   io.__spec__.name.__class__.__name__ == 'str'
#
# Both anchors are novel in the iorepr62 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra62.spec_class_name_eq:
  description: "io module __spec__ object type identity — io.__spec__.__class__.__name__.__eq__('ModuleSpec') and io.__spec__.name.__class__.__name__.__eq__('str'); io_extra61 covers __spec__.name value and length but not the type of __spec__ or its .name attribute; both novel anchors in iorepr62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: iorepr62spec

  columns: [id, function, args, expected]
  rows:
    - [spec_class_name,      "__spec__.__class__.__name__.__eq__",      ["ModuleSpec"], true]
    - [spec_name_class_name, "__spec__.name.__class__.__name__.__eq__", ["str"],        true]

# ---------------------------------------------------------------------------
# io BytesIO/StringIO __hash__.__class__.__name__ == 'wrapper_descriptor'
#
# BytesIO and StringIO do not define __eq__, so they inherit __hash__ from
# object. object.__hash__ is a wrapper_descriptor. Therefore:
#
#   BytesIO.__hash__.__class__.__name__ == 'wrapper_descriptor'
#   StringIO.__hash__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior io spec checks __hash__.__class__.__name__ for any io class.
# Both anchors are novel in the iorepr62 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra62.hash_class_name_eq:
  description: "io BytesIO/StringIO __hash__.__class__.__name__.__eq__('wrapper_descriptor') — BytesIO and StringIO inherit __hash__ from object (object.__hash__ is a wrapper_descriptor); both classes do not define __eq__ so they remain hashable; no prior io spec checks __hash__.__class__.__name__ for any io class; both novel anchors in iorepr62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iorepr62hash

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_hash_class_name,  "BytesIO.__hash__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - [StringIO_hash_class_name, "StringIO.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

invariant io_extra62.BytesIO_repr_class_name_wrapper_descriptor:
  description: "io.BytesIO.__repr__.__class__.__name__ == 'wrapper_descriptor' — BytesIO is a C-extension type that does not define __repr__ in its own __dict__; it inherits object.__repr__ which is a wrapper_descriptor; in Python 3.14.3 the class name is 'wrapper_descriptor' (not 'slot_wrapper'); no prior io spec checks __repr__.__class__.__name__; novel anchor in iorepr62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra62.spec_class_name_ModuleSpec:
  description: "io.__spec__.__class__.__name__ == 'ModuleSpec' — the io module's __spec__ attribute is an importlib.machinery.ModuleSpec instance; io_extra61 covers __spec__.name value and length but not __spec__.__class__.__name__; novel module-spec type anchor in iorepr62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant io_extra62.BytesIO_hash_class_name_wrapper_descriptor:
  description: "io.BytesIO.__hash__.__class__.__name__ == 'wrapper_descriptor' — BytesIO inherits __hash__ from object; object.__hash__ is a wrapper_descriptor; BytesIO does not define __eq__ so it is hashable; no prior io spec checks __hash__.__class__.__name__ for any io class; novel anchor in iorepr62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__hash__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
