spec: itertools_extra36
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra35.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types (chain/cycle/count/dropwhile/filterfalse/groupby/islice/pairwise/permutations/combinations/product/repeat/starmap/takewhile/zip_longest/accumulate/compress/combinations_with_replacement); __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 ('object') for all major types; __dict__.__class__.__name__.__len__()==12 ('mappingproxy') for all major types; chain.from_iterable.__name__.__len__()==13; chain.__doc__.__len__()==190; count.__doc__.__len__()==205; repeat.__doc__.__len__()==154; itertools.__name__.__len__()==9; itertools.__package__.__len__()==0; itertools.__spec__.__class__.__name__.__len__()==10; itertools.__doc__.__class__.__name__.__len__()==3."
    - "This spec covers: dropwhile.__doc__.__len__() (126 — C-type docstring); takewhile.__doc__.__len__() (101 — shorter than dropwhile by 25 chars); compress.__doc__.__len__() (164 — the longest of the filtering trio); accumulate.__doc__.__len__() (69 — shortest of all itertools C-type docstrings); filterfalse.__doc__.__len__() (120); starmap.__doc__.__len__() (126 — same length as dropwhile, a numeric coincidence); pairwise.__doc__.__len__() (112)."
    - "Key findings: itertools.dropwhile.__doc__ is 126 chars — describing predicate-based skipping before yielding the rest. itertools.takewhile.__doc__ is 101 chars — the shorter complement of dropwhile. itertools.compress.__doc__ is 164 chars — the longest docstring of the filtering trio (compress/dropwhile/takewhile), because it describes the selector mechanism. itertools.accumulate.__doc__ is 69 chars — the shortest C-type docstring in itertools, just two terse sentences. itertools.filterfalse.__doc__ is 120 chars. itertools.starmap.__doc__ is 126 chars — coincidentally equal to dropwhile. itertools.pairwise.__doc__ is 112 chars."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Filtering-predicate C-type docstring lengths — extra36 namespace
#
# itertools.dropwhile.__doc__ is 126 characters. itertools.takewhile.__doc__ is
# 101 characters — the shorter complement of dropwhile (dropwhile skips then
# yields all; takewhile yields then stops, so its description is more terse).
# itertools.compress.__doc__ is 164 characters — the longest of the three
# filtering types because it must describe a two-iterable (data + selectors)
# protocol. No prior itertools spec records __doc__.__len__() for dropwhile,
# takewhile, or compress. These three values are recorded together for the first
# time in the extra36 namespace.
# ---------------------------------------------------------------------------

table itertools_extra36.filter_type_docstring_lengths:
  description: "itertools filtering C-type __doc__.__len__(): compress(164), dropwhile(126), takewhile(101)"
  kind: python_call_eq
  category: string_properties
  id_prefix: filterdoclen36

  columns: [id, function, args, expected, description]
  rows:
    - [compress,
       compress.__doc__.__len__,
       [],
       164,
       "len(itertools.compress.__doc__) == 164 — longest filtering-type docstring; describes two-iterable (data + selectors) protocol"]
    - [dropwhile,
       dropwhile.__doc__.__len__,
       [],
       126,
       "len(itertools.dropwhile.__doc__) == 126 — C-type docstring: skip while predicate true, then yield all remaining"]
    - [takewhile,
       takewhile.__doc__.__len__,
       [],
       101,
       "len(itertools.takewhile.__doc__) == 101 — shortest filtering-type docstring; yield while predicate true, then stop"]

# ---------------------------------------------------------------------------
# Mapping and accumulating C-type docstring lengths — extra36 namespace
#
# itertools.accumulate.__doc__ is 69 characters — the shortest C-type docstring
# in all of itertools. itertools.starmap.__doc__ is 126 characters — coincidentally
# equal to dropwhile.__doc__.__len__(). itertools.filterfalse.__doc__ is 120
# characters. itertools.pairwise.__doc__ is 112 characters. No prior itertools
# spec records __doc__.__len__() for accumulate, starmap, filterfalse, or pairwise.
# These four values are recorded together for the first time in the extra36 namespace.
# ---------------------------------------------------------------------------

table itertools_extra36.map_accum_type_docstring_lengths:
  description: "itertools mapping/accumulating C-type __doc__.__len__(): accumulate(69), pairwise(112), filterfalse(120), starmap(126)"
  kind: python_call_eq
  category: string_properties
  id_prefix: mapdoclen36

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate,
       accumulate.__doc__.__len__,
       [],
       69,
       "len(itertools.accumulate.__doc__) == 69 — the shortest C-type docstring in all of itertools"]
    - [pairwise,
       pairwise.__doc__.__len__,
       [],
       112,
       "len(itertools.pairwise.__doc__) == 112 — C-type docstring describing consecutive overlapping pairs"]
    - [filterfalse,
       filterfalse.__doc__.__len__,
       [],
       120,
       "len(itertools.filterfalse.__doc__) == 120 — C-type docstring; complement of the builtin filter"]
    - [starmap,
       starmap.__doc__.__len__,
       [],
       126,
       "len(itertools.starmap.__doc__) == 126 — coincidentally equal to dropwhile.__doc__.__len__(); maps a function over argument tuples"]

# ---------------------------------------------------------------------------
# itertools.cycle.__doc__.__len__() — extra36 namespace
#
# itertools.cycle.__doc__ is 95 characters — the shortest docstring among the
# 'infinite iterator' trio (count=205, repeat=154, cycle=95). cycle has the
# shortest docstring because it simply describes cycling through elements
# indefinitely, which requires minimal explanation. No prior itertools spec
# records cycle.__doc__.__len__() == 95 in the extra36 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra36.cycle_doc_len:
  description: "len(itertools.cycle.__doc__) == 95 — shortest of the infinite-iterator trio (count=205, repeat=154, cycle=95)"
  category: string_properties
  kind: python_call_eq
  function: cycle.__doc__.__len__
  args: []
  expected: 95
