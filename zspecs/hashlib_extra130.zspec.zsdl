spec: hashlib_extra130
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra129.zspec.zsdl — covers sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/shake_128/shake_256 constructor __qualname__.__len__() values (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class identity and __module__/__qualname__ / new __class__.__name__ / algorithms_guaranteed __len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / algorithms_available membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ equality (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra129."
    - "Wave 296 theme: hashlib.pbkdf2_hmac and hashlib.scrypt code attributes — __class__.__name__, __module__, __qualname__, __name__ equality for both key-derivation functions."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__qualname__ == 'scrypt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__name__ == 'scrypt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.pbkdf2_hmac.__name__) == 11 ('pbkdf2_hmac' is 11 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.pbkdf2_hmac.__qualname__) == 11 ('pbkdf2_hmac' is 11 chars; __qualname__ == __name__ for top-level C builtins). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.scrypt.__name__) == 6 ('scrypt' is 6 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.scrypt.__qualname__) == 6 ('scrypt' is 6 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Both pbkdf2_hmac and scrypt are C-level builtin functions from the _hashlib extension module. Their __module__ is '_hashlib' (the C extension), not 'hashlib' (the Python wrapper). This matches the pattern of sha256/sha512 constructors (extra95 anchors their __module__=='_hashlib')."
    - "Note: pbkdf2_hmac.__name__ == pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' — for top-level C builtins, __name__ and __qualname__ are equal. Same for scrypt. No enclosing class so no 'Class.' prefix in __qualname__."
    - "Note: pbkdf2_hmac implements PBKDF2 (Password-Based Key Derivation Function 2) using HMAC. scrypt implements the scrypt memory-hard KDF. Both are in the _hashlib C extension via OpenSSL."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib')
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac')
#
# Wave 296 theme: pbkdf2_hmac code attributes.
#
# pbkdf2_hmac is a C-level builtin function from the _hashlib extension module.
# Its __class__.__name__ is 'builtin_function_or_method' (same class as sha256,
# sha512, and other hashlib C-level functions). Its __module__ is '_hashlib'
# (not 'hashlib'), matching the pattern anchored in extra95 for sha256 etc.
# Its __qualname__ == __name__ == 'pbkdf2_hmac' (11 chars, no class prefix).
# No prior hashlib spec anchors pbkdf2_hmac __class__.__name__, __module__,
# __qualname__, or __name__ equality under hashlibkdf130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra130.pbkdf2_hmac_attrs:
  description: "hashlib.pbkdf2_hmac/__class__.__name__.__eq__('builtin_function_or_method')==True / pbkdf2_hmac/__module__.__eq__('_hashlib')==True / pbkdf2_hmac/__qualname__.__eq__('pbkdf2_hmac')==True / pbkdf2_hmac/__name__.__eq__('pbkdf2_hmac')==True — pbkdf2_hmac is a C-level builtin from _hashlib; __module__=='_hashlib' (not 'hashlib'); __qualname__==__name__=='pbkdf2_hmac' (11 chars); no prior hashlib spec anchors these; first hashlibkdf130 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibkdf130

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_class_name,   "pbkdf2_hmac.__class__.__name__.__eq__",  ["builtin_function_or_method"],  true,  "pbkdf2_hmac.__class__.__name__ is 'builtin_function_or_method' (C-level, same as sha256/sha512)"]
    - [pbkdf2_module_eq,    "pbkdf2_hmac.__module__.__eq__",          ["_hashlib"],                    true,  "pbkdf2_hmac.__module__ is '_hashlib' (C extension, not the Python 'hashlib' wrapper)"]
    - [pbkdf2_qualname_eq,  "pbkdf2_hmac.__qualname__.__eq__",        ["pbkdf2_hmac"],                 true,  "pbkdf2_hmac.__qualname__ is 'pbkdf2_hmac' (11 chars; equals __name__ for top-level C builtins)"]
    - [pbkdf2_name_eq,      "pbkdf2_hmac.__name__.__eq__",            ["pbkdf2_hmac"],                 true,  "pbkdf2_hmac.__name__ is 'pbkdf2_hmac' (11 chars; PBKDF2 key derivation function)"]

# ---------------------------------------------------------------------------
# hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.scrypt.__module__.__eq__('_hashlib')
# hashlib.scrypt.__qualname__.__eq__('scrypt')
# hashlib.scrypt.__name__.__eq__('scrypt')
#
# Wave 296 theme: scrypt code attributes.
#
# scrypt is a C-level builtin function from _hashlib implementing the scrypt
# memory-hard key derivation function. Its __class__.__name__ is
# 'builtin_function_or_method'. Its __module__ is '_hashlib'. Its __qualname__
# == __name__ == 'scrypt' (6 chars, shorter than pbkdf2_hmac at 11). No prior
# hashlib spec anchors scrypt __class__.__name__, __module__, __qualname__, or
# __name__ equality under hashlibkdf130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra130.scrypt_attrs:
  description: "hashlib.scrypt/__class__.__name__.__eq__('builtin_function_or_method')==True / scrypt/__module__.__eq__('_hashlib')==True / scrypt/__qualname__.__eq__('scrypt')==True / scrypt/__name__.__eq__('scrypt')==True — scrypt is a C-level builtin from _hashlib implementing the memory-hard scrypt KDF; __module__=='_hashlib'; __qualname__==__name__=='scrypt' (6 chars, shorter than pbkdf2_hmac); no prior hashlib spec anchors these; first hashlibkdf130 scrypt anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibkdf130

  columns: [id, function, args, expected, description]
  rows:
    - [scrypt_class_name,   "scrypt.__class__.__name__.__eq__",  ["builtin_function_or_method"],  true,  "scrypt.__class__.__name__ is 'builtin_function_or_method' (C-level, same class as pbkdf2_hmac)"]
    - [scrypt_module_eq,    "scrypt.__module__.__eq__",          ["_hashlib"],                    true,  "scrypt.__module__ is '_hashlib' (C extension; memory-hard KDF via OpenSSL)"]
    - [scrypt_qualname_eq,  "scrypt.__qualname__.__eq__",        ["scrypt"],                      true,  "scrypt.__qualname__ is 'scrypt' (6 chars; equals __name__ for top-level C builtins)"]
    - [scrypt_name_eq,      "scrypt.__name__.__eq__",            ["scrypt"],                      true,  "scrypt.__name__ is 'scrypt' (6 chars; shorter than pbkdf2_hmac 11 chars)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__len__()==11
# hashlib.pbkdf2_hmac.__qualname__.__len__()==11
# hashlib.scrypt.__name__.__len__()==6
# hashlib.scrypt.__qualname__.__len__()==6
#
# Wave 296 theme: pbkdf2_hmac and scrypt name/qualname lengths.
#
# pbkdf2_hmac.__name__.__len__() is 11 ('pbkdf2_hmac' = 7 chars 'pbkdf2_' + 4 chars 'hmac').
# scrypt.__name__.__len__() is 6 ('scrypt'). For top-level C builtins __name__==__qualname__
# so both lengths are equal. pbkdf2_hmac (11) is longer than most hashlib function names.
# No prior hashlib spec anchors pbkdf2_hmac or scrypt name/qualname lengths
# under hashlibkdf130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra130.kdf_name_lengths:
  description: "hashlib.pbkdf2_hmac/__name__/__len__()==11 / pbkdf2_hmac/__qualname__/__len__()==11 / scrypt/__name__/__len__()==6 / scrypt/__qualname__/__len__()==6 — pbkdf2_hmac name is 11 chars ('pbkdf2_hmac'); scrypt name is 6 chars ('scrypt'); for top-level C builtins __name__==__qualname__ so lengths are equal; no prior hashlib spec anchors these lengths; first hashlibkdf130 anchor"
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlibkdf130

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_name_len,      "pbkdf2_hmac.__name__.__len__",      [],  11,  "pbkdf2_hmac.__name__.__len__() is 11 ('pbkdf2_' 7 + 'hmac' 4)"]
    - [pbkdf2_qualname_len,  "pbkdf2_hmac.__qualname__.__len__",  [],  11,  "pbkdf2_hmac.__qualname__.__len__() is 11 (equals __name__.__len__() for top-level C builtins)"]
    - [scrypt_name_len,      "scrypt.__name__.__len__",           [],  6,   "scrypt.__name__.__len__() is 6 ('scrypt' is 6 chars)"]
    - [scrypt_qualname_len,  "scrypt.__qualname__.__len__",       [],  6,   "scrypt.__qualname__.__len__() is 6 (equals __name__.__len__() for top-level C builtins)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.pbkdf2_hmac.__class__.__name__ is 'builtin_function_or_method'. pbkdf2_hmac
# is a C-level function in the _hashlib extension module, not a Python-level function.
# This matches the sha256/sha512/sha1/md5/sha224/sha384/sha3_*/shake_* constructors
# (anchored in extra99/extra98). hashlib.new.__class__.__name__ is also
# 'builtin_function_or_method' (anchored in extra99). No prior hashlib spec anchors
# pbkdf2_hmac.__class__.__name__ as a standalone under hashlibkdf130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra130.pbkdf2_hmac_class_name_builtin:
  description: "hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') == True — pbkdf2_hmac is a C-level builtin; same class as sha256/sha512 constructors (extra99 anchors those); no prior hashlib spec anchors pbkdf2_hmac.__class__.__name__ as standalone; first standalone under hashlibkdf130"
  category: function_identity
  kind: python_call_eq
  function: "pbkdf2_hmac.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.scrypt.__module__.__eq__('_hashlib') — standalone
#
# hashlib.scrypt.__module__ is '_hashlib'. scrypt is defined in the _hashlib C
# extension module, not in the Python-level hashlib wrapper. This is the same
# __module__ value as all other hashlib C-level functions (sha256, sha512,
# pbkdf2_hmac, etc.). The _hashlib module is the OpenSSL-backed C extension
# that provides cryptographic hash implementations. No prior hashlib spec anchors
# scrypt.__module__.__eq__('_hashlib') as a standalone under hashlibkdf130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra130.scrypt_module_hashlib:
  description: "hashlib.scrypt.__module__.__eq__('_hashlib') == True — scrypt's __module__ is '_hashlib' (C extension), not 'hashlib' (Python wrapper); same pattern as sha256/sha512/pbkdf2_hmac; no prior hashlib spec anchors scrypt.__module__ as standalone; first standalone under hashlibkdf130"
  category: function_identity
  kind: python_call_eq
  function: "scrypt.__module__.__eq__"
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') — standalone
#
# hashlib.pbkdf2_hmac.__module__ is '_hashlib'. pbkdf2_hmac is exported from
# the _hashlib C extension module. The Python-level 'hashlib' module imports
# pbkdf2_hmac from _hashlib, but the function's own __module__ attribute
# reflects its origin in the C extension. This contrasts with pure-Python
# hashlib functions (if any) whose __module__ would be 'hashlib'. No prior
# hashlib spec anchors pbkdf2_hmac.__module__.__eq__('_hashlib') as a
# standalone under hashlibkdf130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra130.pbkdf2_hmac_module_hashlib:
  description: "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — pbkdf2_hmac.__module__ is '_hashlib' (C extension); reflects origin in the C extension not the Python wrapper; extra95 anchors sha256.__module__=='_hashlib'; no prior hashlib spec anchors pbkdf2_hmac.__module__ as standalone; first standalone under hashlibkdf130"
  category: function_identity
  kind: python_call_eq
  function: "pbkdf2_hmac.__module__.__eq__"
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__len__()==11 — standalone
#
# hashlib.pbkdf2_hmac.__name__.__len__() is 11. 'pbkdf2_hmac' has 7 chars in
# 'pbkdf2_' plus 4 chars in 'hmac' = 11. Among all hashlib functions by name
# length, this is among the longest (sha3_256.__qualname__ is 16 but that is
# qualname including 'openssl_' prefix). pbkdf2_hmac is the full name of the
# PBKDF2-HMAC key derivation function. No prior hashlib spec anchors
# pbkdf2_hmac.__name__.__len__()==11 as a standalone under hashlibkdf130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra130.pbkdf2_hmac_name_len_11:
  description: "hashlib.pbkdf2_hmac.__name__.__len__() == 11 — 'pbkdf2_hmac' is 11 chars ('pbkdf2_'7 + 'hmac'4); among the longer hashlib function names; no prior hashlib spec anchors pbkdf2_hmac.__name__.__len__() as standalone; first standalone under hashlibkdf130"
  category: name_lengths
  kind: python_call_eq
  function: "pbkdf2_hmac.__name__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# hashlib.scrypt.__name__.__len__()==6 — standalone
#
# hashlib.scrypt.__name__.__len__() is 6. 'scrypt' is a 6-character name.
# This is shorter than pbkdf2_hmac (11) and comparable to 'sha256'
# (6 chars, though sha256.__qualname__ is 'openssl_sha256' at 14 chars).
# For scrypt, __name__ == __qualname__ == 'scrypt' so both have length 6.
# No prior hashlib spec anchors scrypt.__name__.__len__()==6 as a standalone
# under hashlibkdf130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra130.scrypt_name_len_6:
  description: "hashlib.scrypt.__name__.__len__() == 6 — 'scrypt' is 6 chars; shorter than pbkdf2_hmac (11); for top-level C builtins __name__==__qualname__ so both are 6 chars; no prior hashlib spec anchors scrypt.__name__.__len__() as standalone; first standalone under hashlibkdf130"
  category: name_lengths
  kind: python_call_eq
  function: "scrypt.__name__.__len__"
  args: []
  expected: 6
