spec: destr
version: ">=2.0.0"
backend: node(destr)

docs: https://github.com/unjs/destr#readme

provenance:
  derived_from:
    - "destr README — https://github.com/unjs/destr#readme"
    - "Test vectors verified with destr via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "destr source"
  notes:
    - "Safe, fast & convenient JSON parser — never throws; falls back to original string."
    - "Install: npm install destr"
    - "v2 ESM only; named export destr."
    - "Drops __proto__ / constructor.prototype keys to defeat prototype-pollution."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws — returns input on parse failure."
  stderr: "warns to stderr when dropping __proto__ keys"
  stickiness: "N/A — each call independent."
  codes: {}

invariant destr.parses_integer_literal:
  description: "destr('42') returns 42"
  category: parse
  kind: node_chain_eq
  entry: named
  function: destr
  entry_args: ["42"]
  chain: []
  expected: 42

invariant destr.parses_quoted_string:
  description: "destr('\"hi\"') returns 'hi' (string literal)"
  category: parse
  kind: node_chain_eq
  entry: named
  function: destr
  entry_args: ["\"hi\""]
  chain: []
  expected: "hi"

invariant destr.parses_true:
  description: "destr('true') returns true"
  category: parse
  kind: node_chain_eq
  entry: named
  function: destr
  entry_args: ["true"]
  chain: []
  expected: true

invariant destr.parses_null:
  description: "destr('null') returns null"
  category: parse
  kind: node_chain_eq
  entry: named
  function: destr
  entry_args: ["null"]
  chain: []
  expected: ~

invariant destr.bad_json_passes_through:
  description: "destr on malformed JSON returns the original string (does not throw)"
  category: fallback
  kind: node_chain_eq
  entry: named
  function: destr
  entry_args: ["{bad json}"]
  chain: []
  expected: "{bad json}"

invariant destr.bare_undefined_string:
  description: "destr('undefined') returns the literal undefined value (JSON null on the wire)"
  category: parse
  kind: node_chain_eq
  entry: named
  function: destr
  entry_args: ["undefined"]
  chain: []
  expected: ~

invariant destr.parses_object:
  description: "destr('{\"a\":1}') returns the parsed object"
  category: parse
  kind: node_chain_eq
  entry: named
  function: destr
  entry_args: ["{\"a\":1}"]
  chain:
    - {get: a}
  expected: 1

invariant destr.drops_proto_pollution_key:
  description: "destr drops __proto__ keys (prototype-pollution defence) — resulting object has no 'a'"
  category: security
  kind: node_chain_eq
  entry: named
  function: destr
  entry_args: ["{\"__proto__\":{\"a\":1}}"]
  chain:
    - {method: hasOwnProperty, args: ["__proto__"]}
  expected: false

invariant destr.empty_input_passthrough:
  description: "Empty input passes through as empty string"
  category: edge
  kind: node_chain_eq
  entry: named
  function: destr
  entry_args: [""]
  chain: []
  expected: ""

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:14:20Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
