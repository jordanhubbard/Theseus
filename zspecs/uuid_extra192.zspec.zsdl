spec: uuid_extra192
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.UUID.__dict__ is a mappingproxy (not a plain dict) because UUID is a class object."
    - "uuid.UUID uses __slots__ = ('int', 'is_safe', '__weakref__') — a 3-element tuple."
    - "uuid.UUID.__weakref__ is a getset_descriptor object (the slot descriptor for __weakref__)."
    - "uuid.SafeUUID is an enum class: __class__.__name__ == 'EnumType' (the metaclass for enums)."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly subclasses enum.Enum."
    - "uuid.SafeUUID.__module__ == 'uuid', uuid.UUID.__module__ == 'uuid', uuid.uuid4.__module__ == 'uuid'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID class structure — __dict__, __weakref__, __slots__
# ---------------------------------------------------------------------------

table uuid_extra192.uuid_class_structure:
  kind: python_call_eq
  category: class_structure
  id_prefix: uuidstructure192dict

  columns: [id, function, args, expected, description]
  rows:
    - [dict_class,      UUID.__dict__.__class__.__name__.__eq__,     ["mappingproxy"],      true, "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy"]
    - [weakref_class,   UUID.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true, "uuid.UUID.__weakref__.__class__.__name__ == 'getset_descriptor' — __weakref__ slot descriptor"]
    - [slots_class,     UUID.__slots__.__class__.__name__.__eq__,    ["tuple"],             true, "uuid.UUID.__slots__.__class__.__name__ == 'tuple' — __slots__ is declared as a tuple"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID class structure — metaclass and base class
# ---------------------------------------------------------------------------

table uuid_extra192.safe_uuid_structure:
  kind: python_call_eq
  category: class_structure
  id_prefix: uuidstructure192safe

  columns: [id, function, args, expected, description]
  rows:
    - [safe_uuid_class,  SafeUUID.__class__.__name__.__eq__,    ["EnumType"], true, "uuid.SafeUUID.__class__.__name__ == 'EnumType' — the metaclass for enum classes"]
    - [safe_uuid_module, SafeUUID.__module__.__eq__,            ["uuid"],     true, "uuid.SafeUUID.__module__ == 'uuid'"]

# ---------------------------------------------------------------------------
# Module membership — UUID, uuid4
# ---------------------------------------------------------------------------

table uuid_extra192.module_membership:
  kind: python_call_eq
  category: module
  id_prefix: uuidstructure192module

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_module,  UUID.__module__.__eq__,   ["uuid"], true, "uuid.UUID.__module__ == 'uuid'"]
    - [uuid4_module, uuid4.__module__.__eq__,  ["uuid"], true, "uuid.uuid4.__module__ == 'uuid'"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant uuid_extra192.UUID.dict_class_name:
  description: "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy' — class namespace is always a mappingproxy"
  category: class_structure
  kind: python_call_eq
  function: UUID.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant uuid_extra192.UUID.weakref_class_name:
  description: "uuid.UUID.__weakref__.__class__.__name__ == 'getset_descriptor' — slot descriptor for __weakref__"
  category: class_structure
  kind: python_call_eq
  function: UUID.__weakref__.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant uuid_extra192.UUID.slots_class_name:
  description: "uuid.UUID.__slots__.__class__.__name__ == 'tuple' — UUID declares __slots__ as a tuple"
  category: class_structure
  kind: python_call_eq
  function: UUID.__slots__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant uuid_extra192.SafeUUID.class_name:
  description: "uuid.SafeUUID.__class__.__name__ == 'EnumType' — SafeUUID uses the enum metaclass"
  category: class_structure
  kind: python_call_eq
  function: SafeUUID.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

invariant uuid_extra192.SafeUUID.bases_first:
  description: "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly subclasses enum.Enum"
  category: class_structure
  kind: python_call_eq
  function: "SafeUUID.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["Enum"]
  expected: true

invariant uuid_extra192.SafeUUID.module:
  description: "uuid.SafeUUID.__module__ == 'uuid'"
  category: module
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra192.UUID.module:
  description: "uuid.UUID.__module__ == 'uuid'"
  category: module
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra192.uuid4.module:
  description: "uuid.uuid4.__module__ == 'uuid'"
  category: module
  kind: python_call_eq
  function: uuid4.__module__.__eq__
  args: ["uuid"]
  expected: true

