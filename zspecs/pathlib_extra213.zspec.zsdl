spec: pathlib_extra213
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: __code__ attributes of pathlib.Path methods (Python-level implementations)."
    - "pathlib.Path.open.__code__.co_flags.__class__.__name__ == 'int' — co_flags bitmask value 201326595 on Python 3.14.3."
    - "pathlib.Path.read_text.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 201326595."
    - "pathlib.Path.write_text.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 201326595."
    - "pathlib.Path.open.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 8."
    - "pathlib.Path.read_text.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7."
    - "pathlib.Path.write_text.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7."
    - "pathlib.Path.open.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the source file path string."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.open.__code__ co_flags and co_stacksize — class names
#
# pathlib.Path.open is a Python function.
# __code__.co_flags.__class__.__name__ == 'int'  (value 201326595)
# __code__.co_stacksize.__class__.__name__ == 'int'  (value 8)
# __code__.co_filename.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table pathlib_extra213.Path_open_code_attrs:
  description: "pathlib.Path.open.__code__ attribute types — co_flags and co_stacksize are int; co_filename is str; co_flags==201326595; co_stacksize==8; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibcoflags213

  columns: [id, function, args, expected, description]
  rows:
    - [open_coflags_cls,      Path.open.__code__.co_flags.__class__.__name__.__eq__,      ["int"], true,  "pathlib.Path.open.__code__.co_flags.__class__.__name__ == 'int' — co_flags bitmask 201326595; verified Python 3.14.3"]
    - [open_costacksize_cls,  Path.open.__code__.co_stacksize.__class__.__name__.__eq__,  ["int"], true,  "pathlib.Path.open.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 8; verified Python 3.14.3"]
    - [open_cofilename_cls,   Path.open.__code__.co_filename.__class__.__name__.__eq__,   ["str"], true,  "pathlib.Path.open.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the source file path; verified Python 3.14.3"]
    - [open_coflags_not_str,  Path.open.__code__.co_flags.__class__.__name__.__eq__,      ["str"], false, "pathlib.Path.open.__code__.co_flags.__class__.__name__ != 'str' — co_flags is int bitmask; verified Python 3.14.3"]

