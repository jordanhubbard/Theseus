    - [read_text_costacksize_cls, Path.read_text.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true,  "pathlib.Path.read_text.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7; verified Python 3.14.3"]
    - [read_text_coflags_not_float, Path.read_text.__code__.co_flags.__class__.__name__.__eq__,  ["float"], false, "pathlib.Path.read_text.__code__.co_flags.__class__.__name__ != 'float' — co_flags is int; verified Python 3.14.3"]
