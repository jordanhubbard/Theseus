# ---------------------------------------------------------------------------
# Standalone invariants — pathlib_extra213
# ---------------------------------------------------------------------------

invariant pathlib_extra213.Path_open_co_flags_class_name:
  description: "pathlib.Path.open.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a CPython integer bitmask encoding function compilation flags; value 201326595 on Python 3.14.3; pathlib.Path.open is a pure-Python method with full __code__ introspection; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Path.open.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pathlib_extra213.Path_read_text_co_flags_class_name:
  description: "pathlib.Path.read_text.__code__.co_flags.__class__.__name__ == 'int' — co_flags bitmask value 201326595 on Python 3.14.3; same value as Path.open and Path.write_text co_flags; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Path.read_text.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pathlib_extra213.Path_write_text_co_flags_class_name:
  description: "pathlib.Path.write_text.__code__.co_flags.__class__.__name__ == 'int' — co_flags bitmask value 201326595 on Python 3.14.3; same value as Path.open and Path.read_text co_flags; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Path.write_text.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pathlib_extra213.Path_open_co_stacksize_class_name:
  description: "pathlib.Path.open.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the maximum stack depth required for the code frame; value 8 on Python 3.14.3; slightly larger than read_text/write_text (7) reflecting open()'s broader logic; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Path.open.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pathlib_extra213.Path_read_text_co_stacksize_class_name:
  description: "pathlib.Path.read_text.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7 on Python 3.14.3; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Path.read_text.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pathlib_extra213.Path_write_text_co_stacksize_class_name:
  description: "pathlib.Path.write_text.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7 on Python 3.14.3; same as read_text; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Path.write_text.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pathlib_extra213.Path_open_co_filename_class_name:
  description: "pathlib.Path.open.__code__.co_filename.__class__.__name__ == 'str' — co_filename records the source file path where the function was defined; always a string in CPython; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Path.open.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra213.Path_open_co_flags_not_str:
  description: "pathlib.Path.open.__code__.co_flags.__class__.__name__ != 'str' — co_flags is always an integer in CPython; it encodes compilation flags like CO_OPTIMIZED and CO_NEWLOCALS as bit positions; never a string; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Path.open.__code__.co_flags.__class__.__name__.__eq__
  args: ["str"]
  expected: false
