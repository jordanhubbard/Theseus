spec: graphene_rust
version: ">=3.9"
backend: rust_module(graphene_rust)

docs: https://graphene-python.org/

provenance:
  derived_from:
    - "https://graphene-python.org/ — Graphene Python"
  notes:
    - "Graphene provides GraphQL framework for Python."
    - "graphene.Schema is a class."
    - "graphene.ObjectType is a class."
    - "graphene.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant graphene_rust.has_schema:
  description: "graphene.Schema is a class"
  category: presence
  kind: python_call_eq
  function: graphene_has_schema
  args: []
  expected: true

invariant graphene_rust.has_object_type:
  description: "graphene.ObjectType is a class"
  category: presence
  kind: python_call_eq
  function: graphene_has_object_type
  args: []
  expected: true

invariant graphene_rust.version_nonempty:
  description: "graphene.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: graphene_version_nonempty
  args: []
  expected: true

