spec: uuid_extra2566
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/uuid.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 2566 theme: __getattr__, __setattr__, __delattr__ dict-presence — custom attribute access protocol."
    - "uuid.UUID defines __setattr__ in its own __dict__ to enforce immutability — once constructed, UUID fields cannot be reassigned."
    - "uuid.UUID does NOT define __delattr__ — deletion is not individually guarded (the class uses __slots__ which prevents arbitrary attribute deletion)."
    - "uuid.UUID does NOT define __getattr__ or __getattribute__ — attribute reads go through the normal slot descriptor mechanism."
    - "uuid.UUID uses __slots__ = ('int', 'is_safe', '__weakref__') to restrict the instance namespace."
    - "uuid.UUID defines a full comparison suite: __eq__, __lt__, __gt__, __le__, __ge__ (sorted by integer value)."
    - "uuid.UUID defines __hash__ so UUIDs can be used as dict keys and set members."
    - "uuid.UUID defines __int__ and __str__ for numeric and string coercion."
    - "uuid.UUID defines __getstate__ and __setstate__ for pickling support."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Core attribute access protocol — __setattr__ present, others absent
# ---------------------------------------------------------------------------

table uuid_extra2566.attr_access_protocol:
  description: "uuid.UUID defines __setattr__ to block mutation; __getattr__, __delattr__, __getattribute__ are absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2566

  columns: [id, function, args, expected]
  rows:
    - ["uu2566001", "uuid.UUID.__dict__.__contains__", ["__setattr__"],      true]
    - ["uu2566002", "uuid.UUID.__dict__.__contains__", ["__getattr__"],      false]
    - ["uu2566003", "uuid.UUID.__dict__.__contains__", ["__delattr__"],      false]
    - ["uu2566004", "uuid.UUID.__dict__.__contains__", ["__getattribute__"], false]

# ---------------------------------------------------------------------------
# Comparison protocol — UUID defines full ordering suite
# ---------------------------------------------------------------------------

table uuid_extra2566.comparison_protocol:
  description: "uuid.UUID defines a full comparison suite for sorting and equality in its __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2566

  columns: [id, function, args, expected]
  rows:
    - ["uu2566005", "uuid.UUID.__dict__.__contains__", ["__eq__"], true]
    - ["uu2566006", "uuid.UUID.__dict__.__contains__", ["__lt__"], true]
    - ["uu2566007", "uuid.UUID.__dict__.__contains__", ["__gt__"], true]
    - ["uu2566008", "uuid.UUID.__dict__.__contains__", ["__le__"], true]
    - ["uu2566009", "uuid.UUID.__dict__.__contains__", ["__ge__"], true]
    - ["uu2566010", "uuid.UUID.__dict__.__contains__", ["__hash__"], true]

# ---------------------------------------------------------------------------
# Lifecycle and coercion protocol
# ---------------------------------------------------------------------------

table uuid_extra2566.lifecycle_protocol:
  description: "uuid.UUID defines __init__, __slots__, and coercion methods __int__ and __str__ in its __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2566

  columns: [id, function, args, expected]
  rows:
    - ["uu2566011", "uuid.UUID.__dict__.__contains__", ["__init__"],     true]
    - ["uu2566012", "uuid.UUID.__dict__.__contains__", ["__slots__"],    true]
    - ["uu2566013", "uuid.UUID.__dict__.__contains__", ["__int__"],      true]
    - ["uu2566014", "uuid.UUID.__dict__.__contains__", ["__str__"],      true]
    - ["uu2566015", "uuid.UUID.__dict__.__contains__", ["__repr__"],     true]
    - ["uu2566016", "uuid.UUID.__dict__.__contains__", ["__getstate__"], true]
    - ["uu2566017", "uuid.UUID.__dict__.__contains__", ["__setstate__"], true]

# ---------------------------------------------------------------------------
# Absent standard dunders — not overridden in uuid.UUID
# ---------------------------------------------------------------------------

table uuid_extra2566.absent_dunders:
  description: "Standard dunders absent from uuid.UUID.__dict__ — inherited from object or not applicable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2566

  columns: [id, function, args, expected]
  rows:
    - ["uu2566018", "uuid.UUID.__dict__.__contains__", ["__new__"],    false]
    - ["uu2566019", "uuid.UUID.__dict__.__contains__", ["__del__"],    false]
    - ["uu2566020", "uuid.UUID.__dict__.__contains__", ["__class__"],  false]
