spec: io_extra30
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra29.zspec.zsdl — covers __qualname__ for BytesIO.read/write/seek/tell, StringIO.read/write/getvalue, IOBase.close/readline."
    - "io_extra26.zspec.zsdl — covers __qualname__ equality for class objects (BytesIO, StringIO, etc.), not their methods."
    - "io_extra9.zspec.zsdl — covers __qualname__ equality for the class objects themselves, not instance methods."
  notes:
    - "This spec extends io_extra29.zspec.zsdl."
    - "Focus: __qualname__ values for io class instance methods not yet covered (BytesIO.getvalue, BytesIO.getbuffer, BytesIO.close, StringIO.close, StringIO.seek, StringIO.tell, StringIO.truncate) and __qualname__ for BufferedReader, BufferedWriter, TextIOWrapper class objects."
    - "BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' — instance method qualname carries class prefix."
    - "BytesIO.getbuffer.__qualname__ == 'BytesIO.getbuffer' — instance method qualname carries class prefix."
    - "BytesIO.close.__qualname__ == 'BytesIO.close' — BytesIO.close is a concrete override on BytesIO (not the C _IOBase.close); qualname uses the class name BytesIO."
    - "StringIO.close.__qualname__ == 'StringIO.close' — StringIO.close is a concrete override on StringIO; qualname uses StringIO."
    - "StringIO.seek.__qualname__ == 'StringIO.seek' — instance method qualname carries class prefix."
    - "StringIO.tell.__qualname__ == 'StringIO.tell' — instance method qualname carries class prefix."
    - "StringIO.truncate.__qualname__ == 'StringIO.truncate' — instance method qualname carries class prefix."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — class object qualname equals the simple class name."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — class object qualname equals the simple class name."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — class object qualname equals the simple class name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ for additional BytesIO instance methods
#
# io_extra29 covers BytesIO.read/write/seek/tell.__qualname__.
# No prior io spec covers __qualname__ for BytesIO.getvalue, getbuffer, or
# close. All three carry the 'BytesIO.<method>' prefix because BytesIO is a
# concrete class that owns these methods directly.
# Verified: getvalue='BytesIO.getvalue', getbuffer='BytesIO.getbuffer',
#           close='BytesIO.close'.
# ---------------------------------------------------------------------------

table io_extra30.bytesio_extra_method_qualnames:
  description: "__qualname__ for BytesIO instance methods getvalue/getbuffer/close"
  kind: python_call_eq
  category: method_identity
  id_prefix: bioemq30

  columns: [id, function, args, expected]
  rows:
    - [getvalue,  BytesIO.getvalue.__qualname__.__eq__,  ["BytesIO.getvalue"],  true]
    - [getbuffer, BytesIO.getbuffer.__qualname__.__eq__, ["BytesIO.getbuffer"], true]
    - [close,     BytesIO.close.__qualname__.__eq__,     ["BytesIO.close"],     true]

# ---------------------------------------------------------------------------
# Table: __qualname__ for additional StringIO instance methods
#
# io_extra29 covers StringIO.read/write/getvalue.__qualname__.
# No prior io spec covers __qualname__ for StringIO.close, seek, tell, or
# truncate. These are concrete methods on StringIO (the C _StringIO class),
# so their qualnames carry the 'StringIO.<method>' prefix.
# Verified: close='StringIO.close', seek='StringIO.seek',
#           tell='StringIO.tell', truncate='StringIO.truncate'.
# ---------------------------------------------------------------------------

table io_extra30.stringio_extra_method_qualnames:
  description: "__qualname__ for StringIO instance methods close/seek/tell/truncate"
  kind: python_call_eq
  category: method_identity
  id_prefix: sioemq30

  columns: [id, function, args, expected]
  rows:
    - [close,    StringIO.close.__qualname__.__eq__,    ["StringIO.close"],    true]
    - [seek,     StringIO.seek.__qualname__.__eq__,     ["StringIO.seek"],     true]
    - [tell,     StringIO.tell.__qualname__.__eq__,     ["StringIO.tell"],     true]
    - [truncate, StringIO.truncate.__qualname__.__eq__, ["StringIO.truncate"], true]

# ---------------------------------------------------------------------------
# Table: __qualname__ for buffered I/O class objects
#
# io_extra9 and io_extra26 cover __qualname__ for BytesIO and StringIO class
# objects. No prior io spec covers __qualname__ for BufferedReader,
# BufferedWriter, or TextIOWrapper. For classes defined at module top level
# in C, __qualname__ equals the simple class name.
# Verified: BufferedReader='BufferedReader', BufferedWriter='BufferedWriter',
#           TextIOWrapper='TextIOWrapper'.
# ---------------------------------------------------------------------------

table io_extra30.buffered_class_qualnames:
  description: "__qualname__ for BufferedReader/BufferedWriter/TextIOWrapper class objects"
  kind: python_call_eq
  category: class_identity
  id_prefix: bcqn30

  columns: [id, function, args, expected]
  rows:
    - [BufferedReader,  BufferedReader.__qualname__.__eq__,  ["BufferedReader"],  true]
    - [BufferedWriter,  BufferedWriter.__qualname__.__eq__,  ["BufferedWriter"],  true]
    - [TextIOWrapper,   TextIOWrapper.__qualname__.__eq__,   ["TextIOWrapper"],   true]

# ---------------------------------------------------------------------------
# Standalone: BytesIO.close.__qualname__ — concrete override, not _IOBase
#
# io.IOBase.close.__qualname__ is '_IOBase.close' (the C-level base, covered
# in io_extra29). BytesIO overrides close with its own concrete method, so
# io.BytesIO.close.__qualname__ is 'BytesIO.close' — a different qualname
# from the base class. This distinction highlights how BytesIO specialises
# the close method.
# Verified: io.BytesIO.close.__qualname__ == 'BytesIO.close'
# ---------------------------------------------------------------------------

invariant io_extra30.BytesIO.close.qualname:
  description: "io.BytesIO.close.__qualname__ == 'BytesIO.close' — BytesIO provides a concrete close override; qualname differs from IOBase.close's '_IOBase.close'"
  category: method_identity
  kind: python_call_eq
  function: BytesIO.close.__qualname__.__eq__
  args: ["BytesIO.close"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: TextIOWrapper.__qualname__ — class object identity
#
# io.TextIOWrapper is the main class for reading and writing text files. It
# is implemented in C as _io.TextIOWrapper. Its __qualname__ equals the
# simple class name 'TextIOWrapper' (not a nested name). No prior io spec
# covers TextIOWrapper.__qualname__ as a standalone invariant in the extra30
# namespace.
# Verified: io.TextIOWrapper.__qualname__ == 'TextIOWrapper'
# ---------------------------------------------------------------------------

invariant io_extra30.TextIOWrapper.qualname:
  description: "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — top-level C class; qualname equals simple class name"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true
