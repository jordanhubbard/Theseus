spec: socket_extra1051
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket, socket.error, socket.timeout __init_subclass__ qualnames and socket.socket method qualnames including dup, detach, fromfd"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1051.init_subclass_qualnames:
  description: "socket.socket, socket.error, socket.timeout __init_subclass__.__qualname__ identity"
  kind: python_call_eq
  category: init_subclass_qualnames
  id_prefix: sk1051i
  columns: [id, function, args, expected]
  rows:
    - [sk1051i001, socket.socket.__init_subclass__.__qualname__.__eq__,  ["object.__init_subclass__"], true]
    - [sk1051i002, socket.error.__init_subclass__.__qualname__.__eq__,   ["object.__init_subclass__"], true]
    - [sk1051i003, socket.timeout.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [sk1051i004, socket.socket.__init_subclass__.__qualname__.__class__.__name__.__eq__, ["str"],    true]
    - [sk1051i005, socket.error.__init_subclass__.__qualname__.__class__.__name__.__eq__,  ["str"],    true]
    - [sk1051i006, socket.timeout.__init_subclass__.__qualname__.__class__.__name__.__eq__, ["str"],   true]
    - [sk1051i007, socket.socket.__class__.__name__.__eq__,              ["type"],                     true]
    - [sk1051i008, socket.error.__class__.__name__.__eq__,               ["type"],                     true]

table socket_extra1051.socket_method_qualnames:
  description: "socket.socket instance method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: sk1051m
  columns: [id, function, args, expected]
  rows:
    - [sk1051m001, socket.socket.dup.__qualname__.__eq__,     ["socket.dup"],     true]
    - [sk1051m002, socket.socket.detach.__qualname__.__eq__,  ["socket.detach"],  true]
    - [sk1051m003, socket.socket.fromfd.__qualname__.__eq__,  ["socket.fromfd"],  true]
    - [sk1051m004, socket.socket.dup.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [sk1051m005, socket.socket.detach.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [sk1051m006, socket.socket.fromfd.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [sk1051m007, socket.socket.__module__.__eq__,           ["socket"],         true]
    - [sk1051m008, socket.socket.__qualname__.__eq__,         ["socket"],         true]

table socket_extra1051.class_identity:
  description: "socket module class and type identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: sk1051c
  columns: [id, function, args, expected]
  rows:
    - [sk1051c001, socket.socket.__class__.__name__.__eq__,              ["type"],           true]
    - [sk1051c002, socket.error.__class__.__name__.__eq__,               ["type"],           true]
    - [sk1051c003, socket.timeout.__class__.__name__.__eq__,             ["type"],           true]
    - [sk1051c004, socket.error.__module__.__eq__,                       ["builtins"],       true]
    - [sk1051c005, socket.timeout.__module__.__eq__,                     ["builtins"],       true]
    - [sk1051c006, socket.socket.__doc__.__class__.__name__.__eq__,      ["str"],            true]
    - [sk1051c007, socket.socket.dup.__class__.__name__.__eq__,          ["function"],       true]
    - [sk1051c008, socket.socket.detach.__class__.__name__.__eq__,       ["method_wrapper"], true]
    - [sk1051c009, socket.socket.fromfd.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
