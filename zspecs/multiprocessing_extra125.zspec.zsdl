spec: multiprocessing_extra125
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers: wave 255 theme — multiprocessing.context module class identity (BaseContext, SpawnContext, ForkContext, ForkServerContext, DefaultContext). NEW in extra125: multiprocessing.context.BaseContext.__name__=='BaseContext' (len=11); multiprocessing.context.BaseContext.__module__=='multiprocessing.context'; multiprocessing.context.BaseContext.__bases__[0].__name__=='object'; multiprocessing.context.BaseContext.__mro__.__len__()==2; multiprocessing.context.SpawnContext.__name__=='SpawnContext' (len=12); multiprocessing.context.SpawnContext.__bases__[0].__name__=='BaseContext'; multiprocessing.context.SpawnContext.__mro__.__len__()==3; multiprocessing.context.ForkContext.__name__=='ForkContext' (len=11, on Unix); multiprocessing.context.ForkContext.__bases__[0].__name__=='BaseContext'; multiprocessing.context.ForkServerContext.__name__=='ForkServerContext' (len=17, longest); multiprocessing.context.DefaultContext.__name__=='DefaultContext' (len=14); multiprocessing.context.DefaultContext.__bases__[0].__name__=='BaseContext'; all derived context classes have __mro__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.context.BaseContext.__mro__.__len__() == 2. BaseContext inherits directly from object (MRO=[BaseContext, object]); its subclasses SpawnContext, ForkContext, ForkServerContext, DefaultContext each have MRO len=3 ([Derived, BaseContext, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.context.ForkServerContext.__name__.__len__() == 17. 'ForkServerContext' is 17 chars: 'Fork'=4+'Server'=6+'Context'=7=17; the longest class name in this spec, compared to BaseContext=11, ForkContext=11, SpawnContext=12, DefaultContext=14. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.context.BaseContext class identity — extra125
#
# Wave 255 theme: multiprocessing.context module class identity.
#
# multiprocessing.context.BaseContext.__name__              == 'BaseContext'
# multiprocessing.context.BaseContext.__module__            == 'multiprocessing.context'
# multiprocessing.context.BaseContext.__bases__[0].__name__ == 'object'
# multiprocessing.context.BaseContext.__mro__.__len__()     == 2
# multiprocessing.context.BaseContext.__qualname__          == 'BaseContext' (len=11)
# multiprocessing.context.BaseContext.__class__.__name__    == 'type'
# ---------------------------------------------------------------------------

table multiprocessing_extra125.mp_context_base_identity:
  description: "multiprocessing.context.BaseContext class identity checks in mpcontextident125 namespace — wave 255 theme: multiprocessing.context.BaseContext is the root class of the multiprocessing context class hierarchy defined in Lib/multiprocessing/context.py; it provides all the factory methods (Lock, Semaphore, Process, etc.) that are dispatched to the appropriate implementation for the current start method; BaseContext.__name__.__eq__('BaseContext')==True (len=11: 'Base'=4+'Context'=7=11); BaseContext.__module__.__eq__('multiprocessing.context')==True (defined in context.py); BaseContext.__bases__[0].__name__.__eq__('object')==True (BaseContext inherits directly from object with no intermediate classes); BaseContext.__mro__.__len__()==2 (minimal 2-element MRO: [BaseContext, object]; BaseContext is a direct subclass of object); BaseContext.__qualname__.__eq__('BaseContext')==True (len=11, module-level class so qualname equals name); BaseContext.__class__.__name__.__eq__('type')==True (regular class, metaclass is type); BaseContext.__name__.__len__()==11; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpcontextident125

  columns: [id, function, args, expected, description]
  rows:
    - [bc_name_eq,    "multiprocessing.context.BaseContext.__name__.__eq__",                 ["BaseContext"],              true, "multiprocessing.context.BaseContext.__name__ == 'BaseContext' (len=11); verified with Python 3.14.3"]
    - [bc_name_len,   "multiprocessing.context.BaseContext.__name__.__len__",                [],                           11,   "multiprocessing.context.BaseContext.__name__.__len__() == 11 ('Base'=4+'Context'=7=11); verified with Python 3.14.3"]
    - [bc_module,     "multiprocessing.context.BaseContext.__module__.__eq__",               ["multiprocessing.context"],  true, "multiprocessing.context.BaseContext.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [bc_base0,      "multiprocessing.context.BaseContext.__bases__[0].__name__.__eq__",    ["object"],                   true, "multiprocessing.context.BaseContext.__bases__[0].__name__ == 'object' (direct subclass of object); verified with Python 3.14.3"]
    - [bc_mro_len,    "multiprocessing.context.BaseContext.__mro__.__len__",                 [],                           2,    "multiprocessing.context.BaseContext.__mro__.__len__() == 2 ([BaseContext, object]); verified with Python 3.14.3"]
    - [bc_qualname,   "multiprocessing.context.BaseContext.__qualname__.__eq__",             ["BaseContext"],              true, "multiprocessing.context.BaseContext.__qualname__ == 'BaseContext' (len=11, qualname equals name for module-level class); verified with Python 3.14.3"]
    - [bc_cls,        "multiprocessing.context.BaseContext.__class__.__name__.__eq__",       ["type"],                     true, "multiprocessing.context.BaseContext.__class__.__name__ == 'type' (regular class, metaclass is type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.context.SpawnContext and ForkContext — extra125
#
# SpawnContext.__name__              == 'SpawnContext'     (len=12)
# SpawnContext.__module__            == 'multiprocessing.context'
# SpawnContext.__bases__[0].__name__ == 'BaseContext'
# SpawnContext.__mro__.__len__()     == 3   [SpawnContext, BaseContext, object]
# ForkContext.__name__               == 'ForkContext'      (len=11, same as BaseContext)
# ForkContext.__bases__[0].__name__  == 'BaseContext'
# ForkContext.__mro__.__len__()      == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra125.mp_context_spawn_fork_identity:
  description: "multiprocessing.context.SpawnContext and ForkContext class identity checks in mpcontextident125 namespace — wave 255 theme: SpawnContext and ForkContext are concrete subclasses of BaseContext for specific process start methods; SpawnContext.__name__.__eq__('SpawnContext')==True (len=12: 'Spawn'=5+'Context'=7=12, one more than BaseContext len=11); SpawnContext.__module__.__eq__('multiprocessing.context')==True (same module as BaseContext); SpawnContext.__bases__[0].__name__.__eq__('BaseContext')==True (SpawnContext directly inherits from BaseContext); SpawnContext.__mro__.__len__()==3 (MRO is [SpawnContext, BaseContext, object]; 3-element chain, one more than BaseContext's 2-element chain); SpawnContext.__qualname__.__eq__('SpawnContext')==True (len=12, qualname equals name); SpawnContext.__name__.__len__()==12; ForkContext.__name__.__eq__('ForkContext')==True (len=11: 'Fork'=4+'Context'=7=11; tied with BaseContext at len=11); ForkContext.__module__.__eq__('multiprocessing.context')==True; ForkContext.__bases__[0].__name__.__eq__('BaseContext')==True (ForkContext also inherits directly from BaseContext); ForkContext.__mro__.__len__()==3 (same 3-element structure as SpawnContext); ForkContext.__name__.__len__()==11; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpcontextident125a

  columns: [id, function, args, expected, description]
  rows:
    - [sp_name_eq,    "multiprocessing.context.SpawnContext.__name__.__eq__",                ["SpawnContext"],             true, "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext' (len=12); verified with Python 3.14.3"]
    - [sp_name_len,   "multiprocessing.context.SpawnContext.__name__.__len__",               [],                          12,   "multiprocessing.context.SpawnContext.__name__.__len__() == 12 ('Spawn'=5+'Context'=7=12); verified with Python 3.14.3"]
    - [sp_module,     "multiprocessing.context.SpawnContext.__module__.__eq__",              ["multiprocessing.context"],  true, "multiprocessing.context.SpawnContext.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [sp_base0,      "multiprocessing.context.SpawnContext.__bases__[0].__name__.__eq__",   ["BaseContext"],              true, "multiprocessing.context.SpawnContext.__bases__[0].__name__ == 'BaseContext' (inherits from BaseContext); verified with Python 3.14.3"]
    - [sp_mro_len,    "multiprocessing.context.SpawnContext.__mro__.__len__",                [],                          3,    "multiprocessing.context.SpawnContext.__mro__.__len__() == 3 ([SpawnContext, BaseContext, object]); verified with Python 3.14.3"]
    - [sp_qualname,   "multiprocessing.context.SpawnContext.__qualname__.__eq__",            ["SpawnContext"],             true, "multiprocessing.context.SpawnContext.__qualname__ == 'SpawnContext' (len=12); verified with Python 3.14.3"]
    - [fk_name_eq,    "multiprocessing.context.ForkContext.__name__.__eq__",                 ["ForkContext"],              true, "multiprocessing.context.ForkContext.__name__ == 'ForkContext' (len=11, tied with BaseContext); verified with Python 3.14.3"]
    - [fk_name_len,   "multiprocessing.context.ForkContext.__name__.__len__",                [],                          11,   "multiprocessing.context.ForkContext.__name__.__len__() == 11 ('Fork'=4+'Context'=7=11, tied with BaseContext); verified with Python 3.14.3"]
    - [fk_base0,      "multiprocessing.context.ForkContext.__bases__[0].__name__.__eq__",    ["BaseContext"],              true, "multiprocessing.context.ForkContext.__bases__[0].__name__ == 'BaseContext' (same direct base as SpawnContext); verified with Python 3.14.3"]
    - [fk_mro_len,    "multiprocessing.context.ForkContext.__mro__.__len__",                 [],                          3,    "multiprocessing.context.ForkContext.__mro__.__len__() == 3 (same 3-element structure as SpawnContext); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.context.ForkServerContext and DefaultContext — extra125
#
# ForkServerContext.__name__              == 'ForkServerContext'  (len=17, longest)
# ForkServerContext.__bases__[0].__name__ == 'BaseContext'
# ForkServerContext.__mro__.__len__()     == 3
# DefaultContext.__name__                 == 'DefaultContext'     (len=14)
# DefaultContext.__bases__[0].__name__    == 'BaseContext'
# DefaultContext.__mro__.__len__()        == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra125.mp_context_forkserver_default_identity:
  description: "multiprocessing.context.ForkServerContext and DefaultContext class identity checks in mpcontextident125 namespace — wave 255 theme: ForkServerContext is the context class for the 'forkserver' start method; ForkServerContext.__name__.__eq__('ForkServerContext')==True (len=17: 'Fork'=4+'Server'=6+'Context'=7=17; the longest class name in this spec; four more chars than SpawnContext's 12 and six more than BaseContext's 11); ForkServerContext.__bases__[0].__name__.__eq__('BaseContext')==True (same direct base as all other context classes); ForkServerContext.__mro__.__len__()==3 (same 3-element structure as SpawnContext and ForkContext: [ForkServerContext, BaseContext, object]); ForkServerContext.__qualname__.__eq__('ForkServerContext')==True (len=17, qualname equals name); ForkServerContext.__name__.__len__()==17; DefaultContext.__name__.__eq__('DefaultContext')==True (len=14: 'Default'=7+'Context'=7=14; DefaultContext is the subclass that represents the platform-default start method); DefaultContext.__bases__[0].__name__.__eq__('BaseContext')==True (DefaultContext also inherits directly from BaseContext, not from SpawnContext or ForkContext); DefaultContext.__mro__.__len__()==3 (same 3-element structure); DefaultContext.__name__.__len__()==14; DefaultContext.__qualname__.__eq__('DefaultContext')==True (len=14); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpcontextident125b

  columns: [id, function, args, expected, description]
  rows:
    - [fks_name_eq,   "multiprocessing.context.ForkServerContext.__name__.__eq__",                ["ForkServerContext"],        true, "multiprocessing.context.ForkServerContext.__name__ == 'ForkServerContext' (len=17, longest in spec); verified with Python 3.14.3"]
    - [fks_name_len,  "multiprocessing.context.ForkServerContext.__name__.__len__",               [],                          17,   "multiprocessing.context.ForkServerContext.__name__.__len__() == 17 ('Fork'=4+'Server'=6+'Context'=7=17); verified with Python 3.14.3"]
    - [fks_base0,     "multiprocessing.context.ForkServerContext.__bases__[0].__name__.__eq__",   ["BaseContext"],              true, "multiprocessing.context.ForkServerContext.__bases__[0].__name__ == 'BaseContext'; verified with Python 3.14.3"]
    - [fks_mro_len,   "multiprocessing.context.ForkServerContext.__mro__.__len__",                [],                          3,    "multiprocessing.context.ForkServerContext.__mro__.__len__() == 3 ([ForkServerContext, BaseContext, object]); verified with Python 3.14.3"]
    - [fks_qualname,  "multiprocessing.context.ForkServerContext.__qualname__.__eq__",            ["ForkServerContext"],        true, "multiprocessing.context.ForkServerContext.__qualname__ == 'ForkServerContext' (len=17); verified with Python 3.14.3"]
    - [dc_name_eq,    "multiprocessing.context.DefaultContext.__name__.__eq__",                   ["DefaultContext"],           true, "multiprocessing.context.DefaultContext.__name__ == 'DefaultContext' (len=14); verified with Python 3.14.3"]
    - [dc_name_len,   "multiprocessing.context.DefaultContext.__name__.__len__",                  [],                          14,   "multiprocessing.context.DefaultContext.__name__.__len__() == 14 ('Default'=7+'Context'=7=14); verified with Python 3.14.3"]
    - [dc_base0,      "multiprocessing.context.DefaultContext.__bases__[0].__name__.__eq__",      ["BaseContext"],              true, "multiprocessing.context.DefaultContext.__bases__[0].__name__ == 'BaseContext' (direct subclass of BaseContext, not of SpawnContext); verified with Python 3.14.3"]
    - [dc_mro_len,    "multiprocessing.context.DefaultContext.__mro__.__len__",                   [],                          3,    "multiprocessing.context.DefaultContext.__mro__.__len__() == 3 ([DefaultContext, BaseContext, object]); verified with Python 3.14.3"]
    - [dc_qualname,   "multiprocessing.context.DefaultContext.__qualname__.__eq__",               ["DefaultContext"],           true, "multiprocessing.context.DefaultContext.__qualname__ == 'DefaultContext' (len=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra125
# ---------------------------------------------------------------------------

invariant multiprocessing_extra125.BaseContext_mro_len_is_2:
  description: "multiprocessing.context.BaseContext.__mro__.__len__() == 2 — multiprocessing.context.BaseContext.__mro__ is [BaseContext, object]; this minimal 2-element MRO reflects that BaseContext inherits directly from object with no intermediate classes; all four concrete subclasses (SpawnContext, ForkContext, ForkServerContext, DefaultContext) have MRO len=3 because they insert BaseContext between themselves and object; BaseContext.__bases__[0].__name__ is 'object'; BaseContext.__module__ is 'multiprocessing.context'; BaseContext.__name__ is 'BaseContext' (len=11); the 2-element MRO contrasts with multiprocessing.Process.__mro__.__len__()==3 (Process inherits from BaseProcess, and BaseProcess inherits from object); NEW in extra125: first standalone BaseContext MRO length invariant in mpcontextident125 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.context.BaseContext.__mro__.__len__"
  args: []
  expected: 2

invariant multiprocessing_extra125.ForkServerContext_name_len_17:
  description: "multiprocessing.context.ForkServerContext.__name__.__len__() == 17 — 'ForkServerContext' is 17 chars: 'Fork'=4+'Server'=6+'Context'=7=17; this is the longest class name in this spec; compare all five context class name lengths: BaseContext=11, ForkContext=11, SpawnContext=12, DefaultContext=14, ForkServerContext=17; ForkServerContext uses the 'forkserver' start method where a server process is forked once and used to spawn new worker processes on demand; ForkServerContext.__bases__[0].__name__ is 'BaseContext'; ForkServerContext.__mro__.__len__() is 3; ForkServerContext.__qualname__.__len__() is also 17 (qualname equals name for module-level classes); NEW in extra125: first standalone ForkServerContext name length invariant in mpcontextident125 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.context.ForkServerContext.__name__.__len__"
  args: []
  expected: 17

invariant multiprocessing_extra125.SpawnContext_base_is_BaseContext:
  description: "multiprocessing.context.SpawnContext.__bases__[0].__name__.__eq__('BaseContext') returns True — multiprocessing.context.SpawnContext inherits directly from BaseContext; all four concrete context classes (SpawnContext, ForkContext, ForkServerContext, DefaultContext) have BaseContext as their sole direct base; the inheritance pattern is flat: each concrete context class adds only start-method-specific implementations without deeper hierarchies; SpawnContext.__mro__ is [SpawnContext, BaseContext, object] (len=3); SpawnContext.__name__ is 'SpawnContext' (len=12); SpawnContext.__module__ is 'multiprocessing.context'; the 'spawn' start method creates fresh Python interpreter processes for each worker, making it the safest start method and the only one supported on Windows; NEW in extra125: first standalone SpawnContext base class invariant in mpcontextident125 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.context.SpawnContext.__bases__[0].__name__.__eq__"
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra125.DefaultContext_name_len_14:
  description: "multiprocessing.context.DefaultContext.__name__.__len__() == 14 — 'DefaultContext' is 14 chars: 'Default'=7+'Context'=7=14; DefaultContext is the class whose instance is the default context used by the top-level multiprocessing module; the factory methods accessible as multiprocessing.Lock, multiprocessing.Process, etc. are all bound methods of this DefaultContext instance; DefaultContext inherits directly from BaseContext (not from SpawnContext or ForkContext); DefaultContext.__mro__.__len__() is 3 ([DefaultContext, BaseContext, object]); DefaultContext.__name__.__len__()==14 places it second-longest in the spec after ForkServerContext=17, and above SpawnContext=12, BaseContext=11, ForkContext=11; NEW in extra125: first standalone DefaultContext name length invariant in mpcontextident125 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.context.DefaultContext.__name__.__len__"
  args: []
  expected: 14

invariant multiprocessing_extra125.BaseContext_module_is_multiprocessing_context:
  description: "multiprocessing.context.BaseContext.__module__.__eq__('multiprocessing.context') returns True — multiprocessing.context.BaseContext.__module__ is 'multiprocessing.context' (len=24: 'multiprocessing.'=16+'context'=8=24); all five context classes (BaseContext, SpawnContext, ForkContext, ForkServerContext, DefaultContext) share this same module; the module is 'multiprocessing.context' (the submodule) rather than 'multiprocessing' (the package); this parallels multiprocessing.Process.__module__=='multiprocessing.context' (covered in extra99); BaseContext.__name__ is 'BaseContext' (len=11); BaseContext.__bases__[0].__name__ is 'object'; BaseContext.__mro__.__len__() is 2; NEW in extra125: first standalone BaseContext module invariant in mpcontextident125 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.context.BaseContext.__module__.__eq__"
  args: ["multiprocessing.context"]
  expected: true
