spec: itertools_extra205
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers MRO (method resolution order) of itertools classes: chain, count, product, combinations."
    - "All four itertools types are C-extension types defined in Modules/itertoolsmodule.c."
    - "itertools.chain.__mro__ is a 2-tuple: (chain, object). chain inherits directly from object with no intermediary."
    - "itertools.count.__mro__ is a 2-tuple: (count, object). count is a C-extension iterator type."
    - "itertools.product.__mro__ is a 2-tuple: (product, object). product is a C-extension Cartesian-product iterator."
    - "itertools.combinations.__mro__ is a 2-tuple: (combinations, object). combinations is a C-extension iterator."
    - "All four classes have MRO length 2, consistent with being C-extension types that inherit directly from object."
    - "itertools.chain.__mro__[0].__name__ == 'chain' — class is always the first entry in its own MRO."
    - "itertools.chain.__mro__[1].__name__ == 'object' — object is always the terminal MRO entry."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.chain MRO — type, length, and indexed name checks
#
# itertools.chain.__mro__ == (<class 'itertools.chain'>, <class 'object'>)
# len == 2, [0].__name__ == 'chain', [1].__name__ == 'object'
# ---------------------------------------------------------------------------

table itertools_extra205.chain_mro:
  description: "itertools.chain.__mro__ shape and indexed name checks — C-extension type, 2-entry MRO"
  kind: python_call_eq
  category: mro
  id_prefix: itermro205

  columns: [id, function, args, expected, description]
  rows:
    - [chain_mro_is_tuple,  chain.__mro__.__class__.__name__.__eq__,  ["tuple"],  true,  "chain.__mro__.__class__.__name__ == 'tuple'"]
    - [chain_mro_len,       chain.__mro__.__len__,                    [],         2,     "len(chain.__mro__) == 2"]
    - [chain_mro0_name,     "chain.__mro__[0].__name__.__eq__",       ["chain"],  true,  "chain.__mro__[0].__name__ == 'chain'"]
    - [chain_mro1_name,     "chain.__mro__[1].__name__.__eq__",       ["object"], true,  "chain.__mro__[1].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# itertools.count and itertools.product MRO — type, length, and indexed name checks
#
# itertools.count.__mro__ == (<class 'itertools.count'>, <class 'object'>)
# itertools.product.__mro__ == (<class 'itertools.product'>, <class 'object'>)
# ---------------------------------------------------------------------------

table itertools_extra205.count_product_mro:
  description: "itertools.count and itertools.product MRO shape and indexed name checks — C-extension types"
  kind: python_call_eq
  category: mro
  id_prefix: itermro205

  columns: [id, function, args, expected, description]
  rows:
    - [count_mro_is_tuple,    count.__mro__.__class__.__name__.__eq__,    ["tuple"],    true,  "count.__mro__.__class__.__name__ == 'tuple'"]
    - [count_mro_len,         count.__mro__.__len__,                      [],           2,     "len(count.__mro__) == 2"]
    - [count_mro0_name,       "count.__mro__[0].__name__.__eq__",         ["count"],    true,  "count.__mro__[0].__name__ == 'count'"]
    - [product_mro_is_tuple,  product.__mro__.__class__.__name__.__eq__,  ["tuple"],    true,  "product.__mro__.__class__.__name__ == 'tuple'"]
    - [product_mro_len,       product.__mro__.__len__,                    [],           2,     "len(product.__mro__) == 2"]
    - [product_mro0_name,     "product.__mro__[0].__name__.__eq__",       ["product"],  true,  "product.__mro__[0].__name__ == 'product'"]

# ---------------------------------------------------------------------------
# itertools.combinations MRO — type, length, and indexed name checks
#
# itertools.combinations.__mro__ == (<class 'itertools.combinations'>, <class 'object'>)
# len == 2, [0].__name__ == 'combinations', [1].__name__ == 'object'
# ---------------------------------------------------------------------------

table itertools_extra205.combinations_mro:
  description: "itertools.combinations.__mro__ shape and indexed name checks — C-extension iterator type"
  kind: python_call_eq
  category: mro
  id_prefix: itermro205

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_mro_is_tuple,  combinations.__mro__.__class__.__name__.__eq__,  ["tuple"],        true,  "combinations.__mro__.__class__.__name__ == 'tuple'"]
    - [combinations_mro_len,       combinations.__mro__.__len__,                    [],               2,     "len(combinations.__mro__) == 2"]
    - [combinations_mro0_name,     "combinations.__mro__[0].__name__.__eq__",       ["combinations"], true,  "combinations.__mro__[0].__name__ == 'combinations'"]
    - [combinations_mro1_name,     "combinations.__mro__[1].__name__.__eq__",       ["object"],       true,  "combinations.__mro__[1].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant itertools_extra205.chain_mro_is_tuple:
  description: "itertools.chain.__mro__.__class__.__name__ == 'tuple' — MRO is always a tuple in CPython"
  category: mro
  kind: python_call_eq
  function: chain.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant itertools_extra205.chain_mro_len_eq_2:
  description: "len(itertools.chain.__mro__) == 2 — chain is a C-extension type that inherits only from object"
  category: mro
  kind: python_call_eq
  function: chain.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra205.chain_mro0_name:
  description: "itertools.chain.__mro__[0].__name__ == 'chain' — first MRO entry is always the class itself"
  category: mro
  kind: python_call_eq
  function: "chain.__mro__[0].__name__.__eq__"
  args: ["chain"]
  expected: true

invariant itertools_extra205.chain_mro1_name:
  description: "itertools.chain.__mro__[1].__name__ == 'object' — second and final MRO entry is object"
  category: mro
  kind: python_call_eq
  function: "chain.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra205.count_mro_len_eq_2:
  description: "len(itertools.count.__mro__) == 2 — count is a C-extension infinite-counter iterator that inherits only from object"
  category: mro
  kind: python_call_eq
  function: count.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra205.count_mro0_name:
  description: "itertools.count.__mro__[0].__name__ == 'count' — first MRO entry is the class itself"
  category: mro
  kind: python_call_eq
  function: "count.__mro__[0].__name__.__eq__"
  args: ["count"]
  expected: true

invariant itertools_extra205.product_mro_len_eq_2:
  description: "len(itertools.product.__mro__) == 2 — product is a C-extension Cartesian-product iterator that inherits only from object"
  category: mro
  kind: python_call_eq
  function: product.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra205.combinations_mro0_name:
  description: "itertools.combinations.__mro__[0].__name__ == 'combinations' — first MRO entry is the class itself"
  category: mro
  kind: python_call_eq
  function: "combinations.__mro__[0].__name__.__eq__"
  args: ["combinations"]
  expected: true

