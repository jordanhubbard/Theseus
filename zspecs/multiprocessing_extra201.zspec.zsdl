spec: multiprocessing_extra201
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#exceptions — multiprocessing Exceptions"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers __qualname__ attributes of multiprocessing exception classes and Process: ProcessError, AuthenticationError, BufferTooShort, TimeoutError, Process."
    - "multiprocessing.ProcessError.__qualname__ == 'ProcessError' — top-level exception; qualname equals name. len == 12. Verified Python 3.14.3."
    - "multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError' — top-level exception; qualname equals name. len == 19. Verified Python 3.14.3."
    - "multiprocessing.BufferTooShort.__qualname__ == 'BufferTooShort' — top-level exception; qualname equals name. len == 14. Verified Python 3.14.3."
    - "multiprocessing.TimeoutError.__qualname__ == 'TimeoutError' — top-level exception; qualname equals name. len == 12. Verified Python 3.14.3."
    - "multiprocessing.Process.__qualname__ == 'Process' — top-level class; qualname equals name. len == 7. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing exception __qualname__ equality — ProcessError and AuthenticationError
#
# multiprocessing.ProcessError.__qualname__ == 'ProcessError' (len 12)
# multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError' (len 19)
# multiprocessing.BufferTooShort.__qualname__ == 'BufferTooShort' (len 14)
# multiprocessing.TimeoutError.__qualname__ == 'TimeoutError' (len 12)
#
# All are top-level exception classes; qualname equals simple name.
# ---------------------------------------------------------------------------

table multiprocessing_extra201.exception_qualnames:
  description: "multiprocessing exception __qualname__ equality checks for ProcessError/AuthenticationError/BufferTooShort/TimeoutError in mpqualname201 namespace — top-level exceptions; qualname equals name; new to multiprocessing_extra201"
  kind: python_call_eq
  category: qualnames
  id_prefix: mpqualname201

  columns: [id, function, args, expected, description]
  rows:
    - [process_error_qualname_eq,
       ProcessError.__qualname__.__eq__,
       ["ProcessError"],
       true,
       "multiprocessing.ProcessError.__qualname__.__eq__('ProcessError') == True — ProcessError is the top-level base exception for multiprocessing; qualname equals name; new to multiprocessing_extra201; verified Python 3.14.3"]
    - [authentication_error_qualname_eq,
       AuthenticationError.__qualname__.__eq__,
       ["AuthenticationError"],
       true,
       "multiprocessing.AuthenticationError.__qualname__.__eq__('AuthenticationError') == True — AuthenticationError is a top-level exception for auth failures; qualname equals name; new to multiprocessing_extra201; verified Python 3.14.3"]
    - [buffer_too_short_qualname_eq,
       BufferTooShort.__qualname__.__eq__,
       ["BufferTooShort"],
       true,
       "multiprocessing.BufferTooShort.__qualname__.__eq__('BufferTooShort') == True — BufferTooShort is a top-level exception raised when a buffer is too small; qualname equals name; new to multiprocessing_extra201; verified Python 3.14.3"]
    - [timeout_error_qualname_eq,
       TimeoutError.__qualname__.__eq__,
       ["TimeoutError"],
       true,
       "multiprocessing.TimeoutError.__qualname__.__eq__('TimeoutError') == True — TimeoutError is a top-level exception for operation timeouts; qualname equals name; new to multiprocessing_extra201; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.Process __qualname__ equality and length
#
# multiprocessing.Process.__qualname__ == 'Process' (len 7)
#
# Process is the core class for spawning child processes. Its qualname
# equals its simple name (top-level class, not nested).
# Also captures length for ProcessError and TimeoutError (both len 12).
# ---------------------------------------------------------------------------

table multiprocessing_extra201.process_qualname:
  description: "multiprocessing.Process __qualname__ equality and exception length checks in mpqualname201 namespace; new to multiprocessing_extra201"
  kind: python_call_eq
  category: qualnames
  id_prefix: mpqualname201

  columns: [id, function, args, expected, description]
  rows:
    - [process_qualname_eq,
       Process.__qualname__.__eq__,
       ["Process"],
       true,
       "multiprocessing.Process.__qualname__.__eq__('Process') == True — Process is the top-level class for spawning child processes; qualname equals name; new to multiprocessing_extra201; verified Python 3.14.3"]
    - [process_qualname_len,
       Process.__qualname__.__len__,
       [],
       7,
       "multiprocessing.Process.__qualname__.__len__() == 7 — 'Process' has 7 characters; new to multiprocessing_extra201; verified Python 3.14.3"]
    - [process_error_qualname_len,
       ProcessError.__qualname__.__len__,
       [],
       12,
       "multiprocessing.ProcessError.__qualname__.__len__() == 12 — 'ProcessError' has 12 characters; new to multiprocessing_extra201; verified Python 3.14.3"]
    - [timeout_error_qualname_len,
       TimeoutError.__qualname__.__len__,
       [],
       12,
       "multiprocessing.TimeoutError.__qualname__.__len__() == 12 — 'TimeoutError' has 12 characters; same length as ProcessError; new to multiprocessing_extra201; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing class __qualname__ lengths — all five
#
# ProcessError: 12, AuthenticationError: 19, BufferTooShort: 14,
# TimeoutError: 12, Process: 7
#
# Length axis for AuthenticationError and BufferTooShort not yet captured.
# AuthenticationError has the longest qualname of the five (19 chars).
# ---------------------------------------------------------------------------

table multiprocessing_extra201.class_qualname_lengths:
  description: "multiprocessing class __qualname__ lengths for all five classes in mpqualname201 namespace; new to multiprocessing_extra201"
  kind: python_call_eq
  category: qualnames
  id_prefix: mpqualname201

  columns: [id, function, args, expected, description]
  rows:
    - [authentication_error_qualname_len,
       AuthenticationError.__qualname__.__len__,
       [],
       19,
       "multiprocessing.AuthenticationError.__qualname__.__len__() == 19 — 'AuthenticationError' has 19 characters; longest qualname of the five; new to multiprocessing_extra201; verified Python 3.14.3"]
    - [buffer_too_short_qualname_len,
       BufferTooShort.__qualname__.__len__,
       [],
       14,
       "multiprocessing.BufferTooShort.__qualname__.__len__() == 14 — 'BufferTooShort' has 14 characters; new to multiprocessing_extra201; verified Python 3.14.3"]
    - [process_error_len_eq_timeout_error_len,
       ProcessError.__qualname__.__len__,
       [],
       12,
       "multiprocessing.ProcessError.__qualname__.__len__() == 12 — same length as TimeoutError (12); both are 12-character names; new to multiprocessing_extra201; verified Python 3.14.3"]
    - [process_qualname_len_shortest,
       Process.__qualname__.__len__,
       [],
       7,
       "multiprocessing.Process.__qualname__.__len__() == 7 — 'Process' is the shortest qualname of the five at 7 characters; new to multiprocessing_extra201; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra201
# ---------------------------------------------------------------------------

invariant multiprocessing_extra201.ProcessError.qualname_eq:
  description: "multiprocessing.ProcessError.__qualname__.__eq__('ProcessError') == True — ProcessError is the top-level base exception class for multiprocessing errors; its qualname equals its simple name; new to multiprocessing_extra201; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: ProcessError.__qualname__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra201.AuthenticationError.qualname_eq:
  description: "multiprocessing.AuthenticationError.__qualname__.__eq__('AuthenticationError') == True — AuthenticationError is raised when an authentication check fails in multiprocessing connections; its qualname equals its simple name; new to multiprocessing_extra201; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra201.BufferTooShort.qualname_eq:
  description: "multiprocessing.BufferTooShort.__qualname__.__eq__('BufferTooShort') == True — BufferTooShort is raised by Connection.recv_bytes_into when the buffer is too small; its qualname equals its simple name; new to multiprocessing_extra201; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: BufferTooShort.__qualname__.__eq__
  args: ["BufferTooShort"]
  expected: true

invariant multiprocessing_extra201.TimeoutError.qualname_eq:
  description: "multiprocessing.TimeoutError.__qualname__.__eq__('TimeoutError') == True — TimeoutError is raised when a timeout expires in a multiprocessing operation; its qualname equals its simple name; new to multiprocessing_extra201; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: TimeoutError.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant multiprocessing_extra201.Process.qualname_eq:
  description: "multiprocessing.Process.__qualname__.__eq__('Process') == True — Process is the top-level class used to spawn child processes; its qualname equals its simple name; new to multiprocessing_extra201; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: Process.__qualname__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra201.AuthenticationError.qualname_len:
  description: "multiprocessing.AuthenticationError.__qualname__.__len__() == 19 — 'AuthenticationError' has exactly 19 characters; the longest qualname among the five classes; new to multiprocessing_extra201; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra201.BufferTooShort.qualname_len:
  description: "multiprocessing.BufferTooShort.__qualname__.__len__() == 14 — 'BufferTooShort' has exactly 14 characters; new to multiprocessing_extra201; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: BufferTooShort.__qualname__.__len__
  args: []
  expected: 14

invariant multiprocessing_extra201.Process.qualname_len:
  description: "multiprocessing.Process.__qualname__.__len__() == 7 — 'Process' has exactly 7 characters; the shortest qualname of the five; new to multiprocessing_extra201; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: Process.__qualname__.__len__
  args: []
  expected: 7
