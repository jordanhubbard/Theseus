spec: enum_extra13
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra12.zspec.zsdl and enum_flags.zspec.zsdl."
    - "enum_extra12 covers: EnumMeta MRO length (3) and MRO[1].__name__; Flag MRO length (3) and MRO[1].__name__; ReprEnum.__qualname__ and __bases__.__len__; nonmember/member __module__ and __qualname__; global_enum/show_flag_values __qualname__."
    - "NOT yet covered: IntEnum.__mro__.__len__() (== 5); IntEnum MRO entries [1..4]; StrEnum.__mro__.__len__() (== 5); StrEnum MRO[2].__name__ == 'ReprEnum'; IntFlag.__mro__.__len__() (== 6); IntFlag MRO entries; auto.__mro__.__len__() (== 2); auto MRO[1].__name__; unique.__qualname__ and __module__; FlagBoundary.__qualname__ and __mro__.__len__; ReprEnum.__bases__[0].__name__ == 'Enum'; EnumMeta.__mro__[2].__name__ == 'object'."
    - "enum.IntEnum.__mro__.__len__() == 5 — [IntEnum, int, ReprEnum, Enum, object]."
    - "enum.IntEnum.__mro__[1].__name__ == 'int'."
    - "enum.IntEnum.__mro__[2].__name__ == 'ReprEnum'."
    - "enum.StrEnum.__mro__.__len__() == 5 — [StrEnum, str, ReprEnum, Enum, object] (Python 3.11+)."
    - "enum.StrEnum.__mro__[2].__name__ == 'ReprEnum' (Python 3.11+)."
    - "enum.IntFlag.__mro__.__len__() == 6 — [IntFlag, int, ReprEnum, Flag, Enum, object]."
    - "enum.IntFlag.__mro__[3].__name__ == 'Flag'."
    - "enum.auto.__mro__.__len__() == 2 — [auto, object]."
    - "enum.auto.__mro__[1].__name__ == 'object'."
    - "enum.unique.__qualname__ == 'unique' (top-level decorator function)."
    - "enum.unique.__module__ == 'enum'."
    - "enum.FlagBoundary.__qualname__ == 'FlagBoundary' (Python 3.11+)."
    - "enum.FlagBoundary.__mro__.__len__() == 6 — [FlagBoundary, StrEnum, str, ReprEnum, Enum, object] (Python 3.11+)."
    - "enum.ReprEnum.__bases__[0].__name__ == 'Enum' (Python 3.11+)."
    - "enum.EnumMeta.__mro__[2].__name__ == 'object'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IntEnum.__mro__ — length and key entries
#
# enum_extra11 verified IntEnum.__bases__.__len__() == 2. Not yet verified:
# the full MRO. IntEnum MRO is [IntEnum, int, ReprEnum, Enum, object] — len 5.
# ---------------------------------------------------------------------------

invariant enum_extra13.IntEnum.mro_len:
  description: "enum.IntEnum.__mro__.__len__() == 5 — [IntEnum, int, ReprEnum, Enum, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: IntEnum.__mro__.__len__
  args: []
  expected: 5

table enum_extra13.IntEnum_mro_entries:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_entry

  columns: [id, function, args, expected]
  rows:
    - [IntEnum_mro1, IntEnum.__mro__.__getitem__, [1], "int"]
    - [IntEnum_mro2, IntEnum.__mro__.__getitem__, [2], "ReprEnum"]

# ---------------------------------------------------------------------------
# StrEnum.__mro__ — length and ReprEnum entry (Python 3.11+)
#
# enum_extra9 verified StrEnum.__mro__[1].__name__ == 'str'.
# enum_extra11 verified StrEnum.__bases__.__len__() == 2.
# Not yet verified: MRO length or the ReprEnum entry at position 2.
# StrEnum MRO is [StrEnum, str, ReprEnum, Enum, object] — length 5.
# ---------------------------------------------------------------------------

invariant enum_extra13.StrEnum.mro_len:
  description: "enum.StrEnum.__mro__.__len__() == 5 — [StrEnum, str, ReprEnum, Enum, object] (Python 3.11+)"
  category: class_hierarchy
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__mro__.__len__
  args: []
  expected: 5

invariant enum_extra13.StrEnum.mro_reprEnum:
  description: "enum.StrEnum.__mro__[2].__name__ == 'ReprEnum' — ReprEnum is third in StrEnum's MRO (Python 3.11+)"
  category: class_hierarchy
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "ReprEnum"

# ---------------------------------------------------------------------------
# IntFlag.__mro__ — length and Flag entry
#
# enum_extra11 verified IntFlag.__bases__.__len__() == 2. Not yet verified:
# the MRO tuple. IntFlag MRO is [IntFlag, int, ReprEnum, Flag, Enum, object]
# — length 6.
# ---------------------------------------------------------------------------

invariant enum_extra13.IntFlag.mro_len:
  description: "enum.IntFlag.__mro__.__len__() == 6 — [IntFlag, int, ReprEnum, Flag, Enum, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: IntFlag.__mro__.__len__
  args: []
  expected: 6

invariant enum_extra13.IntFlag.mro_flag:
  description: "enum.IntFlag.__mro__[3].__name__ == 'Flag' — Flag is fourth in IntFlag's MRO"
  category: class_hierarchy
  kind: python_call_eq
  function: IntFlag.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "Flag"

# ---------------------------------------------------------------------------
# auto.__mro__ — length and second entry
#
# enum_extra10 verified auto.__bases__[0].__name__ == 'int'. However, on
# Python 3.12+ auto's MRO is [auto, object] — length 2 — because auto no
# longer inherits from int. Not yet verified: MRO length or MRO[1].__name__.
# ---------------------------------------------------------------------------

invariant enum_extra13.auto.mro_len:
  description: "enum.auto.__mro__.__len__() == 2 — [auto, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: auto.__mro__.__len__
  args: []
  expected: 2

invariant enum_extra13.auto.mro_second:
  description: "enum.auto.__mro__[1].__name__ == 'object' — object is second in auto's MRO"
  category: class_hierarchy
  kind: python_call_eq
  function: auto.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# unique — __qualname__ and __module__
#
# enum_extra9 and prior specs cover __name__ for IntEnum/StrEnum/nonmember/
# member/auto but not for unique. enum.unique is a plain decorator function.
# Not tested in any prior spec: unique.__qualname__ or unique.__module__.
# ---------------------------------------------------------------------------

invariant enum_extra13.unique.qualname:
  description: "enum.unique.__qualname__ == 'unique'"
  category: function_attrs
  kind: python_call_eq
  function: unique.__qualname__.__eq__
  args: ["unique"]
  expected: true

invariant enum_extra13.unique.module:
  description: "enum.unique.__module__ == 'enum'"
  category: function_attrs
  kind: python_call_eq
  function: unique.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# ReprEnum.__bases__[0].__name__ == 'Enum' (Python 3.11+)
#
# enum_extra12 verified ReprEnum.__bases__.__len__() == 1.
# Not yet verified: the name of that sole base (Enum).
# ---------------------------------------------------------------------------

invariant enum_extra13.ReprEnum.base_is_Enum:
  description: "enum.ReprEnum.__bases__[0].__name__ == 'Enum' — ReprEnum's sole base is Enum (Python 3.11+)"
  category: class_hierarchy
  version: ">=3.11"
  kind: python_call_eq
  function: ReprEnum.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Enum"

# ---------------------------------------------------------------------------
# EnumMeta.__mro__[2].__name__ == 'object'
#
# enum_extra12 verified EnumMeta.__mro__.__len__() == 3 and
# EnumMeta.__mro__[1].__name__ == 'type'. Not yet verified: the third
# (final) entry, which is 'object'.
# ---------------------------------------------------------------------------

invariant enum_extra13.EnumMeta.mro_third:
  description: "enum.EnumMeta.__mro__[2].__name__ == 'object' — object is last in EnumMeta's MRO"
  category: class_hierarchy
  kind: python_call_eq
  function: EnumMeta.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"
