spec: th3556
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (th3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for threading types."
    - "All values false — threading types do not define __reduce__, __reduce_ex__, or __getstate__ in their own __dict__."
    - "Threading primitives (Lock, RLock, Condition, Semaphore, Event, Barrier) are not picklable; no custom pickle protocol is defined."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __reduce__ dict-presence — operator.contains(Cls.__dict__, '__reduce__')
# ---------------------------------------------------------------------------

table th3556.reduce:
  description: "threading types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3556
  columns: [id, function, args, expected]
  rows:
    - ["th3556001", operator.contains, [threading.Thread.__dict__,           "__reduce__"], false]
    - ["th3556002", operator.contains, [threading.Event.__dict__,            "__reduce__"], false]
    - ["th3556003", operator.contains, [threading.Condition.__dict__,        "__reduce__"], false]
    - ["th3556004", operator.contains, [threading.Semaphore.__dict__,        "__reduce__"], false]
    - ["th3556005", operator.contains, [threading.BoundedSemaphore.__dict__, "__reduce__"], false]
    - ["th3556006", operator.contains, [threading.Timer.__dict__,            "__reduce__"], false]
    - ["th3556007", operator.contains, [threading.Barrier.__dict__,          "__reduce__"], false]
    - ["th3556008", operator.contains, [threading.local.__dict__,            "__reduce__"], false]
    - ["th3556009", operator.contains, [type(threading.Lock()).__dict__,     "__reduce__"], false]
    - ["th3556010", operator.contains, [type(threading.RLock()).__dict__,    "__reduce__"], false]

