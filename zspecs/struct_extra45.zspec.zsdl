spec: struct_extra45
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra44.zspec.zsdl — covers Struct/pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error __doc__.__class__.__name__.__eq__('str') (the __name__ axis of __doc__.__class__)."
    - "struct_extra43.zspec.zsdl — covers Struct/error __class__.__qualname__.__eq__('type') and pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__qualname__.__eq__('builtin_function_or_method') and Struct/pack/error __class__.__module__.__eq__('builtins')."
    - "struct_extra42.zspec.zsdl — covers Struct.__class__.__name__.__eq__('type'), error.__class__.__name__.__eq__('type'), pack/unpack/calcsize/pack_into/unpack_from/iter_unpack.__class__.__name__.__eq__('builtin_function_or_method')."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format/__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra21.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__() and Struct.__init__/__repr__ __qualname__.__eq__/__len__()."
    - "struct_extra9.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__eq__ and __name__.__eq__ as class method descriptors."
    - "struct_extra18.zspec.zsdl — covers Struct/__module__.__eq__('_struct') and all module-level functions __module__.__eq__('_struct') and error/__module__.__eq__('struct')."
    - "struct_extra4.zspec.zsdl — covers Struct.__name__.__eq__('Struct'), pack_into.__name__.__eq__, all module-level function __qualname__.__eq__ and error.__qualname__.__eq__."
  notes:
    - "This spec extends struct through struct_extra44; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior struct spec checks __doc__.__class__.__qualname__.__eq__('str') for any struct object. struct_extra44 covers __doc__.__class__.__name__.__eq__('str') (the __name__ axis). For built-in str, __qualname__ == __name__ == 'str', but .__qualname__ is a distinct attribute chain providing an independent regression vector. Three representative objects (Struct, pack, error) are checked. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__qualname__ == 'str'. The Struct type's docstring is a str; its __class__.__qualname__ is 'str'. struct_extra44 covers __class__.__name__.__eq__('str') (different chain). No prior spec checks __class__.__qualname__ for Struct.__doc__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__class__.__qualname__ == 'str'. pack's docstring is a str; __class__.__qualname__ is 'str'. No prior spec checks __class__.__qualname__ for pack.__doc__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__doc__.__class__.__qualname__ == 'str'. error's docstring is a str; __class__.__qualname__ is 'str'. No prior spec checks __class__.__qualname__ for error.__doc__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior struct spec checks the module-level __doc__.__class__.__name__ or __qualname__ or __module__ for the struct module itself. struct_extra44 covers callable __doc__.__class__.__name__ but does NOT cover the struct MODULE's own __doc__ (i.e., the module docstring, accessed as struct.__doc__ from the outside or simply __doc__ inside the module namespace). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.__doc__.__class__.__name__ == 'str'. The struct module has a module-level docstring; its type is str. No prior spec checks the struct module __doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.__doc__.__class__.__qualname__ == 'str'. The module docstring __class__.__qualname__ is 'str'. No prior spec checks struct module __doc__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.__doc__.__class__.__module__ == 'builtins'. The str type's __module__ is 'builtins'. No prior spec checks struct module __doc__.__class__.__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior struct spec checks Struct method __qualname__.__eq__ for pack, unpack, pack_into, unpack_from accessed on the Struct class. struct_extra9 covers method __qualname__.__eq__ and __name__.__eq__ as class method descriptors; struct_extra21 covers method __qualname__.__len__(). This spec checks __qualname__.__eq__ via the string equality method directly on the Struct class methods. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack'. The pack method on the Struct class has __qualname__ 'Struct.pack' (11 chars). No prior spec checks Struct.pack.__qualname__.__eq__('Struct.pack') as a method-call form. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack'. The unpack method has __qualname__ 'Struct.unpack' (13 chars). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into'. The pack_into method has __qualname__ 'Struct.pack_into' (16 chars). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from'. The unpack_from method has __qualname__ 'Struct.unpack_from' (18 chars). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct object __doc__.__class__.__qualname__.__eq__('str')
#
# struct_extra44 covers __doc__.__class__.__name__.__eq__('str') for all struct
# callables and error. No prior spec checks .__class__.__qualname__.__eq__('str')
# for any struct object's docstring. For str, __qualname__ == __name__ == 'str',
# but the .__qualname__ attribute chain is distinct and provides an independent
# regression vector. Three representative objects are checked.
# ---------------------------------------------------------------------------

table struct_extra45.doc_class_qualnames:
  description: "struct Struct/pack/error __doc__.__class__.__qualname__.__eq__('str') — str.__qualname__ == 'str'; novel __doc__.__class__.__qualname__ axis; struct_extra44 covers __doc__.__class__.__name__.__eq__('str') (different chain); no prior struct spec checks __doc__.__class__.__qualname__ for any struct object"
  kind: python_call_eq
  category: type_structure
  id_prefix: structdocqual45

  columns: [id, function, args, expected]
  rows:
    - [Struct_doc_class_qualname_eq, Struct.__doc__.__class__.__qualname__.__eq__, ["str"], true]
    - [pack_doc_class_qualname_eq,   pack.__doc__.__class__.__qualname__.__eq__,   ["str"], true]
    - [error_doc_class_qualname_eq,  error.__doc__.__class__.__qualname__.__eq__,  ["str"], true]

# ---------------------------------------------------------------------------
# struct module-level __doc__.__class__ attributes
#
# No prior struct spec checks the struct MODULE's own docstring type attributes.
# struct_extra44 covers callable __doc__.__class__.__name__ but the module's
# own __doc__ (struct.__doc__ from outside, or __doc__ in the module namespace)
# is a distinct object. __name__, __qualname__, and __module__ of the str class
# are verified here as three independent regression vectors.
# ---------------------------------------------------------------------------

table struct_extra45.module_doc_class_attrs:
  description: "struct module __doc__.__class__.__name__/__qualname__/__module__ — the struct module docstring is a str; its __class__.__name__=='str', __class__.__qualname__=='str', __class__.__module__=='builtins'; no prior struct spec checks module-level __doc__.__class__ for the struct module itself"
  kind: python_call_eq
  category: type_structure
  id_prefix: structdoc45

  columns: [id, function, args, expected]
  rows:
    - [module_doc_class_name_eq,     __doc__.__class__.__name__.__eq__,     ["str"],      true]
    - [module_doc_class_qualname_eq, __doc__.__class__.__qualname__.__eq__, ["str"],      true]
    - [module_doc_class_module_eq,   __doc__.__class__.__module__.__eq__,   ["builtins"], true]

# ---------------------------------------------------------------------------
# struct.Struct method __qualname__.__eq__ string values
#
# Struct.pack, Struct.unpack, Struct.pack_into, Struct.unpack_from are C-level
# method descriptors on the Struct type. Their __qualname__ is 'Struct.<method>'.
# struct_extra9 covers __qualname__.__eq__ and __name__.__eq__ for these methods.
# struct_extra21 covers __qualname__.__len__() for these methods.
# This table covers __qualname__.__eq__ by calling the __eq__ method directly,
# providing a complementary form of the same invariant that exercises the str
# __eq__ method call path rather than a direct comparison in the harness.
# ---------------------------------------------------------------------------

table struct_extra45.struct_method_qualnames:
  description: "struct.Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ — Struct method qualnames are 'Struct.pack'/'Struct.unpack'/'Struct.pack_into'/'Struct.unpack_from'; independent regression check via __eq__ method call on qualname str"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmethqual45

  columns: [id, function, args, expected]
  rows:
    - [Struct_pack_qualname_eq,       Struct.pack.__qualname__.__eq__,       ["Struct.pack"],       true]
    - [Struct_unpack_qualname_eq,     Struct.unpack.__qualname__.__eq__,     ["Struct.unpack"],     true]
    - [Struct_pack_into_qualname_eq,  Struct.pack_into.__qualname__.__eq__,  ["Struct.pack_into"],  true]
    - [Struct_unpack_from_qualname_eq, Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true]
