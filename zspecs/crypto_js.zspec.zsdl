spec: crypto_js
version: ">=4.0.0"
backend: node(crypto-js)

docs: https://www.npmjs.com/package/crypto-js

provenance:
  derived_from:
    - "crypto-js README — https://www.npmjs.com/package/crypto-js"
    - "Test vectors verified with crypto-js via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "crypto-js source"
  notes:
    - "crypto-js is an npm package. Install: npm install crypto-js"
    - "CryptoJS.SHA256(str) returns a WordArray; .toString() converts to hex string."
    - "Also provides MD5, SHA1, SHA512, HmacSHA256 and more."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns hex hash string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table crypto_js.SHA256:
  kind: node_factory_call_eq
  factory: SHA256
  method: toString
  id_prefix: cjsha256

  columns: [id, factory_args, expected]
  rows:
    - [hello, ["hello"], "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"]
    - [empty, [""],      "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"]

table crypto_js.MD5:
  kind: node_factory_call_eq
  factory: MD5
  method: toString
  id_prefix: cjmd5

  columns: [id, factory_args, expected]
  rows:
    - [hello, ["hello"], "5d41402abc4b2a76b9719d911017c592"]

table crypto_js.SHA1:
  kind: node_factory_call_eq
  factory: SHA1
  method: toString
  id_prefix: cjsha1

  columns: [id, factory_args, expected]
  rows:
    - [hello, ["hello"], "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T14:53:05Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
