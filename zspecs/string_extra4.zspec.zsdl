spec: string_extra4
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends prior string specs."
    - "Focus: string constants, Formatter class, Template class."
    - "string.ascii_letters == string.ascii_lowercase + string.ascii_uppercase."
    - "string.digits == '0123456789'."
    - "string.hexdigits == '0123456789abcdefABCDEF'."
    - "string.octdigits == '01234567'."
    - "string.punctuation contains 32 ASCII punctuation characters."
    - "string.whitespace contains space, tab, newline, carriage return, form feed, vertical tab."
    - "string.Formatter.__module__ == 'string'."
    - "string.Template.__module__ == 'string'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table string_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Formatter, Formatter.__name__.__eq__, ["Formatter"], true]
    - [Template,  Template.__name__.__eq__,  ["Template"],  true]

table string_extra4.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Formatter, Formatter.__module__.__eq__, ["string"], true]
    - [Template,  Template.__module__.__eq__,  ["string"], true]

invariant string_extra4.digits.value:
  description: "string.digits == '0123456789'"
  category: constants
  kind: python_call_eq
  function: digits.__eq__
  args: ["0123456789"]
  expected: true

invariant string_extra4.hexdigits.value:
  description: "string.hexdigits == '0123456789abcdefABCDEF'"
  category: constants
  kind: python_call_eq
  function: hexdigits.__eq__
  args: ["0123456789abcdefABCDEF"]
  expected: true

invariant string_extra4.octdigits.value:
  description: "string.octdigits == '01234567'"
  category: constants
  kind: python_call_eq
  function: octdigits.__eq__
  args: ["01234567"]
  expected: true

invariant string_extra4.ascii_lowercase.length:
  description: "len(string.ascii_lowercase) == 26"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.__len__
  args: []
  expected: 26

invariant string_extra4.ascii_uppercase.length:
  description: "len(string.ascii_uppercase) == 26"
  category: constants
  kind: python_call_eq
  function: ascii_uppercase.__len__
  args: []
  expected: 26

invariant string_extra4.ascii_letters.length:
  description: "len(string.ascii_letters) == 52"
  category: constants
  kind: python_call_eq
  function: ascii_letters.__len__
  args: []
  expected: 52

invariant string_extra4.digits.length:
  description: "len(string.digits) == 10"
  category: constants
  kind: python_call_eq
  function: digits.__len__
  args: []
  expected: 10

invariant string_extra4.punctuation.length:
  description: "len(string.punctuation) == 32"
  category: constants
  kind: python_call_eq
  function: punctuation.__len__
  args: []
  expected: 32

invariant string_extra4.Formatter.format_method_name:
  description: "string.Formatter().format.__func__.__name__ == 'format'"
  category: Formatter
  kind: python_call_eq
  function: Formatter
  args: []
  method: format.__func__.__name__.__eq__
  method_args: ["format"]
  expected: true

invariant string_extra4.Template.class_name:
  description: "string.Template.__name__ == 'Template'"
  category: Template
  kind: python_call_eq
  function: Template.__name__.__eq__
  args: ["Template"]
  expected: true
