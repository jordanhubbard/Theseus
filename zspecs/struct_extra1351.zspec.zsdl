spec: struct_extra1351
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "struct.Struct is a C extension type; it does not expose __slots__ or __weakref__ descriptors in its __dict__."
    - "struct.Struct.__dict__.__contains__('__slots__') == False — C extension types use tp_members, not Python __slots__."
    - "struct.Struct.__dict__.__contains__('__weakref__') == False — C extension types manage weakref support at the C level."
    - "struct.Struct.__dict__.__contains__('__dict__') == False — Struct instances have no instance __dict__; all attributes are C-level."
    - "struct.Struct.__dict__ does contain descriptors: pack, unpack, pack_into, unpack_from, iter_unpack, size, format."
    - "struct.error is a subclass of Exception; its __dict__ contains __weakref__ (inherited from object's weakref support added at class creation) but no __slots__."
    - "struct.error.__dict__.__contains__('__slots__') == False — struct.error does not declare __slots__."
    - "struct.error.__dict__.__contains__('__weakref__') == True — struct.error is a pure Python exception subclass; object provides __weakref__ descriptor."
    - "struct.error.__dict__.__contains__('__dict__') == False — exception subclasses expose __dict__ via BaseException, not as a separate descriptor in their own __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra1351.struct_class_slot_weakref_dict_checks:
  description: "struct.Struct C extension class __dict__ containment checks for __slots__, __weakref__, and __dict__ descriptors; Struct is a C type with no Python-level slot machinery"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: st1351sc
  columns: [id, function, args, expected]
  rows:
    - [st1351sc001, struct.Struct.__dict__.__contains__, ["__slots__"],    false]
    - [st1351sc002, struct.Struct.__dict__.__contains__, ["__weakref__"],  false]
    - [st1351sc003, struct.Struct.__dict__.__contains__, ["__dict__"],     false]
    - [st1351sc004, struct.Struct.__dict__.__contains__, ["pack"],         true]
    - [st1351sc005, struct.Struct.__dict__.__contains__, ["unpack"],       true]
    - [st1351sc006, struct.Struct.__dict__.__contains__, ["size"],         true]

table struct_extra1351.struct_class_method_presence_checks:
  description: "struct.Struct class __dict__ containment checks for additional C-level method and attribute descriptors"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: st1351sm
  columns: [id, function, args, expected]
  rows:
    - [st1351sm001, struct.Struct.__dict__.__contains__, ["format"],       true]
    - [st1351sm002, struct.Struct.__dict__.__contains__, ["pack_into"],    true]
    - [st1351sm003, struct.Struct.__dict__.__contains__, ["unpack_from"],  true]
    - [st1351sm004, struct.Struct.__dict__.__contains__, ["iter_unpack"],  true]
    - [st1351sm005, struct.Struct.__dict__.__contains__, ["__slots__"],    false]
    - [st1351sm006, struct.Struct.__dict__.__contains__, ["__weakref__"],  false]

table struct_extra1351.error_class_slot_weakref_dict_checks:
  description: "struct.error exception class __dict__ containment checks; struct.error is a pure Python Exception subclass that has __weakref__ but no __slots__ or __dict__ descriptor in its own __dict__"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: st1351ec
  columns: [id, function, args, expected]
  rows:
    - [st1351ec001, struct.error.__dict__.__contains__, ["__slots__"],    false]
    - [st1351ec002, struct.error.__dict__.__contains__, ["__weakref__"],  true]
    - [st1351ec003, struct.error.__dict__.__contains__, ["__dict__"],     false]
    - [st1351ec004, struct.Struct.__dict__.__contains__, ["__slots__"],   false]
    - [st1351ec005, struct.Struct.__dict__.__contains__, ["__weakref__"], false]
    - [st1351ec006, struct.Struct.__dict__.__contains__, ["__dict__"],    false]
