spec: decimal_extra77
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra76."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for various dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context.__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__; Decimal division/power operator wrapper_descriptor identity and __dict__ membership; Context.__init__/__class__.__name__; Context arithmetic method __class__.__name__; Context/__dict__/__class__/__name__ and membership; Context.__bases__[0].__name__; Context.__mro__.__len__(); Decimal arithmetic/string/conversion dunder __qualname__ values and lengths."
    - "This spec covers: Decimal.__eq__/__qualname__.__len__(); Decimal.__ne__/__qualname__.__len__(); Decimal.__lt__/__qualname__.__len__(); Decimal.__le__/__qualname__.__len__(); Decimal.__gt__/__qualname__.__len__(); Decimal.__ge__/__qualname__.__len__(); Decimal.to_eng_string/__qualname__.__len__(); Decimal.to_integral/__qualname__.__len__(); Decimal.to_integral_value/__qualname__.__len__(); Decimal.to_integral_exact/__qualname__.__len__(); Decimal.normalize/__qualname__.__len__(); Decimal.quantize/__qualname__.__len__(); Decimal.sqrt/__qualname__.__len__(); Decimal.compare/__qualname__.__len__()."
    - "Decimal.__eq__.__qualname__ == 'Decimal.__eq__' — length 14 ('Decimal.__eq__' has 14 chars)."
    - "Decimal.__ne__/__lt__/__le__/__gt__/__ge__ all have qualname length 14."
    - "Decimal.to_eng_string.__qualname__ == 'Decimal.to_eng_string' — length 21."
    - "Decimal.to_integral.__qualname__ == 'Decimal.to_integral' — length 19."
    - "Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value' — length 25."
    - "Decimal.to_integral_exact.__qualname__ == 'Decimal.to_integral_exact' — length 25."
    - "Decimal.normalize.__qualname__ == 'Decimal.normalize' — length 17."
    - "Decimal.quantize.__qualname__ == 'Decimal.quantize' — length 16."
    - "Decimal.sqrt.__qualname__ == 'Decimal.sqrt' — length 12."
    - "Decimal.compare.__qualname__ == 'Decimal.compare' — length 15."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal comparison operator __qualname__ lengths: __eq__, __ne__, __lt__, __le__
# All are wrapper_descriptors (C slot wrappers); qualnames are 'Decimal.__xx__'.
# __eq__/__ne__/__lt__/__le__ each have length 14.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra77.Decimal_cmp_eq_ne_lt_le_qualname_lens:
  description: "Decimal.__eq__, __ne__, __lt__, __le__ __qualname__ lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalextra77

  columns: [id, function, args, expected]
  rows:
    - [eq_qn_len, Decimal.__eq__.__qualname__.__len__, [], 14]
    - [ne_qn_len, Decimal.__ne__.__qualname__.__len__, [], 14]
    - [lt_qn_len, Decimal.__lt__.__qualname__.__len__, [], 14]
    - [le_qn_len, Decimal.__le__.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# Decimal comparison operator __qualname__ lengths: __gt__, __ge__
# Both are wrapper_descriptors (C slot wrappers); qualnames are 'Decimal.__gt__'/'Decimal.__ge__'.
# Both have length 14.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra77.Decimal_cmp_gt_ge_qualname_lens:
  description: "Decimal.__gt__ and __ge__ __qualname__ lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalextra77

  columns: [id, function, args, expected]
  rows:
    - [gt_qn_len, Decimal.__gt__.__qualname__.__len__, [], 14]
    - [ge_qn_len, Decimal.__ge__.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# Decimal.to_eng_string, to_integral, to_integral_value, to_integral_exact __qualname__ lengths
# to_eng_string: length 21; to_integral: length 19; to_integral_value/to_integral_exact: length 25.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra77.Decimal_to_methods_qualname_lens:
  description: "Decimal.to_eng_string, to_integral, to_integral_value, to_integral_exact __qualname__ lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalextra77

  columns: [id, function, args, expected]
  rows:
    - [to_eng_qn_len,   Decimal.to_eng_string.__qualname__.__len__,   [], 21]
    - [to_int_qn_len,   Decimal.to_integral.__qualname__.__len__,     [], 19]
    - [to_intv_qn_len,  Decimal.to_integral_value.__qualname__.__len__, [], 25]
    - [to_intx_qn_len,  Decimal.to_integral_exact.__qualname__.__len__, [], 25]

# ---------------------------------------------------------------------------
# Decimal.normalize, quantize, sqrt, compare __qualname__ lengths
# normalize: length 17; quantize: length 16; sqrt: length 12; compare: length 15.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra77.Decimal_math_methods_qualname_lens:
  description: "Decimal.normalize, quantize, sqrt, compare __qualname__ lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalextra77

  columns: [id, function, args, expected]
  rows:
    - [normalize_qn_len, Decimal.normalize.__qualname__.__len__, [], 17]
    - [quantize_qn_len,  Decimal.quantize.__qualname__.__len__,  [], 16]
    - [sqrt_qn_len,      Decimal.sqrt.__qualname__.__len__,      [], 12]
    - [compare_qn_len,   Decimal.compare.__qualname__.__len__,   [], 15]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra77.Decimal_eq.qualname_len:
  description: "decimal.Decimal.__eq__.__qualname__.__len__() == 14 ('Decimal.__eq__' has 14 chars)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__eq__.__qualname__.__len__
  args: []
  expected: 14

invariant decimal_extra77.Decimal_ne.qualname_len:
  description: "decimal.Decimal.__ne__.__qualname__.__len__() == 14 ('Decimal.__ne__' has 14 chars)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__ne__.__qualname__.__len__
  args: []
  expected: 14

invariant decimal_extra77.Decimal_to_eng_string.qualname_len:
  description: "decimal.Decimal.to_eng_string.__qualname__.__len__() == 21 ('Decimal.to_eng_string' has 21 chars)"
  category: qualname
  kind: python_call_eq
  function: Decimal.to_eng_string.__qualname__.__len__
  args: []
  expected: 21

invariant decimal_extra77.Decimal_sqrt.qualname_len:
  description: "decimal.Decimal.sqrt.__qualname__.__len__() == 12 ('Decimal.sqrt' has 12 chars)"
  category: qualname
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__len__
  args: []
  expected: 12

invariant decimal_extra77.Decimal_compare.qualname_len:
  description: "decimal.Decimal.compare.__qualname__.__len__() == 15 ('Decimal.compare' has 15 chars)"
  category: qualname
  kind: python_call_eq
