spec: strip_eof
version: ">=1.0.0"
backend: node(strip-eof)

docs: https://github.com/sindresorhus/strip-eof#readme

provenance:
  derived_from:
    - "strip-eof README — https://github.com/sindresorhus/strip-eof#readme"
    - "Test vectors verified with strip-eof via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "strip-eof source"
  notes:
    - "Strip end-of-file marker (\\n or \\r\\n) from the end of a string or Buffer."
    - "Install: npm install strip-eof"
    - "v1 CJS; module export IS the function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string/Buffer input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant strip_eof.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant strip_eof.module_arity:
  description: "Module function declared length is 1"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant strip_eof.strip_lf:
  description: "Trailing \\n is stripped"
  category: strip
  kind: node_chain_eq
  entry: module
  entry_args: ["foo\n"]
  chain: []
  expected: "foo"

invariant strip_eof.strip_crlf:
  description: "Trailing \\r\\n is stripped"
  category: strip
  kind: node_chain_eq
  entry: module
  entry_args: ["foo\r\n"]
  chain: []
  expected: "foo"

invariant strip_eof.empty_string_passthrough:
  description: "Empty string passes through"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [""]
  chain: []
  expected: ""

invariant strip_eof.no_trailing_eof_passthrough:
  description: "String without trailing newline is unchanged"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: ["foo"]
  chain: []
  expected: "foo"

invariant strip_eof.only_strips_one_newline:
  description: "Only the final newline is stripped — earlier newlines remain"
  category: strip
  kind: node_chain_eq
  entry: module
  entry_args: ["a\nb\n"]
  chain: []
  expected: "a\nb"

invariant strip_eof.lone_cr_stripped:
  description: "Lone trailing \\r is stripped (impl strips \\n then \\r independently)"
  category: strip
  kind: node_chain_eq
  entry: module
  entry_args: ["foo\r"]
  chain: []
  expected: "foo"
