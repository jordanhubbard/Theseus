spec: pathlib_extra154
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.__spec__ and loader identity — pathlib.__loader__.__class__.__name__ == 'SourceFileLoader', pathlib.__spec__.__class__.__name__ == 'ModuleSpec', pathlib.__package__ == 'pathlib', pathlib.__spec__.parent == 'pathlib'. Also covers pathlib.Path.__dict__ and pathlib.PurePath.__dict__ mappingproxy lengths, pathlib.Path/__mro__ (len=3), pathlib.PurePath.__mro__ (len=2)."
    - "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16) — pathlib is a pure Python source file, so its loader is a SourceFileLoader instance (not FrozenImporter like io)."
    - "pathlib.__package__ == 'pathlib' (len=7); pathlib.__spec__.parent == 'pathlib' (len=7) — pathlib is both a module and a package."
    - "pathlib.Path.__dict__.__len__() == 62 (the largest __dict__ in pathlib; Path defines 62 entries covering all filesystem operations, classmethods, properties, and dunder methods)."
    - "pathlib.PurePath.__dict__.__len__() == 61 (almost as large as Path with 61 entries; PurePath covers all path string manipulation methods without touching the filesystem)."
    - "pathlib.PurePosixPath.__dict__.__len__() == 6; pathlib.PureWindowsPath.__dict__.__len__() == 6; pathlib.PosixPath.__dict__.__len__() == 5; pathlib.WindowsPath.__dict__.__len__() == 6 (variant subclasses add very few entries on top of their bases)."
    - "pathlib.Path.__mro__ len == 3 ([Path, PurePath, object]); pathlib.PurePath.__mro__ len == 2 ([PurePath, object])."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.__spec__ and loader identity
# pathlib.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16).
# pathlib.__spec__.__class__.__name__ == 'ModuleSpec' (len=10).
# pathlib.__package__ == 'pathlib' (len=7).
# pathlib.__spec__.parent == 'pathlib' (len=7).
# ---------------------------------------------------------------------------

table pathlib_extra154.spec_and_loader_identity:
  description: "pathlib.__spec__ class identity: __class__.__name__=='ModuleSpec'; __loader__.__class__.__name__=='SourceFileLoader' (16); __package__=='pathlib' (7); __spec__.parent=='pathlib' (7)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibspec154

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_eq,      __spec__.__class__.__name__.__eq__,   ["ModuleSpec"],     true, "pathlib.__spec__.__class__.__name__ == 'ModuleSpec' (same as io, re, and decimal — all module specs are ModuleSpec instances regardless of whether the module is frozen or source-based)"]
    - [loader_cls_eq,    __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"],true, "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16) — pathlib is a Python source file at Lib/pathlib/__init__.py; its loader is a SourceFileLoader instance, unlike io which uses FrozenImporter"]
    - [loader_cls_len,   __loader__.__class__.__name__.__len__, [],                 16,   "pathlib.__loader__.__class__.__name__.__len__() == 16 ('SourceFileLoader' has 16 characters; the same loader class is used for re and decimal)"]
    - [pkg_eq,           __package__.__eq__,                   ["pathlib"],        true, "pathlib.__package__ == 'pathlib' (len=7; pathlib is itself a package — it lives in Lib/pathlib/__init__.py — so __package__ is 'pathlib', not '' like io or decimal)"]
    - [pkg_len,          __package__.__len__,                  [],                 7,    "pathlib.__package__.__len__() == 7 ('pathlib' has 7 characters; the same length as pathlib.__spec__.name)"]
    - [spec_parent_eq,   __spec__.parent.__eq__,               ["pathlib"],        true, "pathlib.__spec__.parent == 'pathlib' (len=7; as a package, pathlib's own spec parent is itself; this differs from io whose __spec__.parent == '' and decimal whose __spec__.parent == '')"]
    - [spec_name_eq,     __spec__.name.__eq__,                  ["pathlib"],       true, "pathlib.__spec__.name == 'pathlib' (the module spec name; len=7)"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ mappingproxy identity and size
# pathlib.Path.__dict__.__len__() == 62 (the largest __dict__ in pathlib).
# pathlib.PurePath.__dict__.__len__() == 61.
# ---------------------------------------------------------------------------

table pathlib_extra154.Path_PurePath_dict_identity:
  description: "pathlib.Path.__dict__ identity: __class__.__name__=='mappingproxy', __len__()==62; pathlib.PurePath.__dict__.__len__()==61"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibspec154

  columns: [id, function, args, expected, description]
  rows:
    - [path_dict_cls_eq,   Path.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true, "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' (Path.__dict__ is a read-only mappingproxy like all class __dict__ attributes)"]
    - [path_dict_len,      Path.__dict__.__len__,                       [],               62,   "pathlib.Path.__dict__.__len__() == 62 (Path defines 62 entries; the largest __dict__ in pathlib; includes stat, exists, is_dir, is_file, open, read_bytes, read_text, write_bytes, write_text, iterdir, glob, rglob, mkdir, rmdir, touch, chmod, unlink, rename, resolve, symlink_to, cwd, home, absolute, and many more)"]
    - [purepath_dict_cls_eq,PurePath.__dict__.__class__.__name__.__eq__,["mappingproxy"], true, "pathlib.PurePath.__dict__.__class__.__name__ == 'mappingproxy' (PurePath.__dict__ is also a mappingproxy)"]
    - [purepath_dict_len,  PurePath.__dict__.__len__,                   [],               61,   "pathlib.PurePath.__dict__.__len__() == 61 (PurePath defines 61 entries; almost as many as Path (62); PurePath covers path string manipulation: joinpath, with_name, with_stem, with_suffix, relative_to, is_relative_to, match, full_match, is_absolute, as_uri, as_posix, and all properties)"]

# ---------------------------------------------------------------------------
# pathlib variant subclass __dict__ sizes
# PurePosixPath.__dict__.__len__() == 6; PureWindowsPath.__dict__.__len__() == 6.
# PosixPath.__dict__.__len__() == 5; WindowsPath.__dict__.__len__() == 6.
# ---------------------------------------------------------------------------

table pathlib_extra154.variant_subclass_dict_sizes:
  description: "pathlib variant subclass __dict__ sizes: PurePosixPath=6, PureWindowsPath=6, PosixPath=5, WindowsPath=6; variant subclasses add very few entries beyond their base"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibspec154

  columns: [id, function, args, expected, description]
  rows:
    - [pureposix_dict_len,    PurePosixPath.__dict__.__len__,  [],  6,  "pathlib.PurePosixPath.__dict__.__len__() == 6 (only 6 entries: __module__, __doc__, __slots__, and a few POSIX-specific overrides; almost all behavior is inherited from PurePath)"]
    - [purewin_dict_len,      PureWindowsPath.__dict__.__len__,[],  6,  "pathlib.PureWindowsPath.__dict__.__len__() == 6 (only 6 entries: same structure as PurePosixPath; Windows-specific path parsing is controlled by the 'parser' class attribute on PurePath)"]
    - [posixpath_dict_len,    PosixPath.__dict__.__len__,      [],  5,  "pathlib.PosixPath.__dict__.__len__() == 5 (the fewest entries among all pathlib classes at 5: __module__, __doc__, __slots__, and a couple of POSIX-specific entries; all filesystem operations are inherited from Path)"]
    - [winpath_dict_len,      WindowsPath.__dict__.__len__,    [],  6,  "pathlib.WindowsPath.__dict__.__len__() == 6 (1 more entry than PosixPath at 6; Windows paths need slightly more OS-specific setup)"]
    - [purepath_mro_len,      "PurePath.__mro__.__len__",      [],  2,  "pathlib.PurePath.__mro__.__len__() == 2 (MRO: [PurePath, object]; PurePath directly subclasses object with no intermediate types — the shortest possible MRO for a non-trivial class)"]
    - [path_mro_len,          "Path.__mro__.__len__",          [],  3,  "pathlib.Path.__mro__.__len__() == 3 (MRO: [Path, PurePath, object]; Path inherits from PurePath, adding filesystem operations; a 3-entry chain)"]
    - [path_base0_eq,         "Path.__bases__[0].__name__.__eq__", ["PurePath"], true, "pathlib.Path.__bases__[0].__name__ == 'PurePath' (Path directly subclasses PurePath; all pure path operations are inherited from PurePath)"]
    - [purepath_base0_eq,     "PurePath.__bases__[0].__name__.__eq__",["object"], true, "pathlib.PurePath.__bases__[0].__name__ == 'object' (PurePath directly subclasses object; no intermediate abstract base class)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra154.loader.class_is_SourceFileLoader:
  description: "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16) — pathlib is a Python source file loaded from Lib/pathlib/__init__.py; its loader is a SourceFileLoader instance; this contrasts with io whose __loader__.__class__.__name__ == 'type' (FrozenImporter is a class, not an instance)"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant pathlib_extra154.spec.parent_eq_pathlib:
  description: "pathlib.__spec__.parent == 'pathlib' (len=7) — pathlib is a package (lives in Lib/pathlib/__init__.py), so its __spec__.parent is 'pathlib' (the package name is its own parent); this differs from io (__spec__.parent == '') and decimal (__spec__.parent == ''), which are not packages"
  category: identity
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra154.package_eq_pathlib:
  description: "pathlib.__package__ == 'pathlib' (len=7) — pathlib is a package, so __package__ equals the module name 'pathlib'; for top-level non-package modules like io and decimal, __package__ is '' (empty string); for package modules, __package__ is the full dotted name of the package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra154.Path.dict_len_62:
  description: "pathlib.Path.__dict__.__len__() == 62 — Path has the most entries (62) among all pathlib classes; it adds all filesystem operations (stat, exists, is_dir, is_file, open, read_bytes, write_bytes, mkdir, rmdir, unlink, rename, resolve, symlink_to, glob, iterdir, cwd, home, absolute, etc.) on top of PurePath's 61 entries"
  category: identity
  kind: python_call_eq
  function: Path.__dict__.__len__
  args: []
  expected: 62

invariant pathlib_extra154.PurePath.dict_len_61:
  description: "pathlib.PurePath.__dict__.__len__() == 61 — PurePath has 61 entries; almost as many as Path (62); PurePath defines all path string operations: joinpath, with_name, with_stem, with_suffix, relative_to, match, is_absolute, as_posix, as_uri, and all properties (drive, root, anchor, parts, parent, parents, name, stem, suffix, suffixes)"
  category: identity
  kind: python_call_eq
  function: PurePath.__dict__.__len__
  args: []
  expected: 61

invariant pathlib_extra154.PurePath.mro_len_2:
  description: "pathlib.PurePath.__mro__.__len__() == 2 (MRO: [PurePath, object]) — PurePath directly subclasses object with no intermediate base classes; this gives it the shortest possible non-trivial MRO at 2 entries; by contrast, io.IOBase has MRO length 3 ([IOBase, _IOBase, object]) due to the C-extension wrapping pattern"
  category: identity
  kind: python_call_eq
  function: "PurePath.__mro__.__len__"
  args: []
  expected: 2

invariant pathlib_extra154.Path.mro_len_3:
  description: "pathlib.Path.__mro__.__len__() == 3 (MRO: [Path, PurePath, object]) — Path has a 3-entry MRO; it inherits from PurePath which inherits from object; this is the same depth as io.IOBase (3) but shorter than io.BytesIO/StringIO/TextIOWrapper (4)"
  category: identity
  kind: python_call_eq
  function: "Path.__mro__.__len__"
  args: []
  expected: 3

invariant pathlib_extra154.PosixPath.dict_len_5:
  description: "pathlib.PosixPath.__dict__.__len__() == 5 — PosixPath has the fewest entries (5) among all pathlib classes; it inherits all filesystem operations from Path and all path manipulation from PurePath; the 5 entries are mostly __module__, __doc__, __slots__, and a couple of POSIX-specific class attributes"
  category: identity
  kind: python_call_eq
  function: PosixPath.__dict__.__len__
  args: []
  expected: 5

