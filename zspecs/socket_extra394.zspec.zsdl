spec: socket_extra394
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.create_server.__name__ == 'create_server', __module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.fromfd.__name__ == 'fromfd', __module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socketpair.__name__ == 'socketpair', __module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getservbyname.__name__ == 'getservbyname', __module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.fromshare is not available on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.create_server, socket.fromfd, and socket.socketpair are pure-Python functions defined in Lib/socket.py (__class__.__name__ == 'function', __module__ == 'socket'). socket.getservbyname is a C builtin_function_or_method from the _socket extension (__module__ == '_socket'). socket.fromshare is Windows-only and absent on macOS."
    - "Note: socket.create_server was added in Python 3.8 (bpo-18643) as a convenience function for creating listening TCP sockets. It is pure Python and lives in Lib/socket.py."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module function identity: __name__ and __module__
#
# Wave 394 theme: socket function identity — pure-Python vs C extension.
#
# The socket module mixes pure-Python functions (defined in Lib/socket.py)
# and C builtin functions (from the _socket extension). This distinction is
# visible in their __module__ attribute: pure-Python functions have
# __module__ == 'socket', while C builtins have __module__ == '_socket'.
#
# socket.create_server (Python 3.8+), socket.fromfd, and socket.socketpair
# are pure-Python wrappers in Lib/socket.py — __module__ == 'socket'.
# socket.getservbyname is a C builtin from _socket — __module__ == '_socket'.
#
# socket.fromshare is Windows-only and not present on macOS/Darwin.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra394.function_names:
  description: "socket function __name__ attributes — create_server, fromfd, socketpair, getservbyname all have __name__ equal to their attribute name in the socket namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketfn394

  columns: [id, function, args, expected]
  rows:
    - [create_server_name,  create_server.__name__.__eq__,  ["create_server"],  true]
    - [fromfd_name,         fromfd.__name__.__eq__,         ["fromfd"],         true]
    - [socketpair_name,     socketpair.__name__.__eq__,     ["socketpair"],     true]
    - [getservbyname_name,  getservbyname.__name__.__eq__,  ["getservbyname"],  true]

# ---------------------------------------------------------------------------
# socket function __module__ attributes: 'socket' vs '_socket'
#
# Pure-Python functions in Lib/socket.py report __module__ == 'socket'.
# C builtin functions from _socket report __module__ == '_socket'.
# This table covers both cases.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra394.function_modules:
  description: "socket function __module__ attributes — create_server/fromfd/socketpair are pure-Python in Lib/socket.py so __module__=='socket'; getservbyname is a C builtin from _socket so __module__=='_socket'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketfm394

  columns: [id, function, args, expected]
  rows:
    - [create_server_module, create_server.__module__.__eq__, ["socket"],  true]
    - [fromfd_module,        fromfd.__module__.__eq__,        ["socket"],  true]
    - [socketpair_module,    socketpair.__module__.__eq__,    ["socket"],  true]
    - [getservbyname_module, getservbyname.__module__.__eq__, ["_socket"], true]
