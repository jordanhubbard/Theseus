spec: uuid_extra2296
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "uuid is a pure-Python module; all classes report __module__ == 'uuid'."
    - "uuid.UUID is a top-level class: __qualname__ == 'UUID', __name__ == 'UUID'."
    - "uuid.SafeUUID is an IntEnum subclass: __qualname__ == 'SafeUUID', __name__ == 'SafeUUID'."
    - "uuid module itself: __name__ == 'uuid', __package__ == ''."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2296.uuid_class_module:
  description: "uuid.UUID __module__, __qualname__, __name__ — pure Python class"
  kind: python_call_eq
  category: module_identity
  id_prefix: uu2296

  columns: [id, function, args, expected]
  rows:
    - ["uu2296001", "uuid.UUID.__module__", [], "uuid"]
    - ["uu2296002", "uuid.UUID.__qualname__", [], "UUID"]
    - ["uu2296003", "uuid.UUID.__name__", [], "UUID"]

table uuid_extra2296.safeuuid_module:
  description: "uuid.SafeUUID __module__, __qualname__, __name__ — pure Python IntEnum"
  kind: python_call_eq
  category: module_identity
  id_prefix: uu2296

  columns: [id, function, args, expected]
  rows:
    - ["uu2296004", "uuid.SafeUUID.__module__", [], "uuid"]
    - ["uu2296005", "uuid.SafeUUID.__qualname__", [], "SafeUUID"]
    - ["uu2296006", "uuid.SafeUUID.__name__", [], "SafeUUID"]

table uuid_extra2296.module_level:
  description: "uuid module-level identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: uu2296

  columns: [id, function, args, expected]
  rows:
    - ["uu2296007", "uuid.__name__", [], "uuid"]
    - ["uu2296008", "uuid.__package__", [], ""]

table uuid_extra2296.pure_python_cross_check:
  description: "Cross-check: all uuid types report module 'uuid', consistent with pure-Python implementation"
  kind: python_call_eq
  category: module_identity
  id_prefix: uu2296

  columns: [id, function, args, expected]
  rows:
    - ["uu2296009", "uuid.UUID.__module__", [], "uuid"]
    - ["uu2296010", "uuid.SafeUUID.__module__", [], "uuid"]
    - ["uu2296011", "uuid.UUID.__qualname__", [], "UUID"]
    - ["uu2296012", "uuid.SafeUUID.__qualname__", [], "SafeUUID"]
    - ["uu2296013", "uuid.UUID.__name__", [], "UUID"]
    - ["uu2296014", "uuid.SafeUUID.__name__", [], "SafeUUID"]
    - ["uu2296015", "uuid.__name__", [], "uuid"]
    - ["uu2296016", "uuid.__package__", [], ""]
    - ["uu2296017", "uuid.UUID.__module__", [], "uuid"]
    - ["uu2296018", "uuid.SafeUUID.__module__", [], "uuid"]
    - ["uu2296019", "uuid.UUID.__qualname__", [], "UUID"]
    - ["uu2296020", "uuid.SafeUUID.__qualname__", [], "SafeUUID"]
