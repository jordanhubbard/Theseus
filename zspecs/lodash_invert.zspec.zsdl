spec: lodash_invert
version: ">=4.0.0"
backend: node(lodash.invert)

docs: https://lodash.com/docs/#invert

provenance:
  derived_from:
    - "lodash.invert README — https://www.npmjs.com/package/lodash.invert"
    - "Test vectors verified with lodash.invert@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.invert exports the _.invert function directly as module.exports."
    - "invert(object) creates an inverted object where keys become values and values become keys."
    - "If multiple keys map to the same value, the last key wins."
    - "All values are converted to strings."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns object with keys and values swapped."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_invert.invert:
  kind: node_module_call_eq
  function: ~
  category: invert
  id_prefix: linv

  columns: [id, args, expected]
  rows:
    - [basic,  [{"a": "b", "c": "d"}],   {"b": "a", "d": "c"}]
    - [nums,   [{"x": 1, "y": 2}],        {"1": "x", "2": "y"}]
    - [one,    [{"k": "v"}],              {"v": "k"}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:29:02Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
