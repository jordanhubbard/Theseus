spec: lodash_invert
version: ">=4.0.0"
backend: node(lodash.invert)

docs: https://lodash.com/docs/#invert

provenance:
  derived_from:
    - "lodash.invert README — https://www.npmjs.com/package/lodash.invert"
    - "Test vectors verified with lodash.invert@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.invert exports the _.invert function directly as module.exports."
    - "invert(object) creates an object with keys and values swapped."
    - "If multiple values map to the same key, later values overwrite earlier ones."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns new object with swapped keys/values. No errors for object inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_invert.invert:
  kind: node_module_call_eq
  function: ~
  category: invert
  id_prefix: linvert

  columns: [id, args, expected]
  rows:
    - [simple,  [{"a": 1, "b": 2, "c": 3}],  {"1": "a", "2": "b", "3": "c"}]
    - [strings, [{"x": "foo", "y": "bar"}],   {"foo": "x", "bar": "y"}]
