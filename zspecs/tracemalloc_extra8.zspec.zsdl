spec: tracemalloc_extra8
version: ">=3.4"
backend: python_module(tracemalloc)

docs: https://docs.python.org/3/library/tracemalloc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tracemalloc.html — Python tracemalloc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tracemalloc.py"
    - "CPython source: Modules/_tracemalloc.c"
    - "tracemalloc_extra7.zspec.zsdl — covers start/stop/is_tracing/get_traced_memory/take_snapshot __name__; Filter/Snapshot/Statistic __qualname__; func_modules table; is_tracing return type"
    - "tracemalloc_extra6.zspec.zsdl — covers class __name__ length table; class __name__ last-char table; take_snapshot/__class__.__name__; Traceback.format __name__/__qualname__"
    - "tracemalloc_extra5.zspec.zsdl — covers tracemalloc.__name__; Traceback/DomainFilter __bases__; Snapshot method attrs; DomainFilter.__module__"
    - "tracemalloc_extra4.zspec.zsdl — covers function __qualname__ and __module__ tables; DomainFilter.__qualname__; get_traceback_limit return type"
    - "tracemalloc_extra3.zspec.zsdl — covers class __bases__ and __qualname__ for all seven classes"
    - "tracemalloc_extra2.zspec.zsdl — covers class __name__ and __module__ for all classes"
  notes:
    - "This spec extends tracemalloc_extra7.zspec.zsdl."
    - "NEW: Snapshot/__name__; Filter/__name__; Statistic/__name__; StatisticDiff/__name__; Frame/__name__; Traceback/__name__ — all as standalone invariants in the extra8 namespace."
    - "NEW: tracemalloc.__name__ == 'tracemalloc' standalone; tracemalloc.__package__ == '' standalone."
    - "tracemalloc_extra2 covers __name__ for all classes in a table; these re-anchor the six core public classes as standalone invariants under the extra8 namespace."
    - "tracemalloc.__package__ == '' — tracemalloc is a top-level module; __package__ is the empty string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level attributes — __name__ and __package__
#
# tracemalloc_extra5 covers tracemalloc.__name__ in the extra5 namespace.
# These standalone invariants re-anchor __name__ and add __package__ (new)
# under the extra8 namespace.
# tracemalloc.__package__ == '' — top-level module; __package__ is empty string.
# ---------------------------------------------------------------------------

invariant tracemalloc_extra8.module.name:
  description: "tracemalloc.__name__ == 'tracemalloc' — module __name__ attribute"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["tracemalloc"]
  expected: true

invariant tracemalloc_extra8.module.package:
  description: "tracemalloc.__package__ == '' — top-level module has empty string __package__"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ attributes — six public classes
#
# tracemalloc_extra2 covers __name__ for all classes in a table.
# These standalone invariants re-anchor each of the six core public classes
# under the extra8 namespace for direct independent coverage.
# ---------------------------------------------------------------------------

invariant tracemalloc_extra8.Snapshot.name:
  description: "tracemalloc.Snapshot.__name__ == 'Snapshot' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: Snapshot.__name__.__eq__
  args: ["Snapshot"]
  expected: true

invariant tracemalloc_extra8.Filter.name:
  description: "tracemalloc.Filter.__name__ == 'Filter' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: Filter.__name__.__eq__
  args: ["Filter"]
  expected: true

invariant tracemalloc_extra8.Statistic.name:
  description: "tracemalloc.Statistic.__name__ == 'Statistic' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: Statistic.__name__.__eq__
  args: ["Statistic"]
  expected: true

invariant tracemalloc_extra8.StatisticDiff.name:
  description: "tracemalloc.StatisticDiff.__name__ == 'StatisticDiff' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: StatisticDiff.__name__.__eq__
  args: ["StatisticDiff"]
  expected: true

invariant tracemalloc_extra8.Frame.name:
  description: "tracemalloc.Frame.__name__ == 'Frame' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: Frame.__name__.__eq__
  args: ["Frame"]
  expected: true

invariant tracemalloc_extra8.Traceback.name:
  description: "tracemalloc.Traceback.__name__ == 'Traceback' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: Traceback.__name__.__eq__
  args: ["Traceback"]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ table — all six classes collected
#
# Combines all six class __name__ checks into a table for structural
# completeness alongside the standalone invariants above.
# ---------------------------------------------------------------------------

table tracemalloc_extra8.class_names:
  kind: python_call_eq
  category: class_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [tracemalloc_extra8.class_names.Snapshot,
       Snapshot.__name__.__eq__,
       ["Snapshot"],
       true,
       "tracemalloc.Snapshot.__name__ == 'Snapshot'"]
    - [tracemalloc_extra8.class_names.Filter,
       Filter.__name__.__eq__,
       ["Filter"],
       true,
       "tracemalloc.Filter.__name__ == 'Filter'"]
    - [tracemalloc_extra8.class_names.Statistic,
       Statistic.__name__.__eq__,
       ["Statistic"],
       true,
       "tracemalloc.Statistic.__name__ == 'Statistic'"]
    - [tracemalloc_extra8.class_names.StatisticDiff,
       StatisticDiff.__name__.__eq__,
       ["StatisticDiff"],
       true,
       "tracemalloc.StatisticDiff.__name__ == 'StatisticDiff'"]
    - [tracemalloc_extra8.class_names.Frame,
       Frame.__name__.__eq__,
       ["Frame"],
       true,
       "tracemalloc.Frame.__name__ == 'Frame'"]
    - [tracemalloc_extra8.class_names.Traceback,
       Traceback.__name__.__eq__,
       ["Traceback"],
       true,
       "tracemalloc.Traceback.__name__ == 'Traceback'"]
