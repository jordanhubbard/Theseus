spec: pathlib_extra198
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec extends pathlib_extra197.zspec.zsdl."
    - "This spec covers pathlib.Path method qualnames: open, read_text, write_text, read_bytes, write_bytes, mkdir, exists, unlink."
    - "pathlib.Path.open.__qualname__ == 'Path.open' (len=9); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (len=14); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.write_text.__qualname__ == 'Path.write_text' (len=15); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes' (len=15); same length as write_text; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes' (len=16, longest in spec); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' (len=10); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.exists.__qualname__ == 'Path.exists' (len=11); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.unlink.__qualname__ == 'Path.unlink' (len=11); same length as exists; confirmed Python 3.14.3 macOS."
    - "Qualname length ordering: open(9) < mkdir(10) < exists(11)==unlink(11) < read_text(14) < write_text(15)==read_bytes(15) < write_bytes(16); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path I/O method __qualname__ equality
# open(9), read_text(14), write_text(15), read_bytes(15), write_bytes(16)
# ---------------------------------------------------------------------------

table pathlib_extra198.path_io_method_qualnames:
  description: "pathlib.Path I/O method __qualname__ values: open='Path.open'(9), read_text='Path.read_text'(14), write_text='Path.write_text'(15), read_bytes='Path.read_bytes'(15), write_bytes='Path.write_bytes'(16, longest)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmethods198

  columns: [id, function, args, expected, description]
  rows:
    - [open_qn_eq,        pathlib.Path.open.__qualname__.__eq__,        ["Path.open"],        true, "pathlib.Path.open.__qualname__ == 'Path.open' (len=9); confirmed Python 3.14.3 macOS"]
    - [read_text_qn_eq,   pathlib.Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true, "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (len=14); confirmed Python 3.14.3 macOS"]
    - [write_text_qn_eq,  pathlib.Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true, "pathlib.Path.write_text.__qualname__ == 'Path.write_text' (len=15); confirmed Python 3.14.3 macOS"]
    - [read_bytes_qn_eq,  pathlib.Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"],  true, "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes' (len=15, same as write_text); confirmed Python 3.14.3 macOS"]
    - [write_bytes_qn_eq, pathlib.Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true, "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes' (len=16, longest in spec); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path filesystem method __qualname__ equality
# mkdir(10), exists(11), unlink(11)
# ---------------------------------------------------------------------------

table pathlib_extra198.path_fs_method_qualnames:
  description: "pathlib.Path filesystem method __qualname__ values: mkdir='Path.mkdir'(10), exists='Path.exists'(11), unlink='Path.unlink'(11)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmethods198

  columns: [id, function, args, expected, description]
  rows:
    - [mkdir_qn_eq,  pathlib.Path.mkdir.__qualname__.__eq__,  ["Path.mkdir"],  true, "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' (len=10); confirmed Python 3.14.3 macOS"]
    - [exists_qn_eq, pathlib.Path.exists.__qualname__.__eq__, ["Path.exists"], true, "pathlib.Path.exists.__qualname__ == 'Path.exists' (len=11); confirmed Python 3.14.3 macOS"]
    - [unlink_qn_eq, pathlib.Path.unlink.__qualname__.__eq__, ["Path.unlink"], true, "pathlib.Path.unlink.__qualname__ == 'Path.unlink' (len=11, same as exists); confirmed Python 3.14.3 macOS"]
    - [mkdir_qn_len,  pathlib.Path.mkdir.__qualname__.__len__,  [], 10, "pathlib.Path.mkdir.__qualname__.__len__() == 10 ('Path.'=5+'mkdir'=5); confirmed Python 3.14.3 macOS"]
    - [exists_qn_len, pathlib.Path.exists.__qualname__.__len__, [], 11, "pathlib.Path.exists.__qualname__.__len__() == 11 ('Path.'=5+'exists'=6); same length as unlink; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.Path method __qualname__ lengths comparison
# open(9) < mkdir(10) < exists(11)==unlink(11) < read_text(14) < write_text(15)==read_bytes(15) < write_bytes(16)
# ---------------------------------------------------------------------------

table pathlib_extra198.path_method_qualname_lengths:
  description: "pathlib.Path method __qualname__ lengths: open=9, mkdir=10, exists=11, unlink=11, read_text=14, write_text=15, read_bytes=15, write_bytes=16; write_bytes is longest"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmethods198

  columns: [id, function, args, expected, description]
  rows:
    - [open_qn_len,        pathlib.Path.open.__qualname__.__len__,        [], 9,  "pathlib.Path.open.__qualname__.__len__() == 9 ('Path.'=5+'open'=4); shortest in spec; confirmed Python 3.14.3 macOS"]
    - [read_text_qn_len,   pathlib.Path.read_text.__qualname__.__len__,   [], 14, "pathlib.Path.read_text.__qualname__.__len__() == 14 ('Path.'=5+'read_text'=9); confirmed Python 3.14.3 macOS"]
    - [write_text_qn_len,  pathlib.Path.write_text.__qualname__.__len__,  [], 15, "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.'=5+'write_text'=10); same as read_bytes; confirmed Python 3.14.3 macOS"]
    - [read_bytes_qn_len,  pathlib.Path.read_bytes.__qualname__.__len__,  [], 15, "pathlib.Path.read_bytes.__qualname__.__len__() == 15 ('Path.'=5+'read_bytes'=10); same as write_text; confirmed Python 3.14.3 macOS"]
    - [write_bytes_qn_len, pathlib.Path.write_bytes.__qualname__.__len__, [], 16, "pathlib.Path.write_bytes.__qualname__.__len__() == 16 ('Path.'=5+'write_bytes'=11); longest in spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra198.path_open_qualname_eq:
  description: "pathlib.Path.open.__qualname__ == 'Path.open' — the qualified name of the open method is 'Path.open' (len=9: 'Path.'=5 + 'open'=4 = 9); this is the shortest qualname in the spec; Path.open opens the file and returns a file object, analogous to the built-in open(); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.open.__qualname__.__eq__
  args: ["Path.open"]
  expected: true

invariant pathlib_extra198.path_read_text_qualname_eq:
  description: "pathlib.Path.read_text.__qualname__ == 'Path.read_text' — the qualified name of the read_text method is 'Path.read_text' (len=14: 'Path.'=5 + 'read_text'=9 = 14); Path.read_text reads the file as a text string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.read_text.__qualname__.__eq__
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra198.path_write_text_qualname_eq:
  description: "pathlib.Path.write_text.__qualname__ == 'Path.write_text' — the qualified name of the write_text method is 'Path.write_text' (len=15: 'Path.'=5 + 'write_text'=10 = 15); Path.write_text writes a text string to the file; same length as read_bytes.__qualname__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.write_text.__qualname__.__eq__
  args: ["Path.write_text"]
  expected: true

invariant pathlib_extra198.path_read_bytes_qualname_eq:
  description: "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes' — the qualified name of the read_bytes method is 'Path.read_bytes' (len=15: 'Path.'=5 + 'read_bytes'=10 = 15); Path.read_bytes reads the file as bytes; same length as write_text.__qualname__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.read_bytes.__qualname__.__eq__
  args: ["Path.read_bytes"]
  expected: true

invariant pathlib_extra198.path_write_bytes_qualname_eq:
  description: "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes' — the qualified name of the write_bytes method is 'Path.write_bytes' (len=16: 'Path.'=5 + 'write_bytes'=11 = 16); this is the longest qualname in the spec; Path.write_bytes writes bytes to the file; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.write_bytes.__qualname__.__eq__
  args: ["Path.write_bytes"]
  expected: true

invariant pathlib_extra198.path_mkdir_qualname_eq:
  description: "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' — the qualified name of the mkdir method is 'Path.mkdir' (len=10: 'Path.'=5 + 'mkdir'=5 = 10); Path.mkdir creates the directory; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.mkdir.__qualname__.__eq__
  args: ["Path.mkdir"]
  expected: true

invariant pathlib_extra198.path_exists_qualname_eq:
  description: "pathlib.Path.exists.__qualname__ == 'Path.exists' — the qualified name of the exists method is 'Path.exists' (len=11: 'Path.'=5 + 'exists'=6 = 11); Path.exists returns True if the path points to an existing file or directory; same length as unlink.__qualname__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.exists.__qualname__.__eq__
  args: ["Path.exists"]
  expected: true

invariant pathlib_extra198.path_unlink_qualname_eq:
  description: "pathlib.Path.unlink.__qualname__ == 'Path.unlink' — the qualified name of the unlink method is 'Path.unlink' (len=11: 'Path.'=5 + 'unlink'=6 = 11); Path.unlink removes the file or symbolic link; same length as exists.__qualname__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.unlink.__qualname__.__eq__
  args: ["Path.unlink"]
  expected: true

