  columns: [id, function, args, expected]
  rows:
    - ["pl2176017", "pathlib.PurePath.__dict__.__contains__",        ["__await__"],        false]
    - ["pl2176018", "pathlib.PurePath.__dict__.__contains__",        ["__length_hint__"],  false]
    - ["pl2176019", "pathlib.PurePath.__dict__.__contains__",        ["__reversed__"],     false]
    - ["pl2176020", "pathlib.PurePath.__dict__.__contains__",        ["__missing__"],      false]
    - ["pl2176021", "pathlib.PurePosixPath.__dict__.__contains__",   ["__await__"],        false]
    - ["pl2176022", "pathlib.PurePosixPath.__dict__.__contains__",   ["__length_hint__"],  false]
