spec: pathlib_extra2176
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2176 (_extra2176): iterator/sequence protocol dict-presence theme — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "pathlib.PurePath, PurePosixPath, PureWindowsPath, and Path do NOT define __iter__ or __next__ in their own __dict__ — path objects are not iterators."
    - "pathlib.Path.iterdir() returns a generator for directory contents, but Path itself is not an iterator and has no __iter__ or __next__ in its __dict__."
    - "No pathlib class defines __aiter__, __anext__, __await__, __length_hint__, __reversed__, or __missing__ in its own __dict__."
    - "pathlib.PurePath defines comparison operators (__eq__, __lt__, __le__, __gt__, __ge__) but not iteration or size-hint protocols."
    - "pathlib.PurePath.__dict__ contains __truediv__ and __rtruediv__ for the / path-joining operator, but no iteration protocol."
  created_at: "2026-04-12"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __iter__ dict-presence across pathlib classes — all absent
#
# Path objects represent filesystem paths; they are not iterators.
# iterdir() produces iteration externally but __iter__ is not in __dict__.
# ---------------------------------------------------------------------------

table pathlib_extra2176.iter_absent:
  description: "pathlib classes __iter__ dict-presence — all false; path objects are not iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2176
  columns: [id, function, args, expected]
  rows:
    - ["pl2176001", "pathlib.PurePath.__dict__.__contains__",        ["__iter__"], false]
    - ["pl2176002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__iter__"], false]
    - ["pl2176003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__iter__"], false]
    - ["pl2176004", "pathlib.Path.__dict__.__contains__",            ["__iter__"], false]

# ---------------------------------------------------------------------------
# Table 2: __next__ dict-presence across pathlib classes — all absent
#
# Path objects do not implement the iterator protocol; __next__ is absent.
# ---------------------------------------------------------------------------

table pathlib_extra2176.next_absent:
  description: "pathlib classes __next__ dict-presence — all false"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2176
  columns: [id, function, args, expected]
  rows:
    - ["pl2176005", "pathlib.PurePath.__dict__.__contains__",        ["__next__"], false]
    - ["pl2176006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__next__"], false]
    - ["pl2176007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__next__"], false]
    - ["pl2176008", "pathlib.Path.__dict__.__contains__",            ["__next__"], false]

# ---------------------------------------------------------------------------
# Table 3: __aiter__ and __anext__ dict-presence — all absent
#
# pathlib has no async iteration support. Async filesystem access requires
# external libraries (e.g. anyio, aiofiles). No pathlib class defines these.
# ---------------------------------------------------------------------------

table pathlib_extra2176.aiter_anext_absent:
  description: "pathlib classes __aiter__ and __anext__ dict-presence — all false; no async iteration support"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2176
  columns: [id, function, args, expected]
  rows:
    - ["pl2176009",  "pathlib.PurePath.__dict__.__contains__",        ["__aiter__"], false]
    - ["pl2176010",  "pathlib.PurePath.__dict__.__contains__",        ["__anext__"], false]
    - ["pl2176011",  "pathlib.PurePosixPath.__dict__.__contains__",   ["__aiter__"], false]
    - ["pl2176012",  "pathlib.PurePosixPath.__dict__.__contains__",   ["__anext__"], false]
    - ["pl2176013",  "pathlib.PureWindowsPath.__dict__.__contains__", ["__aiter__"], false]
    - ["pl2176014",  "pathlib.PureWindowsPath.__dict__.__contains__", ["__anext__"], false]
    - ["pl2176015",  "pathlib.Path.__dict__.__contains__",            ["__aiter__"], false]
    - ["pl2176016",  "pathlib.Path.__dict__.__contains__",            ["__anext__"], false]

# ---------------------------------------------------------------------------
# Table 4: __await__, __length_hint__, __reversed__, __missing__ — all absent
#
# pathlib classes are not awaitable, provide no size hint, do not support
# reverse iteration, and are not dict subclasses requiring __missing__.
# ---------------------------------------------------------------------------

table pathlib_extra2176.await_lengthhint_reversed_missing_absent:
  description: "pathlib classes __await__, __length_hint__, __reversed__, __missing__ dict-presence — all false"
  kind: python_call_eq
  category: dict_contains
