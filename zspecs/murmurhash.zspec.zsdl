spec: murmurhash
version: ">=2.0.1"
backend: node(murmurhash)

docs: https://www.npmjs.com/package/murmurhash

provenance:
  derived_from:
    - "murmurhash README — https://www.npmjs.com/package/murmurhash"
    - "Test vectors verified with murmurhash via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "murmurhash source"
  notes:
    - "murmurhash is an npm package. Install: npm install murmurhash"
    - "v2 and v3 are MurmurHash2 and MurmurHash3 hash functions, returning 32-bit unsigned integers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a 32-bit unsigned integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table murmurhash.v3:
  kind: node_module_call_eq
  function: v3
  category: crypto
  id_prefix: mmh3

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"],       613153351]
    - [world,  ["world"],       4220927227]
    - [seeded, ["hello", 1],    3142237357]

table murmurhash.v2:
  kind: node_module_call_eq
  function: v2
  category: crypto
  id_prefix: mmh2

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"],  3848350155]
    - [world,  ["world"],  3312674086]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:36:37Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
