spec: re_extra51
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra50.zspec.zsdl — covers re.Pattern/__class__.__qualname__.__eq__('type'); re.Match/__class__.__qualname__.__eq__('type'); re.RegexFlag/__class__.__qualname__.__eq__('EnumType'); re.search/compile/sub/fullmatch/findall.__class__.__qualname__.__eq__('function'); re.error/__class__.__qualname__.__eq__('type')."
    - "re_extra49.zspec.zsdl — covers re.Pattern/__class__.__name__.__eq__('type'); re.Match/__class__.__name__.__eq__('type'); re.RegexFlag/__class__.__name__.__eq__('EnumType'); re.search/compile/sub/__class__.__name__.__eq__('function'); re.error/__class__.__name__.__eq__('type')."
    - "re_extra48.zspec.zsdl — covers re.RegexFlag member ._name_ equality and ._name_.__len__() for IGNORECASE/ASCII/MULTILINE/DOTALL/VERBOSE/UNICODE/LOCALE."
    - "re_extra45.zspec.zsdl — covers RegexFlag._value_ for IGNORECASE/ASCII/LOCALE/UNICODE/DEBUG/NOFLAG; re.A and re.I __class__.__name__=='RegexFlag'."
    - "re_extra33.zspec.zsdl — covers IGNORECASE.__class__.__name__.__len__()==9."
    - "re_extra27.zspec.zsdl — covers IGNORECASE.__class__.__qualname__.__eq__('RegexFlag'); IGNORECASE.__class__.__module__.__eq__('re'); MULTILINE.__class__.__qualname__.__eq__('RegexFlag')."
    - "re_extra10.zspec.zsdl — covers LOCALE/__class__.__name__=='RegexFlag'; UNICODE/__class__.__name__=='RegexFlag'."
    - "re_extra8.zspec.zsdl — covers IGNORECASE/__class__.__name__=='RegexFlag'; MULTILINE/__class__.__name__=='RegexFlag'."
    - "re_extra2.zspec.zsdl — covers LOCALE/UNICODE/IGNORECASE/NOFLAG __class__.__name__.__eq__('RegexFlag') in table."
  notes:
    - "This spec extends re_extra50.zspec.zsdl."
    - "Prior specs collectively covered: IGNORECASE/__class__.__qualname__=='RegexFlag' (re_extra27); IGNORECASE/__class__.__module__=='re' (re_extra27); MULTILINE/__class__.__qualname__=='RegexFlag' (re_extra27); LOCALE/UNICODE/IGNORECASE/NOFLAG/__class__.__name__=='RegexFlag' (re_extra2); MULTILINE/__class__.__name__=='RegexFlag' (re_extra8); IGNORECASE/__class__.__name__.__len__()==9 (re_extra33). NOT YET COVERED: DOTALL/__class__.__name__=='RegexFlag' (novel); VERBOSE/__class__.__name__=='RegexFlag' (novel); ASCII/__class__.__name__=='RegexFlag' (the full constant, not the re.A alias; re_extra2 covers IGNORECASE/LOCALE/UNICODE/NOFLAG but not ASCII; re_extra45 covers re.A alias but not ASCII.__class__.__name__; novel); DOTALL/__class__.__qualname__=='RegexFlag' (novel); VERBOSE/__class__.__qualname__=='RegexFlag' (novel); ASCII/__class__.__qualname__=='RegexFlag' (novel); UNICODE/__class__.__qualname__=='RegexFlag' (novel — re_extra27 covers IGNORECASE and MULTILINE only); MULTILINE/__class__.__module__=='re' (novel — re_extra27 covers IGNORECASE.__class__.__module__ only); DOTALL/__class__.__module__=='re' (novel); VERBOSE/__class__.__module__=='re' (novel); ASCII/__class__.__module__=='re' (novel); UNICODE/__class__.__module__=='re' (novel)."
    - "This spec covers: re.DOTALL.__class__.__name__.__eq__('RegexFlag') (NOVEL — no prior re spec checks DOTALL.__class__.__name__; novel); re.VERBOSE.__class__.__name__.__eq__('RegexFlag') (NOVEL — no prior re spec checks VERBOSE.__class__.__name__; novel); re.ASCII.__class__.__name__.__eq__('RegexFlag') (NOVEL — re_extra2 covers LOCALE/UNICODE/IGNORECASE/NOFLAG; re_extra45 covers re.A alias; no prior re spec checks ASCII.__class__.__name__; novel); re.DOTALL.__class__.__qualname__.__eq__('RegexFlag') (NOVEL — re_extra27 covers IGNORECASE and MULTILINE only; no prior re spec checks DOTALL.__class__.__qualname__; novel); re.VERBOSE.__class__.__qualname__.__eq__('RegexFlag') (NOVEL); re.ASCII.__class__.__qualname__.__eq__('RegexFlag') (NOVEL); re.UNICODE.__class__.__qualname__.__eq__('RegexFlag') (NOVEL — re_extra27 anchors IGNORECASE/MULTILINE only; no prior re spec checks UNICODE.__class__.__qualname__; novel); re.MULTILINE.__class__.__module__.__eq__('re') (NOVEL — re_extra27 covers IGNORECASE.__class__.__module__ only; novel); re.DOTALL.__class__.__module__.__eq__('re') (NOVEL); re.VERBOSE.__class__.__module__.__eq__('re') (NOVEL); re.ASCII.__class__.__module__.__eq__('re') (NOVEL); re.UNICODE.__class__.__module__.__eq__('re') (NOVEL)."
    - "re.DOTALL.__class__.__name__ == 'RegexFlag'. DOTALL is a RegexFlag enum member (value 16). Its type is RegexFlag; __class__.__name__ == 'RegexFlag'. No prior re spec checks DOTALL.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.VERBOSE.__class__.__name__ == 'RegexFlag'. VERBOSE is a RegexFlag enum member (value 64). Its type is RegexFlag; __class__.__name__ == 'RegexFlag'. No prior re spec checks VERBOSE.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.ASCII.__class__.__name__ == 'RegexFlag'. ASCII is a RegexFlag enum member (value 256). re_extra2 covers LOCALE/UNICODE/IGNORECASE/NOFLAG but not ASCII directly; re_extra45 covers the re.A alias. No prior re spec checks ASCII.__class__.__name__ directly. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.DOTALL.__class__.__qualname__ == 'RegexFlag'. RegexFlag is a top-level class in the re module, so its __qualname__=='RegexFlag'==__name__. re_extra27 covers IGNORECASE and MULTILINE only. No prior re spec checks DOTALL.__class__.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.UNICODE.__class__.__qualname__ == 'RegexFlag'. UNICODE is a RegexFlag enum member (value 32). re_extra27 covers IGNORECASE/MULTILINE only. No prior re spec checks UNICODE.__class__.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.IGNORECASE.__class__.__module__ == 're'. RegexFlag is defined in the re module so all its members have __class__.__module__ == 're'. re_extra27 covers IGNORECASE.__class__.__module__ only. Novel for MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re RegexFlag member __class__.__name__ — novel flags
#
# Each RegexFlag enum member's type is the RegexFlag class itself. Therefore:
#
#   DOTALL.__class__.__name__  == 'RegexFlag'
#   VERBOSE.__class__.__name__ == 'RegexFlag'
#   ASCII.__class__.__name__   == 'RegexFlag'
#
# Prior specs (re_extra2/re_extra8/re_extra10) cover LOCALE/UNICODE/IGNORECASE/
# NOFLAG/MULTILINE.__class__.__name__. re_extra45 covers re.A and re.I aliases.
# DOTALL, VERBOSE, and ASCII (full constant) are not covered by any prior re spec.
# All three equality anchors are novel in the re_extra51 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra51.flag_class_names_novel:
  description: "re RegexFlag member __class__.__name__.__eq__('RegexFlag') for DOTALL/VERBOSE/ASCII — prior specs cover LOCALE/UNICODE/IGNORECASE/NOFLAG/MULTILINE via __class__.__name__; DOTALL/VERBOSE/ASCII.(full constant) not covered; all three novel equality anchors in re_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constant_identity
  id_prefix: reconst51cn

  columns: [id, function, args, expected]
  rows:
    - [DOTALL_class_name,  DOTALL.__class__.__name__.__eq__,  ["RegexFlag"], true]
    - [VERBOSE_class_name, VERBOSE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [ASCII_class_name,   ASCII.__class__.__name__.__eq__,   ["RegexFlag"], true]

# ---------------------------------------------------------------------------
# re RegexFlag member __class__.__qualname__ — novel flags
#
# RegexFlag is a top-level class in the re module, so its __qualname__ equals
# its __name__: __qualname__=='RegexFlag'. All flag instances share the same
# __class__, so:
#
#   DOTALL.__class__.__qualname__  == 'RegexFlag'
#   VERBOSE.__class__.__qualname__ == 'RegexFlag'
#   ASCII.__class__.__qualname__   == 'RegexFlag'
#   UNICODE.__class__.__qualname__ == 'RegexFlag'
#
# re_extra27 covers IGNORECASE.__class__.__qualname__ and
# MULTILINE.__class__.__qualname__. No prior re spec checks
# __class__.__qualname__ for DOTALL, VERBOSE, ASCII, or UNICODE.
# All four equality anchors are novel in the re_extra51 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra51.flag_class_qualnames:
  description: "re RegexFlag member __class__.__qualname__.__eq__('RegexFlag') for DOTALL/VERBOSE/ASCII/UNICODE — RegexFlag is a top-level class so __qualname__==__name__=='RegexFlag'; re_extra27 covers IGNORECASE/MULTILINE only; no prior re spec checks __class__.__qualname__ for DOTALL/VERBOSE/ASCII/UNICODE; all four novel equality anchors in re_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constant_identity
  id_prefix: reconst51cq

  columns: [id, function, args, expected]
  rows:
    - [DOTALL_class_qualname,  DOTALL.__class__.__qualname__.__eq__,  ["RegexFlag"], true]
    - [VERBOSE_class_qualname, VERBOSE.__class__.__qualname__.__eq__, ["RegexFlag"], true]
    - [ASCII_class_qualname,   ASCII.__class__.__qualname__.__eq__,   ["RegexFlag"], true]
    - [UNICODE_class_qualname, UNICODE.__class__.__qualname__.__eq__, ["RegexFlag"], true]

# ---------------------------------------------------------------------------
# re RegexFlag member __class__.__module__ — novel flags
#
# RegexFlag is defined in the re module, so its __module__ == 're'. All
# RegexFlag instances share the same __class__, so:
#
#   MULTILINE.__class__.__module__ == 're'
#   DOTALL.__class__.__module__    == 're'
#   VERBOSE.__class__.__module__   == 're'
#   ASCII.__class__.__module__     == 're'
#   UNICODE.__class__.__module__   == 're'
#
# re_extra27 covers IGNORECASE.__class__.__module__ only. No prior re spec
# checks __class__.__module__ for MULTILINE, DOTALL, VERBOSE, ASCII, or UNICODE.
# All five equality anchors are novel in the re_extra51 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra51.flag_class_modules:
  description: "re RegexFlag member __class__.__module__.__eq__('re') for MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE — RegexFlag is defined in the re module so all members have __class__.__module__=='re'; re_extra27 covers IGNORECASE only; no prior re spec checks __class__.__module__ for MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE; all five novel equality anchors in re_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constant_identity
  id_prefix: reconst51cm

  columns: [id, function, args, expected]
  rows:
    - [MULTILINE_class_module, MULTILINE.__class__.__module__.__eq__, ["re"], true]
    - [DOTALL_class_module,    DOTALL.__class__.__module__.__eq__,    ["re"], true]
    - [VERBOSE_class_module,   VERBOSE.__class__.__module__.__eq__,   ["re"], true]
    - [ASCII_class_module,     ASCII.__class__.__module__.__eq__,     ["re"], true]
    - [UNICODE_class_module,   UNICODE.__class__.__module__.__eq__,   ["re"], true]
