spec: inspect_extra901
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect module __spec__.__name__, qualnames for isfunction/isclass/ismodule/signature, and Parameter __module__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra901.module_spec_identity:
  description: "inspect module __spec__.__name__ and top-level module identity"
  kind: python_call_eq
  category: module_spec_identity
  id_prefix: ip901ms
  columns: [id, function, args, expected]
  rows:
    - [ip901ms001, inspect.__spec__.__name__.__eq__,                    ["inspect"],                 true]
    - [ip901ms002, inspect.__name__.__eq__,                             ["inspect"],                 true]
    - [ip901ms003, inspect.__package__.__eq__,                          ["inspect"],                 true]
    - [ip901ms004, inspect.__spec__.__class__.__name__.__eq__,          ["ModuleSpec"],              true]
    - [ip901ms005, inspect.__loader__.__class__.__name__.__eq__,        ["SourceFileLoader"],        true]

table inspect_extra901.predicate_qualnames:
  description: "inspect predicate functions __qualname__ identity"
  kind: python_call_eq
  category: predicate_qualnames
  id_prefix: ip901pq
  columns: [id, function, args, expected]
  rows:
    - [ip901pq001, inspect.isfunction.__qualname__.__eq__,              ["isfunction"],              true]
    - [ip901pq002, inspect.isfunction.__module__.__eq__,                ["inspect"],                 true]
    - [ip901pq003, inspect.isclass.__qualname__.__eq__,                 ["isclass"],                 true]
    - [ip901pq004, inspect.isclass.__module__.__eq__,                   ["inspect"],                 true]
    - [ip901pq005, inspect.ismodule.__qualname__.__eq__,                ["ismodule"],                true]
    - [ip901pq006, inspect.ismodule.__module__.__eq__,                  ["inspect"],                 true]
    - [ip901pq007, inspect.signature.__qualname__.__eq__,               ["signature"],               true]
    - [ip901pq008, inspect.signature.__module__.__eq__,                 ["inspect"],                 true]

table inspect_extra901.parameter_class_identity:
  description: "inspect.Parameter class __module__ and identity checks"
  kind: python_call_eq
  category: parameter_class_identity
  id_prefix: ip901pa
  columns: [id, function, args, expected]
  rows:
    - [ip901pa001, inspect.Parameter.__module__.__eq__,                 ["inspect"],                 true]
    - [ip901pa002, inspect.Parameter.__qualname__.__eq__,               ["Parameter"],               true]
    - [ip901pa003, inspect.Parameter.__class__.__name__.__eq__,         ["type"],                    true]
    - [ip901pa004, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__, ["ParameterKind"],   true]
    - [ip901pa005, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,    ["ParameterKind"],   true]
