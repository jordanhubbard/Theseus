spec: os_path_extra4
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
    - "os_path.zspec.zsdl — join, split, splitext, basename, dirname, normpath, abspath, expanduser, isabs, exists, isfile, isdir, getsize, getatime, getmtime, getctime, samefile"
    - "os_path_extra.zspec.zsdl — function __name__ checks for many functions; splitext/basename/dirname vectors; isabs, commonprefix, commonpath"
    - "os_path_extra2.zspec.zsdl — function __name__ checks for realpath, relpath, commonpath; splitdrive; normpath vectors; commonpath/commonprefix vectors"
    - "os_path_extra3.zspec.zsdl — function __module__ for join/split/splitext/basename/dirname/normpath/abspath/expanduser; function __name__ for abspath/expanduser/normcase/samefile/getatime/getmtime/getsize; normcase POSIX identity; splitext/split/basename/dirname for /a/b/c; isabs /tmp; commonprefix ['/a/b','/a/c']; commonpath three-path vector"
  notes:
    - "This spec extends the os_path chain; it does NOT duplicate invariants present in any prior spec."
    - "Focus: module-level string constants (sep, extsep, altsep, curdir, pardir, devnull, defpath) and their class names; __name__ checks for expandvars, lexists, islink, ismount."
    - "os.path.sep == '/' on POSIX; os.path.extsep == '.'; os.path.altsep is None on POSIX; os.path.curdir == '.'; os.path.pardir == '..'."
    - "os.path.devnull == '/dev/null' on POSIX; we test __class__.__name__ == 'str' only (value is platform-dependent)."
    - "os.path.defpath is a colon-separated string on POSIX; we test __class__.__name__ == 'str' (value varies by platform)."
    - "expandvars.__name__ == 'expandvars' — os_path_extra3 checks expandvars.__module__ but not __name__ (os_path_extra checks __name__; double-checking in a fresh table form)."
    - "Actually os_path_extra.zspec.zsdl covers expandvars.__name__ already; we skip __name__ for expandvars and instead add lexists, islink, ismount __name__ (none covered previously)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level string constants — class name checks
# None of the prior os_path specs test the type of sep, extsep, curdir, etc.
# ---------------------------------------------------------------------------

invariant os_path_extra4.sep.class_name:
  description: "os.path.sep.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: sep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_path_extra4.extsep.class_name:
  description: "os.path.extsep.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: extsep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_path_extra4.curdir.class_name:
  description: "os.path.curdir.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: curdir.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_path_extra4.pardir.class_name:
  description: "os.path.pardir.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: pardir.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_path_extra4.devnull.class_name:
  description: "os.path.devnull.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: devnull.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_path_extra4.defpath.class_name:
  description: "os.path.defpath.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: defpath.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level string constants — value checks (POSIX-specific)
# ---------------------------------------------------------------------------

invariant os_path_extra4.sep.posix_value:
  description: "os.path.sep == '/' on POSIX"
  category: constants
  kind: python_call_eq
  function: sep.__eq__
  args: ["/"]
  expected: true

invariant os_path_extra4.extsep.value:
  description: "os.path.extsep == '.'"
  category: constants
  kind: python_call_eq
  function: extsep.__eq__
  args: ["."]
  expected: true

invariant os_path_extra4.curdir.value:
  description: "os.path.curdir == '.'"
  category: constants
  kind: python_call_eq
  function: curdir.__eq__
  args: ["."]
  expected: true

invariant os_path_extra4.pardir.value:
  description: "os.path.pardir == '..'"
  category: constants
  kind: python_call_eq
  function: pardir.__eq__
  args: [".."]
  expected: true

# ---------------------------------------------------------------------------
# __name__ checks for lexists, islink, ismount
# os_path_extra.zspec.zsdl covers join/split/splitext/basename/dirname/
#   normpath/abspath/expanduser/isabs/exists/isfile/isdir/getsize/getatime/
#   getmtime/getctime/samefile.
# os_path_extra2.zspec.zsdl adds realpath, relpath, commonpath.
# os_path_extra3.zspec.zsdl adds abspath, expanduser, normcase, samefile,
#   getatime, getmtime, getsize.
# None of the prior specs cover lexists, islink, or ismount __name__.
# ---------------------------------------------------------------------------

invariant os_path_extra4.lexists.name:
  description: "os.path.lexists.__name__ == 'lexists'"
  category: function_names
  kind: python_call_eq
  function: lexists.__name__.__eq__
  args: ["lexists"]
  expected: true

invariant os_path_extra4.islink.name:
  description: "os.path.islink.__name__ == 'islink'"
  category: function_names
  kind: python_call_eq
  function: islink.__name__.__eq__
  args: ["islink"]
  expected: true

invariant os_path_extra4.ismount.name:
  description: "os.path.ismount.__name__ == 'ismount'"
  category: function_names
  kind: python_call_eq
  function: ismount.__name__.__eq__
  args: ["ismount"]
  expected: true

# ---------------------------------------------------------------------------
# expandvars — __name__ check
# os_path_extra3 checks expandvars.__module__ == 'posixpath'.
# os_path_extra covers many function __name__ checks but not expandvars
# (expandvars appears in the __module__ table in extra3 but __name__ was not
# included there). We add it here.
# ---------------------------------------------------------------------------

invariant os_path_extra4.expandvars.name:
  description: "os.path.expandvars.__name__ == 'expandvars'"
  category: function_names
  kind: python_call_eq
  function: expandvars.__name__.__eq__
  args: ["expandvars"]
  expected: true
