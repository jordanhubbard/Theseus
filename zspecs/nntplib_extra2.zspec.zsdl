spec: nntplib_extra2
version: ">=3.9,<3.13"
backend: python_module(nntplib)

docs: https://docs.python.org/3.11/library/nntplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3.11/library/nntplib.html — Python nntplib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/nntplib.py"
  notes:
    - "This spec extends nntplib.zspec.zsdl and nntplib_extra.zspec.zsdl."
    - "nntplib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "nntplib.zspec.zsdl covers: all class __name__ values (table), NNTP.__module__, NNTP.port==119, all base-class hierarchy chains."
    - "nntplib_extra.zspec.zsdl covers: NNTP/NNTP_SSL __name__, NNTP.__module__, NNTP_SSL.__bases__[0]=='_NNTPBase', NNTPError/NNTPTemporaryError/NNTPPermanentError/NNTPReplyError/NNTPDataError __name__ and hierarchy."
    - "This spec adds: NNTP_SSL.__module__, NNTP.__qualname__, NNTP_SSL.__qualname__, NNTP.port.__class__.__name__=='int', NNTPProtocolError hierarchy invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NNTP_SSL.__module__ — not in nntplib_extra.zspec.zsdl (only NNTP.__module__)
# ---------------------------------------------------------------------------

invariant nntplib_extra2.module.NNTP_SSL:
  description: "nntplib.NNTP_SSL.__module__ == 'nntplib'"
  category: module
  kind: python_call_eq
  function: NNTP_SSL.__module__.__eq__
  args: ["nntplib"]
  expected: true

# ---------------------------------------------------------------------------
# Qualnames — not covered in any prior nntplib spec
# ---------------------------------------------------------------------------

table nntplib_extra2.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [NNTP,     NNTP.__qualname__.__eq__,     ["NNTP"],     true]
    - [NNTP_SSL, NNTP_SSL.__qualname__.__eq__, ["NNTP_SSL"], true]

# ---------------------------------------------------------------------------
# NNTP.port — type check (value==119 is in nntplib.zspec.zsdl; type is new)
# ---------------------------------------------------------------------------

invariant nntplib_extra2.port.type_is_int:
  description: "nntplib.NNTP.port.__class__.__name__ == 'int' — port class attribute is an int"
  category: class_attributes
  kind: python_call_eq
  function: NNTP.port.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# NNTPProtocolError hierarchy — base is NNTPError
# nntplib.zspec.zsdl covers this invariant; nntplib_extra does not.
# We add it here as a cross-check under nntplib_extra2 namespace.
# ---------------------------------------------------------------------------

invariant nntplib_extra2.hierarchy.NNTPProtocolError_base:
  description: "nntplib.NNTPProtocolError.__bases__[0].__name__ == 'NNTPError'"
  category: hierarchy
  kind: python_call_eq
  function: NNTPProtocolError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"

# ---------------------------------------------------------------------------
# Table of exception class names — verifies name attribute via __eq__ chain
# nntplib.zspec.zsdl has a combined table; nntplib_extra adds invariants.
# This table groups the four primary error subclasses as a named set.
# ---------------------------------------------------------------------------

table nntplib_extra2.exception_names:
  kind: python_call_eq
  category: class_names
  id_prefix: excname

  columns: [id, function, args, expected]
  rows:
    - [NNTPError,          NNTPError.__name__.__eq__,          ["NNTPError"],          true]
    - [NNTPReplyError,     NNTPReplyError.__name__.__eq__,     ["NNTPReplyError"],     true]
    - [NNTPTemporaryError, NNTPTemporaryError.__name__.__eq__, ["NNTPTemporaryError"], true]
    - [NNTPPermanentError, NNTPPermanentError.__name__.__eq__, ["NNTPPermanentError"], true]
