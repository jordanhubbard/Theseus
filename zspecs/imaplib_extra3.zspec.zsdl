spec: imaplib_extra3
version: ">=3.9"
backend: python_module(imaplib)

docs: https://docs.python.org/3/library/imaplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/imaplib.html — Python imaplib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/imaplib.py"
  notes:
    - "This spec extends imaplib.zspec.zsdl and prior extras."
    - "imaplib.zspec.zsdl covers: class names (table), IMAP4.__module__, IMAP4.port==143, IMAP4_SSL.port==993, hierarchy chains, method names."
    - "imaplib_extra.zspec.zsdl covers: IMAP4/__name__/__module__, IMAP4_SSL __name__/__bases__[0], nested IMAP4.error/abort/readonly __name__ and hierarchy, method names."
    - "imaplib_extra2.zspec.zsdl covers: IMAP4_stream __name__/__module__/__bases__[0], IMAP4_SSL.__module__, module-level error/abort/readonly __name__, error/abort hierarchy, port type checks."
    - "This spec adds: qualnames for IMAP4, IMAP4_SSL, IMAP4_stream (table); qualnames for nested IMAP4.error/abort/readonly; module-level IMAP4_PORT and IMAP4_SSL_PORT constants."
    - "imaplib.IMAP4_PORT is a module-level alias for 143 (distinct from IMAP4.port class attribute)."
    - "imaplib.IMAP4_SSL_PORT is a module-level alias for 993 (distinct from IMAP4_SSL.port class attribute)."
    - "IMAP4.error.__qualname__ == 'IMAP4.error' — nested class qualname includes enclosing class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Qualnames table — IMAP4, IMAP4_SSL, IMAP4_stream
# None of the prior imaplib specs cover __qualname__ for these classes.
# ---------------------------------------------------------------------------

table imaplib_extra3.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [IMAP4,        IMAP4.__qualname__.__eq__,        ["IMAP4"],        true]
    - [IMAP4_SSL,    IMAP4_SSL.__qualname__.__eq__,    ["IMAP4_SSL"],    true]
    - [IMAP4_stream, IMAP4_stream.__qualname__.__eq__, ["IMAP4_stream"], true]

# ---------------------------------------------------------------------------
# Nested exception class qualnames
# For nested classes, __qualname__ includes the enclosing class name.
# Not covered in any prior imaplib spec.
# ---------------------------------------------------------------------------

invariant imaplib_extra3.IMAP4.error.qualname:
  description: "imaplib.IMAP4.error.__qualname__ == 'IMAP4.error' — nested class qualname"
  category: qualnames
  kind: python_call_eq
  function: IMAP4.error.__qualname__.__eq__
  args: ["IMAP4.error"]
  expected: true

invariant imaplib_extra3.IMAP4.abort.qualname:
  description: "imaplib.IMAP4.abort.__qualname__ == 'IMAP4.abort' — nested class qualname"
  category: qualnames
  kind: python_call_eq
  function: IMAP4.abort.__qualname__.__eq__
  args: ["IMAP4.abort"]
  expected: true

invariant imaplib_extra3.IMAP4.readonly.qualname:
  description: "imaplib.IMAP4.readonly.__qualname__ == 'IMAP4.readonly' — nested class qualname"
  category: qualnames
  kind: python_call_eq
  function: IMAP4.readonly.__qualname__.__eq__
  args: ["IMAP4.readonly"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level port constants — IMAP4_PORT and IMAP4_SSL_PORT
# These are module-level integer constants (aliases for 143 and 993).
# imaplib.zspec covers IMAP4.port and IMAP4_SSL.port (class attributes);
# the module-level IMAP4_PORT / IMAP4_SSL_PORT names are not tested elsewhere.
# ---------------------------------------------------------------------------

invariant imaplib_extra3.IMAP4_PORT.value:
  description: "imaplib.IMAP4_PORT == 143 — module-level constant for the standard IMAP port"
  category: constants
  kind: python_call_eq
  function: IMAP4_PORT.__eq__
  args: [143]
  expected: true

invariant imaplib_extra3.IMAP4_SSL_PORT.value:
  description: "imaplib.IMAP4_SSL_PORT == 993 — module-level constant for the standard IMAPS port"
  category: constants
  kind: python_call_eq
  function: IMAP4_SSL_PORT.__eq__
  args: [993]
  expected: true

# ---------------------------------------------------------------------------
# Module-level port constants — type checks
# IMAP4_PORT and IMAP4_SSL_PORT are plain ints.
# ---------------------------------------------------------------------------

table imaplib_extra3.port_constant_types:
  kind: python_call_eq
  category: constants
  id_prefix: porttype

  columns: [id, function, args, expected]
  rows:
    - [IMAP4_PORT,     IMAP4_PORT.__class__.__name__.__eq__,     ["int"], true]
    - [IMAP4_SSL_PORT, IMAP4_SSL_PORT.__class__.__name__.__eq__, ["int"], true]
