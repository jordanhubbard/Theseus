spec: struct_extra435
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module function identity and error class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct built-in functions (pack, unpack, etc.) are implemented in _struct C extension"
    - "struct.error inherits from Exception; struct.Struct is a C-level type in _struct"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra435.function_identity:
  description: "Identity attributes of struct module functions and error class"
  kind: python_call_eq
  category: identity
  id_prefix: stex

  columns: [id, function, args, expected]
  rows:
    - [stex001, struct.pack.__name__.__eq__,                          ["pack"],        true]
    - [stex002, struct.unpack.__name__.__eq__,                        ["unpack"],      true]
    - [stex003, struct.calcsize.__name__.__eq__,                      ["calcsize"],    true]
    - [stex004, struct.pack_into.__name__.__eq__,                     ["pack_into"],   true]
    - [stex005, struct.unpack_from.__name__.__eq__,                   ["unpack_from"], true]
    - [stex006, struct.iter_unpack.__name__.__eq__,                   ["iter_unpack"], true]
    - [stex007, struct.error.__name__.__eq__,                         ["error"],       true]
    - [stex008, struct.error.__module__.__eq__,                       ["struct"],      true]
    - [stex009, "struct.error.__bases__[0].__name__.__eq__",          ["Exception"],   true]
    - [stex010, struct.Struct.__name__.__eq__,                        ["Struct"],      true]
    - [stex011, struct.Struct.__module__.__eq__,                      ["_struct"],     true]
