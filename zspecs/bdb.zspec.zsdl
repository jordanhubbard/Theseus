# ---------------------------------------------------------------------------
# Breakpoint class attribute — next is a class-level integer counter
# ---------------------------------------------------------------------------

invariant bdb.breakpoint.next_is_int:
  description: "bdb.Breakpoint.next.__class__.__name__ == 'int' — class-level BP counter"
  category: breakpoint_attrs
  kind: python_call_eq
  function: Breakpoint.next.__class__.__name__.__eq__
  args: ["int"]
  expected: true
