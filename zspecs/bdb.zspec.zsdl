spec: bdb
version: ">=3.0"
backend: python_module(bdb)

docs: https://docs.python.org/3/library/bdb.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/bdb.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "bdb source: Lib/bdb.py (PSF; source inspection permitted)"
  not_derived_from:
    - "bdb source: internal trace dispatch implementation details"
  notes:
    - "bdb.Bdb is the base debugger class; subclasses override user_* hooks to implement behavior."
    - "bdb.Breakpoint is a class representing a single breakpoint; next is a class-level counter (int) for BP numbers."
    - "bdb.BdbQuit is the exception raised when the debugger is asked to quit; it inherits from Exception."
    - "Bdb.set_trace() starts tracing at the calling frame."
    - "Bdb.set_break() sets a breakpoint at a given filename/line; returns None on success or an error string."
    - "Bdb.clear_break() removes a breakpoint; Bdb.clear_all_breaks() removes all breakpoints."
    - "Bdb.get_breaks() returns a list of line numbers with breakpoints in a given filename."
    - "Bdb.run(), runcall(), and runeval() execute code under debugger control."
    - "Bdb.set_continue() sets the debugger to run until the next breakpoint; set_quit() terminates tracing."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant bdb.names.Bdb:
  description: "bdb.Bdb.__name__ == 'Bdb'"
  category: names
  kind: python_call_eq
  function: Bdb.__name__.__eq__
  args: ["Bdb"]
  expected: true

invariant bdb.names.Breakpoint:
  description: "bdb.Breakpoint.__name__ == 'Breakpoint'"
  category: names
  kind: python_call_eq
  function: Breakpoint.__name__.__eq__
  args: ["Breakpoint"]
  expected: true

invariant bdb.names.BdbQuit:
  description: "bdb.BdbQuit.__name__ == 'BdbQuit'"
  category: names
  kind: python_call_eq
  function: BdbQuit.__name__.__eq__
  args: ["BdbQuit"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership
# ---------------------------------------------------------------------------

invariant bdb.modules.Bdb_module:
  description: "bdb.Bdb.__module__ == 'bdb'"
  category: modules
  kind: python_call_eq
  function: Bdb.__module__.__eq__
  args: ["bdb"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance hierarchy
# ---------------------------------------------------------------------------

invariant bdb.hierarchy.BdbQuit_base:
  description: "bdb.BdbQuit.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: BdbQuit.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

