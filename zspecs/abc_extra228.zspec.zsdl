spec: abc_extra228
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABC.__mro__ has length 2: [ABC, object]; verified with Python 3.14.3."
    - "abc.ABC.__mro__[0].__name__ == 'ABC' — the class itself is first in its own MRO; verified with Python 3.14.3."
    - "abc.ABC.__mro__[1].__name__ == 'object' — ABC directly inherits from object; verified with Python 3.14.3."
    - "abc.ABCMeta.__mro__ has length 3: [ABCMeta, type, object]; verified with Python 3.14.3."
    - "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' — the metaclass itself is first; verified with Python 3.14.3."
    - "abc.ABCMeta.__mro__[1].__name__ == 'type' — ABCMeta inherits from type (the root metaclass); verified with Python 3.14.3."
    - "abc.ABCMeta.__mro__[2].__name__ == 'object' — object is the root of the MRO for all classes; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__mro__ length and chain contracts — extra228 namespace
#
# abc.ABC has a 2-element MRO: [ABC, object].
# ABC directly inherits from object with no intermediate abstract base.
# ---------------------------------------------------------------------------

invariant abc_extra228.abc_mro_len_2:
  description: "abc.ABC.__mro__.__len__() == 2 — ABC MRO has exactly two entries"
  category: abc_mro
  kind: python_call_eq
  function: ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra228.abc_mro_0_is_abc:
  description: "abc.ABC.__mro__[0].__name__ == 'ABC' — the class itself is first in its MRO"
  category: abc_mro
  kind: python_call_eq
  function: ABC.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "ABC"

invariant abc_extra228.abc_mro_1_is_object:
  description: "abc.ABC.__mro__[1].__name__ == 'object' — ABC directly inherits from object"
  category: abc_mro
  kind: python_call_eq
  function: ABC.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# abc.ABCMeta.__mro__ length and chain contracts — extra228 namespace
#
# abc.ABCMeta has a 3-element MRO: [ABCMeta, type, object].
# ABCMeta inherits from type (the root metaclass), which inherits from object.
# ---------------------------------------------------------------------------

invariant abc_extra228.abcmeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta MRO has exactly three entries"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra228.abcmeta_mro_0_is_abcmeta:
  description: "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' — the metaclass itself is first in its MRO"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "ABCMeta"

invariant abc_extra228.abcmeta_mro_1_is_type:
  description: "abc.ABCMeta.__mro__[1].__name__ == 'type' — ABCMeta inherits from type"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "type"

invariant abc_extra228.abcmeta_mro_2_is_object:
  description: "abc.ABCMeta.__mro__[2].__name__ == 'object' — object is the root of ABCMeta MRO"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# abc.ABC and abc.ABCMeta MRO length comparison contracts — extra228 namespace
#
# ABCMeta MRO is one element longer than ABC MRO (3 vs 2).
# Both MRO chains terminate in 'object'.
# ---------------------------------------------------------------------------

table abc_extra228.mro_len_comparison:
  description: "abc.ABC and abc.ABCMeta MRO length comparison contracts in abc228mro namespace"
  kind: python_call_eq
  category: abc_mro
  id_prefix: abc228mro

  columns: [id, function, args, expected, description]
  rows:
    - [abc_mro_len_eq_2,     ABC.__mro__.__len__,     [],  2,  "abc.ABC.__mro__.__len__() == 2; verified with Python 3.14.3"]
    - [abcmeta_mro_len_eq_3, ABCMeta.__mro__.__len__,  [],  3,  "abc.ABCMeta.__mro__.__len__() == 3; verified with Python 3.14.3"]
