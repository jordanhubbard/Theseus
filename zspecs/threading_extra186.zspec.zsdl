spec: threading_extra186
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading module-level constant and exception identity — threading.ThreadError.__name__=='RuntimeError' (ThreadError is an alias for RuntimeError; __module__=='builtins'); threading.ThreadError.__bases__[0].__name__=='Exception'; threading.ExceptHookArgs.__name__=='_ExceptHookArgs' (__module__=='_thread', len=15); threading.TIMEOUT_MAX.__class__.__name__=='float'; threading.settrace.__name__=='settrace' (len=8); threading.setprofile.__name__=='setprofile' (len=10); threading.stack_size.__name__=='stack_size' (len=10)."
    - "threading.ThreadError.__name__ == 'RuntimeError' — IMPORTANT: threading.ThreadError is an alias for the built-in RuntimeError (threading.ThreadError is RuntimeError evaluates True); its __name__ is 'RuntimeError' (not 'ThreadError'), and __module__ is 'builtins'. Verified with Python 3.14.3."
    - "threading.ThreadError.__module__ == 'builtins' — because ThreadError is RuntimeError, its __module__ is 'builtins', not 'threading' or '_thread'. Verified with Python 3.14.3."
    - "threading.ThreadError.__bases__[0].__name__ == 'Exception' — RuntimeError inherits from Exception; __bases__[0].__name__ is 'Exception'. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — ExceptHookArgs is actually the named tuple type '_ExceptHookArgs' defined in the _thread C extension; __name__ is '_ExceptHookArgs' (15 chars) and __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is the maximum timeout value for blocking calls as a float (sys.maxsize on CPython); type(TIMEOUT_MAX).__name__ is 'float'. Verified with Python 3.14.3."
    - "threading.settrace.__name__ == 'settrace' — settrace sets a trace function for all threads started from the threading module; its __name__ is 'settrace' (8 chars) and __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.setprofile.__name__ == 'setprofile' — setprofile sets a profile function for all threads started from the threading module; its __name__ is 'setprofile' (10 chars). Verified with Python 3.14.3."
    - "threading.stack_size.__name__ == 'stack_size' — stack_size returns/sets the thread stack size; it is a C builtin from _thread with __name__ 'stack_size' (10 chars) and __module__ '_thread'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.ThreadError identity (alias for RuntimeError)
#
# threading.ThreadError.__name__ == 'RuntimeError'
# threading.ThreadError.__module__ == 'builtins'
# threading.ThreadError.__bases__[0].__name__ == 'Exception'
#
# CAUTION: threading.ThreadError is an alias for the built-in RuntimeError;
# "threading.ThreadError is RuntimeError" evaluates to True. As a result,
# its __name__ is 'RuntimeError' (not 'ThreadError'), its __module__ is
# 'builtins' (not 'threading'), and its first base is Exception. New to
# extra186.
# ---------------------------------------------------------------------------

table threading_extra186.thread_error_identity:
  description: "threading.ThreadError is RuntimeError alias: __name__=='RuntimeError'; __module__=='builtins'; __bases__[0].__name__=='Exception'; new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: threadingconsts186

  columns: [id, function, args, expected, description]
  rows:
    - [thread_error_name_eq,
       ThreadError.__name__.__eq__,
       ["RuntimeError"],
       true,
       "threading.ThreadError.__name__.__eq__('RuntimeError') == True — ThreadError is an alias for the built-in RuntimeError; its __name__ is 'RuntimeError' (not 'ThreadError'); str.__eq__('RuntimeError') returns True; new to extra186"]
    - [thread_error_module_eq,
       ThreadError.__module__.__eq__,
       ["builtins"],
       true,
       "threading.ThreadError.__module__.__eq__('builtins') == True — because ThreadError is RuntimeError, its __module__ is 'builtins', not 'threading' or '_thread'; str.__eq__('builtins') returns True; new to extra186"]
    - ["thread_error_bases0_name_eq",
       "ThreadError.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "threading.ThreadError.__bases__[0].__name__.__eq__('Exception') == True — RuntimeError inherits from Exception; __bases__[0].__name__ is 'Exception'; str.__eq__('Exception') returns True; new to extra186"]
    - [thread_error_name_len_12,
       ThreadError.__name__.__len__,
       [],
       12,
       "threading.ThreadError.__name__.__len__() == 12 — the actual __name__ is 'RuntimeError' which has exactly 12 characters: R-u-n-t-i-m-e-E-r-r-o-r; str.__len__() returns 12; new to extra186"]

# ---------------------------------------------------------------------------
# Table 2: threading.ExceptHookArgs identity and threading.TIMEOUT_MAX type
#
# threading.ExceptHookArgs.__name__ == '_ExceptHookArgs'
# threading.ExceptHookArgs.__name__.__len__() == 15
# threading.ExceptHookArgs.__module__ == '_thread'
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
#
# ExceptHookArgs is the named tuple type used for threading.excepthook; its
# actual __name__ is '_ExceptHookArgs' (15 chars, with leading underscore)
# and __module__ is '_thread' (the C extension). TIMEOUT_MAX is the maximum
# timeout value as a float constant. New to extra186.
# ---------------------------------------------------------------------------

table threading_extra186.except_hook_args_and_timeout_max:
  description: "threading.ExceptHookArgs.__name__=='_ExceptHookArgs' len 15; __module__=='_thread'; TIMEOUT_MAX.__class__.__name__=='float'; new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: threadingconsts186

  columns: [id, function, args, expected, description]
  rows:
    - [except_hook_args_name_eq,
       ExceptHookArgs.__name__.__eq__,
       ["_ExceptHookArgs"],
       true,
       "threading.ExceptHookArgs.__name__.__eq__('_ExceptHookArgs') == True — ExceptHookArgs is the named tuple type for threading.excepthook; its actual __name__ is '_ExceptHookArgs' (15 chars, leading underscore) from the _thread C extension; str.__eq__('_ExceptHookArgs') returns True; new to extra186"]
    - [except_hook_args_name_len_15,
       ExceptHookArgs.__name__.__len__,
       [],
       15,
       "threading.ExceptHookArgs.__name__.__len__() == 15 — '_ExceptHookArgs' has exactly 15 characters including the leading underscore; str.__len__() returns 15; new to extra186"]
    - [except_hook_args_module_eq,
       ExceptHookArgs.__module__.__eq__,
       ["_thread"],
       true,
       "threading.ExceptHookArgs.__module__.__eq__('_thread') == True — _ExceptHookArgs is defined in the _thread C extension, not in Lib/threading.py; its __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra186"]
    - [timeout_max_class_eq,
       TIMEOUT_MAX.__class__.__name__.__eq__,
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is the maximum timeout value for blocking calls (sys.maxsize on CPython), stored as a float constant; type(TIMEOUT_MAX).__name__ is 'float'; str.__eq__('float') returns True; new to extra186"]

# ---------------------------------------------------------------------------
# Table 3: threading.settrace, threading.setprofile, threading.stack_size
#          identity
#
# threading.settrace.__name__ == 'settrace'
# threading.settrace.__name__.__len__() == 8
# threading.setprofile.__name__ == 'setprofile'
# threading.stack_size.__name__ == 'stack_size'
#
# settrace and setprofile are pure-Python functions in Lib/threading.py that
# install trace/profile hooks for all subsequently started threads. stack_size
# is a C builtin from _thread that returns or sets the thread stack size in
# bytes. New to extra186.
# ---------------------------------------------------------------------------

table threading_extra186.settrace_setprofile_stack_size_identity:
  description: "threading.settrace.__name__=='settrace' len 8; threading.setprofile.__name__=='setprofile' len 10; threading.stack_size.__name__=='stack_size' len 10; new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: threadingconsts186

  columns: [id, function, args, expected, description]
  rows:
    - [settrace_name_eq,
       settrace.__name__.__eq__,
       ["settrace"],
       true,
       "threading.settrace.__name__.__eq__('settrace') == True — settrace installs a trace hook for all threads subsequently started from the threading module; its __name__ is 'settrace' (8 chars); str.__eq__('settrace') returns True; new to extra186"]
    - [settrace_name_len_8,
       settrace.__name__.__len__,
       [],
       8,
       "threading.settrace.__name__.__len__() == 8 — the name 'settrace' has exactly 8 characters: s-e-t-t-r-a-c-e; str.__len__() returns 8; new to extra186"]
    - [setprofile_name_eq,
       setprofile.__name__.__eq__,
       ["setprofile"],
       true,
       "threading.setprofile.__name__.__eq__('setprofile') == True — setprofile installs a profile hook for all threads subsequently started from the threading module; its __name__ is 'setprofile' (10 chars); str.__eq__('setprofile') returns True; new to extra186"]
    - [stack_size_name_eq,
       stack_size.__name__.__eq__,
       ["stack_size"],
       true,
       "threading.stack_size.__name__.__eq__('stack_size') == True — stack_size is a C builtin from _thread that returns or sets the thread stack size in bytes; its __name__ is 'stack_size' (10 chars); str.__eq__('stack_size') returns True; new to extra186"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra186
# ---------------------------------------------------------------------------

invariant threading_extra186.thread_error_name_is_runtime_error:
  description: "threading.ThreadError.__name__ == 'RuntimeError' — ThreadError is an alias for the built-in RuntimeError (threading.ThreadError is RuntimeError is True); its __name__ is 'RuntimeError', not 'ThreadError'; new to extra186"
  category: identity
  kind: python_call_eq
  function: ThreadError.__name__.__eq__
  args: ["RuntimeError"]
  expected: true

invariant threading_extra186.thread_error_module_is_builtins:
  description: "threading.ThreadError.__module__ == 'builtins' — ThreadError is RuntimeError whose __module__ is 'builtins', not 'threading' or '_thread'; new to extra186"
  category: identity
  kind: python_call_eq
  function: ThreadError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant threading_extra186.thread_error_base_is_exception:
  description: "threading.ThreadError.__bases__[0].__name__ == 'Exception' — RuntimeError (aliased as ThreadError) inherits directly from Exception; __bases__[0].__name__ is 'Exception'; new to extra186"
  category: identity
  kind: python_call_eq
  function: "ThreadError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant threading_extra186.except_hook_args_name_is_private:
  description: "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — the named tuple type for threading.excepthook has actual __name__ '_ExceptHookArgs' (15 chars, leading underscore) from the _thread C extension; new to extra186"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__name__.__eq__
  args: ["_ExceptHookArgs"]
  expected: true

invariant threading_extra186.except_hook_args_module_is_thread_c:
  description: "threading.ExceptHookArgs.__module__ == '_thread' — _ExceptHookArgs is defined in the _thread C extension; its __module__ is '_thread', not 'threading'; new to extra186"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra186.timeout_max_class_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is the maximum blocking timeout value (sys.maxsize on CPython), stored as a Python float; type(TIMEOUT_MAX).__name__ is 'float'; new to extra186"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra186.settrace_name_is_settrace:
  description: "threading.settrace.__name__ == 'settrace' — installs a trace hook for all threads subsequently started from the threading module; __name__ is 'settrace' (8 chars); new to extra186"
  category: identity
  kind: python_call_eq
  function: settrace.__name__.__eq__
  args: ["settrace"]
  expected: true

invariant threading_extra186.setprofile_name_is_setprofile:
  description: "threading.setprofile.__name__ == 'setprofile' — installs a profile hook for all threads subsequently started from the threading module; __name__ is 'setprofile' (10 chars); new to extra186"
  category: identity
  kind: python_call_eq
  function: setprofile.__name__.__eq__
  args: ["setprofile"]
  expected: true

invariant threading_extra186.stack_size_name_is_stack_size:
  description: "threading.stack_size.__name__ == 'stack_size' — C builtin from _thread that returns or sets the thread stack size in bytes; __name__ is 'stack_size' (10 chars); new to extra186"
  category: identity
  kind: python_call_eq
  function: stack_size.__name__.__eq__
  args: ["stack_size"]
  expected: true
