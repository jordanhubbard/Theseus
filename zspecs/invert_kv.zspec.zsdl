spec: invert_kv
version: ">=4.2.0"
backend: node(invert-kv)

docs: https://www.npmjs.com/package/invert-kv

provenance:
  derived_from:
    - "invert-kv README — https://www.npmjs.com/package/invert-kv"
    - "Test vectors verified with invert-kv via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "invert-kv source"
  notes:
    - "invert-kv is an npm package. Install: npm install invert-kv"
    - "Returns a new object with keys and values swapped."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table invert_kv.invert:
  kind: node_module_call_eq
  function: "default"
  category: objects
  id_prefix: invkv

  columns: [id, args, expected]
  rows:
    - [simple, [{"a": "x", "b": "y"}],      {"x": "a", "y": "b"}]
    - [two,    [{"foo": "bar", "baz": "qux"}], {"bar": "foo", "qux": "baz"}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:20:13Z
  iterations: 2
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 2 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
