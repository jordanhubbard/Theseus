spec: inspect_extra265
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect module __name__, __package__, __spec__ identity; inspect.Attribute namedtuple identity; inspect.ArgInfo namedtuple identity."
    - "inspect.__name__ == 'inspect' — the module's own name attribute. Verified with Python 3.14.3."
    - "inspect.__package__ == '' — inspect is a top-level Python module (Lib/inspect.py); its __package__ is the empty string. Verified with Python 3.14.3."
    - "inspect.__spec__.__class__.__name__ == 'ModuleSpec' — inspect.__spec__ is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "inspect.__spec__.name == 'inspect' — the spec's name matches the module name. Verified with Python 3.14.3."
    - "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect is loaded from Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Attribute.__name__ == 'Attribute' — Attribute is a namedtuple defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Attribute.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Attribute.__bases__[0].__name__ == 'tuple' — Attribute inherits from tuple (namedtuple base). Verified with Python 3.14.3."
    - "inspect.Attribute._fields == ('name', 'kind', 'defining_class', 'object') — 4 fields. Verified with Python 3.14.3."
    - "len(inspect.Attribute._fields) == 4. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__name__ == 'ArgInfo' — ArgInfo is a namedtuple defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.ArgInfo._fields == ('args', 'varargs', 'keywords', 'locals') — 4 fields. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect module __name__, __package__, __spec__ identity
#
# inspect.__name__ == 'inspect'
# inspect.__package__ == ''
# inspect.__spec__.__class__.__name__ == 'ModuleSpec'
# inspect.__spec__.name == 'inspect'
# inspect.__loader__.__class__.__name__ == 'SourceFileLoader'
#
# inspect is a top-level Python module in Lib/inspect.py loaded by
# SourceFileLoader. Its __package__ is '' (empty string). New to extra265.
# ---------------------------------------------------------------------------

table inspect_extra265.module_identity:
  description: "inspect module __name__, __package__, __spec__, __loader__ identity; new to extra265"
  kind: python_call_eq
  category: identity
  id_prefix: inspmod265

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,
       "__name__.__eq__",
       ["inspect"],
       true,
       "inspect.__name__.__eq__('inspect') == True — the inspect module's __name__ attribute is the string 'inspect'; str.__eq__('inspect') returns True; new to extra265"]
    - [mod_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "inspect.__package__.__eq__('') == True — inspect is a top-level Python module in Lib/inspect.py; its __package__ is the empty string ''; str.__eq__('') returns True; new to extra265"]
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — inspect.__spec__ is an importlib.machinery.ModuleSpec instance; str.__eq__('ModuleSpec') returns True; new to extra265"]
    - [spec_name_eq,
       "__spec__.name.__eq__",
       ["inspect"],
       true,
       "inspect.__spec__.name.__eq__('inspect') == True — the ModuleSpec's name field matches the module __name__; str.__eq__('inspect') returns True; new to extra265"]
    - [loader_class_source_file_loader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — inspect is a pure Python module loaded from Lib/inspect.py by importlib._bootstrap_external.SourceFileLoader; str.__eq__('SourceFileLoader') returns True; new to extra265"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Attribute namedtuple identity
#
# inspect.Attribute.__name__ == 'Attribute'
# inspect.Attribute.__module__ == 'inspect'
# inspect.Attribute.__bases__[0].__name__ == 'tuple'
# len(inspect.Attribute._fields) == 4
# inspect.Attribute.__name__.__len__() == 9
#
# Attribute is a namedtuple with fields (name, kind, defining_class, object).
# Its first base class is tuple (namedtuples inherit from tuple). New to extra265.
# ---------------------------------------------------------------------------

table inspect_extra265.attribute_namedtuple_identity:
  description: "inspect.Attribute namedtuple __name__, __module__, __bases__, _fields len; new to extra265"
  kind: python_call_eq
  category: identity
  id_prefix: inspattr265

  columns: [id, function, args, expected, description]
  rows:
    - [attribute_name_eq,
       Attribute.__name__.__eq__,
       ["Attribute"],
       true,
       "inspect.Attribute.__name__.__eq__('Attribute') == True — Attribute is a namedtuple defined in Lib/inspect.py representing an attribute found by getmembers_static; its __name__ is 'Attribute'; str.__eq__('Attribute') returns True; new to extra265"]
    - [attribute_module_eq,
       Attribute.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Attribute.__module__.__eq__('inspect') == True — Attribute is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra265"]
    - [attribute_base_name_tuple,
       Attribute.__bases__.__getitem__(0).__name__.__eq__,
       ["tuple"],
       true,
       "inspect.Attribute.__bases__[0].__name__.__eq__('tuple') == True — Attribute is a namedtuple; namedtuples inherit from tuple; its first base class __name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra265"]
    - [attribute_fields_len_4,
       Attribute._fields.__len__,
       [],
       4,
       "inspect.Attribute._fields.__len__() == 4 — Attribute is a namedtuple with 4 fields: ('name', 'kind', 'defining_class', 'object'); tuple.__len__() returns 4; new to extra265"]
    - [attribute_name_len_9,
       Attribute.__name__.__len__,
       [],
       9,
       "inspect.Attribute.__name__.__len__() == 9 — the name 'Attribute' has exactly 9 characters: A-t-t-r-i-b-u-t-e; str.__len__() returns 9; new to extra265"]

# ---------------------------------------------------------------------------
# Table 3: inspect.ArgInfo namedtuple identity
#
# inspect.ArgInfo.__name__ == 'ArgInfo'
# inspect.ArgInfo.__module__ == 'inspect'
# inspect.ArgInfo.__bases__[0].__name__ == 'tuple'
# len(inspect.ArgInfo._fields) == 4
# inspect.ArgInfo.__name__.__len__() == 7
#
# ArgInfo is a namedtuple with fields (args, varargs, keywords, locals).
# New to extra265.
# ---------------------------------------------------------------------------

table inspect_extra265.arginfo_namedtuple_identity:
  description: "inspect.ArgInfo namedtuple __name__, __module__, __bases__, _fields len; new to extra265"
  kind: python_call_eq
  category: identity
  id_prefix: inspai265

  columns: [id, function, args, expected, description]
  rows:
    - [arginfo_name_eq,
       ArgInfo.__name__.__eq__,
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__name__.__eq__('ArgInfo') == True — ArgInfo is a namedtuple defined in Lib/inspect.py representing the results of getargvalues(); its __name__ is 'ArgInfo'; str.__eq__('ArgInfo') returns True; new to extra265"]
    - [arginfo_module_eq,
       ArgInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ArgInfo.__module__.__eq__('inspect') == True — ArgInfo is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra265"]
    - [arginfo_base_name_tuple,
       ArgInfo.__bases__.__getitem__(0).__name__.__eq__,
       ["tuple"],
       true,
       "inspect.ArgInfo.__bases__[0].__name__.__eq__('tuple') == True — ArgInfo is a namedtuple; namedtuples inherit from tuple; its first base class __name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra265"]
    - [arginfo_fields_len_4,
       ArgInfo._fields.__len__,
       [],
       4,
       "inspect.ArgInfo._fields.__len__() == 4 — ArgInfo is a namedtuple with 4 fields: ('args', 'varargs', 'keywords', 'locals'); tuple.__len__() returns 4; new to extra265"]
    - [arginfo_name_len_7,
       ArgInfo.__name__.__len__,
       [],
       7,
       "inspect.ArgInfo.__name__.__len__() == 7 — the name 'ArgInfo' has exactly 7 characters: A-r-g-I-n-f-o; str.__len__() returns 7; new to extra265"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra265
# ---------------------------------------------------------------------------

invariant inspect_extra265.module_name.eq:
  description: "inspect.__name__.__eq__('inspect') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra265.module_package.empty:
  description: "inspect.__package__.__eq__('') == True — top-level module, not a package; new to extra265"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant inspect_extra265.spec_class.modulespec:
  description: "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant inspect_extra265.spec_name.eq:
  description: "inspect.__spec__.name.__eq__('inspect') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra265.loader_class.source_file_loader:
  description: "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant inspect_extra265.Attribute.name_eq:
  description: "inspect.Attribute.__name__.__eq__('Attribute') == True — namedtuple; new to extra265"
  category: identity
  kind: python_call_eq
  function: Attribute.__name__.__eq__
  args: ["Attribute"]
  expected: true

invariant inspect_extra265.Attribute.module_eq:
  description: "inspect.Attribute.__module__.__eq__('inspect') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: Attribute.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra265.Attribute.base_is_tuple:
  description: "inspect.Attribute.__bases__[0].__name__.__eq__('tuple') == True — namedtuple inherits from tuple; new to extra265"
  category: identity
  kind: python_call_eq
  function: Attribute.__bases__.__getitem__(0).__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra265.Attribute.fields_len_4:
  description: "inspect.Attribute._fields.__len__() == 4 — fields: name, kind, defining_class, object; new to extra265"
  category: identity
  kind: python_call_eq
  function: Attribute._fields.__len__
  args: []
  expected: 4

invariant inspect_extra265.ArgInfo.name_eq:
  description: "inspect.ArgInfo.__name__.__eq__('ArgInfo') == True — namedtuple; new to extra265"
  category: identity
  kind: python_call_eq
  function: ArgInfo.__name__.__eq__
  args: ["ArgInfo"]
  expected: true

invariant inspect_extra265.ArgInfo.module_eq:
  description: "inspect.ArgInfo.__module__.__eq__('inspect') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: ArgInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra265.ArgInfo.fields_len_4:
  description: "inspect.ArgInfo._fields.__len__() == 4 — fields: args, varargs, keywords, locals; new to extra265"
  category: identity
  kind: python_call_eq
  function: ArgInfo._fields.__len__
  args: []
  expected: 4
