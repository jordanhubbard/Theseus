spec: difflib_extra16
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra15.zspec.zsdl."
    - "difflib_extra15 covers: SequenceMatcher/Differ/HtmlDiff __mro__.__len__(); SequenceMatcher __mro__[0]/__mro__[1] names; Differ.__qualname__; HtmlDiff.__qualname__; SequenceMatcher.__qualname__; table of function __module__ attributes."
    - "difflib_extra11 covers: unified_diff.__qualname__; get_close_matches.__qualname__; restore.__qualname__."
    - "difflib_extra8 covers: context_diff.__qualname__; IS_LINE_JUNK/__IS_CHARACTER_JUNK __qualname__."
    - "difflib_extra3 covers: ndiff/__qualname__; SequenceMatcher/__qualname__; Differ/__qualname__; HtmlDiff/__qualname__; unified_diff/__qualname__; context_diff/__qualname__."
    - "NOT yet covered (now covered here): difflib.SequenceMatcher.__qualname__.__len__() == 15 — length of 'SequenceMatcher'."
    - "NOT yet covered (now covered here): difflib.Differ.__qualname__.__len__() == 6 — length of 'Differ'."
    - "NOT yet covered (now covered here): difflib.HtmlDiff.__qualname__.__len__() == 8 — length of 'HtmlDiff'."
    - "NOT yet covered (now covered here): difflib.unified_diff.__qualname__.__len__() == 12 — length of 'unified_diff'."
    - "NOT yet covered (now covered here): difflib.context_diff.__qualname__.__len__() == 12 — length of 'context_diff'."
    - "NOT yet covered (now covered here): difflib.ndiff.__qualname__.__len__() == 5 — length of 'ndiff'."
    - "NOT yet covered (now covered here): difflib.get_close_matches.__qualname__.__len__() == 17 — length of 'get_close_matches'."
    - "NOT yet covered (now covered here): difflib.SequenceMatcher.__module__ == 'difflib' as standalone extra16 invariant."
    - "difflib.SequenceMatcher.__qualname__.__len__() == 15 verified at runtime ('SequenceMatcher' has 15 chars)."
    - "difflib.Differ.__qualname__.__len__() == 6 verified at runtime ('Differ' has 6 chars)."
    - "difflib.HtmlDiff.__qualname__.__len__() == 8 verified at runtime ('HtmlDiff' has 8 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher — __qualname__ string length and __module__
#
# difflib_extra15 covers SequenceMatcher.__qualname__ == 'SequenceMatcher'.
# No prior spec verifies SequenceMatcher.__qualname__.__len__(). The string
# 'SequenceMatcher' has 15 characters. The standalone __module__ invariant
# is a namespace anchor for extra16.
# Verified at runtime: __len__() == 15; __module__ == 'difflib'.
# ---------------------------------------------------------------------------

invariant difflib_extra16.SequenceMatcher.qualname_len:
  description: "difflib.SequenceMatcher.__qualname__.__len__() == 15 — 'SequenceMatcher' has 15 characters"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__qualname__.__len__
  args: []
  expected: 15

invariant difflib_extra16.SequenceMatcher.module:
  description: "difflib.SequenceMatcher.__module__ == 'difflib' — SequenceMatcher is defined in difflib"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.Differ — __qualname__ string length
#
# difflib_extra15 covers Differ.__qualname__ == 'Differ'. No prior spec
# verifies Differ.__qualname__.__len__(). The string 'Differ' has 6 characters.
# Verified at runtime: __len__() == 6.
# ---------------------------------------------------------------------------

invariant difflib_extra16.Differ.qualname_len:
  description: "difflib.Differ.__qualname__.__len__() == 6 — 'Differ' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Differ.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# difflib.HtmlDiff — __qualname__ string length
#
# difflib_extra15 covers HtmlDiff.__qualname__ == 'HtmlDiff'. No prior spec
# verifies HtmlDiff.__qualname__.__len__(). The string 'HtmlDiff' has 8 chars.
# Verified at runtime: __len__() == 8.
# ---------------------------------------------------------------------------

invariant difflib_extra16.HtmlDiff.qualname_len:
  description: "difflib.HtmlDiff.__qualname__.__len__() == 8 — 'HtmlDiff' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Table: difflib function __qualname__ string lengths
#
# No prior table groups __qualname__.__len__() checks for difflib functions.
# difflib_extra3/11 cover __qualname__ equality; here we verify character
# counts: unified_diff(12), context_diff(12), ndiff(5), get_close_matches(17).
# All verified at runtime.
# ---------------------------------------------------------------------------

table difflib_extra16.function_qualname_lengths:
  description: "difflib function __qualname__ string lengths — unified_diff, context_diff, ndiff, get_close_matches"
  kind: python_call_eq
  category: function_identity
  id_prefix: qnlen16

  columns: [id, function, args, expected]
  rows:
    - [unified_diff_len,      unified_diff.__qualname__.__len__,      [], 12]
    - [context_diff_len,      context_diff.__qualname__.__len__,      [], 12]
    - [ndiff_len,             ndiff.__qualname__.__len__,             [], 5]
    - [get_close_matches_len, get_close_matches.__qualname__.__len__, [], 17]
