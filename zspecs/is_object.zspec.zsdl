spec: is_object
version: ">=1.0.2"
backend: node(is-object)

docs: https://www.npmjs.com/package/is-object

provenance:
  derived_from:
    - "is-object README — https://www.npmjs.com/package/is-object"
    - "Test vectors verified with is-object via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-object source"
  notes:
    - "is-object is an npm package. Install: npm install is-object"
    - "Returns true for objects and arrays; false for null, strings, numbers, booleans."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_object.isObject:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: isobj

  columns: [id, args, expected]
  rows:
    - [plain_obj,  [{"a": 1}],   true]
    - [array,      [[1, 2]],     true]
    - [null_v,     [null],       false]
    - [string,     ["hi"],       false]
    - [number,     [42],         false]
