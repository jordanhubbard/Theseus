spec: asyncio_extra
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-stream.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-exceptions.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "asyncio source: internal event loop and scheduling implementation"
  notes:
    - "Covers __module__ checks and additional function name checks not in asyncio.zspec.zsdl or asyncio_events.zspec.zsdl."
    - "Task and Future live in asyncio.tasks and asyncio.futures respectively."
    - "Queue, Lock, Semaphore, Event, Condition live in asyncio.queues and asyncio.locks."
    - "StreamReader and StreamWriter live in asyncio.streams."
    - "TimeoutError and CancelledError are standard exceptions re-exported by asyncio."
    - "IncompleteReadError is defined in asyncio.streams."
    - "create_task, ensure_future, gather, sleep, run are top-level asyncio coroutine/function names."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — verifying __name__ for core asyncio classes
# ---------------------------------------------------------------------------

invariant asyncio_extra.classes.Task_name:
  description: "asyncio.Task.__name__ == 'Task'"
  category: classes
  kind: python_call_eq
  function: Task.__name__.__eq__
  args: ["Task"]
  expected: true

invariant asyncio_extra.classes.Future_name:
  description: "asyncio.Future.__name__ == 'Future'"
  category: classes
  kind: python_call_eq
  function: Future.__name__.__eq__
  args: ["Future"]
  expected: true

