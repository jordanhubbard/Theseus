spec: errno_extra7
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/errno.html — Python errno module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "This spec extends errno.zspec.zsdl through errno_extra6.zspec.zsdl."
    - "errno.zspec covers: EPERM=1, ENOENT=2, ESRCH=3, EINTR=4, EIO=5, EBADF=9, ENOMEM=12, EACCES=13, EINVAL=22 values; errorcode type/lookups 1/2/22."
    - "errno_extra covers: class names for ENOENT/EACCES/EEXIST/EPERM; errorcode class name; errorcode[2]=='ENOENT'."
    - "errno_extra2 covers: class names EPERM/ENOENT/ESRCH/EINTR/EIO/ENXIO/EACCES/EEXIST/ENOTDIR/EISDIR; errorcode class/len>=50; positivity EPERM/ENOENT/EACCES."
    - "errno_extra3 covers: class names EBADF/ENOMEM/EINVAL; errorcode lookups 9/12; contains 9/12."
    - "errno_extra4 covers: class names ENOSPC/EPIPE/ERANGE/EMFILE/ENFILE; errorcode lookups 5/13/28/32; positivity ESRCH/EINTR/EIO."
    - "errno_extra5 covers: constant values ECHILD=10/EFAULT=14/ENOTDIR=20/EISDIR=21/ENXIO=6; errorcode lookups 3/4/6/10/14; contains 5/13/22; positivity EBADF/ENOMEM/EINVAL."
    - "errno_extra6 covers: class names EAGAIN/EWOULDBLOCK/EADDRINUSE/ECONNRESET; EAGAIN==EWOULDBLOCK==35; errorcode[35]=='EAGAIN'; contains 35; positivity EAGAIN/EADDRINUSE."
    - "No prior spec verifies class names for ECONNREFUSED, ETIMEDOUT, EHOSTUNREACH, or ENETUNREACH."
    - "No prior spec verifies ECONNREFUSED==61, ETIMEDOUT==60, EHOSTUNREACH==65, ENETUNREACH==51 as standalone invariants (macOS/Darwin values)."
    - "No prior spec verifies errorcode[13]=='EACCES', errorcode[17]=='EEXIST', 17 in errorcode, or 13 in errorcode as standalone invariants."
    - "This spec adds: class name checks for ECONNREFUSED/ETIMEDOUT/EHOSTUNREACH/ENETUNREACH; value checks ECONNREFUSED==61/ETIMEDOUT==60/EHOSTUNREACH==65/ENETUNREACH==51; errorcode reverse-lookups 13/17; contains checks 13/17; positivity ECONNREFUSED/ETIMEDOUT."
    - "errno.ECONNREFUSED == 61 on macOS/Darwin (connection refused)."
    - "errno.ETIMEDOUT == 60 on macOS/Darwin (operation timed out)."
    - "errno.EHOSTUNREACH == 65 on macOS/Darwin (no route to host)."
    - "errno.ENETUNREACH == 51 on macOS/Darwin (network is unreachable)."
    - "errno.errorcode[13] == 'EACCES' — reverse-lookup of errno 13 on macOS."
    - "errno.errorcode[17] == 'EEXIST' — reverse-lookup of errno 17 on macOS."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — ECONNREFUSED, ETIMEDOUT, EHOSTUNREACH, ENETUNREACH
#
# All prior errno specs cover class names through errno_extra6 (EAGAIN/EWOULDBLOCK/
# EADDRINUSE/ECONNRESET). The four network-related constants ECONNREFUSED,
# ETIMEDOUT, EHOSTUNREACH, and ENETUNREACH have not appeared in any class-name
# table in any prior spec.
# ---------------------------------------------------------------------------

table errno_extra7.constant_class_names:
  description: "ECONNREFUSED, ETIMEDOUT, EHOSTUNREACH, ENETUNREACH are plain int objects — __class__.__name__ == 'int'"
  kind: python_call_eq
  category: constant_types
  id_prefix: cls7

  columns: [id, function, args, expected]
  rows:
    - [ECONNREFUSED, ECONNREFUSED.__class__.__name__.__eq__, ["int"], true]
    - [ETIMEDOUT,    ETIMEDOUT.__class__.__name__.__eq__,    ["int"], true]
    - [EHOSTUNREACH, EHOSTUNREACH.__class__.__name__.__eq__, ["int"], true]
    - [ENETUNREACH,  ENETUNREACH.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# Constant values — ECONNREFUSED, ETIMEDOUT, EHOSTUNREACH, ENETUNREACH
#
# No prior spec verifies these four constants' integer values as standalone
# invariants. All are POSIX-defined but their numeric values vary by platform.
# The values below are correct for macOS/Darwin 25.4.0.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra7.ECONNREFUSED.value:
  description: "errno.ECONNREFUSED == 61 on macOS/Darwin (connection refused)"
  category: constants
  kind: python_call_eq
  function: ECONNREFUSED.__eq__
  args: [61]
  expected: true

invariant errno_extra7.ETIMEDOUT.value:
  description: "errno.ETIMEDOUT == 60 on macOS/Darwin (operation timed out)"
  category: constants
  kind: python_call_eq
  function: ETIMEDOUT.__eq__
  args: [60]
  expected: true

invariant errno_extra7.EHOSTUNREACH.value:
  description: "errno.EHOSTUNREACH == 65 on macOS/Darwin (no route to host)"
  category: constants
  kind: python_call_eq
  function: EHOSTUNREACH.__eq__
  args: [65]
  expected: true

invariant errno_extra7.ENETUNREACH.value:
  description: "errno.ENETUNREACH == 51 on macOS/Darwin (network is unreachable)"
  category: constants
  kind: python_call_eq
  function: ENETUNREACH.__eq__
  args: [51]
  expected: true

# ---------------------------------------------------------------------------
# errorcode — reverse-lookup for keys 13 (EACCES) and 17 (EEXIST)
#
# Prior specs cover reverse-lookups for keys 1/2/3/4/5/6/9/10/12/13/14/22/28/32/35.
# errno_extra4 covers errorcode[13]=='EACCES' as part of a broader table, but
# no prior spec anchors it or errorcode[17]=='EEXIST' as standalone invariants.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra7.errorcode.eacces_lookup:
  description: "errno.errorcode[13] == 'EACCES' — reverse-lookup of errno 13 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [13]
  expected: "EACCES"

invariant errno_extra7.errorcode.eexist_lookup:
  description: "errno.errorcode[17] == 'EEXIST' — reverse-lookup of errno 17 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [17]
  expected: "EEXIST"

# ---------------------------------------------------------------------------
# errorcode — __contains__ for keys 13 and 17
#
# errno_extra5 covers __contains__ for keys 5/13/22 in a table, but no prior
# spec anchors contains-13 or contains-17 as standalone invariants.
# Verified: both keys are present in errorcode on macOS.
# ---------------------------------------------------------------------------

invariant errno_extra7.errorcode.contains_eacces_key:
  description: "13 in errno.errorcode — EACCES key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [13]
  expected: true

invariant errno_extra7.errorcode.contains_eexist_key:
  description: "17 in errno.errorcode — EEXIST key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [17]
  expected: true

# ---------------------------------------------------------------------------
# Positivity checks — ECONNREFUSED and ETIMEDOUT
#
# No prior spec checks positivity for ECONNREFUSED or ETIMEDOUT.
# Both are positive integers (61 and 60 respectively on macOS).
# ---------------------------------------------------------------------------

invariant errno_extra7.ECONNREFUSED_positive:
  description: "errno.ECONNREFUSED > 0 — ECONNREFUSED == 61 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: ECONNREFUSED.__gt__
  args: [0]
  expected: true

invariant errno_extra7.ETIMEDOUT_positive:
  description: "errno.ETIMEDOUT > 0 — ETIMEDOUT == 60 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: ETIMEDOUT.__gt__
  args: [0]
  expected: true
