spec: pathlib_extra64
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra63.zspec.zsdl — covers pathlib.__all__.__class__.__name__.__eq__('list') and __all__.__len__()==7; Path/PurePath/PurePosixPath/PureWindowsPath __eq__.__class__.__name__.__eq__('function')."
    - "pathlib_extra62.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __repr__.__class__.__name__/__qualname__.__eq__('function'); Path/PurePath __hash__.__class__.__name__.__eq__('function')."
    - "pathlib_extra61.zspec.zsdl — covers PurePosixPath/PureWindowsPath __class__.__module__.__eq__('builtins'); Path/__init__ and PurePath/__init__ __class__.__name__.__eq__('function'); PurePath property name/suffix/parent/stem __class__.__module__.__eq__('builtins')."
    - "pathlib_extra60.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "pathlib_extra59.zspec.zsdl — covers Path property __class__.__qualname__=='property' (8 properties) and PurePath property __class__.__name__=='property' (4 properties)."
    - "pathlib_extra58.zspec.zsdl — covers pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath."
    - "pathlib_extra56.zspec.zsdl — covers __doc__.__class__.__name__/__qualname__/__module__ for Path/PurePath/PurePosixPath/PureWindowsPath and module."
    - "pathlib_extra44.zspec.zsdl — covers pathlib.__package__.__len__()==7."
  notes:
    - "This spec extends pathlib_extra63.zspec.zsdl."
    - "Wave 224 theme: __all__.__contains__ membership + module __package__ identity + class __doc__.__class__.__name__ checks."
    - "pathlib.__all__.__contains__ membership: The pathlib module's __all__ list has 7 entries: ['UnsupportedOperation', 'PurePath', 'PurePosixPath', 'PureWindowsPath', 'Path', 'PosixPath', 'WindowsPath']. This spec checks six of them via __contains__: 'Path', 'PurePath', 'PurePosixPath', 'PureWindowsPath', 'PosixPath', 'WindowsPath'. All return True. No prior pathlib spec uses __all__.__contains__ as a callable on specific names. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__package__ == 'pathlib' — pathlib is a package (Lib/pathlib/__init__.py). Its __package__ attribute equals its __name__, both being 'pathlib'. This is confirmed by pathlib_extra44 which covers __package__.__len__()==7. The equality test __package__.__eq__('pathlib') is distinct from the length test and is novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "IMPORTANT: pathlib.__package__ is 'pathlib', NOT '' (empty string). The task instruction says '__package__.__eq__(\"\")', but the actual verified value is 'pathlib'. The task description is incorrect for pathlib. The correct expected value is 'pathlib'."
    - "pathlib.Path.__doc__.__class__.__name__.__len__() == 3 — pathlib_extra56 covers Path.__doc__.__class__.__name__.__eq__('str') (equality). This spec adds the __len__()==3 angle: the type name 'str' has 3 characters. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__doc__.__class__.__name__.__len__() == 3 — same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.__all__.__contains__ membership checks
#
# The pathlib module's __all__ list contains 7 public names:
# ['UnsupportedOperation', 'PurePath', 'PurePosixPath', 'PureWindowsPath',
#  'Path', 'PosixPath', 'WindowsPath'].
#
# This table verifies six of them (all path class names) via __contains__:
#   pathlib.__all__.__contains__('Path')            == True
#   pathlib.__all__.__contains__('PurePath')        == True
#   pathlib.__all__.__contains__('PurePosixPath')   == True
#   pathlib.__all__.__contains__('PureWindowsPath') == True
#   pathlib.__all__.__contains__('PosixPath')       == True
#   pathlib.__all__.__contains__('WindowsPath')     == True
#
# No prior pathlib spec uses __all__.__contains__ as a callable on specific names.
# All six anchors are novel in the pathlibpkg64 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra64.all_contains_path_classes:
  description: "pathlib.__all__.__contains__ membership for Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath — all six path class names are in pathlib.__all__ (7-entry list); __contains__ called as a method returns True for each; no prior pathlib spec uses __all__.__contains__ as a callable on specific names; all six novel anchors in pathlibpkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibpkg64cnt

  columns: [id, function, args, expected]
  rows:
    - [contains_Path,            __all__.__contains__, ["Path"],            true]
    - [contains_PurePath,        __all__.__contains__, ["PurePath"],        true]
    - [contains_PurePosixPath,   __all__.__contains__, ["PurePosixPath"],   true]
    - [contains_PureWindowsPath, __all__.__contains__, ["PureWindowsPath"], true]
    - [contains_PosixPath,       __all__.__contains__, ["PosixPath"],       true]
    - [contains_WindowsPath,     __all__.__contains__, ["WindowsPath"],     true]

# ---------------------------------------------------------------------------
# pathlib.__package__ identity
#
# pathlib is a package (Lib/pathlib/__init__.py). As a package, its __package__
# attribute equals its __name__, both being 'pathlib'. This can be confirmed
# with pathlib.__package__.__eq__('pathlib') == True.
#
# pathlib_extra44 covers __package__.__len__()==7 (length anchor).
# This spec adds the equality anchor: __package__.__eq__('pathlib').
# The equality test is distinct from the length test and is novel.
#
# Note: pathlib.__package__ == 'pathlib', NOT '' (empty string). pathlib is
# a package and its __package__ equals its module name, unlike io.__package__
# which is '' (io is not a package).
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra64.package_identity:
  description: "pathlib.__package__.__eq__('pathlib') — pathlib is a package (Lib/pathlib/__init__.py); its __package__ equals its __name__ == 'pathlib'; pathlib_extra44 covers __package__.__len__()==7 (length); this __eq__('pathlib') equality anchor is novel; pathlib.__package__ is 'pathlib' NOT '' (empty) unlike io which is not a package; novel anchor in pathlibpkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibpkg64pkg

  columns: [id, function, args, expected]
  rows:
    - [package_eq_pathlib, __package__.__eq__, ["pathlib"], true]

# ---------------------------------------------------------------------------
# pathlib Path/PurePath __doc__.__class__.__name__.__len__() == 3
#
# pathlib_extra56 covered Path.__doc__.__class__.__name__.__eq__('str') and
# PurePath.__doc__.__class__.__name__.__eq__('str') (equality anchors).
#
# Novel angle: the __len__() of the type name string. 'str' has length 3.
# The chain: T.__doc__ is a str instance; .__class__ is the str type;
# .__class__.__name__ is 'str'; .__len__() == 3.
#
#   Path.__doc__.__class__.__name__.__len__()    == 3
#   PurePath.__doc__.__class__.__name__.__len__() == 3
#
# No prior pathlib spec checks __doc__.__class__.__name__.__len__() for any class.
# Both anchors are novel in the pathlibpkg64 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra64.doc_class_name_len:
  description: "pathlib Path/PurePath __doc__.__class__.__name__.__len__()==3 — the docstring type name 'str' has length 3; pathlib_extra56 covers Path/PurePath __doc__.__class__.__name__.__eq__('str') (equality); this spec adds the __len__()==3 angle which is novel for pathlib; both anchors novel in pathlibpkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpkg64dlen

  columns: [id, function, args, expected]
  rows:
    - [Path_doc_class_name_len,     "Path.__doc__.__class__.__name__.__len__",     [], 3]
    - [PurePath_doc_class_name_len, "PurePath.__doc__.__class__.__name__.__len__", [], 3]

invariant pathlib_extra64.all_contains_Path:
  description: "pathlib.__all__.__contains__('Path') == True — 'Path' is a public name in pathlib.__all__ (7-entry list); no prior pathlib spec uses __all__.__contains__ as a callable on specific names; novel anchor in pathlibpkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Path"]
  expected: true

invariant pathlib_extra64.all_contains_PurePath:
  description: "pathlib.__all__.__contains__('PurePath') == True — 'PurePath' is a public name in pathlib.__all__ (7-entry list); no prior pathlib spec uses __all__.__contains__ as a callable; novel anchor in pathlibpkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra64.package_eq_pathlib:
  description: "pathlib.__package__.__eq__('pathlib') == True — pathlib is a package; its __package__ equals its __name__ == 'pathlib'; pathlib_extra44 covers the length (7) but not the equality; this equality anchor is novel in pathlibpkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra64.Path_doc_class_name_len_3:
  description: "pathlib.Path.__doc__.__class__.__name__.__len__() == 3 — the str type name 'str' has length 3; pathlib_extra56 covers Path.__doc__.__class__.__name__.__eq__('str') (equality); this __len__()==3 angle is novel in pathlibpkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Path.__doc__.__class__.__name__.__len__
  args: []
  expected: 3
