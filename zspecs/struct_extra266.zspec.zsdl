spec: struct_extra266
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra265.zspec.zsdl — covers struct.calcsize for byte-order prefix sizes."
    - "struct_extra264.zspec.zsdl — covers struct.calcsize for multi-format network-order strings."
  notes:
    - "struct.__name__ == 'struct' — the pure-Python struct wrapper module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__package__ == '' — struct is a top-level module with empty package string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__spec__.name == 'struct' — ModuleSpec.name matches the module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is an importlib.machinery.ModuleSpec. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader' — the struct module wrapper is a .py source file. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__spec__.origin.__class__.__name__ == 'str' — the origin is a string path to the struct.py source file. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "_struct.__name__ == '_struct' — the C extension backing module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "_struct.__spec__.name == '_struct' — ModuleSpec.name for C extension matches module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "_struct.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension modules use ExtensionFileLoader. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack.__name__ == 'pack' — pack function exposed by the struct module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack.__module__ == '_struct' — pack is implemented in the _struct C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack.__name__ == 'unpack' — unpack function exposed by the struct module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack.__module__ == '_struct' — unpack is implemented in the _struct C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module __spec__ and __loader__ identity
# struct is a thin pure-Python wrapper (SourceFileLoader) around the _struct
# C extension (ExtensionFileLoader). The wrapper module re-exports all names
# from _struct. __spec__.origin is a string path to struct.py.
# ---------------------------------------------------------------------------

table struct_extra266.struct_module_spec_identity:
  description: "struct module __spec__ and __loader__ identity — __name__/'struct', __package__/'', __spec__.name/'struct', __spec__.__class__.__name__/'ModuleSpec', __loader__.__class__.__name__/'SourceFileLoader'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structspec266

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name,        __name__.__eq__,                          ["struct"],           true, "struct.__name__ == 'struct' — pure-Python wrapper module name"]
    - [struct_package,     __package__.__eq__,                       [""],                 true, "struct.__package__ == '' — top-level module has empty package string"]
    - [struct_spec_name,   __spec__.name.__eq__,                     ["struct"],           true, "struct.__spec__.name == 'struct' — ModuleSpec.name matches module name"]
    - [struct_spec_class,  __spec__.__class__.__name__.__eq__,       ["ModuleSpec"],       true, "struct.__spec__.__class__.__name__ == 'ModuleSpec' — importlib.machinery.ModuleSpec instance"]
    - [struct_loader,      __loader__.__class__.__name__.__eq__,     ["SourceFileLoader"], true, "struct.__loader__.__class__.__name__ == 'SourceFileLoader' — wrapper loaded from struct.py"]

# ---------------------------------------------------------------------------
# _struct C extension module __spec__ and __loader__ identity plus
# struct.pack and struct.unpack function __module__ identity
# _struct is the C extension backing struct; both pack and unpack are
# implemented in _struct and re-exported by the struct wrapper.
# ---------------------------------------------------------------------------

table struct_extra266.struct_c_ext_and_func_identity:
  description: "_struct C extension __spec__ identity and struct.pack/unpack __module__ — _struct.__loader__ is ExtensionFileLoader; pack.__module__ == '_struct'; unpack.__module__ == '_struct'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structcext266

  columns: [id, function, args, expected, description]
  rows:
    - [c_ext_name,        _struct.__name__.__eq__,                          ["_struct"],            true, "_struct.__name__ == '_struct' — C extension backing module name"]
    - [c_ext_spec_name,   _struct.__spec__.name.__eq__,                     ["_struct"],            true, "_struct.__spec__.name == '_struct' — ModuleSpec.name matches C extension name"]
    - [c_ext_loader,      _struct.__loader__.__class__.__name__.__eq__,     ["ExtensionFileLoader"], true, "_struct.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension uses ExtensionFileLoader"]
    - [pack_module,       pack.__module__.__eq__,                           ["_struct"],            true, "struct.pack.__module__ == '_struct' — pack is implemented in the _struct C extension"]
    - [unpack_module,     unpack.__module__.__eq__,                         ["_struct"],            true, "struct.unpack.__module__ == '_struct' — unpack is implemented in the _struct C extension"]

# ---------------------------------------------------------------------------
# Standalone invariants — struct module spec and function identity
# ---------------------------------------------------------------------------

invariant struct_extra266.struct_name_eq:
  description: "struct.__name__ == 'struct' — the module name attribute of the struct wrapper module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra266.struct_package_eq:
  description: "struct.__package__ == '' — struct is a top-level module so __package__ is the empty string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant struct_extra266.struct_spec_name_eq:
  description: "struct.__spec__.name == 'struct' — the ModuleSpec.name attribute for the struct wrapper module; mirrors __name__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra266.struct_spec_class_eq:
  description: "struct.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is an importlib.machinery.ModuleSpec; set by the import system for all Python modules; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant struct_extra266.struct_loader_class_eq:
  description: "struct.__loader__.__class__.__name__ == 'SourceFileLoader' — struct.py is a thin pure-Python wrapper loaded from source by SourceFileLoader; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant struct_extra266.struct_spec_origin_class_eq:
  description: "struct.__spec__.origin.__class__.__name__ == 'str' — the origin is a filesystem path string pointing to struct.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra266.c_ext_name_eq:
  description: "_struct.__name__ == '_struct' — the C extension module that provides the actual implementation of struct operations; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: _struct.__name__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra266.c_ext_loader_class_eq:
  description: "_struct.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension modules use ExtensionFileLoader from importlib._bootstrap_external; contrasts with SourceFileLoader used for struct.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: _struct.__loader__.__class__.__name__.__eq__
  args: ["ExtensionFileLoader"]
  expected: true

invariant struct_extra266.pack_name_eq:
  description: "struct.pack.__name__ == 'pack' — the pack function exposed by the struct module; implemented in _struct C extension; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra266.pack_module_eq:
  description: "struct.pack.__module__ == '_struct' — pack is implemented in the _struct C extension and re-exported by the struct wrapper module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra266.unpack_name_eq:
  description: "struct.unpack.__name__ == 'unpack' — the unpack function exposed by the struct module; implemented in _struct C extension; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: unpack.__name__.__eq__
  args: ["unpack"]
  expected: true

invariant struct_extra266.unpack_module_eq:
  description: "struct.unpack.__module__ == '_struct' — unpack is implemented in the _struct C extension and re-exported by the struct wrapper module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: unpack.__module__.__eq__
  args: ["_struct"]
  expected: true
