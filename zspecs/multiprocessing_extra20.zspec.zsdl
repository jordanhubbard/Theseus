spec: multiprocessing_extra20
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra19.zspec.zsdl."
    - "multiprocessing_extra5 notes claimed Manager/__qualname__=='Manager' and Pipe/__qualname__=='Pipe', but Python 3.12 returns 'BaseContext.Manager' and 'BaseContext.Pipe' — these are bound methods of the context object."
    - "multiprocessing_extra16 covers: Process/Queue/Pool/Lock/Event __qualname__ table (correct 'BaseContext.*' values)."
    - "multiprocessing_extra6 covers: current_process/active_children/cpu_count __qualname__ in a table."
    - "NOT yet covered in any prior spec: multiprocessing context method __qualname__ table for Value/Array/Manager/Pipe in extra20 namespace."
    - "NOT yet covered: multiprocessing.Process.__qualname__ == 'Process' as standalone extra20-namespace invariant."
    - "NOT yet covered: multiprocessing.Value.__qualname__ == 'BaseContext.Value' as a correct standalone invariant — extra5 had wrong expected value."
    - "NOT yet covered: multiprocessing.Array.__qualname__ == 'BaseContext.Array' as a correct standalone invariant — extra5 had wrong expected value."
    - "NOT yet covered: multiprocessing context method __qualname__ __len__ table for Value/Array/Manager/Pipe in extra20 namespace."
    - "multiprocessing.Value.__qualname__ == 'BaseContext.Value' — Value is a bound method of the default context object."
    - "multiprocessing.Array.__qualname__ == 'BaseContext.Array' — Array is a bound method of the default context object."
    - "multiprocessing.Manager.__qualname__ == 'BaseContext.Manager' — Manager is a bound method of the default context object."
    - "multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe' — Pipe is a bound method of the default context object."
    - "multiprocessing.Process.__qualname__ == 'Process' — Process is a true class, not a context method; qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context method __qualname__ table — Value/Array/Manager/Pipe
#
# multiprocessing_extra16 covers Process/Queue/Pool/Lock/Event __qualname__
# (with 'BaseContext.*' values). No prior spec provides a unified extra20-
# namespace table covering Value/Array/Manager/Pipe with the correct
# 'BaseContext.*' qualnames. These four names are bound methods of the default
# multiprocessing context object, not standalone classes or functions.
# ---------------------------------------------------------------------------

table multiprocessing_extra20.context_method_qualnames:
  description: "multiprocessing context-bound callables report __qualname__ as 'BaseContext.<Name>'"
  kind: python_call_eq
  category: class_names
  id_prefix: ctxqn20

  columns: [id, function, args, expected]
  rows:
    - [Value,   Value.__qualname__.__eq__,   ["BaseContext.Value"],   true]
    - [Array,   Array.__qualname__.__eq__,   ["BaseContext.Array"],   true]
    - [Manager, Manager.__qualname__.__eq__, ["BaseContext.Manager"], true]
    - [Pipe,    Pipe.__qualname__.__eq__,    ["BaseContext.Pipe"],    true]

# ---------------------------------------------------------------------------
# Context method __qualname__ __len__ table — extra20 namespace
#
# No prior spec checks __qualname__ lengths for Value/Array/Manager/Pipe.
# The 'BaseContext.' prefix (12 chars) is added to each bare name.
# Lengths: BaseContext.Value(17), BaseContext.Array(17),
#          BaseContext.Manager(19), BaseContext.Pipe(16).
# ---------------------------------------------------------------------------

table multiprocessing_extra20.context_method_qualname_lengths:
  description: "multiprocessing context-bound callable __qualname__ lengths include 'BaseContext.' prefix"
  kind: python_call_eq
  category: class_names
  id_prefix: ctxqnlen20

  columns: [id, function, args, expected]
  rows:
    - [Value,   Value.__qualname__.__len__,   [], 17]
    - [Array,   Array.__qualname__.__len__,   [], 17]
    - [Manager, Manager.__qualname__.__len__, [], 19]
    - [Pipe,    Pipe.__qualname__.__len__,    [], 16]

# ---------------------------------------------------------------------------
# Process.__qualname__ == 'Process' — standalone extra20 invariant
#
# multiprocessing_extra16 covers Process/__qualname__ in table form. This
# standalone extra20-namespace invariant provides an independent anchor
# confirming Process is a true class (not a context method), so its
# __qualname__ equals its simple name 'Process', not 'BaseContext.Process'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra20.Process.qualname_eq:
  description: "multiprocessing.Process.__qualname__ == 'Process' — true class, qualname equals simple name"
  category: class_names
  kind: python_call_eq
  function: Process.__qualname__.__eq__
  args: ["Process"]
  expected: true

# ---------------------------------------------------------------------------
# Value.__qualname__ == 'BaseContext.Value' — standalone extra20 invariant
#
# multiprocessing.Value is a bound method of the default context object, so
# its __qualname__ is 'BaseContext.Value', not 'Value'. This standalone
# invariant explicitly documents the correct value, contrasting with the
# earlier incorrect note in multiprocessing_extra5 which claimed 'Value'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra20.Value.qualname_eq:
  description: "multiprocessing.Value.__qualname__ == 'BaseContext.Value' — bound context method, not standalone class"
  category: class_names
  kind: python_call_eq
  function: Value.__qualname__.__eq__
  args: ["BaseContext.Value"]
  expected: true

# ---------------------------------------------------------------------------
# Array.__qualname__ == 'BaseContext.Array' — standalone extra20 invariant
#
# Like Value, multiprocessing.Array is a bound method of the default context
# object. Its __qualname__ is 'BaseContext.Array'. This standalone invariant
# provides an independent extra20-namespace anchor for this pattern.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra20.Array.qualname_eq:
  description: "multiprocessing.Array.__qualname__ == 'BaseContext.Array' — bound context method, not standalone class"
  category: class_names
  kind: python_call_eq
  function: Array.__qualname__.__eq__
  args: ["BaseContext.Array"]
  expected: true
