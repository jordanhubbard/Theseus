spec: json_extra27
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
    - "json_extra25.zspec.zsdl — covers __mro__.__len__() for JSONDecodeError/JSONDecoder/JSONEncoder; __bases__[0].__name__.__len__() for same; __init__.__qualname__.__len__() for same; json.scanner.__name__.__len__()"
    - "json_extra26.zspec.zsdl — covers json.__all__.__len__()==7; __all__.__class__.__name__.__len__()==4; __dict__.__class__.__name__.__len__()==12 for JSONDecoder/JSONEncoder/JSONDecodeError; __reduce__.__name__.__len__()==10 for all three; __init_subclass__.__qualname__.__len__() for all three; decoder/encoder __class__.__name__.__len__()==6"
  notes:
    - "This spec extends json_extra26.zspec.zsdl."
    - "Prior specs covered: JSONDecoder/JSONEncoder/JSONDecodeError __name__/__module__/__qualname__/__bases__[0].__name__, loads/dumps/load/dump attributes, method qualname lengths, class MRO depths, base-name lengths, __init__ qualname lengths, json.scanner.__name__.__len__(), __all__, __dict__.__class__.__name__.__len__(), __reduce__.__name__.__len__(), __init_subclass__.__qualname__.__len__(), decoder/encoder module class name."
    - "This spec covers: JSONDecoder.decode.__qualname__.__len__()==18; JSONDecoder.raw_decode.__qualname__.__len__()==22; JSONEncoder.encode.__qualname__.__len__()==18; JSONEncoder.iterencode.__qualname__.__len__()==22; json.dumps.__qualname__.__len__()==5; json.loads.__qualname__.__len__()==5; json.dump.__qualname__.__len__()==4; json.load.__qualname__.__len__()==4; JSONDecodeError.__mro__.__len__()==5; JSONDecodeError.__bases__[0].__name__.__len__()==10; JSONDecoder.__mro__.__len__()==2; JSONEncoder.__mro__.__len__()==2."
    - "JSONDecoder.decode.__qualname__ == 'JSONDecoder.decode' — len 18. Verified Python 3.12."
    - "JSONDecoder.raw_decode.__qualname__ == 'JSONDecoder.raw_decode' — len 22. Verified Python 3.12."
    - "JSONEncoder.encode.__qualname__ == 'JSONEncoder.encode' — len 18. Verified Python 3.12."
    - "JSONEncoder.iterencode.__qualname__ == 'JSONEncoder.iterencode' — len 22. Verified Python 3.12."
    - "json.dumps.__qualname__ == 'dumps' — len 5. Module-level function; qualname equals __name__. Verified Python 3.12."
    - "json.loads.__qualname__ == 'loads' — len 5. Verified Python 3.12."
    - "json.dump.__qualname__ == 'dump' — len 4. Verified Python 3.12."
    - "json.load.__qualname__ == 'load' — len 4. Verified Python 3.12."
    - "JSONDecodeError.__mro__ == [JSONDecodeError, ValueError, Exception, BaseException, object] — len 5. Verified Python 3.12."
    - "JSONDecodeError.__bases__[0].__name__ == 'ValueError' — len 10. Verified Python 3.12."
    - "JSONDecoder.__mro__ == [JSONDecoder, object] — len 2. Already noted in json_extra25 but __len__ not separately checked there. Verified Python 3.12."
    - "JSONEncoder.__mro__ == [JSONEncoder, object] — len 2. Already noted in json_extra25 but __len__ not separately checked there. Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# json.JSONDecoder method qualname lengths
#
# JSONDecoder exposes two public instance methods: decode() and raw_decode().
# Their qualnames follow the 'JSONDecoder.<method>' pattern:
#   JSONDecoder.decode     -> 'JSONDecoder.decode'     -> 18 chars
#   JSONDecoder.raw_decode -> 'JSONDecoder.raw_decode' -> 22 chars
# No prior json spec checks qualname lengths for decode or raw_decode.
# ---------------------------------------------------------------------------

table json_extra27.JSONDecoder_method_qualname_lens:
  description: "json.JSONDecoder method __qualname__.__len__(): decode (18), raw_decode (22)"
  kind: python_call_eq
  category: method_identity
  id_prefix: jdm27

  columns: [id, function, args, expected]
  rows:
    - [decode,     JSONDecoder.decode.__qualname__.__len__,     [], 18]
    - [raw_decode, JSONDecoder.raw_decode.__qualname__.__len__, [], 22]

# ---------------------------------------------------------------------------
# json.JSONEncoder method qualname lengths
#
# JSONEncoder exposes two public instance methods: encode() and iterencode().
# Their qualnames follow the 'JSONEncoder.<method>' pattern:
#   JSONEncoder.encode      -> 'JSONEncoder.encode'      -> 18 chars
#   JSONEncoder.iterencode  -> 'JSONEncoder.iterencode'  -> 22 chars
# No prior json spec checks qualname lengths for encode or iterencode.
# ---------------------------------------------------------------------------

table json_extra27.JSONEncoder_method_qualname_lens:
  description: "json.JSONEncoder method __qualname__.__len__(): encode (18), iterencode (22)"
  kind: python_call_eq
  category: method_identity
  id_prefix: jem27

  columns: [id, function, args, expected]
  rows:
    - [encode,      JSONEncoder.encode.__qualname__.__len__,      [], 18]
    - [iterencode,  JSONEncoder.iterencode.__qualname__.__len__,  [], 22]

# ---------------------------------------------------------------------------
# json module-level function qualname lengths
#
# The four primary json API functions are all top-level module functions.
# Their __qualname__ equals their __name__ (no class scoping).
#   json.dump  -> 'dump'  -> 4 chars
#   json.load  -> 'load'  -> 4 chars
#   json.dumps -> 'dumps' -> 5 chars
#   json.loads -> 'loads' -> 5 chars
# No prior json spec checks __qualname__.__len__() for any of these functions.
# ---------------------------------------------------------------------------

table json_extra27.toplevel_function_qualname_lens:
  description: "json top-level function __qualname__.__len__(): dump (4), load (4), dumps (5), loads (5)"
  kind: python_call_eq
  category: function_identity
  id_prefix: jtf27

  columns: [id, function, args, expected]
  rows:
    - [dump,  dump.__qualname__.__len__,  [], 4]
    - [load,  load.__qualname__.__len__,  [], 4]
    - [dumps, dumps.__qualname__.__len__, [], 5]
    - [loads, loads.__qualname__.__len__, [], 5]

# ---------------------------------------------------------------------------
# json.JSONDecodeError class hierarchy
#
# JSONDecodeError is a subclass of ValueError. Its MRO traverses the full
# exception hierarchy:
#   JSONDecodeError -> ValueError -> Exception -> BaseException -> object
# That gives __mro__.__len__() == 5 and __bases__[0].__name__ == 'ValueError'
# (len 10).
# json_extra25 covered JSONDecodeError.__bases__[0].__name__ value but NOT the
# length of that string. json_extra25 covered __mro__.__len__()==5.
# No prior json spec checks JSONDecodeError.__bases__[0].__name__.__len__().
# ---------------------------------------------------------------------------

invariant json_extra27.JSONDecodeError.base_name_len:
  description: "json.JSONDecodeError.__bases__[0].__name__.__len__() == 10 — direct base is 'ValueError' (10 chars)"
  category: class_hierarchy
  kind: python_call_eq
  "function": "JSONDecodeError.__bases__[0].__name__.__len__"
  args: []
  expected: 10

invariant json_extra27.JSONDecodeError.mro_len:
  description: "json.JSONDecodeError.__mro__.__len__() == 5 — MRO is [JSONDecodeError, ValueError, Exception, BaseException, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONDecodeError.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# json.JSONDecoder and json.JSONEncoder MRO depths
#
# Both JSONDecoder and JSONEncoder inherit directly from object, giving each
# a simple two-entry MRO:
#   JSONDecoder -> [JSONDecoder, object] -> len 2
#   JSONEncoder -> [JSONEncoder, object] -> len 2
# json_extra25 noted these MRO lengths in prose/notes but the table invariants
# there focused on __bases__[0].__name__ and __init__ qualnames.
# This provides explicit python_call_eq invariants for the MRO lengths.
# ---------------------------------------------------------------------------

table json_extra27.class_mro_lens:
  description: "json.JSONDecoder and json.JSONEncoder __mro__.__len__() == 2 — both inherit directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: jml27

  columns: [id, function, args, expected]
  rows:
    - [JSONDecoder, JSONDecoder.__mro__.__len__, [], 2]
    - [JSONEncoder, JSONEncoder.__mro__.__len__, [], 2]
