spec: struct_extra410
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct module functions (pack, unpack, calcsize, iter_unpack, pack_into, unpack_from) are C builtin functions. For C builtins, __qualname__ equals __name__ — there is no enclosing class scope in the qualname. This contrasts with pure-Python class methods where __qualname__ is prefixed with the class name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module function __name__ values
#
# Wave 410 theme: struct module top-level function name identity.
#
# The struct module's top-level functions (pack, unpack, calcsize,
# iter_unpack, pack_into, unpack_from) are C builtin functions implemented
# in the _struct C extension. Each function's __name__ is the bare function
# name without any module prefix.
#
# Covered functions: pack, unpack, calcsize, iter_unpack, pack_into,
#                    unpack_from
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra410.function_names:
  description: "struct module function __name__ values — pack, unpack, calcsize, iter_unpack, pack_into, unpack_from are C builtins whose __name__ is the bare function name; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: structfn410

  columns: [id, function, args, expected]
  rows:
    - [pack_name,         pack.__name__.__eq__,         ["pack"],         true]
    - [unpack_name,       unpack.__name__.__eq__,       ["unpack"],       true]
    - [calcsize_name,     calcsize.__name__.__eq__,     ["calcsize"],     true]
    - [iter_unpack_name,  iter_unpack.__name__.__eq__,  ["iter_unpack"],  true]
    - [pack_into_name,    pack_into.__name__.__eq__,    ["pack_into"],    true]
    - [unpack_from_name,  unpack_from.__name__.__eq__,  ["unpack_from"],  true]

# ---------------------------------------------------------------------------
# struct module function __qualname__ values
#
# For C builtin functions, __qualname__ equals __name__ — there is no class
# or closure scope in the qualname. This is the standard CPython behavior
# for module-level C functions defined via PyMethodDef. It contrasts with
# pure-Python class methods where __qualname__ is 'ClassName.method_name'.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra410.function_qualnames:
  description: "struct module function __qualname__ values — for C builtins, __qualname__ equals __name__ with no class prefix; contrasts with pure-Python methods where qualname includes the class name; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: structfq410

  columns: [id, function, args, expected]
  rows:
    - [pack_qualname,         pack.__qualname__.__eq__,         ["pack"],         true]
    - [unpack_qualname,       unpack.__qualname__.__eq__,       ["unpack"],       true]
    - [calcsize_qualname,     calcsize.__qualname__.__eq__,     ["calcsize"],     true]
    - [iter_unpack_qualname,  iter_unpack.__qualname__.__eq__,  ["iter_unpack"],  true]
    - [pack_into_qualname,    pack_into.__qualname__.__eq__,    ["pack_into"],    true]
    - [unpack_from_qualname,  unpack_from.__qualname__.__eq__,  ["unpack_from"],  true]
