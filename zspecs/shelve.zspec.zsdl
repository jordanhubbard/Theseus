spec: shelve
version: ">=3.0"
backend: python_module(shelve)

docs: https://docs.python.org/3/library/shelve.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/shelve.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "shelve source: Lib/shelve.py (PSF; source inspection permitted)"
  not_derived_from:
    - "shelve source: internal dbm backend implementation details"
  notes:
    - "shelve.open() returns a DbfilenameShelf, which is a subclass of Shelf."
    - "Shelf inherits from MutableMapping (collections.abc), providing dict-like semantics."
    - "DbfilenameShelf.__module__ == 'shelve' — both primary classes live in the shelve module."
    - "BsdDbShelf is present in the shelve namespace but requires the bsddb3 third-party package at runtime."
    - "shelve stores values as pickled byte strings keyed by string keys."
    - "shelve.open() accepts flag='r'/'w'/'c'/'n' matching dbm.open() semantics."
    - "All expected values verified by running Python 3.12 shelve module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name metadata
# ---------------------------------------------------------------------------

invariant shelve.open_name:
  description: "shelve.open.__name__ == 'open'"
  category: functions
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

table shelve.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [shelf,           Shelf.__name__.__eq__,           ["Shelf"],           true]
    - [dbfilenameshelf, DbfilenameShelf.__name__.__eq__,  ["DbfilenameShelf"], true]
    - [bsddbshelf,      BsdDbShelf.__name__.__eq__,       ["BsdDbShelf"],      true]

# ---------------------------------------------------------------------------
# Module membership — both primary classes live in shelve
# ---------------------------------------------------------------------------

table shelve.class_modules:
  kind: python_call_eq
  category: modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [shelf_module,    Shelf.__module__.__eq__,           ["shelve"], true]
    - [dbfilename_mod,  DbfilenameShelf.__module__.__eq__,  ["shelve"], true]

# ---------------------------------------------------------------------------
# Inheritance chain
# ---------------------------------------------------------------------------

invariant shelve.shelf_base_is_mutablemapping:
  description: "Shelf.__bases__[0].__name__ == 'MutableMapping' — Shelf subclasses MutableMapping"
  category: inheritance
  kind: python_call_eq
  function: Shelf.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["MutableMapping"]
  expected: true

invariant shelve.dbfilenameshelf_base_is_shelf:
  description: "DbfilenameShelf.__bases__[0].__name__ == 'Shelf' — DbfilenameShelf subclasses Shelf"
  category: inheritance
  kind: python_call_eq
  function: DbfilenameShelf.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Shelf"]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-04-15T13:27:35Z
  iterations: 3
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 3 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
