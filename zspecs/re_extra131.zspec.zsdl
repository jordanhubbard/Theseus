spec: re_extra131
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re.Match method __qualname__ values and lengths."
    - "re.Match methods are C extension methods (method_descriptor); they do NOT have __code__."
    - "re.Match.__class__.__name__ == 'type' (re.Match is a C extension class)."
    - "re.Match.group.__qualname__ == 'Match.group' (length 11)."
    - "re.Match.groups.__qualname__ == 'Match.groups' (length 12)."
    - "re.Match.span.__qualname__ == 'Match.span' (length 10)."
    - "re.Match.expand.__qualname__ == 'Match.expand' (length 12)."
    - "re.Match.start.__qualname__ == 'Match.start' (length 11)."
    - "re.Match.end.__qualname__ == 'Match.end' (length 9)."
    - "re.Match.groupdict.__qualname__ == 'Match.groupdict' (length 15)."
    - "re.Match.re.__qualname__ == 'Match.re' (length 8)."
    - "re.Match.pos.__qualname__ == 'Match.pos' (length 9)."
    - "re.Match.endpos.__qualname__ == 'Match.endpos' (length 12)."
    - "re.Match.lastindex.__qualname__ == 'Match.lastindex' (length 15)."
    - "re.Match.lastgroup.__qualname__ == 'Match.lastgroup' (length 15)."
    - "re.Match.string.__qualname__ == 'Match.string' (length 12)."
    - "re.Match.regs.__qualname__ == 'Match.regs' (length 10)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match core extraction method __qualname__ lengths
# group (len 11), groups (len 12), span (len 10), expand (len 12).
# group and start share length 11; groups/expand/string/endpos share length 12.
# ---------------------------------------------------------------------------

table re_extra131.Match_core_method_qualnames:
  description: "re.Match core extraction method __qualname__ values: group='Match.group'(11), groups='Match.groups'(12), span='Match.span'(10), expand='Match.expand'(12)"
  kind: python_call_eq
  category: qualname
  id_prefix: rematch131

  columns: [id, function, args, expected]
  rows:
    - [group_qname_eq,   Match.group.__qualname__.__eq__,   ["Match.group"],   true]
    - [group_qname_len,  Match.group.__qualname__.__len__,  [],                11]
    - [groups_qname_eq,  Match.groups.__qualname__.__eq__,  ["Match.groups"],  true]
    - [groups_qname_len, Match.groups.__qualname__.__len__, [],                12]
    - [span_qname_eq,    Match.span.__qualname__.__eq__,    ["Match.span"],    true]
    - [span_qname_len,   Match.span.__qualname__.__len__,   [],                10]
    - [expand_qname_eq,  Match.expand.__qualname__.__eq__,  ["Match.expand"],  true]
    - [expand_qname_len, Match.expand.__qualname__.__len__, [],                12]

# ---------------------------------------------------------------------------
# re.Match position method __qualname__ lengths
# start (len 11), end (len 9), groupdict (len 15).
# end is the shortest at length 9; groupdict is the longest at length 15.
# ---------------------------------------------------------------------------

table re_extra131.Match_position_method_qualnames:
  description: "re.Match position method __qualname__ values: start='Match.start'(11), end='Match.end'(9), groupdict='Match.groupdict'(15)"
  kind: python_call_eq
  category: qualname
  id_prefix: rematch131

  columns: [id, function, args, expected]
  rows:
    - [start_qname_eq,     Match.start.__qualname__.__eq__,     ["Match.start"],     true]
    - [start_qname_len,    Match.start.__qualname__.__len__,    [],                  11]
    - [end_qname_eq,       Match.end.__qualname__.__eq__,       ["Match.end"],       true]
    - [end_qname_len,      Match.end.__qualname__.__len__,      [],                  9]
    - [groupdict_qname_eq, Match.groupdict.__qualname__.__eq__, ["Match.groupdict"], true]
    - [groupdict_qname_len,Match.groupdict.__qualname__.__len__,[],                  15]
    - [start_gt_end,       Match.start.__qualname__.__len__,    [],                  11]
    - [groupdict_gt_start, Match.groupdict.__qualname__.__len__,[],                  15]

# ---------------------------------------------------------------------------
# re.Match attribute __qualname__ lengths
# re (len 8), pos (len 9), endpos (len 12), string (len 12), regs (len 10),
# lastindex (len 15), lastgroup (len 15).
# ---------------------------------------------------------------------------

table re_extra131.Match_attribute_qualnames:
  description: "re.Match attribute __qualname__ values: re='Match.re'(8), pos='Match.pos'(9), regs='Match.regs'(10), endpos='Match.endpos'(12), string='Match.string'(12), lastindex='Match.lastindex'(15), lastgroup='Match.lastgroup'(15)"
  kind: python_call_eq
  category: qualname
  id_prefix: rematch131

  columns: [id, function, args, expected]
  rows:
    - [re_qname_eq,        Match.re.__qualname__.__eq__,        ["Match.re"],        true]
    - [re_qname_len,       Match.re.__qualname__.__len__,       [],                  8]
    - [pos_qname_eq,       Match.pos.__qualname__.__eq__,       ["Match.pos"],       true]
    - [pos_qname_len,      Match.pos.__qualname__.__len__,      [],                  9]
    - [regs_qname_eq,      Match.regs.__qualname__.__eq__,      ["Match.regs"],      true]
    - [regs_qname_len,     Match.regs.__qualname__.__len__,     [],                  10]
    - [endpos_qname_eq,    Match.endpos.__qualname__.__eq__,    ["Match.endpos"],    true]
    - [endpos_qname_len,   Match.endpos.__qualname__.__len__,   [],                  12]
    - [string_qname_eq,    Match.string.__qualname__.__eq__,    ["Match.string"],    true]
    - [string_qname_len,   Match.string.__qualname__.__len__,   [],                  12]
    - [lastindex_qname_eq, Match.lastindex.__qualname__.__eq__, ["Match.lastindex"], true]
    - [lastindex_qname_len,Match.lastindex.__qualname__.__len__,[],                  15]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra131.Match.group_qualname_eq:
  description: "re.Match.group.__qualname__ == 'Match.group' (length 11; re.Match methods are C extension method_descriptors with no __code__)"
  category: qualname
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra131.Match.span_qualname_len:
  description: "re.Match.span.__qualname__.__len__() == 10 ('Match.span' has 10 characters)"
  category: qualname
  kind: python_call_eq
  function: Match.span.__qualname__.__len__
  args: []
  expected: 10

invariant re_extra131.Match.groupdict_qualname_eq:
  description: "re.Match.groupdict.__qualname__ == 'Match.groupdict' (length 15; same length as lastindex and lastgroup)"
  category: qualname
  kind: python_call_eq
  function: Match.groupdict.__qualname__.__eq__
  args: ["Match.groupdict"]
  expected: true

invariant re_extra131.Match.re_qualname_len:
  description: "re.Match.re.__qualname__.__len__() == 8 ('Match.re' has 8 characters; shortest qualname among re.Match attributes)"
  category: qualname
  kind: python_call_eq
  function: Match.re.__qualname__.__len__
  args: []
  expected: 8

invariant re_extra131.Match.lastindex_qualname_eq:
  description: "re.Match.lastindex.__qualname__ == 'Match.lastindex' (length 15; same length as groupdict and lastgroup)"
  category: qualname
  kind: python_call_eq
  function: Match.lastindex.__qualname__.__eq__
  args: ["Match.lastindex"]
  expected: true
