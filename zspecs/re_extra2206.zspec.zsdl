spec: re_extra2206
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2206 (re_extra2206): rich comparison operator protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "re.Pattern defines all six comparison dunders (__lt__, __le__, __gt__, __ge__, __eq__, __ne__) in its own __dict__ — compiled regex patterns support ordering and equality comparison, useful for sorted collections and deduplication."
    - "re.Match does NOT define any of the six comparison dunders in its own __dict__ — match objects use default object identity semantics."
    - "re.RegexFlag does NOT define any of the six comparison dunders in its own __dict__ — RegexFlag is an IntFlag subclass; its comparison operators are inherited from int and are not redefined in the class body."
    - "re.error does NOT define any of the six comparison dunders in its own __dict__ — exception classes rely on object identity for comparison."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra2206.pattern_comparison_protocol:
  description: "re.Pattern rich comparison operator dict-presence checks — compiled pattern type defines all six comparison operators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2206

  columns: [id, function, args, expected]
  rows:
    - ["re2206001", "re.Pattern.__dict__.__contains__", ["__lt__"], true]
    - ["re2206002", "re.Pattern.__dict__.__contains__", ["__le__"], true]
    - ["re2206003", "re.Pattern.__dict__.__contains__", ["__gt__"], true]
    - ["re2206004", "re.Pattern.__dict__.__contains__", ["__ge__"], true]
    - ["re2206005", "re.Pattern.__dict__.__contains__", ["__eq__"], true]
    - ["re2206006", "re.Pattern.__dict__.__contains__", ["__ne__"], true]

table re_extra2206.match_comparison_protocol:
  description: "re.Match rich comparison operator dict-presence checks — match object type defines none of the six comparison operators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2206

  columns: [id, function, args, expected]
  rows:
    - ["re2206007", "re.Match.__dict__.__contains__", ["__lt__"], false]
    - ["re2206008", "re.Match.__dict__.__contains__", ["__le__"], false]
    - ["re2206009", "re.Match.__dict__.__contains__", ["__gt__"], false]
    - ["re2206010", "re.Match.__dict__.__contains__", ["__ge__"], false]
    - ["re2206011", "re.Match.__dict__.__contains__", ["__eq__"], false]
    - ["re2206012", "re.Match.__dict__.__contains__", ["__ne__"], false]

table re_extra2206.regexflag_comparison_protocol:
  description: "re.RegexFlag rich comparison operator dict-presence checks — IntFlag subclass does not redefine comparison operators in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2206

  columns: [id, function, args, expected]
  rows:
    - ["re2206013", "re.RegexFlag.__dict__.__contains__", ["__lt__"], false]
    - ["re2206014", "re.RegexFlag.__dict__.__contains__", ["__le__"], false]
    - ["re2206015", "re.RegexFlag.__dict__.__contains__", ["__gt__"], false]
    - ["re2206016", "re.RegexFlag.__dict__.__contains__", ["__ge__"], false]
    - ["re2206017", "re.RegexFlag.__dict__.__contains__", ["__eq__"], false]
    - ["re2206018", "re.RegexFlag.__dict__.__contains__", ["__ne__"], false]

