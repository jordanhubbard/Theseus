spec: doctest_extra4
version: ">=3.9"
backend: python_module(doctest)

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/doctest.html — Python doctest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/doctest.py"
  notes:
    - "This spec extends doctest.zspec.zsdl, doctest_extra.zspec.zsdl, doctest_extra2.zspec.zsdl, and doctest_extra3.zspec.zsdl."
    - "Focus: __qualname__ attributes for doctest classes, functions, and constants not yet covered."
    - "doctest.DocTest.__qualname__ == 'DocTest' — top-level class, qualname equals name."
    - "doctest.DocTestFinder.__qualname__ == 'DocTestFinder'."
    - "doctest.DocTestRunner.__qualname__ == 'DocTestRunner'."
    - "doctest.DocTestSuite.__qualname__ == 'DocTestSuite'."
    - "doctest.DocTestParser.__qualname__ == 'DocTestParser'."
    - "doctest.Example.__qualname__ == 'Example'."
    - "doctest.DocTestFailure.__qualname__ == 'DocTestFailure'."
    - "doctest.UnexpectedException.__qualname__ == 'UnexpectedException'."
    - "doctest.testmod.__qualname__ == 'testmod' — module-level function."
    - "doctest.testfile.__qualname__ == 'testfile'."
    - "doctest.run_docstring_examples.__qualname__ == 'run_docstring_examples'."
    - "doctest.ELLIPSIS.__class__.__name__ == 'int' — ELLIPSIS is an integer option flag."
    - "doctest.NORMALIZE_WHITESPACE.__class__.__name__ == 'int' — NORMALIZE_WHITESPACE is an integer flag."
    - "doctest.DocTest.__module__ == 'doctest' — all public doctest classes are defined in doctest."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — class objects
# Prior specs cover __name__; this spec adds the parallel __qualname__ table.
# ---------------------------------------------------------------------------

table doctest_extra4.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [DocTest,             DocTest.__qualname__.__eq__,             ["DocTest"],             true]
    - [DocTestFinder,       DocTestFinder.__qualname__.__eq__,       ["DocTestFinder"],       true]
    - [DocTestRunner,       DocTestRunner.__qualname__.__eq__,       ["DocTestRunner"],       true]
    - [DocTestSuite,        DocTestSuite.__qualname__.__eq__,        ["DocTestSuite"],        true]
    - [DocTestParser,       DocTestParser.__qualname__.__eq__,       ["DocTestParser"],       true]
    - [Example,             Example.__qualname__.__eq__,             ["Example"],             true]
    - [DocTestFailure,      DocTestFailure.__qualname__.__eq__,      ["DocTestFailure"],      true]
    - [UnexpectedException, UnexpectedException.__qualname__.__eq__, ["UnexpectedException"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — module-level functions
# ---------------------------------------------------------------------------

table doctest_extra4.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [testmod,                 testmod.__qualname__.__eq__,                 ["testmod"],                 true]
    - [testfile,                testfile.__qualname__.__eq__,                ["testfile"],                true]
    - [run_docstring_examples,  run_docstring_examples.__qualname__.__eq__,  ["run_docstring_examples"],  true]

# ---------------------------------------------------------------------------
# Option flag class name checks
# These verify that ELLIPSIS and NORMALIZE_WHITESPACE are int instances.
# doctest_extra3 covers IGNORE_EXCEPTION_DETAIL via a similar table;
# this table focuses on ELLIPSIS and NORMALIZE_WHITESPACE as a new pair.
# ---------------------------------------------------------------------------

table doctest_extra4.flag_class_names:
  kind: python_call_eq
  category: flag_types
  id_prefix: flagclass

  columns: [id, function, args, expected]
  rows:
    - [ELLIPSIS,             ELLIPSIS.__class__.__name__.__eq__,             ["int"], true]
    - [NORMALIZE_WHITESPACE, NORMALIZE_WHITESPACE.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# __module__ check — DocTest (all public classes defined in doctest)
# ---------------------------------------------------------------------------

invariant doctest_extra4.DocTest.module:
  description: "doctest.DocTest.__module__ == 'doctest'"
  category: modules
  kind: python_call_eq
  function: DocTest.__module__.__eq__
  args: ["doctest"]
  expected: true
