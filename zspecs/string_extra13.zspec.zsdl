spec: string_extra13
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra12.zspec.zsdl."
    - "string_extra12 covers: hexdigits/octdigits/printable/punctuation startswith checks; Formatter().vformat positional; capwords four-word input; Template punctuation-suffix substitute."
    - "string_extra11 covers: digits.startswith('0'); octdigits.endswith('7'); hexdigits.endswith('F'); Formatter/Template name and behavior."
    - "string_extra8 covers: standalone __len__ for all constants; Formatter/Template __name__/__module__."
    - "string_extra7 covers: hexdigits contains A/f/G; whitespace vtab/ff membership; digits first/last char via __getitem__."
    - "string_extra6 covers: whitespace CR/tab membership; punctuation membership; ascii_letters z/Z/not-0 membership."
    - "NOT yet covered: string.ascii_lowercase.__contains__('a') == True — lowercase-specific membership."
    - "NOT yet covered: string.ascii_lowercase.__contains__('z') == True — last lowercase letter membership."
    - "NOT yet covered: string.digits.__contains__('5') == True — mid-range digit membership."
    - "NOT yet covered: string.octdigits.__contains__('7') == True — last octal digit membership."
    - "NOT yet covered: string.octdigits.__contains__('8') == False — '8' is not an octal digit."
    - "NOT yet covered: string.hexdigits.__contains__('9') == True — '9' is in hexdigits."
    - "NOT yet covered: string.whitespace.__contains__(' ') == True — space character membership."
    - "NOT yet covered: string.ascii_lowercase[0] == 'a' — index access on lowercase constant."
    - "NOT yet covered: string.ascii_uppercase[-1] == 'Z' — last char via negative index on uppercase constant."
    - "NOT yet covered: string.capwords('the quick brown fox jumps') == 'The Quick Brown Fox Jumps' — five-word input."
    - "string.ascii_lowercase.__contains__('a') == True — 'a' is in ascii_lowercase (not ascii_letters)."
    - "string.ascii_lowercase.__contains__('z') == True — 'z' is the last ascii_lowercase letter."
    - "string.digits.__contains__('5') == True — '5' is a mid-range digit."
    - "string.octdigits.__contains__('7') == True — '7' is the last octal digit."
    - "string.octdigits.__contains__('8') == False — '8' is not an octal digit (0-7 only)."
    - "string.hexdigits.__contains__('9') == True — '9' is in both digits and hexdigits."
    - "string.whitespace.__contains__(' ') == True — ASCII space is whitespace."
    - "string.ascii_lowercase[0] == 'a' — first element of 'abcdefghijklmnopqrstuvwxyz'."
    - "string.ascii_uppercase[-1] == 'Z' — last element via negative index."
    - "string.capwords('the quick brown fox jumps') == 'The Quick Brown Fox Jumps' — five words."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ascii_lowercase.__contains__ — 'a' and 'z'
#
# Prior specs test ascii_letters.__contains__('z') and ascii_letters.__contains__('Z')
# (string_extra3, string_extra6), but these use the combined ascii_letters constant.
# No prior spec tests ascii_lowercase.__contains__ directly for any character.
# ascii_lowercase.__contains__('a') == True (first letter).
# ascii_lowercase.__contains__('z') == True (last letter).
# ---------------------------------------------------------------------------

invariant string_extra13.ascii_lowercase.contains_a:
  description: "string.ascii_lowercase.__contains__('a') == True — 'a' is in ascii_lowercase"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.__contains__
  args: ["a"]
  expected: true

invariant string_extra13.ascii_lowercase.contains_z:
  description: "string.ascii_lowercase.__contains__('z') == True — 'z' is in ascii_lowercase"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.__contains__
  args: ["z"]
  expected: true

# ---------------------------------------------------------------------------
# digits.__contains__('5') — mid-range digit
#
# string_extra3 covers digits.__contains__('a') == False.
# string_extra6 covers digits.__contains__('a') == False and ('9') == True.
# No prior spec tests digits.__contains__('5') as a standalone invariant.
# '5' is a mid-range digit (neither first nor last).
# ---------------------------------------------------------------------------

invariant string_extra13.digits.contains_five:
  description: "string.digits.__contains__('5') == True — '5' is a mid-range digit"
  category: constants
  kind: python_call_eq
  function: digits.__contains__
  args: ["5"]
  expected: true

# ---------------------------------------------------------------------------
# octdigits.__contains__ — '7' (True) and '8' (False)
#
# No prior spec tests octdigits.__contains__ for any character.
# octdigits == '01234567'; '7' is the last octal digit (True);
# '8' is the first non-octal digit (False).
# ---------------------------------------------------------------------------

invariant string_extra13.octdigits.contains_seven:
  description: "string.octdigits.__contains__('7') == True — '7' is the last octal digit"
  category: constants
  kind: python_call_eq
  function: octdigits.__contains__
  args: ["7"]
  expected: true

invariant string_extra13.octdigits.contains_eight_false:
  description: "string.octdigits.__contains__('8') == False — '8' is not an octal digit"
  category: constants
  kind: python_call_eq
  function: octdigits.__contains__
  args: ["8"]
  expected: false

# ---------------------------------------------------------------------------
# hexdigits.__contains__('9') — digit present in both digits and hexdigits
#
# string_extra7 covers hexdigits.__contains__('A') == True,
# hexdigits.__contains__('f') == True, and hexdigits.__contains__('G') == False.
# No prior spec tests hexdigits.__contains__('9'). The character '9' is present
# in both the decimal digits portion and the hex digit set.
# ---------------------------------------------------------------------------

invariant string_extra13.hexdigits.contains_nine:
  description: "string.hexdigits.__contains__('9') == True — '9' is in hexdigits"
  category: constants
  kind: python_call_eq
  function: hexdigits.__contains__
  args: ["9"]
  expected: true

# ---------------------------------------------------------------------------
# whitespace.__contains__(' ') — ASCII space character
#
# string_extra2 covers whitespace.__contains__('\n') == True.
# string_extra6 covers whitespace.__contains__('\r') == True,
#   whitespace.__contains__('\t') == True, and whitespace.__contains__('a') == False.
# string_extra7 covers whitespace.__contains__('\x0b') == True (vertical tab).
# No prior spec tests whitespace.__contains__(' ') (plain space character).
# ---------------------------------------------------------------------------

invariant string_extra13.whitespace.contains_space:
  description: "string.whitespace.__contains__(' ') == True — ASCII space is whitespace"
  category: constants
  kind: python_call_eq
  function: whitespace.__contains__
  args: [" "]
  expected: true

# ---------------------------------------------------------------------------
# ascii_lowercase[0] and ascii_uppercase[-1] — index access
#
# string_extra7 covers digits[0] == '0' and digits[-1] == '9' via __getitem__.
# No prior spec uses __getitem__ on ascii_lowercase or ascii_uppercase.
# ascii_lowercase[0] == 'a' (first letter); ascii_uppercase[-1] == 'Z' (last letter).
# ---------------------------------------------------------------------------

invariant string_extra13.ascii_lowercase.first_char:
  description: "string.ascii_lowercase[0] == 'a' — first character of ascii_lowercase"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.__getitem__
  args: [0]
  expected: "a"

invariant string_extra13.ascii_uppercase.last_char:
  description: "string.ascii_uppercase[-1] == 'Z' — last character via negative index"
  category: constants
  kind: python_call_eq
  function: ascii_uppercase.__getitem__
  args: [-1]
  expected: "Z"

# ---------------------------------------------------------------------------
# capwords — five-word input
#
# string_extra12 covers capwords('fox in a box') == 'Fox In A Box' (four words).
# Prior specs cover two, three, and four word inputs.
# No prior spec uses a five-word input:
# capwords('the quick brown fox jumps') == 'The Quick Brown Fox Jumps'.
# ---------------------------------------------------------------------------

invariant string_extra13.capwords.five_words:
  description: "string.capwords('the quick brown fox jumps') == 'The Quick Brown Fox Jumps' — five words"
  category: capwords
  kind: python_call_eq
  function: capwords
  args: ["the quick brown fox jumps"]
  expected: "The Quick Brown Fox Jumps"

# ---------------------------------------------------------------------------
# Table: octdigits and hexdigits membership boundary checks
#
# Groups the new __contains__ vectors for octdigits and hexdigits in one table.
# ---------------------------------------------------------------------------

table string_extra13.octhex_contains:
  description: "octdigits and hexdigits __contains__ boundary checks — extra13 namespace"
  kind: python_call_eq
  category: constants
  id_prefix: ohc

  columns: [id, function, args, expected]
  rows:
    - [oct_seven,    octdigits.__contains__,  ["7"], true]
    - [oct_eight,    octdigits.__contains__,  ["8"], false]
    - [hex_nine,     hexdigits.__contains__,  ["9"], true]
