spec: decimal_extra263
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "decimal.Decimal arithmetic dunder methods (__add__, __sub__, __mul__, __truediv__, __abs__) are wrapper_descriptor objects."
    - "decimal.Decimal numeric methods (quantize, to_integral_value, sqrt, ln, log10) are method_descriptor objects."
    - "Dunder method qualnames follow 'Decimal.<method_name>' pattern."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: Decimal dunder method __name__ identity
# ---------------------------------------------------------------------------

table decimal_extra263.decimal_dunder_names:
  description: "decimal.Decimal dunder method __name__ for __add__, __sub__, __mul__, __truediv__, __abs__"
  kind: python_call_eq
  category: identity
  id_prefix: dn

  columns: [id, function, args, expected, description]
  rows:
    - [add_name,      Decimal.__add__.__name__.__eq__,      ["__add__"],      true, "decimal.Decimal.__add__.__name__ == '__add__'"]
    - [sub_name,      Decimal.__sub__.__name__.__eq__,      ["__sub__"],      true, "decimal.Decimal.__sub__.__name__ == '__sub__'"]
    - [mul_name,      Decimal.__mul__.__name__.__eq__,      ["__mul__"],      true, "decimal.Decimal.__mul__.__name__ == '__mul__'"]
    - [truediv_name,  Decimal.__truediv__.__name__.__eq__,  ["__truediv__"],  true, "decimal.Decimal.__truediv__.__name__ == '__truediv__'"]
    - [abs_name,      Decimal.__abs__.__name__.__eq__,      ["__abs__"],      true, "decimal.Decimal.__abs__.__name__ == '__abs__'"]

# ---------------------------------------------------------------------------
# Table: Decimal dunder method __class__.__name__ (all wrapper_descriptor)
# ---------------------------------------------------------------------------

table decimal_extra263.decimal_dunder_classes:
  description: "decimal.Decimal dunder method __class__.__name__ for __add__, __sub__, __mul__, __truediv__, __abs__"
  kind: python_call_eq
  category: identity
  id_prefix: dcls

  columns: [id, function, args, expected, description]
  rows:
    - [add_class,     Decimal.__add__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor'"]
    - [sub_class,     Decimal.__sub__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "decimal.Decimal.__sub__.__class__.__name__ == 'wrapper_descriptor'"]
    - [mul_class,     Decimal.__mul__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "decimal.Decimal.__mul__.__class__.__name__ == 'wrapper_descriptor'"]
    - [truediv_class, Decimal.__truediv__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "decimal.Decimal.__truediv__.__class__.__name__ == 'wrapper_descriptor'"]
    - [abs_class,     Decimal.__abs__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "decimal.Decimal.__abs__.__class__.__name__ == 'wrapper_descriptor'"]

# ---------------------------------------------------------------------------
# Table: Decimal numeric method identity — name, class, qualname
# ---------------------------------------------------------------------------

table decimal_extra263.decimal_numeric_methods:
  description: "decimal.Decimal numeric method __name__, __class__.__name__, __qualname__ for quantize, to_integral_value, sqrt, ln, log10"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [quantize_name,          Decimal.quantize.__name__.__eq__,             ["quantize"],          true, "decimal.Decimal.quantize.__name__ == 'quantize'"]
    - [quantize_class,         Decimal.quantize.__class__.__name__.__eq__,   ["method_descriptor"], true, "decimal.Decimal.quantize.__class__.__name__ == 'method_descriptor'"]
    - [quantize_qualname,      Decimal.quantize.__qualname__.__eq__,         ["Decimal.quantize"],  true, "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize'"]
    - [to_integral_name,       Decimal.to_integral_value.__name__.__eq__,    ["to_integral_value"], true, "decimal.Decimal.to_integral_value.__name__ == 'to_integral_value'"]
    - [to_integral_class,      Decimal.to_integral_value.__class__.__name__.__eq__, ["method_descriptor"], true, "decimal.Decimal.to_integral_value.__class__.__name__ == 'method_descriptor'"]
    - [to_integral_qualname,   Decimal.to_integral_value.__qualname__.__eq__, ["Decimal.to_integral_value"], true, "decimal.Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value'"]
    - [sqrt_name,              Decimal.sqrt.__name__.__eq__,                 ["sqrt"],              true, "decimal.Decimal.sqrt.__name__ == 'sqrt'"]
    - [sqrt_class,             Decimal.sqrt.__class__.__name__.__eq__,       ["method_descriptor"], true, "decimal.Decimal.sqrt.__class__.__name__ == 'method_descriptor'"]
    - [ln_name,                Decimal.ln.__name__.__eq__,                   ["ln"],                true, "decimal.Decimal.ln.__name__ == 'ln'"]
    - [ln_class,               Decimal.ln.__class__.__name__.__eq__,         ["method_descriptor"], true, "decimal.Decimal.ln.__class__.__name__ == 'method_descriptor'"]
    - [log10_name,             Decimal.log10.__name__.__eq__,                ["log10"],             true, "decimal.Decimal.log10.__name__ == 'log10'"]
    - [log10_class,            Decimal.log10.__class__.__name__.__eq__,      ["method_descriptor"], true, "decimal.Decimal.log10.__class__.__name__ == 'method_descriptor'"]

# ---------------------------------------------------------------------------
# Standalone invariants: cross-checks for Decimal methods
# ---------------------------------------------------------------------------

invariant decimal_extra263.Decimal.__add__.is_wrapper_descriptor:
  description: "decimal.Decimal.__add__ is a wrapper_descriptor (C slot wrapper for arithmetic)"
  category: identity
  kind: python_call_eq
  function: Decimal.__add__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra263.Decimal.quantize.is_method_descriptor:
  description: "decimal.Decimal.quantize is a method_descriptor (C-extension method)"
  category: identity
  kind: python_call_eq
  function: Decimal.quantize.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra263.Decimal.__add__.qualname:
  description: "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__add__.__qualname__.__eq__
  args: ["Decimal.__add__"]
  expected: true

invariant decimal_extra263.Decimal.sqrt.qualname:
  description: "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt'"
  category: identity
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__eq__
  args: ["Decimal.sqrt"]
  expected: true
