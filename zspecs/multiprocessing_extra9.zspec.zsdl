spec: multiprocessing_extra9
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra8.zspec.zsdl."
    - "multiprocessing_extra8 covers: class hierarchy (__bases__[0].__name__) for Process/ProcessError/AuthenticationError/TimeoutError; MRO[1] for ProcessError/AuthenticationError/TimeoutError; __name__/__module__ for get_context/get_start_method/set_start_method."
    - "multiprocessing_extra2 covers: __name__ and __module__ for BoundedSemaphore/Barrier/Condition/RLock; __module__ for Pool/Lock/Event/Semaphore/Value/Array/Manager/Pipe/Queue."
    - "multiprocessing_extra covers: Process.__module__, Process base class, factory __name__ for Pool/Lock/Event/Semaphore/Value/Array/Manager."
    - "This spec adds NEW axes:"
    - "  (1) BufferTooShort.__name__/__qualname__/__module__/__bases__[0].__name__ — no prior spec covers any attribute of BufferTooShort beyond its class name in multiprocessing.exception_names."
    - "  (2) RLock.__qualname__ — extra2 checks __name__/__module__ but not __qualname__."
    - "  (3) parent_process.__name__/__qualname__/__module__ — multiprocessing.function_names covers __name__; __qualname__ and __module__ are new."
    - "  (4) BoundedSemaphore.__qualname__ and Barrier.__qualname__ and Condition.__qualname__ — extra2 covers __name__/__module__ but not __qualname__."
    - "  (5) Process.__mro__[2].__name__ == 'object' — extra8 adds MRO[1] checks for exception classes; Process MRO[2] is new."
    - "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort' (covered in multiprocessing.exception_names but not as a standalone invariant)."
    - "multiprocessing.BufferTooShort.__qualname__ == 'BufferTooShort' — top-level exception class."
    - "multiprocessing.BufferTooShort.__module__ == 'multiprocessing.context' — defined via context.py."
    - "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError' — subclass of ProcessError."
    - "multiprocessing.RLock.__qualname__ == 'RLock' — extra2 has __name__/__module__ only."
    - "multiprocessing.parent_process.__qualname__ == 'parent_process' — top-level function."
    - "multiprocessing.parent_process.__module__ == 'multiprocessing.process' — defined in process.py."
    - "multiprocessing.BoundedSemaphore.__qualname__ == 'BoundedSemaphore'."
    - "multiprocessing.Barrier.__qualname__ == 'Barrier'."
    - "multiprocessing.Condition.__qualname__ == 'Condition'."
    - "multiprocessing.Process.__mro__[2].__name__ == 'object' — at index 2 (after Process and BaseProcess)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BufferTooShort — comprehensive coverage
#
# multiprocessing.exception_names (base spec) checks BufferTooShort.__name__.
# No prior spec checks __qualname__, __module__, or __bases__[0].__name__.
# BufferTooShort is raised when the buffer in Connection.recv_bytes_into() is
# too small to hold the incoming message. It inherits from ProcessError.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra9.BufferTooShort.qualname:
  description: "multiprocessing.BufferTooShort.__qualname__ == 'BufferTooShort' — top-level exception"
  category: exception_qualnames
  kind: python_call_eq
  function: BufferTooShort.__qualname__.__eq__
  args: ["BufferTooShort"]
  expected: true

invariant multiprocessing_extra9.BufferTooShort.module:
  description: "multiprocessing.BufferTooShort.__module__ == 'multiprocessing.context'"
  category: exception_modules
  kind: python_call_eq
  function: BufferTooShort.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra9.BufferTooShort.base_is_ProcessError:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: BufferTooShort.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ProcessError"

# ---------------------------------------------------------------------------
# RLock __qualname__
#
# multiprocessing_extra2 checks RLock.__name__ == 'RLock' and
# RLock.__module__ == 'multiprocessing.context'. No prior spec verifies
# RLock.__qualname__. For a top-level symbol __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra9.RLock.qualname:
  description: "multiprocessing.RLock.__qualname__ == 'RLock' — top-level factory function"
  category: qualnames
  kind: python_call_eq
  function: RLock.__qualname__.__eq__
  args: ["RLock"]
  expected: true

# ---------------------------------------------------------------------------
# parent_process — __qualname__ and __module__
#
# multiprocessing.zspec covers parent_process.__name__ == 'parent_process' via
# the function_names table. No prior spec checks __qualname__ or __module__.
# parent_process is defined in multiprocessing.process; its __qualname__ equals
# its __name__ since it is a top-level function.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra9.parent_process.qualname:
  description: "multiprocessing.parent_process.__qualname__ == 'parent_process'"
  category: function_qualnames
  kind: python_call_eq
  function: parent_process.__qualname__.__eq__
  args: ["parent_process"]
  expected: true

invariant multiprocessing_extra9.parent_process.module:
  description: "multiprocessing.parent_process.__module__ == 'multiprocessing.process'"
  category: function_modules
  kind: python_call_eq
  function: parent_process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

# ---------------------------------------------------------------------------
# BoundedSemaphore, Barrier, Condition __qualname__
#
# multiprocessing_extra2 checks __name__ and __module__ for these three.
# No prior spec verifies __qualname__. For top-level symbols __qualname__ == __name__.
# ---------------------------------------------------------------------------

table multiprocessing_extra9.extra_primitive_qualnames:
  description: "multiprocessing extra synchronization primitives have correct __qualname__"
  kind: python_call_eq
  category: qualnames
  id_prefix: pqualname

  columns: [id, function, args, expected]
  rows:
    - [BoundedSemaphore, BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true]
    - [Barrier,          Barrier.__qualname__.__eq__,          ["Barrier"],          true]
    - [Condition,        Condition.__qualname__.__eq__,        ["Condition"],        true]

# ---------------------------------------------------------------------------
# Process MRO[2] — deep hierarchy check
#
# multiprocessing_extra8 adds MRO[1] for ProcessError/AuthenticationError/
# TimeoutError. Process itself has MRO: [Process, BaseProcess, object].
# MRO[1] is BaseProcess (not previously checked for Process);
# MRO[2] is object. Neither has been verified in any prior spec.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra9.Process.mro_index1:
  description: "multiprocessing.Process.__mro__[1].__name__ == 'BaseProcess' — MRO confirms inheritance"
  category: class_hierarchy
  kind: python_call_eq
  function: Process.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "BaseProcess"

invariant multiprocessing_extra9.Process.mro_index2:
  description: "multiprocessing.Process.__mro__[2].__name__ == 'object' — top of the hierarchy"
  category: class_hierarchy
  kind: python_call_eq
  function: Process.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"
