spec: multiprocessing_extra187
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.Process.start.__name__ == 'start' (len=5)"
    - "multiprocessing.Process.run.__name__ == 'run' (len=3)"
    - "multiprocessing.Process.join.__name__ == 'join' (len=4)"
    - "multiprocessing.Process.is_alive.__name__ == 'is_alive' (len=8)"
    - "multiprocessing.Process.terminate.__name__ == 'terminate' (len=9)"
    - "multiprocessing.Process.kill.__name__ == 'kill' (len=4)"
    - "multiprocessing.Process.close.__name__ == 'close' (len=5)"
    - "Length ordering: run(3) < join(4)==kill(4) < start(5)==close(5) < is_alive(8) < terminate(9)"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process short-name methods (run, join, kill)
#
# multiprocessing.Process.run.__name__.__eq__('run') == True (len=3)
# multiprocessing.Process.join.__name__.__eq__('join') == True (len=4)
# multiprocessing.Process.kill.__name__.__eq__('kill') == True (len=4)
# ---------------------------------------------------------------------------

table multiprocessing_extra187.process_short_names:
  description: "multiprocessing.Process short method names: run(3), join(4), kill(4); verified with Python 3.14.3; new to multiprocessing_extra187"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocessmethods187

  columns: [id, function, args, expected, description]
  rows:
    - [run_name_eq,
       Process.run.__name__.__eq__,
       ["run"],
       true,
       "multiprocessing.Process.run.__name__.__eq__('run') == True — method name is 'run', len=3; shortest Process method name; str.__eq__ returns True; new to multiprocessing_extra187"]
    - [join_name_eq,
       Process.join.__name__.__eq__,
       ["join"],
       true,
       "multiprocessing.Process.join.__name__.__eq__('join') == True — method name is 'join', len=4; str.__eq__ returns True; new to multiprocessing_extra187"]
    - [kill_name_eq,
       Process.kill.__name__.__eq__,
       ["kill"],
       true,
       "multiprocessing.Process.kill.__name__.__eq__('kill') == True — method name is 'kill', len=4; same length as 'join'; str.__eq__ returns True; new to multiprocessing_extra187"]
    - [run_name_len,
       Process.run.__name__.__len__,
       [],
       3,
       "multiprocessing.Process.run.__name__.__len__() == 3 — 'run' has 3 characters; shortest in ordering; str.__len__() returns 3; new to multiprocessing_extra187"]
    - [join_name_len,
       Process.join.__name__.__len__,
       [],
       4,
       "multiprocessing.Process.join.__name__.__len__() == 4 — 'join' has 4 characters; str.__len__() returns 4; new to multiprocessing_extra187"]

