# ---------------------------------------------------------------------------
# Table 3: multiprocessing.Process longest method and full length ordering
#
# multiprocessing.Process.terminate.__name__.__eq__('terminate') == True (len=9)
# Length ordering: run(3) < join(4)==kill(4) < start(5)==close(5) < is_alive(8) < terminate(9)
# ---------------------------------------------------------------------------

table multiprocessing_extra187.process_long_name_and_ordering:
  description: "multiprocessing.Process longest method terminate(9) and full length ordering; verified with Python 3.14.3; new to multiprocessing_extra187"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocessmethods187

  columns: [id, function, args, expected, description]
  rows:
    - [terminate_name_eq,
       Process.terminate.__name__.__eq__,
       ["terminate"],
       true,
       "multiprocessing.Process.terminate.__name__.__eq__('terminate') == True — method name is 'terminate', len=9; longest Process method name; str.__eq__ returns True; new to multiprocessing_extra187"]
    - [terminate_name_len,
       Process.terminate.__name__.__len__,
       [],
       9,
       "multiprocessing.Process.terminate.__name__.__len__() == 9 — 'terminate' has 9 characters; ordering ceiling; str.__len__() returns 9; new to multiprocessing_extra187"]
    - [run_name_len_ordering,
       Process.run.__name__.__len__,
       [],
       3,
       "multiprocessing.Process.run.__name__.__len__() == 3 — ordering anchor: run(3) is shortest; run(3) < join(4)==kill(4) < start(5)==close(5) < is_alive(8) < terminate(9); new to multiprocessing_extra187"]
    - [is_alive_name_len_ordering,
       Process.is_alive.__name__.__len__,
       [],
       8,
       "multiprocessing.Process.is_alive.__name__.__len__() == 8 — ordering: start(5)==close(5) < is_alive(8) < terminate(9); str.__len__() returns 8; new to multiprocessing_extra187"]
    - [kill_name_len_ordering,
       Process.kill.__name__.__len__,
       [],
       4,
       "multiprocessing.Process.kill.__name__.__len__() == 4 — ordering: run(3) < kill(4)==join(4) < start(5); str.__len__() returns 4; new to multiprocessing_extra187"]

