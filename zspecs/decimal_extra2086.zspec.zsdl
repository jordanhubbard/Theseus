spec: decimal_extra2086
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal.zspec.zsdl"
    - "decimal_extra1876.zspec.zsdl"
  notes:
    - "Wave extra2086, theme: __format__ string formatting protocol dict-presence; __bytes__ bytes conversion dict-presence; __fspath__ filesystem path protocol dict-presence; __buffer__/__release_buffer__ buffer protocol dict-presence."
    - "decimal.Decimal defines __format__ in its own __dict__ (True) — it provides custom format spec handling per IEEE 754 decimal arithmetic."
    - "decimal.Context does NOT define __format__ in its own __dict__ (False) — Context instances are not directly format-specifier-aware."
    - "Neither decimal.Decimal nor decimal.Context defines __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "decimal.Decimal.__format__ accepts a format spec string per PEP 3101 and the decimal module format mini-language."
    - "All expected values verified by running Python 3.12 decimal module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __format__ string formatting protocol dict-presence
# ---------------------------------------------------------------------------

table decimal_extra2086.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["dc2086001", "decimal.Decimal.__dict__.__contains__", ["__format__"], true]
    - ["dc2086002", "decimal.Context.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# __bytes__ bytes conversion protocol dict-presence
# ---------------------------------------------------------------------------

table decimal_extra2086.bytes_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["dc2086003", "decimal.Decimal.__dict__.__contains__", ["__bytes__"], false]
    - ["dc2086004", "decimal.Context.__dict__.__contains__", ["__bytes__"], false]

