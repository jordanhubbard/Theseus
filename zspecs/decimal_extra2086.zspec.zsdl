    - ["dc2086008", "decimal.Decimal.__dict__.__contains__", ["__release_buffer__"], false]
    - ["dc2086009", "decimal.Context.__dict__.__contains__", ["__buffer__"], false]
    - ["dc2086010", "decimal.Context.__dict__.__contains__", ["__release_buffer__"], false]

# ---------------------------------------------------------------------------
# Cross-protocol summary — Decimal and Context own-dict membership
# ---------------------------------------------------------------------------

table decimal_extra2086.decimal_dict_summary:
  columns: [id, function, args, expected]
  rows:
    - ["dc2086011", "decimal.Decimal.__dict__.__contains__", ["__format__"], true]
    - ["dc2086012", "decimal.Decimal.__dict__.__contains__", ["__bytes__"], false]
    - ["dc2086013", "decimal.Decimal.__dict__.__contains__", ["__fspath__"], false]
    - ["dc2086014", "decimal.Decimal.__dict__.__contains__", ["__buffer__"], false]
    - ["dc2086015", "decimal.Decimal.__dict__.__contains__", ["__release_buffer__"], false]
    - ["dc2086016", "decimal.Context.__dict__.__contains__", ["__format__"], false]
    - ["dc2086017", "decimal.Context.__dict__.__contains__", ["__bytes__"], false]
    - ["dc2086018", "decimal.Context.__dict__.__contains__", ["__fspath__"], false]
    - ["dc2086019", "decimal.Context.__dict__.__contains__", ["__buffer__"], false]
    - ["dc2086020", "decimal.Context.__dict__.__contains__", ["__release_buffer__"], false]

