spec: inspect_extra103
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra102

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra102.zspec.zsdl."
    - "This spec covers: inspect FrameInfo and Traceback namedtuple class identity (__class__.__name__, __module__, __bases__[0].__name__, __mro__ length); inspect Signature/Parameter/BoundArguments class qualnames; inspect frame-introspection function qualnames; wave 260."
    - "inspect.FrameInfo.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__mro__.__len__() == 4. Verified with Python 3.14.3."
    - "inspect.Traceback.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Traceback.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Traceback.__bases__[0].__name__ == '_Traceback'. Verified with Python 3.14.3."
    - "inspect.Traceback.__mro__.__len__() == 4. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__qualname__ == 'getframeinfo' (len 12). Verified with Python 3.14.3."
    - "inspect.stack.__qualname__ == 'stack' (len 5). Verified with Python 3.14.3."
    - "inspect.currentframe.__qualname__ == 'currentframe' (len 12). Verified with Python 3.14.3."
    - "inspect.Signature.__qualname__ == 'Signature' (len 9). Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter' (len 9). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__qualname__ == 'BoundArguments' (len 14). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.FrameInfo namedtuple class identity
#
# Wave 260 theme: inspect FrameInfo namedtuple class introspection.
#
# inspect.FrameInfo.__class__.__name__ == 'type'
# inspect.FrameInfo.__module__ == 'inspect'
# inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'
# inspect.FrameInfo.__mro__.__len__() == 4
#
# FrameInfo is a NamedTuple-derived class defined in Lib/inspect.py.
# Its MRO is [FrameInfo, _FrameInfo, tuple, object] (depth 4).
# _FrameInfo is the generated namedtuple base class. New to extra103.
# ---------------------------------------------------------------------------

table inspect_extra103.frameinfo_class_identity:
  description: "inspect.FrameInfo class identity: __class__.__name__=='type', __module__=='inspect', __bases__[0].__name__=='_FrameInfo', __mro__ len==4; wave 260; new to extra103"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfi103

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_class_name_eq_type,
       "FrameInfo.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.FrameInfo.__class__.__name__.__eq__('type') == True — FrameInfo is a Python class created by NamedTuple; all classes in Python 3 are instances of 'type' (or a metaclass); FrameInfo.__class__ is type, so __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra103"]
    - [frameinfo_module_eq_inspect,
       "FrameInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra103"]
    - [frameinfo_base_name_eq_FrameInfo,
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — FrameInfo inherits from _FrameInfo, the anonymous namedtuple base class generated by collections.namedtuple for the FrameInfo fields; __bases__[0].__name__ is '_FrameInfo'; str.__eq__('_FrameInfo') returns True; new to extra103"]
    - [frameinfo_mro_len_eq_4,
       "FrameInfo.__mro__.__len__",
       [],
       4,
       "inspect.FrameInfo.__mro__.__len__() == 4 — the MRO of FrameInfo is [FrameInfo, _FrameInfo, tuple, object]; len of this tuple is 4; new to extra103"]
    - [frameinfo_module_len_eq_7,
       "FrameInfo.__module__.__len__",
       [],
       7,
       "inspect.FrameInfo.__module__.__len__() == 7 — FrameInfo.__module__ is 'inspect'; len('inspect') == 7 (i-n-s-p-e-c-t); new to extra103"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Traceback namedtuple class identity
#
# Wave 260 theme: inspect Traceback namedtuple class introspection.
#
# inspect.Traceback.__class__.__name__ == 'type'
# inspect.Traceback.__module__ == 'inspect'
# inspect.Traceback.__bases__[0].__name__ == '_Traceback'
# inspect.Traceback.__mro__.__len__() == 4
#
# Traceback is a NamedTuple-derived class with fields
# (filename, lineno, function, code_context, index).
# Its MRO is [Traceback, _Traceback, tuple, object] (depth 4). New to extra103.
# ---------------------------------------------------------------------------

table inspect_extra103.traceback_class_identity:
  description: "inspect.Traceback class identity: __class__.__name__=='type', __module__=='inspect', __bases__[0].__name__=='_Traceback', __mro__ len==4; wave 260; new to extra103"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspecttr103

  columns: [id, function, args, expected, description]
  rows:
    - [traceback_class_name_eq_type,
       "Traceback.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Traceback.__class__.__name__.__eq__('type') == True — Traceback is a NamedTuple class and therefore an instance of type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra103"]
    - [traceback_module_eq_inspect,
       "Traceback.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Traceback.__module__.__eq__('inspect') == True — Traceback is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra103"]
    - [traceback_base_name_eq_Traceback,
       "Traceback.__bases__[0].__name__.__eq__",
       ["_Traceback"],
       true,
       "inspect.Traceback.__bases__[0].__name__.__eq__('_Traceback') == True — Traceback inherits from _Traceback, the anonymous namedtuple base class generated for the Traceback fields (filename, lineno, function, code_context, index); __bases__[0].__name__ is '_Traceback'; str.__eq__('_Traceback') returns True; new to extra103"]
    - [traceback_mro_len_eq_4,
       "Traceback.__mro__.__len__",
       [],
       4,
       "inspect.Traceback.__mro__.__len__() == 4 — the MRO of Traceback is [Traceback, _Traceback, tuple, object]; len of this tuple is 4; same depth as FrameInfo; new to extra103"]
    - [traceback_module_len_eq_7,
       "Traceback.__module__.__len__",
       [],
       7,
       "inspect.Traceback.__module__.__len__() == 7 — Traceback.__module__ is 'inspect'; len('inspect') == 7; new to extra103"]

# ---------------------------------------------------------------------------
# Table 3: inspect frame-introspection and signature function qualnames
#
# Wave 260 theme: inspect frame-introspection function __qualname__ lengths.
#
# inspect.getframeinfo.__qualname__ == 'getframeinfo' (len 12)
# inspect.stack.__qualname__ == 'stack' (len 5)
# inspect.currentframe.__qualname__ == 'currentframe' (len 12)
# inspect.Signature.__qualname__ == 'Signature' (len 9)
# inspect.Parameter.__qualname__ == 'Parameter' (len 9)
# inspect.BoundArguments.__qualname__ == 'BoundArguments' (len 14)
#
# Frame-introspection functions and signature classes are module-scope
# objects in Lib/inspect.py. New to extra103.
# ---------------------------------------------------------------------------

table inspect_extra103.frame_signature_qualnames:
  description: "inspect frame/signature qualnames: getframeinfo/currentframe 12, stack 5, Signature/Parameter 9, BoundArguments 14; wave 260; new to extra103"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectframe103

  columns: [id, function, args, expected, description]
  rows:
    - [getframeinfo_qualname_len_eq_12,
       "getframeinfo.__qualname__.__len__",
       [],
       12,
       "inspect.getframeinfo.__qualname__.__len__() == 12 — getframeinfo returns a Traceback namedtuple for the given frame; it is a module-scope function in Lib/inspect.py; its __qualname__ is 'getframeinfo'; len('getframeinfo') == 12 (g-e-t-f-r-a-m-e-i-n-f-o); new to extra103"]
    - [stack_qualname_len_eq_5,
       "stack.__qualname__.__len__",
       [],
       5,
       "inspect.stack.__qualname__.__len__() == 5 — inspect.stack returns a list of FrameInfo namedtuples for the current call stack; it is a module-scope function in Lib/inspect.py; its __qualname__ is 'stack'; len('stack') == 5 (s-t-a-c-k); new to extra103"]
    - [currentframe_qualname_len_eq_12,
       "currentframe.__qualname__.__len__",
       [],
       12,
       "inspect.currentframe.__qualname__.__len__() == 12 — inspect.currentframe returns the frame object for the caller's current execution frame; its __qualname__ is 'currentframe'; len('currentframe') == 12 (c-u-r-r-e-n-t-f-r-a-m-e); new to extra103"]
    - [signature_qualname_class_len_eq_9,
       "Signature.__qualname__.__len__",
       [],
       9,
       "inspect.Signature.__qualname__.__len__() == 9 — Signature is the class that represents the calling convention of a callable, with parameters and return annotation; its __qualname__ is 'Signature'; len('Signature') == 9 (S-i-g-n-a-t-u-r-e); new to extra103"]
    - [parameter_qualname_len_eq_9,
       "Parameter.__qualname__.__len__",
       [],
       9,
       "inspect.Parameter.__qualname__.__len__() == 9 — Parameter represents a function parameter in a Signature; its __qualname__ is 'Parameter'; len('Parameter') == 9 (P-a-r-a-m-e-t-e-r); new to extra103"]
    - [boundarguments_qualname_len_eq_14,
       "BoundArguments.__qualname__.__len__",
       [],
       14,
       "inspect.BoundArguments.__qualname__.__len__() == 14 — BoundArguments represents arguments bound to a Signature via Signature.bind(); its __qualname__ is 'BoundArguments'; len('BoundArguments') == 14 (B-o-u-n-d-A-r-g-u-m-e-n-t-s); new to extra103"]
    - [getframeinfo_qualname_eq,
       "getframeinfo.__qualname__.__eq__",
       ["getframeinfo"],
       true,
       "inspect.getframeinfo.__qualname__.__eq__('getframeinfo') == True — getframeinfo is a module-scope function in Lib/inspect.py; its __qualname__ is 'getframeinfo'; str.__eq__('getframeinfo') returns True; new to extra103"]
    - [stack_qualname_eq,
       "stack.__qualname__.__eq__",
       ["stack"],
       true,
       "inspect.stack.__qualname__.__eq__('stack') == True — inspect.stack is a module-scope function in Lib/inspect.py that returns the call stack as FrameInfo namedtuples; its __qualname__ is 'stack'; str.__eq__('stack') returns True; new to extra103"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra103
# ---------------------------------------------------------------------------

invariant inspect_extra103.frameinfo_class_name:
  description: "inspect.FrameInfo.__class__.__name__ == 'type' — FrameInfo is a NamedTuple class, instance of type; wave 260; new to extra103"
  kind: python_call_eq
  function: FrameInfo.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra103.frameinfo_mro_len:
  description: "inspect.FrameInfo.__mro__.__len__() == 4 — MRO is [FrameInfo, _FrameInfo, tuple, object]; wave 260; new to extra103"
  kind: python_call_eq
  function: FrameInfo.__mro__.__len__
  args: []
  expected: 4

invariant inspect_extra103.traceback_module:
  description: "inspect.Traceback.__module__ == 'inspect' — Traceback is defined in Lib/inspect.py; wave 260; new to extra103"
  kind: python_call_eq
  function: Traceback.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra103.traceback_mro_len:
  description: "inspect.Traceback.__mro__.__len__() == 4 — MRO is [Traceback, _Traceback, tuple, object]; wave 260; new to extra103"
  kind: python_call_eq
  function: Traceback.__mro__.__len__
  args: []
  expected: 4

invariant inspect_extra103.getframeinfo_qualname_len:
  description: "len(inspect.getframeinfo.__qualname__) == 12 — qualname is 'getframeinfo'; wave 260; new to extra103"
  kind: python_call_eq
  function: getframeinfo.__qualname__.__len__
  args: []
  expected: 12

invariant inspect_extra103.boundarguments_qualname_len:
  description: "len(inspect.BoundArguments.__qualname__) == 14 — qualname is 'BoundArguments'; wave 260; new to extra103"
  kind: python_call_eq
  function: BoundArguments.__qualname__.__len__
  args: []
  expected: 14
