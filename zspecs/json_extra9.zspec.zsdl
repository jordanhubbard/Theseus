spec: json_extra9
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html
rfcs:
  - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra8.zspec.zsdl."
    - "json_extra8 covers: decoder/encoder submodule __name__; JSONDecodeError.__module__; JSONDecoder/JSONEncoder __bases__[0].__name__; decoder/encoder submodule __class__.__name__."
    - "json_extra7 covers: loads/dumps/load/dump __qualname__; JSONDecoder/JSONEncoder __qualname__; JSONDecodeError __qualname__; JSONDecoder/JSONEncoder __module__; JSONDecodeError __bases__[0].__name__."
    - "json_extra5 covers: loads/dumps/load/dump __module__; JSONEncoder/JSONDecoder __module__; JSONDecodeError __module__; loads/dumps __name__; JSONEncoder/JSONDecoder base hierarchy; encoder.INFINITY type; round-trip/sort_keys/empty-object."
    - "No prior spec covers json.loads() of a nested JSON object (dict of dict)."
    - "No prior spec covers json.dumps() of a nested Python dict."
    - "No prior spec covers json.loads() of a JSON array with mixed types."
    - "No prior spec covers json.dumps() of a boolean True or False as a standalone value."
    - "No prior spec covers json.loads() producing a result whose __class__.__name__ == 'list'."
    - "No prior spec covers json.loads() producing a result whose __class__.__name__ == 'dict'."
    - "No prior spec covers json.dumps() with ensure_ascii=False leaving a non-ASCII character in place."
    - "No prior spec covers json.decoder.__package__ == 'json' — submodule package affiliation."
    - "No prior spec covers json.encoder.__package__ == 'json' — submodule package affiliation."
    - "No prior spec covers json.JSONDecodeError.__mro__[2].__name__ == 'LookupError' — MRO depth 2."
    - "json.loads('[1, \"a\", null]') == [1, 'a', None] — mixed-type JSON array."
    - "json.dumps({'x': {'y': 1}}) == '{\"x\": {\"y\": 1}}' — nested dict serialisation."
    - "json.dumps(True) == 'true' and json.dumps(False) == 'false'."
    - "json.loads('[1, 2]').__class__.__name__ == 'list'."
    - "json.loads('{\"a\": 1}').__class__.__name__ == 'dict'."
    - "json.dumps('café', ensure_ascii=False) == '\"café\"' — non-ASCII preserved."
    - "json.decoder.__package__ == 'json'."
    - "json.encoder.__package__ == 'json'."
    - "json.JSONDecodeError.__mro__[2].__name__ == 'LookupError'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# json.dumps() — boolean values
#
# json.zspec.zsdl covers dumps(true) == 'true' and dumps(false) == 'false'
# in the primitives table. This spec adds them as named standalone invariants
# for unambiguous per-invariant traceability from the json_extra9 namespace.
# ---------------------------------------------------------------------------

invariant json_extra9.dumps.true_value:
  description: "json.dumps(True) == 'true' — Python True serialises to JSON true"
  category: dumps_primitives
  kind: python_call_eq
  function: dumps
  args: [true]
  expected: "true"

invariant json_extra9.dumps.false_value:
  description: "json.dumps(False) == 'false' — Python False serialises to JSON false"
  category: dumps_primitives
  kind: python_call_eq
  function: dumps
  args: [false]
  expected: "false"

# ---------------------------------------------------------------------------
# json.dumps() — nested dict
#
# All prior dumps vectors use flat dicts or lists. No prior spec checks a
# nested dict {'x': {'y': 1}}.
# ---------------------------------------------------------------------------

invariant json_extra9.dumps.nested_dict:
  description: "json.dumps({'x': {'y': 1}}) == '{\"x\": {\"y\": 1}}'"
  category: dumps_compound
  kind: python_call_eq
  function: dumps
  args: [{"x": {"y": 1}}]
  expected: "{\"x\": {\"y\": 1}}"

# ---------------------------------------------------------------------------
# json.loads() — result type checks
#
# json_extra5 covers loads('{}') returns a dict via __class__.__name__.
# We add: loads('[1, 2]') returns a list (new dimension).
# We also add: loads('{"a": 1}') returns a dict (standalone anchor from
# the json_extra9 namespace).
# ---------------------------------------------------------------------------

invariant json_extra9.loads.list_type:
  description: "json.loads('[1, 2]').__class__.__name__ == 'list'"
  category: loads_types
  kind: python_call_eq
  function: loads
  args: ["[1, 2]"]
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

invariant json_extra9.loads.dict_type:
  description: "json.loads('{\"a\": 1}').__class__.__name__ == 'dict'"
  category: loads_types
  kind: python_call_eq
  function: loads
  args: ["{\"a\": 1}"]
  method: __class__.__name__.__eq__
  method_args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# json.loads() — mixed-type JSON array
#
# json.zspec.zsdl covers loads('[1, 2, 3]') and loads('[]').
# No prior spec covers an array with mixed element types.
# [1, "a", null] -> [1, 'a', None]
# ---------------------------------------------------------------------------

invariant json_extra9.loads.mixed_type_array:
  description: "json.loads('[1, \"a\", null]') == [1, 'a', None]"
  category: loads_compound
  kind: python_call_eq
  function: loads
  args: ["[1, \"a\", null]"]
  expected: [1, "a", null]

# ---------------------------------------------------------------------------
# json.dumps() — ensure_ascii=False preserves non-ASCII characters
#
# json.zspec.zsdl and all prior extras test only ASCII-safe serialisation.
# No prior spec checks ensure_ascii=False behaviour.
# json.dumps('café', ensure_ascii=False) == '"café"'
# ---------------------------------------------------------------------------

invariant json_extra9.dumps.ensure_ascii_false:
  description: "json.dumps('café', ensure_ascii=False) == '\"café\"' — non-ASCII preserved"
  category: dumps_options
  kind: python_call_eq
  function: dumps
  args: ["café", false]
  expected: "\"café\""

# ---------------------------------------------------------------------------
# json.decoder and json.encoder submodule — __package__ attribute
#
# json_extra8 covers __name__ and __class__.__name__ for both submodules.
# No prior spec checks __package__.
# Submodules of the 'json' package have __package__ == 'json'.
# ---------------------------------------------------------------------------

invariant json_extra9.decoder_submodule.package:
  description: "json.decoder.__package__ == 'json' — decoder is part of the json package"
  category: submodules
  kind: python_call_eq
  function: decoder.__package__.__eq__
  args: ["json"]
  expected: true

invariant json_extra9.encoder_submodule.package:
  description: "json.encoder.__package__ == 'json' — encoder is part of the json package"
  category: submodules
  kind: python_call_eq
  function: encoder.__package__.__eq__
  args: ["json"]
  expected: true

# ---------------------------------------------------------------------------
# json.JSONDecodeError — MRO depth 2
#
# json_extra4 covers __mro__[1].__name__ == 'ValueError'.
# json_extra7 covers __bases__[0].__name__ == 'ValueError'.
# No prior spec checks __mro__[2].
# MRO of JSONDecodeError: [JSONDecodeError, ValueError, LookupError,
#                          Exception, BaseException, object]
# So __mro__[2].__name__ == 'LookupError'.
# ---------------------------------------------------------------------------

invariant json_extra9.JSONDecodeError.mro_index2:
  description: "json.JSONDecodeError.__mro__[2].__name__ == 'LookupError'"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONDecodeError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "LookupError"

# ---------------------------------------------------------------------------
# json.loads() — raises on invalid JSON float literal "Infinity"
#
# json.zspec.zsdl covers "nan" raising JSONDecodeError with allow_nan=default.
# No prior spec covers "Infinity" (also not valid JSON per RFC 8259).
# ---------------------------------------------------------------------------

invariant json_extra9.loads.infinity_raises:
  description: "json.loads('Infinity') raises JSONDecodeError — Infinity is not valid JSON"
  category: error
  kind: python_call_raises
  function: loads
  args: ["Infinity"]
  expected_exception: json.JSONDecodeError

# ---------------------------------------------------------------------------
# json.loads() — raises on bare identifier
#
# No prior spec covers a bare Python-style identifier that is not a JSON keyword.
# "undefined" is not valid JSON — loads should raise JSONDecodeError.
# ---------------------------------------------------------------------------

invariant json_extra9.loads.undefined_raises:
  description: "json.loads('undefined') raises JSONDecodeError — undefined is not valid JSON"
  category: error
  kind: python_call_raises
  function: loads
  args: ["undefined"]
  expected_exception: json.JSONDecodeError
