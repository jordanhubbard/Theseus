spec: struct_extra138
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra137.zspec.zsdl — covers struct.pack/__doc__/__class__.__name__.__eq__('str') / Struct.format.__doc__/__len__()==20 / Struct.size.__doc__/__len__()==20 / format vs size __doc__ inequality / module function __doc__ length ordering (calcsize/unpack/pack/pack_into) (table + invariants)."
    - "struct_extra136.zspec.zsdl — covers struct.Struct method __doc__ lengths (pack/pack_into/unpack/unpack_from/iter_unpack) / module-level pack_into/unpack_from/iter_unpack __doc__ lengths / module-level vs Struct-method __doc__ inequality table."
    - "struct_extra135.zspec.zsdl — covers struct.Struct.__eq__ inherited from object / struct.error MRO member names / struct module-level function __doc__ lengths (pack/unpack/calcsize) / struct.__doc__.__len__() and __class__.__name__."
    - "struct_extra134.zspec.zsdl — covers struct.__spec__ and __loader__ attribute identity / Struct method __doc__ lengths (pack/unpack/pack_into/unpack_from/iter_unpack) / Struct class __doc__ identity."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths / Struct.size and Struct.format __doc__ equality and lengths / struct module __doc__ length."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() / error.__name__/__len__()."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__()."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra137."
    - "Wave 295 theme: Struct method __qualname__ string equality (pack/unpack/pack_into/unpack_from/iter_unpack) / __qualname__ length ordering among Struct methods / struct.error.__name__.__eq__('error') / struct.error.__bases__[0].__name__.__eq__('Exception') and length (9)."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' (len 18). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' (len 18). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error' (len 5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct method qualname lengths follow the 'Struct.<method>' pattern (7-char 'Struct.' prefix + method name length): pack=11 (7+4), unpack=13 (7+6), pack_into=16 (7+9), unpack_from=18 (7+11), iter_unpack=18 (7+11). unpack_from and iter_unpack tie at 18 chars because 'unpack_from' and 'iter_unpack' are both 11 chars."
    - "Note: struct.error.__bases__[0].__name__ is 'Exception' (9 chars). struct.error inherits directly from Exception, making it a simple user-visible error class without an intermediate hierarchy. extra93 anchors error __bases__ broadly; this spec anchors __bases__[0].__name__ equality and length specifically."
    - "Note: The qualname length ordering among Struct methods is pack (11) < unpack (13) < pack_into (16) < unpack_from == iter_unpack (18). The two longest qualnames tie because both method names are 11 chars. extra94 anchors these lengths individually; this spec anchors the equality check for unpack_from and iter_unpack lengths and the qualname string equality values."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack')
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack')
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into')
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from')
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')
#
# Wave 295 theme: Struct method __qualname__ string equality.
#
# All five Struct methods follow the 'Struct.<method>' qualname pattern with
# the 7-char 'Struct.' prefix. extra94 anchors qualname lengths; no prior
# struct spec anchors the qualname equality strings as a table under structqn138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra138.Struct_method_qualname_equality:
  description: "struct.Struct.pack/__qualname__.__eq__('Struct.pack')==True / Struct.unpack/__qualname__.__eq__('Struct.unpack')==True / Struct.pack_into/__qualname__.__eq__('Struct.pack_into')==True / Struct.unpack_from/__qualname__.__eq__('Struct.unpack_from')==True / Struct.iter_unpack/__qualname__.__eq__('Struct.iter_unpack')==True — all follow 'Struct.<method>' pattern (7-char prefix); extra94 anchors lengths; first structqn138 anchor for qualname equality strings"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: structqn138

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_eq,        Struct.pack.__qualname__.__eq__,        ["Struct.pack"],        true, "struct.Struct.pack.__qualname__ == 'Struct.pack' (7-char 'Struct.' prefix + 4-char 'pack'; total 11)"]
    - [unpack_qualname_eq,      Struct.unpack.__qualname__.__eq__,      ["Struct.unpack"],      true, "struct.Struct.unpack.__qualname__ == 'Struct.unpack' (7-char 'Struct.' prefix + 6-char 'unpack'; total 13)"]
    - [pack_into_qualname_eq,   Struct.pack_into.__qualname__.__eq__,   ["Struct.pack_into"],   true, "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' (7-char prefix + 9-char 'pack_into'; total 16)"]
    - [unpack_from_qualname_eq, Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true, "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' (7-char prefix + 11-char 'unpack_from'; total 18)"]
    - [iter_unpack_qualname_eq, Struct.iter_unpack.__qualname__.__eq__, ["Struct.iter_unpack"], true, "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' (7-char prefix + 11-char 'iter_unpack'; total 18)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__len__()==11
# struct.Struct.unpack.__qualname__.__len__()==13
# struct.Struct.pack_into.__qualname__.__len__()==16
# struct.Struct.unpack_from.__qualname__.__len__()==18
# struct.Struct.iter_unpack.__qualname__.__len__()==18
#
# Wave 295 theme: Struct method __qualname__ length ordering.
#
# The qualname length ordering is pack (11) < unpack (13) < pack_into (16) <
# unpack_from == iter_unpack (18). unpack_from and iter_unpack tie because both
# method names are 11 chars. extra94 anchors these lengths at the individual
# method level; this table groups them to show the full ordering under structqn138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra138.Struct_method_qualname_length_ordering:
  description: "struct.Struct.pack/__qualname__/__len__()==11 / unpack/__qualname__/__len__()==13 / pack_into/__qualname__/__len__()==16 / unpack_from/__qualname__/__len__()==18 / iter_unpack/__qualname__/__len__()==18 — ordering: pack(11) < unpack(13) < pack_into(16) < unpack_from==iter_unpack(18); last two tie because 'unpack_from' and 'iter_unpack' are both 11 chars; extra94 anchors individually; this table shows the complete ordering under structqn138"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: structqn138

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_len,        Struct.pack.__qualname__.__len__,        [], 11, "struct.Struct.pack.__qualname__.__len__() is 11 ('Struct.pack' = 7 + 4 chars)"]
    - [unpack_qualname_len,      Struct.unpack.__qualname__.__len__,      [], 13, "struct.Struct.unpack.__qualname__.__len__() is 13 ('Struct.unpack' = 7 + 6 chars)"]
    - [pack_into_qualname_len,   Struct.pack_into.__qualname__.__len__,   [], 16, "struct.Struct.pack_into.__qualname__.__len__() is 16 ('Struct.pack_into' = 7 + 9 chars)"]
    - [unpack_from_qualname_len, Struct.unpack_from.__qualname__.__len__, [], 18, "struct.Struct.unpack_from.__qualname__.__len__() is 18 ('Struct.unpack_from' = 7 + 11 chars)"]
    - [iter_unpack_qualname_len, Struct.iter_unpack.__qualname__.__len__, [], 18, "struct.Struct.iter_unpack.__qualname__.__len__() is 18 ('Struct.iter_unpack' = 7 + 11 chars; ties with unpack_from)"]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error')
# struct.error.__bases__[0].__name__.__eq__('Exception')
# struct.error.__bases__[0].__name__.__len__()==9
# struct.error.__qualname__.__eq__('error')
#
# Wave 295 theme: struct.error name and bases identity.
#
# struct.error.__name__ is 'error' (5 chars). Its only base class is Exception
# (9 chars). struct.error.__qualname__ == 'error'. extra93 anchors error __bases__
# and __module__ broadly; extra96 anchors __name__.__len__()==5; no prior struct spec
# anchors error.__bases__[0].__name__ equality and length together under structqn138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra138.error_name_and_bases:
  description: "struct.error/__name__.__eq__('error')==True / __qualname__.__eq__('error')==True / __bases__[0].__name__.__eq__('Exception')==True / __bases__[0].__name__/__len__()==9 — struct.error is a simple exception class inheriting directly from Exception (9 chars); __name__ and __qualname__ are both 'error' (5 chars); extra93 covers error bases broadly; extra96 anchors __name__.__len__()==5; first structqn138 anchor for bases name equality and length"
  kind: python_call_eq
  category: identity
  id_prefix: structqn138

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,        error.__name__.__eq__,              ["error"],     true, "struct.error.__name__ == 'error' (5 chars; all-lowercase unlike most exception names)"]
    - [error_qualname_eq,    error.__qualname__.__eq__,          ["error"],     true, "struct.error.__qualname__ == 'error' (same as __name__; error is a top-level class in struct module)"]
    - [error_base_name_eq,   "error.__bases__[0].__name__.__eq__",  ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception' (direct single-level inheritance from Exception)"]
    - [error_base_name_len,  "error.__bases__[0].__name__.__len__", [],           9,    "struct.error.__bases__[0].__name__.__len__() is 9 ('Exception' = 9 chars)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack'. The 7-char 'Struct.' prefix
# indicates that pack is a method of the Struct class (not a module-level function).
# At 11 chars total, pack has the shortest qualname of the five Struct methods —
# because 'pack' (4 chars) is the shortest method name. extra94 anchors the length;
# no prior struct spec anchors the equality string as a standalone under structqn138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra138.Struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — 'Struct.pack' (11 chars = 7-char prefix + 4-char 'pack'); shortest Struct method qualname because 'pack' (4) is the shortest method name; extra94 anchors the length; first standalone for qualname equality under structqn138"
  category: qualname_identity
  kind: python_call_eq
  function: Struct.pack.__qualname__.__eq__
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') — standalone
#
# struct.Struct.unpack_from.__qualname__ is 'Struct.unpack_from' (18 chars).
# At 18 chars, unpack_from ties with iter_unpack for the longest Struct method
# qualname because both method names ('unpack_from' and 'iter_unpack') are 11
# chars. The 'unpack_from' method unpacks bytes from a buffer at a given offset,
# returning a tuple — the counterpart to pack_into. No prior struct spec anchors
# this equality string as a standalone under structqn138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra138.Struct_unpack_from_qualname_eq:
  description: "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — 'Struct.unpack_from' (18 chars = 7-char prefix + 11-char 'unpack_from'); ties with iter_unpack (also 18) as longest Struct method qualname; counterpart to pack_into; no prior struct spec anchors this as a standalone; first standalone under structqn138"
  category: qualname_identity
  kind: python_call_eq
  function: Struct.unpack_from.__qualname__.__eq__
  args: ["Struct.unpack_from"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') — standalone
#
# struct.Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack' (18 chars).
# At 18 chars, iter_unpack ties with unpack_from for the longest Struct method
# qualname. iter_unpack is the most recently added of the five Struct methods
# (added in Python 3.4 for memory-efficient repeated unpacking). No prior struct
# spec anchors this equality string as a standalone under structqn138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra138.Struct_iter_unpack_qualname_eq:
  description: "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') == True — 'Struct.iter_unpack' (18 chars = 7-char prefix + 11-char 'iter_unpack'); ties with unpack_from (also 18) as longest Struct method qualname; memory-efficient repeated unpacking; no prior struct spec anchors this as a standalone; first standalone under structqn138"
  category: qualname_identity
  kind: python_call_eq
  function: Struct.iter_unpack.__qualname__.__eq__
  args: ["Struct.iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception'. struct.error inherits
# directly from Exception — the standard parent for library-level errors that
# are not OS errors or system exits. The single-level inheritance (no intermediate
# class) means error.__bases__ has exactly one entry. 'Exception' is 9 chars.
# extra93 anchors error __bases__ broadly; no prior struct spec anchors
# __bases__[0].__name__.__eq__('Exception') as a standalone under structqn138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra138.error_base_Exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error inherits directly from Exception (9 chars; single-level inheritance); standard parent for library errors; extra93 anchors error __bases__ broadly; first standalone for __bases__[0].__name__ equality under structqn138"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__len__()==9 — standalone
#
# struct.error.__bases__[0].__name__.__len__() is 9. The name 'Exception' is
# 9 chars. Among the common Python exception hierarchy, 'Exception' (9) is
# longer than 'OSError' (7), 'ValueError' (10), 'TypeError' (9), etc. No prior
# struct spec anchors error.__bases__[0].__name__.__len__()==9 as a standalone
# under structqn138. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra138.error_base_name_len_9:
  description: "struct.error.__bases__[0].__name__.__len__() == 9 — 'Exception' is 9 chars; struct.error inherits from Exception (not OSError or ValueError); 9-char base name; no prior struct spec anchors this as a standalone; first standalone under structqn138"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__len__"
  args: []
  expected: 9
