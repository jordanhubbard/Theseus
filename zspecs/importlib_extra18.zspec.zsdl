spec: importlib_extra18
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "importlib_extra5.zspec.zsdl — covers __qualname__ for importlib.import_module and importlib.reload (and util/abc functions); NOT their __module__ string length."
    - "importlib_extra17.zspec.zsdl — covers __qualname__ for abc.MetaPathFinder/PathEntryFinder and machinery.ModuleSpec attrs; NOT __len__() on __module__ strings or __name__ strings."
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra17.zspec.zsdl."
    - "Prior specs covered: importlib.__name__/__package__, importlib.import_module/__name__/__module__, importlib.reload/__name__/__module__, importlib.find_loader/__name__, importlib.util.__name__, importlib.resources.__name__, importlib.metadata.__name__, importlib.abc.__name__, importlib.machinery.__name__, various __qualname__ checks."
    - "This spec covers: importlib.import_module.__qualname__, importlib.reload.__qualname__, importlib.import_module.__module__.__len__(), importlib.reload.__module__.__len__(), importlib.util.__name__.__len__(), importlib.resources.__name__.__len__(), importlib.abc.__name__.__len__(), importlib.machinery.__name__.__len__(), importlib.import_module.__name__.__len__(), importlib.reload.__name__.__len__()."
    - "importlib.import_module.__qualname__ == 'import_module' — top-level function, qualname equals bare name; not covered in any prior importlib spec."
    - "importlib.reload.__qualname__ == 'reload' — top-level function, qualname equals bare name; not covered in any prior importlib spec."
    - "importlib.import_module.__module__ == 'importlib', len == 9; importlib.reload.__module__ == 'importlib', len == 9."
    - "importlib.util.__name__ == 'importlib.util', len == 14; importlib.resources.__name__ == 'importlib.resources', len == 19."
    - "importlib.abc.__name__ == 'importlib.abc', len == 13; importlib.machinery.__name__ == 'importlib.machinery', len == 19."
    - "importlib.import_module.__name__ == 'import_module', len == 13; importlib.reload.__name__ == 'reload', len == 6."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib top-level function __qualname__ attributes
#
# No prior importlib spec covers __qualname__ for import_module or reload.
# Both are top-level functions in importlib so their __qualname__ equals
# their bare __name__.
# ---------------------------------------------------------------------------

table importlib_extra18.toplevel_function_qualnames:
  description: "__qualname__ for importlib top-level functions equals the bare function name"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnqn18

  columns: [id, function, args, expected]
  rows:
    - [import_module, import_module.__qualname__.__eq__, ["import_module"], true]
    - [reload,        reload.__qualname__.__eq__,        ["reload"],        true]

# ---------------------------------------------------------------------------
# importlib top-level function __module__ string length
#
# importlib.import_module.__module__ == 'importlib' (len 9).
# importlib.reload.__module__ == 'importlib' (len 9).
# No prior importlib spec checks the __len__() of these __module__ strings.
# ---------------------------------------------------------------------------

table importlib_extra18.toplevel_function_module_lengths:
  description: "__module__.__len__() for importlib top-level functions (both 9, for 'importlib')"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnmodlen18

  columns: [id, function, args, expected]
  rows:
    - [import_module, import_module.__module__.__len__, [], 9]
    - [reload,        reload.__module__.__len__,        [], 9]

# ---------------------------------------------------------------------------
# importlib submodule __name__ string lengths
#
# importlib.util.__name__ == 'importlib.util' (len 14)
# importlib.resources.__name__ == 'importlib.resources' (len 19)
# importlib.abc.__name__ == 'importlib.abc' (len 13)
# importlib.machinery.__name__ == 'importlib.machinery' (len 19)
# Prior specs confirmed the __name__ values; no prior spec checks __len__().
# ---------------------------------------------------------------------------

table importlib_extra18.submodule_name_lengths:
  description: "__name__.__len__() for importlib submodules"
  kind: python_call_eq
  category: submodule_attrs
  id_prefix: subnlen18

  columns: [id, function, args, expected]
  rows:
    - [util,      util.__name__.__len__,      [], 14]
    - [resources, resources.__name__.__len__, [], 19]
    - [abc,       abc.__name__.__len__,       [], 13]
    - [machinery, machinery.__name__.__len__, [], 19]

# ---------------------------------------------------------------------------
# importlib top-level function __name__ string lengths
#
# importlib.import_module.__name__ == 'import_module' (len 13)
# importlib.reload.__name__ == 'reload' (len 6)
# No prior importlib spec checks the __len__() of these __name__ strings.
# ---------------------------------------------------------------------------

table importlib_extra18.toplevel_function_name_lengths:
  description: "__name__.__len__() for importlib top-level functions"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnnlen18

  columns: [id, function, args, expected]
  rows:
    - [import_module, import_module.__name__.__len__, [], 13]
    - [reload,        reload.__name__.__len__,        [], 6]

# ---------------------------------------------------------------------------
# Standalone invariants — __qualname__ for import_module and reload
# ---------------------------------------------------------------------------

invariant importlib_extra18.import_module.qualname:
  description: "importlib.import_module.__qualname__ == 'import_module' — top-level function qualname equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: import_module.__qualname__.__eq__
  args: ["import_module"]
  expected: true

invariant importlib_extra18.reload.qualname:
  description: "importlib.reload.__qualname__ == 'reload' — top-level function qualname equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: reload.__qualname__.__eq__
  args: ["reload"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — __module__ string length
# ---------------------------------------------------------------------------

invariant importlib_extra18.import_module.module_len:
  description: "importlib.import_module.__module__.__len__() == 9 — 'importlib' has 9 characters"
  category: function_attrs
  kind: python_call_eq
  function: import_module.__module__.__len__
  args: []
  expected: 9

invariant importlib_extra18.reload.module_len:
  description: "importlib.reload.__module__.__len__() == 9 — 'importlib' has 9 characters"
  category: function_attrs
  kind: python_call_eq
  function: reload.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# Standalone invariants — submodule __name__ lengths
# ---------------------------------------------------------------------------

invariant importlib_extra18.util.name_len:
  description: "importlib.util.__name__.__len__() == 14 — 'importlib.util' has 14 characters"
  category: submodule_attrs
  kind: python_call_eq
  function: util.__name__.__len__
  args: []
  expected: 14

invariant importlib_extra18.resources.name_len:
  description: "importlib.resources.__name__.__len__() == 19 — 'importlib.resources' has 19 characters"
  category: submodule_attrs
  kind: python_call_eq
  function: resources.__name__.__len__
  args: []
  expected: 19

invariant importlib_extra18.abc.name_len:
  description: "importlib.abc.__name__.__len__() == 13 — 'importlib.abc' has 13 characters"
  category: submodule_attrs
  kind: python_call_eq
  function: abc.__name__.__len__
  args: []
  expected: 13

invariant importlib_extra18.machinery.name_len:
  description: "importlib.machinery.__name__.__len__() == 19 — 'importlib.machinery' has 19 characters"
  category: submodule_attrs
  kind: python_call_eq
  function: machinery.__name__.__len__
  args: []
  expected: 19
