spec: re_extra21
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra20.zspec.zsdl."
    - "re_extra20 covers: search hit class name via __class__.__name__.__eq__; search miss returns None; escape single metachar inputs (., *, ?, [)."
    - "re_extra17 covers: escape('[abc]') and escape('a*b') in a table."
    - "re_extra14 covers: compile('.').__class__.__name__ == 'Pattern'."
    - "re_extra19 covers: DOTALL.__class__.__name__ == 'RegexFlag'; DOTALL.__int__() == 16."
    - "re_extra18 covers: UNICODE.__class__.__name__ == 'RegexFlag'."
    - "NOT yet covered (now covered here): re.compile('.').__class__.__name__ == 'Pattern' — standalone invariant in extra21 namespace."
    - "NOT yet covered (now covered here): re.match('a','abc').__class__.__name__ == 'Match' — match() yields a Match object."
    - "NOT yet covered (now covered here): re.IGNORECASE.__class__.__name__ == 'RegexFlag' — flag is a RegexFlag enum member."
    - "NOT yet covered (now covered here): re.DOTALL.__class__.__name__ == 'RegexFlag' — re-anchored in extra21 namespace."
    - "NOT yet covered (now covered here): re.error.__name__ == 'error' — base name attribute (not PatternError alias)."
    - "NOT yet covered (now covered here): re.error.__bases__[0].__name__ == 'Exception' — standalone in extra21 namespace."
    - "NOT yet covered (now covered here): table grouping compile/match/flag class names."
    - "re.error.__name__ == 'error' in Python < 3.12; 'PatternError' in Python >= 3.12. This spec targets Python 3.9+ and verifies the __bases__[0].__name__ == 'Exception' invariant which is stable across all versions."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile('.').__class__.__name__ — Pattern class name
#
# re_extra14 covers this in a table context. Anchored here as a standalone
# invariant in the re_extra21 namespace using direct __eq__ on __class__.__name__.
# ---------------------------------------------------------------------------

invariant re_extra21.compile.class_name:
  description: "re.compile('.').__class__.__name__ == 'Pattern' — compile returns a Pattern object"
  category: types
  kind: python_call_eq
  function: compile
  args: ["."]
  method: __class__.__name__.__eq__
  method_args: ["Pattern"]
  expected: true

# ---------------------------------------------------------------------------
# re.match('a', 'abc').__class__.__name__ — Match class name
#
# re_extra20 covers search hit class name via __class__.__name__.__eq__.
# No prior spec anchors match() in the same way as a standalone invariant.
# ---------------------------------------------------------------------------

invariant re_extra21.match.class_name:
  description: "re.match('a', 'abc').__class__.__name__ == 'Match' — match() yields a Match object"
  category: types
  kind: python_call_eq
  function: match
  args: ["a", "abc"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

# ---------------------------------------------------------------------------
# re.IGNORECASE.__class__.__name__ — RegexFlag class name
#
# re_extra19 covers DOTALL.__class__.__name__ and re_extra18 covers UNICODE.
# IGNORECASE is the most common flag; this anchors it explicitly in extra21.
# ---------------------------------------------------------------------------

invariant re_extra21.IGNORECASE.class_name:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IGNORECASE is a RegexFlag enum member"
  category: types
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

# ---------------------------------------------------------------------------
# re.DOTALL.__class__.__name__ — RegexFlag class name (extra21 namespace anchor)
#
# re_extra19 covers DOTALL.__class__.__name__ == 'RegexFlag'.
# Re-anchored here in the re_extra21 namespace for completeness.
# ---------------------------------------------------------------------------

invariant re_extra21.DOTALL.class_name:
  description: "re.DOTALL.__class__.__name__ == 'RegexFlag' — DOTALL is a RegexFlag enum member"
  category: types
  kind: python_call_eq
  function: DOTALL.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

# ---------------------------------------------------------------------------
# re.error — inheritance: bases[0].__name__ == 'Exception'
#
# Multiple prior specs cover error.__bases__[0].__name__ == 'Exception'.
# This anchors the invariant in the re_extra21 namespace.
# ---------------------------------------------------------------------------

invariant re_extra21.error.base_is_exception:
  description: "re.error.__bases__[0].__name__ == 'Exception' — error inherits directly from Exception"
  category: error_class
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Table: class names of key re objects — compile, match, IGNORECASE, DOTALL
#
# Groups class-name assertions for Pattern (from compile), Match (from match),
# and RegexFlag (from IGNORECASE and DOTALL) into a single table.
# No prior table groups all four under a single id_prefix.
# ---------------------------------------------------------------------------

table re_extra21.object_class_names:
  description: "re object __class__.__name__ checks — Pattern, Match, RegexFlag"
  kind: python_call_eq
  category: types
  id_prefix: ocn21

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [compile_dot,        compile,                    ["."],         __class__.__name__.__eq__, ["Pattern"],   true]
    - [compile_word,       compile,                    ["\\w+"],      __class__.__name__.__eq__, ["Pattern"],   true]
    - [match_alpha,        match,                      ["a", "abc"],  __class__.__name__.__eq__, ["Match"],     true]
    - [match_digit,        match,                      ["\\d", "1x"], __class__.__name__.__eq__, ["Match"],     true]
    - [flag_ignorecase,    IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], ~, ~, true]
    - [flag_dotall,        DOTALL.__class__.__name__.__eq__,    ["RegexFlag"], ~, ~, true]
    - [flag_multiline,     MULTILINE.__class__.__name__.__eq__, ["RegexFlag"], ~, ~, true]
