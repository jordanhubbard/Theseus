spec: mimetypes_extra
version: ">=3.0"
backend: python_module(mimetypes)

docs: https://docs.python.org/3/library/mimetypes.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/mimetypes.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/mimetypes.py"
    - "mimetypes.zspec.zsdl — covers MimeTypes.__name__, all function names, guess_type for common extensions, guess_extension, types_map"
  notes:
    - "mimetypes.MimeTypes.__module__ == 'mimetypes' — class is defined in the mimetypes module."
    - "encodings_map maps compression suffixes to encoding names; '.gz' maps to 'gzip'."
    - "suffix_map maps compound suffixes to simpler ones; '.tgz' maps to '.tar.gz'."
    - "mimetypes.read_mime_types('/nonexistent') returns None for nonexistent files."
    - "guess_all_extensions('text/plain') includes '.txt' among its results."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MimeTypes class __module__ check
# ---------------------------------------------------------------------------

invariant mimetypes_extra.MimeTypes.module:
  description: "mimetypes.MimeTypes.__module__ == 'mimetypes'"
  category: class_modules
  kind: python_call_eq
  function: MimeTypes.__module__.__eq__
  args: ["mimetypes"]
  expected: true

# ---------------------------------------------------------------------------
# encodings_map — compression suffix registry
# ---------------------------------------------------------------------------

invariant mimetypes_extra.encodings_map.type:
  description: "mimetypes.encodings_map is a dict"
  category: encodings_map
  kind: python_call_eq
  function: encodings_map.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant mimetypes_extra.encodings_map.gz:
  description: "mimetypes.encodings_map['.gz'] == 'gzip' — gzip compression encoding"
  category: encodings_map
  kind: python_call_eq
  function: encodings_map.__getitem__
  args: [".gz"]
  expected: "gzip"

invariant mimetypes_extra.encodings_map.gz_contains:
  description: "'.gz' in mimetypes.encodings_map"
  category: encodings_map
  kind: python_call_eq
  function: encodings_map.__contains__
  args: [".gz"]
  expected: true

# ---------------------------------------------------------------------------
# suffix_map — compound suffix registry
# ---------------------------------------------------------------------------

invariant mimetypes_extra.suffix_map.type:
  description: "mimetypes.suffix_map is a dict"
  category: suffix_map
  kind: python_call_eq
  function: suffix_map.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant mimetypes_extra.suffix_map.tgz:
  description: "mimetypes.suffix_map['.tgz'] == '.tar.gz' — .tgz expands to .tar.gz"
  category: suffix_map
  kind: python_call_eq
  function: suffix_map.__getitem__
  args: [".tgz"]
  expected: ".tar.gz"

# ---------------------------------------------------------------------------
# read_mime_types — returns None for nonexistent files
# ---------------------------------------------------------------------------

invariant mimetypes_extra.read_mime_types.nonexistent:
  description: "mimetypes.read_mime_types('/nonexistent/path') == None — missing file returns None"
  category: read_mime_types
  kind: python_call_eq
  function: read_mime_types
  args: ["/nonexistent/path"]
  expected: null

# ---------------------------------------------------------------------------
# guess_all_extensions — returns list containing known extension
# ---------------------------------------------------------------------------

invariant mimetypes_extra.guess_all_extensions.txt_in_list:
  description: "'.txt' in mimetypes.guess_all_extensions('text/plain')"
  category: guess_all_extensions
  kind: python_call_eq
  function: guess_all_extensions
  args: ["text/plain"]
  method: __contains__
  method_args: [".txt"]
  expected: true

invariant mimetypes_extra.guess_all_extensions.html_in_list:
  description: "'.html' in mimetypes.guess_all_extensions('text/html')"
  category: guess_all_extensions
  kind: python_call_eq
  function: guess_all_extensions
  args: ["text/html"]
  method: __contains__
  method_args: [".html"]
  expected: true
