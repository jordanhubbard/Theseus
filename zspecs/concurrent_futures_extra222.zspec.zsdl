spec: concurrent_futures_extra222
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.Executor.__doc__.__contains__('executor') == True — Executor.__doc__ is 'This is an abstract base class for concrete asynchronous executors.'; 'executor' (lowercase) is present in 'asynchronous executors'; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__doc__ is None — ThreadPoolExecutor has no docstring; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__doc__ is None — ProcessPoolExecutor has no docstring; verified with Python 3.14.3."
    - "concurrent.futures.Future.__doc__ does NOT contain 'future' (lowercase) — Future.__doc__ is 'Represents the result of an asynchronous computation.'; 'future' is not present; verified with Python 3.14.3."
    - "concurrent.futures.Future.cancel.__doc__.__contains__('cancel') == True — cancel.__doc__ starts with 'Cancel the future if possible.'; 'cancel' (lowercase) is present in 'Cancel the future'; verified with Python 3.14.3."
    - "concurrent.futures.Future.result.__doc__.__contains__('result') == True — result.__doc__ starts with 'Return the result of the call that the future represents.'; 'result' is present; verified with Python 3.14.3."
    - "concurrent.futures.Future.done.__doc__ does NOT contain 'done' (lowercase) — done.__doc__ is 'Return True if the future was cancelled or finished executing.'; 'done' is not present; verified with Python 3.14.3."
    - "concurrent.futures.as_completed.__doc__.__contains__('future') == True — as_completed.__doc__ starts with 'An iterator over the given futures that yields each as it completes.'; 'future' is present in 'futures'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Executor __doc__ contains check — extra222 namespace
#
# Executor.__doc__ contains 'executor' (lowercase); verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra222.executor_doc_has_executor:
  description: "concurrent.futures.Executor.__doc__.__contains__('executor') == True — Executor.__doc__ is 'This is an abstract base class for concrete asynchronous executors.'; 'executor' (lowercase) is present in 'asynchronous executors'; NEW in extra222: first Executor.__doc__ contains check; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: Executor.__doc__.__contains__
  args: ["executor"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures.Future __doc__ contains checks — extra222 namespace
#
# Future.cancel.__doc__ contains 'cancel'; Future.result.__doc__ contains 'result'.
# as_completed.__doc__ contains 'future'.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table concurrent_futures_extra222.future_method_doc:
  description: "concurrent.futures.Future method __doc__.__contains__ checks in cf222doc namespace"
  kind: python_call_eq
  category: doc_contains
  id_prefix: cf222doc

  columns: [id, function, args, expected, description]
  rows:
    - [future_cancel_doc_has_cancel, Future.cancel.__doc__.__contains__, ["cancel"], true, "concurrent.futures.Future.cancel.__doc__.__contains__('cancel') == True — cancel.__doc__ starts with 'Cancel the future if possible.'; 'cancel' (lowercase) is present; verified with Python 3.14.3"]
    - [future_result_doc_has_result, Future.result.__doc__.__contains__, ["result"], true, "concurrent.futures.Future.result.__doc__.__contains__('result') == True — result.__doc__ starts with 'Return the result of the call that the future represents.'; 'result' is present; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.as_completed __doc__ contains check — extra222 namespace
#
# as_completed.__doc__ contains 'future' (lowercase); verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra222.as_completed_doc_has_future:
  description: "concurrent.futures.as_completed.__doc__.__contains__('future') == True — as_completed.__doc__ starts with 'An iterator over the given futures that yields each as it completes.'; 'future' is present as part of 'futures'; NEW in extra222: first as_completed.__doc__ contains check; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: as_completed.__doc__.__contains__
  args: ["future"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures.Executor.__doc__ contains 'abstract' — extra222 namespace
#
# Executor.__doc__ is 'This is an abstract base class for concrete asynchronous
# executors.'; 'abstract' is present; verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra222.executor_doc_has_abstract:
  description: "concurrent.futures.Executor.__doc__.__contains__('abstract') == True — Executor.__doc__ is 'This is an abstract base class for concrete asynchronous executors.'; 'abstract' is present in 'abstract base class'; NEW in extra222: second Executor.__doc__ contains check; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: Executor.__doc__.__contains__
  args: ["abstract"]
  expected: true
