spec: socket_extra54
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra53.zspec.zsdl — covers socket.socket/herror/gaierror/timeout __dict__/__class__/__qualname__.__eq__('mappingproxy'); socket module __dict__/__class__/__name__/__qualname__.__eq__('mappingproxy')."
    - "socket_extra52.zspec.zsdl — covers AF_INET6/AF_UNIX __class__/__qualname__/__module__/__qualname__.__len__() axes."
    - "socket_extra51.zspec.zsdl — covers AF_INET/SOCK_STREAM/SOCK_DGRAM __class__.__module__.__eq__('socket') and __len__()==6; SOCK_DGRAM __class__.__qualname__.__eq__/'__len__()."
    - "socket_extra47.zspec.zsdl — covers socket.socket/gethostname/getaddrinfo __class__.__module__.__eq__('builtins') as three representative rows; does NOT cover herror/gaierror/timeout/gethostbyname/setdefaulttimeout on the __class__.__module__.__eq__('builtins') axis."
  notes:
    - "This spec extends socket through socket_extra53; it does NOT duplicate invariants present in those files."
    - "Wave 221 theme: __class__.__module__ string equality checks + __init__.__class__ checks for class objects."
    - "Coverage gap 1: socket_extra47 checks socket.socket/gethostname/getaddrinfo __class__.__module__.__eq__('builtins') as three representative rows (one per distinct __class__ kind: type, builtin_function_or_method, function). It does NOT cover herror, gaierror, timeout, gethostbyname, or setdefaulttimeout on the __class__.__module__.__eq__('builtins') axis. All five have their __class__ defined in builtins. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__class__.__module__ == 'builtins'. herror is an exception class; its metaclass is the built-in type with __module__ == 'builtins'. socket_extra47 covers socket.socket.__class__.__module__.__eq__('builtins') but NOT herror. No prior socket spec checks herror.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__class__.__module__ == 'builtins'. Same type metaclass pattern as herror. No prior socket spec checks gaierror.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__class__.__module__ == 'builtins'. Same type metaclass pattern. No prior socket spec checks timeout.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__class__.__module__ == 'builtins'. gethostbyname is a C builtin function; the builtin_function_or_method type has __module__ == 'builtins'. socket_extra47 covers gethostname.__class__.__module__.__eq__('builtins') but NOT gethostbyname. No prior socket spec checks gethostbyname.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__class__.__module__ == 'builtins'. setdefaulttimeout is a C builtin function; same pattern as gethostbyname. No prior socket spec checks setdefaulttimeout.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior socket spec checks __init__.__class__.__name__ or __init__.__class__.__module__ for socket.herror, gaierror, or timeout. socket.herror/gaierror/timeout are Python-defined exception classes (subclasses of OSError) implemented in Lib/socket.py; they inherit their __init__ from the OSError C type chain, giving them a 'wrapper_descriptor' __init__. No prior socket spec checks __init__.__class__.__name__.__eq__('wrapper_descriptor') for any socket exception class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__init__.__class__.__name__ == 'wrapper_descriptor'. herror is a Python subclass of OSError; its __init__ resolves to the C-slot wrapper_descriptor from OSError. No prior socket spec checks herror.__init__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__init__.__class__.__name__ == 'wrapper_descriptor'. Same OSError C-slot wrapper inheritance as herror. No prior socket spec checks gaierror.__init__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__init__.__class__.__name__ == 'wrapper_descriptor'. Same OSError C-slot wrapper inheritance as herror/gaierror. No prior socket spec checks timeout.__init__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.herror/gaierror/timeout/gethostbyname/setdefaulttimeout
#   __class__.__module__.__eq__('builtins')
#
# socket_extra47 checks socket.socket/gethostname/getaddrinfo __class__.__module__
# __eq__('builtins') as three representative rows covering each distinct __class__
# kind (type, builtin_function_or_method, function). It does NOT cover herror,
# gaierror, timeout (all type-metaclassed exception classes) or gethostbyname,
# setdefaulttimeout (both builtin_function_or_method). Completing this table
# closes the gap on the __class__.__module__.__eq__('builtins') axis for
# the remaining commonly-tested socket objects.
# ---------------------------------------------------------------------------

table socket_extra54.class_module_eq:
  description: "socket.herror/gaierror/timeout/__class__/__module__.__eq__('builtins') and gethostbyname/setdefaulttimeout/__class__/__module__.__eq__('builtins') — socket_extra47 covers socket/gethostname/getaddrinfo __class__.__module__.__eq__('builtins') (3 representative rows) but NOT herror/gaierror/timeout/gethostbyname/setdefaulttimeout; all five have __class__ from builtins; novel extension of the __class__.__module__ axis"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketmod54

  columns: [id, function, args, expected]
  rows:
    - [herror_class_module_eq,          herror.__class__.__module__.__eq__,          ["builtins"], true]
    - [gaierror_class_module_eq,        gaierror.__class__.__module__.__eq__,        ["builtins"], true]
    - [timeout_class_module_eq,         timeout.__class__.__module__.__eq__,         ["builtins"], true]
    - [gethostbyname_class_module_eq,   gethostbyname.__class__.__module__.__eq__,   ["builtins"], true]
    - [setdefaulttimeout_class_module_eq, setdefaulttimeout.__class__.__module__.__eq__, ["builtins"], true]

# ---------------------------------------------------------------------------
# socket.herror/gaierror/timeout __init__.__class__.__name__.__eq__('wrapper_descriptor')
#
# No prior socket spec checks __init__.__class__.__name__ for herror, gaierror,
# or timeout. These exception classes subclass OSError (a C type); they do not
# define their own __init__, so MRO lookup resolves to the C-slot wrapper_descriptor
# from OSError's __init__. This means __init__.__class__.__name__ == 'wrapper_descriptor'
# for all three, reflecting the C slot wrapper pattern inherited from the C exception
# type hierarchy.
# ---------------------------------------------------------------------------

table socket_extra54.exception_init_class_name_eq:
  description: "socket.herror/gaierror/timeout/__init__/__class__/__name__.__eq__('wrapper_descriptor') — Python exception classes inheriting OSError's C slot __init__; __init__ resolves to a wrapper_descriptor via MRO; no prior socket spec checks __init__.__class__.__name__.__eq__('wrapper_descriptor') for any socket exception class"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketmod54

  columns: [id, function, args, expected]
  rows:
    - [herror_init_class_name_eq,  herror.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [gaierror_init_class_name_eq, gaierror.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [timeout_init_class_name_eq,  timeout.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# socket.herror __init__.__class__.__module__.__eq__('builtins')
#
# No prior socket spec checks __init__.__class__.__module__ for any socket
# exception class. wrapper_descriptor is a C builtin type with __module__ ==
# 'builtins'. The __module__ check is independent from the __class__.__name__
# check above: if the descriptor type were moved outside builtins, __module__
# would detect it while __name__ would not; if renamed to a same-length name,
# __name__ catches it while __module__ would not.
# ---------------------------------------------------------------------------

invariant socket_extra54.herror.init_class_module_eq:
  description: "socket.herror.__init__.__class__.__module__ == 'builtins' — wrapper_descriptor is a C builtin type with __module__ == 'builtins'; independent from __class__.__name__ axis; no prior socket spec checks __init__.__class__.__module__.__eq__('builtins') for any socket exception class"
  category: type_structure
  kind: python_call_eq
  function: herror.__init__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
