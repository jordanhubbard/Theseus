spec: io_extra2311
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content checks."
    - "io abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) have __abstractmethods__ in their __dict__."
    - "In CPython 3.14 these ABCs are implemented in C (_io module); __abstractmethods__ is an empty frozenset for all four."
    - "Concrete classes (FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, TextIOWrapper) do NOT have __abstractmethods__ in __dict__ and raise AttributeError on direct access."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ dict-presence for io ABCs
#
# All four io ABCs expose __abstractmethods__ in their __dict__.
# In CPython 3.14 the C implementation keeps this as an empty frozenset.
# All expected True.
# ---------------------------------------------------------------------------

table io_extra2311.iobase_abstract_dict_presence:
  description: "io ABCs have __abstractmethods__ present in class __dict__ — all True — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2311

  columns: [id, function, args, expected]
  rows:
    - ["io2311001", "io.IOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io2311002", "io.RawIOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io2311003", "io.BufferedIOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io2311004", "io.TextIOBase.__dict__.__contains__", ["__abstractmethods__"], true]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__.__len__ for io ABCs
#
# All four ABCs carry an empty frozenset in CPython 3.14 (C implementation).
# Expected: 0 for all.
# ---------------------------------------------------------------------------

table io_extra2311.iobase_abstract_len:
  description: "io ABCs __abstractmethods__ length — all 0 in CPython 3.14 C impl — wave 601 _extra2311"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: io2311

  columns: [id, function, args, expected]
  rows:
    - ["io2311005", "io.IOBase.__abstractmethods__.__len__", [], 0]
    - ["io2311006", "io.RawIOBase.__abstractmethods__.__len__", [], 0]
    - ["io2311007", "io.BufferedIOBase.__abstractmethods__.__len__", [], 0]
    - ["io2311008", "io.TextIOBase.__abstractmethods__.__len__", [], 0]

# ---------------------------------------------------------------------------
# Table 3: __abstractmethods__.__contains__ for io.IOBase
#
# IOBase has an empty frozenset; none of the common method names are abstract.
# ---------------------------------------------------------------------------

table io_extra2311.iobase_contains:
  description: "io.IOBase.__abstractmethods__ does not contain any method name — wave 601 _extra2311"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: io2311

  columns: [id, function, args, expected]
  rows:
    - ["io2311009",  "io.IOBase.__abstractmethods__.__contains__", ["read"],     false]
    - ["io2311010",  "io.IOBase.__abstractmethods__.__contains__", ["write"],    false]
    - ["io2311011",  "io.IOBase.__abstractmethods__.__contains__", ["readline"], false]
    - ["io2311012",  "io.IOBase.__abstractmethods__.__contains__", ["readinto"], false]

# ---------------------------------------------------------------------------
# Table 4: __abstractmethods__.__contains__ for io.RawIOBase
#
# RawIOBase has an empty frozenset in CPython 3.14 (pure-Python _pyio.RawIOBase
# declares readinto as abstract, but the C _io.RawIOBase does not).
# ---------------------------------------------------------------------------

table io_extra2311.rawiobase_contains:
  description: "io.RawIOBase.__abstractmethods__ contains checks — wave 601 _extra2311"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: io2311

  columns: [id, function, args, expected]
  rows:
    - ["io2311013", "io.RawIOBase.__abstractmethods__.__contains__", ["readinto"], false]
    - ["io2311014", "io.RawIOBase.__abstractmethods__.__contains__", ["read"],     false]
    - ["io2311015", "io.RawIOBase.__abstractmethods__.__contains__", ["write"],    false]

# ---------------------------------------------------------------------------
# Table 5: __abstractmethods__.__contains__ for io.BufferedIOBase
#
# BufferedIOBase has an empty frozenset in CPython 3.14.
# ---------------------------------------------------------------------------

table io_extra2311.bufferediobase_contains:
  description: "io.BufferedIOBase.__abstractmethods__ contains checks — wave 601 _extra2311"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: io2311

  columns: [id, function, args, expected]
  rows:
    - ["io2311016", "io.BufferedIOBase.__abstractmethods__.__contains__", ["read"],      false]
    - ["io2311017", "io.BufferedIOBase.__abstractmethods__.__contains__", ["read1"],     false]
    - ["io2311018", "io.BufferedIOBase.__abstractmethods__.__contains__", ["readinto"],  false]
    - ["io2311019", "io.BufferedIOBase.__abstractmethods__.__contains__", ["readinto1"], false]
    - ["io2311020", "io.BufferedIOBase.__abstractmethods__.__contains__", ["write"],     false]

# ---------------------------------------------------------------------------
# Table 6: __abstractmethods__.__contains__ for io.TextIOBase
#
# TextIOBase has an empty frozenset in CPython 3.14.
# ---------------------------------------------------------------------------

table io_extra2311.textiobase_contains:
  description: "io.TextIOBase.__abstractmethods__ contains checks — wave 601 _extra2311"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: io2311

  columns: [id, function, args, expected]
  rows:
    - ["io2311021", "io.TextIOBase.__abstractmethods__.__contains__", ["read"],     false]
    - ["io2311022", "io.TextIOBase.__abstractmethods__.__contains__", ["readline"], false]
    - ["io2311023", "io.TextIOBase.__abstractmethods__.__contains__", ["write"],    false]
    - ["io2311024", "io.TextIOBase.__abstractmethods__.__contains__", ["readinto"], false]

# ---------------------------------------------------------------------------
# Table 7: concrete io classes — __abstractmethods__ absent from __dict__
#
# FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, TextIOWrapper
# are fully concrete C types; they do not set __abstractmethods__ in their
# own __dict__.  Expected: False for all.
# ---------------------------------------------------------------------------

table io_extra2311.concrete_abstract_absence:
  description: "Concrete io classes have no __abstractmethods__ in class __dict__ — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2311

  columns: [id, function, args, expected]
  rows:
    - ["io2311025", "io.FileIO.__dict__.__contains__",        ["__abstractmethods__"], false]
    - ["io2311026", "io.BytesIO.__dict__.__contains__",       ["__abstractmethods__"], false]
    - ["io2311027", "io.StringIO.__dict__.__contains__",      ["__abstractmethods__"], false]
    - ["io2311028", "io.BufferedReader.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["io2311029", "io.BufferedWriter.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["io2311030", "io.TextIOWrapper.__dict__.__contains__",  ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 8: concrete io classes — __abstractmethods__ access raises AttributeError
#
# Because __abstractmethods__ is absent from each concrete class dict and their
# C-level MRO does not provide the attribute, direct access raises AttributeError.
# ---------------------------------------------------------------------------

table io_extra2311.concrete_abstract_attr_error:
  description: "Concrete io classes raise AttributeError on __abstractmethods__.__len__ — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: io2311

  columns: [id, function, args, expected]
  rows:
    - ["io2311031", "io.FileIO.__abstractmethods__.__len__",         [], "AttributeError"]
    - ["io2311032", "io.BytesIO.__abstractmethods__.__len__",        [], "AttributeError"]
    - ["io2311033", "io.StringIO.__abstractmethods__.__len__",       [], "AttributeError"]
    - ["io2311034", "io.BufferedReader.__abstractmethods__.__len__",  [], "AttributeError"]
    - ["io2311035", "io.BufferedWriter.__abstractmethods__.__len__",  [], "AttributeError"]
    - ["io2311036", "io.TextIOWrapper.__abstractmethods__.__len__",   [], "AttributeError"]
