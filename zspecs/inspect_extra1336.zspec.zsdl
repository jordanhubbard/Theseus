spec: inspect_extra1336
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method class checks for inspect classes."
    - "inspect.Parameter defines both __eq__ and __hash__ as Python functions in the class body."
    - "inspect.Parameter.__eq__.__class__.__name__ == 'function' — defined as a Python method in Lib/inspect.py."
    - "inspect.Parameter.__eq__.__qualname__ == 'Parameter.__eq__' — defined directly in the Parameter class body."
    - "inspect.Parameter.__hash__.__class__.__name__ == 'function' — Python explicitly defines __hash__ alongside __eq__."
    - "inspect.Parameter.__hash__.__qualname__ == 'Parameter.__hash__' — defined directly in the Parameter class body."
    - "inspect.Signature defines both __eq__ and __hash__ as Python functions."
    - "inspect.Signature.__eq__.__qualname__ == 'Signature.__eq__' — defined in the Signature class body."
    - "inspect.Signature.__hash__.__qualname__ == 'Signature.__hash__' — defined in the Signature class body."
    - "inspect.BoundArguments defines __eq__ as a Python function but __hash__ is None (unhashable: defines __eq__ without explicit __hash__)."
    - "inspect.BoundArguments.__hash__ is None — Python sets __hash__ to None when __eq__ is defined without a paired __hash__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra1336.parameter_hash_eq_checks:
  description: "inspect.Parameter __hash__ and __eq__ class name and qualname; Parameter explicitly defines both as Python functions"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: in1336pa
  columns: [id, function, args, expected]
  rows:
    - [in1336pa001, inspect.Parameter.__eq__.__class__.__name__.__eq__,   ["function"],          true]
    - [in1336pa002, inspect.Parameter.__eq__.__qualname__.__eq__,         ["Parameter.__eq__"],  true]
    - [in1336pa003, inspect.Parameter.__hash__.__class__.__name__.__eq__, ["function"],          true]
    - [in1336pa004, inspect.Parameter.__hash__.__qualname__.__eq__,       ["Parameter.__hash__"], true]
    - [in1336pa005, inspect.Signature.__eq__.__class__.__name__.__eq__,   ["function"],          true]
    - [in1336pa006, inspect.Signature.__eq__.__qualname__.__eq__,         ["Signature.__eq__"],  true]

table inspect_extra1336.signature_hash_eq_checks:
  description: "inspect.Signature __hash__ and __eq__ class name and qualname; Signature explicitly defines both as Python functions"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: in1336si
  columns: [id, function, args, expected]
  rows:
    - [in1336si001, inspect.Signature.__hash__.__class__.__name__.__eq__, ["function"],           true]
    - [in1336si002, inspect.Signature.__hash__.__qualname__.__eq__,       ["Signature.__hash__"], true]
    - [in1336si003, inspect.Signature.__eq__.__class__.__name__.__eq__,   ["function"],           true]
    - [in1336si004, inspect.Signature.__eq__.__qualname__.__eq__,         ["Signature.__eq__"],   true]
    - [in1336si005, inspect.Parameter.__hash__.__class__.__name__.__eq__, ["function"],           true]
    - [in1336si006, inspect.Parameter.__eq__.__class__.__name__.__eq__,   ["function"],           true]

table inspect_extra1336.boundarguments_hash_eq_checks:
  description: "inspect.BoundArguments __eq__ and __hash__ checks; BoundArguments defines __eq__ but __hash__ is None (unhashable per Python data model)"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: in1336ba
  columns: [id, function, args, expected]
  rows:
    - [in1336ba001, inspect.BoundArguments.__eq__.__class__.__name__.__eq__,   ["function"],              true]
    - [in1336ba002, inspect.BoundArguments.__eq__.__qualname__.__eq__,         ["BoundArguments.__eq__"], true]
    - [in1336ba003, (inspect.BoundArguments.__hash__ is None).__eq__,          [true],                    true]
    - [in1336ba004, inspect.BoundArguments.__hash__.__class__.__name__.__eq__, ["NoneType"],              true]
    - [in1336ba005, inspect.Parameter.__hash__.__qualname__.__eq__,            ["Parameter.__hash__"],    true]
    - [in1336ba006, inspect.Signature.__hash__.__qualname__.__eq__,            ["Signature.__hash__"],    true]
