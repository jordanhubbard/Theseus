spec: string_extra22
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra21.zspec.zsdl."
    - "string_extra21 covers: Formatter.format/__qualname__; Formatter.vformat/__qualname__; Formatter.parse/__qualname__; Template.substitute/__qualname__; Template.safe_substitute/__qualname__."
    - "string_extra5 covers: Formatter.__qualname__=='Formatter'; Template.__qualname__=='Template'; capwords.__qualname__=='capwords'."
    - "string_extra covers: ascii_letters/__class__.__name__=='str' and digits/__class__.__name__=='str' in a type-is-str table."
    - "No prior spec covers Formatter.get_field/__qualname__, Formatter.get_value/__qualname__, Formatter.check_unused_args/__qualname__, Formatter.format_field/__qualname__, or Formatter.convert_field/__qualname__ as standalone invariants."
    - "No prior spec covers Template.__init__.__qualname__ or Template.__init_subclass__.__qualname__ as standalone invariants."
    - "No prior spec covers string.whitespace/__class__.__name__ or string.punctuation/__class__.__name__ as standalone invariants."
    - "string.Formatter.get_field.__qualname__ == 'Formatter.get_field' — method qualname includes owning class. Verified at runtime."
    - "string.Formatter.get_value.__qualname__ == 'Formatter.get_value' — method qualname includes owning class. Verified at runtime."
    - "string.Formatter.check_unused_args.__qualname__ == 'Formatter.check_unused_args' — method qualname includes owning class. Verified at runtime."
    - "string.Formatter.format_field.__qualname__ == 'Formatter.format_field' — method qualname includes owning class. Verified at runtime."
    - "string.Formatter.convert_field.__qualname__ == 'Formatter.convert_field' — method qualname includes owning class. Verified at runtime."
    - "string.Template.__init__.__qualname__ == 'Template.__init__' — method qualname includes owning class. Verified at runtime."
    - "string.Template.__init_subclass__.__qualname__ == 'Template.__init_subclass__' — inherited classmethod qualname. Verified at runtime."
    - "string.whitespace.__class__.__name__ == 'str' — whitespace constant is a str. Verified at runtime."
    - "string.punctuation.__class__.__name__ == 'str' — punctuation constant is a str. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Formatter.get_field — __qualname__
#
# No prior spec verifies Formatter.get_field.__qualname__ as a standalone
# invariant. For a method defined in class Formatter, __qualname__ takes the
# form 'Formatter.get_field'. Verified at runtime: 'Formatter.get_field'.
# ---------------------------------------------------------------------------

invariant string_extra22.Formatter.get_field_qualname:
  description: "string.Formatter.get_field.__qualname__ == 'Formatter.get_field' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Formatter.get_field.__qualname__.__eq__
  args: ["Formatter.get_field"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.get_value — __qualname__
#
# No prior spec verifies Formatter.get_value.__qualname__ as a standalone
# invariant. For a method defined in class Formatter, __qualname__ takes the
# form 'Formatter.get_value'. Verified at runtime: 'Formatter.get_value'.
# ---------------------------------------------------------------------------

invariant string_extra22.Formatter.get_value_qualname:
  description: "string.Formatter.get_value.__qualname__ == 'Formatter.get_value' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Formatter.get_value.__qualname__.__eq__
  args: ["Formatter.get_value"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.check_unused_args — __qualname__
#
# No prior spec verifies Formatter.check_unused_args.__qualname__ as a
# standalone invariant. For a method defined in class Formatter, __qualname__
# takes the form 'Formatter.check_unused_args'.
# Verified at runtime: 'Formatter.check_unused_args'.
# ---------------------------------------------------------------------------

invariant string_extra22.Formatter.check_unused_args_qualname:
  description: "string.Formatter.check_unused_args.__qualname__ == 'Formatter.check_unused_args' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Formatter.check_unused_args.__qualname__.__eq__
  args: ["Formatter.check_unused_args"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.format_field — __qualname__
#
# No prior spec verifies Formatter.format_field.__qualname__ as a standalone
# invariant. For a method defined in class Formatter, __qualname__ takes the
# form 'Formatter.format_field'. Verified at runtime: 'Formatter.format_field'.
# ---------------------------------------------------------------------------

invariant string_extra22.Formatter.format_field_qualname:
  description: "string.Formatter.format_field.__qualname__ == 'Formatter.format_field' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Formatter.format_field.__qualname__.__eq__
  args: ["Formatter.format_field"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.convert_field — __qualname__
#
# No prior spec verifies Formatter.convert_field.__qualname__ as a standalone
# invariant. For a method defined in class Formatter, __qualname__ takes the
# form 'Formatter.convert_field'. Verified at runtime: 'Formatter.convert_field'.
# ---------------------------------------------------------------------------

invariant string_extra22.Formatter.convert_field_qualname:
  description: "string.Formatter.convert_field.__qualname__ == 'Formatter.convert_field' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Formatter.convert_field.__qualname__.__eq__
  args: ["Formatter.convert_field"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.__init__ — __qualname__
#
# No prior spec verifies Template.__init__.__qualname__ as a standalone
# invariant. For a method defined in class Template, __qualname__ takes the
# form 'Template.__init__'. Verified at runtime: 'Template.__init__'.
# ---------------------------------------------------------------------------

invariant string_extra22.Template.init_qualname:
  description: "string.Template.__init__.__qualname__ == 'Template.__init__' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Template.__init__.__qualname__.__eq__
  args: ["Template.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.__init_subclass__ — __qualname__
#
# No prior spec verifies Template.__init_subclass__.__qualname__ as a standalone
# invariant. This classmethod is inherited; its __qualname__ is
# 'Template.__init_subclass__'. Verified at runtime: 'Template.__init_subclass__'.
# ---------------------------------------------------------------------------

invariant string_extra22.Template.init_subclass_qualname:
  description: "string.Template.__init_subclass__.__qualname__ == 'Template.__init_subclass__' — classmethod qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Template.__init_subclass__.__qualname__.__eq__
  args: ["Template.__init_subclass__"]
  expected: true

# ---------------------------------------------------------------------------
# string.whitespace — __class__.__name__
#
# No prior spec verifies string.whitespace.__class__.__name__ as a standalone
# invariant. The whitespace constant is a str. Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra22.whitespace.class_name:
  description: "string.whitespace.__class__.__name__ == 'str' — whitespace constant is a str"
  category: string_constants
  kind: python_call_eq
  function: whitespace.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# string.punctuation — __class__.__name__
#
# No prior spec verifies string.punctuation.__class__.__name__ as a standalone
# invariant. The punctuation constant is a str. Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra22.punctuation.class_name:
  description: "string.punctuation.__class__.__name__ == 'str' — punctuation constant is a str"
  category: string_constants
  kind: python_call_eq
  function: punctuation.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Formatter additional method __qualname__ values
#
# No prior spec groups get_field, get_value, check_unused_args, format_field,
# and convert_field __qualname__ checks into a single table.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra22.formatter_method_qualnames:
  description: "string.Formatter additional method __qualname__ values — get_field, get_value, check_unused_args, format_field, convert_field"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Formatter_get_field,
       Formatter.get_field.__qualname__.__eq__,
       ["Formatter.get_field"],
       true,
       "Formatter.get_field.__qualname__ == 'Formatter.get_field'"]
    - [Formatter_get_value,
       Formatter.get_value.__qualname__.__eq__,
       ["Formatter.get_value"],
       true,
       "Formatter.get_value.__qualname__ == 'Formatter.get_value'"]
    - [Formatter_check_unused_args,
       Formatter.check_unused_args.__qualname__.__eq__,
       ["Formatter.check_unused_args"],
       true,
       "Formatter.check_unused_args.__qualname__ == 'Formatter.check_unused_args'"]
    - [Formatter_format_field,
       Formatter.format_field.__qualname__.__eq__,
       ["Formatter.format_field"],
       true,
       "Formatter.format_field.__qualname__ == 'Formatter.format_field'"]
    - [Formatter_convert_field,
       Formatter.convert_field.__qualname__.__eq__,
       ["Formatter.convert_field"],
       true,
       "Formatter.convert_field.__qualname__ == 'Formatter.convert_field'"]

# ---------------------------------------------------------------------------
# Table: Template __init__ and constant class names
#
# Groups Template.__init__/__qualname__, Template.__init_subclass__/__qualname__,
# and the two string constant class name checks into a single table.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra22.template_and_constants:
  description: "string.Template init qualnames and string constant class names"
  kind: python_call_eq
  category: string_constants
  columns: [id, function, args, expected, description]
  rows:
    - [Template_init,
       Template.__init__.__qualname__.__eq__,
       ["Template.__init__"],
       true,
       "Template.__init__.__qualname__ == 'Template.__init__'"]
    - [Template_init_subclass,
       Template.__init_subclass__.__qualname__.__eq__,
       ["Template.__init_subclass__"],
       true,
       "Template.__init_subclass__.__qualname__ == 'Template.__init_subclass__'"]
    - [whitespace_class,
       whitespace.__class__.__name__.__eq__,
       ["str"],
       true,
       "whitespace.__class__.__name__ == 'str'"]
    - [punctuation_class,
       punctuation.__class__.__name__.__eq__,
       ["str"],
       true,
       "punctuation.__class__.__name__ == 'str'"]
