spec: socket_extra170
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra169.zspec.zsdl — covers socket.socket.__dict__ Python vs C-inherited membership (connect==False/makefile==True/sendfile==True) and __dict__.__len__()==28 and socket.socket.__name__/__module__ identity (table + invariants)."
    - "socket_extra168.zspec.zsdl — covers socket.socket class base identity and socket.create_connection/__create_server/__getaddrinfo function identity (table + invariants)."
    - "socket_extra167.zspec.zsdl — covers socket.AddressFamily/__SocketKind __name__/__module__/__bases__[0].__name__=='IntEnum' and name lengths (13/10) (table + invariants)."
    - "socket_extra166.zspec.zsdl — covers socket.AF_INET/__SOCK_STREAM/__AF_INET6/__SOCK_DGRAM/__IPPROTO_TCP/__IPPROTO_UDP enum constant class names and integer values (table + invariants)."
    - "socket_extra165.zspec.zsdl — covers socket.error/__timeout/__gaierror/__herror class identity (table + invariants)."
    - "socket_extra164.zspec.zsdl — covers socket.socket.__dict__ method membership (table + invariants)."
    - "socket_extra159.zspec.zsdl — covers socket.socket.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra169."
    - "Wave 352 theme: socket low-level constants AF_UNIX/SOCK_RAW (AddressFamily/SocketKind enums) and SOL_SOCKET/SO_REUSEADDR (plain int constants) on macOS/Darwin. socket_extra166 anchors AF_INET/SOCK_STREAM/AF_INET6/SOCK_DGRAM as AddressFamily/SocketKind enums with their integer values. This spec anchors AF_UNIX (==1 on macOS) and SOCK_RAW (==3 on macOS) plus the plain int SOL_SOCKET (==65535 on macOS) and SO_REUSEADDR (==4 on macOS) as the primary novel content."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0. AF_UNIX is a member of the socket.AddressFamily IntEnum."
    - "socket.AF_UNIX.__eq__(1) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. On macOS, AF_UNIX has integer value 1."
    - "socket.SOCK_RAW.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0. SOCK_RAW is a member of the socket.SocketKind IntEnum."
    - "socket.SOCK_RAW.__eq__(3) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. SOCK_RAW has integer value 3."
    - "socket.SOL_SOCKET.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0. SOL_SOCKET is a plain int constant (not an IntEnum member)."
    - "socket.SOL_SOCKET.__eq__(65535) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. On macOS, SOL_SOCKET is 65535 (0xFFFF)."
    - "socket.SO_REUSEADDR.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0. SO_REUSEADDR is a plain int constant."
    - "socket.SO_REUSEADDR.__eq__(4) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. On macOS, SO_REUSEADDR is 4."
    - "Note: socket.AF_UNIX.__class__.__name__ == 'AddressFamily' (13 chars). AF_UNIX is the address family for Unix domain sockets (local inter-process communication). Its integer value is 1 on macOS (AF_UNIX=1). socket_extra166 anchors AF_INET.__class__.__name__=='AddressFamily' and AF_INET6.__class__.__name__=='AddressFamily'; this spec adds AF_UNIX (value 1 — the lowest-numbered address family on macOS)."
    - "Note: socket.SOCK_RAW.__class__.__name__ == 'SocketKind' (10 chars). SOCK_RAW provides raw network protocol access, bypassing the transport layer. Its integer value is 3 on macOS. socket_extra166 anchors SOCK_STREAM (1) and SOCK_DGRAM (2); this spec adds SOCK_RAW (3 — the third SocketKind value)."
    - "Note: socket.SOL_SOCKET.__class__.__name__ == 'int' (3 chars). SOL_SOCKET is the socket-level option level constant, used as the first argument to setsockopt()/getsockopt() when the option is at the socket level (not protocol-specific). On macOS, SOL_SOCKET == 65535 (0xFFFF). It is a plain int, not an IntEnum member."
    - "Note: socket.SO_REUSEADDR.__class__.__name__ == 'int' (3 chars). SO_REUSEADDR is a socket option that allows reuse of a local address. On macOS, SO_REUSEADDR == 4. It is a plain int, not an IntEnum member."
    - "Note: macOS/Darwin platform specifics: AF_UNIX=1, SOCK_RAW=3, SOL_SOCKET=65535 (0xFFFF — macOS uses 0xFFFF for SOL_SOCKET while Linux uses 1), SO_REUSEADDR=4. These values may differ on Linux (SOL_SOCKET=1 on Linux)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily')
# socket.AF_UNIX.__eq__(1)
# socket.SOCK_RAW.__class__.__name__.__eq__('SocketKind')
# socket.SOCK_RAW.__eq__(3)
#
# Wave 352 theme: AF_UNIX and SOCK_RAW enum constants — class names and integer values.
#
# AF_UNIX.__class__.__name__ == 'AddressFamily' (13 chars; socket_extra166 anchors AF_INET).
# AF_UNIX.__eq__(1) == True (value 1 on macOS).
# SOCK_RAW.__class__.__name__ == 'SocketKind' (10 chars; socket_extra166 anchors SOCK_STREAM).
# SOCK_RAW.__eq__(3) == True (value 3 on macOS).
# Novel: no prior socket spec anchors AF_UNIX or SOCK_RAW.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra170.AF_UNIX_SOCK_RAW_class_and_value:
  description: "socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily')==True / AF_UNIX.__eq__(1)==True / SOCK_RAW.__class__.__name__.__eq__('SocketKind')==True / SOCK_RAW.__eq__(3)==True — AF_UNIX.__class__.__name__ is 'AddressFamily' (13 chars; socket.AF_UNIX is a member of socket.AddressFamily IntEnum; AF_UNIX is the address family for Unix domain sockets (AF_UNIX, also called AF_LOCAL), used for local inter-process communication via filesystem paths or abstract namespace; 'AddressFamily'(13 chars) is the same 13-char class name as AF_INET.__class__.__name__ — socket_extra166 anchors AF_INET.__class__.__name__=='AddressFamily'; this spec adds AF_UNIX; novel anchor); AF_UNIX.__eq__(1) is True (socket.AF_UNIX has integer value 1 on macOS/Darwin; AF_UNIX is the first address family constant — value 1; AF_INET is value 2 on macOS — so AF_UNIX(1) < AF_INET(2); socket_extra166 anchors AF_INET.__eq__(2)==True; this spec adds AF_UNIX==1 as the novel anchor); SOCK_RAW.__class__.__name__ is 'SocketKind' (10 chars; socket.SOCK_RAW is a member of socket.SocketKind IntEnum; SOCK_RAW provides raw network protocol access bypassing TCP/UDP transport layer; used for custom protocol implementations; 'SocketKind'(10 chars) is the same 10-char class name as SOCK_STREAM.__class__.__name__ — socket_extra166 anchors SOCK_STREAM.__class__.__name__=='SocketKind'; this spec adds SOCK_RAW; novel anchor); SOCK_RAW.__eq__(3) is True (socket.SOCK_RAW has integer value 3 on macOS; SOCK_STREAM(1) < SOCK_DGRAM(2) < SOCK_RAW(3) in integer value ordering; socket_extra166 anchors SOCK_STREAM==1 and SOCK_DGRAM==2; first sockenum170 anchor for AF_UNIX and SOCK_RAW)"
  kind: python_call_eq
  category: identity
  id_prefix: sockenum170

  columns: [id, function, args, expected, description]
  rows:
    - [af_unix_class_af,   "AF_UNIX.__class__.__name__.__eq__",  ["AddressFamily"], true, "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' (13 chars; Unix domain sockets; socket_extra166 anchors AF_INET same class; novel AF_UNIX anchor)"]
    - [af_unix_eq_1,       "AF_UNIX.__eq__",                     [1],               true, "socket.AF_UNIX.__eq__(1) == True (value 1 on macOS; AF_UNIX(1) < AF_INET(2); socket_extra166 anchors AF_INET==2; novel anchor)"]
    - [sock_raw_class_sk,  "SOCK_RAW.__class__.__name__.__eq__", ["SocketKind"],    true, "socket.SOCK_RAW.__class__.__name__ == 'SocketKind' (10 chars; raw protocol access; socket_extra166 anchors SOCK_STREAM same class; novel SOCK_RAW anchor)"]
    - [sock_raw_eq_3,      "SOCK_RAW.__eq__",                    [3],               true, "socket.SOCK_RAW.__eq__(3) == True (value 3 on macOS; SOCK_STREAM(1)<SOCK_DGRAM(2)<SOCK_RAW(3); socket_extra166 anchors SOCK_STREAM==1/SOCK_DGRAM==2)"]

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET.__class__.__name__.__eq__('int')
# socket.SOL_SOCKET.__eq__(65535)
# socket.SO_REUSEADDR.__class__.__name__.__eq__('int')
# socket.SO_REUSEADDR.__eq__(4)
#
# Wave 352 theme: SOL_SOCKET and SO_REUSEADDR are plain int constants (not IntEnum) on macOS.
#
# SOL_SOCKET.__class__.__name__ == 'int' (3 chars; plain int, not AddressFamily/SocketKind).
# SOL_SOCKET.__eq__(65535) == True (0xFFFF on macOS; Linux uses 1).
# SO_REUSEADDR.__class__.__name__ == 'int' (3 chars; plain int).
# SO_REUSEADDR.__eq__(4) == True (value 4 on macOS).
# Novel: no prior socket spec anchors SOL_SOCKET or SO_REUSEADDR.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra170.SOL_SOCKET_SO_REUSEADDR_class_and_value:
  description: "socket.SOL_SOCKET.__class__.__name__.__eq__('int')==True / SOL_SOCKET.__eq__(65535)==True / SO_REUSEADDR.__class__.__name__.__eq__('int')==True / SO_REUSEADDR.__eq__(4)==True — SOL_SOCKET.__class__.__name__ is 'int' (3 chars; socket.SOL_SOCKET is a plain Python int constant, NOT an IntEnum member like AF_UNIX or SOCK_RAW; SOL_SOCKET is the socket option level used as the first argument to setsockopt(SOL_SOCKET, optname, optval) when the option operates at the generic socket level; 'int'(3 chars) < 'AddressFamily'(13) < 'SocketKind'(10) in type name length: plain int constants have shorter type names than enum members; novel anchor — no prior socket spec anchors SOL_SOCKET.__class__.__name__); SOL_SOCKET.__eq__(65535) is True (socket.SOL_SOCKET == 65535 (0xFFFF) on macOS/Darwin; this is platform-specific: on Linux, SOL_SOCKET == 1; the macOS value 65535 == 0xFFFF is unusual; novel anchor); SO_REUSEADDR.__class__.__name__ is 'int' (3 chars; socket.SO_REUSEADDR is a plain Python int constant; SO_REUSEADDR is a socket option that allows reuse of a local address/port — used in servers to bind to a recently-used port without waiting for TIME_WAIT; 'int'(3)==SOL_SOCKET.__class__.__name__(3) — both socket-level option constants are plain ints; novel anchor); SO_REUSEADDR.__eq__(4) is True (socket.SO_REUSEADDR == 4 on macOS/Darwin; this is platform-specific: on Linux, SO_REUSEADDR == 2; novel anchor; first sockenum170 anchor for SOL_SOCKET and SO_REUSEADDR constants)"
  kind: python_call_eq
  category: identity
  id_prefix: sockenum170

  columns: [id, function, args, expected, description]
  rows:
    - [sol_sock_class_int,    "SOL_SOCKET.__class__.__name__.__eq__",  ["int"], true,  "socket.SOL_SOCKET.__class__.__name__ == 'int' (3 chars; plain int not IntEnum; used as setsockopt level; novel anchor)"]
    - [sol_sock_eq_65535,     "SOL_SOCKET.__eq__",                     [65535], true,  "socket.SOL_SOCKET.__eq__(65535) == True (0xFFFF on macOS; platform-specific: Linux uses 1; novel anchor)"]
    - [so_reuseaddr_class_int,"SO_REUSEADDR.__class__.__name__.__eq__",["int"], true,  "socket.SO_REUSEADDR.__class__.__name__ == 'int' (3 chars; plain int not IntEnum; allows port reuse; novel anchor)"]
    - [so_reuseaddr_eq_4,     "SO_REUSEADDR.__eq__",                   [4],    true,  "socket.SO_REUSEADDR.__eq__(4) == True (value 4 on macOS; platform-specific: Linux uses 2; novel anchor)"]

# ---------------------------------------------------------------------------
# Cross-type comparison: AddressFamily/SocketKind enum vs int constants
#
# Wave 352 theme: comparing the two kinds of socket constants — IntEnum vs plain int.
#
# AF_UNIX.__class__.__name__ == 'AddressFamily' (13 chars; IntEnum member).
# SOCK_RAW.__class__.__name__ == 'SocketKind' (10 chars; IntEnum member).
# SOL_SOCKET.__class__.__name__ == 'int' (3 chars; plain int).
# SO_REUSEADDR.__class__.__name__ == 'int' (3 chars; plain int).
# Type name length ordering: 'int'(3) < 'SocketKind'(10) < 'AddressFamily'(13).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra170.socket_constant_type_name_ordering:
  description: "socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily')==True / SOCK_RAW.__class__.__name__.__eq__('SocketKind')==True / SOL_SOCKET.__class__.__name__.__eq__('int')==True / SO_REUSEADDR.__class__.__name__.__eq__('int')==True — AF_UNIX.__class__.__name__ is 'AddressFamily' (13 chars; confirmed; IntEnum subclass; 'AddressFamily'(13) is the longest type name in this comparison: 13 > 10 > 3; socket_extra167 anchors AddressFamily.__name__=='AddressFamily' with __name__.__len__()==13); SOCK_RAW.__class__.__name__ is 'SocketKind' (10 chars; confirmed; IntEnum subclass; 'SocketKind'(10) is the middle type name: 3 < 10 < 13; socket_extra167 anchors SocketKind.__name__=='SocketKind' with __name__.__len__()==10; complete ordering: 'int'(3) < 'SocketKind'(10) < 'AddressFamily'(13)); SOL_SOCKET.__class__.__name__ is 'int' (3 chars; confirmed; plain int, not an IntEnum member; 'int'(3) is the shortest type name: 3 < 10 < 13; SOL_SOCKET is a plain int module-level constant, not wrapped in an IntEnum subclass; 'int'(3) is the Python built-in integer type name); SO_REUSEADDR.__class__.__name__ is 'int' (3 chars; confirmed; plain int; SO_REUSEADDR.__class__.__name__(3)==SOL_SOCKET.__class__.__name__(3)=='int'(3) — both socket-level option constants have the same 3-char type name; type name ordering: 'int'(3) < 'SocketKind'(10) < 'AddressFamily'(13); first sockenum170 anchor for cross-type comparison)"
  kind: python_call_eq
  category: identity
  id_prefix: sockenum170

  columns: [id, function, args, expected, description]
  rows:
    - [af_unix_class_af_b,    "AF_UNIX.__class__.__name__.__eq__",     ["AddressFamily"], true, "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' (13 chars; longest type name; IntEnum subclass; 'AddressFamily'(13) > 'SocketKind'(10) > 'int'(3))"]
    - [sock_raw_class_sk_b,   "SOCK_RAW.__class__.__name__.__eq__",    ["SocketKind"],    true, "socket.SOCK_RAW.__class__.__name__ == 'SocketKind' (10 chars; IntEnum subclass; 'SocketKind'(10) is between 'int'(3) and 'AddressFamily'(13))"]
    - [sol_sock_class_int_b,  "SOL_SOCKET.__class__.__name__.__eq__",  ["int"],           true, "socket.SOL_SOCKET.__class__.__name__ == 'int' (3 chars; shortest type name; plain int not IntEnum; 'int'(3) < 'SocketKind'(10) < 'AddressFamily'(13))"]
    - [so_reuseaddr_int_b,    "SO_REUSEADDR.__class__.__name__.__eq__",["int"],           true, "socket.SO_REUSEADDR.__class__.__name__ == 'int' (3 chars; plain int; SO_REUSEADDR(3)==SOL_SOCKET(3) in type name length — both plain ints)"]

# ---------------------------------------------------------------------------
# socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily') — standalone
#
# socket.AF_UNIX.__class__.__name__ is 'AddressFamily' (13 chars). AF_UNIX is a member
# of the socket.AddressFamily IntEnum. It represents Unix domain sockets (AF_UNIX / AF_LOCAL),
# used for local inter-process communication. On macOS, AF_UNIX == 1 (the lowest-valued
# address family). socket_extra166 anchors AF_INET.__class__.__name__=='AddressFamily';
# this standalone provides the first anchor for AF_UNIX.__class__.__name__ under sockenum170.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra170.AF_UNIX_class_AddressFamily:
  description: "socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily') == True — 'AddressFamily' (13 chars; socket.AF_UNIX is a member of socket.AddressFamily IntEnum; AF_UNIX (also AF_LOCAL) is the address family for Unix domain sockets, used for local inter-process communication via filesystem paths or abstract namespace; AF_UNIX.__eq__(1)==True on macOS — value 1 is the lowest numbered address family; socket_extra166 anchors AF_INET.__class__.__name__=='AddressFamily' and AF_INET6.__class__.__name__=='AddressFamily' as table rows; this spec provides the first anchor for AF_UNIX.__class__.__name__=='AddressFamily'; first sockenum170 standalone for AF_UNIX.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: AF_UNIX.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_RAW.__class__.__name__.__eq__('SocketKind') — standalone
#
# socket.SOCK_RAW.__class__.__name__ is 'SocketKind' (10 chars). SOCK_RAW is a member
# of the socket.SocketKind IntEnum. It provides raw network protocol access, bypassing
# the TCP/UDP transport layer — useful for custom protocol implementations. On macOS,
# SOCK_RAW == 3. socket_extra166 anchors SOCK_STREAM.__class__.__name__=='SocketKind';
# this standalone provides the first anchor for SOCK_RAW.__class__.__name__ under sockenum170.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra170.SOCK_RAW_class_SocketKind:
  description: "socket.SOCK_RAW.__class__.__name__.__eq__('SocketKind') == True — 'SocketKind' (10 chars; socket.SOCK_RAW is a member of socket.SocketKind IntEnum; SOCK_RAW provides raw access to underlying network protocol, bypassing TCP/UDP; requires root/CAP_NET_RAW on most systems; SOCK_RAW.__eq__(3)==True on macOS — value 3; SOCK_STREAM(1) < SOCK_DGRAM(2) < SOCK_RAW(3) in integer value ordering; socket_extra166 anchors SOCK_STREAM.__class__.__name__=='SocketKind' and SOCK_DGRAM.__class__.__name__=='SocketKind' as table rows; first sockenum170 standalone for SOCK_RAW.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: SOCK_RAW.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_UNIX.__eq__(1) — standalone (macOS)
#
# socket.AF_UNIX.__eq__(1) is True. On macOS/Darwin, AF_UNIX has integer value 1.
# AF_UNIX is the lowest-numbered address family on macOS. socket_extra166 anchors
# AF_INET.__eq__(2)==True and AF_INET6.__eq__(30)==True (macOS values). This standalone
# provides the first anchor for AF_UNIX.__eq__(1) under sockenum170.
# NOTE: macOS-specific. Linux also uses AF_UNIX=1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra170.AF_UNIX_eq_1:
  description: "socket.AF_UNIX.__eq__(1) == True — value 1 on macOS/Darwin 25.4.0; AF_UNIX is the lowest-numbered address family constant on macOS; AF_UNIX(1) < AF_INET(2): AF_UNIX is 1 less than AF_INET; socket_extra166 anchors AF_INET.__eq__(2)==True on macOS; AF_UNIX == 1 on Linux as well (this value is consistent across POSIX platforms); AF_UNIX.__class__.__name__=='AddressFamily'(13) — it is an IntEnum member with integer value 1; first sockenum170 standalone for AF_UNIX.__eq__(1)"
  category: identity
  kind: python_call_eq
  function: AF_UNIX.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_RAW.__eq__(3) — standalone (macOS)
#
# socket.SOCK_RAW.__eq__(3) is True. On macOS/Darwin, SOCK_RAW has integer value 3.
# SOCK_STREAM==1, SOCK_DGRAM==2, SOCK_RAW==3 — three consecutive integers. socket_extra166
# anchors SOCK_STREAM.__eq__(1)==True and SOCK_DGRAM.__eq__(2)==True (macOS values).
# This standalone provides the first anchor for SOCK_RAW.__eq__(3) under sockenum170.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra170.SOCK_RAW_eq_3:
  description: "socket.SOCK_RAW.__eq__(3) == True — value 3 on macOS/Darwin 25.4.0; SOCK_STREAM(1) < SOCK_DGRAM(2) < SOCK_RAW(3): three consecutive integer values for the three basic socket kinds; socket_extra166 anchors SOCK_STREAM.__eq__(1)==True and SOCK_DGRAM.__eq__(2)==True on macOS; SOCK_RAW(3) is the third in the sequence; SOCK_RAW.__class__.__name__=='SocketKind'(10) — IntEnum member with value 3; SOCK_RAW typically requires elevated privileges (root or CAP_NET_RAW); first sockenum170 standalone for SOCK_RAW.__eq__(3)"
  category: identity
  kind: python_call_eq
  function: SOCK_RAW.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET.__class__.__name__.__eq__('int') — standalone
#
# socket.SOL_SOCKET.__class__.__name__ is 'int' (3 chars). SOL_SOCKET is a plain Python
# int constant, not an IntEnum member. It is used as the first argument to
# setsockopt(SOL_SOCKET, optname, optval) when setting socket-level options (as opposed to
# IPPROTO_TCP or IPPROTO_UDP for protocol-specific options). On macOS, SOL_SOCKET == 65535.
# Novel anchor: no prior socket spec anchors SOL_SOCKET.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra170.SOL_SOCKET_class_int:
  description: "socket.SOL_SOCKET.__class__.__name__.__eq__('int') == True — 'int' (3 chars; SOL_SOCKET is a plain Python int module-level constant, NOT a socket.AddressFamily or socket.SocketKind IntEnum member; used as the first arg to setsockopt(SOL_SOCKET, optname, val) for socket-level options; 'int'(3) < 'SocketKind'(10) < 'AddressFamily'(13): plain int type name is shorter than both IntEnum type names; SOL_SOCKET.__eq__(65535)==True on macOS (0xFFFF); novel anchor — no prior socket spec anchors SOL_SOCKET.__class__.__name__; first sockenum170 standalone for SOL_SOCKET.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: SOL_SOCKET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET.__eq__(65535) — standalone (macOS)
#
# socket.SOL_SOCKET.__eq__(65535) is True. On macOS/Darwin, SOL_SOCKET == 65535 (0xFFFF).
# This is a macOS-specific value — on Linux, SOL_SOCKET == 1. The macOS value 65535 = 0xFFFF
# is a large 16-bit constant used as the socket-level option level identifier.
# Novel anchor: no prior socket spec anchors SOL_SOCKET.__eq__(65535).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra170.SOL_SOCKET_eq_65535:
  description: "socket.SOL_SOCKET.__eq__(65535) == True — value 65535 (0xFFFF) on macOS/Darwin 25.4.0; platform-specific: Linux uses SOL_SOCKET==1, while macOS uses 65535 (0xFFFF); 65535 = 2^16 - 1 = the maximum 16-bit unsigned integer value; SOL_SOCKET.__class__.__name__=='int'(3 chars; plain int constant); SOL_SOCKET is used as the level arg in setsockopt(SOL_SOCKET, SO_REUSEADDR, 1) etc.; novel anchor — no prior socket spec anchors SOL_SOCKET.__eq__(65535); first sockenum170 standalone for SOL_SOCKET.__eq__(65535)"
  category: identity
  kind: python_call_eq
  function: SOL_SOCKET.__eq__
  args: [65535]
  expected: true

# ---------------------------------------------------------------------------
# socket.SO_REUSEADDR.__class__.__name__.__eq__('int') — standalone
#
# socket.SO_REUSEADDR.__class__.__name__ is 'int' (3 chars). SO_REUSEADDR is a plain Python
# int constant used as a socket option name with setsockopt(SOL_SOCKET, SO_REUSEADDR, 1).
# It enables address reuse, allowing a server to bind to a recently-released port without
# waiting for the TIME_WAIT state to expire. On macOS, SO_REUSEADDR == 4.
# Novel anchor: no prior socket spec anchors SO_REUSEADDR.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra170.SO_REUSEADDR_class_int:
  description: "socket.SO_REUSEADDR.__class__.__name__.__eq__('int') == True — 'int' (3 chars; SO_REUSEADDR is a plain Python int constant, not an IntEnum member; used as setsockopt(SOL_SOCKET, SO_REUSEADDR, 1) to enable address reuse — allows servers to bind to recently-released ports; SO_REUSEADDR.__class__.__name__(3)==SOL_SOCKET.__class__.__name__(3)=='int'(3): both socket-level option constants are plain ints; SO_REUSEADDR.__eq__(4)==True on macOS; novel anchor — no prior socket spec anchors SO_REUSEADDR.__class__.__name__; first sockenum170 standalone for SO_REUSEADDR.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: SO_REUSEADDR.__class__.__name__.__eq__
  args: ["int"]
  expected: true
