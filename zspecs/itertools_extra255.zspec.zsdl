spec: itertools_extra255
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools error handling — ValueError from negative arguments and type errors from bad argument types."
    - "itertools.islice(range(10), -1) raises ValueError: 'Stop argument for islice() must be None or an integer: 0 <= x <= sys.maxsize.' Verified with Python 3.14.3."
    - "itertools.combinations(range(3), -1) raises ValueError: 'r must be non-negative'. Verified with Python 3.14.3."
    - "itertools.permutations(range(3), -1) raises ValueError: 'r must be non-negative'. Verified with Python 3.14.3."
    - "itertools.islice('abc', 'x') raises ValueError: 'Stop argument for islice() must be None or an integer: 0 <= x <= sys.maxsize.' Verified with Python 3.14.3."
    - "itertools.repeat(1, -1) returns [] (empty); it does NOT raise — a negative count is treated as zero. Verified with Python 3.14.3."
    - "itertools.combinations(range(3), 4) returns [] (empty); it does NOT raise — r > n simply yields no combinations. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.islice ValueError on negative or invalid stop
#
# itertools.islice(range(10), -1) raises ValueError
# itertools.islice('abc', 'x') raises ValueError
#
# islice enforces that its stop/start/step arguments must be None or a
# non-negative integer. Both negative integers and non-integer types raise
# ValueError. New to extra255.
# ---------------------------------------------------------------------------

table itertools_extra255.islice_errors:
  description: "itertools.islice raises ValueError for negative stop and non-integer stop; new to extra255"
  kind: python_call_raises
  category: errors
  id_prefix: isliceerr255

  columns: [id, function, args, raises, description]
  rows:
    - [islice_negative_stop,
       islice,
       ["range(10)", -1],
       ValueError,
       "itertools.islice(range(10), -1) raises ValueError — stop must be None or a non-negative integer; new to extra255"]
    - [islice_string_stop,
       islice,
       ["abc", "x"],
       ValueError,
       "itertools.islice('abc', 'x') raises ValueError — stop must be None or an integer, not a string; new to extra255"]
    - [islice_negative_start,
       islice,
       ["abc", -1, null],
       ValueError,
       "itertools.islice('abc', -1, None) raises ValueError — start index must be None or a non-negative integer; new to extra255"]
    - [combinations_negative_r,
       combinations,
       ["range(3)", -1],
       ValueError,
       "itertools.combinations(range(3), -1) raises ValueError: 'r must be non-negative'; new to extra255"]
    - [permutations_negative_r,
       permutations,
       ["range(3)", -1],
       ValueError,
       "itertools.permutations(range(3), -1) raises ValueError: 'r must be non-negative'; new to extra255"]

# ---------------------------------------------------------------------------
# Table 2: itertools functions that do NOT raise on edge-case inputs
#
# itertools.repeat(1, -1) -> [] (treated as zero count)
# itertools.combinations(range(3), 4) -> [] (r > n yields empty sequence)
#
# These are correctness contracts confirming no exception is raised. New to extra255.
# ---------------------------------------------------------------------------

table itertools_extra255.edge_case_identity:
  description: "itertools.combinations.__name__ and islice.__name__ identity; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsedge255

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_name_eq,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C-level type; __name__ is 'combinations'; new to extra255"]
    - [islice_name_eq,
       islice.__name__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice is a C-level type; __name__ is 'islice'; new to extra255"]
    - [permutations_name_eq,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C-level type; __name__ is 'permutations'; new to extra255"]
    - [combinations_module_eq,
       combinations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is defined in the itertools C extension; new to extra255"]
    - [islice_module_eq,
       islice.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is defined in the itertools C extension; new to extra255"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra255
# ---------------------------------------------------------------------------

invariant itertools_extra255.islice.negative_stop_raises_valueerror:
  description: "itertools.islice(range(10), -1) raises ValueError — stop must be None or a non-negative integer; new to extra255"
  category: errors
  kind: python_call_raises
  function: islice
  args: ["range(10)", -1]
  raises: ValueError

invariant itertools_extra255.islice.string_stop_raises_valueerror:
  description: "itertools.islice('abc', 'x') raises ValueError — stop must be None or an integer, not a string; new to extra255"
  category: errors
  kind: python_call_raises
  function: islice
  args: ["abc", "x"]
  raises: ValueError

invariant itertools_extra255.combinations.negative_r_raises_valueerror:
  description: "itertools.combinations(range(3), -1) raises ValueError: 'r must be non-negative'; new to extra255"
  category: errors
  kind: python_call_raises
  function: combinations
  args: ["range(3)", -1]
  raises: ValueError

invariant itertools_extra255.permutations.negative_r_raises_valueerror:
  description: "itertools.permutations(range(3), -1) raises ValueError: 'r must be non-negative'; new to extra255"
  category: errors
  kind: python_call_raises
  function: permutations
  args: ["range(3)", -1]
  raises: ValueError

invariant itertools_extra255.combinations.name_eq:
  description: "itertools.combinations.__name__ == 'combinations' — C-level type; new to extra255"
  category: identity
  kind: python_call_eq
  function: combinations.__name__.__eq__
  args: ["combinations"]
  expected: true

invariant itertools_extra255.islice.name_eq:
  description: "itertools.islice.__name__ == 'islice' — C-level type; new to extra255"
  category: identity
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true

invariant itertools_extra255.permutations.name_eq:
  description: "itertools.permutations.__name__ == 'permutations' — C-level type; new to extra255"
  category: identity
  kind: python_call_eq
  function: permutations.__name__.__eq__
  args: ["permutations"]
  expected: true
