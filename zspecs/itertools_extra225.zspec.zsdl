spec: itertools_extra225
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools __doc__ string contains checks."
    - "itertools.__doc__ contains 'iterators'. Verified with Python 3.14.3."
    - "itertools.chain.__doc__ contains 'chain'. Verified with Python 3.14.3."
    - "itertools.cycle.__doc__ contains 'repeat'. Verified with Python 3.14.3 — cycle docstring is 'Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.'"
    - "itertools.repeat.__doc__ contains 'repeat'. Verified with Python 3.14.3."
    - "itertools.count.__doc__ contains 'count'. Verified with Python 3.14.3."
    - "itertools.islice.__doc__ contains 'iterator'. Verified with Python 3.14.3."
    - "itertools.product.__doc__ contains 'product'. Verified with Python 3.14.3."
    - "itertools.combinations.__doc__ contains 'combination'. Verified with Python 3.14.3."
    - "itertools.permutations.__doc__ contains 'permutation'. Verified with Python 3.14.3."
    - "itertools.accumulate.__doc__ contains 'accumulate'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools __doc__ contains checks (module + basic iterators)
#
# Verified with Python 3.14.3:
#   itertools.__doc__ contains 'iterators' (module docstring: 'Functional tools for creating and using iterators.')
#   itertools.chain.__doc__ contains 'chain'
#   itertools.cycle.__doc__ contains 'repeat' (docstring: '...Then repeat the sequence indefinitely.')
#   itertools.repeat.__doc__ contains 'repeat'
#   itertools.count.__doc__ contains 'count'
# ---------------------------------------------------------------------------

table itertools_extra225.doc_contains_basic:
  description: "itertools __doc__ string contains checks for module and basic iterators; new to extra225"
  kind: python_call_eq
  category: doc_inspection
  id_prefix: itertoolsextra225docbasic

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_contains_iterators,
       __doc__.__contains__,
       ["iterators"],
       true,
       "itertools.__doc__.__contains__('iterators') == True — module docstring is 'Functional tools for creating and using iterators.'; contains 'iterators'; new to extra225"]
    - [chain_doc_contains_chain,
       chain.__doc__.__contains__,
       ["chain"],
       true,
       "itertools.chain.__doc__.__contains__('chain') == True — chain docstring starts with 'Return a chain object whose .__next__() method'; contains 'chain'; new to extra225"]
    - [cycle_doc_contains_repeat,
       cycle.__doc__.__contains__,
       ["repeat"],
       true,
       "itertools.cycle.__doc__.__contains__('repeat') == True — cycle docstring is 'Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.'; contains 'repeat'; new to extra225"]
    - [repeat_doc_contains_repeat,
       repeat.__doc__.__contains__,
       ["repeat"],
       true,
       "itertools.repeat.__doc__.__contains__('repeat') == True — repeat docstring starts with 'repeat(object [,times]) -> create an iterator which returns the object'; contains 'repeat'; new to extra225"]
    - [count_doc_contains_count,
       count.__doc__.__contains__,
       ["count"],
       true,
       "itertools.count.__doc__.__contains__('count') == True — count docstring starts with 'Return a count object whose .__next__() method'; contains 'count'; new to extra225"]

# ---------------------------------------------------------------------------
# Table 2: itertools __doc__ contains checks (slice + combinatoric)
#
# Verified with Python 3.14.3:
#   itertools.islice.__doc__ contains 'iterator' (docstring: '...Return an iterator whose next() method...')
#   itertools.product.__doc__ contains 'product'
#   itertools.combinations.__doc__ contains 'combination'
#   itertools.permutations.__doc__ contains 'permutation'
#   itertools.accumulate.__doc__ contains 'accumulate'
# ---------------------------------------------------------------------------

table itertools_extra225.doc_contains_combinatoric:
  description: "itertools __doc__ string contains checks for slice and combinatoric iterators; new to extra225"
  kind: python_call_eq
  category: doc_inspection
  id_prefix: itertoolsextra225doccomb

  columns: [id, function, args, expected, description]
  rows:
    - [islice_doc_contains_iterator,
       islice.__doc__.__contains__,
       ["iterator"],
       true,
       "itertools.islice.__doc__.__contains__('iterator') == True — islice docstring contains 'Return an iterator whose next() method returns selected values'; contains 'iterator'; new to extra225"]
    - [product_doc_contains_product,
       product.__doc__.__contains__,
       ["product"],
       true,
       "itertools.product.__doc__.__contains__('product') == True — product docstring starts with 'Cartesian product of input iterables'; contains 'product'; new to extra225"]
    - [combinations_doc_contains_combination,
       combinations.__doc__.__contains__,
       ["combination"],
       true,
       "itertools.combinations.__doc__.__contains__('combination') == True — combinations docstring is 'Return successive r-length combinations of elements in the iterable.'; contains 'combination'; new to extra225"]
    - [permutations_doc_contains_permutation,
       permutations.__doc__.__contains__,
       ["permutation"],
       true,
       "itertools.permutations.__doc__.__contains__('permutation') == True — permutations docstring is 'Return successive r-length permutations of elements in the iterable.'; contains 'permutation'; new to extra225"]
    - [accumulate_doc_contains_accumulate,
       accumulate.__doc__.__contains__,
       ["accumulate"],
       true,
       "itertools.accumulate.__doc__.__contains__('accumulate') == True — accumulate docstring is 'Return series of accumulated sums (or other binary function results).'; contains 'accumulate'; new to extra225"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra225
# ---------------------------------------------------------------------------

invariant itertools_extra225.module_doc_contains_iterators:
  description: "itertools.__doc__.__contains__('iterators') == True — module docstring contains 'iterators'; new to extra225"
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["iterators"]
  expected: true

invariant itertools_extra225.chain_doc_contains_chain:
  description: "itertools.chain.__doc__.__contains__('chain') == True — chain docstring contains 'chain'; new to extra225"
  kind: python_call_eq
  function: chain.__doc__.__contains__
  args: ["chain"]
  expected: true

invariant itertools_extra225.cycle_doc_contains_repeat:
  description: "itertools.cycle.__doc__.__contains__('repeat') == True — cycle docstring contains 'repeat' (sequence is repeated indefinitely); new to extra225"
  kind: python_call_eq
  function: cycle.__doc__.__contains__
  args: ["repeat"]
  expected: true

invariant itertools_extra225.repeat_doc_contains_repeat:
  description: "itertools.repeat.__doc__.__contains__('repeat') == True — repeat docstring contains 'repeat'; new to extra225"
  kind: python_call_eq
  function: repeat.__doc__.__contains__
  args: ["repeat"]
  expected: true

invariant itertools_extra225.count_doc_contains_count:
  description: "itertools.count.__doc__.__contains__('count') == True — count docstring contains 'count'; new to extra225"
  kind: python_call_eq
  function: count.__doc__.__contains__
  args: ["count"]
  expected: true

invariant itertools_extra225.islice_doc_contains_iterator:
  description: "itertools.islice.__doc__.__contains__('iterator') == True — islice docstring contains 'iterator'; new to extra225"
  kind: python_call_eq
  function: islice.__doc__.__contains__
  args: ["iterator"]
  expected: true

invariant itertools_extra225.product_doc_contains_product:
  description: "itertools.product.__doc__.__contains__('product') == True — product docstring contains 'product'; new to extra225"
  kind: python_call_eq
  function: product.__doc__.__contains__
  args: ["product"]
  expected: true

invariant itertools_extra225.combinations_doc_contains_combination:
  description: "itertools.combinations.__doc__.__contains__('combination') == True — combinations docstring contains 'combination'; new to extra225"
  kind: python_call_eq
  function: combinations.__doc__.__contains__
  args: ["combination"]
  expected: true

invariant itertools_extra225.permutations_doc_contains_permutation:
  description: "itertools.permutations.__doc__.__contains__('permutation') == True — permutations docstring contains 'permutation'; new to extra225"
  kind: python_call_eq
  function: permutations.__doc__.__contains__
  args: ["permutation"]
  expected: true

invariant itertools_extra225.accumulate_doc_contains_accumulate:
  description: "itertools.accumulate.__doc__.__contains__('accumulate') == True — accumulate docstring contains 'accumulate'; new to extra225"
  kind: python_call_eq
  function: accumulate.__doc__.__contains__
  args: ["accumulate"]
  expected: true
