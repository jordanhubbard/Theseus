spec: theseus_cmd_cr
version: ">=3.8"
backend: python_cleanroom(theseus_cmd_cr)
blocks: cmd

docs: https://docs.python.org/3/library/cmd.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/cmd.html"
  not_derived_from:
    - "CPython source: Lib/cmd.py (internal implementation)"
  notes:
    - "Clean-room cmd module. Do NOT import cmd."
    - "Cmd: base class for line-oriented command interpreters."
    - "Subclass and define do_<command> methods."
    - "onecmd(line): parse and dispatch a command line."
    - "parseline(line): return (cmd, args, line) tuple."
    - "default(line): called for unrecognized commands."

error_model: python_exceptions

invariant theseus_cmd_cr.cmd2_parseline:
  description: "parseline('hello world') returns ('hello', 'world', 'hello world')"
  category: parseline
  kind: python_call_eq
  function: cmd2_parseline
  args: []
  expected: true

invariant theseus_cmd_cr.cmd2_onecmd:
  description: "onecmd dispatches do_test and returns result"
  category: onecmd
  kind: python_call_eq
  function: cmd2_onecmd
  args: []
  expected: "test ran"

invariant theseus_cmd_cr.cmd2_default:
  description: "onecmd with unknown command calls default"
  category: default
  kind: python_call_eq
  function: cmd2_default
  args: []
  expected: "unknown"
