spec: circular_json
version: ">=0.5.9"
backend: node(circular-json)

docs: https://www.npmjs.com/package/circular-json

provenance:
  derived_from:
    - "circular-json README — https://www.npmjs.com/package/circular-json"
    - "Test vectors verified with circular-json via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "circular-json source"
  notes:
    - "circular-json is an npm package. Install: npm install circular-json"
    - "Serializes objects (including circular references) to JSON strings."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a JSON string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table circular_json.stringify:
  kind: node_module_call_eq
  function: stringify
  category: serialization
  id_prefix: cirjson

  columns: [id, args, expected]
  rows:
    - [object,  [{"a": 1, "b": "hello"}],  "{\"a\":1,\"b\":\"hello\"}"]
    - [array,   [[1, 2, 3]],               "[1,2,3]"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:15:44Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
