spec: chalk
version: ">=5.0.0"
backend: node(chalk)
esm: true

docs: https://github.com/chalk/chalk#readme

provenance:
  derived_from:
    - "chalk README — https://github.com/chalk/chalk#readme"
    - "ANSI escape code reference — https://en.wikipedia.org/wiki/ANSI_escape_code"
    - "Test vectors verified with chalk 5.6.2 on Node.js v22.20.0 / macOS Darwin 25.4.0, 2026-04-04"
    - "chalk source: source/index.js — ANSI open/close codes for colors and styles (MIT; source inspection permitted)"
  not_derived_from:
    - "chalk source: source/utilities.js"
  notes:
    - "chalk v5 is ESM-only; the node backend uses dynamic import() (esm: true)"
    - "level:0 disables all ANSI output — plain text returned regardless of method chain"
    - "level:3 enables 16M-color (TrueColor) ANSI output"
    - "Chalk class instantiated with {level:N} ctor_args to ensure deterministic output regardless of terminal detection"
    - "ANSI codes: ESC=\\u001b; format is \\u001b[<open>m...text...\\u001b[<close>m"
  created_at: "2026-04-04T00:00:00Z"

# --- Foreground colors (level:3) ---

table chalk.colors:
  kind: node_constructor_call_eq
  category: colors
  class: Chalk
  ctor_args: [{level: 3}]

  columns: [id, method, args, expected]
  rows:
    - [red,   red,   ["hi"], "\u001b[31mhi\u001b[39m"]
    - [green, green, ["hi"], "\u001b[32mhi\u001b[39m"]

# --- Text styles (level:3) ---

table chalk.styles:
  kind: node_constructor_call_eq
  category: styles
  class: Chalk
  ctor_args: [{level: 3}]

  columns: [id, method, args, expected]
  rows:
    - [bold,      bold,      ["hi"], "\u001b[1mhi\u001b[22m"]
    - [italic,    italic,    ["hi"], "\u001b[3mhi\u001b[23m"]
    - [underline, underline, ["hi"], "\u001b[4mhi\u001b[24m"]
    - [bgBlue,    bgBlue,    ["hi"], "\u001b[44mhi\u001b[49m"]

# --- Extended foreground colors (level:3) ---

table chalk.colors.extended:
  kind: node_constructor_call_eq
  category: colors
  class: Chalk
  ctor_args: [{level: 3}]

  columns: [id, method, args, expected]
  rows:
    - [blue,        blue,        ["hi"], "\u001b[34mhi\u001b[39m"]
    - [yellow,      yellow,      ["hi"], "\u001b[33mhi\u001b[39m"]
    - [cyan,        cyan,        ["hi"], "\u001b[36mhi\u001b[39m"]
    - [magenta,     magenta,     ["hi"], "\u001b[35mhi\u001b[39m"]
    - [white,       white,       ["hi"], "\u001b[37mhi\u001b[39m"]
    - [black,       black,       ["hi"], "\u001b[30mhi\u001b[39m"]
    - [gray,        gray,        ["hi"], "\u001b[90mhi\u001b[39m"]

# --- Extended text styles (level:3) ---

table chalk.styles.extended:
  kind: node_constructor_call_eq
  category: styles
  class: Chalk
  ctor_args: [{level: 3}]

  columns: [id, method, args, expected]
  rows:
    - [dim,           dim,           ["hi"], "\u001b[2mhi\u001b[22m"]
    - [strikethrough, strikethrough, ["hi"], "\u001b[9mhi\u001b[29m"]
    - [inverse,       inverse,       ["hi"], "\u001b[7mhi\u001b[27m"]

# --- Background colors (level:3) ---

table chalk.bg_colors:
  kind: node_constructor_call_eq
  category: bg_colors
  class: Chalk
  ctor_args: [{level: 3}]

  columns: [id, method, args, expected]
  rows:
    - [bgRed,     bgRed,     ["hi"], "\u001b[41mhi\u001b[49m"]
    - [bgGreen,   bgGreen,   ["hi"], "\u001b[42mhi\u001b[49m"]
    - [bgYellow,  bgYellow,  ["hi"], "\u001b[43mhi\u001b[49m"]
    - [bgCyan,    bgCyan,    ["hi"], "\u001b[46mhi\u001b[49m"]
    - [bgMagenta, bgMagenta, ["hi"], "\u001b[45mhi\u001b[49m"]

# --- Color stripping (level:0 = no ANSI output) ---

table chalk.strip:
  kind: node_constructor_call_eq
  category: strip
  class: Chalk
  ctor_args: [{level: 0}]

  columns: [id, method, args, expected]
  rows:
    - [strip_red,       red,       ["hello"], "hello"]
    - [strip_bold,      bold,      ["hello"], "hello"]
    - [strip_bgBlue,    bgBlue,    ["hello"], "hello"]
    - [strip_underline, underline, ["hello"], "hello"]

