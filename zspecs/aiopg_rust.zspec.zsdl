spec: aiopg_rust
version: ">=3.9"
backend: rust_module(aiopg_rust)

docs: https://aiopg.readthedocs.io/

provenance:
  derived_from:
    - "https://aiopg.readthedocs.io/ — aiopg library"
  notes:
    - "aiopg provides async PostgreSQL driver."
    - "aiopg.connect is callable."
    - "aiopg.Connection is a class."
    - "aiopg.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant aiopg_rust.has_connect:
  description: "aiopg.connect is callable"
  category: presence
  kind: python_call_eq
  function: aiopg_has_connect
  args: []
  expected: true

invariant aiopg_rust.has_connection_class:
  description: "aiopg.Connection is a class"
  category: presence
  kind: python_call_eq
  function: aiopg_has_connection_class
  args: []
  expected: true

invariant aiopg_rust.version_nonempty:
  description: "aiopg.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: aiopg_version_nonempty
  args: []
  expected: true

