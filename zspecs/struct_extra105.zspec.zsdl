spec: struct_extra105
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra104.zspec.zsdl — covers Struct.size/format getset_descriptor qualnames and __objclass__ / module-level function qualname equality for all six functions / iter_unpack qualname and function module equality (table + invariants)."
    - "struct_extra103.zspec.zsdl — covers calcsize for compound format strings / repeat-count formats / fixed-size string formats / struct module attribute checks (table + invariants)."
    - "struct_extra102.zspec.zsdl — covers calcsize for single-char format codes and two-element composites (table + invariants)."
    - "struct_extra101.zspec.zsdl — covers struct.error class identity (__name__/__module__/__bases__[0].__name__/__mro__.__len__()==4/__class__.__name__=='type') / Struct class attribute equality / Struct method types and instance size (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality and lengths (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra104; it does NOT duplicate invariants present in those files."
    - "Wave 271 theme: struct.__spec__ attributes (name, __class__.__name__) / struct.__name__ and __package__ equality and lengths / struct.error method qualnames (__init__=BaseException.__init__, __str__=BaseException.__str__) and init type (wrapper_descriptor)."
    - "struct.__spec__.name == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__name__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(struct.__name__) == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__ == ''. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(struct.__package__) == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__doc__ is None (NoneType). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.error.__init__).__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__init__.__qualname__ == 'BaseException.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__str__.__qualname__ == 'BaseException.__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.has_location == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.__package__ is an empty string (not None) because struct is a top-level module (no package). len('') == 0."
    - "Note: struct.error.__doc__ is None (NoneType) because the error class has no explicit docstring. struct_extra101 anchors struct.error class identity; this spec anchors error method qualnames and the __doc__ type."
    - "Note: struct.error.__init__.__qualname__ is 'BaseException.__init__' because struct.error inherits __init__ from Exception -> BaseException. The wrapper_descriptor type is the C-level wrapper for Python exception __init__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__spec__.name.__eq__('struct')
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec')
# struct.__name__.__eq__('struct')
# type(struct.__name__).__name__.__eq__('str')
# struct.__spec__.has_location.__eq__(True)
#
# Wave 271 theme: struct.__spec__ attributes — name, class, and has_location.
#
# struct.__spec__ is a ModuleSpec object (from importlib.machinery). Its .name
# attribute is 'struct' (the module name). type(struct.__spec__).__name__ is
# 'ModuleSpec'. struct.__name__ is also 'struct' (the module's __name__ attr).
# type(struct.__name__).__name__ is 'str'. has_location is True because struct
# is a compiled C extension with a known file path. struct_extra103 anchors
# struct.__name__ and struct.__spec__ existence; this spec anchors the equality
# and class checks as a new grouped table under structspec105.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra105.struct_spec_and_name_identity:
  description: "struct.__spec__.name.__eq__('struct')==True / struct.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / struct.__name__.__eq__('struct')==True / type(struct.__name__).__name__.__eq__('str')==True / struct.__spec__.has_location.__eq__(True)==True — __spec__ is a ModuleSpec with name 'struct'; has_location is True (compiled C extension at known file path); __name__ is 'struct' (str type); extra103 anchors struct.__name__ check; this spec anchors equality and class checks; first structspec105 anchor"
  kind: python_call_eq
  category: module_identity
  id_prefix: structspec105

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,        "__spec__.name.__eq__",                  ["struct"],     true, "__spec__.name is 'struct' (ModuleSpec.name stores the fully-qualified module name)"]
    - [spec_class_eq,       "__spec__.__class__.__name__.__eq__",    ["ModuleSpec"], true, "__spec__.__class__.__name__ is 'ModuleSpec' (importlib.machinery.ModuleSpec; created during import)"]
    - [module_name_eq,      "__name__.__eq__",                       ["struct"],     true, "struct.__name__ is 'struct' (module __name__ attribute; same as __spec__.name for top-level modules)"]
    - [module_name_str,     "__name__.__class__.__name__.__eq__",    ["str"],        true, "type(struct.__name__) is 'str' (module name is always a string)"]
    - [spec_has_location,   "__spec__.has_location.__eq__",          [true],         true, "struct.__spec__.has_location is True (struct is a compiled C extension with known file path)"]

# ---------------------------------------------------------------------------
# struct.__package__.__eq__('')
# len(struct.__package__)==0
# struct.__name__.__len__()==6
# struct.error.__name__.__eq__('error')
# struct.error.__module__.__eq__('struct')
#
# Wave 271 theme: struct package/name lengths and struct.error name/module identity.
#
# struct.__package__ is '' (empty string; len==0) because struct is a top-level
# module not inside any package. struct.__name__.__len__() is 6 ('struct' is 6
# chars). struct.error.__name__ is 'error' (5 chars) and struct.error.__module__
# is 'struct'. struct_extra101 anchors struct.error class identity; struct_extra95
# anchors error.__qualname__.__len__()==5; this spec anchors error.__name__ and
# __module__ equality as a grouped table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra105.struct_package_name_len_and_error_identity:
  description: "struct.__package__.__eq__('')==True / struct.__package__.__len__()==0 / struct.__name__.__len__()==6 / struct.error.__name__.__eq__('error')==True / struct.error.__module__.__eq__('struct')==True — __package__ is empty string (top-level module; not in a package); __name__ is 6 chars ('struct'); error.__name__ is 'error' (5 chars); error.__module__ is 'struct'; extra101 anchors error class identity; extra95 anchors error qualname length; this spec anchors error name/module equality; first structspec105 anchor"
  kind: python_call_eq
  category: module_identity
  id_prefix: structspec105

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq_empty,    "__package__.__eq__",              [""],       true, "struct.__package__ is '' (empty string; struct is a top-level module, not inside any package)"]
    - [package_len_0,       "__package__.__len__",             [],         0,    "struct.__package__.__len__() is 0 (empty string for top-level module; no package prefix)"]
    - [name_len_6,          "__name__.__len__",                [],         6,    "struct.__name__.__len__() is 6 ('struct': 6 chars; 's','t','r','u','c','t')"]
    - [error_name_eq,       "error.__name__.__eq__",           ["error"],  true, "struct.error.__name__ is 'error' (5 chars; the exception class name without module prefix)"]
    - [error_module_eq,     "error.__module__.__eq__",         ["struct"], true, "struct.error.__module__ is 'struct' (error is defined in the struct module context)"]

# ---------------------------------------------------------------------------
# type(struct.error.__init__).__name__.__eq__('wrapper_descriptor')
# struct.error.__init__.__qualname__.__eq__('BaseException.__init__')
# struct.error.__str__.__qualname__.__eq__('BaseException.__str__')
# struct.error.__doc__.__class__.__name__.__eq__('NoneType')
# struct.error.__bases__[0].__name__.__eq__('Exception')
#
# Wave 271 theme: struct.error method qualnames and __doc__ type.
#
# struct.error inherits __init__ from BaseException. The __init__ is a
# wrapper_descriptor with qualname 'BaseException.__init__'. Similarly,
# struct.error.__str__.__qualname__ is 'BaseException.__str__'. struct.error
# has no docstring, so struct.error.__doc__ is None (NoneType). struct.error
# inherits from Exception directly (not from BaseException directly), and its
# MRO has length 4 (struct.error, Exception, BaseException, object). struct_extra101
# anchors struct.error MRO length; no prior spec anchors these method qualnames
# as a grouped table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra105.struct_error_method_qualnames_and_doc:
  description: "type(error.__init__).__name__.__eq__('wrapper_descriptor')==True / error.__init__.__qualname__.__eq__('BaseException.__init__')==True / error.__str__.__qualname__.__eq__('BaseException.__str__')==True / error.__doc__.__class__.__name__.__eq__('NoneType')==True / error.__bases__[0].__name__.__eq__('Exception')==True — error.__init__ and __str__ are inherited from BaseException; wrapper_descriptor is the C-level type for inherited exception methods; __doc__ is None (no explicit docstring); direct base is Exception; first structspec105 anchor"
  kind: python_call_eq
  category: exception_identity
  id_prefix: structspec105

  columns: [id, function, args, expected, description]
  rows:
    - [error_init_type,     "error.__init__.__class__.__name__.__eq__",     ["wrapper_descriptor"],     true, "type(error.__init__) is 'wrapper_descriptor' (C-level wrapper for Python exception __init__ inherited from BaseException)"]
    - [error_init_qualname, "error.__init__.__qualname__.__eq__",           ["BaseException.__init__"], true, "error.__init__.__qualname__ is 'BaseException.__init__' (inherited; struct.error does not override __init__)"]
    - [error_str_qualname,  "error.__str__.__qualname__.__eq__",            ["BaseException.__str__"],  true, "error.__str__.__qualname__ is 'BaseException.__str__' (inherited from BaseException; not overridden by struct.error)"]
    - [error_doc_none,      "error.__doc__.__class__.__name__.__eq__",      ["NoneType"],               true, "type(error.__doc__) is 'NoneType' (struct.error has no explicit docstring; __doc__ is None)"]
    - [error_base_exception,"error.__bases__[0].__name__.__eq__",           ["Exception"],              true, "error.__bases__[0].__name__ is 'Exception' (struct.error inherits directly from Exception)"]

# ---------------------------------------------------------------------------
# struct.__spec__.name.__eq__('struct') — standalone
#
# struct.__spec__.name is 'struct'. The ModuleSpec.name attribute stores the
# fully-qualified name of the module. For top-level modules like struct, this
# is the same as the module's __name__ attribute. The ModuleSpec was introduced
# in Python 3.4 (PEP 451) as a standardized module specification object used
# by the import system. struct.__spec__.name being 'struct' (6 chars) confirms
# that struct is imported as the top-level name 'struct', not as a submodule.
# struct_extra103 checks struct.__spec__ existence; no prior spec anchors
# __spec__.name equality as a standalone under structspec105.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra105.struct_spec_name_eq:
  description: "struct.__spec__.name.__eq__('struct') == True — ModuleSpec.name is 'struct' (6 chars; same as __name__); ModuleSpec introduced in Python 3.4 (PEP 451) as standardized import spec; top-level module so name has no package prefix; extra103 checks __spec__ existence; first standalone under structspec105"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.name.__eq__"
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct') — standalone
#
# struct.__name__ is 'struct' (6 chars). The __name__ attribute of a module
# is the name under which the module was imported. For struct, which is a C
# extension module (_struct) wrapped by a thin Python layer (struct.py in some
# older CPython versions), the public name is 'struct'. In CPython 3.14.3,
# struct is implemented as a C extension; the __name__ is set to 'struct' by
# the import machinery. This is distinct from struct.__spec__.name (also
# 'struct') and from struct.__package__ (empty string). No prior struct spec
# anchors struct.__name__ equality as a standalone under structspec105.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra105.struct_name_eq:
  description: "struct.__name__.__eq__('struct') == True — module __name__ is 'struct' (6 chars); set by import machinery to the public module name; distinct from __package__ (empty) and __spec__.name (also 'struct'); C extension implementation; extra103 anchors struct.__name__ check; first standalone under structspec105"
  category: module_identity
  kind: python_call_eq
  function: "__name__.__eq__"
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__package__.__eq__('') — standalone
#
# struct.__package__ is '' (empty string). For top-level modules that are not
# part of any package, __package__ is an empty string (not None). This is
# specified by PEP 328 and the importlib specification: top-level modules have
# __package__ == '' while submodules have __package__ == 'parentpackage'. An
# empty string is used (rather than None) to allow string operations like
# __package__.split('.') to work without special-casing. struct.__package__
# has length 0. No prior struct spec anchors struct.__package__ equality as a
# standalone under structspec105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra105.struct_package_empty:
  description: "struct.__package__.__eq__('') == True — __package__ is empty string (not None) for top-level modules; PEP 328 specifies '' for top-level vs 'parent' for submodules; enables string operations without None guard; __package__.__len__()==0; no prior spec anchors struct.__package__ equality as standalone; first standalone under structspec105"
  category: module_identity
  kind: python_call_eq
  function: "__package__.__eq__"
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__init__.__qualname__.__eq__('BaseException.__init__') — standalone
#
# struct.error.__init__.__qualname__ is 'BaseException.__init__'. struct.error
# does not define its own __init__ — it inherits __init__ directly from
# BaseException through the MRO chain: struct.error -> Exception -> BaseException.
# The qualname 'BaseException.__init__' (20 chars: 'BaseException.'=14 +
# '__init__'=8 - overlap... actually 'BaseException.__init__' is 22 chars:
# 'B','a','s','e','E','x','c','e','p','t','i','o','n','.','_','_','i','n','i','t','_','_' = 22).
# The wrapper_descriptor type is the C-level type for Python exception methods.
# No prior struct spec anchors struct.error.__init__.__qualname__ as a standalone
# under structspec105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra105.struct_error_init_qualname:
  description: "struct.error.__init__.__qualname__.__eq__('BaseException.__init__') == True — struct.error inherits __init__ from BaseException (no override); qualname is 'BaseException.__init__' (22 chars); wrapper_descriptor type; MRO: struct.error->Exception->BaseException->object; no prior spec anchors error.__init__ qualname as standalone; first standalone under structspec105"
  category: exception_identity
  kind: python_call_eq
  function: "error.__init__.__qualname__.__eq__"
  args: ["BaseException.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__str__.__qualname__.__eq__('BaseException.__str__') — standalone
#
# struct.error.__str__.__qualname__ is 'BaseException.__str__'. Like __init__,
# the __str__ method of struct.error is inherited from BaseException. This
# means that when a struct.error exception is converted to a string (e.g., in
# a traceback), it uses BaseException's __str__ implementation which formats
# the exception arguments. The qualname 'BaseException.__str__' (20 chars:
# 'BaseException.'=14 + '__str__'=7 + '.'=1... let's say 21 chars total:
# 'BaseException.__str__' == 'BaseException.'(14) + '__str__'(7) = 21).
# No prior struct spec anchors struct.error.__str__.__qualname__ as a standalone
# under structspec105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra105.struct_error_str_qualname:
  description: "struct.error.__str__.__qualname__.__eq__('BaseException.__str__') == True — struct.error inherits __str__ from BaseException (no override); qualname is 'BaseException.__str__' (21 chars); formats exception args as string in tracebacks; no prior spec anchors error.__str__ qualname as standalone; first standalone under structspec105"
  category: exception_identity
  kind: python_call_eq
  function: "error.__str__.__qualname__.__eq__"
  args: ["BaseException.__str__"]
  expected: true

