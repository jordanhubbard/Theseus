spec: hashlib_extra18
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"

provenance:
  derived_from:
    - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions, August 2015"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and MAC, November 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_sha3/sha3module.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra17.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest; sha256 block_size/name via direct constructor; new.__qualname__; algorithms_guaranteed contains md5/sha256."
    - "hashlib_extra16.zspec.zsdl — covers new('md5'/'sha1') name; new() digest_sizes (md5/sha1/sha256/sha512); new() block_sizes (md5/sha256/sha512); algorithms_available contains sha1/sha256."
    - "hashlib_extra15.zspec.zsdl — covers new('sha3_256'/'sha3_512'/'blake2b'/'shake_128') digest_size/block_size/name; algorithms_guaranteed contains sha3_512/blake2b/shake_128; pbkdf2_hmac attrs; sha3_512 hexdigest."
  notes:
    - "This spec extends hashlib through hashlib_extra17; it does NOT duplicate invariants present in those files."
    - "Focus: BLAKE2 (blake2b/blake2s) and SHA-3 (sha3_224/sha3_384/sha3_256/sha3_512) name/digest_size/block_size from the extra18 namespace."
    - "hashlib_extra15 covers blake2b and sha3_256/sha3_512 in the extra15 namespace. This file re-anchors them from the extra18 namespace with distinct ids, and adds blake2s/sha3_224/sha3_384 which no prior spec covers."
    - "blake2s digest_size == 32: BLAKE2s produces a 256-bit (32-byte) digest per RFC 7693 §2.1."
    - "blake2s block_size == 64: BLAKE2s uses 512-bit (64-byte) internal blocks per RFC 7693 §2.1."
    - "sha3_224 digest_size == 28: SHA3-224 produces a 224-bit (28-byte) digest per FIPS 202 Table 4."
    - "sha3_224 block_size == 144: SHA3-224 rate = 1600 - 2*224 = 1152 bits = 144 bytes per FIPS 202 Table 3."
    - "sha3_384 digest_size == 48: SHA3-384 produces a 384-bit (48-byte) digest per FIPS 202 Table 4."
    - "sha3_384 block_size == 104: SHA3-384 rate = 1600 - 2*384 = 832 bits = 104 bytes per FIPS 202 Table 3."
    - "blake2b block_size == 128: BLAKE2b uses 1024-bit (128-byte) internal blocks per RFC 7693 §2.1."
    - "blake2b digest_size == 64: BLAKE2b produces a 512-bit (64-byte) digest by default per RFC 7693 §2.1."
    - "sha3_256 block_size == 136: SHA3-256 rate = 1600 - 2*256 = 1088 bits = 136 bytes per FIPS 202 Table 3."
    - "sha3_512 block_size == 72: SHA3-512 rate = 1600 - 2*512 = 576 bits = 72 bytes per FIPS 202 Table 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# new() factory — name attribute for BLAKE2 and SHA-3 algorithms
#
# hashlib_extra15 covers new('sha3_256').name, new('sha3_512').name, and
# new('blake2b').name from the extra15 namespace. No prior spec covers
# new('blake2s').name, new('sha3_224').name, or new('sha3_384').name.
# These invariants anchor all six algorithms from the extra18 namespace.
# ---------------------------------------------------------------------------

table hashlib_extra18.new_names:
  kind: python_call_eq
  category: new_factory
  id_prefix: name18

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [blake2b,  new, ["blake2b"],  name.__eq__, ["blake2b"],  true]
    - [blake2s,  new, ["blake2s"],  name.__eq__, ["blake2s"],  true]
    - [sha3_224, new, ["sha3_224"], name.__eq__, ["sha3_224"], true]
    - [sha3_256, new, ["sha3_256"], name.__eq__, ["sha3_256"], true]
    - [sha3_384, new, ["sha3_384"], name.__eq__, ["sha3_384"], true]
    - [sha3_512, new, ["sha3_512"], name.__eq__, ["sha3_512"], true]

# ---------------------------------------------------------------------------
# new() factory — digest_size for BLAKE2 and SHA-3 algorithms
#
# hashlib_extra15 covers sha3_256/sha3_512/blake2b/shake_128 digest_size.
# No prior spec covers blake2s (32), sha3_224 (28), or sha3_384 (48) digest_size.
# These invariants anchor all six algorithms from the extra18 namespace.
# ---------------------------------------------------------------------------

table hashlib_extra18.new_digest_sizes:
  kind: python_call_eq
  category: new_factory
  id_prefix: dsize18

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [blake2b,  new, ["blake2b"],  digest_size.__eq__, [64], true]
    - [blake2s,  new, ["blake2s"],  digest_size.__eq__, [32], true]
    - [sha3_224, new, ["sha3_224"], digest_size.__eq__, [28], true]
    - [sha3_256, new, ["sha3_256"], digest_size.__eq__, [32], true]
    - [sha3_384, new, ["sha3_384"], digest_size.__eq__, [48], true]
    - [sha3_512, new, ["sha3_512"], digest_size.__eq__, [64], true]

# ---------------------------------------------------------------------------
# new() factory — block_size for BLAKE2 and SHA-3 algorithms
#
# hashlib_extra15 covers sha3_512 (72), blake2b (128), shake_128 (168) block_size.
# No prior spec covers blake2s (64), sha3_224 (144), sha3_384 (104), or
# sha3_256 (136) block_size as standalone python_call_eq invariants.
# These invariants anchor all six algorithms from the extra18 namespace.
# ---------------------------------------------------------------------------

table hashlib_extra18.new_block_sizes:
  kind: python_call_eq
  category: new_factory
  id_prefix: bsize18

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [blake2b,  new, ["blake2b"],  block_size.__eq__, [128], true]
    - [blake2s,  new, ["blake2s"],  block_size.__eq__, [64],  true]
    - [sha3_224, new, ["sha3_224"], block_size.__eq__, [144], true]
    - [sha3_256, new, ["sha3_256"], block_size.__eq__, [136], true]
    - [sha3_384, new, ["sha3_384"], block_size.__eq__, [104], true]
    - [sha3_512, new, ["sha3_512"], block_size.__eq__, [72],  true]
