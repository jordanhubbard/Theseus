spec: re_extra1231
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re.__dict__.__contains__ checks for module-level names: compile, match, search, sub, findall, split, escape, fullmatch, finditer, subn, error, Pattern, Match, RegexFlag; re.error.__dict__.__contains__ checks for exception-specific attributes: msg, pattern, pos, lineno, colno"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.__dict__.__contains__ for module-level function names and class names exported by the re module; checks re.__dict__.__contains__ for names that should NOT be present (e.g. pathlib names, io names); checks re.error.__dict__.__contains__ for exception instance attributes that re.error defines directly (msg, pattern, pos, lineno, colno); none of these re.__dict__.__contains__ or re.error.__dict__.__contains__ membership checks were covered in _extra1201, _extra1216, or any prior re_extra spec"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1231.module_dict_contains_functions:
  description: "re.__dict__.__contains__ checks for module-level function names — compile, match, search, sub, findall, split, escape, fullmatch, finditer, subn all present in re.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1231mf
  columns: [id, function, args, expected]
  rows:
    - [re1231mf001, re.__dict__.__contains__, ["compile"],   true]
    - [re1231mf002, re.__dict__.__contains__, ["match"],     true]
    - [re1231mf003, re.__dict__.__contains__, ["search"],    true]
    - [re1231mf004, re.__dict__.__contains__, ["sub"],       true]
    - [re1231mf005, re.__dict__.__contains__, ["findall"],   true]
    - [re1231mf006, re.__dict__.__contains__, ["split"],     true]
    - [re1231mf007, re.__dict__.__contains__, ["escape"],    true]
    - [re1231mf008, re.__dict__.__contains__, ["fullmatch"], true]
    - [re1231mf009, re.__dict__.__contains__, ["finditer"],  true]
    - [re1231mf010, re.__dict__.__contains__, ["subn"],      true]

table re_extra1231.module_dict_contains_classes_and_absent:
  description: "re.__dict__.__contains__ checks for module-level class names — error, Pattern, Match, RegexFlag present; names from unrelated modules absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1231ca
  columns: [id, function, args, expected]
  rows:
    - [re1231ca001, re.__dict__.__contains__, ["error"],      true]
    - [re1231ca002, re.__dict__.__contains__, ["Pattern"],    true]
    - [re1231ca003, re.__dict__.__contains__, ["Match"],      true]
    - [re1231ca004, re.__dict__.__contains__, ["RegexFlag"],  true]
    - [re1231ca005, re.__dict__.__contains__, ["Path"],       false]
    - [re1231ca006, re.__dict__.__contains__, ["IOBase"],     false]
    - [re1231ca007, re.__dict__.__contains__, ["Decimal"],    false]
    - [re1231ca008, re.__dict__.__contains__, ["socket"],     false]
    - [re1231ca009, re.__dict__.__contains__, ["purge"],      true]
    - [re1231ca010, re.__dict__.__contains__, ["IGNORECASE"], true]

table re_extra1231.error_dict_contains:
  description: "re.error.__dict__.__contains__ checks for exception-specific attributes — msg, pattern, pos, lineno, colno present in error.__dict__; Match-object and Pattern-object names absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1231ed
  columns: [id, function, args, expected]
  rows:
    - [re1231ed001, re.error.__dict__.__contains__, ["msg"],      true]
    - [re1231ed002, re.error.__dict__.__contains__, ["pattern"],  true]
    - [re1231ed003, re.error.__dict__.__contains__, ["pos"],      true]
    - [re1231ed004, re.error.__dict__.__contains__, ["lineno"],   true]
    - [re1231ed005, re.error.__dict__.__contains__, ["colno"],    true]
    - [re1231ed006, re.error.__dict__.__contains__, ["group"],    false]
    - [re1231ed007, re.error.__dict__.__contains__, ["groups"],   false]
    - [re1231ed008, re.error.__dict__.__contains__, ["match"],    false]
    - [re1231ed009, re.error.__dict__.__contains__, ["search"],   false]
    - [re1231ed010, re.error.__dict__.__contains__, ["findall"],  false]
