spec: functools_extra244
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_functoolsmodule.c"
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers functools.reduce and functools.partial function identity contracts."
    - "functools.reduce.__name__ == 'reduce' (len=6) — reduce is a C builtin in _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' (len=10) — reduce is implemented in the C extension _functools, not the Python functools module. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' (len=6) — same as __name__ for C builtins. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C-level builtin. Verified with Python 3.14.3."
    - "functools.reduce.__doc__ contains 'function' == True — docstring says 'Apply a function of two arguments...'. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial' (len=7) — partial is a type/class in functools. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' (len=9) — partial is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object. Verified with Python 3.14.3."
    - "functools.partial.__class__.__name__ == 'type' — partial is a class; its metaclass is type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce identity contracts
#
# functools.reduce.__name__ == 'reduce' (len=6)
# functools.reduce.__module__ == '_functools' (len=10)
# functools.reduce.__qualname__ == 'reduce' (len=6)
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__doc__.__contains__('function') == True
#
# reduce is a C builtin in _functoolsmodule.c; __module__ is '_functools'.
# New to extra244.
# ---------------------------------------------------------------------------

table functools_extra244.reduce244_identity:
  description: "functools.reduce identity: name, module, qualname, class, doc; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: reduce244

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — reduce is a C builtin in _functoolsmodule.c; __name__ is 'reduce' (len=6); new to extra244"]
    - [reduce_name_len_6,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — 'reduce' has exactly 6 characters (r-e-d-u-c-e); str.__len__() returns 6; new to extra244"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in the C extension _functools, not Lib/functools.py; new to extra244"]
    - [reduce_module_len_10,
       reduce.__module__.__len__,
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — '_functools' has exactly 10 characters; str.__len__() returns 10; new to extra244"]
    - [reduce_qualname_eq,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — for C builtins __qualname__ equals __name__; __qualname__ is 'reduce' (len=6); new to extra244"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce class and doc contracts
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__qualname__.__len__() == 6
# functools.reduce.__doc__.__contains__('function') == True
# functools.reduce.__doc__.__class__.__name__ == 'str'
# functools.reduce.__module__.__contains__('functools') == True
#
# reduce docstring describes applying a function of two arguments. New to extra244.
# ---------------------------------------------------------------------------

table functools_extra244.reduce244_class_doc:
  description: "functools.reduce class, qualname len, doc checks; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: reduce244doc

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_is_builtin,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C-level builtin; its __class__ is builtin_function_or_method; new to extra244"]
    - [reduce_qualname_len_6,
       reduce.__qualname__.__len__,
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — 'reduce' has 6 characters; for C builtins __qualname__ equals __name__; new to extra244"]
    - [reduce_doc_contains_function,
       reduce.__doc__.__contains__,
       ["function"],
       true,
       "functools.reduce.__doc__.__contains__('function') == True — docstring says 'Apply a function of two arguments cumulatively'; new to extra244"]
    - [reduce_doc_class_is_str,
       reduce.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — the reduce docstring is a plain Python str object; new to extra244"]
    - [reduce_module_contains_functools,
       reduce.__module__.__contains__,
       ["functools"],
       true,
       "functools.reduce.__module__.__contains__('functools') == True — '_functools' contains the substring 'functools'; new to extra244"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial identity contracts
#
# functools.partial.__name__ == 'partial' (len=7)
# functools.partial.__module__ == 'functools' (len=9)
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partial.__class__.__name__ == 'type'
# functools.partial.__qualname__ == 'partial' (len=7)
#
# partial is a class in Lib/functools.py. New to extra244.
# ---------------------------------------------------------------------------

table functools_extra244.partial244_identity:
  description: "functools.partial identity: name, module, bases, class, qualname; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: partial244

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a class in Lib/functools.py; __name__ is 'partial' (len=7); new to extra244"]
    - [partial_name_len_7,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — 'partial' has exactly 7 characters (p-a-r-t-i-a-l); str.__len__() returns 7; new to extra244"]
    - [partial_module_eq,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra244"]
    - [partial_module_len_9,
       partial.__module__.__len__,
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra244"]
    - [partial_bases_0_is_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial inherits directly from object; __bases__[0] is object; new to extra244"]

# ---------------------------------------------------------------------------
# Table 4: functools.partial class and doc contracts
#
# functools.partial.__class__.__name__ == 'type'
# functools.partial.__qualname__ == 'partial' (len=7)
# functools.partial.__doc__.__contains__('function') == True
# functools.partial.__doc__.__class__.__name__ == 'str'
# functools.partial.__qualname__.__len__() == 7
#
# partial docstring describes creating a new function with partial application. New to extra244.
# ---------------------------------------------------------------------------

table functools_extra244.partial244_class_doc:
  description: "functools.partial class, qualname, doc checks; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: partial244doc

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_is_type,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a class; its metaclass is the built-in type type; new to extra244"]
    - [partial_qualname_eq,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — __qualname__ is 'partial' (len=7); same as __name__ for top-level class; new to extra244"]
    - [partial_qualname_len_7,
       partial.__qualname__.__len__,
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — 'partial' has exactly 7 characters; str.__len__() returns 7; new to extra244"]
    - [partial_doc_contains_function,
       partial.__doc__.__contains__,
       ["function"],
       true,
       "functools.partial.__doc__.__contains__('function') == True — docstring says 'Create a new function with partial application'; new to extra244"]
    - [partial_doc_class_is_str,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — the partial docstring is a plain Python str object; new to extra244"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra244
# ---------------------------------------------------------------------------

invariant functools_extra244.reduce_name_eq:
  description: "functools.reduce.__name__ == 'reduce' (len=6); new to extra244"
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra244.reduce_name_len_6:
  description: "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters; new to extra244"
  kind: python_call_eq
  function: reduce.__name__.__len__
  args: []
  expected: 6

invariant functools_extra244.reduce_module_eq:
  description: "functools.reduce.__module__ == '_functools' — C extension module; new to extra244"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra244.reduce_module_len_10:
  description: "functools.reduce.__module__.__len__() == 10 — '_functools' has 10 characters; new to extra244"
  kind: python_call_eq
  function: reduce.__module__.__len__
  args: []
  expected: 10

invariant functools_extra244.reduce_qualname_eq:
  description: "functools.reduce.__qualname__ == 'reduce'; new to extra244"
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra244.reduce_class_is_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method'; new to extra244"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra244.reduce_doc_contains_function:
  description: "functools.reduce.__doc__.__contains__('function') == True; new to extra244"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["function"]
  expected: true

invariant functools_extra244.partial_name_eq:
  description: "functools.partial.__name__ == 'partial' (len=7); new to extra244"
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra244.partial_name_len_7:
  description: "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters; new to extra244"
  kind: python_call_eq
  function: partial.__name__.__len__
  args: []
  expected: 7

invariant functools_extra244.partial_module_eq:
  description: "functools.partial.__module__ == 'functools'; new to extra244"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra244.partial_module_len_9:
  description: "functools.partial.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra244"
  kind: python_call_eq
  function: partial.__module__.__len__
  args: []
  expected: 9

invariant functools_extra244.partial_bases_0_is_object:
  description: "functools.partial.__bases__[0].__name__ == 'object'; new to extra244"
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra244.partial_class_is_type:
  description: "functools.partial.__class__.__name__ == 'type'; new to extra244"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra244.partial_qualname_eq:
  description: "functools.partial.__qualname__ == 'partial' (len=7); new to extra244"
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra244.partial_doc_contains_function:
  description: "functools.partial.__doc__.__contains__('function') == True; new to extra244"
  kind: python_call_eq
  function: partial.__doc__.__contains__
  args: ["function"]
  expected: true
