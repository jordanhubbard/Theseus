spec: abc_extra811
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "abc standard library documentation"
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  not_derived_from:
    - "any third-party abstract base class library"
  notes:
    - "Covers qualname and module identity for abc.ABC, ABCMeta, abstractmethod, and get_cache_token"
    - "Doc string class identity checks confirm public API surfaces carry docstrings in CPython >=3.9"
  created_at: "2026-04-12"

table abc_extra811.class_identity:
  description: "abc.ABC and abc.ABCMeta qualname and module identity"
  kind: python_call_eq
  category: identity
  id_prefix: ab811
  columns: [id, function, args, expected]
  rows:
    - ["ab81101001", "abc.ABC.__qualname__.__eq__", ["ABC"], true]
    - ["ab81101002", "abc.ABC.__module__.__eq__", ["abc"], true]
    - ["ab81101003", "abc.ABCMeta.__qualname__.__eq__", ["ABCMeta"], true]
    - ["ab81101004", "abc.ABCMeta.__module__.__eq__", ["abc"], true]

table abc_extra811.decorator_and_function_identity:
  description: "abc.abstractmethod and abc.get_cache_token qualname and module identity"
