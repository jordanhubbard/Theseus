spec: inspect_extra247
version: ">=3.8"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra246.zspec.zsdl — covers other inspect identity contracts"
  notes:
    - "This spec covers inspect.isfunction, inspect.isgeneratorfunction, inspect.isbuiltin, inspect.isroutine identity contracts."
    - "Note: inspect.islambda does not exist in Python 3.14.3 — islambda is not an attribute of inspect."
    - "inspect.isfunction.__name__ == 'isfunction' (len=10). Verified with Python 3.14.3."
    - "inspect.isfunction.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isfunction.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction' (len=19). Verified with Python 3.14.3."
    - "inspect.isbuiltin.__name__ == 'isbuiltin' (len=9). Verified with Python 3.14.3."
    - "inspect.isroutine.__name__ == 'isroutine' (len=9). Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction' (len=19). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isfunction identity contracts
#
# inspect.isfunction.__name__ == 'isfunction' (len=10)
# inspect.isfunction.__module__ == 'inspect'
# inspect.isfunction.__class__.__name__ == 'function'
# inspect.isfunction.__qualname__ == 'isfunction' (len=10)
# inspect.isfunction.__doc__.__contains__('function') == True
#
# isfunction is a pure-Python function in Lib/inspect.py. New to extra247.
# ---------------------------------------------------------------------------

table inspect_extra247.inspisfn247_isfunction_identity:
  description: "inspect.isfunction identity: name, module, class, qualname, doc; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: inspisfn247

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_eq,
       isfunction.__name__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — isfunction is a pure-Python predicate in Lib/inspect.py; __name__ is 'isfunction' (len=10); new to extra247"]
    - [isfunction_name_len_10,
       isfunction.__name__.__len__,
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has exactly 10 characters; str.__len__() returns 10; new to extra247"]
    - [isfunction_module_inspect,
       isfunction.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — isfunction is defined in Lib/inspect.py; __module__ is 'inspect'; new to extra247"]
    - [isfunction_class_function,
       isfunction.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isfunction.__class__.__name__.__eq__('function') == True — isfunction is a plain Python function; __class__.__name__ is 'function'; new to extra247"]
    - [isfunction_qualname_eq,
       isfunction.__qualname__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__qualname__.__eq__('isfunction') == True — __qualname__ equals __name__ for a top-level function; 'isfunction' (len=10); new to extra247"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isfunction doc content and name checks
#
# inspect.isfunction.__doc__.__contains__('function') == True
# inspect.isfunction.__doc__.__contains__('user') == True
# inspect.isfunction.__name__.__contains__('is') == True
# inspect.isfunction.__qualname__.__len__() == 10
# inspect.isfunction.__module__.__len__() == 7
#
# New to extra247.
# ---------------------------------------------------------------------------

table inspect_extra247.inspisfn247_isfunction_extra:
  description: "inspect.isfunction doc content, name checks, module length; new to extra247"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspisfn247b

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_doc_contains_function,
       isfunction.__doc__.__contains__,
       ["function"],
       true,
       "inspect.isfunction.__doc__.__contains__('function') == True — docstring mentions 'function'; new to extra247"]
    - [isfunction_doc_contains_user,
       isfunction.__doc__.__contains__,
       ["user"],
       true,
       "inspect.isfunction.__doc__.__contains__('user') == True — docstring mentions 'user-defined function'; new to extra247"]
    - [isfunction_name_contains_is,
       isfunction.__name__.__contains__,
       ["is"],
       true,
       "inspect.isfunction.__name__.__contains__('is') == True — 'isfunction' starts with 'is'; new to extra247"]
    - [isfunction_qualname_len_10,
       isfunction.__qualname__.__len__,
       [],
       10,
       "inspect.isfunction.__qualname__.__len__() == 10 — 'isfunction' has exactly 10 characters; str.__len__() returns 10; new to extra247"]
    - [isfunction_module_len_7,
       isfunction.__module__.__len__,
       [],
       7,
       "inspect.isfunction.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra247"]

# ---------------------------------------------------------------------------
# Table 3: inspect.isgeneratorfunction identity contracts
#
# inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction' (len=19)
# inspect.isgeneratorfunction.__module__ == 'inspect'
# inspect.isgeneratorfunction.__class__.__name__ == 'function'
# inspect.isgeneratorfunction.__qualname__ == 'isgeneratorfunction' (len=19)
# inspect.isgeneratorfunction.__doc__.__contains__('generator') == True
#
# isgeneratorfunction is a pure-Python predicate in Lib/inspect.py. New to extra247.
# ---------------------------------------------------------------------------

table inspect_extra247.inspisfn247_isgenfn_identity:
  description: "inspect.isgeneratorfunction identity: name, module, class, qualname, doc; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: inspisfn247c

  columns: [id, function, args, expected, description]
  rows:
    - [isgenfn_name_eq,
       isgeneratorfunction.__name__.__eq__,
       ["isgeneratorfunction"],
       true,
       "inspect.isgeneratorfunction.__name__.__eq__('isgeneratorfunction') == True — isgeneratorfunction is a pure-Python predicate; __name__ is 'isgeneratorfunction' (len=19); new to extra247"]
    - [isgenfn_name_len_19,
       isgeneratorfunction.__name__.__len__,
       [],
       19,
       "inspect.isgeneratorfunction.__name__.__len__() == 19 — 'isgeneratorfunction' has exactly 19 characters; str.__len__() returns 19; new to extra247"]
    - [isgenfn_module_inspect,
       isgeneratorfunction.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isgeneratorfunction.__module__.__eq__('inspect') == True — isgeneratorfunction is defined in Lib/inspect.py; __module__ is 'inspect'; new to extra247"]
    - [isgenfn_class_function,
       isgeneratorfunction.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isgeneratorfunction.__class__.__name__.__eq__('function') == True — isgeneratorfunction is a plain Python function; __class__.__name__ is 'function'; new to extra247"]
    - [isgenfn_qualname_eq,
       isgeneratorfunction.__qualname__.__eq__,
       ["isgeneratorfunction"],
       true,
       "inspect.isgeneratorfunction.__qualname__.__eq__('isgeneratorfunction') == True — __qualname__ equals __name__ for a top-level function; 'isgeneratorfunction' (len=19); new to extra247"]

# ---------------------------------------------------------------------------
# Table 4: inspect.isbuiltin and inspect.isroutine identity contracts
#
# inspect.isbuiltin.__name__ == 'isbuiltin' (len=9)
# inspect.isbuiltin.__module__ == 'inspect'
# inspect.isbuiltin.__qualname__ == 'isbuiltin' (len=9)
# inspect.isroutine.__name__ == 'isroutine' (len=9)
# inspect.isroutine.__module__ == 'inspect'
#
# isbuiltin and isroutine are pure-Python predicates in Lib/inspect.py. New to extra247.
# ---------------------------------------------------------------------------

table inspect_extra247.inspisfn247_isbuiltin_isroutine:
  description: "inspect.isbuiltin and inspect.isroutine identity: name, module, qualname; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: inspisfn247d

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_name_eq,
       isbuiltin.__name__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — isbuiltin is a pure-Python predicate in Lib/inspect.py; __name__ is 'isbuiltin' (len=9); new to extra247"]
    - [isbuiltin_module_inspect,
       isbuiltin.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is defined in Lib/inspect.py; __module__ is 'inspect'; new to extra247"]
    - [isbuiltin_qualname_eq,
       isbuiltin.__qualname__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__qualname__.__eq__('isbuiltin') == True — __qualname__ equals __name__ for top-level function 'isbuiltin'; new to extra247"]
    - [isroutine_name_eq,
       isroutine.__name__.__eq__,
       ["isroutine"],
       true,
       "inspect.isroutine.__name__.__eq__('isroutine') == True — isroutine is a pure-Python predicate in Lib/inspect.py; __name__ is 'isroutine' (len=9); new to extra247"]
    - [isroutine_module_inspect,
       isroutine.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isroutine.__module__.__eq__('inspect') == True — isroutine is defined in Lib/inspect.py; __module__ is 'inspect'; new to extra247"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra247
# ---------------------------------------------------------------------------

invariant inspect_extra247.isfunction_name_eq:
  description: "inspect.isfunction.__name__ == 'isfunction' (len=10); new to extra247"
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra247.isfunction_module_inspect:
  description: "inspect.isfunction.__module__ == 'inspect'; new to extra247"
  kind: python_call_eq
  function: isfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra247.isfunction_class_function:
  description: "inspect.isfunction.__class__.__name__ == 'function' — plain Python function; new to extra247"
  kind: python_call_eq
  function: isfunction.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra247.isfunction_name_len_10:
  description: "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters; new to extra247"
  kind: python_call_eq
  function: isfunction.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra247.isfunction_doc_contains_function:
  description: "inspect.isfunction.__doc__.__contains__('function') == True — docstring mentions 'function'; new to extra247"
  kind: python_call_eq
  function: isfunction.__doc__.__contains__
  args: ["function"]
  expected: true

invariant inspect_extra247.isgenfn_name_eq:
  description: "inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction' (len=19); new to extra247"
  kind: python_call_eq
  function: isgeneratorfunction.__name__.__eq__
  args: ["isgeneratorfunction"]
  expected: true

invariant inspect_extra247.isgenfn_module_inspect:
  description: "inspect.isgeneratorfunction.__module__ == 'inspect'; new to extra247"
  kind: python_call_eq
  function: isgeneratorfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra247.isgenfn_name_len_19:
  description: "inspect.isgeneratorfunction.__name__.__len__() == 19 — 'isgeneratorfunction' has 19 characters; new to extra247"
  kind: python_call_eq
  function: isgeneratorfunction.__name__.__len__
  args: []
  expected: 19

invariant inspect_extra247.isbuiltin_name_eq:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin' (len=9); new to extra247"
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra247.isbuiltin_module_inspect:
  description: "inspect.isbuiltin.__module__ == 'inspect'; new to extra247"
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra247.isroutine_name_eq:
  description: "inspect.isroutine.__name__ == 'isroutine' (len=9); new to extra247"
  kind: python_call_eq
  function: isroutine.__name__.__eq__
  args: ["isroutine"]
  expected: true

invariant inspect_extra247.isroutine_module_inspect:
  description: "inspect.isroutine.__module__ == 'inspect'; new to extra247"
  kind: python_call_eq
  function: isroutine.__module__.__eq__
  args: ["inspect"]
  expected: true
