spec: socket_extra303
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec extends socket.zspec.zsdl, socket_extra.zspec.zsdl, and socket_extra2.zspec.zsdl; it does NOT duplicate invariants already present in those files."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — it is an IntEnum member on POSIX platforms."
    - "socket.AF_UNIX == 1 on macOS/Darwin — verified with Python 3.14.3 on Darwin 25.4.0."
    - "socket.IPPROTO_TCP == 6, IPPROTO_UDP == 17, IPPROTO_IP == 0 — IANA assigned protocol numbers."
    - "socket.SOL_SOCKET == 65535 on macOS/Darwin — this is 0xFFFF, the socket-level option layer constant."
    - "socket.SO_REUSEADDR.__class__.__name__ == 'int' — on macOS it is a plain int, not an IntEnum member."
    - "socket.SO_REUSEADDR == 4 on macOS/Darwin — verified with Python 3.14.3 on Darwin 25.4.0."
    - "socket.SHUT_RDWR == 2 — POSIX standard value for shutting down both directions."
    - "All expected values are macOS/Darwin-specific and verified by running Python 3.14.3 on Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AF_UNIX — class name and integer value (macOS/POSIX)
# ---------------------------------------------------------------------------

invariant socket_extra303.AF_UNIX.class_name:
  description: "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — IntEnum member on POSIX"
  category: constants
  kind: python_call_eq
  function: AF_UNIX.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra303.AF_UNIX.value:
  description: "socket.AF_UNIX == 1 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: AF_UNIX.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# IPPROTO constants — IANA protocol numbers
# ---------------------------------------------------------------------------

invariant socket_extra303.IPPROTO_TCP.value:
  description: "socket.IPPROTO_TCP == 6 — IANA assigned protocol number for TCP"
  category: constants
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

invariant socket_extra303.IPPROTO_UDP.value:
  description: "socket.IPPROTO_UDP == 17 — IANA assigned protocol number for UDP"
  category: constants
  kind: python_call_eq
  function: IPPROTO_UDP.__eq__
  args: [17]
  expected: true

invariant socket_extra303.IPPROTO_IP.value:
  description: "socket.IPPROTO_IP == 0 — dummy protocol for IP layer"
  category: constants
  kind: python_call_eq
  function: IPPROTO_IP.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# SOL_SOCKET — socket-level option layer (macOS-specific value)
# ---------------------------------------------------------------------------

invariant socket_extra303.SOL_SOCKET.value:
  description: "socket.SOL_SOCKET == 65535 on macOS/Darwin (0xFFFF)"
  category: constants
  kind: python_call_eq
  function: SOL_SOCKET.__eq__
  args: [65535]
  expected: true

# ---------------------------------------------------------------------------
# SO_REUSEADDR — socket option class and value (macOS-specific)
# ---------------------------------------------------------------------------

invariant socket_extra303.SO_REUSEADDR.class_name:
  description: "socket.SO_REUSEADDR.__class__.__name__ == 'int' — plain int on macOS (not SocketOption IntEnum)"
  category: constants
  kind: python_call_eq
  function: SO_REUSEADDR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra303.SO_REUSEADDR.value:
  description: "socket.SO_REUSEADDR == 4 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: SO_REUSEADDR.__eq__
  args: [4]
  expected: true

# ---------------------------------------------------------------------------
# SHUT_RDWR — shutdown direction constant
# ---------------------------------------------------------------------------

invariant socket_extra303.SHUT_RDWR.value:
  description: "socket.SHUT_RDWR == 2 — POSIX standard value for shutting down both read and write"
  category: constants
  kind: python_call_eq
  function: SHUT_RDWR.__eq__
  args: [2]
  expected: true
