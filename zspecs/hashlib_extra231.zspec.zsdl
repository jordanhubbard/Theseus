spec: hashlib_extra231
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3module.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.sha3_256().digest_size == 32 — SHA3-256 produces a 256-bit/32-byte digest per FIPS 202."
    - "hashlib.sha3_512().digest_size == 64 — SHA3-512 produces a 512-bit/64-byte digest per FIPS 202."
    - "hashlib.sha3_224().digest_size == 28 — SHA3-224 produces a 224-bit/28-byte digest per FIPS 202."
    - "hashlib.sha3_384().digest_size == 48 — SHA3-384 produces a 384-bit/48-byte digest per FIPS 202."
    - "hashlib.sha3_256().block_size == 136 — SHA3-256 Keccak sponge rate: (1600 - 2*256)/8 == 136 bytes."
    - "hashlib.sha3_512().block_size == 72 — SHA3-512 Keccak sponge rate: (1600 - 2*512)/8 == 72 bytes."
    - "'sha3_256' in hashlib.algorithms_guaranteed == True — sha3_256 is guaranteed on all Python platforms."
    - "'sha3_512' in hashlib.algorithms_guaranteed == True — sha3_512 is guaranteed on all Python platforms."
    - "'shake_128' in hashlib.algorithms_guaranteed == True — shake_128 is guaranteed on all Python platforms."
    - "On macOS/Python 3.14.3 with OpenSSL, hashlib.sha3_256.__name__ is 'openssl_sha3_256' and __module__ is '_hashlib'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib SHA-3 digest_size contracts
#
# hashlib.sha3_256().digest_size == 32
# hashlib.sha3_512().digest_size == 64
# hashlib.sha3_224().digest_size == 28
# hashlib.sha3_384().digest_size == 48
#
# The SHA-3 family is defined in FIPS PUB 202 (Aug 2015). digest_size gives
# the output length in bytes. These values are fixed by the standard.
# ---------------------------------------------------------------------------

table hashlib_extra231.sha3_digest_sizes:
  description: "sha3_256 digest_size==32; sha3_512 digest_size==64; sha3_224 digest_size==28; sha3_384 digest_size==48; FIPS 202 fixed output lengths; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib231

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_digest_size_32,
       "sha3_256().digest_size.__eq__",
       [32],
       true,
       "hashlib.sha3_256().digest_size.__eq__(32) == True — SHA3-256 produces a 256-bit digest (32 bytes); digest_size fixed by FIPS PUB 202; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [sha3_512_digest_size_64,
       "sha3_512().digest_size.__eq__",
       [64],
       true,
       "hashlib.sha3_512().digest_size.__eq__(64) == True — SHA3-512 produces a 512-bit digest (64 bytes); digest_size fixed by FIPS PUB 202; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [sha3_224_digest_size_28,
       "sha3_224().digest_size.__eq__",
       [28],
       true,
       "hashlib.sha3_224().digest_size.__eq__(28) == True — SHA3-224 produces a 224-bit digest (28 bytes); digest_size fixed by FIPS PUB 202; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [sha3_384_digest_size_48,
       "sha3_384().digest_size.__eq__",
       [48],
       true,
       "hashlib.sha3_384().digest_size.__eq__(48) == True — SHA3-384 produces a 384-bit digest (48 bytes); digest_size fixed by FIPS PUB 202; new anchor in extra231 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib SHA-3 block_size contracts
#
# hashlib.sha3_256().block_size == 136
# hashlib.sha3_512().block_size == 72
#
# The SHA-3 (Keccak) sponge construction uses a rate r = (1600 - 2*capacity)
# bits. For SHA3-256: capacity=256, r=1600-512=1088 bits = 136 bytes.
# For SHA3-512: capacity=512, r=1600-1024=576 bits = 72 bytes.
# ---------------------------------------------------------------------------

table hashlib_extra231.sha3_block_sizes:
  description: "sha3_256 block_size==136; sha3_512 block_size==72; Keccak sponge rate r=(1600-2*capacity)/8; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib231a

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_block_size_136,
       "sha3_256().block_size.__eq__",
       [136],
       true,
       "hashlib.sha3_256().block_size.__eq__(136) == True — SHA3-256 Keccak sponge rate r=(1600-2*256)/8=136 bytes; internal absorption block size; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [sha3_512_block_size_72,
       "sha3_512().block_size.__eq__",
       [72],
       true,
       "hashlib.sha3_512().block_size.__eq__(72) == True — SHA3-512 Keccak sponge rate r=(1600-2*512)/8=72 bytes; smaller rate than sha3_256 due to larger capacity; new anchor in extra231 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed membership for SHA-3 variants
#
# 'sha3_256' in hashlib.algorithms_guaranteed == True
# 'sha3_512' in hashlib.algorithms_guaranteed == True
# 'shake_128' in hashlib.algorithms_guaranteed == True
#
# These algorithms are guaranteed on all Python platforms per the docs.
# ---------------------------------------------------------------------------

table hashlib_extra231.sha3_algorithms_guaranteed:
  description: "'sha3_256'/'sha3_512'/'shake_128' in algorithms_guaranteed==True; guaranteed on all Python platforms; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib231b

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["sha3_256"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 is guaranteed on all Python platforms; frozenset membership; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [sha3_512_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["sha3_512"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True — sha3_512 is guaranteed on all Python platforms; frozenset membership; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [shake_128_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["shake_128"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('shake_128') == True — shake_128 XOF (extendable output function) is guaranteed on all Python platforms; frozenset membership; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [sha3_384_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["sha3_384"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha3_384') == True — sha3_384 is guaranteed on all Python platforms; frozenset membership; new anchor in extra231 namespace; verified Python 3.14.3"]
    - [sha3_224_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["sha3_224"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha3_224') == True — sha3_224 is guaranteed on all Python platforms; frozenset membership; new anchor in extra231 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra231.sha3_256_digest_size_32:
  description: "hashlib.sha3_256().digest_size.__eq__(32) == True — SHA3-256 produces a 256-bit digest encoded as 32 bytes; digest_size is fixed by FIPS PUB 202; every call to hashlib.sha3_256() creates a fresh HASH object with digest_size==32; no prior hashlib spec anchors sha3_256().digest_size as standalone in extra231 namespace; first extra231 anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha3_256().digest_size.__eq__"
  args: [32]
  expected: true

invariant hashlib_extra231.sha3_512_digest_size_64:
  description: "hashlib.sha3_512().digest_size.__eq__(64) == True — SHA3-512 produces a 512-bit digest encoded as 64 bytes; digest_size is fixed by FIPS PUB 202; every call to hashlib.sha3_512() creates a fresh HASH object with digest_size==64; no prior hashlib spec anchors sha3_512().digest_size as standalone in extra231 namespace; first extra231 anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha3_512().digest_size.__eq__"
  args: [64]
  expected: true

invariant hashlib_extra231.sha3_256_block_size_136:
  description: "hashlib.sha3_256().block_size.__eq__(136) == True — SHA3-256 uses a Keccak sponge with rate r=(1600-2*256)/8=136 bytes; this is the internal absorption block size; contrasts with SHA-256 block_size==64 (different algorithm family); no prior hashlib spec anchors sha3_256().block_size as standalone in extra231 namespace; first extra231 anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha3_256().block_size.__eq__"
  args: [136]
  expected: true
