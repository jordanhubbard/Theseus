spec: io_extra234
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec covers: io.BytesIO and io.StringIO write/read/seek behavioral contracts — write return values, tell after init, readable/writable/seekable predicates."
    - "io.BytesIO(b'hello').tell() == 0 — initial stream position is 0 even when buffer initialized with bytes; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'hello').write(b' world') returns 6 — write returns number of bytes written; verified Python 3.14.3 macOS."
    - "io.BytesIO().write(b'test') returns 4 — write to empty BytesIO returns byte count 4; verified Python 3.14.3 macOS."
    - "io.BytesIO().write(b'') returns 0 — writing empty bytes returns 0; verified Python 3.14.3 macOS."
    - "io.StringIO().write('hello') returns 5 — write to empty StringIO returns character count; verified Python 3.14.3 macOS."
    - "io.StringIO('hello').write(' world') returns 6 — write returns character count 6; verified Python 3.14.3 macOS."
    - "io.BytesIO().readable() == True — BytesIO is readable; verified Python 3.14.3 macOS."
    - "io.BytesIO().writable() == True — BytesIO is writable; verified Python 3.14.3 macOS."
    - "io.BytesIO().seekable() == True — BytesIO is seekable; verified Python 3.14.3 macOS."
    - "io.StringIO().readable() == True — StringIO is readable; verified Python 3.14.3 macOS."
    - "io.StringIO().writable() == True — StringIO is writable; verified Python 3.14.3 macOS."
    - "io.StringIO().seekable() == True — StringIO is seekable; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO tell and write return-value behavioral contracts
# BytesIO(b'hello').tell() == 0 — init with bytes does not advance position.
# BytesIO(b'hello').write(b' world') returns 6 (bytes written).
# BytesIO().write(b'test') returns 4; write(b'') returns 0.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra234.BytesIO.tell_after_init_zero:
  description: "io.BytesIO(b'hello').tell() == 0 — stream position starts at 0 even when buffer is pre-populated with bytes; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello'"]
  method: tell
  expected: 0

invariant io_extra234.BytesIO.write_returns_byte_count:
  description: "io.BytesIO(b'hello').write(b' world') == 6 — write returns the number of bytes written; b' world' has 6 bytes; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello'"]
  method: write
  method_args: ["b' world'"]
  expected: 6

invariant io_extra234.BytesIO.write_empty_returns_4:
  description: "io.BytesIO().write(b'test') == 4 — writing 4-byte literal to empty BytesIO returns 4; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: []
  method: write
  method_args: ["b'test'"]
  expected: 4

invariant io_extra234.BytesIO.write_empty_bytes_returns_0:
  description: "io.BytesIO().write(b'') == 0 — writing empty bytes returns 0; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: []
  method: write
  method_args: ["b''"]
  expected: 0

# ---------------------------------------------------------------------------
# io.StringIO tell and write return-value behavioral contracts
# StringIO('hello').tell() == 0 — position starts at 0 after init with string.
# StringIO().write('hello') returns 5; StringIO('hello').write(' world') returns 6.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra234.StringIO.tell_after_init_zero:
  description: "io.StringIO('hello').tell() == 0 — stream position starts at 0 even when StringIO is initialized with a string; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: tell
  expected: 0

invariant io_extra234.StringIO.write_returns_char_count_5:
  description: "io.StringIO().write('hello') == 5 — write to empty StringIO returns character count; 'hello' has 5 characters; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: StringIO
  args: []
  method: write
  method_args: ["hello"]
  expected: 5

invariant io_extra234.StringIO.write_returns_char_count_6:
  description: "io.StringIO('hello').write(' world') == 6 — write to initialized StringIO returns character count; ' world' has 6 characters; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: write
  method_args: [" world"]
  expected: 6

# ---------------------------------------------------------------------------
# io.BytesIO readable/writable/seekable predicate contracts
# All three return True for BytesIO instances.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra234.BytesIO.readable_true:
  description: "io.BytesIO().readable() == True — BytesIO supports reading; readable() returns True; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: []
  method: readable
  expected: true

invariant io_extra234.BytesIO.writable_true:
  description: "io.BytesIO().writable() == True — BytesIO supports writing; writable() returns True; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: []
  method: writable
  expected: true

invariant io_extra234.BytesIO.seekable_true:
  description: "io.BytesIO().seekable() == True — BytesIO supports seeking; seekable() returns True; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: []
  method: seekable
  expected: true

# ---------------------------------------------------------------------------
# io.StringIO readable/writable/seekable predicate contracts
# All three return True for StringIO instances.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra234.StringIO.readable_true:
  description: "io.StringIO().readable() == True — StringIO supports reading; readable() returns True; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: StringIO
  args: []
  method: readable
  expected: true

invariant io_extra234.StringIO.writable_true:
  description: "io.StringIO().writable() == True — StringIO supports writing; writable() returns True; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: StringIO
  args: []
  method: writable
  expected: true

invariant io_extra234.StringIO.seekable_true:
  description: "io.StringIO().seekable() == True — StringIO supports seeking; seekable() returns True; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: StringIO
  args: []
  method: seekable
  expected: true
