spec: zero_fill
version: ">=2.0.0"
backend: node(zero-fill)

docs: https://github.com/finnp/zero-fill#readme

provenance:
  derived_from:
    - "zero-fill README — https://github.com/finnp/zero-fill#readme"
    - "Test vectors verified with zero-fill via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "zero-fill source"
  notes:
    - "Pad a number with leading zeros to a target width."
    - "Install: npm install zero-fill"
    - "v2 CJS; module export IS the function. Curried: zf(width)(num) also works."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant zero_fill.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant zero_fill.pad_to_three:
  description: "zf(3, 5) is '005'"
  category: pad
  kind: node_chain_eq
  entry: module
  entry_args: [3, 5]
  chain: []
  expected: "005"

invariant zero_fill.pad_to_five_short:
  description: "zf(5, 123) is '00123'"
  category: pad
  kind: node_chain_eq
  entry: module
  entry_args: [5, 123]
  chain: []
  expected: "00123"

invariant zero_fill.no_pad_when_width_smaller:
  description: "zf(5, 12345) is '12345' (no padding when value already meets width)"
  category: pad
  kind: node_chain_eq
  entry: module
  entry_args: [5, 12345]
  chain: []
  expected: "12345"

invariant zero_fill.zero_value_padded:
  description: "zf(3, 0) is '000'"
  category: pad
  kind: node_chain_eq
  entry: module
  entry_args: [3, 0]
  chain: []
  expected: "000"

invariant zero_fill.zero_width_returns_string:
  description: "zf(0, 5) is '5' (zero width = no padding)"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [0, 5]
  chain: []
  expected: "5"

invariant zero_fill.curried_form:
  description: "Curried zf(3)(5) yields '005'"
  category: pad
  kind: node_chain_eq
  entry: bare
  chain:
    - {call: [3]}
    - {call: [5]}
  expected: "005"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:45:02Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
