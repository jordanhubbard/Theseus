# ---------------------------------------------------------------------------
# __getstate__ dict-presence — operator.contains(Cls.__dict__, '__getstate__')
#
# io.FileIO and io.BytesIO (concrete types) define __getstate__ for copy support.
# The abstract base classes do not.
# ---------------------------------------------------------------------------

table io3556.getstate:
  description: "io types __getstate__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3556
  columns: [id, function, args, expected]
  rows:
    - ["io3556011", operator.contains, [io.RawIOBase.__dict__,      "__getstate__"], false]
    - ["io3556012", operator.contains, [io.BufferedIOBase.__dict__, "__getstate__"], false]
    - ["io3556013", operator.contains, [io.TextIOBase.__dict__,     "__getstate__"], false]
    - ["io3556014", operator.contains, [io.FileIO.__dict__,         "__getstate__"], true]
    - ["io3556015", operator.contains, [io.BytesIO.__dict__,        "__getstate__"], true]

