invariant functools_extra105.wraps_qualname_len:
  description: "len(functools.wraps.__qualname__) == 5 — qualname is 'wraps'; wave 257; new to extra105"
  kind: python_call_eq
  function: wraps.__qualname__.__len__
  args: []
  expected: 5

invariant functools_extra105.wrapper_assignments_len:
  description: "len(functools.WRAPPER_ASSIGNMENTS) == 6 — contains 6 attribute names to copy in Python 3.14; wave 257; new to extra105"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra105.partial_class_name:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a C extension type not a function; wave 257; new to extra105"
  kind: python_call_eq
