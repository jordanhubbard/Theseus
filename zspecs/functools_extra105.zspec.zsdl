invariant functools_extra105.update_wrapper_co_argcount:
  description: "functools.update_wrapper.__code__.co_argcount == 4 — takes (wrapper, wrapped, assigned, updated); wave 257; new to extra105"
  kind: python_call_eq
  function: update_wrapper.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant functools_extra105.wraps_co_argcount:
  description: "functools.wraps.__code__.co_argcount == 3 — takes (wrapped, assigned, updated); wave 257; new to extra105"
  kind: python_call_eq
