  args: [3]
  expected: true

invariant functools_extra105.update_wrapper_qualname_len:
  description: "len(functools.update_wrapper.__qualname__) == 14 — qualname is 'update_wrapper'; wave 257; new to extra105"
  kind: python_call_eq
  function: update_wrapper.__qualname__.__len__
  args: []
