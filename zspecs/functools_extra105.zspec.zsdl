spec: functools_extra105
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra99

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra99.zspec.zsdl."
    - "This spec covers: functools.update_wrapper and functools.wraps code object attributes (co_name, co_argcount, __qualname__, __module__); functools.reduce and functools.cmp_to_key __qualname__ attrs; functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES tuple lengths; functools.lru_cache and functools.partial qualnames (Wave 257)."
    - "functools.update_wrapper.__code__.co_argcount == 4 — takes (wrapper, wrapped, assigned, updated). Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper' (len 14) — module-scope function. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_argcount == 3 — takes (wrapped, assigned, updated). Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' (len 5) — module-scope function. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' (len 6) — C builtin_function_or_method from _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10) — C builtin_function_or_method from _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS is a tuple of length 6 in Python 3.14. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES is a tuple of length 1. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (len 9) — pure-Python decorator factory. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial' (len 7) — C extension type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: update_wrapper and wraps code object attributes
#
# Wave 257 theme: functools.update_wrapper and functools.wraps code attrs.
#
# functools.update_wrapper.__code__.co_name == 'update_wrapper'
# functools.update_wrapper.__code__.co_argcount == 4
# functools.update_wrapper.__qualname__ == 'update_wrapper'
# len(functools.update_wrapper.__qualname__) == 14
# functools.wraps.__code__.co_name == 'wraps'
# functools.wraps.__code__.co_argcount == 3
# functools.wraps.__qualname__ == 'wraps'
# len(functools.wraps.__qualname__) == 5
#
# update_wrapper takes (wrapper, wrapped, assigned, updated) — co_argcount is 4.
# wraps takes (wrapped, assigned, updated) — co_argcount is 3.
# New to extra105.
# ---------------------------------------------------------------------------

table functools_extra105.update_wrapper_wraps_code_attrs:
  description: "functools.update_wrapper and functools.wraps code object attributes (co_name, co_argcount, __qualname__); update_wrapper takes 4 args, wraps takes 3; wave 257; new to extra105"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsupdatewrapper105

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_co_name_eq,
       "update_wrapper.__code__.co_name.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True — update_wrapper is a pure-Python function defined in Lib/functools.py; co_name holds the name from the def statement which is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra105"]
    - [update_wrapper_co_argcount_eq_4,
       "update_wrapper.__code__.co_argcount.__eq__",
       [4],
       true,
       "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper takes 4 positional arguments: wrapper, wrapped, assigned, updated; co_argcount counts positional (non-*args, non-**kwargs) parameters; int.__eq__(4) returns True; new to extra105"]
    - [update_wrapper_qualname_eq,
       "update_wrapper.__qualname__.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — update_wrapper is defined at module scope in Lib/functools.py; its __qualname__ equals the plain function name 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra105"]
    - [update_wrapper_qualname_len_eq_14,
       "update_wrapper.__qualname__.__len__",
       [],
       14,
       "functools.update_wrapper.__qualname__.__len__() == 14 — __qualname__ is 'update_wrapper'; len('update_wrapper') == 14; the string has 14 characters (u-p-d-a-t-e-_-w-r-a-p-p-e-r); new to extra105"]
    - [wraps_co_name_eq,
       "wraps.__code__.co_name.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__code__.co_name.__eq__('wraps') == True — wraps is a pure-Python decorator factory defined in Lib/functools.py; co_name holds 'wraps' from the def statement; str.__eq__('wraps') returns True; new to extra105"]
    - [wraps_co_argcount_eq_3,
       "wraps.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps takes 3 positional arguments: wrapped, assigned, updated; co_argcount is 3; int.__eq__(3) returns True; new to extra105"]
    - [wraps_qualname_eq,
       "wraps.__qualname__.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is defined at module scope in Lib/functools.py; its __qualname__ is 'wraps'; str.__eq__('wraps') returns True; new to extra105"]
    - [wraps_qualname_len_eq_5,
       "wraps.__qualname__.__len__",
       [],
       5,
       "functools.wraps.__qualname__.__len__() == 5 — __qualname__ is 'wraps'; len('wraps') == 5; the string has 5 characters (w-r-a-p-s); new to extra105"]

# ---------------------------------------------------------------------------
# Table 2: reduce and cmp_to_key __qualname__ lengths; WRAPPER_ASSIGNMENTS len
#
# Wave 257 theme: functools builtins qualnames and WRAPPER_ASSIGNMENTS tuple length.
#
# functools.reduce.__qualname__ == 'reduce'  (len 6)
# functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10)
# len(functools.WRAPPER_ASSIGNMENTS) == 6
# len(functools.WRAPPER_UPDATES) == 1
# functools.lru_cache.__qualname__ == 'lru_cache' (len 9)
# functools.partial.__qualname__ == 'partial' (len 7)
#
# reduce and cmp_to_key are C builtins from _functoolsmodule.c.
# WRAPPER_ASSIGNMENTS has 6 entries in Python 3.14 (added __annotate__ and __type_params__).
# New to extra105.
# ---------------------------------------------------------------------------

table functools_extra105.qualname_lengths_and_wrapper_attrs:
  description: "functools.reduce/__qualname__ len 6; cmp_to_key len 10; WRAPPER_ASSIGNMENTS len 6; WRAPPER_UPDATES len 1; lru_cache len 9; partial len 7; wave 257; new to extra105"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsupdatewrapper105

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_eq,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — functools.reduce is a C builtin_function_or_method implemented in Modules/_functoolsmodule.c; its __qualname__ is the simple function name 'reduce'; str.__eq__('reduce') returns True; new to extra105"]
    - [reduce_qualname_len_eq_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — __qualname__ is 'reduce'; len('reduce') == 6; (r-e-d-u-c-e); new to extra105"]
    - [cmp_to_key_qualname_eq,
       "cmp_to_key.__qualname__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — cmp_to_key is a C builtin_function_or_method from Modules/_functoolsmodule.c; it converts an old-style comparison function to a key function for sorting; __qualname__ is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra105"]
    - [cmp_to_key_qualname_len_eq_10,
       "cmp_to_key.__qualname__.__len__",
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — __qualname__ is 'cmp_to_key'; len('cmp_to_key') == 10; (c-m-p-_-t-o-_-k-e-y); new to extra105"]
    - [wrapper_assignments_len_eq_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS is a module-level tuple of attribute names copied from the wrapped function to the wrapper; in Python 3.14 it contains 6 entries: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; len() == 6; new to extra105"]
    - [wrapper_updates_len_eq_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is a module-level tuple of attribute names updated (merged) from the wrapped function to the wrapper; it contains one entry: '__dict__'; len() == 1; new to extra105"]
    - [lru_cache_qualname_eq,
       "lru_cache.__qualname__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a pure-Python decorator factory function defined in Lib/functools.py; its __qualname__ is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra105"]
    - [lru_cache_qualname_len_eq_9,
       "lru_cache.__qualname__.__len__",
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — __qualname__ is 'lru_cache'; len('lru_cache') == 9; (l-r-u-_-c-a-c-h-e); new to extra105"]

# ---------------------------------------------------------------------------
# Table 3: update_wrapper and wraps __module__; partial and lru_cache class names
#
# Wave 257 theme: functools function __module__ attrs and partial class name.
#
# functools.update_wrapper.__module__ == 'functools'
# functools.wraps.__module__ == 'functools'
# functools.partial.__class__.__name__ == 'type'
# functools.partial.__qualname__ == 'partial' (len 7)
# functools.lru_cache.__class__.__name__ == 'function'
# functools.update_wrapper.__class__.__name__ == 'function'
# functools.wraps.__class__.__name__ == 'function'
#
# update_wrapper and wraps are pure-Python functions (class 'function').
# partial is a C extension type (class 'type'). lru_cache is a Python function.
# New to extra105.
# ---------------------------------------------------------------------------

table functools_extra105.module_attrs_and_class_names:
  description: "functools update_wrapper/wraps __module__; partial class name 'type'; lru_cache class name 'function'; wave 257; new to extra105"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsupdatewrapper105

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_module_eq_functools,
       "update_wrapper.__module__.__eq__",
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra105"]
    - [wraps_module_eq_functools,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra105"]
    - [update_wrapper_class_name_eq_function,
       "update_wrapper.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__.__eq__('function') == True — update_wrapper is a pure-Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra105"]
    - [wraps_class_name_eq_function,
       "wraps.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is a pure-Python function defined in Lib/functools.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra105"]
    - [lru_cache_class_name_eq_function,
       "lru_cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a pure-Python function (decorator factory) defined in Lib/functools.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra105"]
    - [partial_class_name_eq_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — functools.partial is a C extension type defined in Modules/_functoolsmodule.c; it is a class (type) not a function; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra105"]
    - [partial_qualname_eq,
       "partial.__qualname__.__eq__",
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — functools.partial is a C extension class; its __qualname__ is 'partial'; str.__eq__('partial') returns True; new to extra105"]
    - [partial_qualname_len_eq_7,
       "partial.__qualname__.__len__",
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — __qualname__ is 'partial'; len('partial') == 7; (p-a-r-t-i-a-l); new to extra105"]

