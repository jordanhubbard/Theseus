spec: pathlib_extra279
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' and __module__ == 'pathlib'."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — inherits directly from PurePath."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' and __module__ == 'pathlib'."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — same base as PurePosixPath."
    - "pathlib.Path.__name__ == 'Path' and __module__ == 'pathlib'."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path also inherits directly from PurePath."
    - "pathlib.PurePath.__name__ == 'PurePath' and __bases__[0].__name__ == 'object' — PurePath is the root."
    - "All four path classes have __class__.__name__ == 'type' — they are plain Python classes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: pathlib pure path class identity
# ---------------------------------------------------------------------------

table pathlib_extra279.pure_path_class_identity:
  description: "PurePosixPath, PureWindowsPath __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: ppi

  columns: [id, function, args, expected, description]
  rows:
    - [posix_name,    PurePosixPath.__name__.__eq__,                    ["PurePosixPath"],   true, "pathlib.PurePosixPath.__name__ == 'PurePosixPath'"]
    - [posix_module,  PurePosixPath.__module__.__eq__,                  ["pathlib"],         true, "pathlib.PurePosixPath.__module__ == 'pathlib'"]
    - [posix_base,    "PurePosixPath.__bases__[0].__name__.__eq__",     ["PurePath"],        true, "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath'"]
    - [posix_meta,    PurePosixPath.__class__.__name__.__eq__,          ["type"],            true, "pathlib.PurePosixPath.__class__.__name__ == 'type'"]
    - [win_name,      PureWindowsPath.__name__.__eq__,                  ["PureWindowsPath"], true, "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'"]
    - [win_module,    PureWindowsPath.__module__.__eq__,                ["pathlib"],         true, "pathlib.PureWindowsPath.__module__ == 'pathlib'"]
    - [win_base,      "PureWindowsPath.__bases__[0].__name__.__eq__",   ["PurePath"],        true, "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath'"]
    - [win_meta,      PureWindowsPath.__class__.__name__.__eq__,        ["type"],            true, "pathlib.PureWindowsPath.__class__.__name__ == 'type'"]

# ---------------------------------------------------------------------------
# Table: pathlib.Path and pathlib.PurePath class identity
# ---------------------------------------------------------------------------

table pathlib_extra279.path_class_identity:
  description: "pathlib.Path and pathlib.PurePath __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: pci

  columns: [id, function, args, expected, description]
  rows:
    - [path_name,      Path.__name__.__eq__,                  ["Path"],      true, "pathlib.Path.__name__ == 'Path'"]
    - [path_module,    Path.__module__.__eq__,                ["pathlib"],   true, "pathlib.Path.__module__ == 'pathlib'"]
    - [path_base,      "Path.__bases__[0].__name__.__eq__",   ["PurePath"],  true, "pathlib.Path.__bases__[0].__name__ == 'PurePath'"]
    - [path_meta,      Path.__class__.__name__.__eq__,        ["type"],      true, "pathlib.Path.__class__.__name__ == 'type'"]
    - [purepath_name,  PurePath.__name__.__eq__,              ["PurePath"],  true, "pathlib.PurePath.__name__ == 'PurePath'"]
    - [purepath_mod,   PurePath.__module__.__eq__,            ["pathlib"],   true, "pathlib.PurePath.__module__ == 'pathlib'"]
    - [purepath_base,  "PurePath.__bases__[0].__name__.__eq__", ["object"],  true, "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root"]
    - [purepath_meta,  PurePath.__class__.__name__.__eq__,    ["type"],      true, "pathlib.PurePath.__class__.__name__ == 'type'"]

# ---------------------------------------------------------------------------
# Standalone invariants: confirming inheritance chain consistency
# ---------------------------------------------------------------------------

invariant pathlib_extra279.PurePosixPath.name:
  description: "pathlib.PurePosixPath.__name__ == 'PurePosixPath'"
  category: identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra279.PurePosixPath.base_is_PurePath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath inherits from PurePath"
  category: identity
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra279.PureWindowsPath.base_is_PurePath:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath inherits from PurePath"
  category: identity
  kind: python_call_eq
  function: "PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra279.Path.base_is_PurePath:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path inherits from PurePath"
  category: identity
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra279.PurePath.base_is_object:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the hierarchy"
  category: identity
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
