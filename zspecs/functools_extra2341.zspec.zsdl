spec: functools_extra2341
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 603 (_extra2341): __slots__ content and absence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "functools.cached_property on Python 3.14 is a pure-Python class WITHOUT __slots__ in its __dict__; __dict__.__contains__('__slots__') == False."
    - "functools.partial is a C extension type; __dict__.__contains__('__slots__') == False."
    - "functools.partialmethod is a pure-Python class without __slots__; __dict__.__contains__('__slots__') == False."
    - "functools._lru_cache_wrapper is a C extension type; __dict__.__contains__('__slots__') == False."
    - "functools.singledispatchmethod is a pure-Python class without __slots__; __dict__.__contains__('__slots__') == False."
    - "functools._CacheInfo is a namedtuple with __slots__ == () (empty); __dict__.__contains__('__slots__') == True and __slots__.__len__() == 0."
  created_at: "2026-04-12"

table functools_extra2341.cached_property_no_slots:
  description: "functools.cached_property has no __slots__ in its own __dict__ on Python 3.14"
  kind: python_call_eq
  category: slots_absence
  id_prefix: ft2341
  columns: [id, function, args, expected]
  rows:
    - ["ft2341001", "functools.cached_property.__dict__.__contains__", ["__slots__"], false]
    - ["ft2341002", "functools.partial.__dict__.__contains__", ["__slots__"], false]
    - ["ft2341003", "functools.partialmethod.__dict__.__contains__", ["__slots__"], false]
    - ["ft2341004", "functools._lru_cache_wrapper.__dict__.__contains__", ["__slots__"], false]
    - ["ft2341005", "functools.singledispatchmethod.__dict__.__contains__", ["__slots__"], false]

table functools_extra2341.cache_info_slots:
  description: "functools._CacheInfo is a namedtuple; __slots__ is present but empty"
  kind: python_call_eq
  category: slots_content
  id_prefix: ft2341
  columns: [id, function, args, expected]
  rows:
    - ["ft2341006", "functools._CacheInfo.__dict__.__contains__", ["__slots__"], true]
    - ["ft2341007", "functools._CacheInfo.__slots__.__len__", [], 0]
    - ["ft2341008", "functools._CacheInfo.__slots__.__contains__", ["hits"], false]
    - ["ft2341009", "functools._CacheInfo.__slots__.__contains__", ["misses"], false]
    - ["ft2341010", "functools._CacheInfo.__slots__.__contains__", ["maxsize"], false]
    - ["ft2341011", "functools._CacheInfo.__slots__.__contains__", ["currsize"], false]

table functools_extra2341.no_slots_cross_check:
  description: "Cross-check: none of the non-slotted functools types accidentally expose __slots__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: ft2341
  columns: [id, function, args, expected]
  rows:
    - ["ft2341012", "functools.cached_property.__dict__.__contains__", ["func"], false]
    - ["ft2341013", "functools.cached_property.__dict__.__contains__", ["attrname"], false]
    - ["ft2341014", "functools.partialmethod.__dict__.__contains__", ["__slots__"], false]
    - ["ft2341015", "functools.singledispatchmethod.__dict__.__contains__", ["__slots__"], false]
    - ["ft2341016", "functools.partial.__dict__.__contains__", ["__slots__"], false]
    - ["ft2341017", "functools._lru_cache_wrapper.__dict__.__contains__", ["__slots__"], false]
    - ["ft2341018", "functools._CacheInfo.__slots__.__contains__", ["__slots__"], false]
    - ["ft2341019", "functools._CacheInfo.__slots__.__contains__", ["nonexistent"], false]
    - ["ft2341020", "functools._CacheInfo.__dict__.__contains__", ["__slots__"], true]
    - ["ft2341021", "functools._CacheInfo.__slots__.__len__", [], 0]
