spec: itertools_extra1801
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value and container protocol dict-presence checks for itertools C types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra1801.truth_protocol:
  description: "itertools C types __bool__ and __len__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1801

  columns: [id, function, args, expected]
  rows:
    - ["it1801001", "itertools.count.__dict__.__contains__", ["__bool__"], false]
    - ["it1801002", "itertools.count.__dict__.__contains__", ["__len__"], false]
    - ["it1801003", "itertools.chain.__dict__.__contains__", ["__bool__"], false]
    - ["it1801004", "itertools.chain.__dict__.__contains__", ["__len__"], false]
    - ["it1801005", "itertools.cycle.__dict__.__contains__", ["__bool__"], false]
    - ["it1801006", "itertools.cycle.__dict__.__contains__", ["__len__"], false]
    - ["it1801007", "itertools.repeat.__dict__.__contains__", ["__bool__"], false]
    - ["it1801008", "itertools.repeat.__dict__.__contains__", ["__len__"], false]
    - ["it1801009", "itertools.repeat.__dict__.__contains__", ["__length_hint__"], true]

table itertools_extra1801.container_protocol:
  description: "itertools C types __iter__, __next__, and __contains__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1801

  columns: [id, function, args, expected]
  rows:
    - ["it1801101", "itertools.count.__dict__.__contains__", ["__iter__"], true]
    - ["it1801102", "itertools.count.__dict__.__contains__", ["__next__"], true]
    - ["it1801103", "itertools.count.__dict__.__contains__", ["__contains__"], false]
    - ["it1801104", "itertools.count.__dict__.__contains__", ["__getitem__"], false]
    - ["it1801105", "itertools.chain.__dict__.__contains__", ["__iter__"], true]
    - ["it1801106", "itertools.chain.__dict__.__contains__", ["__next__"], true]
    - ["it1801107", "itertools.chain.__dict__.__contains__", ["from_iterable"], true]
    - ["it1801108", "itertools.repeat.__dict__.__contains__", ["__iter__"], true]
    - ["it1801109", "itertools.repeat.__dict__.__contains__", ["__next__"], true]

table itertools_extra1801.pairwise_attrs:
  description: "itertools product, combinations, permutations, combinations_with_replacement dict-presence checks (3.9+ compatible)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1801

  columns: [id, function, args, expected]
  rows:
    - ["it1801201", "itertools.product.__dict__.__contains__", ["__iter__"], true]
    - ["it1801202", "itertools.product.__dict__.__contains__", ["__next__"], true]
    - ["it1801203", "itertools.product.__dict__.__contains__", ["__new__"], true]
    - ["it1801204", "itertools.combinations.__dict__.__contains__", ["__iter__"], true]
    - ["it1801205", "itertools.combinations.__dict__.__contains__", ["__next__"], true]
    - ["it1801206", "itertools.permutations.__dict__.__contains__", ["__iter__"], true]
    - ["it1801207", "itertools.permutations.__dict__.__contains__", ["__next__"], true]
    - ["it1801208", "itertools.combinations_with_replacement.__dict__.__contains__", ["__iter__"], true]
    - ["it1801209", "itertools.combinations_with_replacement.__dict__.__contains__", ["__next__"], true]
