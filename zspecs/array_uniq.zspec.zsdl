spec: array_uniq
version: ">=3.0.0"
backend: node(array-uniq)

docs: https://www.npmjs.com/package/array-uniq

provenance:
  derived_from:
    - "array-uniq README — https://www.npmjs.com/package/array-uniq"
    - "Test vectors verified with array-uniq via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-uniq source"
  notes:
    - "array-uniq is an npm package. Install: npm install array-uniq"
    - "Removes duplicate values from an array. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array with duplicates removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_uniq.uniq:
  kind: node_module_call_eq
  function: "default"
  category: filter
  id_prefix: arruniq

  columns: [id, args, expected]
  rows:
    - [duplicates, [[1, 2, 1, 3]], [1, 2, 3]]
    - [strings,    [["a", "b", "a"]], ["a", "b"]]
