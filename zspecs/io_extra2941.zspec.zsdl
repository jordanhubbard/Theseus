spec: io2941
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io class __dict__ unary operator presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/"
  notes:
    - "io I/O classes are stream/file types; they do not define numeric unary operators."
    - "operator.contains(cls.__dict__, '__neg__') is False for all io classes — these are not numeric types."
    - "operator.contains(cls.__dict__, '__pos__') is False for all io classes."
    - "operator.contains(cls.__dict__, '__abs__') is False for all io classes."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — unary negation operator in own __dict__
#
# None of the io classes define __neg__ in their own __dict__.
# These are stream/file abstractions, not numeric types.
# ---------------------------------------------------------------------------

table io2941.neg:
  description: "operator.contains(cls.__dict__, '__neg__') is False for all io classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ion2941

  columns: [id, function, args, expected]
  rows:
    - ["ion2941_001", operator.contains, [io.IOBase.__dict__,       "__neg__"], false]
    - ["ion2941_002", operator.contains, [io.RawIOBase.__dict__,    "__neg__"], false]
    - ["ion2941_003", operator.contains, [io.BufferedIOBase.__dict__,"__neg__"], false]
    - ["ion2941_004", operator.contains, [io.TextIOBase.__dict__,   "__neg__"], false]
    - ["ion2941_005", operator.contains, [io.FileIO.__dict__,       "__neg__"], false]
    - ["ion2941_006", operator.contains, [io.BytesIO.__dict__,      "__neg__"], false]
    - ["ion2941_007", operator.contains, [io.StringIO.__dict__,     "__neg__"], false]
    - ["ion2941_008", operator.contains, [io.BufferedReader.__dict__,"__neg__"], false]
    - ["ion2941_009", operator.contains, [io.BufferedWriter.__dict__,"__neg__"], false]
    - ["ion2941_010", operator.contains, [io.BufferedRandom.__dict__,"__neg__"], false]
    - ["ion2941_011", operator.contains, [io.TextIOWrapper.__dict__, "__neg__"], false]

