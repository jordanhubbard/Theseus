# ---------------------------------------------------------------------------
# combined — all three operators across all io classes
#
# Cross-check table confirming that no io class defines any of the three
# unary numeric operators in its own __dict__.
# ---------------------------------------------------------------------------

table io2941.combined:
  description: "Combined: no io class defines __neg__, __pos__, or __abs__ in its own __dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: iox2941

  columns: [id, function, args, expected]
  rows:
    - ["iox2941_001", operator.contains, [io.IOBase.__dict__,        "__neg__"], false]
    - ["iox2941_002", operator.contains, [io.IOBase.__dict__,        "__pos__"], false]
    - ["iox2941_003", operator.contains, [io.IOBase.__dict__,        "__abs__"], false]
    - ["iox2941_004", operator.contains, [io.BytesIO.__dict__,       "__neg__"], false]
    - ["iox2941_005", operator.contains, [io.BytesIO.__dict__,       "__pos__"], false]
    - ["iox2941_006", operator.contains, [io.BytesIO.__dict__,       "__abs__"], false]
    - ["iox2941_007", operator.contains, [io.StringIO.__dict__,      "__neg__"], false]
    - ["iox2941_008", operator.contains, [io.StringIO.__dict__,      "__pos__"], false]
    - ["iox2941_009", operator.contains, [io.StringIO.__dict__,      "__abs__"], false]
    - ["iox2941_010", operator.contains, [io.TextIOWrapper.__dict__, "__neg__"], false]
    - ["iox2941_011", operator.contains, [io.TextIOWrapper.__dict__, "__pos__"], false]
    - ["iox2941_012", operator.contains, [io.TextIOWrapper.__dict__, "__abs__"], false]
    - ["iox2941_013", operator.contains, [io.BufferedReader.__dict__,"__neg__"], false]
    - ["iox2941_014", operator.contains, [io.BufferedReader.__dict__,"__pos__"], false]
    - ["iox2941_015", operator.contains, [io.BufferedReader.__dict__,"__abs__"], false]
