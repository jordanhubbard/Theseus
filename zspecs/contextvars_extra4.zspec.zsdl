spec: contextvars_extra4
version: ">=3.7"
backend: python_module(contextvars)

docs: https://docs.python.org/3/library/contextvars.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextvars.html — Python contextvars documentation"
    - "PEP 567 — Context Variables (https://peps.python.org/pep-0567/)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_contextvars.py or C extension internals"
  notes:
    - "This spec extends contextvars_extra3.zspec.zsdl."
    - "Prior specs covered: class names/modules for ContextVar/Context/Token; copy_context.__name__ and return type; ContextVar.get() with str/None/int/bool defaults; Token/ContextVar/Context base class == object; Token.MISSING.__class__.__name__ == 'object'; ContextVar.__qualname__, Token.__qualname__, Context.__qualname__; copy_context.__module__/__class__.__name__; ContextVar.__name__.__len__() == 10; ContextVar/Token.__bases__.__len__() == 1; Context.__bases__.__len__() == 1; Token.__module__ standalone; Token.MISSING.__class__.__qualname__; Context.__class__.__name__ == 'type'; ContextVar.name property."
    - "NEW in this spec: contextvars.__all__ metadata (__class__.__name__.__len__() == 5, __len__() == 4); class __dict__.__class__.__name__.__len__() for ContextVar/Context/Token (all 12 = mappingproxy); ContextVar/Context/Token __mro__.__len__() (all 2); ContextVar.__bases__[0].__name__.__len__() == 6; ContextVar.get/__qualname__.__len__() == 14; ContextVar.set/__qualname__.__len__() == 14; ContextVar.reset/__qualname__.__len__() == 16; Context.run/__qualname__.__len__() == 11; Context.copy/__qualname__.__len__() == 12; copy_context.__qualname__.__len__() == 12; ContextVar.__qualname__.__len__() == 10; Token.__qualname__.__len__() == 5."
    - "contextvars.__all__ is a tuple — __class__.__name__ == 'tuple' (5 chars), __len__() == 4."
    - "All three main classes (ContextVar, Context, Token) have __dict__ of type mappingproxy — 12 characters."
    - "All three classes have __mro__.__len__() == 2 — each inherits directly from object only."
    - "ContextVar method qualnames: get==14, set==14, reset==16."
    - "Context method qualnames: run==11, copy==12."
    - "copy_context.__qualname__ == 'copy_context' — length 12."
    - "ContextVar.__qualname__.__len__() == 10 (same as __name__.__len__()); Token.__qualname__.__len__() == 5."
    - "Surprise: contextvars.__all__ is a tuple (not a list), unlike threading.__all__ which is a list."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# contextvars.__all__ metadata — extra4 namespace
#
# contextvars.__all__ is a tuple (verified: ('Context','ContextVar','Token',
# 'copy_context')). The type name 'tuple' has 5 characters. The tuple holds
# exactly 4 public names. No prior spec has measured __all__ metadata for
# the contextvars module.
# ---------------------------------------------------------------------------

table contextvars_extra4.all_metadata:
  description: "contextvars.__all__ metadata: tuple type name length and export count in extra4 namespace"
  kind: python_call_eq
  category: module_structure
  id_prefix: allmetadata4

  columns: [id, function, args, expected]
  rows:
    - [all_class_name_len, contextvars.__all__.__class__.__name__.__len__, [], 5]
    - [all_len,            contextvars.__all__.__len__,                    [], 4]

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() table — extra4 namespace
#
# All three contextvars classes (ContextVar, Context, Token) are C-extension
# types exposed through the contextvars package. Their __dict__ attributes
# are mappingproxy objects — 'mappingproxy' has 12 characters. No prior spec
# has measured __dict__.__class__.__name__.__len__() for these classes.
# ---------------------------------------------------------------------------

table contextvars_extra4.class_dict_class_name_lengths:
  description: "contextvars class __dict__.__class__.__name__.__len__() for ContextVar/Context/Token in extra4 namespace — all equal 12 (mappingproxy)"
  kind: python_call_eq
  category: class_structure
  id_prefix: classdictnamelen4

  columns: [id, function, args, expected]
  rows:
    - [ContextVar, ContextVar.__dict__.__class__.__name__.__len__, [], 12]
    - [Context,    Context.__dict__.__class__.__name__.__len__,    [], 12]
    - [Token,      Token.__dict__.__class__.__name__.__len__,      [], 12]

# ---------------------------------------------------------------------------
# Class __mro__.__len__() table — extra4 namespace
#
# All three contextvars classes have MRO length 2: each class inherits
# directly from object with no intermediate classes:
#   ContextVar.__mro__ == [ContextVar, object]
#   Context.__mro__    == [Context,    object]
#   Token.__mro__      == [Token,      object]
# No prior spec has measured __mro__.__len__() for these classes.
# ---------------------------------------------------------------------------

table contextvars_extra4.class_mro_lengths:
  description: "contextvars class __mro__.__len__() for ContextVar/Context/Token in extra4 namespace — all equal 2"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: clsmrolen4

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [ContextVar, ContextVar.__mro__, [], !ascii "", __len__, [], "ContextVar MRO depth == 2"]
    - [Context,    Context.__mro__,    [], !ascii "", __len__, [], "Context MRO depth == 2"]
    - [Token,      Token.__mro__,      [], !ascii "", __len__, [], "Token MRO depth == 2"]

# ---------------------------------------------------------------------------
# ContextVar method __qualname__ length table — extra4 namespace
#
# contextvars.ContextVar exposes three key methods:
#   ContextVar.get.__qualname__   == 'ContextVar.get'   (14)
#   ContextVar.set.__qualname__   == 'ContextVar.set'   (14)
#   ContextVar.reset.__qualname__ == 'ContextVar.reset' (16)
# get and set share the same qualname length (14); reset is 2 chars longer.
# No prior spec has measured __qualname__.__len__() for ContextVar methods.
# ---------------------------------------------------------------------------

table contextvars_extra4.contextvar_method_qualname_lengths:
  description: "contextvars.ContextVar method __qualname__ lengths for get/set/reset in extra4 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: cvmqualnamelen4

  columns: [id, function, args, expected]
  rows:
    - [get,   ContextVar.get.__qualname__.__len__,   [], 14]
    - [set,   ContextVar.set.__qualname__.__len__,   [], 14]
    - [reset, ContextVar.reset.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# Context method __qualname__ length table — extra4 namespace
#
# contextvars.Context exposes two key methods:
#   Context.run.__qualname__  == 'Context.run'  (11)
#   Context.copy.__qualname__ == 'Context.copy' (12)
# No prior spec has measured __qualname__.__len__() for Context methods.
# ---------------------------------------------------------------------------

table contextvars_extra4.context_method_qualname_lengths:
  description: "contextvars.Context method __qualname__ lengths for run/copy in extra4 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: ctxmqualnamelen4

  columns: [id, function, args, expected]
  rows:
    - [run,  Context.run.__qualname__.__len__,  [], 11]
    - [copy, Context.copy.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# copy_context.__qualname__.__len__() == 12 — extra4 standalone invariant
#
# copy_context is a module-level C builtin. Its __qualname__ equals its
# __name__ ('copy_context'), which is 12 characters long. Prior specs
# checked copy_context.__class__.__name__, __module__, and __name__ itself,
# but not __qualname__.__len__().
# ---------------------------------------------------------------------------

invariant contextvars_extra4.copy_context_qualname_len:
  description: "contextvars.copy_context.__qualname__.__len__() == 12 — 'copy_context' has twelve characters"
  category: method_names
  kind: python_call_eq
  function: copy_context.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# ContextVar.__qualname__.__len__() == 10 — extra4 standalone invariant
#
# contextvars_extra2 confirms ContextVar.__qualname__ == 'ContextVar' (equality).
# contextvars_extra3 confirms ContextVar.__name__.__len__() == 10.
# No prior spec confirms ContextVar.__qualname__.__len__() == 10 as a length
# check (distinct from the __name__.__len__() check in extra3).
# ---------------------------------------------------------------------------

invariant contextvars_extra4.ContextVar_qualname_len:
  description: "contextvars.ContextVar.__qualname__.__len__() == 10 — 'ContextVar' has ten characters"
  category: qualnames
  kind: python_call_eq
  function: ContextVar.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Token.__qualname__.__len__() == 5 — extra4 standalone invariant
#
# contextvars_extra2 confirms Token.__qualname__ == 'Token' (equality).
# No prior spec confirms Token.__qualname__.__len__() == 5 as a length check.
# 'Token' is 5 characters, matching Token.__name__.__len__().
# ---------------------------------------------------------------------------

invariant contextvars_extra4.Token_qualname_len:
  description: "contextvars.Token.__qualname__.__len__() == 5 — 'Token' has five characters"
  category: qualnames
  kind: python_call_eq
  function: Token.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# ContextVar.__bases__[0].__name__.__len__() == 6 — extra4 standalone
#
# contextvars_extra3 confirms ContextVar.__bases__.__len__() == 1 and that
# the sole base is 'object' (from contextvars.zspec.zsdl). No prior spec
# measures the length of that base name string: 'object' is 6 characters.
# ---------------------------------------------------------------------------

invariant contextvars_extra4.ContextVar_base_name_len:
  description: "contextvars.ContextVar.__bases__[0].__name__.__len__() == 6 — 'object' has six characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "ContextVar.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant contextvars_extra4.all_len:
  description: "contextvars.__all__.__len__() == 4 — the module exports 4 public names"
  category: module_structure
  kind: python_call_eq
  function: contextvars.__all__.__len__
  args: []
  expected: 4
