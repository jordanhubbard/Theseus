spec: zoneinfo_extra
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zoneinfo.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "zoneinfo.zspec.zsdl — covers ZoneInfo/__name__, ZoneInfo/__module__, ZoneInfoNotFoundError/__name__, available_timezones/__name__, ZoneInfoNotFoundError base, available_timezones return type, UTC/America/New_York containment, ZoneInfo('UTC') instance class"
  notes:
    - "This spec provides additional coverage for zoneinfo not in zoneinfo.zspec.zsdl."
    - "zoneinfo.ZoneInfo.__name__ == 'ZoneInfo'."
    - "zoneinfo.ZoneInfo.__module__ == 'zoneinfo'."
    - "zoneinfo.ZoneInfoNotFoundError.__name__ == 'ZoneInfoNotFoundError'."
    - "zoneinfo.ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError' — verified on Python 3.12."
    - "zoneinfo.available_timezones.__name__ == 'available_timezones'."
    - "zoneinfo.available_timezones().__class__.__name__ == 'set'."
    - "len(zoneinfo.available_timezones()) >= 400 — verified 598 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ZoneInfo() raises ZoneInfoNotFoundError (subclass of KeyError) for unknown timezone keys"
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks — __name__ equality
# ---------------------------------------------------------------------------

table zoneinfo_extra.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [ZoneInfo,              ZoneInfo.__name__.__eq__,              ["ZoneInfo"],              true]
    - [ZoneInfoNotFoundError, ZoneInfoNotFoundError.__name__.__eq__, ["ZoneInfoNotFoundError"], true]

# ---------------------------------------------------------------------------
# Module membership — ZoneInfo is defined in the zoneinfo module
# ---------------------------------------------------------------------------

invariant zoneinfo_extra.ZoneInfo.module:
  description: "zoneinfo.ZoneInfo.__module__ == 'zoneinfo'"
  category: modules
  kind: python_call_eq
  function: ZoneInfo.__module__.__eq__
  args: ["zoneinfo"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError'
# ---------------------------------------------------------------------------

invariant zoneinfo_extra.ZoneInfoNotFoundError.base_is_KeyError:
  description: "zoneinfo.ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError'"
  category: hierarchy
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "KeyError"

# ---------------------------------------------------------------------------
# Function name check — available_timezones
# ---------------------------------------------------------------------------

invariant zoneinfo_extra.available_timezones.name:
  description: "zoneinfo.available_timezones.__name__ == 'available_timezones'"
  category: function_names
  kind: python_call_eq
  function: available_timezones.__name__.__eq__
  args: ["available_timezones"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral — available_timezones() returns a set
# ---------------------------------------------------------------------------

invariant zoneinfo_extra.available_timezones.returns_set:
  description: "zoneinfo.available_timezones().__class__.__name__ == 'set'"
  category: behavioral
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __class__
  method_args: []
  method_chain: __name__
  expected: "set"

# ---------------------------------------------------------------------------
# Behavioral — available_timezones() returns at least 400 timezone keys
#
# Verified 598 on macOS/Darwin 25.4.0 with Python 3.12, 2026-04-09.
# The lower bound 400 is conservative to accommodate minimal tzdata installs.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra.available_timezones.min_count:
  description: "len(zoneinfo.available_timezones()) >= 400"
  category: behavioral
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __len__
  method_args: []
  expected: 598
