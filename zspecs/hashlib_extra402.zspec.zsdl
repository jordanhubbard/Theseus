spec: hashlib_extra402
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib.blake2b.__name__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.SALT_SIZE == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.PERSON_SIZE == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.MAX_KEY_SIZE == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.MAX_DIGEST_SIZE == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.SALT_SIZE == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.PERSON_SIZE == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.MAX_KEY_SIZE == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.MAX_DIGEST_SIZE == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.blake2b and hashlib.blake2s are C extension types implemented in the _blake2 module. They inherit directly from object. Their class-level constants (SALT_SIZE, PERSON_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE) reflect the BLAKE2 specification: blake2b supports up to 64-byte digests and 64-byte keys with 16-byte salt and personalization; blake2s supports up to 32-byte digests and 32-byte keys with 8-byte salt and personalization."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b and hashlib.blake2s class identity
#
# Wave 402 theme: BLAKE2 class identity and class-level constants.
#
# hashlib.blake2b and hashlib.blake2s are C extension types defined in the
# _blake2 module. Unlike the OpenSSL-backed constructors (md5, sha1, etc.),
# these classes carry their canonical names in __name__ without any prefix.
# Both types have __module__ == '_blake2' and inherit directly from object.
#
# The class-level integer constants encode the BLAKE2 algorithm parameters:
#   blake2b: SALT_SIZE=16, PERSON_SIZE=16, MAX_KEY_SIZE=64, MAX_DIGEST_SIZE=64
#   blake2s: SALT_SIZE=8,  PERSON_SIZE=8,  MAX_KEY_SIZE=32, MAX_DIGEST_SIZE=32
#
# These constants allow callers to query algorithm limits without constructing
# an instance, and are documented in PEP 466 / the hashlib docs.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra402.class_identity:
  description: "hashlib.blake2b and blake2s class identity — __name__, __module__, base class; both are C extension types in _blake2 module inheriting directly from object; __name__ is the bare algorithm name without prefix; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibci402

  columns: [id, function, args, expected]
  rows:
    - [blake2b_name,    blake2b.__name__.__eq__,               ["blake2b"],  true]
    - [blake2b_module,  blake2b.__module__.__eq__,             ["_blake2"],  true]
    - [blake2b_base,    "blake2b.__bases__[0].__name__.__eq__",  ["object"],   true]
    - [blake2s_name,    blake2s.__name__.__eq__,               ["blake2s"],  true]
    - [blake2s_module,  blake2s.__module__.__eq__,             ["_blake2"],  true]
    - [blake2s_base,    "blake2s.__bases__[0].__name__.__eq__",  ["object"],   true]

# ---------------------------------------------------------------------------
# hashlib.blake2b class-level algorithm constants
#
# SALT_SIZE=16, PERSON_SIZE=16, MAX_KEY_SIZE=64, MAX_DIGEST_SIZE=64.
# These encode the BLAKE2b specification limits for salt, personalization,
# key, and digest lengths respectively, all in bytes.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra402.blake2b_constants:
  description: "hashlib.blake2b class-level constants — SALT_SIZE=16, PERSON_SIZE=16, MAX_KEY_SIZE=64, MAX_DIGEST_SIZE=64; encodes BLAKE2b algorithm parameter limits in bytes; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constants
  id_prefix: hashlibbc402

  columns: [id, function, args, expected]
  rows:
    - [salt_size,        blake2b.SALT_SIZE.__eq__,        [16],  true]
    - [person_size,      blake2b.PERSON_SIZE.__eq__,      [16],  true]
    - [max_key_size,     blake2b.MAX_KEY_SIZE.__eq__,     [64],  true]
    - [max_digest_size,  blake2b.MAX_DIGEST_SIZE.__eq__,  [64],  true]

# ---------------------------------------------------------------------------
# hashlib.blake2s class-level algorithm constants
#
# SALT_SIZE=8, PERSON_SIZE=8, MAX_KEY_SIZE=32, MAX_DIGEST_SIZE=32.
# blake2s uses smaller limits than blake2b throughout; all values are exactly
# half of their blake2b counterparts.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra402.blake2s_salt_size:
  description: "hashlib.blake2s.SALT_SIZE.__eq__(8) == True — blake2s salt is limited to 8 bytes, half the blake2b limit of 16; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constants
  kind: python_call_eq
  function: blake2s.SALT_SIZE.__eq__
  args: [8]
  expected: true

invariant hashlib_extra402.blake2s_person_size:
  description: "hashlib.blake2s.PERSON_SIZE.__eq__(8) == True — blake2s personalization string is limited to 8 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constants
  kind: python_call_eq
  function: blake2s.PERSON_SIZE.__eq__
  args: [8]
  expected: true

invariant hashlib_extra402.blake2s_max_key_size:
  description: "hashlib.blake2s.MAX_KEY_SIZE.__eq__(32) == True — blake2s key is limited to 32 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constants
  kind: python_call_eq
  function: blake2s.MAX_KEY_SIZE.__eq__
  args: [32]
  expected: true

invariant hashlib_extra402.blake2s_max_digest_size:
  description: "hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32) == True — blake2s digest is limited to 32 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constants
  kind: python_call_eq
  function: blake2s.MAX_DIGEST_SIZE.__eq__
  args: [32]
  expected: true
