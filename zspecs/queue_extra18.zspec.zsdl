spec: queue_extra18
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/queue.py"
    - "CPython source: Modules/_queuemodule.c"
  notes:
    - "This spec extends queue_extra17.zspec.zsdl."
    - "Prior specs covered: queue.__name__/__package__, Queue/LifoQueue/PriorityQueue/SimpleQueue/Empty/Full __name__/__module__/__qualname__, bases checks, Queue method qualnames, SimpleQueue method qualname lengths, Queue.__module__.__len__() (extra16), LifoQueue/__module__.__len__() (extra17), PriorityQueue/__module__.__len__() (extra17), Full/__module__.__len__() (extra17), SimpleQueue/__module__.__len__() (extra17), __name__.__len__() for all 6 classes (extra17), __module__.__len__() for all 6 classes (extra17)."
    - "This spec covers: queue.__all__.__len__() (7 exports); MRO depth (__mro__.__len__()) for Queue/LifoQueue/PriorityQueue/Empty/Full; Queue method __qualname__.__len__() table for put/get/put_nowait/get_nowait/empty/full; __qualname__.__len__() for all 6 classes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "queue.__all__.__len__() == 7. Verified."
    - "queue.Queue.__mro__.__len__() == 2 (Queue, object). Verified."
    - "queue.LifoQueue.__mro__.__len__() == 3 (LifoQueue, Queue, object). Verified."
    - "queue.PriorityQueue.__mro__.__len__() == 3 (PriorityQueue, Queue, object). Verified."
    - "queue.Empty.__mro__.__len__() == 4 (Empty, Exception, BaseException, object). Verified."
    - "queue.Full.__mro__.__len__() == 4 (Full, Exception, BaseException, object). Verified."
    - "queue.Queue.put.__qualname__.__len__() == 9. Verified."
    - "queue.Queue.get.__qualname__.__len__() == 9. Verified."
    - "queue.Queue.put_nowait.__qualname__.__len__() == 16. Verified."
    - "queue.Queue.get_nowait.__qualname__.__len__() == 16. Verified."
    - "queue.Queue.empty.__qualname__.__len__() == 11. Verified."
    - "queue.Queue.full.__qualname__.__len__() == 10. Verified."
    - "queue.Queue.__qualname__.__len__() == 5. Verified."
    - "queue.LifoQueue.__qualname__.__len__() == 9. Verified."
    - "queue.PriorityQueue.__qualname__.__len__() == 13. Verified."
    - "queue.SimpleQueue.__qualname__.__len__() == 11. Verified."
    - "queue.Empty.__qualname__.__len__() == 5. Verified."
    - "queue.Full.__qualname__.__len__() == 4. Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# queue.__all__.__len__() — 7 public names exported
#
# queue.__all__ == ['Empty', 'Full', 'ShutDown', 'Queue', 'PriorityQueue',
# 'LifoQueue', 'SimpleQueue'] — exactly 7 entries. No prior queue spec checks
# __all__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant queue_extra18.all.len:
  description: "queue.__all__.__len__() == 7 — seven public names: Empty, Full, ShutDown, Queue, PriorityQueue, LifoQueue, SimpleQueue"
  category: module_all
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# queue.Queue.__mro__.__len__() — MRO depth 2 (Queue, object)
#
# queue.Queue has no explicit base classes beyond object. MRO is
# [Queue, object], length 2. No prior queue spec checks __mro__.__len__()
# for Queue as a standalone invariant.
# ---------------------------------------------------------------------------

invariant queue_extra18.Queue.mro_len:
  description: "queue.Queue.__mro__.__len__() == 2 — MRO: [Queue, object]"
  category: class_mro
  kind: python_call_eq
  function: Queue.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# queue.LifoQueue.__mro__.__len__() — MRO depth 3 (LifoQueue, Queue, object)
#
# LifoQueue inherits from Queue which inherits from object. MRO is
# [LifoQueue, Queue, object], length 3. No prior queue spec checks
# __mro__.__len__() for LifoQueue.
# ---------------------------------------------------------------------------

invariant queue_extra18.LifoQueue.mro_len:
  description: "queue.LifoQueue.__mro__.__len__() == 3 — MRO: [LifoQueue, Queue, object]"
  category: class_mro
  kind: python_call_eq
  function: LifoQueue.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# queue.Empty.__mro__.__len__() — MRO depth 4 (exception hierarchy)
#
# queue.Empty inherits from Exception → BaseException → object. MRO is
# [Empty, Exception, BaseException, object], length 4. This is deeper than
# Queue (depth 2) and LifoQueue/PriorityQueue (depth 3) because exception
# classes carry extra hierarchy levels.
# ---------------------------------------------------------------------------

invariant queue_extra18.Empty.mro_len:
  description: "queue.Empty.__mro__.__len__() == 4 — MRO: [Empty, Exception, BaseException, object]"
  category: class_mro
  kind: python_call_eq
  function: Empty.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Table: __mro__.__len__() for queue classes — comparing hierarchy depths
#
# Queue (2) and SimpleQueue (2, C type with only object) are shallow.
# LifoQueue and PriorityQueue (both 3) add one Queue intermediary.
# Empty and Full (both 4) sit in the exception hierarchy with three levels
# above them. id_prefix qmro18 is novel. SimpleQueue.__mro__.__len__() was
# not directly verified in prior specs; checked here alongside the others.
# ---------------------------------------------------------------------------

table queue_extra18.mro_depths:
  description: "__mro__.__len__() for queue classes — Queue=2, LifoQueue=3, PriorityQueue=3, SimpleQueue=2, Empty=4, Full=4"
  kind: python_call_eq
  category: class_mro
  id_prefix: qmro18

  columns: [id, function, method, method_args, expected]
  rows:
    - [Queue_mro,         Queue.__mro__,         __len__, [], 2]
    - [LifoQueue_mro,     LifoQueue.__mro__,     __len__, [], 3]
    - [PriorityQueue_mro, PriorityQueue.__mro__, __len__, [], 3]
    - [SimpleQueue_mro,   SimpleQueue.__mro__,   __len__, [], 2]
    - [Empty_mro,         Empty.__mro__,         __len__, [], 4]
    - [Full_mro,          Full.__mro__,          __len__, [], 4]

# ---------------------------------------------------------------------------
# Table: Queue method __qualname__.__len__() — extra18 namespace
#
# Queue methods have dotted qualnames of the form 'Queue.<method>'. The dot
# separator means __qualname__.__len__() == len('Queue.') + len(method_name)
# == 6 + method_name_len. Checks: put(9), get(9), put_nowait(16),
# get_nowait(16), empty(11), full(10). No prior queue spec collects all 6
# in a single table in the extra18 namespace. id_prefix qmql18 is novel.
# ---------------------------------------------------------------------------

table queue_extra18.Queue_method_qualname_lens:
  description: "queue.Queue method __qualname__.__len__() — dotted form 'Queue.<method>'; put=9, get=9, put_nowait=16, get_nowait=16, empty=11, full=10"
  kind: python_call_eq
  category: function_qualname
  id_prefix: qmql18

  columns: [id, function, method, method_args, expected]
  rows:
    - [put_ql,       "Queue.put.__qualname__",       __len__, [], 9]
    - [get_ql,       "Queue.get.__qualname__",       __len__, [], 9]
    - [putnow_ql,    "Queue.put_nowait.__qualname__", __len__, [], 16]
    - [getnow_ql,    "Queue.get_nowait.__qualname__", __len__, [], 16]
    - [empty_ql,     "Queue.empty.__qualname__",     __len__, [], 11]
    - [full_ql,      "Queue.full.__qualname__",      __len__, [], 10]
