spec: itertools_extra27
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra26.zspec.zsdl."
    - "itertools_extra26 covers: infinite iterator qualnames (count/cycle/repeat); combinatoric qualnames (permutations/combinations/combinations_with_replacement); filtering/windowing qualnames (accumulate/compress/filterfalse/pairwise); count.__bases__[0].__name__."
    - "itertools_extra25 covers: __module__ attributes for chain/islice/starmap/takewhile/dropwhile/zip_longest/product/groupby/cycle/repeat."
    - "itertools_extra24 covers: dropwhile/takewhile/filterfalse/accumulate class qualnames; pairwise qualname."
    - "This spec covers: __bases__[0].__name__ for chain/cycle/count/repeat/zip_longest/starmap/takewhile/dropwhile/filterfalse/islice/groupby — all in the extra27 namespace."
    - "Key finding: all itertools C-level types inherit directly from object (__bases__[0].__name__ == 'object' for all eleven classes)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "spec version >=3.10 required for pairwise."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — infinite iterator base classes
#
# itertools.chain, cycle, count, and repeat are C-level types implementing
# infinite or bounded iterators. All four inherit directly from object, with no
# intermediate abstract base class. chain concatenates iterables; cycle repeats
# an iterable indefinitely; count produces an arithmetic sequence; repeat yields
# a single value N times (or forever). No prior itertools spec records all four
# together in the extra27 namespace.
# ---------------------------------------------------------------------------

table itertools_extra27.infinite_bases:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra27.infinite_bases.chain,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__ == 'object'"]
    - [itertools_extra27.infinite_bases.cycle,
       "cycle.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.cycle.__bases__[0].__name__ == 'object'"]
    - [itertools_extra27.infinite_bases.count,
       "count.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.count.__bases__[0].__name__ == 'object'"]
    - [itertools_extra27.infinite_bases.repeat,
       "repeat.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.repeat.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — terminating iterator base classes
#
# itertools.zip_longest, starmap, takewhile, and dropwhile are C-level types
# that produce terminating iterators (they exhaust when their shortest or
# longest input is exhausted). All four inherit directly from object. No prior
# itertools spec records all four together in the extra27 namespace.
# ---------------------------------------------------------------------------

table itertools_extra27.terminating_bases:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra27.terminating_bases.zip_longest,
       "zip_longest.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__name__ == 'object'"]
    - [itertools_extra27.terminating_bases.starmap,
       "starmap.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__bases__[0].__name__ == 'object'"]
    - [itertools_extra27.terminating_bases.takewhile,
       "takewhile.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.takewhile.__bases__[0].__name__ == 'object'"]
    - [itertools_extra27.terminating_bases.dropwhile,
       "dropwhile.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.dropwhile.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — filtering and slicing iterator base classes
#
# itertools.filterfalse, islice, and groupby are C-level types that filter or
# group elements from an iterable. filterfalse is the inverse of the built-in
# filter; islice produces a slice of an iterator without materializing it;
# groupby groups consecutive elements by a key function. All three inherit
# directly from object. No prior itertools spec records all three together in
# the extra27 namespace.
# ---------------------------------------------------------------------------

table itertools_extra27.filtering_bases:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra27.filtering_bases.filterfalse,
       "filterfalse.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.filterfalse.__bases__[0].__name__ == 'object'"]
    - [itertools_extra27.filtering_bases.islice,
       "islice.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.islice.__bases__[0].__name__ == 'object'"]
    - [itertools_extra27.filtering_bases.groupby,
       "groupby.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.groupby.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# chain.__bases__[0].__name__.__eq__ — standalone inheritance
#
# itertools.chain is a C-level type that chains multiple iterables together,
# yielding elements from each in sequence. It inherits directly from object
# and has a notable classmethod (chain.from_iterable) for lazy flattening.
# extra26 records count.__bases__ in the extra26 namespace; this standalone
# records chain's base in the extra27 namespace.
# No prior itertools spec records this standalone in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra27.chain.base:
  description: "itertools.chain.__bases__[0].__name__ == 'object'"
  category: inheritance
  kind: python_call_eq
  function: "chain.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# groupby.__bases__[0].__name__.__eq__ — standalone inheritance
#
# itertools.groupby is a C-level type that groups consecutive elements of an
# iterable by a key function. It yields (key, group_iterator) pairs. groupby
# inherits directly from object, with no ABC. No prior itertools spec records
# this standalone in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra27.groupby.base:
  description: "itertools.groupby.__bases__[0].__name__ == 'object'"
  category: inheritance
  kind: python_call_eq
  function: "groupby.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# zip_longest.__bases__[0].__name__.__eq__ — standalone inheritance
#
# itertools.zip_longest pads shorter iterables with a fill value so that all
# inputs are exhausted together. It is the counterpart to the built-in zip
# (which stops at the shortest). zip_longest is a C-level type inheriting
# directly from object. No prior itertools spec records this standalone in
# the extra27 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra27.zip_longest.base:
  description: "itertools.zip_longest.__bases__[0].__name__ == 'object'"
  category: inheritance
  kind: python_call_eq
  function: "zip_longest.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
