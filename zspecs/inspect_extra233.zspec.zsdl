spec: inspect_extra233
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.Signature class identity contracts."
    - "inspect.Signature.__name__ == 'Signature' (len=9) — the class name. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' — Signature is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Signature.__qualname__ == 'Signature' — top-level class with unqualified qualname. Verified with Python 3.14.3."
    - "inspect.Signature.__class__.__name__ == 'type' — Signature is a Python class; its metaclass is the built-in type. Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object. Verified with Python 3.14.3."
    - "inspect.Signature.bind.__name__ == 'bind' (len=4) — bind is a method of Signature. Verified with Python 3.14.3."
    - "inspect.Signature.bind.__qualname__ == 'Signature.bind' — bind qualname carries the class prefix. Verified with Python 3.14.3."
    - "inspect.Signature.bind_partial.__name__ == 'bind_partial' (len=12) — bind_partial is a method of Signature. Verified with Python 3.14.3."
    - "inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial' — bind_partial qualname carries the class prefix. Verified with Python 3.14.3."
    - "inspect.Signature.replace.__name__ == 'replace' (len=7) — replace is a method of Signature. Verified with Python 3.14.3."
    - "inspect.Signature.replace.__qualname__ == 'Signature.replace' — replace qualname carries the class prefix. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature class identity contracts
#
# inspect.Signature.__name__ == 'Signature' (len=9)
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__qualname__ == 'Signature'
# inspect.Signature.__class__.__name__ == 'type'
# inspect.Signature.__bases__[0].__name__ == 'object'
#
# Signature is a Python class in Lib/inspect.py that represents the overall
# signature of a function. New to extra233.
# ---------------------------------------------------------------------------

table inspect_extra233.signature_class_identity:
  description: "inspect.Signature class identity contracts: name, module, qualname, metaclass, base; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra233sigclassid

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is the class in inspect that represents a function's overall signature; __name__ is 'Signature' (len=9); new to extra233"]
    - [signature_name_len_9,
       Signature.__name__.__len__,
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — 'Signature' has exactly 9 characters (S-i-g-n-a-t-u-r-e); str.__len__() returns 9; new to extra233"]
    - [signature_module_eq,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in the inspect module (Lib/inspect.py); __module__ is 'inspect' (len=7); new to extra233"]
    - [signature_qualname_eq,
       Signature.__qualname__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — Signature is a top-level class with unqualified qualname 'Signature'; str.__eq__('Signature') returns True; new to extra233"]
    - [signature_class_is_type,
       Signature.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Signature.__class__.__name__.__eq__('type') == True — Signature is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; new to extra233"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature.bind and bind_partial method contracts
#
# inspect.Signature.bind.__name__ == 'bind' (len=4)
# inspect.Signature.bind.__qualname__ == 'Signature.bind'
# inspect.Signature.bind_partial.__name__ == 'bind_partial' (len=12)
# inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial'
# inspect.Signature.__bases__[0].__name__ == 'object'
#
# bind and bind_partial are Python methods on the Signature class.
# New to extra233.
# ---------------------------------------------------------------------------

table inspect_extra233.signature_bind_methods:
  description: "inspect.Signature.bind and bind_partial method name and qualname contracts; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra233sigbindid

  columns: [id, function, args, expected, description]
  rows:
    - [signature_base_is_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; new to extra233"]
    - [bind_name_eq,
       Signature.bind.__name__.__eq__,
       ["bind"],
       true,
       "inspect.Signature.bind.__name__.__eq__('bind') == True — bind is a method of Signature that maps arguments to parameters; __name__ is 'bind' (len=4); new to extra233"]
    - [bind_name_len_4,
       Signature.bind.__name__.__len__,
       [],
       4,
       "inspect.Signature.bind.__name__.__len__() == 4 — 'bind' has exactly 4 characters (b-i-n-d); str.__len__() returns 4; new to extra233"]
    - [bind_qualname_eq,
       Signature.bind.__qualname__.__eq__,
       ["Signature.bind"],
       true,
       "inspect.Signature.bind.__qualname__.__eq__('Signature.bind') == True — bind is a method of the Signature class; its __qualname__ carries the class prefix 'Signature.bind'; new to extra233"]
    - [bind_partial_name_eq,
       Signature.bind_partial.__name__.__eq__,
       ["bind_partial"],
       true,
       "inspect.Signature.bind_partial.__name__.__eq__('bind_partial') == True — bind_partial is a method of Signature that maps partial arguments; __name__ is 'bind_partial' (len=12); new to extra233"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Signature.replace method and bind_partial qualname contracts
#
# inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial'
# inspect.Signature.replace.__name__ == 'replace' (len=7)
# inspect.Signature.replace.__qualname__ == 'Signature.replace'
# inspect.Signature.bind_partial.__name__.__len__() == 12
# inspect.Signature.replace.__name__.__len__() == 7
#
# replace is a method that returns a modified copy of the Signature.
# New to extra233.
# ---------------------------------------------------------------------------

table inspect_extra233.signature_replace_method:
  description: "inspect.Signature.replace method and bind_partial qualname contracts; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra233sigreplaceid

  columns: [id, function, args, expected, description]
  rows:
    - [bind_partial_qualname_eq,
       Signature.bind_partial.__qualname__.__eq__,
       ["Signature.bind_partial"],
       true,
       "inspect.Signature.bind_partial.__qualname__.__eq__('Signature.bind_partial') == True — bind_partial is a method of the Signature class; its __qualname__ carries the class prefix; new to extra233"]
    - [bind_partial_name_len_12,
       Signature.bind_partial.__name__.__len__,
       [],
       12,
       "inspect.Signature.bind_partial.__name__.__len__() == 12 — 'bind_partial' has exactly 12 characters (b-i-n-d-_-p-a-r-t-i-a-l); str.__len__() returns 12; new to extra233"]
    - [replace_name_eq,
       Signature.replace.__name__.__eq__,
       ["replace"],
       true,
       "inspect.Signature.replace.__name__.__eq__('replace') == True — replace is a method of Signature that creates a modified copy; __name__ is 'replace' (len=7); new to extra233"]
    - [replace_name_len_7,
       Signature.replace.__name__.__len__,
       [],
       7,
       "inspect.Signature.replace.__name__.__len__() == 7 — 'replace' has exactly 7 characters (r-e-p-l-a-c-e); str.__len__() returns 7; new to extra233"]
    - [replace_qualname_eq,
       Signature.replace.__qualname__.__eq__,
       ["Signature.replace"],
       true,
       "inspect.Signature.replace.__qualname__.__eq__('Signature.replace') == True — replace is a method of the Signature class; its __qualname__ carries the class prefix 'Signature.replace'; new to extra233"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra233
# ---------------------------------------------------------------------------

invariant inspect_extra233.signature_name_eq:
  description: "inspect.Signature.__name__ == 'Signature' (len=9); new to extra233"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra233.signature_name_len_9:
  description: "inspect.Signature.__name__.__len__() == 9 — 'Signature' has 9 characters; new to extra233"
  kind: python_call_eq
  function: Signature.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra233.signature_module_eq:
  description: "inspect.Signature.__module__ == 'inspect'; new to extra233"
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra233.signature_qualname_eq:
  description: "inspect.Signature.__qualname__ == 'Signature'; new to extra233"
  kind: python_call_eq
  function: Signature.__qualname__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra233.signature_class_is_type:
  description: "inspect.Signature.__class__.__name__ == 'type'; new to extra233"
  kind: python_call_eq
  function: Signature.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra233.signature_base_is_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object'; new to extra233"
  kind: python_call_eq
  function: "Signature.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra233.bind_name_eq:
  description: "inspect.Signature.bind.__name__ == 'bind' (len=4); new to extra233"
  kind: python_call_eq
  function: Signature.bind.__name__.__eq__
  args: ["bind"]
  expected: true

invariant inspect_extra233.bind_qualname_eq:
  description: "inspect.Signature.bind.__qualname__ == 'Signature.bind'; new to extra233"
  kind: python_call_eq
  function: Signature.bind.__qualname__.__eq__
  args: ["Signature.bind"]
  expected: true

invariant inspect_extra233.bind_partial_name_eq:
  description: "inspect.Signature.bind_partial.__name__ == 'bind_partial' (len=12); new to extra233"
  kind: python_call_eq
  function: Signature.bind_partial.__name__.__eq__
  args: ["bind_partial"]
  expected: true

invariant inspect_extra233.bind_partial_qualname_eq:
  description: "inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial'; new to extra233"
  kind: python_call_eq
  function: Signature.bind_partial.__qualname__.__eq__
  args: ["Signature.bind_partial"]
  expected: true

invariant inspect_extra233.replace_name_eq:
  description: "inspect.Signature.replace.__name__ == 'replace' (len=7); new to extra233"
  kind: python_call_eq
  function: Signature.replace.__name__.__eq__
  args: ["replace"]
  expected: true

invariant inspect_extra233.replace_qualname_eq:
  description: "inspect.Signature.replace.__qualname__ == 'Signature.replace'; new to extra233"
  kind: python_call_eq
  function: Signature.replace.__qualname__.__eq__
  args: ["Signature.replace"]
  expected: true
