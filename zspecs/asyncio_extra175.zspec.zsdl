  columns: [id, function, args, expected, description]
  rows:
    - [aelp_name_eq,   asyncio.AbstractEventLoopPolicy.__name__.__eq__,    ["AbstractEventLoopPolicy"],  true,  "asyncio.AbstractEventLoopPolicy.__name__ == 'AbstractEventLoopPolicy' (len=23: 'AbstractEventLoop'=17+'Policy'=6=23); verified with Python 3.14.3"]
    - [aelp_name_len,  asyncio.AbstractEventLoopPolicy.__name__.__len__,   [],                           23,    "asyncio.AbstractEventLoopPolicy.__name__.__len__() == 23 (6 longer than AbstractEventLoop=17); verified with Python 3.14.3"]
    - [aelp_mod_eq,    asyncio.AbstractEventLoopPolicy.__module__.__eq__,  ["asyncio.events"],           true,  "asyncio.AbstractEventLoopPolicy.__module__ == 'asyncio.events' (same module as AbstractEventLoop); verified with Python 3.14.3"]
    - [aelp_mro_len,   "asyncio.AbstractEventLoopPolicy.__mro__.__len__",  [],                           2,     "asyncio.AbstractEventLoopPolicy.__mro__.__len__() == 2 (MRO: AbstractEventLoopPolicy > object); verified with Python 3.14.3"]

