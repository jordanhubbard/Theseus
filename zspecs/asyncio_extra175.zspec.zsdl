table asyncio_extra175.handle_identity:
  description: "asyncio.Handle class identity checks in asyncioel175handle namespace — asyncio.Handle.__name__.__eq__('Handle')==True ('Handle'=6: 'H'+'a'+'n'+'d'+'l'+'e'=6; asyncio.Handle is the class representing a scheduled callback — an opaque handle returned by loop.call_soon(), loop.call_later(), and loop.call_at(); it provides the cancel() method to cancel a pending callback; Handle is a concrete class unlike AbstractEventLoop which is abstract); asyncio.Handle.__name__.__len__()==6; asyncio.Handle.__module__.__eq__('asyncio.events')==True (defined in Lib/asyncio/events.py — same module as AbstractEventLoop and AbstractEventLoopPolicy; all three are defined together in events.py); asyncio.Handle.__mro__.__len__()==2 (MRO: Handle > object; 2 entries; Handle is a direct subclass of object with no intermediate bases — same MRO depth as AbstractEventLoop and AbstractEventLoopPolicy); NAME LENGTH COMPARISON: 'Handle'=6 << 'AbstractEventLoop'=17 << 'AbstractEventLoopPolicy'=23; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioel175handle

  columns: [id, function, args, expected, description]
  rows:
    - [handle_name_eq,   asyncio.Handle.__name__.__eq__,    ["Handle"],           true,  "asyncio.Handle.__name__ == 'Handle' (len=6: 'H'+'a'+'n'+'d'+'l'+'e'=6); verified with Python 3.14.3"]
    - [handle_name_len,  asyncio.Handle.__name__.__len__,   [],                   6,     "asyncio.Handle.__name__.__len__() == 6 ('Handle'=6; shortest of the 3 class names in this spec); verified with Python 3.14.3"]
    - [handle_mod_eq,    asyncio.Handle.__module__.__eq__,  ["asyncio.events"],   true,  "asyncio.Handle.__module__ == 'asyncio.events' (same module as AbstractEventLoop and AbstractEventLoopPolicy); verified with Python 3.14.3"]
    - [handle_mro_len,   "asyncio.Handle.__mro__.__len__",  [],                   2,     "asyncio.Handle.__mro__.__len__() == 2 (MRO: Handle > object; same depth as AbstractEventLoop and AbstractEventLoopPolicy); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra175
# ---------------------------------------------------------------------------

invariant asyncio_extra175.abstract_event_loop_name_eq:
  description: "asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop') returns True — asyncio.AbstractEventLoop.__name__=='AbstractEventLoop' (len=17: 'Abstract'=8+'Event'=5+'Loop'=4=17); AbstractEventLoop is the abstract base class defining the full asyncio event loop interface; it declares all the methods an event loop must implement: run_forever(), run_until_complete(), stop(), close(), call_soon(), call_later(), call_at(), create_future(), create_task(), and many more I/O and signal methods; concrete implementations include asyncio.SelectorEventLoop (Unix) and asyncio.ProactorEventLoop (Windows); AbstractEventLoop itself inherits directly from object — its MRO is [AbstractEventLoop, object] (len=2); asyncio.AbstractEventLoop.__module__=='asyncio.events' (defined in Lib/asyncio/events.py; len=14); NEW in extra175: first standalone AbstractEventLoop.__name__ invariant in asyncioel175ael namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__name__.__eq__
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra175.abstract_event_loop_module_eq:
  description: "asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events') returns True — asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); asyncio.events (Lib/asyncio/events.py) is the submodule that defines the core asyncio class hierarchy: AbstractEventLoop, AbstractEventLoopPolicy, Handle, TimerHandle (subclass of Handle), AbstractServer, BaseDefaultEventLoopPolicy, DefaultEventLoopPolicy, and the get_event_loop() / set_event_loop() / get_event_loop_policy() / set_event_loop_policy() functions; asyncio.Handle.__module__=='asyncio.events' and asyncio.AbstractEventLoopPolicy.__module__=='asyncio.events' — all three classes are co-defined in events.py; '__module__'='asyncio.events' (len=14) vs the top-level asyncio namespace (len=7); NEW in extra175: first standalone AbstractEventLoop.__module__ invariant in asyncioel175ael namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra175.abstract_event_loop_policy_name_len:
  description: "asyncio.AbstractEventLoopPolicy.__name__.__len__() == 23 — asyncio.AbstractEventLoopPolicy.__name__ is 'AbstractEventLoopPolicy' (23 characters: 'Abstract'=8+'Event'=5+'Loop'=4+'Policy'=6=23); this is the longest class name in this spec: Handle=6, AbstractEventLoop=17, AbstractEventLoopPolicy=23; 'Policy'=6 appended to 'AbstractEventLoop'=17 yields 23; AbstractEventLoopPolicy defines the interface for event loop policies: get_event_loop(), set_event_loop(), new_event_loop(), and on Unix: get_child_watcher(), set_child_watcher(); asyncio.DefaultEventLoopPolicy is the concrete default implementation; asyncio.AbstractEventLoopPolicy.__mro__.__len__()==2 (same MRO depth as AbstractEventLoop — both are direct subclasses of object); NEW in extra175: first standalone AbstractEventLoopPolicy.__name__.__len__ invariant in asyncioel175aelp namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoopPolicy.__name__.__len__
  args: []
  expected: 23

invariant asyncio_extra175.handle_name_eq:
  description: "asyncio.Handle.__name__.__eq__('Handle') returns True — asyncio.Handle.__name__=='Handle' (len=6: 'H'+'a'+'n'+'d'+'l'+'e'=6); asyncio.Handle is the concrete class for scheduled callback handles — objects returned by loop.call_soon(), loop.call_later(), and loop.call_at(); the primary purpose of a Handle is to allow cancellation via handle.cancel(); asyncio.Handle.__cancelled__ tracks whether cancel() was called; asyncio.Handle is NOT abstract — it is a concrete class; its subclass asyncio.TimerHandle (also in asyncio.events) adds scheduled time and comparison operators; Handle.__module__=='asyncio.events' (same as AbstractEventLoop); NAME LENGTH: 'Handle'=6 is the shortest class name in this spec (AbstractEventLoop=17, AbstractEventLoopPolicy=23); NEW in extra175: first standalone Handle.__name__ invariant in asyncioel175handle namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Handle.__name__.__eq__
  args: ["Handle"]
  expected: true

invariant asyncio_extra175.handle_mro_len:
  description: "asyncio.Handle.__mro__.__len__() == 2 — asyncio.Handle.__mro__ is (asyncio.Handle, object); length 2 means Handle's MRO has exactly 2 entries: Handle itself and object; Handle is a direct subclass of object with no intermediate abstract bases; this is identical to AbstractEventLoop.__mro__.__len__()==2 and AbstractEventLoopPolicy.__mro__.__len__()==2 — all three classes in this spec share the same MRO depth of 2 (direct subclasses of object); MRO depth 2 = [ClassName, object] is the minimal possible MRO for any class; asyncio.TimerHandle (not covered in this spec) would have MRO depth 3: [TimerHandle, Handle, object]; NEW in extra175: first standalone Handle.__mro__.__len__ invariant in asyncioel175handle namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Handle.__mro__.__len__"
  args: []
  expected: 2

invariant asyncio_extra175.abstract_event_loop_mro_len:
  description: "asyncio.AbstractEventLoop.__mro__.__len__() == 2 — asyncio.AbstractEventLoop.__mro__ is (asyncio.AbstractEventLoop, object); 2 entries: AbstractEventLoop itself and object; AbstractEventLoop is a direct subclass of object despite defining dozens of abstract methods; it uses no mixin classes or intermediate bases in its MRO; this is a design decision in asyncio: the interface is defined entirely via the single AbstractEventLoop class with no composition via abstract mixin classes (unlike some other frameworks); all three classes in this spec share MRO depth 2: AbstractEventLoop.__mro__.__len__()==2, AbstractEventLoopPolicy.__mro__.__len__()==2, Handle.__mro__.__len__()==2; NEW in extra175: first standalone AbstractEventLoop.__mro__.__len__ invariant in asyncioel175ael namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.AbstractEventLoop.__mro__.__len__"
  args: []
  expected: 2

