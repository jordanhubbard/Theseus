spec: asyncio_extra175
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec covers: asyncio.AbstractEventLoop class identity — asyncio.AbstractEventLoop.__name__=='AbstractEventLoop' (len=17: 'Abstract'=8+'EventLoop'=9=17); asyncio.AbstractEventLoop.__module__=='asyncio.events' (defined in asyncio.events submodule; len=14); asyncio.AbstractEventLoop.__mro__.__len__()==2 (AbstractEventLoop > object; only 2 entries in MRO); asyncio.AbstractEventLoopPolicy.__name__=='AbstractEventLoopPolicy' (len=23: 'Abstract'=8+'EventLoop'=9+'Policy'=6=23; 6 chars longer than AbstractEventLoop); asyncio.AbstractEventLoopPolicy.__mro__.__len__()==2 (same as AbstractEventLoop; direct subclass of object); asyncio.Handle.__name__=='Handle' (len=6); asyncio.Handle.__module__=='asyncio.events' (same module as AbstractEventLoop); asyncio.Handle.__mro__.__len__()==2 (Handle > object). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoop.__name__.__len__() == 17. 'AbstractEventLoop' is 17 characters: 'Abstract'=8 + 'Event'=5 + 'Loop'=4 = 17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoopPolicy.__name__.__len__() == 23. 'AbstractEventLoopPolicy' is 23 characters: 'AbstractEventLoop'=17 + 'Policy'=6 = 23. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Handle.__name__.__len__() == 6. 'Handle' is 6 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoop.__module__ == 'asyncio.events' (len=14: 'asyncio'=7 + '.'=1 + 'events'=6 = 14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.AbstractEventLoop class identity — extra175
#
# asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop')  == True (len=17)
# asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events')   == True (len=14)
# asyncio.AbstractEventLoop.__mro__.__len__()                     == 2
# ---------------------------------------------------------------------------

table asyncio_extra175.abstract_event_loop_identity:
  description: "asyncio.AbstractEventLoop class identity checks in asyncioel175ael namespace — asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop')==True ('AbstractEventLoop'=17: 'Abstract'=8+'Event'=5+'Loop'=4=17; AbstractEventLoop is the base class defining the interface for all asyncio event loops; it lives in asyncio.events and is exposed at the top-level asyncio namespace); asyncio.AbstractEventLoop.__name__.__len__()==17; asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events')==True ('asyncio.events'=14: 'asyncio'=7+'.'=1+'events'=6=14; defined in Lib/asyncio/events.py); asyncio.AbstractEventLoop.__mro__.__len__()==2 (MRO: AbstractEventLoop > object; only 2 entries since AbstractEventLoop is a direct subclass of object with no intermediate bases); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioel175ael

  columns: [id, function, args, expected, description]
  rows:
    - [ael_name_eq,    asyncio.AbstractEventLoop.__name__.__eq__,    ["AbstractEventLoop"],  true,  "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop' (len=17: 'Abstract'=8+'Event'=5+'Loop'=4=17); verified with Python 3.14.3"]
    - [ael_name_len,   asyncio.AbstractEventLoop.__name__.__len__,   [],                     17,    "asyncio.AbstractEventLoop.__name__.__len__() == 17 ('AbstractEventLoop'=17); verified with Python 3.14.3"]
    - [ael_mod_eq,     asyncio.AbstractEventLoop.__module__.__eq__,  ["asyncio.events"],     true,  "asyncio.AbstractEventLoop.__module__ == 'asyncio.events' (len=14; defined in Lib/asyncio/events.py); verified with Python 3.14.3"]
    - [ael_mod_len,    asyncio.AbstractEventLoop.__module__.__len__, [],                     14,    "asyncio.AbstractEventLoop.__module__.__len__() == 14 ('asyncio.events'=14: 'asyncio'=7+'.'=1+'events'=6=14); verified with Python 3.14.3"]
    - [ael_mro_len,    "asyncio.AbstractEventLoop.__mro__.__len__",  [],                     2,     "asyncio.AbstractEventLoop.__mro__.__len__() == 2 (MRO: AbstractEventLoop > object; 2 entries); verified with Python 3.14.3"]

