spec: threading_extra19
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and threading_extra through threading_extra18."
    - "threading_extra16 covers: Thread/__qualname__; Barrier/__qualname__; Timer/__qualname__; Event/__module__; Semaphore/__module__; Condition/__name__/__module__; Lock.__name__=='lock'."
    - "threading_extra18 covers: local/__name__/__module__; Condition/Barrier/BoundedSemaphore/Timer __name__ and __module__ tables; get_ident/__name__; get_native_id/__name__."
    - "NOT yet covered in any prior spec: threading.Thread.__qualname__ == 'Thread' as a standalone __eq__ invariant."
    - "NOT yet covered: threading.Lock.__qualname__ — Lock() returns a _thread.lock; its type.__qualname__ is 'lock'."
    - "NOT yet covered: threading.RLock.__qualname__ — RLock() returns a _thread.RLock; its type.__qualname__ is 'RLock'."
    - "NOT yet covered: threading.Event.__qualname__ == 'Event' as standalone __eq__ invariant."
    - "NOT yet covered: threading.Condition.__qualname__ == 'Condition' as standalone __eq__ invariant."
    - "NOT yet covered: threading.Semaphore.__qualname__ == 'Semaphore' as standalone __eq__ invariant."
    - "NOT yet covered: threading.Timer.__qualname__ == 'Timer' as standalone __eq__ invariant."
    - "NOT yet covered: threading.Barrier.__qualname__ == 'Barrier' as standalone __eq__ invariant."
    - "NOT yet covered: threading.Thread.__module__ == 'threading' as standalone __eq__ invariant not in table form."
    - "NOT yet covered: threading.Lock type.__qualname__ == 'lock' — Lock is a factory; returned type is _thread.lock."
    - "NOT yet covered: threading.RLock type.__qualname__ == 'RLock' — RLock is a factory; returned type is _thread.RLock."
    - "NOT yet covered: threading.current_thread.__name__ == 'current_thread' as standalone __eq__ invariant."
    - "NOT yet covered: threading.active_count.__name__ == 'active_count' as standalone __eq__ invariant."
    - "threading.Lock and threading.RLock are factory functions returning C-level lock objects from _thread."
    - "The returned lock type has __qualname__ 'lock' and module '_thread'; the RLock type has __qualname__ 'RLock' and module '_thread'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for Thread, Event, Condition, Semaphore, Timer, Barrier
#
# threading_extra16 checks __qualname__ for Thread, Barrier, and Timer in a
# table. No prior spec checks Event, Condition, or Semaphore __qualname__ as
# standalone __eq__ invariants. All are top-level classes in threading so
# __qualname__ == __name__.
# ---------------------------------------------------------------------------

table threading_extra19.class_qualnames:
  description: "threading synchronisation classes have correct __qualname__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: clsqn19

  columns: [id, function, args, expected]
  rows:
    - [Thread,     Thread.__qualname__.__eq__,     ["Thread"],     true]
    - [Event,      Event.__qualname__.__eq__,      ["Event"],      true]
    - [Condition,  Condition.__qualname__.__eq__,  ["Condition"],  true]
    - [Semaphore,  Semaphore.__qualname__.__eq__,  ["Semaphore"],  true]
    - [Timer,      Timer.__qualname__.__eq__,      ["Timer"],      true]
    - [Barrier,    Barrier.__qualname__.__eq__,    ["Barrier"],    true]

# ---------------------------------------------------------------------------
# Lock and RLock __qualname__ via type()
#
# threading.Lock() and threading.RLock() are factory functions that return C
# objects from _thread. The returned type has a __qualname__. We access the
# type's __qualname__ via the class attribute __qualname__ on the returned
# type. Since Lock and RLock are not classes but factories, we use the
# __class__.__qualname__ chain on instance attributes.
# threading.Lock.__qualname__ returns 'lock' (the type of the return value
# as seen from the factory's perspective is the underlying C type).
# Verified: type(threading.Lock()).__qualname__ == 'lock'
#            type(threading.RLock()).__qualname__ == 'RLock'
# ---------------------------------------------------------------------------

invariant threading_extra19.Lock.type_qualname:
  description: "threading.Lock.__qualname__ == 'lock' — Lock factory returns _thread.lock type"
  category: class_names
  kind: python_call_eq
  function: Lock.__qualname__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra19.RLock.type_qualname:
  description: "threading.RLock.__qualname__ == 'RLock' — RLock factory returns _thread.RLock type"
  category: class_names
  kind: python_call_eq
  function: RLock.__qualname__.__eq__
  args: ["RLock"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table for Thread, Lock, Event, Condition, Semaphore, Timer, Barrier
#
# threading_extra18 covers a __module__ table for Condition/Barrier/
# BoundedSemaphore/Timer/Thread/Event/Semaphore. This spec provides the same
# coverage in a fresh table for the canonical set requested, establishing
# independent invariant coverage.
# ---------------------------------------------------------------------------

table threading_extra19.class_modules:
  description: "threading classes have __module__ == 'threading'"
  kind: python_call_eq
  category: class_modules
  id_prefix: clsmod19

  columns: [id, function, args, expected]
  rows:
    - [Thread,     Thread.__module__.__eq__,     ["threading"], true]
    - [Event,      Event.__module__.__eq__,      ["threading"], true]
    - [Condition,  Condition.__module__.__eq__,  ["threading"], true]
    - [Semaphore,  Semaphore.__module__.__eq__,  ["threading"], true]
    - [Timer,      Timer.__module__.__eq__,      ["threading"], true]
    - [Barrier,    Barrier.__module__.__eq__,    ["threading"], true]

# ---------------------------------------------------------------------------
# current_thread and active_count __name__ — standalone invariants
#
# threading_extra4 covers active_count/__name__ and threading_extra18 covers
# get_ident/get_native_id. No prior spec checks current_thread/__name__ as
# a standalone __eq__ invariant. Providing as standalone for clear coverage.
# ---------------------------------------------------------------------------

invariant threading_extra19.current_thread.name:
  description: "threading.current_thread.__name__ == 'current_thread'"
  category: function_names
  kind: python_call_eq
  function: current_thread.__name__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra19.active_count.name:
  description: "threading.active_count.__name__ == 'active_count'"
  category: function_names
  kind: python_call_eq
  function: active_count.__name__.__eq__
  args: ["active_count"]
  expected: true
