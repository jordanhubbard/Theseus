spec: struct_extra280
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct.calcsize format string sizes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Using '>' (big-endian/network) prefix for deterministic, platform-independent sizes"
    - "Standard sizes: b=1, B=1, h=2, H=2, i=4, I=4, l=4, L=4, q=8, Q=8, f=4, d=8, ?=1"
    - "Multi-field sizes are the sum of individual field sizes with no alignment padding under standard mode"
    - "All calcsize values confirmed on CPython 3.14 macOS"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra280.calcsize_standard_formats:
  description: "struct.calcsize returns standard byte sizes for single-field format strings with '>' prefix"
  kind: python_call_eq
  category: identity
  id_prefix: scs

  columns: [id, function, args, expected, description]
  rows:
    - [scs001, struct.calcsize, [">b"], 1,  "signed byte is 1 byte"]
    - [scs002, struct.calcsize, [">B"], 1,  "unsigned byte is 1 byte"]
    - [scs003, struct.calcsize, [">h"], 2,  "signed short is 2 bytes"]
    - [scs004, struct.calcsize, [">H"], 2,  "unsigned short is 2 bytes"]
    - [scs005, struct.calcsize, [">i"], 4,  "signed int is 4 bytes"]
    - [scs006, struct.calcsize, [">I"], 4,  "unsigned int is 4 bytes"]
    - [scs007, struct.calcsize, [">l"], 4,  "signed long is 4 bytes"]
    - [scs008, struct.calcsize, [">q"], 8,  "signed long long is 8 bytes"]
    - [scs009, struct.calcsize, [">Q"], 8,  "unsigned long long is 8 bytes"]
    - [scs010, struct.calcsize, [">f"], 4,  "float is 4 bytes"]
    - [scs011, struct.calcsize, [">d"], 8,  "double is 8 bytes"]
    - [scs012, struct.calcsize, [">?"], 1,  "bool is 1 byte"]

table struct_extra280.calcsize_multi_field_formats:
  description: "struct.calcsize returns sum of field sizes for multi-field format strings"
  kind: python_call_eq
  category: identity
  id_prefix: scm

  columns: [id, function, args, expected, description]
  rows:
    - [scm001, struct.calcsize, [">bi"],  5,  "byte(1) + int(4) = 5 bytes"]
    - [scm002, struct.calcsize, [">hd"],  10, "short(2) + double(8) = 10 bytes"]
    - [scm003, struct.calcsize, [">bhi"], 7,  "byte(1) + short(2) + int(4) = 7 bytes"]
    - [scm004, struct.calcsize, [">qi"],  12, "long long(8) + int(4) = 12 bytes"]

invariant struct_extra280.calcsize_bool_native:
  description: "bool (?) is 1 byte in native mode"
  category: identity
  kind: python_call_eq
  function: struct.calcsize
  args: ["?"]
  expected: 1

invariant struct_extra280.calcsize_IHB_combined:
  description: "struct.calcsize for '>IHB' (unsigned int + unsigned short + unsigned byte) = 7 bytes"
  category: identity
  kind: python_call_eq
  function: struct.calcsize
  args: [">IHB"]
  expected: 7
