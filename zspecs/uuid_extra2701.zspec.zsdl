spec: uuid_extra2701
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 627: checks uuid.UUID and uuid.SafeUUID __dict__ for __lshift__, __rshift__, __invert__ presence. uuid.UUID is a plain Python class; uuid.SafeUUID is an IntEnum subclass. All return False — neither defines __lshift__, __rshift__, nor __invert__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table uuid_extra2701.UUID_dict_presence:
  description: "uuid.UUID __dict__ does not contain __lshift__, __rshift__, or __invert__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2701ud
  columns: [id, function, args, expected]
  rows:
    - ["uu2701ud001", uuid.UUID.__dict__.__contains__, ["__lshift__"], false]
    - ["uu2701ud002", uuid.UUID.__dict__.__contains__, ["__rshift__"], false]
    - ["uu2701ud003", uuid.UUID.__dict__.__contains__, ["__invert__"], false]

