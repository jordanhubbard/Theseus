    - [str_qualname_str,     "socket.__str__.__qualname__.__eq__",    ["object.__str__"],   true, "socket.socket.__str__.__qualname__ == 'object.__str__' (14 chars = 'object.'=7 + '__str__'=7; wrapper_descriptor; inherited from object; NOT socket-defined)"]
