# ---------------------------------------------------------------------------
# socket.socket.__repr__.__qualname__.__eq__('socket.__repr__') — standalone
#
# socket.socket.__repr__.__qualname__ is 'socket.__repr__' (15 chars = 'socket.'=7 + '__repr__'=8).
# socket.socket defines its own __repr__ in Lib/socket.py as a Python function. The repr
# for a socket object typically shows its type, fileno, and address/port information.
# Because socket.socket defines its own __repr__, the qualname has the 'socket.' class prefix
# (not 'object.'). socket.socket.__repr__ is a 'function' object (Python-defined). '__repr__'
# (8 chars) = '__'=2 + 'repr'=4 + '__'=2. 'socket.__repr__' (15 chars) ties 'socket.__init__'
# (15 chars; extra159) and 'socket.__exit__' (15 chars). No prior socket spec anchors
# socket.__repr__.__qualname__ as a standalone under sockdun162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra162.sock_repr_qualname_eq:
  description: "socket.socket.__repr__.__qualname__.__eq__('socket.__repr__') == True — 15 chars = 'socket.'=7 + '__repr__'=8; Python 'function' (socket.socket defines own __repr__ in Lib/socket.py; shows socket type/fileno/address); 'socket.' prefix confirms it is socket-defined (not inherited from object); '__repr__'=8 chars; ties 'socket.__init__'=15 (extra159) and 'socket.__exit__'=15; length ordering: __str__(14) < __repr__==__exit__(15) < __enter__(16); no prior socket spec anchors this as a standalone; first standalone under sockdun162"
  category: identity
  kind: python_call_eq
  function: socket.__repr__.__qualname__.__eq__
  args: ["socket.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__str__.__qualname__.__eq__('object.__str__') — standalone
#
# socket.socket.__str__.__qualname__ is 'object.__str__' (14 chars = 'object.'=7 + '__str__'=7).
# socket.socket does NOT define its own __str__. When Python looks up __str__ on a socket
# instance, it finds 'object.__str__' via the MRO. The qualname 'object.__str__' with the
# 'object.' prefix confirms that __str__ is inherited from the built-in object class.
# __str__ is a 'wrapper_descriptor' (the type for C-level special method wrappers inherited
# from object). This contrasts with __repr__ which has 'socket.' prefix (socket defines it).
# 'object.__str__' (14 chars) is 1 char shorter than 'socket.__repr__' (15 chars).
# No prior socket spec anchors socket.__str__.__qualname__ as a standalone under sockdun162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra162.sock_str_qualname_eq:
  description: "socket.socket.__str__.__qualname__.__eq__('object.__str__') == True — 14 chars = 'object.'=7 + '__str__'=7; 'object.' prefix confirms __str__ is inherited from object (NOT defined in socket.socket); wrapper_descriptor type (C-level special method from object); contrasts with __repr__ which has 'socket.' prefix (socket-defined); 'object.__str__' (14 chars) is the only inherited-from-object dunder in this spec; shorter than all socket-defined dunders (__repr__=15, __exit__=15, __enter__=16); no prior socket spec anchors this as a standalone; first standalone under sockdun162"
  category: identity
  kind: python_call_eq
  function: socket.__str__.__qualname__.__eq__
  args: ["object.__str__"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__enter__.__qualname__.__eq__('socket.__enter__') — standalone
#
# socket.socket.__enter__.__qualname__ is 'socket.__enter__' (16 chars = 'socket.'=7 + '__enter__'=9).
# socket.socket defines __enter__ as a Python function to support the context manager protocol.
# 'with socket.socket() as s:' calls s.__enter__() which returns s (self). '__enter__'
# (9 chars) = '__'=2 + 'enter'=5 + '__'=2. 'enter' (5 chars) is the longest plain method
# name suffix among the four dunders in this spec ('repr'=4, 'str'=3, 'enter'=5, 'exit'=4).
# 'socket.__enter__' (16 chars) is the longest qualname in this spec. All three socket-defined
# dunders (__repr__, __enter__, __exit__) are Python 'function' type, while __str__ is
# 'wrapper_descriptor' (inherited). No prior socket spec anchors socket.__enter__.__qualname__
# as a standalone under sockdun162. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra162.sock_enter_qualname_eq:
  description: "socket.socket.__enter__.__qualname__.__eq__('socket.__enter__') == True — 16 chars = 'socket.'=7 + '__enter__'=9; Python 'function'; context manager entry protocol; __enter__ returns self; 'with socket.socket() as s' calls s.__enter__(); '__enter__'=9 chars = '__'=2 + 'enter'=5 + '__'=2; 'enter'=5 chars (longest plain suffix among these four dunders); 'socket.__enter__' (16 chars) is the longest qualname in this spec; length ordering: __str__(14) < __repr__==__exit__(15) < __enter__(16); no prior socket spec anchors this as a standalone; first standalone under sockdun162"
  category: identity
  kind: python_call_eq
  function: socket.__enter__.__qualname__.__eq__
  args: ["socket.__enter__"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__exit__.__qualname__.__eq__('socket.__exit__') — standalone
#
# socket.socket.__exit__.__qualname__ is 'socket.__exit__' (15 chars = 'socket.'=7 + '__exit__'=8).
# socket.socket defines __exit__ as a Python function for the context manager protocol.
# __exit__(exc_type, exc_val, exc_tb) is called when exiting a 'with' block; it closes the
# socket. '__exit__' (8 chars) = '__'=2 + 'exit'=4 + '__'=2. 'socket.__exit__' (15 chars)
# ties 'socket.__repr__' (15 chars) and 'socket.__init__' (15 chars; extra159). Length
# ordering: __str__(14) < __repr__==__exit__(15) < __enter__(16). __exit__ is a Python
# 'function' (same type as __repr__ and __enter__, unlike __str__ which is 'wrapper_descriptor').
# No prior socket spec anchors socket.__exit__.__qualname__ as a standalone under sockdun162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra162.sock_exit_qualname_eq:
  description: "socket.socket.__exit__.__qualname__.__eq__('socket.__exit__') == True — 15 chars = 'socket.'=7 + '__exit__'=8; Python 'function'; context manager cleanup; closes socket when exiting 'with' block; __exit__(exc_type, exc_val, exc_tb); '__exit__'=8 chars = '__'=2 + 'exit'=4 + '__'=2; 'exit'=4 chars; ties 'socket.__repr__'=15 and 'socket.__init__'=15 (extra159); length ordering: __str__(14) < __repr__==__exit__(15) < __enter__(16); __exit__ is 'function' (socket-defined) unlike __str__ which is 'wrapper_descriptor' (object-inherited); no prior socket spec anchors this as a standalone; first standalone under sockdun162"
  category: identity
  kind: python_call_eq
  function: socket.__exit__.__qualname__.__eq__
  args: ["socket.__exit__"]
  expected: true

