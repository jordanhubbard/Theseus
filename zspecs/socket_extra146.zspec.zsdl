spec: socket_extra146
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra145.zspec.zsdl — covers socket.AF_UNSPEC/__class__.__name__.__eq__('AddressFamily') / AF_UNIX/__class__.__name__.__eq__('AddressFamily') / AF_UNSPEC.name.__eq__('AF_UNSPEC') and __len__()==9 / AF_UNIX.name.__eq__('AF_UNIX') and __len__()==7 / IPPROTO_TCP/__class__.__name__.__eq__('int') / __spec__.name.__eq__('socket') / __doc__.__len__()==2021 (table + invariants)."
    - "socket_extra144.zspec.zsdl — covers socket.socket.__module__/__qualname__/__eq__('socket') / socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') / __mro__.__len__()==3 / AF_INET/AF_INET6/SOCK_STREAM/SOCK_DGRAM __class__.__name__ equality (table + invariants)."
    - "socket_extra143.zspec.zsdl — covers socket.socket method __qualname__ string equality for connect/bind/listen/accept/recv / accept/__class__.__name__=='function' vs connect/bind/listen/recv/__class__.__name__=='method_descriptor' (table + invariants)."
    - "socket_extra142.zspec.zsdl — covers socket.AF_INET/AF_INET6 enum member .name values and lengths / SOCK_STREAM/SOCK_DGRAM .name values and lengths / AddressFamily/SocketKind class __name__ values (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra145."
    - "Wave 315 theme: socket.__all__ membership checks — __all__.__contains__('socket')==True / __contains__('AF_INET')==True / __contains__('SOCK_STREAM')==True / __contains__('gethostname')==True / __contains__('error')==True / __contains__('AF_INET6')==True / socket.socket.__init__/__qualname__.__eq__('socket.__init__') (len 15) / socket.socket.__init__/__class__.__name__.__eq__('function')."
    - "socket.__all__.__class__.__name__ == 'list' (238 entries). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.__all__) == 238. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'socket' in socket.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'AF_INET' in socket.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'SOCK_STREAM' in socket.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'gethostname' in socket.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'error' in socket.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'AF_INET6' in socket.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__qualname__ == 'socket.__init__' (len 15). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__class__.__name__ == 'function' (Python-level in Lib/socket.py). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.__all__ is a list with 238 entries — by far the largest __all__ in the stdlib module series: struct(8) < hashlib(19) << socket(238). The 238 entries include constants (AF_INET, AF_INET6, SOCK_STREAM, etc.), module-level functions (gethostname, gethostbyname, getaddrinfo, etc.), the socket class, and exception classes (error, timeout, etc.)."
    - "Note: socket.socket.__init__.__qualname__ is 'socket.__init__' (15 chars = 7-char 'socket.' prefix + 8-char '__init__'). The 'socket.' prefix in the qualname refers to the socket.socket class, not the socket module. The qualname 'socket.__init__' (15 chars) ties in length with struct.Struct.__init__ qualname (also 'Struct.__init__', 15 chars). socket.socket.__init__ is a Python-level function (class 'function') defined in Lib/socket.py, in contrast to most socket.socket methods which are method_descriptors from the C extension."
    - "Note: socket.__all__ has 238 entries because the socket module re-exports many constants from the OS: all AF_* address family constants, all SOCK_* socket type constants, all IPPROTO_* protocol constants, all SO_* socket option constants, and many others. The exact count may vary slightly across platforms depending on which OS-level socket constants are available."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.__all__.__class__.__name__.__eq__('list')
# socket.__all__.__len__()==238
# socket.__all__.__contains__('socket')
# socket.__all__.__contains__('AF_INET')
#
# Wave 315 theme: socket.__all__ is a list with 238 entries.
#
# socket.__all__ is a list — the largest __all__ in the stdlib module series:
# struct(8) < hashlib(19) << socket(238). It contains 'socket' (the class) and
# 'AF_INET' (the most commonly used address family) among its 238 entries.
# extra95 anchors socket.__all__ class name and length at a high level; no prior
# socket spec anchors __all__.__contains__ checks or length as a table under
# sockall146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra146.all_class_and_membership:
  description: "socket.__all__/__class__.__name__.__eq__('list')==True / __all__.__len__()==238 / __all__.__contains__('socket')==True / __all__.__contains__('AF_INET')==True — __all__ is a list with 238 entries (largest __all__ in the stdlib series; struct=8 < hashlib=19 << socket=238); 'socket' names the socket class; 'AF_INET' is the most commonly used address family; extra95 anchors class name and length; first sockall146 anchor for __contains__ checks and length equality"
  kind: python_call_eq
  category: identity
  id_prefix: sockall146

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_list,        __all__.__class__.__name__.__eq__, ["list"],    true, "socket.__all__.__class__.__name__ == 'list' (not a tuple; same as struct.__all__; unlike hashlib's tuple)"]
    - [all_len_238,           __all__.__len__,                   [],          238,  "socket.__all__.__len__() is 238 (largest __all__ in stdlib series; includes constants, classes, functions)"]
    - [all_contains_socket,   __all__.__contains__,              ["socket"],  true, "socket.__all__.__contains__('socket') == True (the socket.socket class exported at module level)"]
    - [all_contains_AF_INET,  __all__.__contains__,              ["AF_INET"], true, "socket.__all__.__contains__('AF_INET') == True (most commonly used address family constant)"]

# ---------------------------------------------------------------------------
# socket.__all__.__contains__('SOCK_STREAM')
# socket.__all__.__contains__('gethostname')
# socket.__all__.__contains__('error')
# socket.__all__.__contains__('AF_INET6')
#
# Wave 315 theme: membership of key names in socket.__all__.
#
# SOCK_STREAM (TCP socket type), gethostname (module-level function), error
# (the base socket exception), and AF_INET6 (IPv6 address family) are all in __all__.
# extra95 anchors AddressFamily/SocketKind enum member values; no prior socket spec
# anchors these __contains__ checks as a table under sockall146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra146.all_contains_key_names:
  description: "socket.__all__.__contains__('SOCK_STREAM')==True / __contains__('gethostname')==True / __contains__('error')==True / __contains__('AF_INET6')==True — SOCK_STREAM is the TCP stream socket type; gethostname is a core module-level function; error is the base socket exception class; AF_INET6 is the IPv6 address family; all four are present in the 238-entry list; first sockall146 anchor for these membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: sockall146

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_SOCK_STREAM,  __all__.__contains__, ["SOCK_STREAM"],  true, "socket.__all__.__contains__('SOCK_STREAM') == True (TCP stream socket type; SocketKind IntEnum member)"]
    - [all_contains_gethostname,  __all__.__contains__, ["gethostname"],  true, "socket.__all__.__contains__('gethostname') == True (11-char name; returns the host name of the machine)"]
    - [all_contains_error,        __all__.__contains__, ["error"],        true, "socket.__all__.__contains__('error') == True (base exception for socket errors; alias for OSError)"]
    - [all_contains_AF_INET6,     __all__.__contains__, ["AF_INET6"],     true, "socket.__all__.__contains__('AF_INET6') == True (IPv6 address family; 7-char name)"]

# ---------------------------------------------------------------------------
# socket.socket.__init__.__qualname__.__eq__('socket.__init__')
# socket.socket.__init__.__qualname__.__len__()==15
# socket.socket.__init__.__class__.__name__.__eq__('function')
#
# Wave 315 theme: socket.socket.__init__ is a Python-level function.
#
# socket.socket.__init__ has qualname 'socket.__init__' (15 chars) and is a
# Python-level function (class 'function'), defined in Lib/socket.py. Most
# socket.socket methods are method_descriptors from the C extension; __init__ is
# unusual in being a Python-level function. No prior socket spec anchors
# socket.socket.__init__ qualname equality string or class name as a table under
# sockall146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra146.socket_init_identity:
  description: "socket.socket.__init__/__qualname__.__eq__('socket.__init__')==True / __qualname__.__len__()==15 / __class__.__name__.__eq__('function')==True — qualname 'socket.__init__' (15 chars = 7-char 'socket.' prefix + 8-char '__init__'); ties in length with struct.Struct.__init__ qualname (also 15); Python-level function in Lib/socket.py (contrasts with most socket methods which are C-level method_descriptors); first sockall146 anchor for socket.socket.__init__ qualname and class"
  kind: python_call_eq
  category: identity
  id_prefix: sockall146

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_eq,      socket.__init__.__qualname__.__eq__,       ["socket.__init__"], true, "socket.socket.__init__.__qualname__ == 'socket.__init__' (15 chars = 7-char prefix + 8-char '__init__')"]
    - [init_qualname_len,     socket.__init__.__qualname__.__len__,      [],                  15,   "socket.socket.__init__.__qualname__.__len__() is 15 (ties with struct.Struct.__init__ qualname length)"]
    - [init_class_function,   socket.__init__.__class__.__name__.__eq__, ["function"],        true, "socket.socket.__init__.__class__.__name__ == 'function' (Python-level; most socket methods are method_descriptor)"]

# ---------------------------------------------------------------------------
# socket.__all__.__class__.__name__.__eq__('list') — standalone
#
# socket.__all__.__class__.__name__ is 'list'. Among the stdlib modules covered
# by this spec series: hashlib.__all__ is a tuple (19 entries), struct.__all__ is a
# list (8 entries), socket.__all__ is a list (238 entries). Both struct and socket
# use lists. The socket list is 29.75x larger than the struct list (238 vs 8),
# reflecting the number of platform-level constants the socket module re-exports.
# extra95 anchors __all__ class name at a high level; no prior socket spec anchors
# this as a standalone under sockall146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra146.all_class_list:
  description: "socket.__all__.__class__.__name__.__eq__('list') == True — 'list' (4 chars); socket and struct both use list for __all__; hashlib uses tuple; socket.__all__ (238) is 29.75x larger than struct.__all__ (8); extra95 anchors at high level; no prior socket spec anchors this as a standalone; first standalone under sockall146"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__all__.__len__()==238 — standalone
#
# socket.__all__.__len__() is 238. This is by far the largest __all__ among the
# stdlib modules in this spec series: struct(8) < hashlib(19) << socket(238).
# The 238 entries reflect the socket module's role as a thin wrapper over the OS
# socket API, re-exporting hundreds of platform constants (AF_*, SOCK_*, IPPROTO_*,
# SO_*, etc.) as well as module-level functions and classes. extra95 anchors __all__
# length at a high level; no prior socket spec anchors this as a standalone under
# sockall146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra146.all_len_238:
  description: "socket.__all__.__len__() == 238 — 238 entries (largest __all__ in the stdlib series: struct=8 < hashlib=19 << socket=238); includes AF_*/SOCK_*/IPPROTO_*/SO_* constants + module-level functions + socket class + exception classes; extra95 anchors at high level; no prior socket spec anchors this as a standalone; first standalone under sockall146"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 238

# ---------------------------------------------------------------------------
# socket.__all__.__contains__('socket') — standalone
#
# socket.__all__.__contains__('socket') is True. 'socket' in socket.__all__ refers
# to the socket.socket class (the main socket object), not the module itself. The
# name 'socket' is 6 chars — the same as the module name and the class qualname.
# extra144 anchors socket.socket.__qualname__.__eq__('socket'); no prior socket spec
# anchors __all__.__contains__('socket') as a standalone under sockall146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra146.all_contains_socket:
  description: "socket.__all__.__contains__('socket') == True — refers to the socket.socket class (6 chars); same name as the module, the class qualname, and __spec__.name (all 'socket', 6 chars); extra144 anchors socket.socket.__qualname__; no prior socket spec anchors this as a standalone; first standalone under sockall146"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__all__.__contains__('AF_INET') — standalone
#
# socket.__all__.__contains__('AF_INET') is True. AF_INET is the address family
# for IPv4 — the most commonly used address family for internet sockets. Its 7-char
# name 'AF_INET' consists of the 3-char 'AF_' prefix plus the 4-char 'INET' suffix.
# extra144 anchors AF_INET.__class__.__name__.__eq__('AddressFamily') and value;
# no prior socket spec anchors __all__.__contains__('AF_INET') as a standalone
# under sockall146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra146.all_contains_AF_INET:
  description: "socket.__all__.__contains__('AF_INET') == True — 'AF_INET' (7 chars = 3-char 'AF_' + 4-char 'INET'); IPv4 address family; most commonly used address family for internet sockets; extra144 anchors AF_INET class name and value; no prior socket spec anchors this as a standalone; first standalone under sockall146"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["AF_INET"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__init__.__qualname__.__eq__('socket.__init__') — standalone
#
# socket.socket.__init__.__qualname__ is 'socket.__init__' (15 chars). The 'socket.'
# prefix (7 chars) in the qualname refers to the socket.socket class (not the socket
# module), followed by '__init__' (8 chars). This 15-char qualname ties in length
# with struct.Struct.__init__.__qualname__ ('Struct.__init__', also 15 chars),
# because both use a 7-char class prefix plus the 8-char '__init__'. extra143 anchors
# socket.socket method qualnames (connect/bind/listen/accept/recv); no prior socket
# spec anchors socket.socket.__init__ qualname as a standalone under sockall146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra146.socket_init_qualname_eq:
  description: "socket.socket.__init__.__qualname__.__eq__('socket.__init__') == True — 'socket.__init__' (15 chars = 7-char 'socket.' class prefix + 8-char '__init__'); ties in length with struct.Struct.__init__ qualname (also 15); Python-level function; extra143 anchors other socket.socket method qualnames; no prior socket spec anchors this as a standalone; first standalone under sockall146"
  category: qualname_identity
  kind: python_call_eq
  function: socket.__init__.__qualname__.__eq__
  args: ["socket.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__init__.__class__.__name__.__eq__('function') — standalone
#
# socket.socket.__init__.__class__.__name__ is 'function'. socket.socket.__init__
# is defined as a Python function in Lib/socket.py, making it one of the few
# Python-level methods on the socket.socket class. Most socket.socket methods
# (connect, bind, listen, recv, send, etc.) are method_descriptor objects from the
# C extension in Modules/socketmodule.c. extra143 anchors accept/__class__.__name__
# =='function' and connect/bind/listen/recv/__class__.__name__=='method_descriptor';
# no prior socket spec anchors __init__.__class__.__name__=='function' as a standalone
# under sockall146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra146.socket_init_class_function:
  description: "socket.socket.__init__.__class__.__name__.__eq__('function') == True — Python-level function in Lib/socket.py; most socket.socket methods are C-level method_descriptor from socketmodule.c; __init__ (with accept/makefile/close, extra97) is among the Python-level socket.socket methods; extra143 anchors accept as 'function'; no prior socket spec anchors __init__ class name as a standalone; first standalone under sockall146"
  category: identity
  kind: python_call_eq
  function: socket.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

