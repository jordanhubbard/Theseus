spec: uuid_extra119
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra118.zspec.zsdl — covers UUID.__int__/__gt__/__le__/__ge__ __qualname__ equality and __len__() / UUID.__int__/__gt__/__le__/__ge__ __code__.co_argcount (table + invariants)."
    - "uuid_extra117.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5/getnode __code__.co_qualname and co_nlocals / uuid1/__code__.co_varnames[0]=='node' / uuid3/__code__.co_varnames[0]=='namespace' (table + invariants)."
    - "uuid_extra116.zspec.zsdl — covers UUID time-related property fget co_varnames[0]=='self' / fget qualname lengths for time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/time (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__ __qualname__ equality and __len__() / UUID.__str__/__repr__/__eq__/__hash__ __class__.__name__=='function' (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / UUID.hex/bytes/urn/fields/variant/version fget.__qualname__.__len__() (table + invariants)."
    - "uuid_extra92.zspec.zsdl — covers UUID property fget.__code__.co_name equality and co_argcount==1 for all UUID properties (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier uuid specs."
    - "Wave 297 theme: UUID property fget.__code__.co_consts lengths — hex/bytes/bytes_le/fields/version/urn/variant/time property getter co_consts tuple lengths."
    - "uuid.UUID.hex.fget.__code__.co_consts.__len__() == 1. co_consts is (None,). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__code__.co_consts.__len__() == 1. co_consts is (16,). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__code__.co_consts.__len__() == 4. co_consts is (4, None, slice(8, None, None), -1). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__code__.co_consts.__len__() == 1. co_consts is (None,). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__code__.co_consts.__len__() == 2. co_consts is (76, None). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__code__.co_consts.__len__() == 1. co_consts is ('urn:uuid:',). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__code__.co_consts.__len__() == 4. co_consts is (32768, 9223372036854775808, 4611686018427387904, 2305843009213693952). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__code__.co_consts.__len__() == 2. co_consts is (6, 4095). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra92 anchors fget.__code__.co_argcount (1 for all properties) and co_name; extra116 anchors fget.__code__.co_varnames[0]=='self'. This spec first anchors fget.__code__.co_consts.__len__() — the number of compile-time constants in each property getter. No prior uuid spec anchors co_consts lengths."
    - "Note: hex/bytes/fields/urn all have co_consts.__len__()==1 (single constant used). bytes_le and variant both have co_consts.__len__()==4 (more complex computations). version and time both have co_consts.__len__()==2."
    - "Note: variant has the richest constant pool — four large integer bitmasks (32768, 9223372036854775808, etc.) used for RFC 4122 variant bit-field comparisons. bytes_le has 4 constants for little-endian byte reordering (slice, step=-1)."
    - "Note: bytes_le.__code__.co_consts contains slice(8, None, None) and -1 for reversing byte segments; version.__code__.co_consts contains 76 (0x4C, the version bit mask) and None."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_consts.__len__()==1
# uuid.UUID.bytes.fget.__code__.co_consts.__len__()==1
# uuid.UUID.bytes_le.fget.__code__.co_consts.__len__()==4
# uuid.UUID.fields.fget.__code__.co_consts.__len__()==1
#
# Wave 297 theme: UUID property fget co_consts lengths (first group).
#
# hex, bytes, and fields fget functions all have co_consts.__len__()==1 —
# the simplest constant pool size. hex has (None,), bytes has (16,) — the
# 16-byte UUID size, fields has (None,). bytes_le has co_consts.__len__()==4
# for its little-endian byte reordering logic (4, None, slice(8, None, None), -1).
# extra92 anchors co_argcount==1 and co_name for all UUID properties; no prior
# uuid spec anchors co_consts.__len__() for any UUID property under uuidconsts119.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra119.UUID_fget_co_consts_simple:
  description: "UUID.hex.fget/__code__/co_consts/__len__()==1 / UUID.bytes.fget/__code__/co_consts/__len__()==1 / UUID.bytes_le.fget/__code__/co_consts/__len__()==4 / UUID.fields.fget/__code__/co_consts/__len__()==1 — hex/bytes/fields fget have a single constant; bytes_le has 4 (slice/step for little-endian reordering); extra92 anchors co_argcount/co_name; first uuidconsts119 anchor for fget co_consts lengths"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidconsts119

  columns: [id, function, args, expected, description]
  rows:
    - [hex_co_consts_len,     "UUID.hex.fget.__code__.co_consts.__len__",     [],  1,  "UUID.hex.fget.__code__.co_consts.__len__() is 1; co_consts is (None,) — simple property requiring no arithmetic constants"]
    - [bytes_co_consts_len,   "UUID.bytes.fget.__code__.co_consts.__len__",   [],  1,  "UUID.bytes.fget.__code__.co_consts.__len__() is 1; co_consts is (16,) — the 16-byte UUID size constant"]
    - [bytes_le_co_consts_len,"UUID.bytes_le.fget.__code__.co_consts.__len__",[], 4,  "UUID.bytes_le.fget.__code__.co_consts.__len__() is 4; has (4, None, slice(8, None, None), -1) for little-endian byte reordering"]
    - [fields_co_consts_len,  "UUID.fields.fget.__code__.co_consts.__len__",  [],  1,  "UUID.fields.fget.__code__.co_consts.__len__() is 1; co_consts is (None,) — simple tuple-returning property"]

# ---------------------------------------------------------------------------
# uuid.UUID.version.fget.__code__.co_consts.__len__()==2
# uuid.UUID.urn.fget.__code__.co_consts.__len__()==1
# uuid.UUID.variant.fget.__code__.co_consts.__len__()==4
# uuid.UUID.time.fget.__code__.co_consts.__len__()==2
#
# Wave 297 theme: UUID property fget co_consts lengths (second group).
#
# version.__code__.co_consts.__len__()==2 — uses (76, None) where 76 is 0x4C,
# the version-field bitmask. urn.__code__.co_consts.__len__()==1 — its single
# constant is the 'urn:uuid:' prefix string. variant.__code__.co_consts.__len__()==4
# — the richest constant pool, with four bitmasks for RFC 4122 variant detection.
# time.__code__.co_consts.__len__()==2 — uses (6, 4095) for time bit-field assembly.
# No prior uuid spec anchors these co_consts lengths under uuidconsts119.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra119.UUID_fget_co_consts_complex:
  description: "UUID.version.fget/__code__/co_consts/__len__()==2 / UUID.urn.fget/__code__/co_consts/__len__()==1 / UUID.variant.fget/__code__/co_consts/__len__()==4 / UUID.time.fget/__code__/co_consts/__len__()==2 — version uses 2 constants (0x4C bitmask and None); urn uses 1 (the 'urn:uuid:' prefix); variant uses 4 (RFC 4122 bitmasks); time uses 2 (bit-field shift constants); extra92 anchors co_argcount/co_name; first uuidconsts119 anchor for these fget co_consts lengths"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidconsts119

  columns: [id, function, args, expected, description]
  rows:
    - [version_co_consts_len, "UUID.version.fget.__code__.co_consts.__len__", [],  2,  "UUID.version.fget.__code__.co_consts.__len__() is 2; uses (76, None) where 76 is the version bitmask 0x4C"]
    - [urn_co_consts_len,     "UUID.urn.fget.__code__.co_consts.__len__",     [],  1,  "UUID.urn.fget.__code__.co_consts.__len__() is 1; single constant is the 'urn:uuid:' prefix string"]
    - [variant_co_consts_len, "UUID.variant.fget.__code__.co_consts.__len__", [],  4,  "UUID.variant.fget.__code__.co_consts.__len__() is 4; richest pool — four RFC 4122 variant bitmasks"]
    - [time_co_consts_len,    "UUID.time.fget.__code__.co_consts.__len__",    [],  2,  "UUID.time.fget.__code__.co_consts.__len__() is 2; uses (6, 4095) for time_hi/time_lo bit-field assembly"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_consts.__len__()==1 (cross-check)
# uuid.UUID.variant.fget.__code__.co_consts.__len__()==4 (cross-check)
# uuid.UUID.bytes_le.fget.__code__.co_consts.__len__()==4 (cross-check)
# uuid.UUID.version.fget.__code__.co_consts.__len__()==2 (cross-check)
# uuid.UUID.time.fget.__code__.co_consts.__len__()==2 (cross-check)
#
# Wave 297 theme: co_consts length grouping cross-check.
#
# Group by co_consts length: len=1 includes hex, bytes, fields, urn;
# len=2 includes version, time; len=4 includes bytes_le, variant.
# variant and bytes_le share length 4 despite very different constants
# (bitmasks vs slice/step). version and time share length 2. This cross-check
# table groups the pattern by length equality.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra119.UUID_fget_co_consts_grouping:
  description: "UUID.hex.fget/__code__/co_consts/__len__()==1 / UUID.variant.fget/__code__/co_consts/__len__()==4 / UUID.bytes_le.fget/__code__/co_consts/__len__()==4 / UUID.version.fget/__code__/co_consts/__len__()==2 / UUID.time.fget/__code__/co_consts/__len__()==2 — cross-check grouping: variant and bytes_le share len=4; version and time share len=2; hex/bytes/fields/urn share len=1; first uuidconsts119 cross-check grouping"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidconsts119

  columns: [id, function, args, expected, description]
  rows:
    - [hex_len1_xcheck,     "UUID.hex.fget.__code__.co_consts.__len__",     [],  1,  "UUID.hex fget co_consts len is 1 (cross-check: same as bytes/fields/urn)"]
    - [variant_len4_xcheck, "UUID.variant.fget.__code__.co_consts.__len__", [],  4,  "UUID.variant fget co_consts len is 4 (cross-check: same as bytes_le despite different constants)"]
    - [bytes_le_len4_xcheck,"UUID.bytes_le.fget.__code__.co_consts.__len__",[], 4,  "UUID.bytes_le fget co_consts len is 4 (cross-check: same as variant)"]
    - [version_len2_xcheck, "UUID.version.fget.__code__.co_consts.__len__", [],  2,  "UUID.version fget co_consts len is 2 (cross-check: same as time)"]
    - [time_len2_xcheck,    "UUID.time.fget.__code__.co_consts.__len__",    [],  2,  "UUID.time fget co_consts len is 2 (cross-check: same as version)"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_consts.__len__()==1 — standalone
#
# uuid.UUID.hex.fget.__code__.co_consts.__len__() is 1. The hex property getter
# returns self.int.to_bytes(16).hex() or equivalent, using only None as a
# compile-time constant. extra92 anchors hex.fget.__code__.co_argcount==1 and
# co_name=='hex'; no prior uuid spec anchors hex.fget.__code__.co_consts.__len__()
# as a standalone under uuidconsts119. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra119.UUID_hex_co_consts_len_1:
  description: "uuid.UUID.hex.fget.__code__.co_consts.__len__() == 1 — hex property getter has co_consts=(None,); one compile-time constant; extra92 anchors co_argcount==1 and co_name; first standalone for hex.fget.co_consts.__len__() under uuidconsts119"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.hex.fget.__code__.co_consts.__len__"
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__code__.co_consts.__len__()==4 — standalone
#
# uuid.UUID.variant.fget.__code__.co_consts.__len__() is 4. The variant property
# getter uses four bitmask constants (32768, 9223372036854775808, 4611686018427387904,
# 2305843009213693952) to detect RFC 4122 variant encoding from the UUID's
# clock_seq_hi_variant byte. This is the most complex UUID property constant pool.
# extra92 anchors variant.fget.__code__.co_argcount==1 and co_name; no prior uuid
# spec anchors variant.fget.__code__.co_consts.__len__() as a standalone under
# uuidconsts119. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra119.UUID_variant_co_consts_len_4:
  description: "uuid.UUID.variant.fget.__code__.co_consts.__len__() == 4 — variant property has 4 constants (RFC 4122 bitmasks: 32768, 9223372036854775808, 4611686018427387904, 2305843009213693952); most complex UUID property constant pool; extra92 anchors co_argcount/co_name; first standalone for variant.fget.co_consts.__len__() under uuidconsts119"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.variant.fget.__code__.co_consts.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid.UUID.urn.fget.__code__.co_consts.__len__()==1 — standalone
#
# uuid.UUID.urn.fget.__code__.co_consts.__len__() is 1. The urn property getter
# returns 'urn:uuid:' + str(self). Its single compile-time constant is the
# 'urn:uuid:' prefix string. Like hex/bytes/fields, urn uses exactly one constant.
# extra92 anchors urn.fget.__code__.co_argcount==1 and co_name=='urn'; no prior
# uuid spec anchors urn.fget.__code__.co_consts.__len__() as a standalone under
# uuidconsts119. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra119.UUID_urn_co_consts_len_1:
  description: "uuid.UUID.urn.fget.__code__.co_consts.__len__() == 1 — urn property has 1 constant (the 'urn:uuid:' prefix string); same count as hex/bytes/fields; extra92 anchors co_argcount/co_name; first standalone for urn.fget.co_consts.__len__() under uuidconsts119"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.urn.fget.__code__.co_consts.__len__"
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# uuid.UUID.bytes_le.fget.__code__.co_consts.__len__()==4 — standalone
#
# uuid.UUID.bytes_le.fget.__code__.co_consts.__len__() is 4. The bytes_le property
# getter reorders UUID bytes into little-endian format (Microsoft-compatible). Its
# 4 constants are: 4, None, slice(8, None, None), -1. The slice and -1 step are
# used to reverse byte segments. bytes_le shares co_consts length 4 with variant,
# but for entirely different purposes (byte reordering vs bitmask comparison).
# extra92 anchors bytes_le.fget.__code__.co_argcount==1 and co_name; no prior uuid
# spec anchors bytes_le.fget.__code__.co_consts.__len__() as standalone under
# uuidconsts119. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra119.UUID_bytes_le_co_consts_len_4:
  description: "uuid.UUID.bytes_le.fget.__code__.co_consts.__len__() == 4 — bytes_le has 4 constants (4, None, slice(8, None, None), -1) for little-endian byte reordering; shares len 4 with variant (different purpose); extra92 anchors co_argcount/co_name; first standalone for bytes_le.fget.co_consts.__len__() under uuidconsts119"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.bytes_le.fget.__code__.co_consts.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid.UUID.version.fget.__code__.co_consts.__len__()==2 — standalone
#
# uuid.UUID.version.fget.__code__.co_consts.__len__() is 2. The version property
# getter reads the version number from the UUID's time_hi_version field using
# the bitmask 76 (0x4C) and None. version and time both use exactly 2 constants
# in their getter implementations. extra92 anchors version.fget.__code__.co_argcount==1
# and co_name=='version'; no prior uuid spec anchors version.fget.__code__.co_consts.__len__()
# as a standalone under uuidconsts119. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra119.UUID_version_co_consts_len_2:
  description: "uuid.UUID.version.fget.__code__.co_consts.__len__() == 2 — version has 2 constants (76 bitmask and None); version and time share co_consts length 2; extra92 anchors co_argcount/co_name; first standalone for version.fget.co_consts.__len__() under uuidconsts119"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.version.fget.__code__.co_consts.__len__"
  args: []
  expected: 2
