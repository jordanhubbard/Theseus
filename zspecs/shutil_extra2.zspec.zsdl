spec: shutil_extra2
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "Covers copy2, copyfileobj, which, disk_usage, make_archive, unpack_archive, and get_archive_formats __name__ checks."
    - "disk_usage returns a named tuple with _fields ('total', 'used', 'free') — verified as standalone invariants here."
    - "disk_usage result fields total, used, free are each integers (type name 'int')."
    - "which.__module__ == 'shutil' — the function is defined in shutil, not os or os.path."
    - "make_archive and unpack_archive __module__ == 'shutil'."
    - "These invariants complement shutil.zspec.zsdl and shutil_extra.zspec.zsdl without duplicating existing checks."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — copy2, copyfileobj, which, disk_usage,
#                             make_archive, unpack_archive, get_archive_formats
# ---------------------------------------------------------------------------

invariant shutil_extra2.function_names.copy2:
  description: "shutil.copy2.__name__ == 'copy2'"
  category: function_names
  kind: python_call_eq
  function: copy2.__name__.__eq__
  args: ["copy2"]
  expected: true

invariant shutil_extra2.function_names.copyfileobj:
  description: "shutil.copyfileobj.__name__ == 'copyfileobj'"
  category: function_names
  kind: python_call_eq
  function: copyfileobj.__name__.__eq__
  args: ["copyfileobj"]
  expected: true

invariant shutil_extra2.function_names.which:
  description: "shutil.which.__name__ == 'which'"
  category: function_names
  kind: python_call_eq
  function: which.__name__.__eq__
  args: ["which"]
  expected: true

invariant shutil_extra2.function_names.disk_usage:
  description: "shutil.disk_usage.__name__ == 'disk_usage'"
  category: function_names
  kind: python_call_eq
  function: disk_usage.__name__.__eq__
  args: ["disk_usage"]
  expected: true

invariant shutil_extra2.function_names.make_archive:
  description: "shutil.make_archive.__name__ == 'make_archive'"
  category: function_names
  kind: python_call_eq
  function: make_archive.__name__.__eq__
  args: ["make_archive"]
  expected: true

invariant shutil_extra2.function_names.unpack_archive:
  description: "shutil.unpack_archive.__name__ == 'unpack_archive'"
  category: function_names
  kind: python_call_eq
  function: unpack_archive.__name__.__eq__
  args: ["unpack_archive"]
  expected: true

invariant shutil_extra2.function_names.get_archive_formats:
  description: "shutil.get_archive_formats.__name__ == 'get_archive_formats'"
  category: function_names
  kind: python_call_eq
  function: get_archive_formats.__name__.__eq__
  args: ["get_archive_formats"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ checks — all defined in shutil
# ---------------------------------------------------------------------------

invariant shutil_extra2.function_modules.which:
  description: "shutil.which.__module__ == 'shutil'"
  category: function_modules
  kind: python_call_eq
  function: which.__module__.__eq__
  args: ["shutil"]
  expected: true

invariant shutil_extra2.function_modules.make_archive:
  description: "shutil.make_archive.__module__ == 'shutil'"
  category: function_modules
  kind: python_call_eq
  function: make_archive.__module__.__eq__
  args: ["shutil"]
  expected: true

invariant shutil_extra2.function_modules.unpack_archive:
  description: "shutil.unpack_archive.__module__ == 'shutil'"
  category: function_modules
  kind: python_call_eq
  function: unpack_archive.__module__.__eq__
  args: ["shutil"]
  expected: true

# ---------------------------------------------------------------------------
# disk_usage result — named tuple with total/used/free fields
# (shutil.zspec.zsdl already checks _fields via method:; these standalone
# invariants check each field type independently)
# ---------------------------------------------------------------------------

invariant shutil_extra2.disk_usage.total_is_int:
  description: "shutil.disk_usage('/').total.__class__.__name__ == 'int'"
  category: disk_usage
  kind: python_call_eq
  function: disk_usage
  args: ["/"]
  method: total.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant shutil_extra2.disk_usage.used_is_int:
  description: "shutil.disk_usage('/').used.__class__.__name__ == 'int'"
  category: disk_usage
  kind: python_call_eq
  function: disk_usage
  args: ["/"]
  method: used.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant shutil_extra2.disk_usage.free_is_int:
  description: "shutil.disk_usage('/').free.__class__.__name__ == 'int'"
  category: disk_usage
  kind: python_call_eq
  function: disk_usage
  args: ["/"]
  method: free.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true
