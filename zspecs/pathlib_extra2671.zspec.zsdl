spec: pathlib_extra2671
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2656.zspec.zsdl — covers __contains__/__add__/__mul__ dict-presence"
  notes:
    - "Wave 625 (pathlib_extra2671) theme: __sub__, __floordiv__, and __mod__ dict-presence checks."
    - "None of the pathlib classes define __sub__, __floordiv__, or __mod__ in their own __dict__."
    - "__sub__ is the subtraction operator; pathlib path objects do not implement arithmetic subtraction."
    - "__floordiv__ is the floor-division operator; pathlib path objects do not implement division semantics."
    - "__mod__ is the modulo operator; pathlib path objects do not implement modulo semantics."
    - "pathlib uses __truediv__ (the / operator) for path joining — none of __sub__, __floordiv__, or __mod__ are used."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __sub__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2671.no_sub_in_pathlib_classes:
  description: "__sub__ is absent from all pathlib class __dict__s — pathlib path objects do not implement arithmetic subtraction"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2671

  columns: [id, function, args, expected]
  rows:
    - ["pp2671001", "pathlib.PurePath.__dict__.__contains__",        ["__sub__"], false]
    - ["pp2671002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__sub__"], false]
    - ["pp2671003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__sub__"], false]
    - ["pp2671004", "pathlib.Path.__dict__.__contains__",            ["__sub__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2671.no_floordiv_in_pathlib_classes:
  description: "__floordiv__ is absent from all pathlib class __dict__s — pathlib uses __truediv__ for path joining, not __floordiv__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2671

  columns: [id, function, args, expected]
  rows:
    - ["pp2671005", "pathlib.PurePath.__dict__.__contains__",        ["__floordiv__"], false]
    - ["pp2671006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__floordiv__"], false]
    - ["pp2671007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__floordiv__"], false]
    - ["pp2671008", "pathlib.Path.__dict__.__contains__",            ["__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2671.no_mod_in_pathlib_classes:
  description: "__mod__ is absent from all pathlib class __dict__s — pathlib path classes do not implement the modulo protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2671

  columns: [id, function, args, expected]
  rows:
    - ["pp2671009", "pathlib.PurePath.__dict__.__contains__",        ["__mod__"], false]
    - ["pp2671010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__mod__"], false]
    - ["pp2671011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__mod__"], false]
    - ["pp2671012", "pathlib.Path.__dict__.__contains__",            ["__mod__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes have path-manipulation methods but not arithmetic hooks
# Confirms that path objects use __truediv__ for joining and have no __sub__/__floordiv__/__mod__ semantics
# ---------------------------------------------------------------------------

table pathlib_extra2671.pathlib_has_path_methods_not_arithmetic_hooks:
  description: "pathlib.PurePath defines __str__/__truediv__/__fspath__ but NOT __sub__/__floordiv__/__mod__; pathlib.Path defines stat/exists/open but NOT __sub__/__floordiv__/__mod__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2671

  columns: [id, function, args, expected]
  rows:
    - ["pp2671013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],      true]
    - ["pp2671014", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - ["pp2671015", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],   true]
    - ["pp2671016", "pathlib.PurePath.__dict__.__contains__", ["__sub__"],      false]
    - ["pp2671017", "pathlib.PurePath.__dict__.__contains__", ["__floordiv__"], false]
    - ["pp2671018", "pathlib.PurePath.__dict__.__contains__", ["__mod__"],      false]
    - ["pp2671019", "pathlib.Path.__dict__.__contains__",     ["stat"],         true]
    - ["pp2671020", "pathlib.Path.__dict__.__contains__",     ["exists"],       true]
    - ["pp2671021", "pathlib.Path.__dict__.__contains__",     ["open"],         true]
    - ["pp2671022", "pathlib.Path.__dict__.__contains__",     ["__sub__"],      false]
    - ["pp2671023", "pathlib.Path.__dict__.__contains__",     ["__floordiv__"], false]
    - ["pp2671024", "pathlib.Path.__dict__.__contains__",     ["__mod__"],      false]
