spec: dis_extra22
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "dis_extra21.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __qualname__.__eq__ (table); Instruction/__qualname__.__eq__ standalone; opname/__class__.__name__=='list' standalone; opmap/__class__.__name__=='dict' standalone"
    - "dis_extra16.zspec.zsdl — covers Bytecode/__qualname__ and Instruction/__qualname__ in a class_qualnames table"
    - "dis_extra15.zspec.zsdl — covers cmp_op/__class__.__name__=='tuple' standalone; opmap class check"
    - "dis_extra13.zspec.zsdl — covers opname.__len__==256 (Python 3.11 value); cmp_op.__len__()>=6; opname.__class__.__name__=='list'"
    - "dis_extra12.zspec.zsdl — covers cmp_op/__class__.__name__=='tuple'; cmp_op[0]=='<'; hasjump class and len; deoptmap class"
    - "dis_extra11.zspec.zsdl — covers Bytecode/__qualname__ standalone; opmap.__len__==154; hasconst/haslocal/hasname/hascompare/hasjrel/hasfree lengths"
    - "dis_extra5.zspec.zsdl — covers Bytecode.__qualname__ (in that spec); code_info/show_code/stack_effect/findlabels/distb __qualname__"
    - "dis_extra4.zspec.zsdl — covers Instruction.__qualname__; opname.__len__>=100; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
  notes:
    - "This spec extends dis_extra21.zspec.zsdl."
    - "Focus: Bytecode.__qualname__ standalone in dis_extra22 namespace; Bytecode.from_traceback/__qualname__; Bytecode.__iter__/__qualname__; Instruction._fields class name; opname.__len__() exact value (267 on Python 3.12+); cmp_op/__class__.__name__ standalone in dis_extra22 namespace; hascompare/__class__.__name__ standalone in dis_extra22 namespace."
    - "dis.Bytecode.__qualname__ == 'Bytecode' — dis_extra11/dis_extra16 cover this in their namespaces; distinct standalone invariant in dis_extra22."
    - "dis.Bytecode.from_traceback.__qualname__ == 'Bytecode.from_traceback' — no prior dis spec covers this method qualname."
    - "dis.Bytecode.__iter__.__qualname__ == 'Bytecode.__iter__' — no prior dis spec covers this dunder method qualname."
    - "dis.Instruction._fields.__class__.__name__ == 'tuple' — Instruction._fields is a tuple of field name strings; no prior dis spec checks _fields class name via __class__.__name__.__eq__."
    - "dis.opname.__len__() == 267 — verified on Python 3.12 (macOS/Darwin 25.4.0); dis_extra13 claimed 256 for an older CPython version; the actual value on this platform is 267."
    - "dis.cmp_op.__class__.__name__ == 'tuple' — dis_extra12/dis_extra15 cover this in their namespaces; distinct standalone invariant in dis_extra22."
    - "dis.hascompare.__class__.__name__ == 'list' — dis_extra6 covers hascompare class via a broader table; standalone __eq__ invariant in dis_extra22 namespace is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Bytecode class and method __qualname__ values
# (dis_extra22 namespace)
#
# dis_extra11/dis_extra16 cover Bytecode.__qualname__ in prior namespaces.
# Bytecode.from_traceback and Bytecode.__iter__ qualnames are not covered
# in any prior dis spec.
# ---------------------------------------------------------------------------

invariant dis_extra22.Bytecode.qualname:
  description: "dis.Bytecode.__qualname__ == 'Bytecode'"
  category: class_qualnames
  kind: python_call_eq
  function: Bytecode.__qualname__.__eq__
  args: ["Bytecode"]
  expected: true

invariant dis_extra22.Bytecode_from_traceback.qualname:
  description: "dis.Bytecode.from_traceback.__qualname__ == 'Bytecode.from_traceback'"
  category: method_qualnames
  kind: python_call_eq
  function: Bytecode.from_traceback.__qualname__.__eq__
  args: ["Bytecode.from_traceback"]
  expected: true

invariant dis_extra22.Bytecode_iter.qualname:
  description: "dis.Bytecode.__iter__.__qualname__ == 'Bytecode.__iter__'"
  category: method_qualnames
  kind: python_call_eq
  function: Bytecode.__iter__.__qualname__.__eq__
  args: ["Bytecode.__iter__"]
  expected: true

# ---------------------------------------------------------------------------
# Instruction._fields class name
# (dis_extra22 namespace)
#
# dis_extra4 covers Instruction._fields class checks (contains 'opname',
# 'opcode'). No prior dis spec verifies _fields.__class__.__name__ == 'tuple'
# via a standalone __eq__ invariant.
# ---------------------------------------------------------------------------

invariant dis_extra22.Instruction_fields.class_is_tuple:
  description: "dis.Instruction._fields.__class__.__name__ == 'tuple' — _fields is a tuple of field name strings"
  category: class_names
  kind: python_call_eq
  function: Instruction._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# opname exact length on Python 3.12
# (dis_extra22 namespace)
#
# dis_extra4 covers opname.__len__() >= 100.
# dis_extra13 covers opname.__len__() == 256 (older CPython).
# The actual value on Python 3.12 (macOS/Darwin 25.4.0) is 267.
# This standalone invariant records the verified value for this platform.
# ---------------------------------------------------------------------------

invariant dis_extra22.opname.len_267:
  description: "dis.opname.__len__() == 267 — verified on Python 3.12 (macOS/Darwin 25.4.0)"
  category: sequence_lengths
  kind: python_call_eq
  function: opname.__len__
  args: []
  expected: 267

# ---------------------------------------------------------------------------
# cmp_op and hascompare __class__.__name__ — standalone invariants
# (dis_extra22 namespace)
#
# dis_extra12/dis_extra15 cover cmp_op/__class__.__name__=='tuple' in prior
# namespaces. dis_extra6 covers hascompare class in a broader table.
# These are distinct standalone invariants in the dis_extra22 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra22.cmp_op.class_is_tuple:
  description: "dis.cmp_op.__class__.__name__ == 'tuple' — cmp_op is a tuple of comparison operator strings"
  category: class_names
  kind: python_call_eq
  function: cmp_op.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant dis_extra22.hascompare.class_is_list:
  description: "dis.hascompare.__class__.__name__ == 'list' — hascompare is a list of opcodes that perform comparisons"
  category: class_names
  kind: python_call_eq
  function: hascompare.__class__.__name__.__eq__
  args: ["list"]
  expected: true
