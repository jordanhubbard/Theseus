spec: bdb_extra3
version: ">=3.9"
backend: python_module(bdb)

docs: https://docs.python.org/3/library/bdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bdb.html — Python bdb module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bdb.py"
  notes:
    - "This spec extends bdb.zspec.zsdl and prior extras."
    - "bdb.zspec covers: Bdb/__name__/__module__, Breakpoint/__name__, BdbQuit/__name__/__bases__[0]/__name__; set_trace/set_break/clear_break/clear_all_breaks/get_breaks/run/runcall/runeval/set_continue/set_quit method names; Breakpoint.next is int."
    - "bdb_extra covers: Bdb/__name__/__module__, Breakpoint/__name__/__module__, BdbQuit/__name__/__module__/__bases__[0]/__name__/__bases__.__len__; method name invariants and table."
    - "bdb_extra2 covers: Bdb.__bases__[0].__name__=='object', checkfuncname/__name__/__module__, effective/__name__/__module__, class_qualnames table (Bdb, Breakpoint, BdbQuit)."
    - "This spec adds: Bdb.__bases__.__len__==1, Breakpoint.__bases__[0].__name__=='object', Breakpoint.__bases__.__len__==1, BdbQuit.__bases__[0].__module__=='builtins', Bdb.__module__ length check."
    - "bdb.Bdb.__bases__.__len__() == 1 — Bdb has exactly one direct base class (object)."
    - "bdb.Breakpoint.__bases__[0].__name__ == 'object' — Breakpoint inherits directly from object."
    - "bdb.Breakpoint.__bases__.__len__() == 1 — Breakpoint has exactly one direct base class."
    - "bdb.BdbQuit.__bases__[0].__module__ == 'builtins' — Exception is defined in builtins."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Bdb — base class count
# bdb_extra2 confirms __bases__[0].__name__ == 'object'.
# This spec adds the length check to confirm exactly one base.
# ---------------------------------------------------------------------------

invariant bdb_extra3.Bdb.bases_len:
  description: "len(bdb.Bdb.__bases__) == 1 — Bdb has exactly one direct base class (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Bdb.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Breakpoint — base class hierarchy
# bdb_extra covers BdbQuit.__bases__ but not Breakpoint.__bases__.
# Breakpoint inherits directly from object (no intermediate class).
# ---------------------------------------------------------------------------

invariant bdb_extra3.Breakpoint.base_is_object:
  description: "bdb.Breakpoint.__bases__[0].__name__ == 'object' — Breakpoint inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Breakpoint.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant bdb_extra3.Breakpoint.bases_len:
  description: "len(bdb.Breakpoint.__bases__) == 1 — Breakpoint has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Breakpoint.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# BdbQuit.__bases__[0].__module__ — Exception lives in builtins
# No prior bdb spec checks the __module__ of the BdbQuit base class.
# ---------------------------------------------------------------------------

invariant bdb_extra3.BdbQuit.base_module:
  description: "bdb.BdbQuit.__bases__[0].__module__ == 'builtins' — Exception is defined in builtins"
  category: class_hierarchy
  kind: python_call_eq
  function: BdbQuit.__bases__.__getitem__
  args: [0]
  method: __module__
  method_args: []
  expected: "builtins"

# ---------------------------------------------------------------------------
# Module string length checks — Bdb, Breakpoint, BdbQuit
# 'bdb' has length 3. Provides a complementary numeric assertion.
# No prior spec checks __module__ string lengths for bdb classes.
# ---------------------------------------------------------------------------

table bdb_extra3.module_lengths:
  kind: python_call_eq
  category: class_modules
  id_prefix: modlen

  columns: [id, function, args, expected]
  rows:
    - [Bdb,        Bdb.__module__.__len__,        [], 3]
    - [Breakpoint, Breakpoint.__module__.__len__, [], 3]
    - [BdbQuit,    BdbQuit.__module__.__len__,    [], 3]
