# ---------------------------------------------------------------------------

table abc_extra244.abcmeta_method_qualname_identity:
  description: "abc.ABCMeta method qualname identity — ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True (len=25; the qualname encodes the class scope using dot notation); ABCMeta.__subclasshook__.__qualname__.__eq__('ABCMeta.__subclasshook__')==True (len=24, one character shorter than __instancecheck__); ABCMeta.__instancecheck__.__qualname__.__len__()==25; ABCMeta.__subclasshook__.__qualname__.__len__()==24; both qualnames confirm class membership inside ABCMeta; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc244qn

  columns: [id, function, args, expected, description]
  rows:
    - [ic_qn_eq,    ABCMeta.__instancecheck__.__qualname__.__eq__,  ["ABCMeta.__instancecheck__"],  true, "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'; verified with Python 3.14.3"]
    - [ic_qn_len,   ABCMeta.__instancecheck__.__qualname__.__len__, [],                             25,   "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [sh_qn_eq,    ABCMeta.__subclasshook__.__qualname__.__eq__,   ["ABCMeta.__subclasshook__"],   true, "abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__'; verified with Python 3.14.3"]
    - [sh_qn_len,   ABCMeta.__subclasshook__.__qualname__.__len__,  [],                             24,   "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24; verified with Python 3.14.3"]
    - [ic_gt_sh,    ABCMeta.__instancecheck__.__qualname__.__gt__,  ["ABCMeta.__subclasshook__"],   true, "ABCMeta.__instancecheck__.__qualname__ > ABCMeta.__subclasshook__.__qualname__ (lexicographic; 'i' > 'h' at position 7); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra244
# ---------------------------------------------------------------------------

invariant abc_extra244.abstractclassmethod_base_is_classmethod:
  description: "abc.abstractclassmethod.__bases__[0].__name__.__eq__('classmethod') returns True — abstractclassmethod extends Python's built-in classmethod descriptor with __isabstractmethod__=True; this makes abstractclassmethod a subclass of classmethod (not abstractmethod, which is a plain function); abstractclassmethod.__name__ == 'abstractclassmethod' (len=19); abstractclassmethod.__module__ == 'abc' (len=3); abstractstaticmethod.__bases__[0].__name__ == 'staticmethod' (parallel pattern); NEW in extra244: first standalone abstractclassmethod base invariant in abc244dep namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abstractclassmethod.__bases__[0].__name__.__eq__"
  args: ["classmethod"]
  expected: true

invariant abc_extra244.get_cache_token_module_is_abc_c:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — get_cache_token is implemented in the C extension _abc (Modules/_abc.c); its __module__ attribute is '_abc' (len=4), not 'abc' (len=3); this distinguishes it from abstractmethod, ABCMeta, and ABC which all have __module__ == 'abc'; get_cache_token.__class__.__name__ == 'builtin_function_or_method' (it is a C builtin, not a Python function); get_cache_token.__name__ == 'get_cache_token' (len=15); NEW in extra244: first standalone get_cache_token module invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra244.abstractstaticmethod_single_base_raises_indexerror:
  description: "abc.abstractstaticmethod.__bases__[1] raises IndexError — abstractstaticmethod has exactly one direct base class (staticmethod); __bases__ is a 1-element tuple; accessing __bases__[1] is out of range and raises IndexError; this confirms single-inheritance: abstractstaticmethod -> staticmethod; abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20); abstractstaticmethod.__module__ == 'abc' (len=3); abstractclassmethod.__bases__[0].__name__ == 'classmethod' (parallel single-base pattern); NEW in extra244: first standalone abstractstaticmethod single-base IndexError invariant; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "abstractstaticmethod.__bases__[1].__name__.__eq__"
  args: ["ShouldNotReach"]
  raises: IndexError

invariant abc_extra244.abcmeta_instancecheck_qualname_eq:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') returns True — the qualname encodes the class scope using dot notation (len=25); ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24, one character shorter); qualnames confirm both methods belong to ABCMeta; ABCMeta.__name__ == 'ABCMeta' (len=7); get_cache_token.__name__ == 'get_cache_token' (len=15); NEW in extra244: first standalone ABCMeta __instancecheck__ qualname invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true
