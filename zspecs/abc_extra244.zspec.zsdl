spec: abc_extra244
version: ">=3.4"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.abstractclassmethod — abstractclassmethod (deprecated)"
    - "https://docs.python.org/3/library/abc.html#abc.abstractstaticmethod — abstractstaticmethod (deprecated)"
    - "https://docs.python.org/3/library/abc.html#abc.abstractproperty — abstractproperty (deprecated)"
    - "https://docs.python.org/3/library/abc.html#abc.get_cache_token — get_cache_token function"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py (internal implementation)"
    - "CPython source: Modules/_abc.c (C-level accelerators)"
  notes:
    - "This spec covers deprecated abstract decorators (abstractclassmethod, abstractstaticmethod, abstractproperty) and get_cache_token."
    - "abc.abstractclassmethod.__name__ == 'abstractclassmethod' (len=19); __module__ == 'abc'; __bases__[0].__name__ == 'classmethod'."
    - "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20); __module__ == 'abc'; __bases__[0].__name__ == 'staticmethod'."
    - "abc.abstractproperty.__name__ == 'abstractproperty' (len=16); __module__ == 'abc'; __bases__[0].__name__ == 'property'."
    - "All three deprecated types are still present in Python 3.14.3 (not yet removed)."
    - "abc.get_cache_token.__name__ == 'get_cache_token' (len=15); __module__ == '_abc' (len=4); __class__.__name__ == 'builtin_function_or_method'."
    - "get_cache_token lives in the '_abc' C extension module, not in 'abc' — the Python abc module re-exports it."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25)."
    - "abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Deprecated abstract decorator class identity
#
# abstractclassmethod.__name__ == 'abstractclassmethod' (len=19)
# abstractclassmethod.__module__ == 'abc' (len=3)
# abstractclassmethod.__bases__[0].__name__ == 'classmethod'
# abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20)
# abstractstaticmethod.__module__ == 'abc' (len=3)
# abstractstaticmethod.__bases__[0].__name__ == 'staticmethod'
# abstractproperty.__name__ == 'abstractproperty' (len=16)
# abstractproperty.__module__ == 'abc' (len=3)
# abstractproperty.__bases__[0].__name__ == 'property'
# ---------------------------------------------------------------------------

table abc_extra244.deprecated_abstract_decorators_identity:
  description: "abc deprecated abstract decorator class identity — abstractclassmethod.__name__.__eq__('abstractclassmethod')==True (len=19); abstractclassmethod.__module__.__eq__('abc')==True (len=3); abstractclassmethod.__bases__[0].__name__.__eq__('classmethod')==True (abstractclassmethod extends classmethod with abstract marking); abstractstaticmethod.__name__.__eq__('abstractstaticmethod')==True (len=20, one character longer than abstractclassmethod); abstractstaticmethod.__module__.__eq__('abc')==True (len=3); abstractstaticmethod.__bases__[0].__name__.__eq__('staticmethod')==True; abstractproperty.__name__.__eq__('abstractproperty')==True (len=16); abstractproperty.__module__.__eq__('abc')==True (len=3); abstractproperty.__bases__[0].__name__.__eq__('property')==True; all three deprecated decorators still present in Python 3.14.3; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc244dep

  columns: [id, function, args, expected, description]
  rows:
    - [acm_name_eq,   abstractclassmethod.__name__.__eq__,                    ["abstractclassmethod"],   true, "abc.abstractclassmethod.__name__ == 'abstractclassmethod'; verified with Python 3.14.3"]
    - [acm_name_len,  abstractclassmethod.__name__.__len__,                   [],                        19,   "abc.abstractclassmethod.__name__.__len__() == 19; verified with Python 3.14.3"]
    - [acm_mod_eq,    abstractclassmethod.__module__.__eq__,                  ["abc"],                   true, "abc.abstractclassmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [acm_mod_len,   abstractclassmethod.__module__.__len__,                 [],                        3,    "abc.abstractclassmethod.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [acm_base_eq,   "abstractclassmethod.__bases__[0].__name__.__eq__",     ["classmethod"],           true, "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod'; verified with Python 3.14.3"]
    - [asm_name_eq,   abstractstaticmethod.__name__.__eq__,                   ["abstractstaticmethod"],  true, "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod'; verified with Python 3.14.3"]
    - [asm_name_len,  abstractstaticmethod.__name__.__len__,                  [],                        20,   "abc.abstractstaticmethod.__name__.__len__() == 20; verified with Python 3.14.3"]
    - [asm_mod_eq,    abstractstaticmethod.__module__.__eq__,                 ["abc"],                   true, "abc.abstractstaticmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [asm_mod_len,   abstractstaticmethod.__module__.__len__,                [],                        3,    "abc.abstractstaticmethod.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [asm_base_eq,   "abstractstaticmethod.__bases__[0].__name__.__eq__",    ["staticmethod"],          true, "abc.abstractstaticmethod.__bases__[0].__name__ == 'staticmethod'; verified with Python 3.14.3"]
    - [ap_name_eq,    abstractproperty.__name__.__eq__,                       ["abstractproperty"],      true, "abc.abstractproperty.__name__ == 'abstractproperty'; verified with Python 3.14.3"]
    - [ap_name_len,   abstractproperty.__name__.__len__,                      [],                        16,   "abc.abstractproperty.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [ap_mod_eq,     abstractproperty.__module__.__eq__,                     ["abc"],                   true, "abc.abstractproperty.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ap_mod_len,    abstractproperty.__module__.__len__,                    [],                        3,    "abc.abstractproperty.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [ap_base_eq,    "abstractproperty.__bases__[0].__name__.__eq__",        ["property"],              true, "abc.abstractproperty.__bases__[0].__name__ == 'property'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.get_cache_token function identity
#
# get_cache_token.__name__ == 'get_cache_token' (len=15)
# get_cache_token.__module__ == '_abc' (len=4)
# get_cache_token.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table abc_extra244.get_cache_token_identity:
  description: "abc.get_cache_token function identity — get_cache_token.__name__.__eq__('get_cache_token')==True (len=15); get_cache_token.__module__.__eq__('_abc')==True (len=4 — the function is implemented in the C extension _abc, not in Lib/abc.py; the abc module re-exports it); get_cache_token.__class__.__name__.__eq__('builtin_function_or_method')==True (it is a C-level builtin, not a Python function); get_cache_token.__name__.__len__()==15; get_cache_token.__module__.__len__()==4; contrast: abstractmethod.__module__ == 'abc' (len=3, shorter); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc244gct

  columns: [id, function, args, expected, description]
  rows:
    - [gct_name_eq,   get_cache_token.__name__.__eq__,           ["get_cache_token"],            true, "abc.get_cache_token.__name__ == 'get_cache_token'; verified with Python 3.14.3"]
    - [gct_name_len,  get_cache_token.__name__.__len__,          [],                             15,   "abc.get_cache_token.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [gct_mod_eq,    get_cache_token.__module__.__eq__,         ["_abc"],                       true, "abc.get_cache_token.__module__ == '_abc' (C extension module); verified with Python 3.14.3"]
    - [gct_mod_len,   get_cache_token.__module__.__len__,        [],                             4,    "abc.get_cache_token.__module__.__len__() == 4; verified with Python 3.14.3"]
    - [gct_cls_eq,    get_cache_token.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]

