spec: fcntl_extra
version: ">=3.9"
backend: python_module(fcntl)

docs: https://docs.python.org/3/library/fcntl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fcntl.html — Python fcntl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/fcntlmodule.c"
  notes:
    - "The fcntl module exposes Unix file control operations; available on Unix/macOS only, not Windows."
    - "fcntl.fcntl, fcntl.ioctl, fcntl.lockf, and fcntl.flock are all C-level builtin functions."
    - "fcntl.__name__ == 'fcntl', ioctl.__name__ == 'ioctl', lockf.__name__ == 'lockf', flock.__name__ == 'flock'."
    - "LOCK_SH=1, LOCK_EX=2, LOCK_NB=4, LOCK_UN=8 on macOS and Linux."
    - "All LOCK_* constants are plain Python ints (or int subclasses); __class__.__name__ == 'int'."
    - "The module-level __name__ attribute is 'fcntl' (the module name)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# fcntl() builtin — function name
# ---------------------------------------------------------------------------

invariant fcntl_extra.fcntl.name:
  description: "fcntl.fcntl.__name__ == 'fcntl'"
  category: functions
  kind: python_call_eq
  function: fcntl.__name__.__eq__
  args: ["fcntl"]
  expected: true

invariant fcntl_extra.fcntl.is_builtin:
  description: "fcntl.fcntl is a builtin_function_or_method"
  category: functions
  kind: python_call_eq
  function: fcntl.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# ioctl() builtin — function name
# ---------------------------------------------------------------------------

invariant fcntl_extra.ioctl.name:
  description: "fcntl.ioctl.__name__ == 'ioctl'"
  category: functions
  kind: python_call_eq
  function: ioctl.__name__.__eq__
  args: ["ioctl"]
  expected: true

invariant fcntl_extra.ioctl.is_builtin:
  description: "fcntl.ioctl is a builtin_function_or_method"
  category: functions
  kind: python_call_eq
  function: ioctl.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# lockf() builtin — function name
# ---------------------------------------------------------------------------

invariant fcntl_extra.lockf.name:
  description: "fcntl.lockf.__name__ == 'lockf'"
  category: functions
  kind: python_call_eq
  function: lockf.__name__.__eq__
  args: ["lockf"]
  expected: true

invariant fcntl_extra.lockf.is_builtin:
  description: "fcntl.lockf is a builtin_function_or_method"
  category: functions
  kind: python_call_eq
  function: lockf.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# flock() builtin — function name
# ---------------------------------------------------------------------------

invariant fcntl_extra.flock.name:
  description: "fcntl.flock.__name__ == 'flock'"
  category: functions
  kind: python_call_eq
  function: flock.__name__.__eq__
  args: ["flock"]
  expected: true

invariant fcntl_extra.flock.is_builtin:
  description: "fcntl.flock is a builtin_function_or_method"
  category: functions
  kind: python_call_eq
  function: flock.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# LOCK_* constants — type (int) and values on macOS/Linux
# ---------------------------------------------------------------------------

invariant fcntl_extra.LOCK_SH.is_int:
  description: "fcntl.LOCK_SH.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: LOCK_SH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant fcntl_extra.LOCK_SH.value:
  description: "fcntl.LOCK_SH == 1 on macOS/Linux"
  category: constants
  kind: python_call_eq
  function: LOCK_SH.__eq__
  args: [1]
  expected: true

invariant fcntl_extra.LOCK_EX.is_int:
  description: "fcntl.LOCK_EX.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: LOCK_EX.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant fcntl_extra.LOCK_EX.value:
  description: "fcntl.LOCK_EX == 2 on macOS/Linux"
  category: constants
  kind: python_call_eq
  function: LOCK_EX.__eq__
  args: [2]
  expected: true

invariant fcntl_extra.LOCK_NB.is_int:
  description: "fcntl.LOCK_NB.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: LOCK_NB.__class__.__name__.__eq__
