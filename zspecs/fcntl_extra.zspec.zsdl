  expected: true

invariant fcntl_extra.LOCK_NB.value:
  description: "fcntl.LOCK_NB == 4 on macOS/Linux"
  category: constants
  kind: python_call_eq
  function: LOCK_NB.__eq__
  args: [4]
  expected: true

invariant fcntl_extra.LOCK_UN.is_int:
  description: "fcntl.LOCK_UN.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: LOCK_UN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant fcntl_extra.LOCK_UN.value:
  description: "fcntl.LOCK_UN == 8 on macOS/Linux"
  category: constants
  kind: python_call_eq
  function: LOCK_UN.__eq__
  args: [8]
  expected: true
