spec: mimesis_rust
version: ">=3.9"
backend: rust_module(mimesis_rust)

docs: https://mimesis.name/en/master/

provenance:
  derived_from:
    - "https://mimesis.name/en/master/ — Mimesis documentation"
  not_derived_from:
    - "mimesis source: mimesis/__init__.py"
  notes:
    - "Mimesis is a Python library for generating fake data."
    - "from mimesis import Person; p = Person(); p.name() is a non-empty string."
    - "from mimesis import Generic; g = Generic(); g.person.name() is a string."
    - "mimesis.__version__ is a non-empty string."
    - "Expose mimesis_name_nonempty() -> bool: len(Person().name()) > 0."
    - "Expose mimesis_email_has_at() -> bool: '@' in Person().email()."
    - "Expose mimesis_version_nonempty() -> bool: len(mimesis.__version__) > 0."
    - "All test vectors verified against mimesis 18.0.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# mimesis_name_nonempty — generated name is non-empty
invariant mimesis_rust.person.name_nonempty:
  description: "Person().name() is non-empty"
  category: person
  kind: python_call_eq
  function: mimesis_name_nonempty
  args: []
  expected: true

# mimesis_email_has_at — generated email has '@'
invariant mimesis_rust.person.email_has_at:
  description: "Person().email() contains '@'"
  category: person
  kind: python_call_eq
  function: mimesis_email_has_at
  args: []
  expected: true

# mimesis_version_nonempty — version non-empty
invariant mimesis_rust.version.nonempty:
  description: "mimesis.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: mimesis_version_nonempty
  args: []
  expected: true

