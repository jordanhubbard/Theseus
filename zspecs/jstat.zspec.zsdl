spec: jstat
version: ">=1.9.0"
backend: node(jstat)

docs: https://www.npmjs.com/package/jstat

provenance:
  derived_from:
    - "jstat README — https://www.npmjs.com/package/jstat"
    - "Test vectors verified with jstat via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "jstat source"
  notes:
    - "jstat is an npm package. Install: npm install jstat"
    - "jStat.mean(arr) computes the arithmetic mean."
    - "jStat.median(arr) computes the median."
    - "jStat.variance(arr) computes the population variance."
    - "jStat.sum(arr) sums an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns computed statistical value."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table jstat.mean:
  kind: node_module_call_eq
  function: mean
  category: descriptive
  id_prefix: jsmean

  columns: [id, args, expected]
  rows:
    - [basic,   [[1, 2, 3, 4, 5]], 3]

table jstat.median:
  kind: node_module_call_eq
  function: median
  category: descriptive
  id_prefix: jsmed

  columns: [id, args, expected]
  rows:
    - [odd,   [[1, 2, 3, 4, 5]], 3]

table jstat.variance:
  kind: node_module_call_eq
  function: variance
  category: descriptive
  id_prefix: jsvar

  columns: [id, args, expected]
  rows:
    - [basic, [[2, 4, 4, 4, 5, 5, 7, 9]], 4]

table jstat.sum:
  kind: node_module_call_eq
  function: sum
  category: descriptive
  id_prefix: jssum

  columns: [id, args, expected]
  rows:
    - [basic, [[1, 2, 3, 4, 5]], 15]

table jstat.min:
  kind: node_module_call_eq
  function: min
  category: descriptive
  id_prefix: jsmin

  columns: [id, args, expected]
  rows:
    - [basic, [[3, 1, 4, 1, 5, 9]], 1]

table jstat.max:
  kind: node_module_call_eq
  function: max
  category: descriptive
  id_prefix: jsmax

  columns: [id, args, expected]
  rows:
    - [basic, [[3, 1, 4, 1, 5, 9]], 9]
