spec: difflib_extra24
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib_extra23.zspec.zsdl."
    - "Prior specs covered: SequenceMatcher/Differ/HtmlDiff __module__.__len__() and __name__.__len__() (extra22); unified_diff/context_diff/ndiff/get_close_matches/diff_bytes/restore __module__.__len__()/__name__.__len__() (extra22/extra23); SequenceMatcher/Differ/HtmlDiff __qualname__.__len__() (extra23); ndiff/get_close_matches/diff_bytes __qualname__.__len__() (extra23)."
    - "This spec covers: __mro__.__len__() for SequenceMatcher, Differ, HtmlDiff; __bases__[0].__name__.__len__() for SequenceMatcher, Differ, HtmlDiff; __qualname__.__len__() for SequenceMatcher.ratio/get_matching_blocks/get_opcodes/__init__ methods; __qualname__.__len__() for Differ.compare/__init__ methods; __qualname__.__len__() for HtmlDiff.make_file/make_table/__init__ methods."
    - "No prior difflib spec checks difflib.SequenceMatcher.__mro__.__len__()."
    - "No prior difflib spec checks difflib.Differ.__mro__.__len__()."
    - "No prior difflib spec checks difflib.HtmlDiff.__mro__.__len__()."
    - "No prior difflib spec checks difflib.SequenceMatcher.__bases__[0].__name__.__len__()."
    - "No prior difflib spec checks difflib.Differ.__bases__[0].__name__.__len__()."
    - "No prior difflib spec checks difflib.HtmlDiff.__bases__[0].__name__.__len__()."
    - "No prior difflib spec checks difflib.SequenceMatcher.ratio.__qualname__.__len__()."
    - "No prior difflib spec checks difflib.SequenceMatcher.get_matching_blocks.__qualname__.__len__()."
    - "No prior difflib spec checks difflib.SequenceMatcher.get_opcodes.__qualname__.__len__()."
    - "No prior difflib spec checks difflib.SequenceMatcher.__init__.__qualname__.__len__()."
    - "No prior difflib spec checks difflib.Differ.compare.__qualname__.__len__()."
    - "No prior difflib spec checks difflib.Differ.__init__.__qualname__.__len__()."
    - "No prior difflib spec checks difflib.HtmlDiff.make_file.__qualname__.__len__()."
    - "No prior difflib spec checks difflib.HtmlDiff.make_table.__qualname__.__len__()."
    - "No prior difflib spec checks difflib.HtmlDiff.__init__.__qualname__.__len__()."
    - "difflib.SequenceMatcher.__mro__ == [SequenceMatcher, object] — len 2."
    - "difflib.Differ.__mro__ == [Differ, object] — len 2."
    - "difflib.HtmlDiff.__mro__ == [HtmlDiff, object] — len 2."
    - "difflib.SequenceMatcher.__bases__[0].__name__ == 'object' — len 6."
    - "difflib.Differ.__bases__[0].__name__ == 'object' — len 6."
    - "difflib.HtmlDiff.__bases__[0].__name__ == 'object' — len 6."
    - "difflib.SequenceMatcher.ratio.__qualname__ == 'SequenceMatcher.ratio' — len 21."
    - "difflib.SequenceMatcher.get_matching_blocks.__qualname__ == 'SequenceMatcher.get_matching_blocks' — len 35."
    - "difflib.SequenceMatcher.get_opcodes.__qualname__ == 'SequenceMatcher.get_opcodes' — len 27."
    - "difflib.SequenceMatcher.__init__.__qualname__ == 'SequenceMatcher.__init__' — len 24."
    - "difflib.Differ.compare.__qualname__ == 'Differ.compare' — len 14."
    - "difflib.Differ.__init__.__qualname__ == 'Differ.__init__' — len 15."
    - "difflib.HtmlDiff.make_file.__qualname__ == 'HtmlDiff.make_file' — len 18."
    - "difflib.HtmlDiff.make_table.__qualname__ == 'HtmlDiff.make_table' — len 19."
    - "difflib.HtmlDiff.__init__.__qualname__ == 'HtmlDiff.__init__' — len 17."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for SequenceMatcher, Differ, HtmlDiff
#
# All three difflib classes inherit directly from object without intermediate
# base classes. Each has MRO depth 2: ClassName -> object.
# No prior difflib spec checks any class's MRO depth.
# ---------------------------------------------------------------------------

invariant difflib_extra24.SequenceMatcher.mro_len:
  description: "difflib.SequenceMatcher.__mro__.__len__() == 2 — MRO: SequenceMatcher, object (flat)"
  category: class_hierarchy
  kind: python_call_eq
  function: SequenceMatcher.__mro__.__len__
  args: []
  expected: 2

invariant difflib_extra24.Differ.mro_len:
  description: "difflib.Differ.__mro__.__len__() == 2 — MRO: Differ, object (flat)"
  category: class_hierarchy
  kind: python_call_eq
  function: Differ.__mro__.__len__
  args: []
  expected: 2

invariant difflib_extra24.HtmlDiff.mro_len:
  description: "difflib.HtmlDiff.__mro__.__len__() == 2 — MRO: HtmlDiff, object (flat)"
  category: class_hierarchy
  kind: python_call_eq
  function: HtmlDiff.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for SequenceMatcher, Differ, HtmlDiff
#
# All three classes have 'object' as their sole direct base (len 6).
# No prior difflib spec checks the string length of any class's first base name.
# ---------------------------------------------------------------------------

invariant difflib_extra24.SequenceMatcher.bases0_name_len:
  description: "difflib.SequenceMatcher.__bases__[0].__name__.__len__() == 6 — first base is 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "SequenceMatcher.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant difflib_extra24.Differ.bases0_name_len:
  description: "difflib.Differ.__bases__[0].__name__.__len__() == 6 — first base is 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "Differ.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant difflib_extra24.HtmlDiff.bases0_name_len:
  description: "difflib.HtmlDiff.__bases__[0].__name__.__len__() == 6 — first base is 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "HtmlDiff.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# __qualname__.__len__() for SequenceMatcher methods
#
# All method qualnames take the form 'SequenceMatcher.<method>'. The long
# class prefix (15 chars) means even short method names produce large totals:
#   SequenceMatcher.ratio             -> 21
#   SequenceMatcher.get_opcodes       -> 27
#   SequenceMatcher.__init__          -> 24
#   SequenceMatcher.get_matching_blocks -> 35 (longest in this spec)
# No prior difflib spec checks method __qualname__ lengths.
# ---------------------------------------------------------------------------

invariant difflib_extra24.SequenceMatcher.ratio.qualname_len:
  description: "difflib.SequenceMatcher.ratio.__qualname__.__len__() == 21 — 'SequenceMatcher.ratio' has 21 characters"
  category: string_lengths
  kind: python_call_eq
  function: "SequenceMatcher.ratio.__qualname__.__len__"
  args: []
  expected: 21

invariant difflib_extra24.SequenceMatcher.get_matching_blocks.qualname_len:
  description: "difflib.SequenceMatcher.get_matching_blocks.__qualname__.__len__() == 35 — 'SequenceMatcher.get_matching_blocks' has 35 characters"
  category: string_lengths
  kind: python_call_eq
  function: "SequenceMatcher.get_matching_blocks.__qualname__.__len__"
  args: []
  expected: 35

invariant difflib_extra24.SequenceMatcher.get_opcodes.qualname_len:
  description: "difflib.SequenceMatcher.get_opcodes.__qualname__.__len__() == 27 — 'SequenceMatcher.get_opcodes' has 27 characters"
  category: string_lengths
  kind: python_call_eq
  function: "SequenceMatcher.get_opcodes.__qualname__.__len__"
  args: []
  expected: 27

invariant difflib_extra24.SequenceMatcher.init.qualname_len:
  description: "difflib.SequenceMatcher.__init__.__qualname__.__len__() == 24 — 'SequenceMatcher.__init__' has 24 characters"
  category: string_lengths
  kind: python_call_eq
  function: "SequenceMatcher.__init__.__qualname__.__len__"
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# Consolidated table — MRO depth and __bases__[0].__name__.__len__()
# for all three difflib classes
#
# All three classes have identical shallow topology (mro len 2, base 'object'
# len 6). All values are first introduced in this spec (difflib_extra24).
# ---------------------------------------------------------------------------

table difflib_extra24.class_mro_and_bases_lengths:
  description: "difflib class __mro__.__len__() (all 2) and __bases__[0].__name__.__len__() (all 6) — SequenceMatcher, Differ, HtmlDiff"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: dfa24a

  columns: [id, function, args, expected]
  rows:
    - [SequenceMatcher_mro_len,         SequenceMatcher.__mro__.__len__,               [], 2]
    - [Differ_mro_len,                  Differ.__mro__.__len__,                         [], 2]
    - [HtmlDiff_mro_len,                HtmlDiff.__mro__.__len__,                       [], 2]
    - [SequenceMatcher_bases0_name_len, "SequenceMatcher.__bases__[0].__name__.__len__", [], 6]
    - [Differ_bases0_name_len,          "Differ.__bases__[0].__name__.__len__",          [], 6]
    - [HtmlDiff_bases0_name_len,        "HtmlDiff.__bases__[0].__name__.__len__",        [], 6]

# ---------------------------------------------------------------------------
# Consolidated table — method __qualname__ lengths across all three classes
#
# Covers SequenceMatcher.ratio/get_matching_blocks/get_opcodes/__init__,
# Differ.compare/__init__, and HtmlDiff.make_file/make_table/__init__.
# All values are first introduced in this spec.
# ---------------------------------------------------------------------------

table difflib_extra24.method_qualname_lengths:
  description: "difflib method __qualname__.__len__() — SequenceMatcher, Differ, and HtmlDiff methods"
  kind: python_call_eq
  category: string_lengths
  id_prefix: dfa24b

  columns: [id, function, args, expected]
  rows:
    - [SequenceMatcher_ratio_qualname_len,               "SequenceMatcher.ratio.__qualname__.__len__",               [], 21]
    - [SequenceMatcher_get_matching_blocks_qualname_len, "SequenceMatcher.get_matching_blocks.__qualname__.__len__", [], 35]
    - [SequenceMatcher_get_opcodes_qualname_len,         "SequenceMatcher.get_opcodes.__qualname__.__len__",         [], 27]
    - [SequenceMatcher_init_qualname_len,                "SequenceMatcher.__init__.__qualname__.__len__",            [], 24]
    - [Differ_compare_qualname_len,                      "Differ.compare.__qualname__.__len__",                      [], 14]
    - [Differ_init_qualname_len,                         "Differ.__init__.__qualname__.__len__",                     [], 15]
    - [HtmlDiff_make_file_qualname_len,                  "HtmlDiff.make_file.__qualname__.__len__",                  [], 18]
    - [HtmlDiff_make_table_qualname_len,                 "HtmlDiff.make_table.__qualname__.__len__",                 [], 19]
    - [HtmlDiff_init_qualname_len,                       "HtmlDiff.__init__.__qualname__.__len__",                   [], 17]
