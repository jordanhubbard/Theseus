spec: datetime_extra13
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra12.zspec.zsdl."
    - "datetime_extra12 covers: __qualname__ for date/time/datetime/timedelta/timezone/tzinfo as standalone invariants; __module__ for all six classes in a table; MINYEAR/MAXYEAR values and class names."
    - "NEW in extra13 — Axis 1: __name__ for date/time/datetime/timedelta/timezone as standalone invariants in the extra13 namespace."
    - "NEW in extra13 — Axis 2: date.__module__ == 'datetime' as standalone invariant in extra13 namespace."
    - "NEW in extra13 — Axis 3: timedelta.__bases__[0].__name__ == 'object' — verifies timedelta directly inherits from object."
    - "NEW in extra13 — Axis 4: date.min.__class__.__name__ and date.max.__class__.__name__ both == 'date' — boundary sentinel objects are date instances."
    - "datetime.date.__name__ == 'date' — verified Python 3.12."
    - "datetime.time.__name__ == 'time' — verified Python 3.12."
    - "datetime.datetime.__name__ == 'datetime' — verified Python 3.12."
    - "datetime.timedelta.__name__ == 'timedelta' — verified Python 3.12."
    - "datetime.timezone.__name__ == 'timezone' — verified Python 3.12."
    - "datetime.date.__module__ == 'datetime' — verified Python 3.12."
    - "datetime.timedelta.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "datetime.date.min.__class__.__name__ == 'date' — verified Python 3.12."
    - "datetime.date.max.__class__.__name__ == 'date' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for date, time, datetime, timedelta, timezone
#
# datetime_extra12 covers __qualname__ for these classes as standalone
# invariants. This spec adds __name__ standalone invariants in the extra13
# namespace. (datetime_extra4 covers __qualname__ in a table; __name__ has
# not been tabled together for all five in a prior namespace anchor.)
# ---------------------------------------------------------------------------

table datetime_extra13.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [date,      date.__name__.__eq__,      ["date"],      true]
    - [time,      time.__name__.__eq__,      ["time"],      true]
    - [datetime,  datetime.__name__.__eq__,  ["datetime"],  true]
    - [timedelta, timedelta.__name__.__eq__, ["timedelta"], true]
    - [timezone,  timezone.__name__.__eq__,  ["timezone"],  true]

# ---------------------------------------------------------------------------
# date.__module__ == 'datetime'
#
# datetime_extra12 covers __module__ for all six classes in a table.
# This spec anchors date.__module__ as a standalone extra13-namespace
# invariant for direct reference.
# ---------------------------------------------------------------------------

invariant datetime_extra13.date.module:
  description: "datetime.date.__module__ == 'datetime' — class is defined in the datetime module"
  category: class_modules
  kind: python_call_eq
  function: date.__module__.__eq__
  args: ["datetime"]
  expected: true

# ---------------------------------------------------------------------------
# timedelta.__bases__[0].__name__ == 'object'
#
# timedelta directly inherits from object — it has no intermediate base class.
# This invariant confirms that via __bases__.__getitem__(0).__name__.
# ---------------------------------------------------------------------------

invariant datetime_extra13.timedelta.base_name:
  description: "datetime.timedelta.__bases__[0].__name__ == 'object' — timedelta directly inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: timedelta.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# date.min and date.max are date instances
#
# datetime.date.min and datetime.date.max are the earliest and latest
# representable date values. Both must be instances of datetime.date,
# confirmed by checking __class__.__name__.
# ---------------------------------------------------------------------------

invariant datetime_extra13.date.min.class_name:
  description: "datetime.date.min.__class__.__name__ == 'date' — lower boundary sentinel is a date instance"
  category: class_instances
  kind: python_call_eq
  function: date.min.__class__.__name__.__eq__
  args: ["date"]
  expected: true

invariant datetime_extra13.date.max.class_name:
  description: "datetime.date.max.__class__.__name__ == 'date' — upper boundary sentinel is a date instance"
  category: class_instances
  kind: python_call_eq
  function: date.max.__class__.__name__.__eq__
  args: ["date"]
  expected: true
