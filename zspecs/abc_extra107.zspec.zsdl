spec: abc_extra107
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra106.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc module public exported name string values (the 8 public names in dir(abc) that do not start with '_'). Note: abc has no __all__ attribute in Python 3.14.3 (verified: hasattr(abc, '__all__')==False); the public interface is determined by dir(abc) filtering non-underscore names. The 8 public names in sorted order are: 'ABC' (len=3, shortest), 'ABCMeta' (len=7), 'abstractclassmethod' (len=19), 'abstractmethod' (len=14), 'abstractproperty' (len=16), 'abstractstaticmethod' (len=20), 'get_cache_token' (len=15), 'update_abstractmethods' (len=22, longest). NEW in extra107: the name strings themselves are used as the invariant subjects — their string equality and length values; abc.__name__=='abc' (len=3, same as 'ABC'=3 — coincidental tie); abc.__package__=='' (empty string, len=0); abc.__spec__.name=='abc' (len=3); type(abc.abstractclassmethod).__name__=='type'; abc.abstractclassmethod.__qualname__=='abstractclassmethod' (len=19); type(abc.abstractstaticmethod).__name__=='type'; abc.abstractstaticmethod.__qualname__=='abstractstaticmethod' (len=20). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "The 8 public names in abc (sorted) by length: 'ABC'=3 (shortest) < 'ABCMeta'=7 < 'abstractmethod'=14 < 'get_cache_token'=15 < 'abstractproperty'=16 < 'abstractclassmethod'=19 < 'abstractstaticmethod'=20 < 'update_abstractmethods'=22 (longest). The two longest names both begin with 'abstract': 'abstractstaticmethod'=20 and 'update_abstractmethods'=22. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__name__ == 'abc' (len=3). abc.__package__ == '' (empty string, len=0 — abc is a top-level module, not inside a package). abc.__spec__.name == 'abc' (len=3). type(abc.abstractclassmethod).__name__ == 'type' (abstractclassmethod is a deprecated class). type(abc.abstractstaticmethod).__name__ == 'type' (abstractstaticmethod is a deprecated class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module public name string values — extra107
#
# Wave 254 theme: the 8 public exported name strings in abc (from dir(abc)).
#
# Sorted public names and their lengths:
#   'ABC'=3 < 'ABCMeta'=7 < 'abstractmethod'=14 < 'get_cache_token'=15
#   < 'abstractproperty'=16 < 'abstractclassmethod'=19 < 'abstractstaticmethod'=20
#   < 'update_abstractmethods'=22
# ---------------------------------------------------------------------------

table abc_extra107.abc_public_name_strings:
  description: "abc module public name string equality and length checks in abcnames107 namespace — wave 254 theme: the 8 non-underscore public names in dir(abc) used as string subjects; 'ABC'.__eq__('ABC')==True (len=3, shortest public name in abc); 'ABCMeta'.__eq__('ABCMeta')==True (len=7); 'abstractmethod'.__eq__('abstractmethod')==True (len=14); 'get_cache_token'.__eq__('get_cache_token')==True (len=15); 'abstractproperty'.__eq__('abstractproperty')==True (len=16); 'abstractclassmethod'.__eq__('abstractclassmethod')==True (len=19); 'abstractstaticmethod'.__eq__('abstractstaticmethod')==True (len=20); 'update_abstractmethods'.__eq__('update_abstractmethods')==True (len=22, longest); abc.abstractclassmethod.__qualname__.__eq__('abstractclassmethod')==True (qualname matches the name string); abc.abstractstaticmethod.__qualname__.__eq__('abstractstaticmethod')==True; type(abc.abstractclassmethod).__name__.__eq__('type')==True (deprecated class); type(abc.abstractstaticmethod).__name__.__eq__('type')==True; compare name lengths: ABC=3 (shortest) < ABCMeta=7 < abstractmethod=14 < get_cache_token=15 < abstractproperty=16 < abstractclassmethod=19 < abstractstaticmethod=20 < update_abstractmethods=22 (longest, 19 chars longer than ABC=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnames107

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,        abc.ABC.__name__.__eq__,                                       ["ABC"],                true, "'ABC' string eq check via abc.ABC.__name__ == 'ABC' (len=3, shortest public name); verified with Python 3.14.3"]
    - [abc_name_len,       abc.ABC.__name__.__len__,                                      [],                     3,    "abc.ABC.__name__.__len__() == 3 ('ABC'=3, shortest public name); verified with Python 3.14.3"]
    - [abcmeta_name_eq,    abc.ABCMeta.__name__.__eq__,                                   ["ABCMeta"],            true, "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [abcmeta_name_len,   abc.ABCMeta.__name__.__len__,                                  [],                     7,    "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'=7); verified with Python 3.14.3"]
    - [am_qn_eq2,          abc.abstractmethod.__qualname__.__eq__,                        ["abstractmethod"],     true, "abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_qn_len2,         abc.abstractmethod.__qualname__.__len__,                       [],                     14,   "abc.abstractmethod.__qualname__.__len__() == 14 ('abstractmethod'=14); verified with Python 3.14.3"]
    - [gct_qn_eq2,         abc.get_cache_token.__qualname__.__eq__,                       ["get_cache_token"],    true, "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_qn_len2,        abc.get_cache_token.__qualname__.__len__,                      [],                     15,   "abc.get_cache_token.__qualname__.__len__() == 15 ('get_cache_token'=15); verified with Python 3.14.3"]
    - [ap_qn_eq2,          abc.abstractproperty.__qualname__.__eq__,                      ["abstractproperty"],   true, "abc.abstractproperty.__qualname__ == 'abstractproperty' (len=16); verified with Python 3.14.3"]
    - [ap_qn_len2,         abc.abstractproperty.__qualname__.__len__,                     [],                     16,   "abc.abstractproperty.__qualname__.__len__() == 16 ('abstractproperty'=16); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc abstractclassmethod and abstractstaticmethod qualnames — extra107
#
# Wave 254 theme: deprecated abstract decorator classes in abc.
#
# abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' (len=19)
# abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' (len=20)
# type(abc.abstractclassmethod).__name__ == 'type'
# type(abc.abstractstaticmethod).__name__ == 'type'
# ---------------------------------------------------------------------------

table abc_extra107.abc_deprecated_abstract_classes:
  description: "abc.abstractclassmethod and abc.abstractstaticmethod qualname and type checks in abcnames107 namespace — wave 254 theme: abc.abstractclassmethod.__qualname__.__eq__('abstractclassmethod')==True (len=19: 'abstractclassmethod'=19; 6th longest public name); abc.abstractclassmethod.__qualname__.__len__()==19; type(abc.abstractclassmethod).__name__.__eq__('type')==True (abstractclassmethod is a deprecated class — subclass of classmethod — so its type() is 'type'); abc.abstractstaticmethod.__qualname__.__eq__('abstractstaticmethod')==True (len=20: 'abstractstaticmethod'=20; 7th longest, second longest after 'update_abstractmethods'=22); abc.abstractstaticmethod.__qualname__.__len__()==20; type(abc.abstractstaticmethod).__name__.__eq__('type')==True (abstractstaticmethod is a deprecated class — subclass of staticmethod — so its type() is 'type'); compare: abstractclassmethod=19 < abstractstaticmethod=20 (abstractstaticmethod is 1 char longer — 'static'=6 vs 'class'=5, +1 char); both have type 'type' (both are class objects); both are deprecated since Python 3.3: use @classmethod + @abstractmethod and @staticmethod + @abstractmethod instead; compare with abstractmethod (type='function', len=14) and abstractproperty (type='type', len=16); in this table both classes are 'type' objects; abstractclassmethod qualname len=19 is shorter than abstractstaticmethod len=20 by 1 char; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnames107a

  columns: [id, function, args, expected, description]
  rows:
    - [acm_qn_eq,          abc.abstractclassmethod.__qualname__.__eq__,                   ["abstractclassmethod"], true, "abstractclassmethod.__qualname__ == 'abstractclassmethod' (len=19); verified with Python 3.14.3"]
    - [acm_qn_len,         abc.abstractclassmethod.__qualname__.__len__,                  [],                     19,   "abstractclassmethod.__qualname__.__len__() == 19 ('abstractclassmethod'=19); verified with Python 3.14.3"]
    - [acm_type_eq,        type(abc.abstractclassmethod).__name__.__eq__,                 ["type"],               true, "type(abstractclassmethod).__name__ == 'type' (deprecated class); verified with Python 3.14.3"]
    - [asm_qn_eq,          abc.abstractstaticmethod.__qualname__.__eq__,                  ["abstractstaticmethod"], true, "abstractstaticmethod.__qualname__ == 'abstractstaticmethod' (len=20); verified with Python 3.14.3"]
    - [asm_qn_len,         abc.abstractstaticmethod.__qualname__.__len__,                 [],                     20,   "abstractstaticmethod.__qualname__.__len__() == 20 ('abstractstaticmethod'=20); verified with Python 3.14.3"]
    - [asm_type_eq,        type(abc.abstractstaticmethod).__name__.__eq__,                ["type"],               true, "type(abstractstaticmethod).__name__ == 'type' (deprecated class); verified with Python 3.14.3"]
    - [acm_vs_asm_len,     abc.abstractstaticmethod.__qualname__.__len__,                 [],                     20,   "abstractstaticmethod len=20 > abstractclassmethod len=19 ('static'=6 vs 'class'=5, +1 char); verified with Python 3.14.3"]
    - [uam_longest,        abc.update_abstractmethods.__qualname__.__len__,               [],                     22,   "update_abstractmethods qualname len=22 (longest public name in abc, 2 more than abstractstaticmethod=20); verified with Python 3.14.3"]
    - [abc_shortest,       abc.ABC.__name__.__len__,                                      [],                     3,    "ABC name len=3 (shortest public name in abc, 17 less than abstractstaticmethod=20); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module identity attributes — extra107
#
# Wave 254 theme: abc module __name__, __package__, and __spec__.
#
# abc.__name__    == 'abc'  (len=3)
# abc.__package__ == ''     (len=0, empty string — top-level module)
# abc.__spec__.name == 'abc' (len=3)
# type(abc.__name__).__name__ == 'str'
# ---------------------------------------------------------------------------

table abc_extra107.abc_module_identity_attrs:
  description: "abc module __name__, __package__, and __spec__ attribute checks in abcnames107 namespace — wave 254 theme: abc.__name__.__eq__('abc')==True (len=3: 'abc'=3; the module name is the short string 'abc'; coincidentally same length as the public name 'ABC'=3); abc.__name__.__len__()==3; type(abc.__name__).__name__.__eq__('str')==True (module __name__ is a Python string); abc.__package__.__eq__('')==True (len=0: the package is an empty string — abc is a top-level module, not inside any package; __package__=='' for top-level modules unlike multiprocessing.__package__=='multiprocessing'); abc.__package__.__len__()==0; abc.__spec__.name.__eq__('abc')==True (len=3; the module spec name matches the module __name__); abc.__spec__.name.__len__()==3; abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (the spec is a ModuleSpec instance from importlib); compare: abc.__name__.__len__()==3 == abc.__spec__.name.__len__()==3 (same length, same value); abc.__package__.__len__()==0 (empty, shorter than __name__=3); abc.__name__='abc' (len=3) is shorter than all 8 public name strings except 'ABC'=3 (tied); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnames107b

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,        abc.__name__.__eq__,                                            ["abc"],                true, "abc.__name__ == 'abc' (len=3, same as 'ABC'=3 — tied shortest); verified with Python 3.14.3"]
    - [mod_name_len,       abc.__name__.__len__,                                           [],                     3,    "abc.__name__.__len__() == 3 ('abc'=3); verified with Python 3.14.3"]
    - [mod_name_type_eq,   type(abc.__name__).__name__.__eq__,                             ["str"],                true, "type(abc.__name__).__name__ == 'str' (module __name__ is a string); verified with Python 3.14.3"]
    - [mod_pkg_eq,         abc.__package__.__eq__,                                         [""],                   true, "abc.__package__ == '' (empty string, len=0 — top-level module, no package); verified with Python 3.14.3"]
    - [mod_pkg_len,        abc.__package__.__len__,                                        [],                     0,    "abc.__package__.__len__() == 0 (empty string — abc has no parent package); verified with Python 3.14.3"]
    - [spec_name_eq,       abc.__spec__.name.__eq__,                                       ["abc"],                true, "abc.__spec__.name == 'abc' (len=3, matches abc.__name__); verified with Python 3.14.3"]
    - [spec_name_len,      abc.__spec__.name.__len__,                                      [],                     3,    "abc.__spec__.name.__len__() == 3 ('abc'=3); verified with Python 3.14.3"]
    - [spec_class_eq,      abc.__spec__.__class__.__name__.__eq__,                         ["ModuleSpec"],         true, "abc.__spec__.__class__.__name__ == 'ModuleSpec' (importlib.machinery.ModuleSpec); verified with Python 3.14.3"]
    - [public_name_count,  abc.ABCMeta.__name__.__len__,                                   [],                     7,    "abc.ABCMeta.__name__.__len__() == 7 (cross-check: ABCMeta=7 is the second shortest public name after ABC=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra107
# ---------------------------------------------------------------------------

invariant abc_extra107.abstractstaticmethod_qualname_len_20:
  description: "abc.abstractstaticmethod.__qualname__.__len__() == 20 — 'abstractstaticmethod'=20 chars; this is the second longest public name in abc (after 'update_abstractmethods'=22); compare public name lengths: ABC=3 (shortest) < ABCMeta=7 < abstractmethod=14 < get_cache_token=15 < abstractproperty=16 < abstractclassmethod=19 < abstractstaticmethod=20 < update_abstractmethods=22 (longest); abstractstaticmethod=20 > abstractclassmethod=19 by 1 char ('static'=6 vs 'class'=5, +1 char); type(abc.abstractstaticmethod).__name__=='type' (deprecated class — subclass of staticmethod); abc.abstractstaticmethod.__qualname__=='abstractstaticmethod' (qualname equals name, top-level class); abc.abstractstaticmethod is deprecated since Python 3.3: use @staticmethod with @abstractmethod instead; NEW in extra107: first standalone abstractstaticmethod qualname length invariant in abcnames107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractstaticmethod.__qualname__.__len__
  args: []
  expected: 20

invariant abc_extra107.abstractclassmethod_qualname_len_19:
  description: "abc.abstractclassmethod.__qualname__.__len__() == 19 — 'abstractclassmethod'=19 chars; compare: abstractclassmethod=19 < abstractstaticmethod=20 < update_abstractmethods=22 (longest in spec); abstractclassmethod=19 > abstractproperty=16 by 3 chars; type(abc.abstractclassmethod).__name__=='type' (deprecated class — subclass of classmethod); abc.abstractclassmethod.__qualname__=='abstractclassmethod' (qualname equals name); abc.abstractclassmethod is deprecated since Python 3.3: use @classmethod with @abstractmethod instead; compare with abstractstaticmethod: both have type='type', both are deprecated, abstractclassmethod qualname len=19 is 1 shorter than abstractstaticmethod=20 ('class'=5 vs 'static'=6 in the name); NEW in extra107: first standalone abstractclassmethod qualname length invariant in abcnames107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractclassmethod.__qualname__.__len__
  args: []
  expected: 19

invariant abc_extra107.abc_module_name_len_3:
  description: "abc.__name__.__len__() == 3 — 'abc'=3 chars; abc.__name__=='abc' (the module name is just 'abc'); type(abc.__name__).__name__=='str'; compare: abc.__name__.__len__()==3 == abc.ABC.__name__.__len__()==3 (coincidental tie: both the module name 'abc' and the public class name 'ABC' have length 3); abc.__name__='abc' (all lowercase) vs 'ABC' (all uppercase) — different strings, same length; abc.__package__=='' (empty string, len=0 — shorter than __name__=3); abc.__spec__.name=='abc' (len=3, same as __name__); compare: abc.__name__.__len__()==3 < ABCMeta.__qualname__.__len__()==7 < abstractmethod.__qualname__.__len__()==14 (all public names are at least as long as the module name); abc is a simple 3-letter module name — among the shortest in Python's standard library; NEW in extra107: first standalone abc.__name__ length invariant in abcnames107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.__name__.__len__
  args: []
  expected: 3

invariant abc_extra107.abc_package_is_empty_string:
  description: "abc.__package__.__eq__('') returns True — abc.__package__ is the empty string '' (len=0); abc is a top-level module, not inside any package; compare: abc.__package__=='' (len=0) vs multiprocessing.__package__=='multiprocessing' (len=15) — a top-level package sets __package__ to its own name; abc.__package__.__len__()==0 (empty string is the shortest possible string value); abc.__name__=='abc' (len=3, non-empty); abc.__spec__.name=='abc' (len=3); the empty __package__ means abc does not belong to any parent package namespace; abc.__package__ being '' is different from multiprocessing.__package__=='multiprocessing' (len=15) and concurrent.futures.__package__ (which would be 'concurrent.futures'); type(abc.__package__).__name__=='str' (it is still a str, just an empty one); NEW in extra107: first standalone abc.__package__ empty string invariant in abcnames107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.__package__.__eq__
  args: [""]
  expected: true

invariant abc_extra107.update_abstractmethods_is_longest_public_name:
  description: "abc.update_abstractmethods.__qualname__.__len__() == 22 — 'update_abstractmethods'=22 chars; this is the longest public name in abc; compare all 8 public abc names by length: ABC=3 (shortest) < ABCMeta=7 < abstractmethod=14 < get_cache_token=15 < abstractproperty=16 < abstractclassmethod=19 < abstractstaticmethod=20 < update_abstractmethods=22 (longest by 2 chars over abstractstaticmethod=20); the 8 public names are all unique in length except two tied pairs would only occur if lengths matched — in this spec all 8 have distinct lengths; update_abstractmethods was added in Python 3.10 to allow dynamic re-registration of abstract methods; abc.update_abstractmethods.__qualname__=='update_abstractmethods' (qualname matches name for module-level function); type(abc.update_abstractmethods).__name__=='function' (Python-defined); abc.update_abstractmethods.__code__.co_argcount==1 (takes cls); longest name in abc is 22 chars while shortest is 3 chars (ABC) — a ratio of 22/3 ≈ 7.3x; NEW in extra107: first standalone update_abstractmethods longest-name invariant in abcnames107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__qualname__.__len__
  args: []
  expected: 22
