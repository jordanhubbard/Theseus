spec: functools_extra229
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools function __code__ attribute contracts."
    - "functools.lru_cache.__code__.co_argcount == 2 (maxsize, typed). Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_argcount == 1 (func). Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_argcount == 3 (wrapped, assigned, updated). Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_argcount == 4 (wrapper, wrapped, assigned, updated). Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_argcount == 1 (cls). Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_varnames[0] == 'maxsize' — first parameter is maxsize. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_name == 'wraps'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_name == 'update_wrapper'. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_name == 'lru_cache'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools function __code__.co_argcount checks
#
# Verified with Python 3.14.3:
#   functools.lru_cache.__code__.co_argcount == 2   (maxsize, typed)
#   functools.singledispatch.__code__.co_argcount == 1   (func)
#   functools.wraps.__code__.co_argcount == 3   (wrapped, assigned, updated)
#   functools.update_wrapper.__code__.co_argcount == 4   (wrapper, wrapped, assigned, updated)
#   functools.total_ordering.__code__.co_argcount == 1   (cls)
# ---------------------------------------------------------------------------

table functools_extra229.func_code_co_argcount:
  description: "functools function __code__.co_argcount checks; new to extra229"
  kind: python_call_eq
  category: code_inspection
  id_prefix: functoolsextra229coa

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_co_argcount_eq,
       lru_cache.__code__.co_argcount.__eq__,
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache(maxsize=128, typed=False) has 2 positional params; co_argcount is 2; int.__eq__(2) returns True; new to extra229"]
    - [singledispatch_co_argcount_eq,
       singledispatch.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch(func) has 1 positional param; co_argcount is 1; int.__eq__(1) returns True; new to extra229"]
    - [wraps_co_argcount_eq,
       wraps.__code__.co_argcount.__eq__,
       [3],
       true,
       "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps(wrapped, assigned, updated) has 3 positional params; co_argcount is 3; int.__eq__(3) returns True; new to extra229"]
    - [update_wrapper_co_argcount_eq,
       update_wrapper.__code__.co_argcount.__eq__,
       [4],
       true,
       "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper(wrapper, wrapped, assigned, updated) has 4 positional params; co_argcount is 4; int.__eq__(4) returns True; new to extra229"]
    - [total_ordering_co_argcount_eq,
       total_ordering.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering(cls) has 1 positional param; co_argcount is 1; int.__eq__(1) returns True; new to extra229"]

# ---------------------------------------------------------------------------
# Table 2: functools function __code__.co_name checks
#
# Verified with Python 3.14.3:
#   functools.wraps.__code__.co_name == 'wraps'
#   functools.update_wrapper.__code__.co_name == 'update_wrapper'
#   functools.lru_cache.__code__.co_name == 'lru_cache'
# ---------------------------------------------------------------------------

table functools_extra229.func_code_co_name:
  description: "functools function __code__.co_name checks; new to extra229"
  kind: python_call_eq
  category: code_inspection
  id_prefix: functoolsextra229coname

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_co_name_eq,
       wraps.__code__.co_name.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__code__.co_name.__eq__('wraps') == True — co_name is the code object's function name; str.__eq__('wraps') returns True; new to extra229"]
    - [update_wrapper_co_name_eq,
       update_wrapper.__code__.co_name.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True — co_name is the code object's function name; str.__eq__('update_wrapper') returns True; new to extra229"]
    - [lru_cache_co_name_eq,
       lru_cache.__code__.co_name.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — co_name is the code object's function name; str.__eq__('lru_cache') returns True; new to extra229"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra229
# ---------------------------------------------------------------------------

invariant functools_extra229.lru_cache_co_argcount:
  description: "functools.lru_cache.__code__.co_argcount == 2 — lru_cache takes maxsize and typed; new to extra229"
  kind: python_call_eq
  function: lru_cache.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant functools_extra229.singledispatch_co_argcount:
  description: "functools.singledispatch.__code__.co_argcount == 1 — singledispatch takes func; new to extra229"
  kind: python_call_eq
  function: singledispatch.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra229.wraps_co_argcount:
  description: "functools.wraps.__code__.co_argcount == 3 — wraps takes wrapped, assigned, updated; new to extra229"
  kind: python_call_eq
  function: wraps.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant functools_extra229.update_wrapper_co_argcount:
  description: "functools.update_wrapper.__code__.co_argcount == 4 — update_wrapper takes wrapper, wrapped, assigned, updated; new to extra229"
  kind: python_call_eq
  function: update_wrapper.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant functools_extra229.total_ordering_co_argcount:
  description: "functools.total_ordering.__code__.co_argcount == 1 — total_ordering takes cls; new to extra229"
  kind: python_call_eq
  function: total_ordering.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra229.lru_cache_co_varnames_0:
  description: "functools.lru_cache.__code__.co_varnames[0] == 'maxsize' — first variable is maxsize; new to extra229"
  kind: python_call_eq
  function: lru_cache.__code__.co_varnames.__getitem__
  args: [0]
  expected: "maxsize"

invariant functools_extra229.wraps_co_name:
  description: "functools.wraps.__code__.co_name == 'wraps' — co_name matches function name; new to extra229"
  kind: python_call_eq
  function: wraps.__code__.co_name.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra229.update_wrapper_co_name:
  description: "functools.update_wrapper.__code__.co_name == 'update_wrapper' — co_name matches function name; new to extra229"
  kind: python_call_eq
  function: update_wrapper.__code__.co_name.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra229.lru_cache_co_name:
  description: "functools.lru_cache.__code__.co_name == 'lru_cache' — co_name matches function name; new to extra229"
  kind: python_call_eq
  function: lru_cache.__code__.co_name.__eq__
  args: ["lru_cache"]
  expected: true
