spec: array_range
version: ">=1.0.1"
backend: node(array-range)

docs: https://www.npmjs.com/package/array-range

provenance:
  derived_from:
    - "array-range README — https://www.npmjs.com/package/array-range"
    - "Test vectors verified with array-range via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-range source"
  notes:
    - "array-range is an npm package. Install: npm install array-range"
    - "Creates an array of integers from 0 (or start) up to but not including end."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of integers."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_range.range:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: arange

  columns: [id, args, expected]
  rows:
    - [from_zero,   [5],     [0, 1, 2, 3, 4]]
    - [with_start,  [3, 7],  [3, 4, 5, 6]]
    - [one,         [1],     [0]]

