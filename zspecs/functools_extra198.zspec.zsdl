       true,
       "functools.cached_property.__get__.__qualname__.__eq__('cached_property.__get__') == True — __get__ implements the descriptor protocol for cached_property; __qualname__ is 'cached_property.__get__' (len=23); str.__eq__('cached_property.__get__') returns True; verified with Python 3.14.3; new to extra198"]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property __set_name__ and __doc__ identity
#
# functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' (len=28)
# functools.cached_property.__doc__.__class__.__name__ == 'NoneType' (len=8)
#
# __set_name__ is the descriptor hook called by type.__new__ when the class
# is created. cached_property has no docstring in Python 3.14 (__doc__ is None),
# so __doc__.__class__.__name__ is 'NoneType'. New to extra198.
# ---------------------------------------------------------------------------

table functools_extra198.cached_property_set_name_doc:
  description: "functools.cached_property __set_name__ and __doc__: __set_name__.__qualname__=='cached_property.__set_name__'(len=28); __doc__.__class__.__name__=='NoneType'(len=8); new to extra198"
