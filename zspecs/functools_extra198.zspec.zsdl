       ["cached_property.__set_name__"],
       true,
       "functools.cached_property.__set_name__.__qualname__.__eq__('cached_property.__set_name__') == True — __set_name__ is the descriptor hook called by type.__new__; __qualname__ is 'cached_property.__set_name__' (len=28); str.__eq__('cached_property.__set_name__') returns True; verified with Python 3.14.3; new to extra198"]
    - [cachedprop_set_name_qualname_len,
