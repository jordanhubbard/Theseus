spec: functools_extra198
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.cached_property.__name__ == 'cached_property' (len=15); cached_property is a descriptor class defined in functools.py; verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools' (len=9); defined at top level in functools.py; verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' (len=6); cached_property has no special superclass, inherits directly from object; verified with Python 3.14.3."
    - "functools.cached_property.__class__.__name__ == 'type' (len=4); cached_property is a class, so its metaclass is the builtin type; verified with Python 3.14.3."
    - "functools.cached_property.__init__.__qualname__ == 'cached_property.__init__' (len=24); qualified name reflects class nesting; verified with Python 3.14.3."
    - "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__' (len=23); descriptor protocol __get__ method; verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' (len=28); descriptor hook __set_name__ method; verified with Python 3.14.3."
    - "functools.cached_property.__doc__.__class__.__name__ == 'NoneType' (len=8); cached_property has no docstring (None) in Python 3.14.3; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cached_property name, module, and base class identity
#
# functools.cached_property.__name__           == 'cached_property' (len=15)
# functools.cached_property.__module__         == 'functools' (len=9)
# functools.cached_property.__bases__[0].__name__ == 'object' (len=6)
#
# cached_property is a pure-Python descriptor class defined in functools.py.
# It has no special superclass and its __module__ is 'functools'.
# New to extra198.
# ---------------------------------------------------------------------------

table functools_extra198.cached_property_name_module_base:
  description: "functools.cached_property identity: __name__=='cached_property'(len=15); __module__=='functools'(len=9); __bases__[0].__name__=='object'(len=6); new to extra198"
  kind: python_call_eq
  category: identity
  id_prefix: functcachedprop198

  columns: [id, function, args, expected, description]
  rows:
    - [cachedprop_name_eq,
       cached_property.__name__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is a descriptor class defined in functools.py; __name__ is 'cached_property' (len=15); str.__eq__('cached_property') returns True; verified with Python 3.14.3; new to extra198"]
    - [cachedprop_name_len,
       cached_property.__name__.__len__,
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has 15 characters: c-a-c-h-e-d-_-p-r-o-p-e-r-t-y; str.__len__() returns 15; verified with Python 3.14.3; new to extra198"]
    - [cachedprop_module_eq,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in functools.py so __module__ is 'functools' (len=9); str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra198"]
    - [cachedprop_module_len,
       cached_property.__module__.__len__,
       [],
       9,
       "functools.cached_property.__module__.__len__() == 9 — 'functools' has 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra198"]
    - [cachedprop_base_name_eq,
       "cached_property.__bases__.__getitem__(0).__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property inherits directly from object with no special superclass; __bases__[0].__name__ is 'object' (len=6); str.__eq__('object') returns True; verified with Python 3.14.3; new to extra198"]

# ---------------------------------------------------------------------------
# Table 2: functools.cached_property metaclass and qualnames
#
# functools.cached_property.__class__.__name__         == 'type' (len=4)
# functools.cached_property.__init__.__qualname__      == 'cached_property.__init__' (len=24)
# functools.cached_property.__get__.__qualname__       == 'cached_property.__get__' (len=23)
#
# cached_property's metaclass is the builtin 'type'. The __init__, __get__
# and __set_name__ qualnames all carry the class prefix 'cached_property.'.
# New to extra198.
# ---------------------------------------------------------------------------

