       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a class so its metaclass is the builtin 'type'; __class__.__name__ is 'type' (len=4); str.__eq__('type') returns True; verified with Python 3.14.3; new to extra198"]
    - [cachedprop_class_name_len,
       cached_property.__class__.__name__.__len__,
