spec: theseus_gc_cr
version: ">=3.8"
backend: python_cleanroom(theseus_gc_cr)
blocks: gc

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/gc.html"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "Clean-room gc module. Do NOT import gc."
    - "Wraps the built-in gc module via _gc or direct access."

error_model: python_exceptions

invariant theseus_gc_cr.gc2_collect:
  description: "collect() runs garbage collection"
  category: behavior
  kind: python_call_eq
  function: gc2_collect
  args: []
  expected: true

invariant theseus_gc_cr.gc2_enable_disable:
  description: "enable/disable controls GC and isenabled reflects state"
  category: behavior
  kind: python_call_eq
  function: gc2_enable_disable
  args: []
  expected: true

invariant theseus_gc_cr.gc2_get_objects:
  description: "get_objects returns list of tracked objects"
  category: behavior
  kind: python_call_eq
  function: gc2_get_objects
  args: []
  expected: true
