spec: decimal_extra796
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - decimal module CPython source
    - Python standard library documentation
  not_derived_from:
    - any third-party decimal or numeric libraries
  notes:
    - Covers decimal.Context arithmetic and logical operation method qualnames
    - Continues coverage of Context methods beyond basic arithmetic
  created_at: "2026-04-12"

table decimal_extra796.name:
  description: Verify __qualname__ attributes for decimal.Context arithmetic and logical methods
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: dc796xx
  columns: [id, function, args, expected]
  rows:
    - [dc796xx001, decimal.Context.exp.__qualname__.__eq__, ["Context.exp"], true]
    - [dc796xx002, decimal.Context.ln.__qualname__.__eq__, ["Context.ln"], true]
    - [dc796xx003, decimal.Context.log10.__qualname__.__eq__, ["Context.log10"], true]
    - [dc796xx004, decimal.Context.logb.__qualname__.__eq__, ["Context.logb"], true]
    - [dc796xx005, decimal.Context.logical_and.__qualname__.__eq__, ["Context.logical_and"], true]
    - [dc796xx006, decimal.Context.logical_or.__qualname__.__eq__, ["Context.logical_or"], true]
    - [dc796xx007, decimal.Context.logical_xor.__qualname__.__eq__, ["Context.logical_xor"], true]
    - [dc796xx008, decimal.Context.logical_invert.__qualname__.__eq__, ["Context.logical_invert"], true]
    - [dc796xx009, decimal.Context.normalize.__qualname__.__eq__, ["Context.normalize"], true]
    - [dc796xx010, decimal.Context.quantize.__qualname__.__eq__, ["Context.quantize"], true]
    - [dc796xx011, decimal.Context.rotate.__qualname__.__eq__, ["Context.rotate"], true]
    - [dc796xx012, decimal.Context.shift.__qualname__.__eq__, ["Context.shift"], true]
