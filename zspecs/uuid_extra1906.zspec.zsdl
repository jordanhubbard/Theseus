spec: uuid_extra1906
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "uuid.UUID is a pure-Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "uuid.SafeUUID is an enum.Enum subclass; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "uuid.UUID.__qualname__ == 'UUID' — top-level Python class defined in uuid.py."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID' — top-level Python enum class defined in uuid.py."
    - "uuid.UUID.__dict__ contains property-based attrs: hex, bytes, int, version, variant, fields, node, clock_seq, time, urn, bytes_le."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra1906.reversed_protocol:
  description: "uuid types __reversed__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1906

  columns: [id, function, args, expected]
  rows:
    - ["uu1906001", "uuid.UUID.__dict__.__contains__", ["__reversed__"], false]
    - ["uu1906002", "uuid.SafeUUID.__dict__.__contains__", ["__reversed__"], false]

table uuid_extra1906.missing_protocol:
  description: "uuid types __missing__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1906

  columns: [id, function, args, expected]
  rows:
    - ["uu1906011", "uuid.UUID.__dict__.__contains__", ["__missing__"], false]
    - ["uu1906012", "uuid.SafeUUID.__dict__.__contains__", ["__missing__"], false]

table uuid_extra1906.match_args_protocol:
  description: "uuid types __match_args__ dict-presence checks (structural pattern matching, 3.10+)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1906

  columns: [id, function, args, expected]
  rows:
    - ["uu1906021", "uuid.UUID.__dict__.__contains__", ["__match_args__"], false]
    - ["uu1906022", "uuid.SafeUUID.__dict__.__contains__", ["__match_args__"], false]

table uuid_extra1906.qualname_values:
  description: "uuid class __qualname__ and __name__ values"
  kind: python_call_eq
  category: qualname_values
  id_prefix: uu1906

  columns: [id, function, args, expected]
  rows:
    - ["uu1906031", "uuid.UUID.__qualname__", [], "UUID"]
    - ["uu1906032", "uuid.SafeUUID.__qualname__", [], "SafeUUID"]
    - ["uu1906033", "uuid.UUID.__name__", [], "UUID"]
    - ["uu1906034", "uuid.SafeUUID.__name__", [], "SafeUUID"]
    - ["uu1906035", "uuid.UUID.__module__", [], "uuid"]
    - ["uu1906036", "uuid.SafeUUID.__module__", [], "uuid"]

table uuid_extra1906.uuid_dict_property_presence:
  description: "uuid.UUID __dict__ contains expected property descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1906

  columns: [id, function, args, expected]
  rows:
    - ["uu1906041", "uuid.UUID.__dict__.__contains__", ["hex"], true]
    - ["uu1906042", "uuid.UUID.__dict__.__contains__", ["bytes"], true]
    - ["uu1906043", "uuid.UUID.__dict__.__contains__", ["int"], true]
    - ["uu1906044", "uuid.UUID.__dict__.__contains__", ["version"], true]
    - ["uu1906045", "uuid.UUID.__dict__.__contains__", ["variant"], true]
    - ["uu1906046", "uuid.UUID.__dict__.__contains__", ["fields"], true]
    - ["uu1906047", "uuid.UUID.__dict__.__contains__", ["node"], true]
    - ["uu1906048", "uuid.UUID.__dict__.__contains__", ["clock_seq"], true]
    - ["uu1906049", "uuid.UUID.__dict__.__contains__", ["time"], true]
    - ["uu1906050", "uuid.UUID.__dict__.__contains__", ["urn"], true]
    - ["uu1906051", "uuid.UUID.__dict__.__contains__", ["bytes_le"], true]

table uuid_extra1906.uuid_dict_absent_protocol_attrs:
  description: "uuid.UUID __dict__ absent dunder protocol attrs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1906

  columns: [id, function, args, expected]
  rows:
    - ["uu1906061", "uuid.UUID.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["uu1906062", "uuid.UUID.__dict__.__contains__", ["__type_params__"], false]
    - ["uu1906063", "uuid.UUID.__dict__.__contains__", ["__length_hint__"], false]
    - ["uu1906064", "uuid.SafeUUID.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["uu1906065", "uuid.SafeUUID.__dict__.__contains__", ["__length_hint__"], false]
    - ["uu1906066", "uuid.SafeUUID.__dict__.__contains__", ["__type_params__"], false]
    - ["uu1906067", "uuid.UUID.__dict__.__contains__", ["__init__"], true]
