spec: abc_extra155
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta.__subclasscheck__ and abc.ABCMeta.__instancecheck__ full qualname strings (wave 322 checked lengths; this spec verifies the actual string values), abc.ABCMeta.register.__code__.co_argcount, and abc.ABCMeta._dump_registry.__qualname__. abc.ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25: 'ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25; '__subclasscheck__'='_'+'_'+'subclasscheck'=13+'_'+'_'=2+13+2=17... wait: 'subclasscheck'='s'+'u'+'b'+'c'+'l'+'a'+'s'+'s'+'c'+'h'+'e'+'c'+'k'=13; '__subclasscheck__'=2+13+2=17; 'ABCMeta.__subclasscheck__'=7+1+17=25); abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: same length as __subclasscheck__ because '__instancecheck__'=2+13+2=17 and 'instancecheck'=13 same length as 'subclasscheck'=13); abc.ABCMeta.register.__code__.co_argcount==2 (register takes self and subclass — 2 positional parameters); abc.ABCMeta._dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22: 'ABCMeta'=7+'.'=1+'_dump_registry'=14=22; '_dump_registry'='_'=1+'dump'=4+'_'=1+'registry'=8=14). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25) and abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25) — both qualnames are exactly length 25 because '__subclasscheck__'=17 and '__instancecheck__'=17 are the same length ('subclasscheck'=13=='instancecheck'=13); ABCMeta defines both to implement isinstance() and issubclass() checks for ABCs, including virtual subclass support via register(); both are pure Python functions (__class__.__name__=='function'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.register.__code__.co_argcount==2 — register(cls, subclass) takes 2 positional parameters: cls (the ABCMeta instance, i.e. the abstract class) and subclass (the class to register as a virtual subclass); after registration, isinstance(subclass(), cls) returns True and issubclass(subclass, cls) returns True even if subclass does not actually inherit from cls; register.__qualname__=='ABCMeta.register' (len=16: established in prior specs). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta._dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22: 'ABCMeta'=7+'.'=1+'_dump_registry'=14=22); _dump_registry is a debugging helper method that prints the registered virtual subclasses of an ABC to a file; the leading underscore indicates it is a private/internal method; '_dump_registry'='_'=1+'dump'=4+'_'=1+'registry'=8=14; qualname length ordering in abc: register(16) < _dump_registry(22) < __subclasscheck__(25) == __instancecheck__(25). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__subclasscheck__ qualname — extra155
#
# abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') == True
# abc.ABCMeta.__subclasscheck__.__qualname__.__len__()                            == 25
# ---------------------------------------------------------------------------

table abc_extra155.abc_abcmeta_subclasscheck_qualname:
  description: "abc.ABCMeta.__subclasscheck__ qualname checks in abcsc155 namespace — abc.ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25: 'ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25; '__subclasscheck__'='_'+'_'+'subclasscheck'=13+'_'+'_'=2+13+2=17; 'subclasscheck'=13: 'subclass'=8+'check'=5=13); ABCMeta defines __subclasscheck__ to implement issubclass() for ABCs — it checks both real subclasses (via inheritance) and virtual subclasses (registered via register()); __subclasscheck__.__class__.__name__=='function' (pure Python method); qualname 'ABCMeta.__subclasscheck__' (len=25) is the longest abc qualname in the series; compare: ABCMeta.register.__qualname__=='ABCMeta.register' (len=16; shorter), ABCMeta._dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22; shorter); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcsc155

  columns: [id, function, args, expected, description]
  rows:
    - [sc_qn_eq,    abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,    ["ABCMeta.__subclasscheck__"],  true,  "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25); verified with Python 3.14.3"]
    - [sc_qn_len,   abc.ABCMeta.__subclasscheck__.__qualname__.__len__,   [],                             25,    "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 (longest abc qualname); verified with Python 3.14.3"]
    - [sc_cls_eq,   abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__, ["function"],                true,  "abc.ABCMeta.__subclasscheck__.__class__.__name__ == 'function' (pure Python method); verified with Python 3.14.3"]
    - [reg_qn_len,  abc.ABCMeta.register.__qualname__.__len__,            [],                             16,    "cross-reference: abc.ABCMeta.register.__qualname__.__len__() == 16 ('ABCMeta.register'; shorter than __subclasscheck__=25); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__instancecheck__ qualname — extra155
#
# abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') == True
# abc.ABCMeta.__instancecheck__.__qualname__.__len__()                            == 25
# ---------------------------------------------------------------------------

table abc_extra155.abc_abcmeta_instancecheck_qualname:
  description: "abc.ABCMeta.__instancecheck__ qualname checks in abcic155 namespace — abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25; '__instancecheck__'='_'+'_'+'instancecheck'=13+'_'+'_'=2+13+2=17; 'instancecheck'=13: 'instance'=8+'check'=5=13 — same length as 'subclasscheck'=13); both __instancecheck__ and __subclasscheck__ have qualname length 25 because '__instancecheck__' and '__subclasscheck__' are both 17 chars; ABCMeta defines __instancecheck__ to implement isinstance() for ABCs — it checks both real instances (via type check) and virtual subclasses (registered via register()); __instancecheck__.__class__.__name__=='function' (pure Python method); compare: abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15; established in extra153; shorter than __instancecheck__=25); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcic155

  columns: [id, function, args, expected, description]
  rows:
    - [ic_qn_eq,    abc.ABCMeta.__instancecheck__.__qualname__.__eq__,    ["ABCMeta.__instancecheck__"],  true,  "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25); verified with Python 3.14.3"]
    - [ic_qn_len,   abc.ABCMeta.__instancecheck__.__qualname__.__len__,   [],                             25,    "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 (same length as __subclasscheck__=25); verified with Python 3.14.3"]
    - [ic_cls_eq,   abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__, ["function"],                true,  "abc.ABCMeta.__instancecheck__.__class__.__name__ == 'function' (pure Python method); verified with Python 3.14.3"]
    - [sc_qn_eq2,   abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,   ["ABCMeta.__subclasscheck__"],   true,  "cross-reference: __subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (same len=25 as __instancecheck__); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.register co_argcount and abc.ABCMeta._dump_registry qualname — extra155
#
# abc.ABCMeta.register.__code__.co_argcount    == 2
# abc.ABCMeta._dump_registry.__qualname__.__eq__('ABCMeta._dump_registry') == True
# ---------------------------------------------------------------------------

table abc_extra155.abc_abcmeta_register_dump_registry:
  description: "abc.ABCMeta.register co_argcount and abc.ABCMeta._dump_registry qualname checks in abcrd155 namespace — abc.ABCMeta.register.__code__.co_argcount==2 (register(cls, subclass) takes 2 positional parameters: cls is the ABCMeta-metaclassed class (the ABC) and subclass is the class to register as a virtual subclass; after registration issubclass(subclass, cls) and isinstance(subclass(), cls) return True even without real inheritance); abc.ABCMeta._dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22: 'ABCMeta'=7+'.'=1+'_dump_registry'=14=22; '_dump_registry'='_'=1+'dump'=4+'_'=1+'registry'=8=14; the leading underscore indicates it is a private debugging method); qualname length ordering: register(16) < _dump_registry(22) < __instancecheck__(25) == __subclasscheck__(25); _dump_registry is 6 chars longer than register (22 vs 16) and 3 chars shorter than the check methods (25 vs 22); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcrd155

  columns: [id, function, args, expected, description]
  rows:
    - [reg_argc,     abc.ABCMeta.register.__code__.co_argcount.__eq__,     [2],                           true,  "abc.ABCMeta.register.__code__.co_argcount == 2 (cls, subclass); verified with Python 3.14.3"]
    - [dr_qn_eq,     abc.ABCMeta._dump_registry.__qualname__.__eq__,       ["ABCMeta._dump_registry"],    true,  "abc.ABCMeta._dump_registry.__qualname__ == 'ABCMeta._dump_registry' (len=22); verified with Python 3.14.3"]
    - [dr_qn_len,    abc.ABCMeta._dump_registry.__qualname__.__len__,      [],                            22,    "abc.ABCMeta._dump_registry.__qualname__.__len__() == 22 ('ABCMeta._dump_registry'; between register=16 and check methods=25); verified with Python 3.14.3"]
    - [reg_qn_eq,    abc.ABCMeta.register.__qualname__.__eq__,             ["ABCMeta.register"],           true,  "cross-reference: abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16; established in prior specs); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra155
# ---------------------------------------------------------------------------

invariant abc_extra155.abc_ABCMeta_subclasscheck_qualname_eq:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') returns True — ABCMeta defines __subclasscheck__ to customize the behavior of issubclass(C, ABC); __subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25: 'ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25; '__subclasscheck__'='_'+'_'+'subclasscheck'=13+'_'+'_'=17; 'subclasscheck'='subclass'=8+'check'=5=13); ABCMeta.__subclasscheck__ first checks the real MRO (via type.__subclasscheck__) and then checks the set of registered virtual subclasses; the qualname starting with 'ABCMeta.' confirms it is defined on ABCMeta itself (not inherited from type); prior wave 322 checked len==25 (the length); this spec verifies the full string 'ABCMeta.__subclasscheck__'; compare: ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25; same length — both check-method qualnames are equal length); NEW in extra155: first standalone __subclasscheck__.__qualname__ identity invariant in abcsc155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true

invariant abc_extra155.abc_ABCMeta_instancecheck_qualname_eq:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') returns True — ABCMeta defines __instancecheck__ to customize the behavior of isinstance(obj, ABC); __instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25; '__instancecheck__'='_'+'_'+'instancecheck'=13+'_'+'_'=17; 'instancecheck'='instance'=8+'check'=5=13); ABCMeta.__instancecheck__ calls __subclasscheck__(type(obj), cls) to check both real and virtual subclasses; both __instancecheck__ and __subclasscheck__ have exactly the same qualname length (25) because 'instancecheck' and 'subclasscheck' are both 13 chars; the qualname 'ABCMeta.__instancecheck__' confirms it is defined on ABCMeta (not inherited from type.__instancecheck__); prior wave 322 checked len==25; this spec verifies the full string; NEW in extra155: first standalone __instancecheck__.__qualname__ identity invariant in abcic155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra155.abc_ABCMeta_register_co_argcount:
  description: "abc.ABCMeta.register.__code__.co_argcount.__eq__(2) returns True — abc.ABCMeta.register takes 2 positional parameters: cls (the abstract class, the ABCMeta instance) and subclass (the class to register as a virtual subclass); co_argcount==2 counts positional and positional-or-keyword parameters; register(cls, subclass) registers subclass as a virtual subclass of cls so that issubclass(subclass, cls) and isinstance(subclass(), cls) return True even if subclass does not inherit from cls; register.__qualname__=='ABCMeta.register' (len=16; established in prior specs); register.__code__.co_argcount==2 is a count of 2 parameters (self/cls is always counted in co_argcount for unbound methods accessed via the class); compare: abc.ABCMeta.__subclasscheck__.__code__.co_argcount would also be 2 (self/cls + subclass); NEW in extra155: first standalone abc.ABCMeta.register co_argcount invariant in abcrd155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant abc_extra155.abc_ABCMeta_dump_registry_qualname_eq:
  description: "abc.ABCMeta._dump_registry.__qualname__.__eq__('ABCMeta._dump_registry') returns True — abc.ABCMeta._dump_registry is a private debugging method that prints the set of registered virtual subclasses to a file (default: sys.stdout); _dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22: 'ABCMeta'=7+'.'=1+'_dump_registry'=14=22; '_dump_registry'='_'=1+'dump'=4+'_'=1+'registry'=8=14); the leading underscore in '_dump_registry' signals it is a private/internal method not part of the public ABC API; qualname length ordering among ABCMeta methods: register(16) < _dump_registry(22) < __subclasscheck__(25) == __instancecheck__(25); _dump_registry (22) is 6 longer than register (16) and 3 shorter than the check methods (25); _dump_registry.__qualname__ starts with 'ABCMeta.' confirming it is defined on ABCMeta (not inherited from type); NEW in extra155: first standalone abc.ABCMeta._dump_registry.__qualname__ identity invariant in abcrd155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta._dump_registry.__qualname__.__eq__
  args: ["ABCMeta._dump_registry"]
  expected: true

invariant abc_extra155.abc_ABCMeta_subclasscheck_qualname_len:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__len__().__eq__(25) — expressing the length check as an eq invariant: the qualname 'ABCMeta.__subclasscheck__' has length 25 ('ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25; '__subclasscheck__'=2+13+2=17 where 'subclasscheck'=13); abc.ABCMeta.__instancecheck__.__qualname__.__len__() is also 25 ('ABCMeta.__instancecheck__'=7+1+17=25 where '__instancecheck__'=2+13+2=17 and 'instancecheck'=13); the two check-method qualnames are equal in length because 'subclasscheck' and 'instancecheck' are both exactly 13 characters ('subclass'=8+'check'=5=13 and 'instance'=8+'check'=5=13 — both share the 5-char 'check' suffix and an 8-char prefix); the equality of these lengths confirms the symmetric design of ABC's isinstance/issubclass overrides; compare: ABCMeta._dump_registry.__qualname__.__len__()==22 (3 shorter); NEW in extra155: first standalone qualname-length invariant for __subclasscheck__ in abcsc155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__qualname__.__len__
  args: []
  expected: 25
