spec: subprocess_extra18
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra6.zspec.zsdl — covers __qualname__ for Popen/CompletedProcess/CalledProcessError/TimeoutExpired/SubprocessError/run/call/check_call/check_output/getoutput/getstatusoutput."
    - "subprocess_extra13.zspec.zsdl — covers standalone qualname equality for CalledProcessError/TimeoutExpired/SubprocessError."
    - "subprocess_extra16.zspec.zsdl — covers __qualname__ for Popen instance methods communicate/wait/poll/kill/terminate/send_signal."
    - "subprocess_extra17.zspec.zsdl — covers Popen.__init__/__repr__ qualnames; __name__/__package__; PIPE/STDOUT/DEVNULL __class__.__qualname__."
  notes:
    - "This spec extends subprocess.zspec.zsdl and all prior subprocess_extra specs through subprocess_extra17.zspec.zsdl."
    - "Focus: __module__ attributes for subprocess classes (Popen, CompletedProcess, CalledProcessError, TimeoutExpired, SubprocessError) and module-level functions (run, call, check_output, check_call); exception class base class names (__bases__[0].__name__)."
    - "subprocess.Popen.__module__ == 'subprocess' — class defined in the subprocess module; not covered in any prior subprocess spec."
    - "subprocess.CompletedProcess.__module__ == 'subprocess' — not covered in any prior subprocess spec."
    - "subprocess.CalledProcessError.__module__ == 'subprocess' — not covered in any prior subprocess spec."
    - "subprocess.TimeoutExpired.__module__ == 'subprocess' — not covered in any prior subprocess spec."
    - "subprocess.SubprocessError.__module__ == 'subprocess' — not covered in any prior subprocess spec."
    - "subprocess.CalledProcessError.__bases__[0].__name__ == 'SubprocessError' — CalledProcessError inherits from SubprocessError; not covered in any prior subprocess spec."
    - "subprocess.TimeoutExpired.__bases__[0].__name__ == 'SubprocessError' — TimeoutExpired inherits from SubprocessError; not covered in any prior subprocess spec."
    - "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception' — SubprocessError inherits from Exception; not covered in any prior subprocess spec."
    - "subprocess.run.__module__ == 'subprocess' — function's module attribute; not covered in any prior subprocess spec."
    - "subprocess.call.__module__ == 'subprocess' — not covered in any prior subprocess spec."
    - "subprocess.check_output.__module__ == 'subprocess' — not covered in any prior subprocess spec."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# subprocess class __module__ attributes
#
# subprocess_extra6 covers __qualname__ for all five subprocess classes.
# No prior subprocess spec checks the __module__ attribute for any class.
# All five classes are defined directly in subprocess.py, so their __module__
# is 'subprocess'.
# ---------------------------------------------------------------------------

table subprocess_extra18.class_modules:
  description: "__module__ for subprocess classes is 'subprocess'"
  kind: python_call_eq
  category: module_attrs
  id_prefix: clsmod18

  columns: [id, function, args, expected]
  rows:
    - [Popen,             Popen.__module__.__eq__,             ["subprocess"], true]
    - [CompletedProcess,  CompletedProcess.__module__.__eq__,  ["subprocess"], true]
    - [CalledProcessError, CalledProcessError.__module__.__eq__, ["subprocess"], true]
    - [TimeoutExpired,    TimeoutExpired.__module__.__eq__,    ["subprocess"], true]
    - [SubprocessError,   SubprocessError.__module__.__eq__,   ["subprocess"], true]

# ---------------------------------------------------------------------------
# subprocess module-level function __module__ attributes
#
# subprocess_extra6 covers __qualname__ for run/call/check_output/check_call.
# No prior subprocess spec covers __module__ for any module-level function.
# All these functions are defined in subprocess.py; __module__ is 'subprocess'.
# ---------------------------------------------------------------------------

table subprocess_extra18.function_modules:
  description: "__module__ for subprocess module-level functions is 'subprocess'"
  kind: python_call_eq
  category: module_attrs
  id_prefix: fnmod18

  columns: [id, function, args, expected]
  rows:
    - [run,          run.__module__.__eq__,          ["subprocess"], true]
    - [call,         call.__module__.__eq__,         ["subprocess"], true]
    - [check_output, check_output.__module__.__eq__, ["subprocess"], true]
    - [check_call,   check_call.__module__.__eq__,   ["subprocess"], true]

# ---------------------------------------------------------------------------
# subprocess exception class inheritance — __bases__[0].__name__
#
# No prior subprocess spec checks the base class name for any subprocess
# exception class. CalledProcessError and TimeoutExpired both inherit from
# SubprocessError; SubprocessError itself inherits from Exception.
# ---------------------------------------------------------------------------

table subprocess_extra18.exception_bases:
  description: "__bases__[0].__name__ for subprocess exception classes"
  kind: python_call_eq
  category: type_attrs
  id_prefix: bases18

  columns: [id, function, args, expected]
  rows:
    - [CalledProcessError_base, "CalledProcessError.__bases__[0].__name__.__eq__", ["SubprocessError"], true]
    - [TimeoutExpired_base,     "TimeoutExpired.__bases__[0].__name__.__eq__",     ["SubprocessError"], true]
    - [SubprocessError_base,    "SubprocessError.__bases__[0].__name__.__eq__",    ["Exception"],       true]

# ---------------------------------------------------------------------------
# Standalone invariants — class __module__
# ---------------------------------------------------------------------------

invariant subprocess_extra18.Popen.module:
  description: "subprocess.Popen.__module__ == 'subprocess' — class defined in its own module"
  category: module_attrs
  kind: python_call_eq
  function: Popen.__module__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra18.CompletedProcess.module:
  description: "subprocess.CompletedProcess.__module__ == 'subprocess' — class defined in its own module"
  category: module_attrs
  kind: python_call_eq
  function: CompletedProcess.__module__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra18.CalledProcessError.module:
  description: "subprocess.CalledProcessError.__module__ == 'subprocess' — exception class defined in its own module"
  category: module_attrs
  kind: python_call_eq
  function: CalledProcessError.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — exception inheritance
# ---------------------------------------------------------------------------

invariant subprocess_extra18.CalledProcessError.base:
  description: "subprocess.CalledProcessError.__bases__[0].__name__ == 'SubprocessError' — direct base class"
  category: type_attrs
  kind: python_call_eq
  function: "CalledProcessError.__bases__[0].__name__.__eq__"
  args: ["SubprocessError"]
  expected: true

invariant subprocess_extra18.TimeoutExpired.base:
  description: "subprocess.TimeoutExpired.__bases__[0].__name__ == 'SubprocessError' — direct base class"
  category: type_attrs
  kind: python_call_eq
  function: "TimeoutExpired.__bases__[0].__name__.__eq__"
  args: ["SubprocessError"]
  expected: true

invariant subprocess_extra18.SubprocessError.base:
  description: "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception' — SubprocessError's direct base is Exception"
  category: type_attrs
  kind: python_call_eq
  function: "SubprocessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — function __module__
# ---------------------------------------------------------------------------

invariant subprocess_extra18.run.module:
  description: "subprocess.run.__module__ == 'subprocess' — function defined in its own module"
  category: module_attrs
  kind: python_call_eq
  function: run.__module__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra18.call.module:
  description: "subprocess.call.__module__ == 'subprocess' — function defined in its own module"
  category: module_attrs
  kind: python_call_eq
  function: call.__module__.__eq__
  args: ["subprocess"]
  expected: true
