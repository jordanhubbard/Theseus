spec: theseus_enum_cr
version: ">=3.8"
backend: python_cleanroom(theseus_enum_cr)
blocks: enum

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/enum.html"
  not_derived_from:
    - "CPython source: Lib/enum.py (internal implementation)"
  notes:
    - "Clean-room enum module. Do NOT import enum."
    - "Enum: base class for enumerations."
    - "IntEnum: enum with integer values."
    - "Flag: enum supporting bitwise operations."
    - "auto(): automatic value assignment."

error_model: python_exceptions

invariant theseus_enum_cr.enum2_name_value:
  description: "Color.RED.name == 'RED' and Color.RED.value == 1"
  category: Enum
  kind: python_call_eq
  function: enum2_name_value
  args: []
  expected: true

invariant theseus_enum_cr.enum2_lookup:
  description: "Color(1) returns Color.RED"
  category: Enum
  kind: python_call_eq
  function: enum2_lookup
  args: []
  expected: true

invariant theseus_enum_cr.enum2_iteration:
  description: "list(Color) returns all members"
  category: Enum
  kind: python_call_eq
  function: enum2_iteration
  args: []
  expected: 3
