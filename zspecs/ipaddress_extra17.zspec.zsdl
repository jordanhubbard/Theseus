spec: ipaddress_extra17
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress_extra3.zspec.zsdl — covers AddressValueError/NetmaskValueError __name__/__bases__/__module__; ip_address/ip_network/ip_interface __module__"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__.__eq__ for six classes, three factories, and both exception classes (AddressValueError/NetmaskValueError)"
    - "ipaddress_extra11.zspec.zsdl — covers IPv4/IPv6Address/Network __name__.__len__()==11; ip_address/__qualname__.__len__()"
    - "ipaddress_extra12.zspec.zsdl — covers class __module__.__len__()==9 for six classes; ip_address/__qualname__.__len__()"
    - "ipaddress_extra14.zspec.zsdl — covers __bases__[0].__name__.__len__() for six classes and both exception classes"
    - "ipaddress_extra15.zspec.zsdl — covers summarize_address_range/collapse_addresses/get_mixed_type_key __module__.__eq__('ipaddress') and __module__.__len__()==9"
    - "ipaddress_extra16.zspec.zsdl — covers IPv4/IPv6Address/Network __qualname__.__len__()==11; IPv4Address/IPv6Network __qualname__.__eq__ standalone"
  notes:
    - "This spec extends the ipaddress chain through extra16; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__len__() for AddressValueError (17), NetmaskValueError (17), summarize_address_range (23), collapse_addresses (18), get_mixed_type_key (18) — extra5 covers their __qualname__.__eq__ but no prior spec checks __qualname__.__len__ for any of these five symbols; __name__.__eq__ for the three utility functions (extra5 covers __qualname__.__eq__; __name__.__eq__ is a distinct attribute); ipaddress module-level __name__ and __package__ attributes."
    - "ipaddress.AddressValueError.__qualname__.__len__() == 17 — len('AddressValueError') == 17. extra5 checks __qualname__.__eq__; extra14 checks __bases__[0].__name__.__len__; no prior spec checks AddressValueError.__qualname__.__len__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.NetmaskValueError.__qualname__.__len__() == 17 — len('NetmaskValueError') == 17. Same rationale as AddressValueError. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.summarize_address_range.__qualname__.__len__() == 23 — len('summarize_address_range') == 23. extra15 checks __module__; extra5 checks __qualname__.__eq__; no prior spec checks length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.collapse_addresses.__qualname__.__len__() == 18 — len('collapse_addresses') == 18. Same rationale. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.get_mixed_type_key.__qualname__.__len__() == 18 — len('get_mixed_type_key') == 18. Same rationale. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.summarize_address_range.__name__ == 'summarize_address_range' — extra5 covers __qualname__.__eq__; __name__.__eq__ is a distinct attribute chain. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.collapse_addresses.__name__ == 'collapse_addresses' — same rationale. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.get_mixed_type_key.__name__ == 'get_mixed_type_key' — same rationale. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.__name__ == 'ipaddress' — module-level attribute; no prior spec checks ipaddress.__name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.__package__ == '' — top-level module has empty __package__; no prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AddressValueError / NetmaskValueError __qualname__.__len__()
#
# ipaddress_extra5 covers __qualname__.__eq__ for both exception classes.
# ipaddress_extra14 covers __bases__[0].__name__.__len__.
# No prior spec checks __qualname__.__len__ for either exception class.
# len('AddressValueError') == len('NetmaskValueError') == 17.
# ---------------------------------------------------------------------------

invariant ipaddress_extra17.AddressValueError.qualname_len:
  description: "ipaddress.AddressValueError.__qualname__.__len__() == 17 — len('AddressValueError') == 17"
  category: exception_metadata
  kind: python_call_eq
  function: AddressValueError.__qualname__.__len__
  args: []
  expected: 17

invariant ipaddress_extra17.NetmaskValueError.qualname_len:
  description: "ipaddress.NetmaskValueError.__qualname__.__len__() == 17 — len('NetmaskValueError') == 17"
  category: exception_metadata
  kind: python_call_eq
  function: NetmaskValueError.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# summarize_address_range / collapse_addresses / get_mixed_type_key
# __qualname__.__len__()
#
# ipaddress_extra5 covers all three via __qualname__.__eq__.
# ipaddress_extra15 covers all three via __module__.__eq__ and __module__.__len__.
# No prior spec checks __qualname__.__len__ for any of these utility functions.
# Lengths: summarize_address_range == 23, collapse_addresses == 18,
# get_mixed_type_key == 18.
# ---------------------------------------------------------------------------

table ipaddress_extra17.utility_qualname_len:
  description: "Length of __qualname__ string for ipaddress utility functions"
  kind: python_call_eq
  category: utility_metadata
  id_prefix: uqlen17

  columns: [id, function, args, expected]
  rows:
    - [summarize_address_range, summarize_address_range.__qualname__.__len__, [], 23]
    - [collapse_addresses,      collapse_addresses.__qualname__.__len__,      [], 18]
    - [get_mixed_type_key,      get_mixed_type_key.__qualname__.__len__,      [], 18]

# ---------------------------------------------------------------------------
# summarize_address_range / collapse_addresses / get_mixed_type_key
# __name__.__eq__
#
# ipaddress_extra5 covers __qualname__.__eq__ for all three; __name__ is a
# distinct attribute — for these top-level functions __name__ == __qualname__,
# but the attribute chain differs. No prior spec checks __name__.__eq__ for
# any of these three utility functions.
# ---------------------------------------------------------------------------

table ipaddress_extra17.utility_name_eq:
  description: "__name__ equality check for ipaddress utility functions (distinct from __qualname__)"
  kind: python_call_eq
  category: utility_metadata
  id_prefix: uname17

  columns: [id, function, args, expected]
  rows:
    - [summarize_address_range, summarize_address_range.__name__.__eq__, ["summarize_address_range"], true]
    - [collapse_addresses,      collapse_addresses.__name__.__eq__,      ["collapse_addresses"],      true]
    - [get_mixed_type_key,      get_mixed_type_key.__name__.__eq__,      ["get_mixed_type_key"],      true]

# ---------------------------------------------------------------------------
# ipaddress module __name__ and __package__
#
# No prior spec in the ipaddress family checks the module-level __name__
# or __package__ attributes of the ipaddress module itself.
# ipaddress.__name__ == 'ipaddress'; ipaddress.__package__ == '' (top-level
# stdlib module has no package prefix).
# ---------------------------------------------------------------------------

invariant ipaddress_extra17.module.name:
  description: "ipaddress.__name__ == 'ipaddress'"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["ipaddress"]
  expected: true

invariant ipaddress_extra17.module.package:
  description: "ipaddress.__package__ == '' — top-level module has no package prefix"
  category: module_metadata
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
