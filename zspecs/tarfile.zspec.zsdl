spec: tarfile
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tarfile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "tarfile source: tarfile.py (PSF; source inspection permitted)"
  not_derived_from:
    - "tarfile source: internal implementation details"
  notes:
    - "tarfile.TarFile is the main class for reading and writing tar archives."
    - "tarfile.TarInfo stores header metadata for a single archive member."
    - "USTAR_FORMAT=0, GNU_FORMAT=1, PAX_FORMAT=2; DEFAULT_FORMAT=PAX_FORMAT=2 since Python 3.8."
    - "BLOCKSIZE=512 is the size of one tar header block in bytes."
    - "RECORDSIZE=10240 is the size of one tape record (20 blocks) in bytes."
    - "ENCODING='utf-8' is the default character encoding used for member names."
    - "Type flags are single-byte values: REGTYPE=b'0', DIRTYPE=b'5', SYMTYPE=b'2', LNKTYPE=b'1'."
    - "CHRTYPE=b'3', BLKTYPE=b'4', FIFOTYPE=b'6' are device/special file type flags."
    - "TarError is the base exception; ReadError, CompressionError, ExtractError, HeaderError, StreamError all inherit from TarError."
    - "TarInfo(name) creates a TarInfo with the given name, size=0, type=REGTYPE, mode=0o644, mtime=0."
    - "tarfile.open() raises ReadError when given unrecognized data in auto-detect mode."
    - "is_tarfile(fileobj) returns False for non-tar bytes without raising."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "tarfile.open() raises ReadError (subclass of TarError) when opening unrecognized data."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Format constants
# ---------------------------------------------------------------------------

invariant tarfile.USTAR_FORMAT.value:
  description: "tarfile.USTAR_FORMAT == 0 — POSIX.1-1988 (ustar) format"
  category: constants
  kind: python_call_eq
  function: USTAR_FORMAT.__eq__
  args: [0]
  expected: true

invariant tarfile.GNU_FORMAT.value:
  description: "tarfile.GNU_FORMAT == 1 — GNU tar format"
  category: constants
  kind: python_call_eq
  function: GNU_FORMAT.__eq__
  args: [1]
  expected: true

invariant tarfile.PAX_FORMAT.value:
  description: "tarfile.PAX_FORMAT == 2 — POSIX.1-2001 (pax) format"
  category: constants
  kind: python_call_eq
  function: PAX_FORMAT.__eq__
  args: [2]
  expected: true

invariant tarfile.DEFAULT_FORMAT.value:
  description: "tarfile.DEFAULT_FORMAT == 2 — default is PAX_FORMAT since Python 3.8"
  category: constants
  kind: python_call_eq
  function: DEFAULT_FORMAT.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Size constants
# ---------------------------------------------------------------------------

invariant tarfile.BLOCKSIZE.value:
  description: "tarfile.BLOCKSIZE == 512 — one tar header block is 512 bytes"
  category: constants
  kind: python_call_eq
  function: BLOCKSIZE.__eq__
  args: [512]
  expected: true

invariant tarfile.RECORDSIZE.value:
  description: "tarfile.RECORDSIZE == 10240 — one tape record is 10240 bytes (20 blocks)"
  category: constants
  kind: python_call_eq
  function: RECORDSIZE.__eq__
  args: [10240]
  expected: true

# ---------------------------------------------------------------------------
# ENCODING constant
# ---------------------------------------------------------------------------

invariant tarfile.ENCODING.value:
  description: "tarfile.ENCODING == 'utf-8' — default character encoding for member names"
  category: constants
  kind: python_call_eq
  function: ENCODING.__eq__
  args: ["utf-8"]
  expected: true

# ---------------------------------------------------------------------------
# Type flag bytes — decoded to ASCII strings
# ---------------------------------------------------------------------------

invariant tarfile.REGTYPE.decode:
  description: "tarfile.REGTYPE.decode('ascii') == '0' — regular file type flag"
  category: type_flags
  kind: python_call_eq
  function: REGTYPE.decode
  args: ["ascii"]
  expected: "0"

invariant tarfile.LNKTYPE.decode:
  description: "tarfile.LNKTYPE.decode('ascii') == '1' — hard link type flag"
  category: type_flags
  kind: python_call_eq
  function: LNKTYPE.decode
  args: ["ascii"]
  expected: "1"

invariant tarfile.SYMTYPE.decode:
  description: "tarfile.SYMTYPE.decode('ascii') == '2' — symbolic link type flag"
  category: type_flags
  kind: python_call_eq
  function: SYMTYPE.decode
  args: ["ascii"]
  expected: "2"

invariant tarfile.CHRTYPE.decode:
  description: "tarfile.CHRTYPE.decode('ascii') == '3' — character device type flag"
  category: type_flags
  kind: python_call_eq
  function: CHRTYPE.decode
  args: ["ascii"]
  expected: "3"

invariant tarfile.BLKTYPE.decode:
  description: "tarfile.BLKTYPE.decode('ascii') == '4' — block device type flag"
  category: type_flags
  kind: python_call_eq
  function: BLKTYPE.decode
  args: ["ascii"]
  expected: "4"

invariant tarfile.DIRTYPE.decode:
  description: "tarfile.DIRTYPE.decode('ascii') == '5' — directory type flag"
  category: type_flags
  kind: python_call_eq
  function: DIRTYPE.decode
  args: ["ascii"]
  expected: "5"

invariant tarfile.FIFOTYPE.decode:
  description: "tarfile.FIFOTYPE.decode('ascii') == '6' — FIFO (named pipe) type flag"
  category: type_flags
  kind: python_call_eq
  function: FIFOTYPE.decode
  args: ["ascii"]
  expected: "6"

# ---------------------------------------------------------------------------
# Class identity — TarFile, TarInfo, exception classes
# ---------------------------------------------------------------------------

invariant tarfile.TarFile.class_name:
  description: "tarfile.TarFile.__name__ == 'TarFile'"
  category: class_metadata
  kind: python_call_eq
  function: TarFile.__name__.__eq__
  args: ["TarFile"]
  expected: true

invariant tarfile.TarInfo.class_name:
  description: "tarfile.TarInfo.__name__ == 'TarInfo'"
  category: class_metadata
  kind: python_call_eq
  function: TarInfo.__name__.__eq__
  args: ["TarInfo"]
  expected: true

invariant tarfile.TarError.class_name:
  description: "tarfile.TarError.__name__ == 'TarError'"
  category: class_metadata
  kind: python_call_eq
  function: TarError.__name__.__eq__
  args: ["TarError"]
  expected: true

invariant tarfile.ReadError.class_name:
  description: "tarfile.ReadError.__name__ == 'ReadError'"
  category: class_metadata
  kind: python_call_eq
  function: ReadError.__name__.__eq__
  args: ["ReadError"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy
# ---------------------------------------------------------------------------

invariant tarfile.TarError.base_is_Exception:
  description: "tarfile.TarError.__bases__[0].__name__ == 'Exception'"
  category: class_metadata
  kind: python_call_eq
  function: TarError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

invariant tarfile.ReadError.base_is_TarError:
  description: "tarfile.ReadError.__bases__[0].__name__ == 'TarError'"
  category: class_metadata
  kind: python_call_eq
  function: ReadError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["TarError"]
  expected: true

# ---------------------------------------------------------------------------
# TarInfo construction — name, size, mode, mtime defaults
# ---------------------------------------------------------------------------

invariant tarfile.TarInfo.name:
  description: "tarfile.TarInfo('test.txt').name == 'test.txt'"
  category: tarinfo
  kind: python_call_eq
  function: TarInfo
  args: ["test.txt"]
  method: name.__eq__
  method_args: ["test.txt"]
  expected: true

invariant tarfile.TarInfo.size_default:
  description: "tarfile.TarInfo('test.txt').size == 0 — default size is zero"
  category: tarinfo
  kind: python_call_eq
  function: TarInfo
  args: ["test.txt"]
  method: size.__eq__
  method_args: [0]
  expected: true

invariant tarfile.TarInfo.mtime_default:
  description: "tarfile.TarInfo('test.txt').mtime == 0 — default mtime is zero"
  category: tarinfo
  kind: python_call_eq
  function: TarInfo
  args: ["test.txt"]
  method: mtime.__eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# is_tarfile — non-tar bytes return False
# ---------------------------------------------------------------------------

invariant tarfile.is_tarfile.false_on_bad_bytes:
  description: "tarfile.is_tarfile(BytesIO(b'not a tar')) == False — non-tar bytes are rejected"
  category: is_tarfile
  kind: python_call_eq
  function: is_tarfile
  args: [{type: bytes_ascii, value: "not a tar"}]
  expected: false

