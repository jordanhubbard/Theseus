spec: pathlib_extra99
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra98

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra98.zspec.zsdl."
    - "This spec covers: pathlib PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath class identity."
    - "pathlib.PurePath.__module__ = 'pathlib' — PurePath is defined in the pathlib module."
    - "pathlib.PurePath.__bases__[0].__name__ = 'object' — PurePath directly extends object."
    - "pathlib.PurePath.__mro__.__len__() = 2 — MRO is [PurePath, object]."
    - "pathlib.PurePosixPath.__bases__[0].__name__ = 'PurePath' — PurePosixPath extends PurePath."
    - "pathlib.PurePosixPath.__mro__.__len__() = 3 — MRO is [PurePosixPath, PurePath, object]."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ = 'PurePath' — PureWindowsPath extends PurePath."
    - "pathlib.PureWindowsPath.__mro__.__len__() = 3 — MRO is [PureWindowsPath, PurePath, object]."
    - "pathlib.Path.__bases__[0].__name__ = 'PurePath' — Path extends PurePath directly."
    - "pathlib.Path.__mro__.__len__() = 3 — MRO is [Path, PurePath, object]."
    - "pathlib.PosixPath.__bases__[0].__name__ = 'Path' — PosixPath extends Path."
    - "pathlib.PosixPath.__mro__.__len__() = 5 — MRO is [PosixPath, Path, PurePosixPath, PurePath, object] (includes PurePosixPath via Path)."
    - "pathlib.WindowsPath.__bases__[0].__name__ = 'Path' — WindowsPath extends Path."
    - "pathlib.WindowsPath.__mro__.__len__() = 5 — MRO is [WindowsPath, Path, PureWindowsPath, PurePath, object]."
    - "On non-Windows, WindowsPath class attributes are available but instantiation raises NotImplementedError."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath class identity
# PurePath is the pure abstract base. __module__ == 'pathlib'.
# __bases__[0].__name__ == 'object' (extends object directly).
# __mro__.__len__() == 2 (only PurePath and object).
# ---------------------------------------------------------------------------

table pathlib_extra99.PurePath_identity:
  description: "pathlib.PurePath class identity: __name__, __module__, __qualname__"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpurepath99

  columns: [id, function, args, expected]
  rows:
    - [pp_name_eq,      PurePath.__name__.__eq__,     ["PurePath"], true]
    - [pp_module_eq,    PurePath.__module__.__eq__,   ["pathlib"],  true]
    - [pp_qualname_eq,  PurePath.__qualname__.__eq__,  ["PurePath"], true]
    - [pp_base_object,  "PurePath.__bases__[0].__name__.__eq__", ["object"], true]
    - [pp_mro_len,      PurePath.__mro__.__len__,      [],          2]

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath and pathlib.PureWindowsPath class identity
# Both extend PurePath. MRO length == 3.
# ---------------------------------------------------------------------------

table pathlib_extra99.PurePosixPath_PureWindowsPath_identity:
  description: "pathlib.PurePosixPath and PureWindowsPath class identity: __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpurepath99

  columns: [id, function, args, expected]
  rows:
    - [ppp_name_eq,      PurePosixPath.__name__.__eq__,                  ["PurePosixPath"],   true]
    - [ppp_module_eq,    PurePosixPath.__module__.__eq__,                ["pathlib"],         true]
    - [ppp_base_eq,      "PurePosixPath.__bases__[0].__name__.__eq__",     ["PurePath"],        true]
    - [ppp_mro_len,      PurePosixPath.__mro__.__len__,                  [],                  3]
    - [pwp_name_eq,      PureWindowsPath.__name__.__eq__,                ["PureWindowsPath"], true]
    - [pwp_module_eq,    PureWindowsPath.__module__.__eq__,              ["pathlib"],         true]
    - [pwp_base_eq,      "PureWindowsPath.__bases__[0].__name__.__eq__",   ["PurePath"],        true]
    - [pwp_mro_len,      PureWindowsPath.__mro__.__len__,                [],                  3]

# ---------------------------------------------------------------------------
# pathlib.Path class identity
# Path extends PurePath directly (__bases__[0].__name__ == 'PurePath').
# __mro__.__len__() == 3 (Path, PurePath, object).
# ---------------------------------------------------------------------------

table pathlib_extra99.Path_identity:
  description: "pathlib.Path class identity: __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpurepath99

  columns: [id, function, args, expected]
  rows:
    - [path_name_eq,    Path.__name__.__eq__,                ["Path"],     true]
    - [path_module_eq,  Path.__module__.__eq__,              ["pathlib"],  true]
    - [path_base_eq,    "Path.__bases__[0].__name__.__eq__",   ["PurePath"], true]
    - [path_mro_len,    Path.__mro__.__len__,                [],           3]
    - [path_qname_eq,   Path.__qualname__.__eq__,            ["Path"],     true]

# ---------------------------------------------------------------------------
# pathlib.PosixPath and pathlib.WindowsPath class identity
# Both extend Path directly. MRO length == 5 (PosixPath/WindowsPath, Path,
# PurePosixPath/PureWindowsPath, PurePath, object).
# On macOS, PosixPath is available; WindowsPath class attributes are readable
# even though instantiation raises NotImplementedError.
# ---------------------------------------------------------------------------

table pathlib_extra99.PosixPath_WindowsPath_identity:
  description: "pathlib.PosixPath and WindowsPath class identity: __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpurepath99

  columns: [id, function, args, expected]
  rows:
    - [posixp_name_eq,   PosixPath.__name__.__eq__,                 ["PosixPath"],   true]
    - [posixp_module_eq, PosixPath.__module__.__eq__,               ["pathlib"],     true]
    - [posixp_base_eq,   "PosixPath.__bases__[0].__name__.__eq__",    ["Path"],        true]
    - [posixp_mro_len,   PosixPath.__mro__.__len__,                 [],              5]
    - [winp_name_eq,     WindowsPath.__name__.__eq__,               ["WindowsPath"], true]
    - [winp_module_eq,   WindowsPath.__module__.__eq__,             ["pathlib"],     true]
    - [winp_base_eq,     "WindowsPath.__bases__[0].__name__.__eq__",  ["Path"],        true]
    - [winp_mro_len,     WindowsPath.__mro__.__len__,               [],              5]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra99.PurePath.module_eq_pathlib:
  description: "pathlib.PurePath.__module__ == 'pathlib' (PurePath is defined in the top-level pathlib package)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra99.PurePath.base_is_object:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' (PurePath directly extends object, it is the root of the pathlib hierarchy)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant pathlib_extra99.PurePath.mro_len_2:
  description: "pathlib.PurePath.__mro__.__len__() == 2 (MRO is [PurePath, object], only two entries)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra99.Path.base_is_PurePath:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' (Path extends PurePath directly)"
  category: class_identity
  kind: python_call_eq
  function: Path.__bases__[0].__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra99.PosixPath.mro_len_5:
  description: "pathlib.PosixPath.__mro__.__len__() == 5 (MRO is [PosixPath, Path, PurePosixPath, PurePath, object])"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__mro__.__len__
  args: []
  expected: 5
