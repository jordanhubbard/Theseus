spec: abc_extra1261
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module has no __all__; verified via __dict__.__contains__('__all__') == False and AttributeError on access"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 531 (_extra1261): __all__ membership theme — abc module does NOT define __all__; abc.__all__ raises AttributeError; verified Python 3.14.3."
    - "abc.__dict__.__contains__('__all__') == False — __all__ is absent from abc's namespace; verified Python 3.14.3."
    - "abc.__dict__.__contains__('ABC') == True — ABC, ABCMeta, abstractmethod, abstractclassmethod, abstractstaticmethod, abstractproperty, get_cache_token, update_abstractmethods are all present in abc.__dict__; verified Python 3.14.3."
    - "abc.__dict__.__contains__('Thread') == False — Thread, Process, Queue, Lock, Future, run, sleep are NOT in abc.__dict__; verified Python 3.14.3."
    - "Distinct from extra1246 (__doc__ class checks), extra1231 (__dict__.__contains__ for class membership), extra1216 (ABCMeta.__dict__ members), extra1201 (__bases__/__mro__ lengths)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1261.no_all_in_dict:
  description: "abc.__dict__.__contains__('__all__') returns false — abc has no __all__; public names ABC, ABCMeta, abstractmethod, get_cache_token, update_abstractmethods ARE in __dict__"
  kind: python_call_eq
  category: all_membership
  id_prefix: ab1261nd
  columns: [id, function, args, expected]
  rows:
    - [ab1261nd001, abc.__dict__.__contains__, ["__all__"],                  false]
    - [ab1261nd002, abc.__dict__.__contains__, ["ABC"],                      true]
    - [ab1261nd003, abc.__dict__.__contains__, ["ABCMeta"],                  true]
    - [ab1261nd004, abc.__dict__.__contains__, ["abstractmethod"],           true]
    - [ab1261nd005, abc.__dict__.__contains__, ["abstractclassmethod"],      true]
    - [ab1261nd006, abc.__dict__.__contains__, ["abstractstaticmethod"],     true]
    - [ab1261nd007, abc.__dict__.__contains__, ["abstractproperty"],         true]
    - [ab1261nd008, abc.__dict__.__contains__, ["get_cache_token"],          true]
    - [ab1261nd009, abc.__dict__.__contains__, ["update_abstractmethods"],   true]

table abc_extra1261.dict_contains_not_in:
  description: "abc.__dict__.__contains__ returns false for names not in abc: Thread, Process, Queue, Lock, Future, run, sleep"
  kind: python_call_eq
  category: all_membership
  id_prefix: ab1261ni
  columns: [id, function, args, expected]
  rows:
    - [ab1261ni001, abc.__dict__.__contains__, ["Thread"],   false]
    - [ab1261ni002, abc.__dict__.__contains__, ["Process"],  false]
    - [ab1261ni003, abc.__dict__.__contains__, ["Queue"],    false]
    - [ab1261ni004, abc.__dict__.__contains__, ["Lock"],     false]
    - [ab1261ni005, abc.__dict__.__contains__, ["Future"],   false]
    - [ab1261ni006, abc.__dict__.__contains__, ["run"],      false]
    - [ab1261ni007, abc.__dict__.__contains__, ["sleep"],    false]
    - [ab1261ni008, abc.__dict__.__contains__, ["gather"],   false]

table abc_extra1261.all_access_raises:
  description: "abc.__all__ does not exist — accessing it raises AttributeError; ABCMeta and ABC also have no __all__ attribute"
  kind: python_call_raises
  category: all_membership
  id_prefix: ab1261ar
  columns: [id, function, args, raises]
  rows:
    - [ab1261ar001, getattr, ["abc", "__all__"],       AttributeError]
    - [ab1261ar002, getattr, ["abc.ABC", "__all__"],   AttributeError]
    - [ab1261ar003, getattr, ["abc.ABCMeta", "__all__"], AttributeError]
    - [ab1261ar004, getattr, ["abc.abstractmethod", "__all__"], AttributeError]
    - [ab1261ar005, getattr, ["abc.get_cache_token", "__all__"], AttributeError]
    - [ab1261ar006, getattr, ["abc.update_abstractmethods", "__all__"], AttributeError]
