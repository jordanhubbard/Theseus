spec: multiprocessing_extra2146
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "CPython source: Lib/multiprocessing/queues.py"
    - "multiprocessing_extra2131.zspec.zsdl — covers exception protocol dict-presence wave"
    - "multiprocessing_extra2116.zspec.zsdl — covers bitwise operator protocol dict-presence wave"
  notes:
    - "Wave (_extra2146): numeric conversion protocol dict-presence — checking __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__."
    - "multiprocessing classes are process/thread synchronization and IPC primitives; none define numeric conversion protocol methods."
    - "multiprocessing.Process.__dict__ does not contain any numeric conversion dunders — Process represents an OS process handle, not a number."
    - "multiprocessing.synchronize.Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition are wrappers around OS synchronization primitives; none define __bool__ or any other numeric conversion dunder."
    - "multiprocessing.queues.Queue and SimpleQueue are inter-process communication queues; neither defines numeric conversion protocol entries."
    - "multiprocessing.synchronize.Lock is accessed via its full submodule path; the top-level multiprocessing.Lock is a bound method factory, not the class itself."
    - "All expected values (false) verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2146.trunc_floor_ceil:
