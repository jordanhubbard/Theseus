spec: concurrent_futures_extra102
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra101.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures executor method qualnames and code attributes. NEW in extra102: concurrent.futures.ThreadPoolExecutor.__init__.__qualname__=='ThreadPoolExecutor.__init__' (len=27); concurrent.futures.ProcessPoolExecutor.__init__.__qualname__=='ProcessPoolExecutor.__init__' (len=28, longest __init__ qualname); concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount==5 (self, max_workers, thread_name_prefix, initializer, initargs); concurrent.futures.ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25); concurrent.futures.ProcessPoolExecutor.submit.__qualname__=='ProcessPoolExecutor.submit' (len=26); concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__=='Executor.__enter__' (len=18, inherited from Executor base class); concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__=='Executor.__exit__' (len=17); concurrent.futures.as_completed.__code__.co_name=='as_completed' (co_argcount=2); concurrent.futures.wait.__code__.co_name=='wait' (co_argcount=3). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__'. ThreadPoolExecutor does not define __enter__ itself; it inherits it from the Executor base class, so the qualname uses 'Executor.' as prefix (len=18: 'Executor.__enter__'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__code__.co_argcount == 2. as_completed is defined as 'def as_completed(fs, timeout=None)' — two positional parameters (fs, timeout), giving co_argcount=2. concurrent.futures.wait.__code__.co_argcount==3 (fs, timeout, return_when). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5. The signature is __init__(self, max_workers=None, thread_name_prefix='', initializer=None, initargs=()) — five positional parameters including self. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28. 'ProcessPoolExecutor.__init__' = 'ProcessPoolExecutor'(19) + '.'(1) + '__init__'(8) = 28. This is the longest executor __init__ qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor __init__ and submit method qualnames — extra102
#
# Wave 254 theme: executor method qualnames and code attributes.
#
# concurrent.futures.ThreadPoolExecutor.__init__.__qualname__  == 'ThreadPoolExecutor.__init__'  (len=27)
# concurrent.futures.ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28, longest)
# concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5
# concurrent.futures.ThreadPoolExecutor.submit.__qualname__    == 'ThreadPoolExecutor.submit'    (len=25)
# concurrent.futures.ProcessPoolExecutor.submit.__qualname__   == 'ProcessPoolExecutor.submit'   (len=26)
# ---------------------------------------------------------------------------

table concurrent_futures_extra102.cf_executor_init_qualnames:
  description: "concurrent.futures executor __init__ and submit method qualname checks in cfexec102 namespace — wave 254 theme: ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__')==True (len=27: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27); ProcessPoolExecutor.__init__.__qualname__.__eq__('ProcessPoolExecutor.__init__')==True (len=28: 'ProcessPoolExecutor'=19+'.'=1+'__init__'=8=28, longest); ThreadPoolExecutor.__init__.__qualname__.__len__()==27; ProcessPoolExecutor.__init__.__qualname__.__len__()==28; ThreadPoolExecutor.__init__.__code__.co_argcount==5 (self, max_workers, thread_name_prefix, initializer, initargs); ThreadPoolExecutor.submit.__qualname__.__eq__('ThreadPoolExecutor.submit')==True (len=25: 'ThreadPoolExecutor'=18+'.'=1+'submit'=6=25); ProcessPoolExecutor.submit.__qualname__.__eq__('ProcessPoolExecutor.submit')==True (len=26); all executor __init__ and submit methods are Python functions (class='function'); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: cfexec102

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_init_qn_eq,  "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__",        ["ThreadPoolExecutor.__init__"],  true, "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27); verified with Python 3.14.3"]
    - [tpe_init_qn_len, "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__",        [],                              27,   "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__() == 27; verified with Python 3.14.3"]
    - [ppe_init_qn_eq,  "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__",        ["ProcessPoolExecutor.__init__"], true, "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28, longest); verified with Python 3.14.3"]
    - [ppe_init_qn_len, "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__",        [],                              28,   "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 (longest executor __init__ qualname); verified with Python 3.14.3"]
    - [tpe_init_args,   "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__",  [5],                             true, "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, thread_name_prefix, initializer, initargs); verified with Python 3.14.3"]
    - [tpe_submit_qn,   "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__",            ["ThreadPoolExecutor.submit"],    true, "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25); verified with Python 3.14.3"]
    - [ppe_submit_qn,   "concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__",           ["ProcessPoolExecutor.submit"],   true, "concurrent.futures.ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures __enter__/__exit__ qualnames — extra102
#
# Both TPE and PPE inherit __enter__/__exit__ from the Executor base class.
#
# ThreadPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__' (len=18)
# ThreadPoolExecutor.__exit__.__qualname__  == 'Executor.__exit__'  (len=17)
# ThreadPoolExecutor.__enter__.__code__.co_argcount == 1 (self)
# ThreadPoolExecutor.__exit__.__code__.co_argcount  == 4 (self, exc_type, exc_val, exc_tb)
# ---------------------------------------------------------------------------

table concurrent_futures_extra102.cf_executor_context_qualnames:
  description: "concurrent.futures executor __enter__/__exit__ qualname checks in cfexec102 namespace — wave 254 theme: ThreadPoolExecutor and ProcessPoolExecutor inherit __enter__ and __exit__ from the Executor base class; ThreadPoolExecutor.__enter__.__qualname__.__eq__('Executor.__enter__')==True (len=18: 'Executor'=8+'.'=1+'__enter__'=9=18); ThreadPoolExecutor.__exit__.__qualname__.__eq__('Executor.__exit__')==True (len=17: 'Executor'=8+'.'=1+'__exit__'=8=17); the qualname prefix 'Executor.' (not 'ThreadPoolExecutor.') shows inheritance from the base class; __enter__ co_argcount==1 (self); __exit__ co_argcount==4 (self, exc_type, exc_val, exc_tb); __enter__ and __exit__ both have __module__=='concurrent.futures._base'; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: cfexec102a

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_enter_qn_eq,  "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__eq__",        ["Executor.__enter__"], true, "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__' (len=18, inherited from Executor); verified with Python 3.14.3"]
    - [tpe_enter_qn_len, "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__len__",        [],                    18,   "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__len__() == 18; verified with Python 3.14.3"]
    - [tpe_exit_qn_eq,   "concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__.__eq__",          ["Executor.__exit__"],  true, "concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__ == 'Executor.__exit__' (len=17, inherited from Executor); verified with Python 3.14.3"]
    - [tpe_exit_qn_len,  "concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__.__len__",         [],                    17,   "concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [tpe_enter_args,   "concurrent.futures.ThreadPoolExecutor.__enter__.__code__.co_argcount.__eq__", [1],                   true, "concurrent.futures.ThreadPoolExecutor.__enter__.__code__.co_argcount == 1 (self); verified with Python 3.14.3"]
    - [tpe_exit_args,    "concurrent.futures.ThreadPoolExecutor.__exit__.__code__.co_argcount.__eq__",  [4],                   true, "concurrent.futures.ThreadPoolExecutor.__exit__.__code__.co_argcount == 4 (self, exc_type, exc_val, exc_tb); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures as_completed and wait code attributes — extra102
#
# concurrent.futures.as_completed.__code__.co_name     == 'as_completed' (co_argcount=2)
# concurrent.futures.wait.__code__.co_name             == 'wait'         (co_argcount=3)
# concurrent.futures.as_completed.__module__           == 'concurrent.futures._base'
# concurrent.futures.wait.__module__                   == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra102.cf_utility_func_code_attrs:
  description: "concurrent.futures as_completed and wait function code attribute checks in cfexec102 namespace — wave 254 theme: as_completed and wait are utility functions defined in Lib/concurrent/futures/_base.py; as_completed.__code__.co_name.__eq__('as_completed')==True (len=12: 'as_completed'); as_completed.__code__.co_argcount.__eq__(2)==True (fs, timeout); wait.__code__.co_name.__eq__('wait')==True (len=4: 'wait'); wait.__code__.co_argcount.__eq__(3)==True (fs, timeout, return_when); both have __module__=='concurrent.futures._base'; as_completed is a generator function (yields futures as they complete); wait blocks until the specified set of futures is done; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfexec102b

  columns: [id, function, args, expected, description]
  rows:
    - [asc_co_name,   "concurrent.futures.as_completed.__code__.co_name.__eq__",      ["as_completed"],             true, "concurrent.futures.as_completed.__code__.co_name == 'as_completed'; verified with Python 3.14.3"]
    - [asc_co_argc,   "concurrent.futures.as_completed.__code__.co_argcount.__eq__",  [2],                          true, "concurrent.futures.as_completed.__code__.co_argcount == 2 (fs, timeout); verified with Python 3.14.3"]
    - [asc_module,    "concurrent.futures.as_completed.__module__.__eq__",            ["concurrent.futures._base"], true, "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [wait_co_name,  "concurrent.futures.wait.__code__.co_name.__eq__",              ["wait"],                     true, "concurrent.futures.wait.__code__.co_name == 'wait'; verified with Python 3.14.3"]
    - [wait_co_argc,  "concurrent.futures.wait.__code__.co_argcount.__eq__",          [3],                          true, "concurrent.futures.wait.__code__.co_argcount == 3 (fs, timeout, return_when); verified with Python 3.14.3"]
    - [wait_module,   "concurrent.futures.wait.__module__.__eq__",                    ["concurrent.futures._base"], true, "concurrent.futures.wait.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra102
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra102.TPE_init_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__') returns True — ThreadPoolExecutor.__init__.__qualname__ is 'ThreadPoolExecutor.__init__' (len=27: 'ThreadPoolExecutor'=18 + '.'=1 + '__init__'=8 = 27); ThreadPoolExecutor.__init__ is a Python function (class='function') defined in Lib/concurrent/futures/thread.py; co_argcount==5 (self, max_workers, thread_name_prefix, initializer, initargs); compare: ProcessPoolExecutor.__init__.__qualname__.__len__()==28 (one more, because 'ProcessPoolExecutor'=19 vs 'ThreadPoolExecutor'=18); NEW in extra102: first standalone TPE __init__ qualname invariant in cfexec102 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__"
  args: ["ThreadPoolExecutor.__init__"]
  expected: true

invariant concurrent_futures_extra102.PPE_init_qualname_longest:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 — ProcessPoolExecutor.__init__.__qualname__ is 'ProcessPoolExecutor.__init__' (28 chars: 'ProcessPoolExecutor'=19 + '.'=1 + '__init__'=8 = 28); this is one char longer than ThreadPoolExecutor.__init__.__qualname__ (27 chars) because 'ProcessPoolExecutor'=19 vs 'ThreadPoolExecutor'=18; ProcessPoolExecutor.__init__ is a Python function defined in Lib/concurrent/futures/process.py; co_argcount==5 (self, max_workers, mp_context, initializer, initargs); this is the longest executor __init__ qualname in this spec; NEW in extra102: first standalone PPE __init__ qualname length invariant in cfexec102 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__"
  args: []
  expected: 28

invariant concurrent_futures_extra102.TPE_enter_qualname_uses_Executor:
  description: "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__eq__('Executor.__enter__') returns True — ThreadPoolExecutor does not define __enter__ itself; it inherits it from the Executor base class in Lib/concurrent/futures/_base.py; the qualname 'Executor.__enter__' (len=18: 'Executor'=8 + '.'=1 + '__enter__'=9 = 18) uses 'Executor.' as the prefix, not 'ThreadPoolExecutor.'; both ThreadPoolExecutor and ProcessPoolExecutor share this inherited __enter__; __enter__ co_argcount==1 (self only); the context manager protocol is supported by all Executor subclasses via Executor.__enter__/__exit__; NEW in extra102: first standalone TPE __enter__ qualname invariant in cfexec102 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__eq__"
  args: ["Executor.__enter__"]
  expected: true

invariant concurrent_futures_extra102.as_completed_co_argcount_2:
  description: "concurrent.futures.as_completed.__code__.co_argcount == 2 — as_completed is defined as 'def as_completed(fs, timeout=None)' in Lib/concurrent/futures/_base.py; co_argcount counts positional parameters giving 2 (fs, timeout); compare: wait.__code__.co_argcount==3 (fs, timeout, return_when — one more); as_completed is a generator that yields futures from 'fs' as they complete; as_completed.__code__.co_name is 'as_completed'; as_completed.__module__ is 'concurrent.futures._base'; as_completed.__qualname__ is 'as_completed' (len=12); NEW in extra102: first standalone as_completed co_argcount invariant in cfexec102 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__code__.co_argcount.__eq__"
  args: [2]
  expected: true

invariant concurrent_futures_extra102.wait_co_argcount_3:
  description: "concurrent.futures.wait.__code__.co_argcount == 3 — wait is defined as 'def wait(fs, timeout=None, return_when=ALL_COMPLETED)' in Lib/concurrent/futures/_base.py; co_argcount counts positional parameters giving 3 (fs, timeout, return_when); compare: as_completed.__code__.co_argcount==2 (one fewer, no return_when param); wait.__code__.co_name is 'wait'; wait.__module__ is 'concurrent.futures._base'; wait.__qualname__ is 'wait' (len=4, the shortest qualname in this spec); wait blocks until the given futures finish or a timeout elapses; NEW in extra102: first standalone wait co_argcount invariant in cfexec102 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: "concurrent.futures.wait.__code__.co_argcount.__eq__"
  args: [3]
  expected: true
