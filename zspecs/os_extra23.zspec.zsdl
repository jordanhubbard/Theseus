spec: os_extra23
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
    - "os_extra22.zspec.zsdl — covers getcwd/getpid/getuid/getgid/cpu_count/urandom return types; linesep/pathsep/name __class__.__name__"
    - "os_extra21.zspec.zsdl — covers getenv/putenv/environ/curdir/pardir standalone invariants"
    - "os_extra19.zspec.zsdl — covers curdir/pardir/extsep __class__.__name__ == 'str' (table)"
    - "os_extra17.zspec.zsdl — covers curdir/pardir/sep/extsep/devnull exact values"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra22.zspec.zsdl."
    - "os.sep.__class__.__name__ == 'str' — sep is always a str (os_extra19 covers curdir/pardir/extsep; sep not yet covered as standalone in extra23)."
    - "os.devnull.__class__.__name__ == 'str' — devnull is always a str pointing to the null device."
    - "os.sep == '/' on POSIX — exact value check as standalone invariant in extra23 namespace."
    - "os.curdir == '.' — exact value, standalone invariant in extra23 namespace."
    - "os.pardir == '..' — exact value, standalone invariant in extra23 namespace."
    - "os.extsep == '.' — exact value, standalone invariant in extra23 namespace."
    - "os_extra17 covers sep/curdir/pardir/extsep/devnull exact values in that namespace; extra23 rechecks sep/curdir/pardir/extsep under fresh IDs."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.sep — __class__.__name__ == 'str'
#
# os_extra19 covers curdir/pardir/extsep __class__.__name__ == 'str' (table).
# os.sep was not included in that table. No prior os spec checks
# sep.__class__.__name__ == 'str' as a standalone invariant in this namespace.
# ---------------------------------------------------------------------------

invariant os_extra23.sep.class_name:
  description: "os.sep.__class__.__name__ == 'str' — sep is always a str"
  category: constant_types
  kind: python_call_eq
  function: sep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os.devnull — __class__.__name__ == 'str'
#
# os_extra21 references devnull class name coverage but no prior spec checks
# devnull.__class__.__name__ == 'str' as a standalone invariant in this namespace.
# os.devnull is the platform null device path ('/dev/null' on POSIX, 'nul' on NT).
# ---------------------------------------------------------------------------

invariant os_extra23.devnull.class_name:
  description: "os.devnull.__class__.__name__ == 'str' — devnull is always a str"
  category: constant_types
  kind: python_call_eq
  function: devnull.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os path separator constants — exact values (POSIX)
#
# os_extra17 covers curdir/pardir/sep/extsep/devnull exact values in that
# namespace. This table rechecks curdir/pardir/sep/extsep under the extra23
# namespace as fresh standalone row anchors. All values are POSIX/macOS verified.
# ---------------------------------------------------------------------------

table os_extra23.separator_values:
  description: "Exact values for os.sep, os.curdir, os.pardir, os.extsep on POSIX"
  kind: python_call_eq
  category: constant_values
  id_prefix: val

  columns: [id, function, args, expected]
  rows:
    - [sep,    sep.__eq__,    ["/"], true]
    - [curdir, curdir.__eq__, ["."], true]
    - [pardir, pardir.__eq__, [".."], true]
    - [extsep, extsep.__eq__, ["."], true]

# ---------------------------------------------------------------------------
# os separator class names — combined table
#
# No prior os spec collects sep/linesep/pathsep/devnull __class__.__name__ in
# a single table. os_extra22 covers linesep/pathsep as standalone invariants;
# this table groups sep/linesep/pathsep/devnull together under extra23.
# ---------------------------------------------------------------------------

table os_extra23.separator_class_names:
  description: "__class__.__name__ == 'str' for os.sep, os.linesep, os.pathsep, os.devnull"
  kind: python_call_eq
  category: constant_types
  id_prefix: cls

  columns: [id, function, args, expected]
  rows:
    - [sep,     sep.__class__.__name__.__eq__,     ["str"], true]
    - [linesep, linesep.__class__.__name__.__eq__, ["str"], true]
    - [pathsep, pathsep.__class__.__name__.__eq__, ["str"], true]
    - [devnull, devnull.__class__.__name__.__eq__, ["str"], true]
