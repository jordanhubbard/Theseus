spec: io_extra246
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/fileio.c"
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io_extra.zspec.zsdl — covers lower-level _io module contracts"
    - "io_extra245.zspec.zsdl — covers BytesIO class identity and method name/qualname checks"
  notes:
    - "This spec covers: io.FileIO class identity contracts — __name__, __module__, __qualname__, __bases__, __class__, and method name/qualname checks."
    - "io.FileIO is the C class for unbuffered raw binary file I/O; its __module__ is '_io' (C extension), not 'io'."
    - "io.FileIO.__name__ == 'FileIO' — the class name is 6 characters; verified Python 3.14.3 macOS."
    - "io.FileIO.__module__ == '_io' — defined in the C extension _io, length 3; verified Python 3.14.3 macOS."
    - "io.FileIO.__qualname__ == 'FileIO' — matches __name__ for a top-level class; verified Python 3.14.3 macOS."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — the immediate base class; length 10; verified Python 3.14.3 macOS."
    - "io.FileIO.__class__.__name__ == 'type' — FileIO is a class object; verified Python 3.14.3 macOS."
    - "io.FileIO.read.__name__ == 'read' — length 4; verified Python 3.14.3 macOS."
    - "io.FileIO.read.__qualname__ == 'FileIO.read' — length 11; verified Python 3.14.3 macOS."
    - "io.FileIO.write.__name__ == 'write' — length 5; verified Python 3.14.3 macOS."
    - "io.FileIO.write.__qualname__ == 'FileIO.write' — length 12; verified Python 3.14.3 macOS."
    - "io.FileIO.readinto.__name__ == 'readinto' — length 8; verified Python 3.14.3 macOS."
    - "io.FileIO.readinto.__qualname__ == 'FileIO.readinto' — length 15; verified Python 3.14.3 macOS."
    - "io.FileIO.close.__name__ == 'close' — length 5; verified Python 3.14.3 macOS."
    - "io.FileIO.close.__qualname__ == 'FileIO.close' — length 12; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO class name and module identity contracts
# These verify the class object's identity attributes from the io module.
# io.FileIO is re-exported from _io (C extension).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra246.FileIO.name_eq:
  description: "io.FileIO.__name__ == 'FileIO' — C class name is 'FileIO'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra246.FileIO.name_len:
  description: "len(io.FileIO.__name__) == 6 — 'FileIO' has 6 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__name__.__len__
  args: []
  expected: 6

invariant io_extra246.FileIO.module_eq:
  description: "io.FileIO.__module__ == '_io' — FileIO is defined in the C extension _io, not in io.py; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra246.FileIO.module_len:
  description: "len(io.FileIO.__module__) == 3 — '_io' has 3 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__module__.__len__
  args: []
  expected: 3

invariant io_extra246.FileIO.qualname_eq:
  description: "io.FileIO.__qualname__ == 'FileIO' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__qualname__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra246.FileIO.qualname_len:
  description: "len(io.FileIO.__qualname__) == 6 — 'FileIO' has 6 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__qualname__.__len__
  args: []
  expected: 6

invariant io_extra246.FileIO.class_is_type:
  description: "io.FileIO.__class__.__name__ == 'type' — FileIO is a class object (its metaclass is type); verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# io.FileIO.__bases__[0].__name__ identity contract
# The immediate base class of FileIO is _RawIOBase.
# Accessed via __bases__.__getitem__(0).__name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra246.FileIO.base_name:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — immediate base class of FileIO; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_RawIOBase"

invariant io_extra246.FileIO.base_name_len:
  description: "len(io.FileIO.__bases__[0].__name__) == 10 — '_RawIOBase' has 10 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_chain: __len__
  expected: 10

# ---------------------------------------------------------------------------
# io.FileIO method name identity contracts
# read, write, readinto, close are key FileIO methods.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra246.FileIO.read.name_eq:
  description: "io.FileIO.read.__name__ == 'read' — method name is 'read'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: FileIO.read.__name__.__eq__
  args: ["read"]
  expected: true

invariant io_extra246.FileIO.read.qualname_eq:
  description: "io.FileIO.read.__qualname__ == 'FileIO.read' — qualname is 'FileIO.read'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: FileIO.read.__qualname__.__eq__
  args: ["FileIO.read"]
  expected: true

invariant io_extra246.FileIO.write.name_eq:
  description: "io.FileIO.write.__name__ == 'write' — method name is 'write'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: FileIO.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant io_extra246.FileIO.write.qualname_eq:
  description: "io.FileIO.write.__qualname__ == 'FileIO.write' — qualname is 'FileIO.write'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: FileIO.write.__qualname__.__eq__
  args: ["FileIO.write"]
  expected: true

invariant io_extra246.FileIO.readinto.name_eq:
  description: "io.FileIO.readinto.__name__ == 'readinto' — method name is 'readinto'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: FileIO.readinto.__name__.__eq__
  args: ["readinto"]
  expected: true

invariant io_extra246.FileIO.readinto.qualname_eq:
  description: "io.FileIO.readinto.__qualname__ == 'FileIO.readinto' — qualname is 'FileIO.readinto'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: FileIO.readinto.__qualname__.__eq__
  args: ["FileIO.readinto"]
  expected: true

invariant io_extra246.FileIO.close.name_eq:
  description: "io.FileIO.close.__name__ == 'close' — method name is 'close'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: FileIO.close.__name__.__eq__
  args: ["close"]
  expected: true

# ---------------------------------------------------------------------------
# io.FileIO method __name__ length spot-checks
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra246.FileIO_method_name_lengths:
  description: "io.FileIO method __name__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: iofio246

  columns: [id, function, args, expected]
  rows:
    - [read_name_len,     FileIO.read.__name__.__len__,     [], 4]
    - [write_name_len,    FileIO.write.__name__.__len__,    [], 5]
    - [readinto_name_len, FileIO.readinto.__name__.__len__, [], 8]
    - [close_name_len,    FileIO.close.__name__.__len__,    [], 5]

# ---------------------------------------------------------------------------
# io.FileIO method __qualname__ length spot-checks
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra246.FileIO_method_qualname_lengths:
  description: "io.FileIO method __qualname__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: iofiom246

  columns: [id, function, args, expected]
  rows:
    - [read_qualname_len,     FileIO.read.__qualname__.__len__,     [], 11]
    - [write_qualname_len,    FileIO.write.__qualname__.__len__,    [], 12]
    - [readinto_qualname_len, FileIO.readinto.__qualname__.__len__, [], 15]
    - [close_qualname_len,    FileIO.close.__qualname__.__len__,    [], 12]
