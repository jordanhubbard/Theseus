spec: theseus_secrets_cr
version: ">=3.9"
backend: python_cleanroom(theseus_secrets_cr)
blocks: secrets

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html"
  notes:
    - "Clean-room cryptographically suitable random values. Do NOT import secrets, random, or os."
    - "Implement using Python's built-in hash/id entropy sources or /dev/urandom via open()."
    - "token_bytes(n): return n cryptographically random bytes."
    - "token_hex(n): return 2n hex characters of random data."
    - "token_urlsafe(n): return URL-safe base64 token of n random bytes."
    - "choice(seq): return random element from sequence."
    - "secrets_token_bytes_len(): len(token_bytes(16)) == 16."
    - "secrets_token_hex_len(): len(token_hex(16)) == 32."
    - "secrets_token_hex_is_hex(): all chars in token_hex(8) are hex digits."
    - "Export: token_bytes, token_hex, token_urlsafe, choice."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_secrets_cr.token_bytes_len:
  description: "len(token_bytes(16)) == 16"
  category: tokens
  kind: python_call_eq
  function: secrets_token_bytes_len
  args: []
  expected: 16

invariant theseus_secrets_cr.token_hex_len:
  description: "len(token_hex(16)) == 32"
  category: tokens
  kind: python_call_eq
  function: secrets_token_hex_len
  args: []
  expected: 32

invariant theseus_secrets_cr.token_hex_is_hex:
  description: "all chars in token_hex(8) are hex digits"
  category: tokens
  kind: python_call_eq
  function: secrets_token_hex_is_hex
  args: []
  expected: true
