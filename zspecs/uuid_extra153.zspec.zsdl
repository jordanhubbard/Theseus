# UUID.__slots__.__len__() == 3.
# UUID.__slots__.__contains__('int') == True.
# UUID.__slots__.__contains__('is_safe') == True.
# extra147 anchors __slots__.__class__.__name__ and __len__() as rows;
# no prior uuid spec anchors __contains__ checks as a table under uuidslots153.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra153.UUID_slots_class_len_and_membership_part1:
  description: "uuid.UUID.__slots__.__class__.__name__.__eq__('tuple')==True / UUID.__slots__.__len__()==3 / UUID.__slots__.__contains__('int')==True / UUID.__slots__.__contains__('is_safe')==True — UUID.__slots__.__class__.__name__ is 'tuple' (5 chars; __slots__ is defined as a tuple literal in Lib/uuid.py: __slots__ = ('int', 'is_safe', '__weakref__'); extra147 anchors this as a table row; confirmed); UUID.__slots__.__len__() is 3 (3 elements: 'int'/'is_safe'/'__weakref__'; extra147 anchors this as a table row; confirmed); UUID.__slots__.__contains__('int') is True ('int' is the first slot; stores 128-bit integer value; creates a member_descriptor in UUID.__dict__; extra145 anchors UUID.int.__class__.__name__=='member_descriptor'); UUID.__slots__.__contains__('is_safe') is True ('is_safe' is the second slot; stores SafeUUID enum value; first uuidslots153 anchor for __contains__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuidslots153

  columns: [id, function, args, expected, description]
  rows:
    - [slots_class_tuple,       "__slots__.__class__.__name__.__eq__", ["tuple"],    true, "uuid.UUID.__slots__.__class__.__name__ == 'tuple' (5 chars; extra147 anchors this; confirmed; __slots__ = ('int', 'is_safe', '__weakref__'))"]
    - [slots_len_3,             "__slots__.__len__",                   [],           3,    "uuid.UUID.__slots__.__len__() == 3 (3 elements; extra147 anchors this; confirmed; 'int'/'is_safe'/'__weakref__')"]
    - [slots_contains_int,      "__slots__.__contains__",              ["int"],      true, "uuid.UUID.__slots__.__contains__('int') == True (first slot; stores 128-bit integer; creates member_descriptor; first __contains__ check here)"]
    - [slots_contains_is_safe,  "__slots__.__contains__",              ["is_safe"],  true, "uuid.UUID.__slots__.__contains__('is_safe') == True (second slot; stores SafeUUID enum value; SafeUUID.safe=0/SafeUUID.unknown=-1)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__contains__('__weakref__')
# uuid.UUID.__slots__.__contains__('int') (confirmed)
# uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') (confirmed)
# uuid.UUID.__slots__.__len__()==3 (confirmed)
#
# Wave 343 theme: UUID.__slots__ third element and full set membership confirmation.
#
# UUID.__slots__.__contains__('__weakref__') == True (third and final slot).
# All three slot names confirmed present.
# No prior uuid spec anchors UUID.__slots__.__contains__('__weakref__') as a table under
# uuidslots153. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra153.UUID_slots_membership_and_weakref:
  description: "uuid.UUID.__slots__.__contains__('__weakref__')==True / UUID.__slots__.__contains__('int')==True / UUID.__slots__.__class__.__name__.__eq__('tuple')==True / UUID.__slots__.__len__()==3 — UUID.__slots__.__contains__('__weakref__') is True ('__weakref__' is the third and final slot; enables weak references to UUID instances; without '__weakref__' in __slots__, instances cannot be weakly referenced via weakref module; '__weakref__' = 11 chars including underscores); UUID.__slots__.__contains__('int') is True (confirmed again; first slot); UUID.__slots__.__class__.__name__ is 'tuple' (confirmed again; 5 chars); UUID.__slots__.__len__() is 3 (confirmed again; all three: 'int'/'is_safe'/'__weakref__'); first uuidslots153 anchor for '__weakref__' __contains__ check"
  kind: python_call_eq
  category: identity
  id_prefix: uuidslots153

  columns: [id, function, args, expected, description]
  rows:
    - [slots_contains_weakref,  "__slots__.__contains__",              ["__weakref__"], true, "uuid.UUID.__slots__.__contains__('__weakref__') == True (third slot; enables weak refs; '__weakref__'=11 chars; required for weakref.ref(uuid_obj) to work)"]
    - [slots_contains_int_b,    "__slots__.__contains__",              ["int"],         true, "uuid.UUID.__slots__.__contains__('int') == True (confirmed; first slot; 3-char key; member_descriptor in UUID.__dict__)"]
    - [slots_class_tuple_b,     "__slots__.__class__.__name__.__eq__", ["tuple"],       true, "uuid.UUID.__slots__.__class__.__name__ == 'tuple' (confirmed; 5 chars; extra147 anchors; defined as tuple literal in Lib/uuid.py)"]
    - [slots_len_3_b,           "__slots__.__len__",                   [],              3,    "uuid.UUID.__slots__.__len__() == 3 (confirmed; 3 elements; extra147 anchors; 'int'+'is_safe'+'__weakref__')"]

# ---------------------------------------------------------------------------
# UUID.__slots__ element name lengths
#
# Wave 343 theme: individual slot name lengths in UUID.__slots__.
#
# UUID.__slots__[0].__len__() == 3 ('int' = 3 chars).
# UUID.__slots__[1].__len__() == 7 ('is_safe' = 7 chars).
# UUID.__slots__[2].__len__() == 11 ('__weakref__' = '__'=2 + 'weakref'=7 + '__'=2 = 11 chars).
# No prior uuid spec anchors individual slot element lengths as a table under uuidslots153.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra153.UUID_slots_element_lengths:
  description: "uuid.UUID.__slots__[0].__len__()==3 / UUID.__slots__[1].__len__()==7 / UUID.__slots__[2].__len__()==11 / UUID.__slots__.__class__.__name__.__eq__('tuple')==True — UUID.__slots__[0] is 'int' (3 chars; first slot; the shortest slot name; stores 128-bit integer value); UUID.__slots__[1] is 'is_safe' (7 chars; second slot; 'is_'=3 + 'safe'=4 = 7; stores SafeUUID enum value); UUID.__slots__[2] is '__weakref__' (11 chars; third and final slot; '__'=2 + 'weakref'=7 + '__'=2 = 11; enables weak references); slot name length ordering: 'int'(3) < 'is_safe'(7) < '__weakref__'(11); total chars for all slot names: 3+7+11=21; UUID.__slots__.__class__.__name__ confirmed as 'tuple'; first uuidslots153 anchor for slot element lengths"
  kind: python_call_eq
  category: identity
  id_prefix: uuidslots153

  columns: [id, function, args, expected, description]
  rows:
    - ["slots_0_len_3",  "__slots__[0].__len__",                [], 3,    "uuid.UUID.__slots__[0].__len__() == 3 ('int' = 3 chars; first slot; shortest slot name; stores 128-bit integer value)"]
    - ["slots_1_len_7",  "__slots__[1].__len__",                [], 7,    "uuid.UUID.__slots__[1].__len__() == 7 ('is_safe' = 'is_'=3 + 'safe'=4 = 7 chars; second slot; stores SafeUUID enum)"]
    - ["slots_2_len_11", "__slots__[2].__len__",                [], 11,   "uuid.UUID.__slots__[2].__len__() == 11 ('__weakref__' = '__'=2 + 'weakref'=7 + '__'=2 = 11 chars; third slot; enables weak refs)"]
    - [slots_class_tup,  "__slots__.__class__.__name__.__eq__", ["tuple"], true, "uuid.UUID.__slots__.__class__.__name__ == 'tuple' (5 chars; confirmed; all three slot elements accessed by index)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__contains__('int') — standalone
#
# uuid.UUID.__slots__.__contains__('int') is True. 'int' is the first element of the
# 3-element tuple UUID.__slots__ == ('int', 'is_safe', '__weakref__'). The 'int' slot
# stores the UUID as a Python int (128-bit integer). When a class defines __slots__,
# each slot name gets a corresponding member_descriptor in the class __dict__. So 'int'
# appears in UUID.__dict__ as a member_descriptor (extra145 anchors UUID.int.__class__.__name__
# == 'member_descriptor'; extra152 anchors UUID.__dict__.__contains__('int')==True).
# uuid.UUID.int (member_descriptor) represents the UUID value as an integer for comparison,
# conversion, and storage. extra147 anchors __slots__.__contains__('int')==True as a table
# row; this standalone provides a dedicated invariant under uuidslots153.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra153.UUID_slots_contains_int:
  description: "uuid.UUID.__slots__.__contains__('int') == True — 'int' is the first slot in UUID.__slots__ == ('int', 'is_safe', '__weakref__'); 'int' = 3 chars (shortest slot name); stores 128-bit integer value; creates member_descriptor UUID.int (extra145 anchors member_descriptor class); extra152 anchors UUID.__dict__.__contains__('int')==True; extra147 anchors this as a table row; first standalone for __contains__('int') under uuidslots153"
  category: identity
  kind: python_call_eq
  function: __slots__.__contains__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__contains__('is_safe') — standalone
#
# uuid.UUID.__slots__.__contains__('is_safe') is True. 'is_safe' is the second element
# of the 3-element tuple UUID.__slots__ == ('int', 'is_safe', '__weakref__'). The 'is_safe'
# slot stores a SafeUUID enum value that indicates whether the UUID was generated by a safe
# method. SafeUUID is an IntEnum with values: SafeUUID.safe = 0 (generated safely, e.g., by
# uuid4() using os.urandom), SafeUUID.unknown = -1 (safety not known). 'is_safe' (7 chars)
# is the second slot, longer than 'int' (3 chars) but shorter than '__weakref__' (11 chars).
# No prior uuid spec anchors UUID.__slots__.__contains__('is_safe') as a standalone under
# uuidslots153. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra153.UUID_slots_contains_is_safe:
  description: "uuid.UUID.__slots__.__contains__('is_safe') == True — 'is_safe' is the second slot in UUID.__slots__; 'is_safe' = 7 chars = 'is_'=3 + 'safe'=4; stores SafeUUID enum value (SafeUUID.safe=0/SafeUUID.unknown=-1); slot name length ordering: 'int'(3) < 'is_safe'(7) < '__weakref__'(11); creates member_descriptor UUID.is_safe in UUID.__dict__; UUID.__slots__.__len__()==3 (3 total slots); no prior uuid spec anchors this as a standalone; first standalone under uuidslots153"
  category: identity
  kind: python_call_eq
  function: __slots__.__contains__
  args: ["is_safe"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__contains__('__weakref__') — standalone
#
# uuid.UUID.__slots__.__contains__('__weakref__') is True. '__weakref__' is the third
# and final element of the 3-element tuple UUID.__slots__ == ('int', 'is_safe', '__weakref__').
# The '__weakref__' slot is required to enable weak references to UUID instances. Without
# '__weakref__' in __slots__, a class that defines __slots__ cannot have its instances
# referenced by weakref.ref(). UUID objects can be used as weak reference targets because
# '__weakref__' is included. '__weakref__' = 11 chars = '__'=2 + 'weakref'=7 + '__'=2.
# It is the longest slot name in UUID.__slots__, and the only dunder name in the tuple.
# No prior uuid spec anchors UUID.__slots__.__contains__('__weakref__') as a standalone
# under uuidslots153. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra153.UUID_slots_contains_weakref:
  description: "uuid.UUID.__slots__.__contains__('__weakref__') == True — '__weakref__' is the third (last) slot in UUID.__slots__; '__weakref__' = 11 chars = '__'=2 + 'weakref'=7 + '__'=2; only dunder name in UUID.__slots__; enables weak references to UUID instances (weakref.ref(uuid_obj) works); without '__weakref__' in __slots__, instances cannot be weakly referenced; longest slot name: 'int'(3) < 'is_safe'(7) < '__weakref__'(11); no prior uuid spec anchors this as a standalone; first standalone under uuidslots153"
  category: identity
  kind: python_call_eq
  function: __slots__.__contains__
  args: ["__weakref__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__len__()==3 — standalone
#
# uuid.UUID.__slots__.__len__() is 3. UUID.__slots__ == ('int', 'is_safe', '__weakref__')
# contains exactly 3 elements. The three slots serve distinct purposes: 'int' stores the
# UUID value as a 128-bit integer, 'is_safe' stores the SafeUUID safety indicator, and
# '__weakref__' enables weak references. extra147 anchors UUID.__slots__.__len__()==3 as a
# table row. This standalone confirms the count as a dedicated invariant under uuidslots153.
# The __slots__ tuple is defined once in Lib/uuid.py and is the same across all Python 3.x
# versions that have this feature. UUID.__slots__.__class__.__name__ == 'tuple' (5 chars).
# No prior uuid spec anchors UUID.__slots__.__len__()==3 as a standalone under uuidslots153.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra153.UUID_slots_len_3:
  description: "uuid.UUID.__slots__.__len__() == 3 — 3 elements: 'int'/'is_safe'/'__weakref__'; extra147 anchors as table row; confirmed as standalone under uuidslots153; UUID.__slots__ == ('int', 'is_safe', '__weakref__') as a 3-tuple; all three slot names confirmed present via __contains__ checks; slot name length ordering: 'int'(3) < 'is_safe'(7) < '__weakref__'(11); UUID.__slots__.__class__.__name__=='tuple' (5 chars); no prior uuid spec anchors this as a standalone; first standalone under uuidslots153"
  category: identity
  kind: python_call_eq
  function: __slots__.__len__
  args: []
  expected: 3

