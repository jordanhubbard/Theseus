spec: merge_deep
version: ">=3.0.3"
backend: node(merge-deep)

docs: https://www.npmjs.com/package/merge-deep

provenance:
  derived_from:
    - "merge-deep README — https://www.npmjs.com/package/merge-deep"
    - "Test vectors verified with merge-deep via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "merge-deep source"
  notes:
    - "merge-deep is an npm package. Install: npm install merge-deep"
    - "Recursively merges own enumerable properties of source objects."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new deeply merged object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table merge_deep.merge:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: mergedeep

  columns: [id, args, expected]
  rows:
    - [nested, [{"a": 1, "b": {"c": 1}}, {"b": {"d": 2}, "e": 3}],
       {"a": 1, "b": {"c": 1, "d": 2}, "e": 3}]
