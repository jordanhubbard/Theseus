spec: merge_options
version: ">=3.0.0"
backend: node(merge-options)

docs: https://github.com/schnittstabil/merge-options#readme

provenance:
  derived_from:
    - "merge-options README — https://github.com/schnittstabil/merge-options#readme"
    - "Test vectors verified with merge-options via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "merge-options source"
  notes:
    - "Deep merge for option objects — second arg wins (opposite of defu); arrays are replaced (not concatenated)."
    - "Install: npm install merge-options"
    - "v3 CJS; module export IS the merge function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant merge_options.basic_merge:
  description: "Two disjoint objects merge to union"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{a: 1}, {b: 2}]
  chain:
    - {get: a}
  expected: 1

invariant merge_options.basic_merge_b:
  description: "Two disjoint objects merge to union (b)"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{a: 1}, {b: 2}]
  chain:
    - {get: b}
  expected: 2

invariant merge_options.right_overrides_left:
  description: "Right (later) arg wins on conflict (opposite of defu)"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{a: 1, b: 1}, {a: 2}]
  chain:
    - {get: a}
  expected: 2

invariant merge_options.left_preserved_when_no_conflict:
  description: "Left key preserved when right doesn't override"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{a: 1, b: 1}, {a: 2}]
  chain:
    - {get: b}
  expected: 1

invariant merge_options.nested_object_deep_merged:
  description: "Nested objects merged recursively"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{user: {name: "a"}}, {user: {age: 30}}]
  chain:
    - {get: "user.name"}
  expected: "a"

invariant merge_options.nested_age_filled:
  description: "Nested age filled in from right arg"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{user: {name: "a"}}, {user: {age: 30}}]
  chain:
    - {get: "user.age"}
  expected: 30

invariant merge_options.arrays_replaced_not_concatenated:
  description: "Arrays from right arg REPLACE left (not merged or concatenated)"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{arr: [1, 2]}, {arr: [3, 4]}]
  chain:
    - {get: arr}
  expected: [3, 4]

invariant merge_options.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"
