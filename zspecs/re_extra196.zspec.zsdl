spec: re_extra196
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra195.zspec.zsdl."
    - "This spec covers re.error / re.PatternError exception class identity — __name__, __module__, __bases__[0].__name__, __class__.__name__, re.PatternError identity, and name length."
    - "re.error.__name__ == 'PatternError' (len=12); in Python 3.13+ re.error was renamed to PatternError; re.error is now an alias; confirmed Python 3.14.3 macOS."
    - "re.error.__module__ == 're' (len=2); the exception class is defined in the re module; confirmed Python 3.14.3 macOS."
    - "re.error.__bases__[0].__name__ == 'Exception' (len=9); PatternError/re.error inherits directly from Exception; confirmed Python 3.14.3 macOS."
    - "re.error.__class__.__name__ == 'type' — exception classes use the plain type metaclass; confirmed Python 3.14.3 macOS."
    - "re.PatternError.__name__ == 'PatternError' (len=12); re.PatternError is the canonical name introduced in Python 3.13; re.error is an alias pointing to the same class; confirmed Python 3.14.3 macOS."
    - "re.PatternError.__module__ == 're' (len=2); same module as re.error; confirmed Python 3.14.3 macOS."
    - "re.PatternError.__name__.__eq__(re.error.__name__) — both aliases report the same __name__ 'PatternError'; confirmed Python 3.14.3 macOS."
    - "re.error.__name__.__len__() == 12 — P(1)a(2)t(3)t(4)e(5)r(6)n(7)E(8)r(9)r(10)o(11)r(12); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.error class identity attributes
# __name__(PatternError,12), __module__(re,2), __bases__[0](Exception,9), __class__(type)
# ---------------------------------------------------------------------------

table re_extra196.error_class_identity:
  description: "re.error class identity: __name__='PatternError'(12), __module__='re'(2), __bases__[0].__name__='Exception'(9), __class__.__name__='type'"
  kind: python_call_eq
  category: identity
  id_prefix: reerror196

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,       re.error.__name__.__eq__,                          ["PatternError"], true, "re.error.__name__ == 'PatternError' (len=12); in Python 3.13+ re.error is an alias for PatternError; confirmed Python 3.14.3 macOS"]
    - [error_module_eq,     re.error.__module__.__eq__,                        ["re"],           true, "re.error.__module__ == 're' (len=2); the exception class is defined in the re module; confirmed Python 3.14.3 macOS"]
    - [error_base_eq,       "re.error.__bases__[0].__name__.__eq__",           ["Exception"],    true, "re.error.__bases__[0].__name__ == 'Exception' (len=9); PatternError inherits directly from Exception; confirmed Python 3.14.3 macOS"]
    - [error_class_name_eq, re.error.__class__.__name__.__eq__,                ["type"],         true, "re.error.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS"]
    - [error_name_len,      re.error.__name__.__len__,                         [], 12, "re.error.__name__.__len__() == 12 — P(1)a(2)t(3)t(4)e(5)r(6)n(7)E(8)r(9)r(10)o(11)r(12); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.PatternError class identity attributes
# __name__(PatternError,12), __module__(re,2) — canonical name introduced in Python 3.13
# ---------------------------------------------------------------------------

table re_extra196.patternerror_class_identity:
  description: "re.PatternError class identity: __name__='PatternError'(12), __module__='re'(2); PatternError is the canonical name; re.error is an alias pointing to the same class object"
  kind: python_call_eq
  category: identity
  id_prefix: reerror196

  columns: [id, function, args, expected, description]
  rows:
    - [patternerror_name_eq,    re.PatternError.__name__.__eq__,    ["PatternError"], true, "re.PatternError.__name__ == 'PatternError' (len=12); canonical name introduced in Python 3.13; confirmed Python 3.14.3 macOS"]
    - [patternerror_module_eq,  re.PatternError.__module__.__eq__,  ["re"],           true, "re.PatternError.__module__ == 're' (len=2); same module as re.error; confirmed Python 3.14.3 macOS"]
    - [patternerror_name_len,   re.PatternError.__name__.__len__,   [], 12, "re.PatternError.__name__.__len__() == 12; same length as re.error.__name__; confirmed Python 3.14.3 macOS"]
    - [patternerror_module_len, re.PatternError.__module__.__len__, [], 2,  "re.PatternError.__module__.__len__() == 2 — r(1)e(2); same length as re.error.__module__; confirmed Python 3.14.3 macOS"]
    - [error_module_len,        re.error.__module__.__len__,        [], 2,  "re.error.__module__.__len__() == 2 — r(1)e(2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.error / re.PatternError alias identity and base class lengths
# both aliases share __name__ and __module__; Exception has len=9
# ---------------------------------------------------------------------------

table re_extra196.error_alias_and_base_lengths:
  description: "re.error and re.PatternError alias identity: both __name__.__eq__('PatternError'); Exception base class name length=9"
  kind: python_call_eq
  category: identity
  id_prefix: reerror196

  columns: [id, function, args, expected, description]
  rows:
    - [names_match,      re.PatternError.__name__.__eq__,               ["PatternError"], true, "re.PatternError.__name__ == re.error.__name__ == 'PatternError'; both aliases report the same __name__; confirmed Python 3.14.3 macOS"]
    - [base_name_len,    "re.error.__bases__[0].__name__.__len__",       [], 9, "re.error.__bases__[0].__name__.__len__() == 9 — E(1)x(2)c(3)e(4)p(5)t(6)i(7)o(8)n(9); confirmed Python 3.14.3 macOS"]
    - [error_name_len2,  re.error.__name__.__len__,                      [], 12, "re.error.__name__.__len__() == 12; same as re.PatternError.__name__.__len__(); confirmed Python 3.14.3 macOS"]
    - [error_class_type, re.error.__class__.__name__.__eq__,             ["type"], true, "re.error.__class__.__name__ == 'type'; exception class uses plain type metaclass; confirmed Python 3.14.3 macOS"]
    - [base_name_eq,     "re.error.__bases__[0].__name__.__eq__",        ["Exception"], true, "re.error.__bases__[0].__name__ == 'Exception' (len=9); PatternError/re.error inherits directly from Exception; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra196.error_name_eq:
  description: "re.error.__name__ == 'PatternError' — in Python 3.13+ re.error was renamed to PatternError; re.error is now an alias for the same class; the __name__ attribute reports the canonical class name 'PatternError' (len=12); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra196.error_module_eq:
  description: "re.error.__module__ == 're' — the PatternError/re.error exception class is defined in the re module (len=2); the module attribute confirms the public module ownership; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra196.error_base_name_eq:
  description: "re.error.__bases__[0].__name__ == 'Exception' — PatternError (re.error) inherits directly from Exception (len=9); this makes it a standard Python exception that can be caught with 'except re.error' or 'except Exception'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra196.error_class_name_type:
  description: "re.error.__class__.__name__ == 'type' — PatternError/re.error uses the plain type metaclass (not ABCMeta or EnumMeta); exception classes are standard Python type instances; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra196.patternerror_name_eq:
  description: "re.PatternError.__name__ == 'PatternError' — re.PatternError is the canonical exception class name introduced in Python 3.13 to improve discoverability; re.error is an alias for the same class object; both report the same __name__ value; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra196.patternerror_module_eq:
  description: "re.PatternError.__module__ == 're' — the canonical PatternError class is defined in the re module (len=2); the module is the same as re.error.__module__; both aliases point to the same class and agree on all class attributes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.PatternError.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra196.patternerror_names_match:
  description: "re.PatternError.__name__.__eq__(re.error.__name__) — re.PatternError and re.error are the same class object; both aliases report __name__ == 'PatternError'; this invariant verifies the alias identity by calling __eq__ on the PatternError name with the string 'PatternError' (the same value as re.error.__name__); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra196.error_name_len:
  description: "re.error.__name__.__len__() == 12 — 'PatternError' has 12 characters: P(1)a(2)t(3)t(4)e(5)r(6)n(7)E(8)r(9)r(10)o(11)r(12); this is the length of the exception class name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__name__.__len__
  args: []
  expected: 12

