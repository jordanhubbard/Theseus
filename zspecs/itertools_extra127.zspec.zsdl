# ---------------------------------------------------------------------------
# Table 1: itertools.permutations iterator protocol slot qualnames
#
# Wave 259 theme: itertools.permutations __iter__ and __next__ slot qualnames.
#
# itertools.permutations.__iter__.__qualname__.__eq__('permutations.__iter__') == True
# len(itertools.permutations.__iter__.__qualname__) == 21
# itertools.permutations.__next__.__qualname__.__eq__('permutations.__next__') == True
# len(itertools.permutations.__next__.__qualname__) == 21
# itertools.permutations.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True
# itertools.permutations.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True
#
# permutations is a C extension type implementing the iterator protocol.
# __iter__ and __next__ are wrapper_descriptor objects; their __qualname__
# is 'permutations.__iter__' and 'permutations.__next__' respectively.
# New to extra127.
# ---------------------------------------------------------------------------

table itertools_extra127.permutations_iter_next_qualnames:
  description: "itertools.permutations __iter__/__next__ __qualname__ and __class__.__name__; wrapper_descriptor slots; wave 259; new to extra127"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsperm127

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_iter_qualname_eq,
       "permutations.__iter__.__qualname__.__eq__",
       ["permutations.__iter__"],
       true,
       "itertools.permutations.__iter__.__qualname__.__eq__('permutations.__iter__') == True — permutations is a C extension type; __iter__ is a wrapper_descriptor slot whose __qualname__ includes the type name as a dotted prefix; str.__eq__('permutations.__iter__') returns True; new to extra127"]
    - [permutations_iter_qualname_len_eq_21,
       "permutations.__iter__.__qualname__.__len__",
       [],
       21,
       "itertools.permutations.__iter__.__qualname__.__len__() == 21 — __qualname__ is 'permutations.__iter__' which has 21 characters; len('permutations.__iter__') == 21; new to extra127"]
    - [permutations_next_qualname_eq,
       "permutations.__next__.__qualname__.__eq__",
       ["permutations.__next__"],
       true,
       "itertools.permutations.__next__.__qualname__.__eq__('permutations.__next__') == True — __next__ is a wrapper_descriptor slot on the C extension type; its __qualname__ is 'permutations.__next__'; str.__eq__('permutations.__next__') returns True; new to extra127"]
    - [permutations_next_qualname_len_eq_21,
       "permutations.__next__.__qualname__.__len__",
       [],
       21,
       "itertools.permutations.__next__.__qualname__.__len__() == 21 — __qualname__ is 'permutations.__next__' which has 21 characters; len('permutations.__next__') == 21; new to extra127"]
    - [permutations_iter_class_name_eq_wrapper_descriptor,
       "permutations.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.permutations.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — when accessed on the C extension type, __iter__ is a wrapper_descriptor (the internal CPython type for C-level tp_iter slots); __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra127"]
    - [permutations_next_class_name_eq_wrapper_descriptor,
       "permutations.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.permutations.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — __next__ accessed on the C extension type is a wrapper_descriptor (CPython internal type for tp_iternext slots); __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra127"]

# ---------------------------------------------------------------------------
# Table 2: itertools.permutations __new__ qualname and class identity
#
# Wave 259 theme: itertools.permutations __new__ slot identity.
#
# itertools.permutations.__new__.__qualname__.__eq__('permutations.__new__') == True
# len(itertools.permutations.__new__.__qualname__) == 20
# itertools.permutations.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True
# itertools.permutations.__class__.__name__.__eq__('type') == True
# itertools.permutations.__module__.__eq__('itertools') == True
#
# __new__ on a C extension type is a builtin_function_or_method (not a
# wrapper_descriptor); its qualname is 'permutations.__new__' (len 20).
# New to extra127.
# ---------------------------------------------------------------------------

table itertools_extra127.permutations_new_identity:
  description: "itertools.permutations __new__ qualname (len 20) and class name 'builtin_function_or_method'; type identity __class__.__name__ and __module__; wave 259; new to extra127"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsperm127

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_new_qualname_eq,
       "permutations.__new__.__qualname__.__eq__",
       ["permutations.__new__"],
       true,
       "itertools.permutations.__new__.__qualname__.__eq__('permutations.__new__') == True — __new__ on the C extension type has a __qualname__ of 'permutations.__new__'; str.__eq__('permutations.__new__') returns True; new to extra127"]
    - [permutations_new_qualname_len_eq_20,
       "permutations.__new__.__qualname__.__len__",
       [],
       20,
       "itertools.permutations.__new__.__qualname__.__len__() == 20 — __qualname__ is 'permutations.__new__' which has 20 characters; len('permutations.__new__') == 20; new to extra127"]
    - [permutations_new_class_name_eq_builtin,
       "permutations.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.permutations.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — unlike __iter__ and __next__ which are wrapper_descriptors, __new__ on a C extension type is a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra127"]
    - [permutations_class_name_eq_type,
       "permutations.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.permutations.__class__.__name__.__eq__('type') == True — itertools.permutations is a C extension type defined in Modules/itertoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra127"]
    - [permutations_module_eq_itertools,
       "permutations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is a C extension type in Modules/itertoolsmodule.c; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra127"]

# ---------------------------------------------------------------------------
# Table 3: itertools.permutations __name__, __qualname__, and __mro__ length
#
# Wave 259 theme: itertools.permutations class name and MRO identity.
#
# itertools.permutations.__name__.__eq__('permutations') == True
# len(itertools.permutations.__name__) == 12
# itertools.permutations.__qualname__.__eq__('permutations') == True
# len(itertools.permutations.__qualname__) == 12
# len(itertools.permutations.__mro__) == 2
#
# permutations is a C extension type; its __name__ and __qualname__ are both
# 'permutations'; MRO is [permutations, object] (length 2). New to extra127.
# ---------------------------------------------------------------------------

table itertools_extra127.permutations_name_mro:
  description: "itertools.permutations __name__=='permutations' (len 12), __qualname__=='permutations' (len 12), __mro__ len==2; wave 259; new to extra127"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsperm127

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_name_eq,
       "permutations.__name__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — the __name__ attribute of the C extension type is 'permutations', matching the tp_name field in the PyTypeObject; str.__eq__('permutations') returns True; new to extra127"]
    - [permutations_name_len_eq_12,
       "permutations.__name__.__len__",
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — __name__ is 'permutations' which has 12 characters; len('permutations') == 12; new to extra127"]
    - [permutations_qualname_eq,
       "permutations.__qualname__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations is a top-level C extension type; __qualname__ equals the simple type name 'permutations'; str.__eq__('permutations') returns True; new to extra127"]
    - [permutations_qualname_len_eq_12,
       "permutations.__qualname__.__len__",
       [],
       12,
       "itertools.permutations.__qualname__.__len__() == 12 — __qualname__ is 'permutations' which has 12 characters; len('permutations') == 12; new to extra127"]
    - [permutations_mro_len_eq_2,
       "permutations.__mro__.__len__",
       [],
       2,
       "itertools.permutations.__mro__.__len__() == 2 — the MRO of permutations is [permutations, object]; as a C extension type inheriting directly from object it has exactly two MRO entries; len(__mro__) is 2; new to extra127"]

