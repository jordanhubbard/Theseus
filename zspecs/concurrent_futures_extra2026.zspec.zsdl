spec: concurrent_futures_extra2026
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __floordiv__, __mod__, __pow__, __divmod__ dict-presence checks."
    - "concurrent.futures types (Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor) are concurrency primitives."
    - "None of these types define division, floor division, modulo, power, or divmod protocols in their own __dict__."
    - "Executor is an abstract base class; ThreadPoolExecutor and ProcessPoolExecutor extend it."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2026.truediv_protocol:
  description: "concurrent.futures types __truediv__/__rtruediv__/__itruediv__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2026

  columns: [id, function, args, expected]
  rows:
    - ["cf2026001", "concurrent.futures.Future.__dict__.__contains__", ["__truediv__"], false]
    - ["cf2026002", "concurrent.futures.Future.__dict__.__contains__", ["__rtruediv__"], false]
    - ["cf2026003", "concurrent.futures.Future.__dict__.__contains__", ["__itruediv__"], false]
    - ["cf2026004", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__truediv__"], false]
    - ["cf2026005", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__rtruediv__"], false]
    - ["cf2026006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__itruediv__"], false]
    - ["cf2026007", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__truediv__"], false]
    - ["cf2026008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__rtruediv__"], false]
    - ["cf2026009", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__itruediv__"], false]
    - ["cf2026010", "concurrent.futures.Executor.__dict__.__contains__", ["__truediv__"], false]
    - ["cf2026011", "concurrent.futures.Executor.__dict__.__contains__", ["__rtruediv__"], false]
    - ["cf2026012", "concurrent.futures.Executor.__dict__.__contains__", ["__itruediv__"], false]

