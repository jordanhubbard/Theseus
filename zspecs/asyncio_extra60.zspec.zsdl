spec: asyncio_extra60
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/importlib.html#importlib.machinery.SourceFileLoader — SourceFileLoader documentation"
    - "https://docs.python.org/3/reference/import.html#module-spec — ModuleSpec documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Lib/_bootstrap_external.py"
    - "CPython source: Lib/importlib/_bootstrap_external.py"
  notes:
    - "This spec extends asyncio_extra59.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ (extra/extra2/extra5), Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), BoundedSemaphore/__bases__[0].__qualname__=='Semaphore' (extra53), Condition/__bases__[0].__qualname__=='object' (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') for Queue/Lock/Event/Semaphore/Condition (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), class __weakref__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), Queue/Lock/Event/Semaphore __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), Queue/Lock/Event __subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') (extra57), asyncio.__all__.__contains__ membership checks for Queue/Lock/Event/Semaphore/gather/sleep/Task/Future (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58), __loader__.__class__.__name__.__eq__('SourceFileLoader') (extra59), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra59), __file__.__class__.__name__.__eq__('str') (extra59), __cached__.__class__.__name__.__eq__('str') (extra59)."
    - "This spec covers (asynciospec60 namespace): wave 226 theme — __spec__.origin values + __spec__.submodule_search_locations checks + __loader__.__name__ length checks. asyncio.__loader__.__class__.__name__.__eq__('SourceFileLoader') — confirmed in extra59; now we check the string length: len('SourceFileLoader') == 16. asyncio.__spec__.origin.__class__.__name__.__eq__('str') — the origin is the file path to asyncio/__init__.py; it is a plain str. asyncio.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') — asyncio IS a package (directory Lib/asyncio/ with __init__.py); submodule_search_locations is NOT None; its __class__.__name__ == 'list' in Python 3.14.3. asyncio.__spec__.has_location — True for file-based packages. No prior asyncio spec has captured __loader__.__class__.__name__.__len__(), __spec__.origin.__class__.__name__, __spec__.submodule_search_locations.__class__.__name__, or __spec__.has_location checks."
    - "asyncio.__loader__.__class__.__name__.__len__() == 16. 'SourceFileLoader' has 16 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__spec__.origin.__class__.__name__ == 'str'. The spec origin is the absolute path to asyncio/__init__.py, which is a plain Python str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__spec__.submodule_search_locations.__class__.__name__ == 'list'. asyncio is a package; its submodule_search_locations is a list containing the asyncio package directory path. __class__.__name__ == 'list'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__spec__.has_location == True. asyncio is a file-based package (Lib/asyncio/__init__.py exists on disk); has_location is True for all SourceFileLoader-loaded modules. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio __spec__.origin + submodule_search_locations + loader name len
# — extra60
#
# Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations
# checks + __loader__.__name__ length checks.
#
# asyncio is a package (Lib/asyncio/__init__.py), so:
#   asyncio.__spec__.origin.__class__.__name__ == 'str'   (file path)
#   asyncio.__spec__.submodule_search_locations is NOT None
#   asyncio.__spec__.submodule_search_locations.__class__.__name__ == 'list'
#   asyncio.__spec__.has_location == True
#   asyncio.__loader__.__class__.__name__.__len__() == 16  (len of 'SourceFileLoader')
#
# No prior asyncio spec has captured these checks. Extra60 introduces the
# wave 226 theme in the asynciospec60 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra60.spec_origin_locations:
  description: "asyncio __spec__.origin + submodule_search_locations + loader name length checks in asynciospec60 namespace — asyncio is a package (Lib/asyncio/__init__.py); __spec__.origin is a str (file path); submodule_search_locations is NOT None and has __class__.__name__ == 'list'; has_location is True; __loader__.__class__.__name__.__len__() == 16 for 'SourceFileLoader'; wave 226 theme: __spec__.origin values + submodule_search_locations + loader name length; first origin/locations/has_location checks in any asyncio spec"
  kind: python_call_eq
  category: spec_origin
  id_prefix: asynciospec60

  columns: [id, function, args, expected, description]
  rows:
    - [loader_name_len,    __loader__.__class__.__name__.__len__,                   [],               16,   "asyncio.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; cross-checks the __loader__.__class__.__name__.__eq__('SourceFileLoader') assertion in extra59; wave 226 first __loader__.__class__.__name__.__len__ check in any asyncio spec"]
    - [origin_class_name,  __spec__.origin.__class__.__name__.__eq__,               ["str"],          true, "asyncio.__spec__.origin.__class__.__name__ == 'str' — the spec origin is the absolute file path to asyncio/__init__.py; it is a plain Python str; __spec__.origin.__class__.__name__.__eq__('str') returns True; wave 226 first __spec__.origin type check in any asyncio spec"]
    - [locations_cls_name, __spec__.submodule_search_locations.__class__.__name__.__eq__, ["list"],   true, "asyncio.__spec__.submodule_search_locations.__class__.__name__ == 'list' — asyncio IS a package; submodule_search_locations is a list containing the asyncio package directory path (NOT None); __class__.__name__ == 'list' in Python 3.14.3; wave 226 first submodule_search_locations class name check in any asyncio spec"]
    - [has_location,       __spec__.has_location.__eq__,                            [true],           true, "asyncio.__spec__.has_location == True — asyncio is a file-based package (Lib/asyncio/__init__.py); SourceFileLoader sets has_location to True for all disk-backed modules; __spec__.has_location.__eq__(True) returns True; wave 226 first has_location check in any asyncio spec"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra60
# ---------------------------------------------------------------------------

invariant asyncio_extra60.loader_name_len:
  description: "asyncio.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; cross-checks the string equality assertion established in extra59; wave 226 first __loader__.__class__.__name__.__len__ invariant in any asyncio spec"
  category: spec_origin
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant asyncio_extra60.origin_class_name_eq:
  description: "asyncio.__spec__.origin.__class__.__name__.__eq__('str') returns True — the spec origin is the absolute file path to asyncio/__init__.py; it is a plain Python str; wave 226 first __spec__.origin type invariant in any asyncio spec"
  category: spec_origin
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant asyncio_extra60.locations_class_name_eq:
  description: "asyncio.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') returns True — asyncio IS a package; submodule_search_locations is a list (NOT None); __class__.__name__ == 'list' in Python 3.14.3; wave 226 first submodule_search_locations class name invariant in any asyncio spec"
  category: spec_origin
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant asyncio_extra60.has_location_eq:
  description: "asyncio.__spec__.has_location.__eq__(True) returns True — asyncio is a file-based package loaded by SourceFileLoader; has_location is True for all disk-backed modules; wave 226 first has_location invariant in any asyncio spec"
  category: spec_origin
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true
