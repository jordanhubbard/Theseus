spec: io_extra205
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers io module class __name__ lengths not covered by prior io_extra specs."
    - "io.IOBase.__name__ == 'IOBase' (len=6); the abstract base class for all I/O classes; confirmed Python 3.14.3 macOS."
    - "io.RawIOBase.__name__ == 'RawIOBase' (len=9); abstract base for raw binary I/O; confirmed Python 3.14.3 macOS."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase' (len=14); abstract base for buffered binary I/O; confirmed Python 3.14.3 macOS."
    - "io.TextIOBase.__name__ == 'TextIOBase' (len=10); abstract base for text I/O; confirmed Python 3.14.3 macOS."
    - "io.FileIO.__name__ == 'FileIO' (len=6); raw binary file I/O class; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__name__ == 'BufferedReader' (len=14); buffered binary reader; confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' (len=14); buffered binary writer; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' (len=13); text-mode wrapper around a buffered binary stream; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io abstract base class __name__ lengths
# IOBase(6), RawIOBase(9), BufferedIOBase(14), TextIOBase(10)
# ---------------------------------------------------------------------------

table io_extra205.abstract_base_name_lengths:
  description: "io abstract base class __name__ lengths: IOBase(6), RawIOBase(9), BufferedIOBase(14), TextIOBase(10)"
  kind: python_call_eq
  category: identity
  id_prefix: ionamelens205

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_name_len,       io.IOBase.__name__.__len__,       [], 6,  "io.IOBase.__name__.__len__() == 6 — I(1)O(2)B(3)a(4)s(5)e(6); IOBase is the abstract base for all I/O; confirmed Python 3.14.3 macOS"]
    - [rawiobase_name_len,    io.RawIOBase.__name__.__len__,    [], 9,  "io.RawIOBase.__name__.__len__() == 9 — R(1)a(2)w(3)I(4)O(5)B(6)a(7)s(8)e(9); abstract base for raw binary I/O; confirmed Python 3.14.3 macOS"]
    - [bufferediobase_name_len, io.BufferedIOBase.__name__.__len__, [], 14, "io.BufferedIOBase.__name__.__len__() == 14 — B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)I(9)O(10)B(11)a(12)s(13)e(14); abstract base for buffered binary I/O; confirmed Python 3.14.3 macOS"]
    - [textiobase_name_len,   io.TextIOBase.__name__.__len__,   [], 10, "io.TextIOBase.__name__.__len__() == 10 — T(1)e(2)x(3)t(4)I(5)O(6)B(7)a(8)s(9)e(10); abstract base for text I/O; confirmed Python 3.14.3 macOS"]
    - [iobase_name_eq,        io.IOBase.__name__.__eq__,        ["IOBase"], true, "io.IOBase.__name__ == 'IOBase' (len=6); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io concrete binary class __name__ lengths
# FileIO(6), BufferedReader(14), BufferedWriter(14)
# ---------------------------------------------------------------------------

table io_extra205.concrete_binary_name_lengths:
  description: "io concrete binary class __name__ lengths: FileIO(6), BufferedReader(14), BufferedWriter(14)"
  kind: python_call_eq
  category: identity
  id_prefix: ionamelens205

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_name_len,         io.FileIO.__name__.__len__,         [], 6,  "io.FileIO.__name__.__len__() == 6 — F(1)i(2)l(3)e(4)I(5)O(6); raw binary file I/O class; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_name_len, io.BufferedReader.__name__.__len__, [], 14, "io.BufferedReader.__name__.__len__() == 14 — B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)R(9)e(10)a(11)d(12)e(13)r(14); buffered binary reader; confirmed Python 3.14.3 macOS"]
    - [bufferedwriter_name_len, io.BufferedWriter.__name__.__len__, [], 14, "io.BufferedWriter.__name__.__len__() == 14 — B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)W(9)r(10)i(11)t(12)e(13)r(14); buffered binary writer; confirmed Python 3.14.3 macOS"]
    - [fileio_name_eq,          io.FileIO.__name__.__eq__,          ["FileIO"], true, "io.FileIO.__name__ == 'FileIO' (len=6); confirmed Python 3.14.3 macOS"]
    - [bufferedreader_name_eq,  io.BufferedReader.__name__.__eq__,  ["BufferedReader"], true, "io.BufferedReader.__name__ == 'BufferedReader' (len=14); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io text wrapper and base comparison
# TextIOWrapper(13), BufferedIOBase(14), RawIOBase(9)
# ---------------------------------------------------------------------------

table io_extra205.text_wrapper_name_lengths:
  description: "io text wrapper and base name lengths: TextIOWrapper(13), BufferedWriter(14), TextIOBase(10)"
  kind: python_call_eq
  category: identity
  id_prefix: ionamelens205

  columns: [id, function, args, expected, description]
  rows:
    - [textiowrapper_name_len,  io.TextIOWrapper.__name__.__len__,  [], 13, "io.TextIOWrapper.__name__.__len__() == 13 — T(1)e(2)x(3)t(4)I(5)O(6)W(7)r(8)a(9)p(10)p(11)e(12)r(13); text-mode wrapper around buffered binary stream; confirmed Python 3.14.3 macOS"]
    - [textiowrapper_name_eq,   io.TextIOWrapper.__name__.__eq__,   ["TextIOWrapper"], true, "io.TextIOWrapper.__name__ == 'TextIOWrapper' (len=13); confirmed Python 3.14.3 macOS"]
    - [bufferedwriter_name_eq,  io.BufferedWriter.__name__.__eq__,  ["BufferedWriter"], true, "io.BufferedWriter.__name__ == 'BufferedWriter' (len=14); confirmed Python 3.14.3 macOS"]
    - [textiobase_name_eq,      io.TextIOBase.__name__.__eq__,      ["TextIOBase"], true, "io.TextIOBase.__name__ == 'TextIOBase' (len=10); confirmed Python 3.14.3 macOS"]
    - [rawiobase_name_eq,       io.RawIOBase.__name__.__eq__,       ["RawIOBase"], true, "io.RawIOBase.__name__ == 'RawIOBase' (len=9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra205.iobase_name_len:
  description: "io.IOBase.__name__.__len__() == 6 — 'IOBase' has 6 characters: I(1)O(2)B(3)a(4)s(5)e(6); IOBase is the abstract root of the io class hierarchy; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.IOBase.__name__.__len__
  args: []
  expected: 6

invariant io_extra205.rawiobase_name_len:
  description: "io.RawIOBase.__name__.__len__() == 9 — 'RawIOBase' has 9 characters: R(1)a(2)w(3)I(4)O(5)B(6)a(7)s(8)e(9); RawIOBase is the abstract base for raw (unbuffered) binary I/O; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.__name__.__len__
  args: []
  expected: 9

invariant io_extra205.bufferediobase_name_len:
  description: "io.BufferedIOBase.__name__.__len__() == 14 — 'BufferedIOBase' has 14 characters; abstract base for buffered binary I/O; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedIOBase.__name__.__len__
  args: []
  expected: 14

invariant io_extra205.textiobase_name_len:
  description: "io.TextIOBase.__name__.__len__() == 10 — 'TextIOBase' has 10 characters: T(1)e(2)x(3)t(4)I(5)O(6)B(7)a(8)s(9)e(10); abstract base for text-mode I/O; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOBase.__name__.__len__
  args: []
  expected: 10

invariant io_extra205.fileio_name_len:
  description: "io.FileIO.__name__.__len__() == 6 — 'FileIO' has 6 characters: F(1)i(2)l(3)e(4)I(5)O(6); FileIO is the raw binary file I/O class; tied in length with IOBase; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.__name__.__len__
  args: []
  expected: 6

invariant io_extra205.bufferedreader_name_len:
  description: "io.BufferedReader.__name__.__len__() == 14 — 'BufferedReader' has 14 characters; provides buffered binary reading; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.__name__.__len__
  args: []
  expected: 14

invariant io_extra205.bufferedwriter_name_len:
  description: "io.BufferedWriter.__name__.__len__() == 14 — 'BufferedWriter' has 14 characters; tied with BufferedReader and BufferedIOBase; provides buffered binary writing; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.__name__.__len__
  args: []
  expected: 14

invariant io_extra205.textiowrapper_name_len:
  description: "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters: T(1)e(2)x(3)t(4)I(5)O(6)W(7)r(8)a(9)p(10)p(11)e(12)r(13); TextIOWrapper wraps a BufferedIOBase for text-mode I/O; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__name__.__len__
  args: []
  expected: 13
