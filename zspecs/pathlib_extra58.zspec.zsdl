spec: pathlib_extra58
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra57.zspec.zsdl — covers 9 Path method qualname equality checks (write_text/read_bytes/write_bytes/mkdir/unlink/is_file/is_dir/stat/rename)."
    - "pathlib_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname/module for Path/PurePath/PurePosixPath/PureWindowsPath/pathlib-module and Path.open/read_text/exists __qualname__.__eq__()."
    - "pathlib_extra55.zspec.zsdl — covers 12 Path method qualname lengths."
    - "pathlib_extra54.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __class__.__qualname__.__eq__('type'); Path/__class__.__module__.__eq__('builtins'); PurePath/__class__.__module__.__eq__('builtins')."
    - "pathlib_extra53.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __class__.__name__.__eq__('type') and __class__.__name__.__len__()==4."
    - "pathlib_extra51.zspec.zsdl — covers pathlib module-level __module__ of various attributes."
    - "pathlib_extra50.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__len__()."
    - "pathlib_extra49.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__eq__()."
  notes:
    - "This spec extends pathlib_extra57.zspec.zsdl."
    - "Prior specs collectively covered: all pathlib class __qualname__ equality and lengths (pathlib_extra49/pathlib_extra50); class __class__.__name__/__qualname__ equality (pathlib_extra53/pathlib_extra54); Path.cwd and Path.home __qualname__ equality and length; Path file-operation method __qualname__ lengths (pathlib_extra55); pathlib class __doc__.__class__.__name__/__qualname__/__module__ (pathlib_extra56); Path method __qualname__.__eq__() for open/read_text/exists/write_text/read_bytes/write_bytes/mkdir/unlink/is_file/is_dir/stat/rename (pathlib_extra56/pathlib_extra57). NO prior pathlib spec checks __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath as standalone invariants. NO prior pathlib spec checks __module__.__len__() for Path or PurePath. NO prior pathlib spec checks pathlib.Path property descriptors (__class__.__name__ == 'property') for the named attributes."
    - "This spec covers: pathlib.Path.__module__.__eq__('pathlib') (NOVEL — no prior pathlib spec checks Path.__module__.__eq__ as a standalone invariant; 'pathlib' is the defining module; novel equality anchor in pathlibmod58 namespace); pathlib.PurePath.__module__.__eq__('pathlib') (NOVEL); pathlib.PurePosixPath.__module__.__eq__('pathlib') (NOVEL); pathlib.PureWindowsPath.__module__.__eq__('pathlib') (NOVEL); pathlib.Path.__module__.__len__()==7 (NOVEL — 'pathlib' has 7 characters; no prior pathlib spec checks Path.__module__.__len__(); novel length anchor); pathlib.PurePath.__module__.__len__()==7 (NOVEL); pathlib.Path.name.__class__.__name__.__eq__('property') (NOVEL — Path.name is a Python property descriptor; no prior pathlib spec checks the __class__.__name__ of any Path attribute descriptor; novel); pathlib.Path.suffix.__class__.__name__.__eq__('property') (NOVEL); pathlib.Path.parent.__class__.__name__.__eq__('property') (NOVEL); pathlib.Path.stem.__class__.__name__.__eq__('property') (NOVEL); pathlib.Path.parts.__class__.__name__.__eq__('property') (NOVEL); pathlib.Path.drive.__class__.__name__.__eq__('property') (NOVEL); pathlib.Path.root.__class__.__name__.__eq__('property') (NOVEL); pathlib.Path.anchor.__class__.__name__.__eq__('property') (NOVEL); pathlib.Path.suffixes.__class__.__name__.__eq__('property') (NOVEL); pathlib.Path.parents.__class__.__name__.__eq__('property') (NOVEL)."
    - "pathlib.Path.__module__ == 'pathlib'. Path is defined in the pathlib module; its __module__ attribute is 'pathlib'. No prior pathlib spec checks Path.__module__.__eq__ as a standalone invariant. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__module__ == 'pathlib'. PurePath is the base abstract class defined in pathlib. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePosixPath.__module__ == 'pathlib'. Defined in pathlib. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__module__ == 'pathlib'. Defined in pathlib. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.__module__.__len__() == 7. 'pathlib' has 7 characters. No prior pathlib spec checks Path.__module__.__len__(). Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__module__.__len__() == 7. 'pathlib' has 7 characters. No prior pathlib spec checks PurePath.__module__.__len__(). Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.name.__class__.__name__ == 'property'. Path.name is a property descriptor on the Path class that returns the final component of the path. Its __class__.__name__ is 'property'. No prior pathlib spec checks the __class__.__name__ of any Path attribute descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.suffix.__class__.__name__ == 'property'. Path.suffix returns the file suffix (extension). It is a property descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.parent.__class__.__name__ == 'property'. Path.parent returns the logical parent of the path. It is a property descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.stem.__class__.__name__ == 'property'. Path.stem is the final path component without its suffix. It is a property descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.parts.__class__.__name__ == 'property'. Path.parts is a tuple of the path's components. It is a property descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.drive.__class__.__name__ == 'property'. Path.drive is the drive letter or name (empty on POSIX). It is a property descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.root.__class__.__name__ == 'property'. Path.root is the root component of the path. It is a property descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.anchor.__class__.__name__ == 'property'. Path.anchor is the concatenation of drive and root. It is a property descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.suffixes.__class__.__name__ == 'property'. Path.suffixes is a list of all path suffixes. It is a property descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.parents.__class__.__name__ == 'property'. Path.parents provides access to the logical ancestors of the path. It is a property descriptor. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __module__ equality (novel standalone invariants)
#
# All pathlib classes — Path, PurePath, PurePosixPath, PureWindowsPath —
# are defined in the pathlib module. Their __module__ attribute is 'pathlib'.
# No prior pathlib spec checks __module__.__eq__('pathlib') for any of these
# classes as standalone equality invariants.
#
#   Path.__module__             == 'pathlib'
#   PurePath.__module__         == 'pathlib'
#   PurePosixPath.__module__    == 'pathlib'
#   PureWindowsPath.__module__  == 'pathlib'
#
# All four equality anchors are novel in the pathlibmod58 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra58.class_module_eq:
  description: "pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath — all are defined in the pathlib module; no prior pathlib spec checks __module__.__eq__ for any of these classes as standalone invariants; all four novel equality anchors in pathlibmod58 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibmod58eq

  columns: [id, function, args, expected]
  rows:
    - [Path_module_eq,            Path.__module__.__eq__,            ["pathlib"], true]
    - [PurePath_module_eq,        PurePath.__module__.__eq__,        ["pathlib"], true]
    - [PurePosixPath_module_eq,   PurePosixPath.__module__.__eq__,   ["pathlib"], true]
    - [PureWindowsPath_module_eq, PureWindowsPath.__module__.__eq__, ["pathlib"], true]

# ---------------------------------------------------------------------------
# pathlib class __module__ lengths (novel length anchors)
#
# 'pathlib' has 7 characters. No prior pathlib spec checks __module__.__len__()
# for Path or PurePath as standalone invariants.
#
#   Path.__module__.__len__()     == 7
#   PurePath.__module__.__len__() == 7
#
# Both length anchors are novel in the pathlibmod58 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra58.class_module_len:
  description: "pathlib class __module__.__len__() for Path(7)/PurePath(7) — 'pathlib' has 7 characters; no prior pathlib spec checks __module__.__len__() for Path or PurePath; both novel length anchors in pathlibmod58 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: string_length
  id_prefix: pathlibmod58len

  columns: [id, function, args, expected]
  rows:
    - [Path_module_len,     Path.__module__.__len__,     [], 7]
    - [PurePath_module_len, PurePath.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# pathlib.Path property descriptors (__class__.__name__ == 'property')
#
# The Path class exposes many computed attributes as Python property descriptors.
# Accessing Path.name (the class attribute, not an instance attribute) returns
# the underlying property object; its __class__.__name__ is 'property'.
#
# No prior pathlib spec checks the __class__.__name__ of any Path attribute
# descriptor. The following ten attributes are all property descriptors:
#
#   Path.name.__class__.__name__     == 'property'
#   Path.suffix.__class__.__name__   == 'property'
#   Path.parent.__class__.__name__   == 'property'
#   Path.stem.__class__.__name__     == 'property'
#   Path.parts.__class__.__name__    == 'property'
#   Path.drive.__class__.__name__    == 'property'
#   Path.root.__class__.__name__     == 'property'
#   Path.anchor.__class__.__name__   == 'property'
#   Path.suffixes.__class__.__name__ == 'property'
#   Path.parents.__class__.__name__  == 'property'
#
# All ten equality anchors are novel in the pathlibmod58 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra58.path_property_descriptors:
  description: "pathlib.Path attribute descriptors __class__.__name__.__eq__('property') for name/suffix/parent/stem/parts/drive/root/anchor/suffixes/parents — all are Python property descriptors; no prior pathlib spec checks __class__.__name__ of any Path attribute descriptor; all ten novel equality anchors in pathlibmod58 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibmod58prop

  columns: [id, function, args, expected]
  rows:
    - [Path_name_class_name,     "Path.name.__class__.__name__.__eq__",     ["property"], true]
    - [Path_suffix_class_name,   "Path.suffix.__class__.__name__.__eq__",   ["property"], true]
    - [Path_parent_class_name,   "Path.parent.__class__.__name__.__eq__",   ["property"], true]
    - [Path_stem_class_name,     "Path.stem.__class__.__name__.__eq__",     ["property"], true]
    - [Path_parts_class_name,    "Path.parts.__class__.__name__.__eq__",    ["property"], true]
    - [Path_drive_class_name,    "Path.drive.__class__.__name__.__eq__",    ["property"], true]
    - [Path_root_class_name,     "Path.root.__class__.__name__.__eq__",     ["property"], true]
    - [Path_anchor_class_name,   "Path.anchor.__class__.__name__.__eq__",   ["property"], true]
    - [Path_suffixes_class_name, "Path.suffixes.__class__.__name__.__eq__", ["property"], true]
    - [Path_parents_class_name,  "Path.parents.__class__.__name__.__eq__",  ["property"], true]
