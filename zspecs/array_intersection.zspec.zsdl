spec: array_intersection
version: ">=0.1.2"
backend: node(array-intersection)

docs: https://www.npmjs.com/package/array-intersection

provenance:
  derived_from:
    - "array-intersection README — https://www.npmjs.com/package/array-intersection"
    - "Test vectors verified with array-intersection via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-intersection source"
  notes:
    - "array-intersection is an npm package. Install: npm install array-intersection"
    - "Returns elements present in both arrays."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array of elements present in both input arrays."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_intersection.intersect:
  kind: node_module_call_eq
  function: ~
  category: set
  id_prefix: arrisect

  columns: [id, args, expected]
  rows:
    - [overlap,  [[1, 2, 3], [2, 3, 4]], [2, 3]]
    - [disjoint, [[1, 2], [3, 4]],       []]
