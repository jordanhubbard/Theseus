spec: theseus_aifc_cr
version: ">=3.0"
backend: python_cleanroom(theseus_aifc_cr)
blocks: aifc

docs: https://docs.python.org/3/library/aifc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/aifc.html"
  not_derived_from:
    - "CPython source: Lib/aifc.py"
  notes:
    - "Clean-room aifc module. Do NOT import aifc."

error_model: python_exceptions

invariant theseus_aifc_cr.aifc2_error:
  description: "Error class exists"
  category: behavior
  kind: python_call_eq
  function: aifc2_error
  args: []
  expected: true

invariant theseus_aifc_cr.aifc2_open:
  description: "open() function exists"
  category: behavior
  kind: python_call_eq
  function: aifc2_open
  args: []
  expected: true

invariant theseus_aifc_cr.aifc2_constants:
  description: "AIFC compression type constants exist"
  category: behavior
  kind: python_call_eq
  function: aifc2_constants
  args: []
  expected: true
