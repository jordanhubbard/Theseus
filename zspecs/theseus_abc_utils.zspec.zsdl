spec: theseus_abc_utils
version: ">=3.9"
backend: python_cleanroom(theseus_abc_utils)
blocks: abc

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
  notes:
    - "Clean-room abstract base class support. Do NOT import abc."
    - "ABCMeta metaclass: prevents instantiation of classes with unimplemented abstract methods."
    - "abstractmethod decorator: marks a method as abstract."
    - "ABC base class: convenience class with ABCMeta as metaclass."
    - "abc_cannot_instantiate(): instantiating abstract class raises TypeError."
    - "abc_concrete_ok(): concrete subclass implementing all abstract methods can be instantiated."
    - "abc_abstractmethod_name(): abstract method name is accessible via __isabstractmethod__."
    - "Export: ABCMeta, abstractmethod, ABC."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_abc_utils.cannot_instantiate:
  description: "instantiating abstract class raises TypeError"
  category: abstract
  kind: python_call_eq
  function: abc_cannot_instantiate
  args: []
  expected: true

invariant theseus_abc_utils.concrete_ok:
  description: "concrete subclass can be instantiated"
  category: concrete
  kind: python_call_eq
  function: abc_concrete_ok
  args: []
  expected: true

invariant theseus_abc_utils.is_abstract:
  description: "abstractmethod sets __isabstractmethod__ = True"
  category: decorator
  kind: python_call_eq
  function: abc_is_abstract
  args: []
  expected: true
