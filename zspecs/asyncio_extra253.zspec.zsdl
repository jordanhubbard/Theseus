spec: asyncio_extra253
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py (AbstractEventLoop and policy definitions)"
    - "CPython source: Lib/asyncio/base_events.py (BaseEventLoop implementation)"
    - "CPython source: Lib/asyncio/unix_events.py (_UnixSelectorEventLoop and _UnixDefaultEventLoopPolicy)"
  notes:
    - "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop' (len=17); __module__ == 'asyncio.events' (len=14); __bases__[0].__name__ == 'object' (len=6) — AbstractEventLoop inherits directly from object."
    - "asyncio.BaseEventLoop.__name__ == 'BaseEventLoop' (len=13); __module__ == 'asyncio.base_events' (len=19); __bases__[0].__name__ == 'AbstractEventLoop' (len=17) — concrete base implementing the abstract interface."
    - "asyncio.SelectorEventLoop.__name__ == '_UnixSelectorEventLoop' (len=22) on macOS/Darwin — platform-specific alias; __module__ == 'asyncio.unix_events' (len=19); __bases__[0].__name__ == 'BaseSelectorEventLoop' (len=21)."
    - "asyncio.DefaultEventLoopPolicy.__name__ == '_UnixDefaultEventLoopPolicy' (len=27) on macOS/Darwin — platform-specific alias; __module__ == 'asyncio.unix_events' (len=19); __bases__[0].__name__ == '_BaseDefaultEventLoopPolicy' (len=27)."
    - "DefaultEventLoopPolicy is deprecated and slated for removal in Python 3.16; tested against Python 3.14.3 where it still exists."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.AbstractEventLoop and asyncio.BaseEventLoop class identity
#
# AbstractEventLoop.__name__ == 'AbstractEventLoop' (len=17)
# AbstractEventLoop.__module__ == 'asyncio.events' (len=14)
# AbstractEventLoop.__bases__[0].__name__ == 'object' (len=6)
# BaseEventLoop.__name__ == 'BaseEventLoop' (len=13)
# BaseEventLoop.__module__ == 'asyncio.base_events' (len=19)
# BaseEventLoop.__bases__[0].__name__ == 'AbstractEventLoop' (len=17)
# ---------------------------------------------------------------------------

table asyncio_extra253.abstract_base_eventloop_class_identity:
  description: "asyncio AbstractEventLoop and BaseEventLoop class identity — AbstractEventLoop(len=17) inherits from object(len=6) directly, defining the abstract interface; BaseEventLoop(len=13) inherits from AbstractEventLoop(len=17), providing the concrete implementation; BaseEventLoop.__module__=='asyncio.base_events'(len=19) is longer than AbstractEventLoop.__module__=='asyncio.events'(len=14); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async253ael

  columns: [id, function, args, expected, description]
  rows:
    - [ael_name_eq,      AbstractEventLoop.__name__.__eq__,                       ["AbstractEventLoop"],   true, "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop'; verified with Python 3.14.3"]
    - [ael_name_len,     AbstractEventLoop.__name__.__len__,                      [],                      17,   "asyncio.AbstractEventLoop.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [ael_mod_eq,       AbstractEventLoop.__module__.__eq__,                     ["asyncio.events"],      true, "asyncio.AbstractEventLoop.__module__ == 'asyncio.events'; verified with Python 3.14.3"]
    - [ael_mod_len,      AbstractEventLoop.__module__.__len__,                    [],                      14,   "asyncio.AbstractEventLoop.__module__.__len__() == 14; verified with Python 3.14.3"]
    - [ael_base_eq,      "AbstractEventLoop.__bases__[0].__name__.__eq__",        ["object"],              true, "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object' — AbstractEventLoop inherits directly from object; verified with Python 3.14.3"]
    - [ael_base_len,     "AbstractEventLoop.__bases__[0].__name__.__len__",       [],                      6,    "asyncio.AbstractEventLoop.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]
    - [bel_name_eq,      BaseEventLoop.__name__.__eq__,                           ["BaseEventLoop"],       true, "asyncio.BaseEventLoop.__name__ == 'BaseEventLoop'; verified with Python 3.14.3"]
    - [bel_name_len,     BaseEventLoop.__name__.__len__,                          [],                      13,   "asyncio.BaseEventLoop.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [bel_mod_eq,       BaseEventLoop.__module__.__eq__,                         ["asyncio.base_events"], true, "asyncio.BaseEventLoop.__module__ == 'asyncio.base_events'; verified with Python 3.14.3"]
    - [bel_mod_len,      BaseEventLoop.__module__.__len__,                        [],                      19,   "asyncio.BaseEventLoop.__module__.__len__() == 19; verified with Python 3.14.3"]
    - [bel_base_eq,      "BaseEventLoop.__bases__[0].__name__.__eq__",            ["AbstractEventLoop"],   true, "asyncio.BaseEventLoop.__bases__[0].__name__ == 'AbstractEventLoop' — BaseEventLoop inherits from AbstractEventLoop; verified with Python 3.14.3"]
    - [bel_base_len,     "BaseEventLoop.__bases__[0].__name__.__len__",           [],                      17,   "asyncio.BaseEventLoop.__bases__[0].__name__.__len__() == 17; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.SelectorEventLoop and asyncio.DefaultEventLoopPolicy class identity
#
# On macOS/Darwin, SelectorEventLoop is an alias for _UnixSelectorEventLoop:
#   __name__ == '_UnixSelectorEventLoop' (len=22)
#   __module__ == 'asyncio.unix_events' (len=19)
#   __bases__[0].__name__ == 'BaseSelectorEventLoop' (len=21)
#
# DefaultEventLoopPolicy is an alias for _UnixDefaultEventLoopPolicy:
#   __name__ == '_UnixDefaultEventLoopPolicy' (len=27)
#   __module__ == 'asyncio.unix_events' (len=19)
#   __bases__[0].__name__ == '_BaseDefaultEventLoopPolicy' (len=27)
# ---------------------------------------------------------------------------

table asyncio_extra253.selector_defaultpolicy_class_identity:
  description: "asyncio SelectorEventLoop and DefaultEventLoopPolicy class identity on macOS/Darwin — SelectorEventLoop resolves to '_UnixSelectorEventLoop'(len=22) with __module__=='asyncio.unix_events'(len=19) and base 'BaseSelectorEventLoop'(len=21); DefaultEventLoopPolicy resolves to '_UnixDefaultEventLoopPolicy'(len=27) with same module and base '_BaseDefaultEventLoopPolicy'(len=27); DefaultEventLoopPolicy deprecated in 3.14, slated for removal in 3.16; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async253sel

  columns: [id, function, args, expected, description]
  rows:
    - [sel_name_eq,      SelectorEventLoop.__name__.__eq__,                       ["_UnixSelectorEventLoop"],       true, "asyncio.SelectorEventLoop.__name__ == '_UnixSelectorEventLoop' (macOS alias); verified with Python 3.14.3"]
    - [sel_name_len,     SelectorEventLoop.__name__.__len__,                      [],                               22,   "asyncio.SelectorEventLoop.__name__.__len__() == 22; verified with Python 3.14.3"]
    - [sel_mod_eq,       SelectorEventLoop.__module__.__eq__,                     ["asyncio.unix_events"],          true, "asyncio.SelectorEventLoop.__module__ == 'asyncio.unix_events'; verified with Python 3.14.3"]
    - [sel_mod_len,      SelectorEventLoop.__module__.__len__,                    [],                               19,   "asyncio.SelectorEventLoop.__module__.__len__() == 19; verified with Python 3.14.3"]
    - [sel_base_eq,      "SelectorEventLoop.__bases__[0].__name__.__eq__",        ["BaseSelectorEventLoop"],        true, "asyncio.SelectorEventLoop.__bases__[0].__name__ == 'BaseSelectorEventLoop'; verified with Python 3.14.3"]
    - [sel_base_len,     "SelectorEventLoop.__bases__[0].__name__.__len__",       [],                               21,   "asyncio.SelectorEventLoop.__bases__[0].__name__.__len__() == 21; verified with Python 3.14.3"]
    - [dep_name_eq,      DefaultEventLoopPolicy.__name__.__eq__,                  ["_UnixDefaultEventLoopPolicy"], true, "asyncio.DefaultEventLoopPolicy.__name__ == '_UnixDefaultEventLoopPolicy' (macOS alias); verified with Python 3.14.3"]
    - [dep_name_len,     DefaultEventLoopPolicy.__name__.__len__,                 [],                               27,   "asyncio.DefaultEventLoopPolicy.__name__.__len__() == 27; verified with Python 3.14.3"]
    - [dep_mod_eq,       DefaultEventLoopPolicy.__module__.__eq__,                ["asyncio.unix_events"],          true, "asyncio.DefaultEventLoopPolicy.__module__ == 'asyncio.unix_events'; verified with Python 3.14.3"]
    - [dep_mod_len,      DefaultEventLoopPolicy.__module__.__len__,               [],                               19,   "asyncio.DefaultEventLoopPolicy.__module__.__len__() == 19; verified with Python 3.14.3"]
    - [dep_base_eq,      "DefaultEventLoopPolicy.__bases__[0].__name__.__eq__",   ["_BaseDefaultEventLoopPolicy"], true, "asyncio.DefaultEventLoopPolicy.__bases__[0].__name__ == '_BaseDefaultEventLoopPolicy'; verified with Python 3.14.3"]
    - [dep_base_len,     "DefaultEventLoopPolicy.__bases__[0].__name__.__len__",  [],                               27,   "asyncio.DefaultEventLoopPolicy.__bases__[0].__name__.__len__() == 27; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra253
# ---------------------------------------------------------------------------

invariant asyncio_extra253.base_eventloop_inherits_abstract:
  description: "asyncio.BaseEventLoop.__bases__[0].__name__.__eq__('AbstractEventLoop') returns True — BaseEventLoop inherits from AbstractEventLoop (not directly from object); this contrasts with AbstractEventLoop.__bases__[0].__name__=='object'(len=6); BaseEventLoop.__name__=='BaseEventLoop'(len=13); __module__=='asyncio.base_events'(len=19); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BaseEventLoop.__bases__[0].__name__.__eq__"
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra253.abstract_eventloop_module:
  description: "asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events') returns True — AbstractEventLoop is defined in asyncio.events(len=14), not in asyncio.base_events(len=19) where BaseEventLoop lives; this module split reflects the separation of interface from implementation; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true
