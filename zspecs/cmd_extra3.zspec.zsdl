spec: cmd_extra3
version: ">=3.9"
backend: python_module(cmd)

docs: https://docs.python.org/3/library/cmd.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmd.html — Python cmd documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cmd.py"
  notes:
    - "This spec extends cmd.zspec.zsdl and prior extras."
    - "cmd covers: Cmd.__name__, Cmd.__module__, Cmd() instance attrs (prompt/intro/use_rawinput/cmdqueue/ruler/doc_header/misc_header/undoc_header), IDENTCHARS contains 'a'/'A'/'0'/'_'."
    - "cmd_extra covers: Cmd.__name__, Cmd.__module__, Cmd method names (cmdloop/onecmd/default/do_help/emptyline/precmd/postcmd/parseline), IDENTCHARS type/nonempty/'_'/'a'."
    - "cmd_extra2 covers: Cmd.__bases__[0].__name__=='object', Cmd.__qualname__, Cmd.PROMPT type+value, Cmd.identchars type, Cmd.ruler type+value, Cmd.lastcmd type, Cmd.doc_header type."
    - "This spec adds: Cmd.__name__.__class__.__name__=='str', Cmd.__module__.__class__.__name__=='str', Cmd.__qualname__.__class__.__name__=='str', Cmd method __qualname__ checks (cmdloop/onecmd/default), Cmd.__bases__.__len__()==1, Cmd.misc_header type, Cmd.undoc_header type."
    - "cmd.Cmd.__bases__.__len__() == 1 — Cmd inherits from a single base class (object)."
    - "cmd.Cmd.__name__.__class__.__name__ == 'str' — the __name__ attribute is a plain string."
    - "cmd.Cmd.cmdloop.__qualname__ == 'Cmd.cmdloop' — method qualname includes the enclosing class scope."
    - "cmd.Cmd.onecmd.__qualname__ == 'Cmd.onecmd' — method qualname includes the enclosing class scope."
    - "cmd.Cmd.default.__qualname__ == 'Cmd.default' — method qualname includes the enclosing class scope."
    - "cmd.Cmd.misc_header.__class__.__name__ == 'str' — misc_header class attribute is a string."
    - "cmd.Cmd.undoc_header.__class__.__name__ == 'str' — undoc_header class attribute is a string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Cmd.__bases__ length — Cmd has exactly one base class (object)
# cmd_extra2 covers __bases__[0].__name__=='object'; length is new here.
# ---------------------------------------------------------------------------

invariant cmd_extra3.Cmd.bases_len:
  description: "len(cmd.Cmd.__bases__) == 1 — Cmd inherits from a single base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Cmd.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# __name__ / __module__ / __qualname__ type checks
# cmd_extra2 covers the values; these check the types (all strings).
# ---------------------------------------------------------------------------

invariant cmd_extra3.Cmd.name_is_str:
  description: "cmd.Cmd.__name__.__class__.__name__ == 'str' — __name__ attribute is a string"
  category: class_types
  kind: python_call_eq
  function: Cmd.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant cmd_extra3.Cmd.module_is_str:
  description: "cmd.Cmd.__module__.__class__.__name__ == 'str' — __module__ attribute is a string"
  category: class_types
  kind: python_call_eq
  function: Cmd.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant cmd_extra3.Cmd.qualname_is_str:
  description: "cmd.Cmd.__qualname__.__class__.__name__ == 'str' — __qualname__ attribute is a string"
  category: class_types
  kind: python_call_eq
  function: Cmd.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Cmd method __qualname__ checks
# cmd_extra and cmd_extra2 cover method __name__; __qualname__ is new here.
# Method qualnames include the enclosing class: 'Cmd.<method>'.
# ---------------------------------------------------------------------------

invariant cmd_extra3.Cmd.cmdloop_qualname:
  description: "cmd.Cmd.cmdloop.__qualname__ == 'Cmd.cmdloop'"
  category: method_qualnames
  kind: python_call_eq
  function: Cmd.cmdloop.__qualname__.__eq__
  args: ["Cmd.cmdloop"]
  expected: true

invariant cmd_extra3.Cmd.onecmd_qualname:
  description: "cmd.Cmd.onecmd.__qualname__ == 'Cmd.onecmd'"
  category: method_qualnames
  kind: python_call_eq
  function: Cmd.onecmd.__qualname__.__eq__
  args: ["Cmd.onecmd"]
  expected: true

invariant cmd_extra3.Cmd.default_qualname:
  description: "cmd.Cmd.default.__qualname__ == 'Cmd.default'"
  category: method_qualnames
  kind: python_call_eq
  function: Cmd.default.__qualname__.__eq__
  args: ["Cmd.default"]
  expected: true

# ---------------------------------------------------------------------------
# Cmd class-level attribute types — misc_header and undoc_header
# cmd_extra2 covers doc_header type; misc_header and undoc_header are new.
# ---------------------------------------------------------------------------

invariant cmd_extra3.Cmd.misc_header_is_str:
  description: "cmd.Cmd.misc_header.__class__.__name__ == 'str' — misc_header class attribute is a string"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.misc_header.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant cmd_extra3.Cmd.undoc_header_is_str:
  description: "cmd.Cmd.undoc_header.__class__.__name__ == 'str' — undoc_header class attribute is a string"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.undoc_header.__class__.__name__.__eq__
  args: ["str"]
  expected: true
