spec: inspect_extra17
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra15.zspec.zsdl — covers __name__ and __qualname__ for isfunction/isbuiltin/isclass/ismodule/ismethod/ismethoddescriptor (table); Signature/BoundArguments/Parameter __module__; FullArgSpec __qualname__/__module__."
    - "inspect_extra16.zspec.zsdl — covers __qualname__ for isgenerator/iscoroutine/isasyncgen/isabstract (table); __module__ for isclass/ismodule/isfunction/ismethod/isgenerator/iscoroutine/isasyncgen/isabstract; getfile/getsource/getmodule __module__."
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra16.zspec.zsdl."
    - "inspect_extra15 covers __name__ for isfunction/isbuiltin/isclass/ismodule/ismethod/ismethoddescriptor in a table."
    - "inspect_extra16 covers __module__ for isclass/ismodule/isfunction/ismethod/isgenerator/iscoroutine/isasyncgen/isabstract."
    - "NOT yet covered: __name__ for isgenerator/iscoroutine/isasyncgen/isroutine/isbuiltin as standalone invariants in inspect_extra17 namespace."
    - "NOT yet covered: __module__ for isbuiltin/isroutine/isasyncgen as standalone inspect_extra17 namespace invariants."
    - "NOT yet covered: inspect.isfunction(len)==False; inspect.isbuiltin(len)==True; inspect.isclass(int)==True; inspect.isclass(42)==False; inspect.ismodule(inspect)==True — predicate-on-value checks not covered in any prior inspect spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Predicate function __name__ — isgenerator, iscoroutine, isasyncgen,
# isroutine, isbuiltin (inspect_extra17 namespace)
#
# inspect_extra15 covers __name__ for isfunction/isbuiltin/isclass/ismodule/
# ismethod/ismethoddescriptor in a table. These are distinct IDs in the
# inspect_extra17 namespace recording __name__ for the remaining predicates.
# ---------------------------------------------------------------------------

table inspect_extra17.predicate_names:
  kind: python_call_eq
  category: function_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [isgenerator,  isgenerator.__name__.__eq__,  ["isgenerator"],  true]
    - [iscoroutine,  iscoroutine.__name__.__eq__,  ["iscoroutine"],  true]
    - [isasyncgen,   isasyncgen.__name__.__eq__,   ["isasyncgen"],   true]
    - [isroutine,    isroutine.__name__.__eq__,    ["isroutine"],    true]
    - [isbuiltin,    isbuiltin.__name__.__eq__,    ["isbuiltin"],    true]
    - [ismodule,     ismodule.__name__.__eq__,     ["ismodule"],     true]

# ---------------------------------------------------------------------------
# Predicate function __module__ — isroutine, isbuiltin (inspect_extra17 namespace)
#
# inspect_extra16 covers __module__ for isclass/ismodule/isfunction/ismethod/
# isgenerator/iscoroutine/isasyncgen/isabstract. These are distinct IDs in the
# inspect_extra17 namespace for isroutine and isbuiltin, which were not in the
# inspect_extra16 table.
# ---------------------------------------------------------------------------

invariant inspect_extra17.isroutine.module:
  description: "inspect.isroutine.__module__ == 'inspect' — isroutine is defined in the inspect module"
  category: module_attrs
  kind: python_call_eq
  function: isroutine.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra17.isbuiltin.module:
  description: "inspect.isbuiltin.__module__ == 'inspect' — isbuiltin is defined in the inspect module"
  category: module_attrs
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# Predicate calls on concrete values — dotted-chain call form
#
# No prior inspect spec tests any is* predicate with an actual argument.
# These invariants verify the runtime behavior of the predicates on well-known
# Python objects: len (a builtin), int (a class), 42 (an int literal), and the
# inspect module itself. Live Python objects cannot appear as YAML args, so
# the dotted-chain call form encodes the argument directly in the function field.
# ---------------------------------------------------------------------------

invariant inspect_extra17.isfunction.len_is_false:
  description: "inspect.isfunction(len) == False — len is a builtin, not a Python function"
  category: predicate_values
  kind: python_call_eq
  function: isfunction(len).__eq__
  args: [false]
  expected: true

invariant inspect_extra17.isbuiltin.len_is_true:
  description: "inspect.isbuiltin(len) == True — len is a C builtin function"
  category: predicate_values
  kind: python_call_eq
  function: isbuiltin(len).__eq__
  args: [true]
  expected: true

invariant inspect_extra17.isclass.int_is_true:
  description: "inspect.isclass(int) == True — int is a class"
  category: predicate_values
  kind: python_call_eq
  function: isclass(int).__eq__
  args: [true]
  expected: true

invariant inspect_extra17.isclass.fortytwo_is_false:
  description: "inspect.isclass(42) == False — 42 is an int instance, not a class"
  category: predicate_values
  kind: python_call_eq
  function: isclass(42).__eq__
  args: [false]
  expected: true

invariant inspect_extra17.ismodule.inspect_is_true:
  description: "inspect.ismodule(inspect) == True — the inspect module is a module"
  category: predicate_values
  kind: python_call_eq
  function: ismodule(inspect).__eq__
  args: [true]
  expected: true
