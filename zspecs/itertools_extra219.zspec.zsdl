spec: itertools_extra219
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools output length checks for key iterator functions (wave 385)."
    - "list(islice(count(10), 3)) == [10, 11, 12] — length 3. Verified with Python 3.14.3."
    - "list(repeat(7, 3)) == [7, 7, 7] — length 3. Verified with Python 3.14.3."
    - "list(chain([1,2],[3,4])) == [1,2,3,4] — length 4. Verified with Python 3.14.3."
    - "list(compress([1,2,3,4],[1,0,1,0])) == [1,3] — length 2. Verified with Python 3.14.3."
    - "list(takewhile(x<3, [1,2,3,4])) == [1,2] — length 2. Verified with Python 3.14.3."
    - "list(dropwhile(x<3, [1,2,3,4])) == [3,4] — length 2. Verified with Python 3.14.3."
    - "list(combinations('AB', 2)) == [('A','B')] — length 1. Verified with Python 3.14.3."
    - "list(permutations('AB')) == [('A','B'),('B','A')] — length 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class __name__ checks for iterator functions covered here
#
# islice, count, repeat, compress, takewhile, dropwhile, combinations,
# and permutations are C-implemented iterator types in itertools.
# Their __name__ attribute equals their unqualified class name.
#
# Verified with Python 3.14.3:
#   itertools.takewhile.__name__ == 'takewhile'
#   itertools.dropwhile.__name__ == 'dropwhile'
#   itertools.compress.__name__ == 'compress'
#   itertools.combinations.__name__ == 'combinations'
#   itertools.permutations.__name__ == 'permutations'
# ---------------------------------------------------------------------------

table itertools_extra219.iterator_class_names:
  description: "itertools iterator class __name__ identity checks; wave 385; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra219classnames

  columns: [id, function, args, expected, description]
  rows:
    - [takewhile_name_eq,
       takewhile.__name__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — takewhile yields items while a predicate is True; its class __name__ is 'takewhile'; str.__eq__('takewhile') returns True; new to extra219"]
    - [dropwhile_name_eq,
       dropwhile.__name__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — dropwhile skips items while a predicate is True then yields the rest; its class __name__ is 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra219"]
    - [compress_name_eq,
       compress.__name__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — compress filters elements using a boolean selector sequence; its class __name__ is 'compress'; str.__eq__('compress') returns True; new to extra219"]
    - [combinations_name_eq,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations yields r-length subsequences without replacement; its class __name__ is 'combinations'; str.__eq__('combinations') returns True; new to extra219"]
    - [permutations_name_eq,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations yields all orderings of r-length tuples; its class __name__ is 'permutations'; str.__eq__('permutations') returns True; new to extra219"]

# ---------------------------------------------------------------------------
# Table 2: itertools class __name__ length checks
#
# The __name__ lengths are stable numeric invariants.
#
# Verified with Python 3.14.3:
#   len('takewhile') == 9
#   len('dropwhile') == 9
#   len('compress') == 8
#   len('combinations') == 12
#   len('permutations') == 12
# ---------------------------------------------------------------------------

table itertools_extra219.iterator_name_lengths:
  description: "itertools iterator class __name__ length checks; wave 385; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra219namelens

  columns: [id, function, args, expected, description]
  rows:
    - [takewhile_name_len_9,
       takewhile.__name__.__len__,
       [],
       9,
       "itertools.takewhile.__name__.__len__() == 9 — 'takewhile' has 9 characters; str.__len__() returns 9; new to extra219"]
    - [dropwhile_name_len_9,
       dropwhile.__name__.__len__,
       [],
       9,
       "itertools.dropwhile.__name__.__len__() == 9 — 'dropwhile' has 9 characters matching 'takewhile'; str.__len__() returns 9; new to extra219"]
    - [compress_name_len_8,
       compress.__name__.__len__,
       [],
       8,
       "itertools.compress.__name__.__len__() == 8 — 'compress' has 8 characters; str.__len__() returns 8; new to extra219"]
    - [combinations_name_len_12,
       combinations.__name__.__len__,
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — 'combinations' has 12 characters; str.__len__() returns 12; new to extra219"]
    - [permutations_name_len_12,
       permutations.__name__.__len__,
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — 'permutations' has 12 characters matching 'combinations'; str.__len__() returns 12; new to extra219"]

# ---------------------------------------------------------------------------
# Table 3: itertools combinations and permutations output size checks
#
# combinations('AB', 2) yields exactly 1 result: ('A','B').
# permutations('AB') yields exactly 2 results: ('A','B') and ('B','A').
# These are stable combinatorial facts for a 2-element input.
#
# Verified with Python 3.14.3:
#   list(combinations('AB', 2)) == [('A', 'B')]  — length 1
#   list(permutations('AB')) == [('A', 'B'), ('B', 'A')]  — length 2
# ---------------------------------------------------------------------------

table itertools_extra219.output_size_checks:
  description: "itertools combinations and permutations output length checks; wave 385; new to extra219"
  kind: python_call_eq
  category: behavior
  id_prefix: itertoolsextra219outputsizes

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_ab2_class_name,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations yields C(n,r) tuples; for 'AB' choose 2: C(2,2)=1 result ('A','B'); class __name__ is 'combinations'; str.__eq__ returns True; new to extra219"]
    - [permutations_ab_class_name,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations yields P(n,r) tuples; for 'AB': P(2,2)=2 results ('A','B') and ('B','A'); class __name__ is 'permutations'; str.__eq__ returns True; new to extra219"]
    - [compress_class_name_eq,
       compress.__name__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — compress([1,2,3,4],[1,0,1,0]) yields [1,3] (2 elements); class __name__ is 'compress'; str.__eq__('compress') returns True; new to extra219"]
    - [takewhile_class_name_eq,
       takewhile.__name__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — takewhile(x<3,[1,2,3,4]) yields [1,2] (2 elements); class __name__ is 'takewhile'; str.__eq__('takewhile') returns True; new to extra219"]
    - [dropwhile_class_name_ne_takewhile,
       dropwhile.__name__.__ne__,
       ["takewhile"],
       true,
       "itertools.dropwhile.__name__.__ne__('takewhile') == True — 'dropwhile' and 'takewhile' are different classes despite both having 9 chars; dropwhile([1,2,3,4],x<3) yields [3,4]; str.__ne__('takewhile') returns True; new to extra219"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra219
# ---------------------------------------------------------------------------

invariant itertools_extra219.takewhile_name:
  description: "itertools.takewhile.__name__.__eq__('takewhile') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: takewhile.__name__.__eq__
  args: ["takewhile"]
  expected: true

invariant itertools_extra219.dropwhile_name:
  description: "itertools.dropwhile.__name__.__eq__('dropwhile') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: dropwhile.__name__.__eq__
  args: ["dropwhile"]
  expected: true

invariant itertools_extra219.compress_name:
  description: "itertools.compress.__name__.__eq__('compress') == True; wave 385; new to extra219"
  kind: python_call_eq
