  args: ["compress"]
  expected: true

invariant itertools_extra219.combinations_name:
  description: "itertools.combinations.__name__.__eq__('combinations') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: combinations.__name__.__eq__
  args: ["combinations"]
  expected: true

invariant itertools_extra219.permutations_name:
  description: "itertools.permutations.__name__.__eq__('permutations') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: permutations.__name__.__eq__
  args: ["permutations"]
  expected: true

invariant itertools_extra219.takewhile_name_len:
  description: "itertools.takewhile.__name__.__len__() == 9 — 'takewhile' has 9 characters; wave 385; new to extra219"
  kind: python_call_eq
  function: takewhile.__name__.__len__
  args: []
  expected: 9

invariant itertools_extra219.dropwhile_name_len:
  description: "itertools.dropwhile.__name__.__len__() == 9 — 'dropwhile' has 9 characters; wave 385; new to extra219"
  kind: python_call_eq
  function: dropwhile.__name__.__len__
  args: []
