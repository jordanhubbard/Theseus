invariant itertools_extra219.combinations_name_len:
  description: "itertools.combinations.__name__.__len__() == 12 — 'combinations' has 12 characters; wave 385; new to extra219"
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra219.permutations_name_len:
  description: "itertools.permutations.__name__.__len__() == 12 — 'permutations' has 12 characters; wave 385; new to extra219"
  kind: python_call_eq
  function: permutations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra219.compress_name_len:
  description: "itertools.compress.__name__.__len__() == 8 — 'compress' has 8 characters; wave 385; new to extra219"
  kind: python_call_eq
  function: compress.__name__.__len__
  args: []
  expected: 8
