spec: inspect_extra1786
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers isfunction, isbuiltin, isclass, ismodule, isroutine, etc."
    - "inspect_extra.zspec.zsdl — covers __name__/__module__ tables, isclass/isbuiltin/isfunction behavioral cases, Parameter and Signature __name__ cross-checks"
    - "inspect_signature.zspec.zsdl — covers BoundArguments, Signature, Parameter module/kind checks"
  notes:
    - "Wave 566 theme: __class_getitem__ and __init_subclass__ class creation hooks (PEP 487/585)."
    - "inspect.Parameter is a pure Python class defined in Lib/inspect.py. It is not a generic container type and does not define __class_getitem__ in its own __dict__."
    - "inspect.Signature is a pure Python class defined in Lib/inspect.py. It does not define __class_getitem__ in its own __dict__."
    - "inspect.BoundArguments is a pure Python class defined in Lib/inspect.py. It does not define __class_getitem__ in its own __dict__."
    - "None of the inspect classes (Parameter, Signature, BoundArguments, FrameInfo) define __init_subclass__ in their own __dict__; they inherit it from object."
    - "None of the inspect classes define __subclasshook__ in their own __dict__."
    - "Complementary table checks for dunder names that inspect classes do or do not own: __init__, __repr__, __eq__, __hash__ as appropriate."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ and __init_subclass__ absence in inspect classes
#
# The inspect module's public classes (Parameter, Signature, BoundArguments)
# are pure Python classes that model introspection results. None of them are
# parameterizable generic container types, so none define __class_getitem__
# in their own __dict__. None define __init_subclass__ in their own __dict__
# either — that dunder is inherited from object for all three.
# ---------------------------------------------------------------------------

table inspect_extra1786.class_creation_hooks:
  description: "inspect classes do not define __class_getitem__ or __init_subclass__ in their own __dict__ (PEP 487/585)"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: in1786

  columns: [id, function, args, expected]
  rows:
    - ["in1786001", inspect.Parameter.__dict__.__contains__,      ["__class_getitem__"],  false]
    - ["in1786002", inspect.Signature.__dict__.__contains__,      ["__class_getitem__"],  false]
    - ["in1786003", inspect.BoundArguments.__dict__.__contains__,  ["__class_getitem__"],  false]
    - ["in1786004", inspect.Parameter.__dict__.__contains__,      ["__init_subclass__"],  false]
    - ["in1786005", inspect.Signature.__dict__.__contains__,      ["__init_subclass__"],  false]
    - ["in1786006", inspect.BoundArguments.__dict__.__contains__,  ["__init_subclass__"],  false]
    - ["in1786007", inspect.Parameter.__dict__.__contains__,      ["__subclasshook__"],   false]
    - ["in1786008", inspect.Signature.__dict__.__contains__,      ["__subclasshook__"],   false]
    - ["in1786009", inspect.BoundArguments.__dict__.__contains__,  ["__subclasshook__"],   false]
    - ["in1786010", inspect.Parameter.__dict__.__contains__,      ["__init__"],           true]
    - ["in1786011", inspect.Signature.__dict__.__contains__,      ["__init__"],           true]
    - ["in1786012", inspect.BoundArguments.__dict__.__contains__,  ["__init__"],           true]

# ---------------------------------------------------------------------------
# Table 2: complementary __dict__ membership checks for inspect classes
#
# Verifies other dunder names in the own __dict__ of inspect classes.
# Parameter owns __init__, __repr__, __eq__, __hash__, replace.
# Signature owns __init__, __repr__, __eq__, __hash__, replace, bind, bind_partial.
# BoundArguments owns __init__, __repr__, __eq__.
# None own __new__ (inherited from object), __class_getitem__, __init_subclass__.
# ---------------------------------------------------------------------------

table inspect_extra1786.dict_membership_complement:
  description: "Complementary __dict__ membership checks for inspect.Parameter, Signature, BoundArguments"
  kind: python_call_eq
  category: dict_membership
  id_prefix: in1786

  columns: [id, function, args, expected]
  rows:
    - ["in1786013", inspect.Parameter.__dict__.__contains__,      ["__repr__"],    true]
    - ["in1786014", inspect.Parameter.__dict__.__contains__,      ["__eq__"],      true]
    - ["in1786015", inspect.Parameter.__dict__.__contains__,      ["__hash__"],    true]
    - ["in1786016", inspect.Parameter.__dict__.__contains__,      ["replace"],     true]
    - ["in1786017", inspect.Signature.__dict__.__contains__,      ["__repr__"],    true]
    - ["in1786018", inspect.Signature.__dict__.__contains__,      ["__eq__"],      true]
    - ["in1786019", inspect.Signature.__dict__.__contains__,      ["replace"],     true]
    - ["in1786020", inspect.Signature.__dict__.__contains__,      ["bind"],        true]
    - ["in1786021", inspect.BoundArguments.__dict__.__contains__,  ["__repr__"],    true]
    - ["in1786022", inspect.BoundArguments.__dict__.__contains__,  ["__eq__"],      true]
    - ["in1786023", inspect.Parameter.__dict__.__contains__,      ["__new__"],     false]
    - ["in1786024", inspect.Signature.__dict__.__contains__,      ["__new__"],     false]
    - ["in1786025", inspect.BoundArguments.__dict__.__contains__,  ["__new__"],     false]
