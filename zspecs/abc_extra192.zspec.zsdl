table abc_extra192.abc_abstractmethod_class_identity:
  description: "abc.abstractmethod.__class__ identity checks in abcattrs192 namespace — abstractmethod.__class__.__name__=='function' (len=8: f(1)u(2)n(3)c(4)t(5)i(6)o(7)n(8); abstractmethod is a plain function, not a class; type(abstractmethod).__name__=='function'); abstractmethod.__class__.__module__=='builtins' (len=8: same length as 'function'; the function type lives in the builtins module); abstractmethod.__class__.__name__ (8) == abstractmethod.__class__.__module__ (8) — coincidentally the same length; abstractmethod.__class__.__module__ (8) == ABCMeta.__class__.__module__ (8: 'builtins') — both function and type live in builtins; verified with Python 3.14.3"
  kind: python_call_eq
  category: abstractmethod_class
  id_prefix: abcattrs192

  columns: [id, function, args, expected, description]
  rows:
    - [am_class_eq,      abc.abstractmethod.__class__.__name__.__eq__,    ["function"],  true, "abc.abstractmethod.__class__.__name__ == 'function' (len=8; abstractmethod is a plain function, not a class); verified Python 3.14.3"]
    - [am_class_len,     abc.abstractmethod.__class__.__name__.__len__,   [],            8,    "abc.abstractmethod.__class__.__name__.__len__() == 8 ('function'=8: f(1)u(2)n(3)c(4)t(5)i(6)o(7)n(8)); verified Python 3.14.3"]
    - [am_class_mod_eq,  abc.abstractmethod.__class__.__module__.__eq__,  ["builtins"],  true, "abc.abstractmethod.__class__.__module__ == 'builtins' (len=8; the function type lives in the builtins module); verified Python 3.14.3"]
    - [am_class_mod_len, abc.abstractmethod.__class__.__module__.__len__, [],            8,    "abc.abstractmethod.__class__.__module__.__len__() == 8 ('builtins'=8); verified Python 3.14.3"]
    - [file_class_len2,  abc.__file__.__class__.__name__.__len__,         [],            3,    "abc.__file__.__class__.__name__.__len__() == 3 ('str'=3); confirmed from file_and_ABC_class table; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra192
# ---------------------------------------------------------------------------

invariant abc_extra192.abc_file_class_name_eq:
  description: "abc.__file__.__class__.__name__.__eq__('str') returns True — abc.__file__.__class__.__name__=='str' (len=3: s(1)t(2)r(3)); the __file__ attribute of any Python source module is always a str (the absolute path to the .py file); confirming its type via __class__.__name__ avoids a machine-specific path comparison; abc.__file__.__class__.__name__ (3: 'str') < abc.ABC.__class__.__name__ (7: 'ABCMeta') by 4 — the type name of __file__ is shorter than the metaclass name; abc.__file__.__class__.__name__ (3) == abc.ABC.__class__.__module__ (3: 'abc') — coincidentally the same length; NEW in abcattrs192: first standalone __file__.__class__.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: file_and_ABC_class
  kind: python_call_eq
  function: abc.__file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra192.abc_ABC_class_name_eq:
  description: "abc.ABC.__class__.__name__.__eq__('ABCMeta') returns True — abc.ABC.__class__.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); ABC is defined as 'class ABC(metaclass=ABCMeta): pass'; using metaclass=ABCMeta makes ABCMeta the type of ABC, so type(ABC).__name__ == 'ABCMeta'; this is the mechanism that gives ABC its abstract-method enforcement: any class inheriting from ABC will use ABCMeta as its metaclass; ABC.__class__.__name__ (7: 'ABCMeta') > ABC.__class__.__module__ (3: 'abc') by 4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: file_and_ABC_class
  kind: python_call_eq
  function: abc.ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra192.abc_ABC_class_module_eq:
  description: "abc.ABC.__class__.__module__.__eq__('abc') returns True — abc.ABC.__class__.__module__=='abc' (len=3: a(1)b(2)c(3)); ABCMeta is defined in the abc module (Lib/abc.py), so the module of ABC's type is 'abc'; abc.ABC.__class__.__module__ (3: 'abc') < abc.ABCMeta.__class__.__module__ (8: 'builtins') by 5 — ABCMeta's metaclass (type) lives in builtins, while ABCMeta itself lives in abc; abc.ABC.__class__.__module__ (3) == abc.__file__.__class__.__name__ (3: 'str') — coincidentally the same length; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: file_and_ABC_class
  kind: python_call_eq
  function: abc.ABC.__class__.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra192.abc_ABCMeta_class_name_eq:
  description: "abc.ABCMeta.__class__.__name__.__eq__('type') returns True — abc.ABCMeta.__class__.__name__=='type' (len=4: t(1)y(2)p(3)e(4)); ABCMeta is a metaclass — it is a class whose instances are themselves classes; since metaclasses are classes, their type is the built-in type; ABCMeta.__class__.__name__ (4: 'type') < ABCMeta.__class__.__module__ (8: 'builtins') by 4; ABCMeta.__class__.__name__ (4: 'type') < ABC.__class__.__name__ (7: 'ABCMeta') by 3 — the metaclass of a metaclass is shorter-named than the metaclass itself; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_class
  kind: python_call_eq
  function: abc.ABCMeta.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra192.abc_ABCMeta_class_module_eq:
  description: "abc.ABCMeta.__class__.__module__.__eq__('builtins') returns True — abc.ABCMeta.__class__.__module__=='builtins' (len=8: b(1)u(2)i(3)l(4)t(5)i(6)n(7)s(8)); the built-in type metaclass lives in the builtins module; ABCMeta.__class__.__module__ (8: 'builtins') == abstractmethod.__class__.__module__ (8: 'builtins') — both type and function live in builtins; ABCMeta.__class__.__module__ (8) > ABC.__class__.__module__ (3: 'abc') by 5; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_class
  kind: python_call_eq
  function: abc.ABCMeta.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra192.abc_abstractmethod_class_name_eq:
  description: "abc.abstractmethod.__class__.__name__.__eq__('function') returns True — abc.abstractmethod.__class__.__name__=='function' (len=8: f(1)u(2)n(3)c(4)t(5)i(6)o(7)n(8)); abstractmethod is implemented as a plain function in Lib/abc.py (it sets __isabstractmethod__ = True on its argument and returns it); type(abstractmethod).__name__ == 'function'; abstractmethod.__class__.__name__ (8) == abstractmethod.__class__.__module__ (8: 'builtins') — coincidentally the same character count; abstractmethod.__class__.__name__ (8) > ABC.__class__.__name__ (7: 'ABCMeta') by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abstractmethod_class
  kind: python_call_eq
  function: abc.abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra192.abc_abstractmethod_class_module_eq:
  description: "abc.abstractmethod.__class__.__module__.__eq__('builtins') returns True — abc.abstractmethod.__class__.__module__=='builtins' (len=8: b(1)u(2)i(3)l(4)t(5)i(6)n(7)s(8)); the function type lives in builtins; abstractmethod.__class__.__module__ (8: 'builtins') == ABCMeta.__class__.__module__ (8: 'builtins') — both type (metaclass of ABCMeta) and function (type of abstractmethod) live in builtins; abstractmethod.__class__.__module__ (8) > ABC.__class__.__module__ (3: 'abc') by 5; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abstractmethod_class
  kind: python_call_eq
  function: abc.abstractmethod.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra192.abc_ABC_class_name_len:
  description: "abc.ABC.__class__.__name__.__len__() == 7 — ABC.__class__.__name__.__len__()==7 ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7); the length 7 is the character count of 'ABCMeta', the name of the metaclass type of ABC; ABC.__class__.__name__.__len__ (7) > ABC.__class__.__module__.__len__ (3) by 4 — the metaclass name is longer than the module name; ABC.__class__.__name__.__len__ (7) > ABCMeta.__class__.__name__.__len__ (4) by 3 — ABCMeta's own metaclass name ('type') is shorter; NEW in abcattrs192: completing 8-invariant coverage for abc module attribute identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: file_and_ABC_class
  kind: python_call_eq
  function: abc.ABC.__class__.__name__.__len__
  args: []
  expected: 7

