spec: abc_extra192
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.__file__.__class__.__name__ == 'str' (len=3); __file__ is always a string path to the .py source file."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' (len=7); the type of ABC is ABCMeta, because ABC is defined as 'class ABC(metaclass=ABCMeta): pass'."
    - "abc.ABC.__class__.__module__ == 'abc' (len=3); ABCMeta is defined in the abc module."
    - "abc.ABCMeta.__class__.__name__ == 'type' (len=4); ABCMeta is a metaclass, so its type is the built-in type."
    - "abc.ABCMeta.__class__.__module__ == 'builtins' (len=8); the built-in type metaclass lives in the builtins module."
    - "abc.abstractmethod.__class__.__name__ == 'function' (len=8); abstractmethod is a plain function (not a class)."
    - "abc.abstractmethod.__class__.__module__ == 'builtins' (len=8); the function type lives in builtins."
    - "abc.ABC.__class__.__module__ (3) < abc.ABCMeta.__class__.__module__ (8) by 5 — 'abc' is shorter than 'builtins'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.__file__ and abc.ABC.__class__ identity
#
# abc.__file__.__class__.__name__ == 'str' (len=3)
# abc.ABC.__class__.__name__ == 'ABCMeta' (len=7)
# abc.ABC.__class__.__module__ == 'abc' (len=3)
# ---------------------------------------------------------------------------

table abc_extra192.abc_file_and_ABC_class_identity:
  description: "abc.__file__ and abc.ABC.__class__ identity checks in abcattrs192 namespace — abc.__file__.__class__.__name__=='str' (len=3: s(1)t(2)r(3); __file__ is always a string attribute holding the path to the module's source file abc.py); abc.ABC.__class__.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7; the type of ABC is ABCMeta because ABC is defined with metaclass=ABCMeta — this is the canonical way to create abstract base classes); abc.ABC.__class__.__module__=='abc' (len=3: a(1)b(2)c(3); ABCMeta is defined in the abc module itself); ABC.__class__.__name__ (7) > ABC.__class__.__module__ (3) by 4 — the metaclass name is longer than the module name; verified with Python 3.14.3"
  kind: python_call_eq
  category: file_and_ABC_class
  id_prefix: abcattrs192

  columns: [id, function, args, expected, description]
  rows:
    - [file_class_eq,      abc.__file__.__class__.__name__.__eq__,      ["str"],      true, "abc.__file__.__class__.__name__ == 'str' (len=3; __file__ is a string path to abc.py source file); verified Python 3.14.3"]
    - [file_class_len,     abc.__file__.__class__.__name__.__len__,     [],           3,    "abc.__file__.__class__.__name__.__len__() == 3 ('str'=3: s(1)t(2)r(3)); verified Python 3.14.3"]
    - [ABC_class_eq,       abc.ABC.__class__.__name__.__eq__,           ["ABCMeta"],  true, "abc.ABC.__class__.__name__ == 'ABCMeta' (len=7; ABC's metaclass is ABCMeta, defined with metaclass=ABCMeta); verified Python 3.14.3"]
    - [ABC_class_len,      abc.ABC.__class__.__name__.__len__,          [],           7,    "abc.ABC.__class__.__name__.__len__() == 7 ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7); verified Python 3.14.3"]
    - [ABC_class_mod_eq,   abc.ABC.__class__.__module__.__eq__,         ["abc"],      true, "abc.ABC.__class__.__module__ == 'abc' (len=3; ABCMeta is defined in the abc module); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta.__class__ identity
#
# abc.ABCMeta.__class__.__name__ == 'type' (len=4)
# abc.ABCMeta.__class__.__module__ == 'builtins' (len=8)
# ---------------------------------------------------------------------------

table abc_extra192.abc_ABCMeta_class_identity:
  description: "abc.ABCMeta.__class__ identity checks in abcattrs192 namespace — ABCMeta.__class__.__name__=='type' (len=4: t(1)y(2)p(3)e(4); ABCMeta is a metaclass, meaning it is an instance of type; all metaclasses have type as their type, since metaclasses are themselves classes); ABCMeta.__class__.__module__=='builtins' (len=8: b(1)u(2)i(3)l(4)t(5)i(6)n(7)s(8); the built-in type metaclass lives in the builtins module); ABCMeta.__class__.__module__ (8) > ABC.__class__.__module__ (3: 'abc') by 5 — 'builtins' is longer than 'abc'; ABCMeta.__class__.__name__ (4: 'type') < ABCMeta.__class__.__module__ (8: 'builtins') by 4; verified with Python 3.14.3"
  kind: python_call_eq
  category: ABCMeta_class
  id_prefix: abcattrs192

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta_class_eq,      abc.ABCMeta.__class__.__name__.__eq__,    ["type"],      true, "abc.ABCMeta.__class__.__name__ == 'type' (len=4; ABCMeta is a metaclass, so its type is the built-in type); verified Python 3.14.3"]
    - [ABCMeta_class_len,     abc.ABCMeta.__class__.__name__.__len__,   [],            4,    "abc.ABCMeta.__class__.__name__.__len__() == 4 ('type'=4: t(1)y(2)p(3)e(4)); verified Python 3.14.3"]
    - [ABCMeta_class_mod_eq,  abc.ABCMeta.__class__.__module__.__eq__,  ["builtins"],  true, "abc.ABCMeta.__class__.__module__ == 'builtins' (len=8; type lives in the builtins module); verified Python 3.14.3"]
    - [ABCMeta_class_mod_len, abc.ABCMeta.__class__.__module__.__len__, [],            8,    "abc.ABCMeta.__class__.__module__.__len__() == 8 ('builtins'=8: b(1)u(2)i(3)l(4)t(5)i(6)n(7)s(8)); verified Python 3.14.3"]
    - [ABC_class_mod_len,     abc.ABC.__class__.__module__.__len__,     [],            3,    "abc.ABC.__class__.__module__.__len__() == 3 ('abc'=3: a(1)b(2)c(3)); confirmed from ABC_class table; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
