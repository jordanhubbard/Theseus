spec: concurrent_futures_extra991
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures Future and Executor documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures.Future, ThreadPoolExecutor, and Executor method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra991.future_qualnames:
  description: "concurrent.futures.Future method __qualname__ identity"
  kind: python_call_eq
  category: future_qualnames
  id_prefix: cf991fq
  columns: [id, function, args, expected]
  rows:
    - [cf991fq001, concurrent.futures.Future.__init__.__qualname__.__eq__, ["Future.__init__"], true]
    - [cf991fq002, concurrent.futures.Future.set_result.__qualname__.__eq__, ["Future.set_result"], true]
    - [cf991fq003, concurrent.futures.Future.set_exception.__qualname__.__eq__, ["Future.set_exception"], true]
    - [cf991fq004, concurrent.futures.Future.exception.__qualname__.__eq__, ["Future.exception"], true]
    - [cf991fq005, concurrent.futures.Future.result.__qualname__.__eq__, ["Future.result"], true]
    - [cf991fq006, concurrent.futures.Future.cancel.__qualname__.__eq__, ["Future.cancel"], true]
    - [cf991fq007, concurrent.futures.Future.cancelled.__qualname__.__eq__, ["Future.cancelled"], true]
    - [cf991fq008, concurrent.futures.Future.done.__qualname__.__eq__, ["Future.done"], true]
    - [cf991fq009, concurrent.futures.Future.running.__qualname__.__eq__, ["Future.running"], true]
    - [cf991fq010, concurrent.futures.Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true]

table concurrent_futures_extra991.threadpool_qualnames:
  description: "concurrent.futures.ThreadPoolExecutor method __qualname__ identity"
  kind: python_call_eq
  category: threadpool_qualnames
  id_prefix: cf991tq
  columns: [id, function, args, expected]
  rows:
    - [cf991tq001, concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__, ["ThreadPoolExecutor.__init__"], true]
    - [cf991tq002, concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__, ["ThreadPoolExecutor.map"], true]
    - [cf991tq003, concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__, ["ThreadPoolExecutor.submit"], true]
    - [cf991tq004, concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"], true]

table concurrent_futures_extra991.executor_qualnames:
  description: "concurrent.futures.Executor method __qualname__ identity"
  kind: python_call_eq
  category: executor_qualnames
  id_prefix: cf991eq
  columns: [id, function, args, expected]
  rows:
    - [cf991eq001, concurrent.futures.Executor.map.__qualname__.__eq__, ["Executor.map"], true]
    - [cf991eq002, concurrent.futures.Executor.submit.__qualname__.__eq__, ["Executor.submit"], true]
    - [cf991eq003, concurrent.futures.Executor.shutdown.__qualname__.__eq__, ["Executor.shutdown"], true]
    - [cf991eq004, concurrent.futures.Executor.__enter__.__qualname__.__eq__, ["Executor.__enter__"], true]
    - [cf991eq005, concurrent.futures.Executor.__exit__.__qualname__.__eq__, ["Executor.__exit__"], true]
