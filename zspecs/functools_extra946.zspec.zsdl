spec: functools_extra946
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.partial, partialmethod, WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, and reduce class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra946.partial_class_identity:
  description: "functools.partial and partialmethod class name identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: ft946ci
  columns: [id, function, args, expected]
  rows:
    - [ft946ci001, functools.partial.__class__.__name__.__eq__,                    ["type"],          true]
    - [ft946ci002, functools.partialmethod.__class__.__name__.__eq__,              ["type"],          true]
    - [ft946ci003, functools.partial.__name__.__eq__,                              ["partial"],       true]
    - [ft946ci004, functools.partialmethod.__name__.__eq__,                        ["partialmethod"], true]
    - [ft946ci005, functools.partial.__module__.__eq__,                            ["functools"],     true]
    - [ft946ci006, functools.partialmethod.__module__.__eq__,                      ["functools"],     true]

table functools_extra946.partial_instance_class:
  description: "functools.partial instance __class__.__name__ checks"
  kind: python_call_eq
  category: instance_class
  id_prefix: ft946ic
  columns: [id, function, args, expected]
  rows:
    - [ft946ic001, functools.partial.__call__.__class__.__name__.__eq__,           ["method-wrapper"], true]
    - [ft946ic002, functools.partial.__init__.__class__.__name__.__eq__,           ["slot_wrapper"],   true]
    - [ft946ic003, functools.partial.__new__.__class__.__name__.__eq__,            ["builtin_function_or_method"], true]
    - [ft946ic004, functools.partialmethod.__get__.__qualname__.__class__.__name__.__eq__, ["str"],   true]
    - [ft946ic005, functools.partialmethod.__init__.__qualname__.__eq__,           ["partialmethod.__init__"], true]

table functools_extra946.wrapper_assignments_identity:
  description: "functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES class identity"
  kind: python_call_eq
  category: wrapper_identity
  id_prefix: ft946wa
  columns: [id, function, args, expected]
  rows:
    - [ft946wa001, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,        ["tuple"],     true]
    - [ft946wa002, functools.WRAPPER_UPDATES.__class__.__name__.__eq__,            ["tuple"],     true]
    - [ft946wa003, functools.WRAPPER_ASSIGNMENTS.__contains__,                     ["__module__"], true]
    - [ft946wa004, functools.WRAPPER_ASSIGNMENTS.__contains__,                     ["__name__"],   true]
    - [ft946wa005, functools.WRAPPER_ASSIGNMENTS.__contains__,                     ["__qualname__"], true]
    - [ft946wa006, functools.WRAPPER_ASSIGNMENTS.__contains__,                     ["__doc__"],    true]
    - [ft946wa007, functools.WRAPPER_UPDATES.__contains__,                         ["__dict__"],   true]

table functools_extra946.reduce_identity:
  description: "functools.reduce class identity checks"
  kind: python_call_eq
  category: reduce_identity
  id_prefix: ft946ri
  columns: [id, function, args, expected]
  rows:
    - [ft946ri001, functools.reduce.__class__.__name__.__eq__,                     ["builtin_function_or_method"], true]
    - [ft946ri002, functools.reduce.__module__.__eq__,                             ["functools"],  true]
    - [ft946ri003, functools.reduce.__doc__.__class__.__name__.__eq__,             ["str"],        true]
