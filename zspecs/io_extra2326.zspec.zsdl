spec: io_extra2326
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 602 (_extra2326): numeric constants and fixed-size attribute checks."
    - "io.DEFAULT_BUFFER_SIZE is 131072 (128 KiB) on macOS/Darwin 25.4.0 with Python 3.14."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — POSIX seek mode constants."
    - "Class __name__ attributes verified for all public io classes."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Numeric constants — DEFAULT_BUFFER_SIZE and SEEK_* values
# ---------------------------------------------------------------------------

table io_extra2326.numeric_constants:
  description: "io module-level integer constants: DEFAULT_BUFFER_SIZE and SEEK_*"
  kind: python_call_eq
  category: constants
  id_prefix: io2326

  columns: [id, function, args, expected]
  rows:
    - ["io2326001", "io.DEFAULT_BUFFER_SIZE", [], 131072]
    - ["io2326002", "io.SEEK_SET",            [], 0]
    - ["io2326003", "io.SEEK_CUR",            [], 1]
    - ["io2326004", "io.SEEK_END",            [], 2]

# ---------------------------------------------------------------------------
# Table 2: Class __name__ attributes — abstract base classes
# ---------------------------------------------------------------------------

table io_extra2326.abstract_class_names:
  description: "io abstract base class __name__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: io2326

  columns: [id, function, args, expected]
  rows:
    - ["io2326005", "io.IOBase.__name__",       [], "IOBase"]
    - ["io2326006", "io.RawIOBase.__name__",    [], "RawIOBase"]
    - ["io2326007", "io.BufferedIOBase.__name__", [], "BufferedIOBase"]
    - ["io2326008", "io.TextIOBase.__name__",   [], "TextIOBase"]

# ---------------------------------------------------------------------------
# Table 3: Class __name__ attributes — concrete classes
# ---------------------------------------------------------------------------

table io_extra2326.concrete_class_names:
  description: "io concrete class __name__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: io2326

  columns: [id, function, args, expected]
  rows:
    - ["io2326009", "io.FileIO.__name__",                  [], "FileIO"]
    - ["io2326010", "io.BytesIO.__name__",                 [], "BytesIO"]
    - ["io2326011", "io.StringIO.__name__",                [], "StringIO"]
    - ["io2326012", "io.BufferedReader.__name__",          [], "BufferedReader"]
    - ["io2326013", "io.BufferedWriter.__name__",          [], "BufferedWriter"]
    - ["io2326014", "io.TextIOWrapper.__name__",           [], "TextIOWrapper"]
    - ["io2326015", "io.IncrementalNewlineDecoder.__name__", [], "IncrementalNewlineDecoder"]

# ---------------------------------------------------------------------------
# Table 4: Constant type checks — confirm integer types
# ---------------------------------------------------------------------------

table io_extra2326.constant_types:
  description: "io integer constants have __class__.__name__ == 'int'"
  kind: python_call_eq
  category: constants
  id_prefix: io2326

  columns: [id, function, args, expected]
  rows:
    - ["io2326016", "io.DEFAULT_BUFFER_SIZE.__class__.__name__", [], "int"]
    - ["io2326017", "io.SEEK_SET.__class__.__name__",            [], "int"]
    - ["io2326018", "io.SEEK_CUR.__class__.__name__",            [], "int"]
    - ["io2326019", "io.SEEK_END.__class__.__name__",            [], "int"]

# ---------------------------------------------------------------------------
# Table 5: SEEK constant distinctness — all three values differ
# ---------------------------------------------------------------------------

table io_extra2326.seek_ordering:
  description: "SEEK_SET < SEEK_CUR < SEEK_END ordering"
  kind: python_call_eq
  category: constants
  id_prefix: io2326

  columns: [id, function, args, expected]
  rows:
    - ["io2326020", "io.SEEK_SET.__lt__", [1], true]
    - ["io2326021", "io.SEEK_CUR.__lt__", [2], true]
    - ["io2326022", "io.SEEK_END.__gt__", [0], true]
