spec: re_extra248
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub whitespace_to_dash, digit_to_X (a1b2c3), backreference_group1, no_match_noop, named_group, empty"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class names, flags, match, search, sub(a1b2), split, findall"
    - "re_extra242.zspec.zsdl — covers fullmatch and finditer function identity and behavioral contracts"
  notes:
    - "This spec covers: re.sub behavioral contracts with distinct test vectors not covered in re.zspec.zsdl or re_extra.zspec.zsdl."
    - "re.sub(r'\\d', 'X', 'a1b2c3') == 'aXbXcX' — replaces all single digits; verified Python 3.14.3 macOS."
    - "re.sub(r'\\s+', ' ', 'a  b   c') == 'a b c' — collapses runs of whitespace to a single space; verified Python 3.14.3 macOS."
    - "re.sub(r'(a)', r'\\1\\1', 'abc') == 'aabc' — backreference \\1 doubles the first group; verified Python 3.14.3 macOS."
    - "re.sub(r'\\d', 'X', 'abc') == 'abc' — no-match leaves string unchanged; verified Python 3.14.3 macOS."
    - "re.sub(r'\\d+', 'N', 'foo123bar456') == 'fooNbarN' — replaces each run of digits; verified Python 3.14.3 macOS."
    - "re.sub(r'[aeiou]', '*', 'hello world') == 'h*ll* w*rld' — replaces all vowels; verified Python 3.14.3 macOS."
    - "re.sub.__name__ == 'sub', __module__ == 're', __qualname__ == 'sub'; verified Python 3.14.3 macOS."
    - "re.sub.__class__.__name__ == 'function' — sub is a plain Python function; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.sub behavioral contracts — distinct vectors not in re.zspec.zsdl
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra248.sub_behavioral:
  description: "re.sub behavioral contracts: digit replacement, whitespace collapse, backreference, no-match; verified Python 3.14.3"
  kind: python_call_eq
  category: substitution
  id_prefix: resubbeh248
  function: sub

  columns: [id, args, expected]
  rows:
    - [digits_to_X,       ["\\d",    "X",  "a1b2c3"     ], "aXbXcX"    ]
    - [whitespace_collapse, ["\\s+", " ",  "a  b   c"   ], "a b c"     ]
    - [no_match_unchanged, ["\\d",   "X",  "abc"        ], "abc"       ]
    - [digit_run_to_N,    ["\\d+",   "N",  "foo123bar456"], "fooNbarN" ]

# ---------------------------------------------------------------------------
# re.sub backreference contract — table with 5 columns (id + args columns)
# Uses a 5-column table: id, arg1_pattern, arg2_repl, arg3_input, expected
# The args column consolidates all three positional arguments into a list.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra248.sub_backreference:
  description: "re.sub backreference and vowel replacement contracts; verified Python 3.14.3"
  kind: python_call_eq
  category: substitution
  id_prefix: resubbeh248
  function: sub

  columns: [id, args, expected]
  rows:
    - [backref_double_a,  ["(a)", "\\1\\1", "abc"        ], "aabc"     ]
    - [vowel_replace,     ["[aeiou]", "*",  "hello world"], "h*ll* w*rld"]

# ---------------------------------------------------------------------------
# re.sub function identity contracts
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra248.sub_identity:
  description: "re.sub function identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: resubbeh248

  columns: [id, function, args, expected]
  rows:
    - [name_eq,      sub.__name__.__eq__,      ["sub"], true]
    - [module_eq,    sub.__module__.__eq__,    ["re"],  true]
    - [qualname_eq,  sub.__qualname__.__eq__,  ["sub"], true]
    - [name_not,     sub.__name__.__eq__,      ["gsub"], false]
    - [class_is_fn,  sub.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# Standalone invariants — re.sub behavioral
# ---------------------------------------------------------------------------

invariant re_extra248.sub.digits_to_X:
  description: "re.sub(r'\\d', 'X', 'a1b2c3') == 'aXbXcX' — replaces every digit with 'X'; verified Python 3.14.3 macOS"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["\\d", "X", "a1b2c3"]
  expected: "aXbXcX"

invariant re_extra248.sub.whitespace_collapse:
  description: "re.sub(r'\\s+', ' ', 'a  b   c') == 'a b c' — collapses runs of whitespace to a single space; verified Python 3.14.3 macOS"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["\\s+", " ", "a  b   c"]
  expected: "a b c"

invariant re_extra248.sub.backref_double:
  description: "re.sub(r'(a)', r'\\1\\1', 'abc') == 'aabc' — backreference \\1 duplicates the first captured group; verified Python 3.14.3 macOS"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["(a)", "\\1\\1", "abc"]
  expected: "aabc"

invariant re_extra248.sub.no_match_unchanged:
  description: "re.sub(r'\\d', 'X', 'abc') == 'abc' — no digit in input means the string is returned unchanged; verified Python 3.14.3 macOS"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["\\d", "X", "abc"]
  expected: "abc"

invariant re_extra248.sub.digit_run_to_N:
  description: "re.sub(r'\\d+', 'N', 'foo123bar456') == 'fooNbarN' — each run of digits is replaced with 'N'; verified Python 3.14.3 macOS"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["\\d+", "N", "foo123bar456"]
  expected: "fooNbarN"

invariant re_extra248.sub.vowel_replace:
  description: "re.sub(r'[aeiou]', '*', 'hello world') == 'h*ll* w*rld' — replaces all ASCII vowels; verified Python 3.14.3 macOS"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["[aeiou]", "*", "hello world"]
  expected: "h*ll* w*rld"

# ---------------------------------------------------------------------------
# Standalone invariants — re.sub function identity
# ---------------------------------------------------------------------------

invariant re_extra248.sub.name_eq:
  description: "re.sub.__name__ == 'sub' — the function name is 'sub'; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: sub.__name__.__eq__
  args: ["sub"]
  expected: true

invariant re_extra248.sub.module_eq:
  description: "re.sub.__module__ == 're' — sub is defined in the re module; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: sub.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra248.sub.qualname_eq:
  description: "re.sub.__qualname__ == 'sub' — qualname matches __name__ for a module-level function; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: sub.__qualname__.__eq__
  args: ["sub"]
  expected: true

invariant re_extra248.sub.class_is_function:
  description: "re.sub.__class__.__name__ == 'function' — sub is a plain Python function; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: sub.__class__.__name__.__eq__
  args: ["function"]
  expected: true
