spec: struct_extra129
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra128.zspec.zsdl — covers Struct.__init__ wrapper_descriptor identity / Struct.pack/unpack/pack_into/unpack_from __qualname__ equality / Struct method __class__.__name__=='method_descriptor' / Struct method __name__ equality (table + invariants)."
    - "struct_extra127.zspec.zsdl — covers Struct.__reduce__/__reduce_ex__ identity / Struct.__sizeof__ class name and qualname / Struct.__doc__ equality and length / Struct.size and format __objclass__.__name__ and __module__ equality (table + invariants)."
    - "struct_extra126.zspec.zsdl — covers Struct.__init__/__repr__/__sizeof__/__reduce_ex__ qualname string equality / Struct.__new__.__qualname__ equality / Struct.__class__.__name__=='type' (table + invariants)."
    - "struct_extra125.zspec.zsdl — covers struct.__all__ list class name and length / __all__ membership / Struct method __objclass__.__name__ equality (table + invariants)."
    - "struct_extra124.zspec.zsdl — covers Struct.__dict__.__contains__ for dunder names (table + invariants)."
    - "struct_extra123.zspec.zsdl — covers Struct.pack/__objclass__/__module__/__qualname__/__class__.__name__ (table + invariants)."
    - "struct_extra122.zspec.zsdl — covers struct.error/__name__/__qualname__/__class__.__name__ / Struct/__name__/__qualname__/__class__.__name__ / Struct.size/format/__name__ equality (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths / Struct.size/__format__ descriptor __doc__ (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__.__len__() (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct module/qualname/bases/mro (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior struct spec files."
    - "Wave 347 theme: struct module-level function __name__/__qualname__/__module__ equality for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack (module-level C builtins, not Struct instance methods) / __class__.__name__=='builtin_function_or_method' equality / __qualname__ lengths."
    - "struct.pack.__qualname__ == 'pack'. Module-level function, not Struct.pack (method_descriptor). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct'. All module-level struct functions come from the _struct C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__class__.__name__ == 'builtin_function_or_method'. Module-level struct functions are C builtins (unlike Struct instance methods which are method_descriptor). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('pack') == 4. len('unpack') == 6. len('pack_into') == 9. len('unpack_from') == 11. len('calcsize') == 8. len('iter_unpack') == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct_extra93 anchors Struct method __name__ and Struct.__module__/__qualname__ at table level. struct_extra122 anchors struct.error class identity. This spec is the first to anchor module-level pack/unpack/calcsize/etc. __name__/__qualname__/__module__/__class__.__name__ via __eq__ calls under structmod129."
    - "Note: The module-level struct.pack (a builtin_function_or_method) is distinct from struct.Struct.pack (a method_descriptor). Their qualnames differ: 'pack' vs 'Struct.pack'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack')
# struct.pack.__qualname__.__eq__('pack')
# struct.pack.__module__.__eq__('_struct')
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.unpack.__name__.__eq__('unpack')
#
# Wave 347 theme: module-level pack/unpack identity as C builtins from _struct.
#
# struct.pack and struct.unpack are module-level C builtin functions (class
# 'builtin_function_or_method') from the _struct extension. They are distinct
# from struct.Struct.pack and struct.Struct.unpack, which are method_descriptor
# objects bound to the Struct class. The module-level functions have qualnames
# without a class prefix ('pack', not 'Struct.pack'), and their __module__ is
# '_struct'. struct_extra93 anchors Struct method __name__; this spec is the
# first to anchor module-level __name__/__qualname__/__module__/__class__.__name__
# via __eq__ calls under structmod129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra129.module_level_pack_unpack_identity:
  description: "struct.pack/__name__.__eq__('pack')==True / pack/__qualname__.__eq__('pack')==True / pack/__module__.__eq__('_struct')==True / pack/__class__.__name__.__eq__('builtin_function_or_method')==True / unpack/__name__.__eq__('unpack')==True — module-level pack/unpack are C builtins from _struct (not Struct.pack/unpack method_descriptors); qualname has no class prefix; extra93 anchors Struct method __name__; first structmod129 anchor for module-level function identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmod129

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name,    pack.__name__.__eq__,               ["pack"],                      true, "struct.pack.__name__ is 'pack' (module-level C builtin, not Struct.pack)"]
    - [pack_qualname, pack.__qualname__.__eq__,           ["pack"],                      true, "struct.pack.__qualname__ is 'pack' (no class prefix, distinct from 'Struct.pack')"]
    - [pack_module,  pack.__module__.__eq__,              ["_struct"],                   true, "struct.pack.__module__ is '_struct' (C extension)"]
    - [pack_class,   pack.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "struct.pack is a C builtin (not method_descriptor like Struct.pack)"]
    - [unpack_name,  unpack.__name__.__eq__,              ["unpack"],                    true, "struct.unpack.__name__ is 'unpack' (module-level C builtin)"]

# ---------------------------------------------------------------------------
# struct.unpack.__qualname__.__eq__('unpack')
# struct.unpack.__module__.__eq__('_struct')
# struct.calcsize.__name__.__eq__('calcsize')
# struct.calcsize.__qualname__.__eq__('calcsize')
# struct.calcsize.__module__.__eq__('_struct')
#
# Wave 347 theme: module-level unpack qualname/module and calcsize identity.
#
# struct.unpack's qualname is 'unpack' (6 chars), module is '_struct'.
# struct.calcsize is a C builtin that returns the size in bytes corresponding
# to a struct format string — useful for computing buffer sizes before packing.
# calcsize's __qualname__ is 'calcsize' (8 chars) and __module__ is '_struct'.
# These are all module-level functions, not Struct instance methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra129.unpack_and_calcsize_identity:
  description: "struct.unpack/__qualname__.__eq__('unpack')==True / unpack/__module__.__eq__('_struct')==True / calcsize/__name__.__eq__('calcsize')==True / calcsize/__qualname__.__eq__('calcsize')==True / calcsize/__module__.__eq__('_struct')==True — module-level unpack/calcsize are C builtins from _struct; calcsize returns byte size for format string; first structmod129 anchor for unpack qualname/module and calcsize identity via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmod129

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_qualname,   unpack.__qualname__.__eq__,   ["unpack"],   true, "struct.unpack.__qualname__ is 'unpack' (6 chars, no class prefix)"]
    - [unpack_module,     unpack.__module__.__eq__,     ["_struct"],  true, "struct.unpack.__module__ is '_struct' (C extension)"]
    - [calcsize_name,     calcsize.__name__.__eq__,     ["calcsize"], true, "struct.calcsize.__name__ is 'calcsize' (8 chars)"]
    - [calcsize_qualname, calcsize.__qualname__.__eq__,  ["calcsize"], true, "struct.calcsize.__qualname__ is 'calcsize' (no class prefix)"]
    - [calcsize_module,   calcsize.__module__.__eq__,   ["_struct"],  true, "struct.calcsize.__module__ is '_struct' (C extension)"]

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__eq__('pack_into')
# struct.pack_into.__qualname__.__eq__('pack_into')
# struct.unpack_from.__name__.__eq__('unpack_from')
# struct.iter_unpack.__name__.__eq__('iter_unpack')
# struct.calcsize.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 347 theme: pack_into/unpack_from/iter_unpack names and calcsize class name.
#
# struct.pack_into, struct.unpack_from, and struct.iter_unpack are module-level
# C builtin functions. pack_into writes into a pre-allocated buffer at an offset;
# unpack_from reads from a buffer at an offset; iter_unpack is a generator-style
# function returning successive fixed-size records. calcsize's class name confirms
# all six module-level functions are 'builtin_function_or_method'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra129.pack_into_unpack_from_iter_identity:
  description: "struct.pack_into/__name__.__eq__('pack_into')==True / pack_into/__qualname__.__eq__('pack_into')==True / unpack_from/__name__.__eq__('unpack_from')==True / iter_unpack/__name__.__eq__('iter_unpack')==True / calcsize/__class__.__name__.__eq__('builtin_function_or_method')==True — pack_into/unpack_from/iter_unpack are module-level C builtins from _struct; first structmod129 anchor for pack_into/unpack_from/iter_unpack name equality and calcsize class name"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmod129

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_name,     pack_into.__name__.__eq__,               ["pack_into"],                 true, "struct.pack_into.__name__ is 'pack_into' (9 chars)"]
    - [pack_into_qualname, pack_into.__qualname__.__eq__,            ["pack_into"],                 true, "struct.pack_into.__qualname__ is 'pack_into' (no class prefix)"]
    - [unpack_from_name,   unpack_from.__name__.__eq__,             ["unpack_from"],               true, "struct.unpack_from.__name__ is 'unpack_from' (11 chars)"]
    - [iter_unpack_name,   iter_unpack.__name__.__eq__,             ["iter_unpack"],               true, "struct.iter_unpack.__name__ is 'iter_unpack' (11 chars)"]
    - [calcsize_class,     calcsize.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "struct.calcsize is a C builtin (confirms all 6 module-level functions are builtin_function_or_method)"]

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack') — standalone
#
# struct.pack.__name__ is 'pack' (4 chars). The module-level struct.pack is
# a C builtin function from the _struct extension. It is distinct from
# struct.Struct.pack, which is a method_descriptor. The module-level function
# has __qualname__ == __name__ == 'pack' (no class prefix), while the Struct
# method has __qualname__ == 'Struct.pack'. struct_extra93 anchors Struct.pack
# __name__ at table level; this is the first standalone for the module-level
# struct.pack.__name__.__eq__('pack') under structmod129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra129.module_pack_name:
  description: "struct.pack.__name__.__eq__('pack') == True — module-level struct.pack is a C builtin from _struct; __name__ is 'pack' (4 chars, no class prefix); distinct from struct.Struct.pack (method_descriptor, __qualname__=='Struct.pack'); extra93 anchors Struct.pack __name__; first standalone for module-level struct.pack __name__ under structmod129"
  category: type_identity
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__module__.__eq__('_struct') — standalone
#
# struct.pack.__module__ is '_struct'. The _struct C extension module provides
# the fast C implementations of all six struct module-level functions. When Python
# imports 'struct', it re-exports these C functions so they appear in the 'struct'
# namespace, but their __module__ still points to the origin '_struct'. This two-
# layer architecture (struct.py as public API, _struct.so as C backend) is the
# same pattern used by hashlib/_hashlib, io/_io, etc. This is the first standalone
# for struct.pack.__module__.__eq__('_struct') under structmod129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra129.module_pack_module:
  description: "struct.pack.__module__.__eq__('_struct') == True — struct.pack's __module__ is '_struct' (C extension origin); struct.py re-exports from _struct same as hashlib/_hashlib; first standalone for struct.pack.__module__.__eq__ under structmod129"
  category: type_identity
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize.__name__.__eq__('calcsize') — standalone
#
# struct.calcsize.__name__ is 'calcsize' (8 chars). calcsize is the struct module's
# format string size query function — it returns the number of bytes required to
# pack or unpack a given format string, without performing actual packing. Unlike
# pack/unpack which process data, calcsize only inspects the format. It is a C
# builtin from _struct. This is the first standalone for calcsize.__name__.__eq__
# ('calcsize') under structmod129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra129.calcsize_name:
  description: "struct.calcsize.__name__.__eq__('calcsize') == True — calcsize queries format string byte size without processing data; 8 chars; C builtin from _struct; first standalone for calcsize.__name__.__eq__ under structmod129"
  category: type_identity
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.pack.__class__.__name__ is 'builtin_function_or_method'. This contrasts
# with struct.Struct.pack, whose __class__.__name__ is 'method_descriptor'. The
# distinction: module-level C functions that are not bound to a type are
# PyCFunction objects (class 'builtin_function_or_method'), while C methods
# bound to a C extension type are PyMethodDescrObject (class 'method_descriptor').
# struct_extra128 anchors Struct.pack as 'method_descriptor'; this is the first
# standalone for the module-level struct.pack as 'builtin_function_or_method'
# under structmod129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra129.module_pack_class:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — module-level struct.pack is a PyCFunction (builtin_function_or_method), contrasting with Struct.pack which is a method_descriptor (PyMethodDescrObject); extra128 anchors Struct.pack class; first standalone for module-level pack class name under structmod129"
  category: type_identity
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__.__eq__('iter_unpack') — standalone
#
# struct.iter_unpack.__name__ is 'iter_unpack' (11 chars). iter_unpack is the
# only struct module-level function that returns an iterator (rather than bytes
# or a tuple). It repeatedly unpacks records of fixed size from a buffer, making
# it suitable for processing binary data streams. Like all six module-level
# functions, it is a C builtin from _struct. struct_extra95 anchors
# iter_unpack.__qualname__.__len__()==11 at table level; this is the first
# standalone for iter_unpack.__name__.__eq__('iter_unpack') under structmod129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra129.iter_unpack_name:
  description: "struct.iter_unpack.__name__.__eq__('iter_unpack') == True — iter_unpack is the only module-level struct function returning an iterator (for streaming fixed-size binary records); 11 chars; C builtin from _struct; extra95 anchors __qualname__.__len__(); first standalone for iter_unpack.__name__.__eq__ under structmod129"
  category: type_identity
  kind: python_call_eq
  function: iter_unpack.__name__.__eq__
  args: ["iter_unpack"]
  expected: true

