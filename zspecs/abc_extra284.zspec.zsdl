spec: abc_extra284
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc.ABC and abc.ABCMeta method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py, Modules/_abc.c"
  notes:
    - "abc.get_cache_token is implemented in C (_abc module); its __module__ is '_abc'"
    - "abc.ABCMeta.__subclasscheck__ and __instancecheck__ are defined in ABCMeta"
    - "abc.ABC.__bases__[0] is object"
    - "abc.abstractmethod is a pure-Python class defined in Lib/abc.py"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra284.abcmeta_method_qualnames:
  description: "ABCMeta method __qualname__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: abc284m

  columns: [id, function, args, expected, description]
  rows:
    - [abc284m001, abc.ABCMeta.register.__qualname__, [], "ABCMeta.register", "register.__qualname__"]
    - [abc284m002, abc.ABCMeta.__subclasscheck__.__qualname__, [], "ABCMeta.__subclasscheck__", "__subclasscheck__.__qualname__"]
    - [abc284m003, abc.ABCMeta.__instancecheck__.__qualname__, [], "ABCMeta.__instancecheck__", "__instancecheck__.__qualname__"]

table abc_extra284.module_function_identity:
  description: "abc module function and class identity"
  kind: python_call_eq
  category: identity
  id_prefix: abc284f

  columns: [id, function, args, expected, description]
  rows:
    - [abc284f001, abc.abstractmethod.__name__, [], abstractmethod, "abstractmethod.__name__"]
    - [abc284f002, abc.abstractmethod.__module__, [], abc, "abstractmethod.__module__ is 'abc'"]
    - [abc284f003, abc.abstractmethod.__qualname__, [], abstractmethod, "abstractmethod.__qualname__"]
    - [abc284f004, abc.get_cache_token.__name__, [], get_cache_token, "get_cache_token.__name__"]
    - [abc284f005, abc.update_abstractmethods.__name__, [], update_abstractmethods, "update_abstractmethods.__name__"]
    - [abc284f006, abc.update_abstractmethods.__module__, [], abc, "update_abstractmethods.__module__ is 'abc'"]
    - [abc284f007, abc.ABC.__name__, [], ABC, "ABC.__name__ is 'ABC'"]
    - [abc284f008, abc.ABC.__module__, [], abc, "ABC.__module__ is 'abc'"]

invariant abc_extra284.abcmeta_name:
  description: "abc.ABCMeta.__name__ == 'ABCMeta'"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__name__
  args: []
  expected: "ABCMeta"

invariant abc_extra284.abcmeta_module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__module__
  args: []
  expected: "abc"

invariant abc_extra284.abc_bases_object:
  description: "abc.ABC.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__bases__[0].__name__
  args: []
  expected: "object"

invariant abc_extra284.get_cache_token_module:
  description: "abc.get_cache_token.__module__ == '_abc' (C extension)"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__
  args: []
  expected: "_abc"
