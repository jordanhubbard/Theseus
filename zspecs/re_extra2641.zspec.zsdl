spec: re_extra2641
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2626.zspec.zsdl — covers __length_hint__/__missing__/__reversed__ dict-presence"
  notes:
    - "Wave 623 (re_extra2641) theme: __copy__, __deepcopy__, and __sizeof__ dict-presence checks."
    - "re.Pattern defines both __copy__ and __deepcopy__ in its own __dict__ — compiled patterns support the copy protocol."
    - "re.Match defines both __copy__ and __deepcopy__ in its own __dict__ — match objects support the copy protocol."
    - "Neither re.Pattern nor re.Match defines __sizeof__ in its own __dict__."
    - "__copy__ and __deepcopy__ on re.Pattern and re.Match return the object itself (patterns and matches are immutable/internable)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __copy__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2641.copy_in_re_classes:
  description: "__copy__ IS defined in re.Pattern and re.Match __dict__s — compiled patterns and match objects implement the copy protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2641

  columns: [id, function, args, expected]
  rows:
    - ["re2641001", "re.Pattern.__dict__.__contains__", ["__copy__"], true]
    - ["re2641002", "re.Match.__dict__.__contains__",   ["__copy__"], true]

# ---------------------------------------------------------------------------
# __deepcopy__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2641.deepcopy_in_re_classes:
  description: "__deepcopy__ IS defined in re.Pattern and re.Match __dict__s — compiled patterns and match objects implement the deep-copy protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2641

  columns: [id, function, args, expected]
  rows:
    - ["re2641003", "re.Pattern.__dict__.__contains__", ["__deepcopy__"], true]
    - ["re2641004", "re.Match.__dict__.__contains__",   ["__deepcopy__"], true]

# ---------------------------------------------------------------------------
# __sizeof__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2641.no_sizeof_in_re_classes:
  description: "__sizeof__ is absent from re.Pattern and re.Match __dict__s — regex classes do not override memory sizing"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2641

  columns: [id, function, args, expected]
  rows:
    - ["re2641005", "re.Pattern.__dict__.__contains__", ["__sizeof__"], false]
    - ["re2641006", "re.Match.__dict__.__contains__",   ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods AND copy hooks but NOT __sizeof__
# Confirms that copy-protocol presence does not entail __sizeof__ presence
# ---------------------------------------------------------------------------

table re_extra2641.re_has_regex_methods_and_copy_hooks_not_sizeof:
  description: "re.Pattern defines match/search/findall/sub AND __copy__/__deepcopy__ but NOT __sizeof__; re.Match defines group/groups/start/end AND __copy__/__deepcopy__ but NOT __sizeof__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2641

  columns: [id, function, args, expected]
  rows:
    - ["re2641007", "re.Pattern.__dict__.__contains__", ["match"],       true]
    - ["re2641008", "re.Pattern.__dict__.__contains__", ["search"],      true]
    - ["re2641009", "re.Pattern.__dict__.__contains__", ["findall"],     true]
    - ["re2641010", "re.Pattern.__dict__.__contains__", ["sub"],         true]
    - ["re2641011", "re.Pattern.__dict__.__contains__", ["__copy__"],    true]
    - ["re2641012", "re.Pattern.__dict__.__contains__", ["__deepcopy__"], true]
    - ["re2641013", "re.Pattern.__dict__.__contains__", ["__sizeof__"],  false]
    - ["re2641014", "re.Match.__dict__.__contains__",   ["group"],       true]
    - ["re2641015", "re.Match.__dict__.__contains__",   ["groups"],      true]
    - ["re2641016", "re.Match.__dict__.__contains__",   ["start"],       true]
    - ["re2641017", "re.Match.__dict__.__contains__",   ["end"],         true]
    - ["re2641018", "re.Match.__dict__.__contains__",   ["__copy__"],    true]
    - ["re2641019", "re.Match.__dict__.__contains__",   ["__deepcopy__"], true]
    - ["re2641020", "re.Match.__dict__.__contains__",   ["__sizeof__"],  false]
