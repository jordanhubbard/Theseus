spec: os_extra11
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra10.zspec.zsdl."
    - "os_extra10 covers: os.name=='posix'; os.path.__name__=='posixpath'; stat_result/DirEntry/terminal_size/PathLike __qualname__; DirEntry/terminal_size __module__; sep/curdir/pardir isascii(); getlogin.__name__."
    - "No prior os spec covers os.F_OK, os.R_OK, os.W_OK, os.X_OK access-test constants."
    - "No prior os spec covers os.SEEK_SET, os.SEEK_CUR, os.SEEK_END seek-mode constants."
    - "No prior os spec covers os.error identity (os.error is OSError alias) attributes."
    - "No prior os spec covers os.getpid/__module__, os.getcwd/__module__, or os.getlogin/__module__."
    - "No prior os spec covers stat_result/DirEntry/terminal_size metaclass (all are 'type')."
    - "os.F_OK==0, os.R_OK==4, os.W_OK==2, os.X_OK==1 — access(2) mode constants (POSIX)."
    - "os.SEEK_SET==0, os.SEEK_CUR==1, os.SEEK_END==2 — lseek(2) whence constants (POSIX)."
    - "os.error is an alias for OSError; os.error.__name__=='OSError', __module__=='builtins', __qualname__=='OSError'."
    - "os.getpid.__module__ == 'posix' — getpid is implemented in the posix C extension."
    - "os.getcwd.__module__ == 'posix' — getcwd is implemented in the posix C extension."
    - "os.getlogin.__module__ == 'posix' — getlogin is implemented in the posix C extension."
    - "os.stat_result.__class__.__name__ == 'type' — stat_result is a type object (C extension type)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.F_OK, os.R_OK, os.W_OK, os.X_OK — access(2) mode constants
#
# No prior os spec covers these constants. They are passed to os.access()
# to test file accessibility. Values: F_OK==0, R_OK==4, W_OK==2, X_OK==1.
# ---------------------------------------------------------------------------

table os_extra11.access_constants.values:
  kind: python_call_eq
  category: constants
  id_prefix: access

  columns: [id, function, args, expected]
  rows:
    - [fok, F_OK.__eq__, [0], true]
    - [rok, R_OK.__eq__, [4], true]
    - [wok, W_OK.__eq__, [2], true]
    - [xok, X_OK.__eq__, [1], true]

table os_extra11.access_constants.types:
  kind: python_call_eq
  category: constants
  id_prefix: access_type

  columns: [id, function, args, expected]
  rows:
    - [fok, F_OK.__class__.__name__.__eq__, ["int"], true]
    - [rok, R_OK.__class__.__name__.__eq__, ["int"], true]
    - [wok, W_OK.__class__.__name__.__eq__, ["int"], true]
    - [xok, X_OK.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# os.SEEK_SET, os.SEEK_CUR, os.SEEK_END — lseek(2) whence constants
#
# No prior os spec covers SEEK_* constants.
# Values are POSIX-standard: SEEK_SET==0, SEEK_CUR==1, SEEK_END==2.
# ---------------------------------------------------------------------------

table os_extra11.seek_constants.values:
  kind: python_call_eq
  category: constants
  id_prefix: seek

  columns: [id, function, args, expected]
  rows:
    - [set, SEEK_SET.__eq__, [0], true]
    - [cur, SEEK_CUR.__eq__, [1], true]
    - [end, SEEK_END.__eq__, [2], true]

table os_extra11.seek_constants.types:
  kind: python_call_eq
  category: constants
  id_prefix: seek_type

  columns: [id, function, args, expected]
  rows:
    - [set, SEEK_SET.__class__.__name__.__eq__, ["int"], true]
    - [cur, SEEK_CUR.__class__.__name__.__eq__, ["int"], true]
    - [end, SEEK_END.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# os.error — OSError alias identity
#
# No prior os spec covers os.error (the OSError alias).
# os.error.__name__ == 'OSError', __module__ == 'builtins', __qualname__ == 'OSError'.
# ---------------------------------------------------------------------------

invariant os_extra11.error.name:
  description: "os.error.__name__ == 'OSError' — os.error is an alias for the built-in OSError"
  category: exceptions
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant os_extra11.error.module:
  description: "os.error.__module__ == 'builtins' — os.error is the built-in OSError"
  category: exceptions
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant os_extra11.error.qualname:
  description: "os.error.__qualname__ == 'OSError' — qualname matches __name__ for this top-level builtin"
  category: exceptions
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# os.getpid, os.getcwd, os.getlogin — __module__ checks
#
# Prior specs cover __name__ and __qualname__ for these functions.
# No prior spec checks __module__ for them.
# All three are implemented in the posix C extension module.
# ---------------------------------------------------------------------------

invariant os_extra11.getpid.module:
  description: "os.getpid.__module__ == 'posix' — getpid is implemented in the posix C extension"
  category: function_modules
  kind: python_call_eq
  function: getpid.__module__.__eq__
  args: ["posix"]
  expected: true

invariant os_extra11.getcwd.module:
  description: "os.getcwd.__module__ == 'posix' — getcwd is implemented in the posix C extension"
  category: function_modules
  kind: python_call_eq
  function: getcwd.__module__.__eq__
  args: ["posix"]
  expected: true

invariant os_extra11.getlogin.module:
  description: "os.getlogin.__module__ == 'posix' — getlogin is implemented in the posix C extension"
  category: function_modules
  kind: python_call_eq
  function: getlogin.__module__.__eq__
  args: ["posix"]
  expected: true

# ---------------------------------------------------------------------------
# os.getlogin — __qualname__ check
#
# os_extra10 covers os.getlogin.__name__. No prior spec covers __qualname__.
# For module-level C builtins, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant os_extra11.getlogin.qualname:
  description: "os.getlogin.__qualname__ == 'getlogin'"
  category: qualnames
  kind: python_call_eq
  function: getlogin.__qualname__.__eq__
  args: ["getlogin"]
  expected: true

# ---------------------------------------------------------------------------
# C-extension type metaclass checks — stat_result, DirEntry, terminal_size
#
# os_extra7 covers __name__ for these types.
# os_extra10 covers __qualname__ for these types.
# No prior spec checks their metaclass (__class__.__name__ == 'type').
# ---------------------------------------------------------------------------

table os_extra11.type_metaclass:
  kind: python_call_eq
  category: class_identity
  id_prefix: metaclass

  columns: [id, function, args, expected]
  rows:
    - [stat_result,   stat_result.__class__.__name__.__eq__,   ["type"], true]
    - [DirEntry,      DirEntry.__class__.__name__.__eq__,      ["type"], true]
    - [terminal_size, terminal_size.__class__.__name__.__eq__, ["type"], true]
