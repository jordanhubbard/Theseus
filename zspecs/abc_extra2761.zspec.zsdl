spec: abc_extra2761
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra.zspec.zsdl — covers abstractmethod.__isabstractmethod__, ABC.__subclasshook__, ABC.__abstractmethods__, ABCMeta.__instancecheck__, get_cache_token"
    - "abc_extra2.zspec.zsdl — covers __name__, __module__, __qualname__, metaclass identity for ABC, ABCMeta, abstractmethod"
  notes:
    - "Wave 631 theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "None of the abc public objects define __matmul__, __truediv__, or __iadd__ in their __dict__."
    - "ABCMeta is a metaclass (type of type); ABC is the abstract base class helper; abstractmethod and abstractproperty are decorators."
    - "abc.abstractproperty is deprecated since Python 3.3 and removed in Python 3.13; version constraint >=3.9,<3.13 applies to abstractproperty rows."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta — __matmul__/__truediv__/__iadd__ dict-presence checks
#
# ABCMeta is the metaclass for abstract base classes. Its __dict__ contains
# metaclass machinery (__instancecheck__, __subclasscheck__, register, etc.)
# but no arithmetic operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2761.abcmeta_operator_dict:
  description: "abc.ABCMeta __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2761am

  columns: [id, function, args, expected]
  rows:
    - ["ab2761am_matmul",  abc.ABCMeta.__dict__.__contains__, ["__matmul__"],  false]
    - ["ab2761am_truediv", abc.ABCMeta.__dict__.__contains__, ["__truediv__"], false]
    - ["ab2761am_iadd",    abc.ABCMeta.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# abc.ABC — __matmul__/__truediv__/__iadd__ dict-presence checks
#
# ABC is the convenience helper class for creating abstract base classes via
# inheritance. Its __dict__ is minimal (only __doc__ and __abstractmethods__).
# It does not define arithmetic operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2761.abc_operator_dict:
  description: "abc.ABC __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2761abc

  columns: [id, function, args, expected]
  rows:
    - ["ab2761abc_matmul",  abc.ABC.__dict__.__contains__, ["__matmul__"],  false]
    - ["ab2761abc_truediv", abc.ABC.__dict__.__contains__, ["__truediv__"], false]
    - ["ab2761abc_iadd",    abc.ABC.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# abc.abstractmethod — __matmul__/__truediv__/__iadd__ dict-presence checks
#
# abstractmethod is a pure-Python decorator function. Its __dict__ holds only
# __isabstractmethod__ == True and the usual function attributes. It does not
# implement arithmetic operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2761.abstractmethod_operator_dict:
  description: "abc.abstractmethod __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2761abm

  columns: [id, function, args, expected]
  rows:
    - ["ab2761abm_matmul",  abc.abstractmethod.__dict__.__contains__, ["__matmul__"],  false]
    - ["ab2761abm_truediv", abc.abstractmethod.__dict__.__contains__, ["__truediv__"], false]
    - ["ab2761abm_iadd",    abc.abstractmethod.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Full cross-type matrix — ABCMeta, ABC, abstractmethod × three operator dunders
#
# Consolidates the 3×3 dict-presence check (excluding deprecated abstractproperty)
# in one table. Every cell is False: ABCMeta, ABC, and abstractmethod do not
# define @, /, or += operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table abc_extra2761.all_types_matmul_truediv_iadd_matrix:
  description: "Full 3×3 dict-presence matrix for abc.ABCMeta, abc.ABC, abc.abstractmethod vs __matmul__/__truediv__/__iadd__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2761mx

  columns: [id, function, args, expected]
  rows:
    - ["ab2761mx_am_mm",  abc.ABCMeta.__dict__.__contains__,      ["__matmul__"],  false]
    - ["ab2761mx_am_td",  abc.ABCMeta.__dict__.__contains__,      ["__truediv__"], false]
    - ["ab2761mx_am_ia",  abc.ABCMeta.__dict__.__contains__,      ["__iadd__"],    false]
    - ["ab2761mx_ac_mm",  abc.ABC.__dict__.__contains__,          ["__matmul__"],  false]
    - ["ab2761mx_ac_td",  abc.ABC.__dict__.__contains__,          ["__truediv__"], false]
    - ["ab2761mx_ac_ia",  abc.ABC.__dict__.__contains__,          ["__iadd__"],    false]
    - ["ab2761mx_ab_mm",  abc.abstractmethod.__dict__.__contains__, ["__matmul__"],  false]
    - ["ab2761mx_ab_td",  abc.abstractmethod.__dict__.__contains__, ["__truediv__"], false]
    - ["ab2761mx_ab_ia",  abc.abstractmethod.__dict__.__contains__, ["__iadd__"],    false]
