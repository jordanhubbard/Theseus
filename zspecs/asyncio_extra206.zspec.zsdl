spec: asyncio_extra206
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "asyncio.sleep.__defaults__ is (None,) — a 1-tuple; the single default is the 'result' parameter (default None, the value to return when the sleep completes)."
    - "asyncio.gather.__defaults__ is None — gather has no default argument values; all positional *coros_or_futures are required at call time."
    - "asyncio.wait.__defaults__ is None — wait has no default argument values in Python 3.14.3; timeout and return_when are keyword-only with defaults set via __kwdefaults__ not __defaults__."
    - "asyncio.run.__defaults__ is None — run has no positional default argument values; debug and loop_factory are keyword-only."
    - "asyncio.sleep.__defaults__.__class__.__name__ == 'tuple' — __defaults__ is always a tuple when present, holding one entry per default value."
    - "asyncio.sleep.__defaults__.__len__() == 1 — sleep has exactly one default: result=None."
    - "asyncio.gather.__defaults__.__class__.__name__ == 'NoneType' — when a function has no defaults, __defaults__ is None (not an empty tuple)."
    - "asyncio.run.__defaults__.__class__.__name__ == 'NoneType' — asyncio.run has no positional defaults; keyword-only arguments use __kwdefaults__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.sleep __defaults__ shape
#
# asyncio.sleep.__defaults__ == (None,)
# asyncio.sleep.__defaults__.__class__.__name__ == 'tuple'
# asyncio.sleep.__defaults__.__len__() == 1
# asyncio.sleep.__defaults__[0] is None -> class name 'NoneType'
# ---------------------------------------------------------------------------

table asyncio_extra206.sleep_defaults_shape:
  description: "asyncio.sleep __defaults__ shape checks in asynciodefaults206 namespace — sleep.__defaults__ is (None,) (a 1-tuple); the sole default is the 'result' parameter which defaults to None, causing sleep() to return None when awaited; __defaults__.__class__.__name__=='tuple' (all present __defaults__ are tuples); __defaults__.__len__()==1 (exactly one default value); __defaults__[0].__class__.__name__=='NoneType' (the default value itself is None); verified with Python 3.14.3"
  kind: python_call_eq
  category: sleep_defaults
  id_prefix: asynciodefaults206

  columns: [id, function, args, expected, description]
  rows:
    - ["sleep_defaults_is_tuple",    "asyncio.sleep.__defaults__.__class__.__name__.__eq__",              ["tuple"],    true, "asyncio.sleep.__defaults__.__class__.__name__ == 'tuple' — __defaults__ is a tuple when present; verified Python 3.14.3"]
    - ["sleep_defaults_len_1",       "asyncio.sleep.__defaults__.__len__",                                [],           1,    "asyncio.sleep.__defaults__.__len__() == 1 — sleep has exactly one default (result=None); verified Python 3.14.3"]
    - ["sleep_defaults0_is_nonetype","asyncio.sleep.__defaults__.__getitem__(0).__class__.__name__.__eq__",["NoneType"], true, "asyncio.sleep.__defaults__[0].__class__.__name__ == 'NoneType' — the default value for 'result' is None; verified Python 3.14.3"]
    - ["sleep_is_function",          "asyncio.sleep.__class__.__name__.__eq__",                           ["function"], true, "asyncio.sleep.__class__.__name__ == 'function' — sleep is a Python function (coroutine function); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.gather and asyncio.wait __defaults__ (both None)
#
# asyncio.gather.__defaults__ is None -> __class__.__name__ == 'NoneType'
# asyncio.wait.__defaults__ is None -> __class__.__name__ == 'NoneType'
# These functions have no positional default arguments
# ---------------------------------------------------------------------------

table asyncio_extra206.gather_wait_defaults_none:
  description: "asyncio.gather and asyncio.wait __defaults__ checks in asynciodefaults206 namespace — both have __defaults__ == None (NoneType), meaning neither function has positional default arguments; gather takes *coros_or_futures as variadic positional args with no defaults; wait's timeout and return_when are keyword-only (stored in __kwdefaults__); gather.__class__.__name__=='function'; wait.__class__.__name__=='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: gather_wait_defaults
  id_prefix: asynciodefaults206

  columns: [id, function, args, expected, description]
  rows:
    - ["gather_defaults_is_nonetype", "asyncio.gather.__defaults__.__class__.__name__.__eq__", ["NoneType"], true, "asyncio.gather.__defaults__.__class__.__name__ == 'NoneType' — gather has no positional defaults; verified Python 3.14.3"]
    - ["wait_defaults_is_nonetype",   "asyncio.wait.__defaults__.__class__.__name__.__eq__",   ["NoneType"], true, "asyncio.wait.__defaults__.__class__.__name__ == 'NoneType' — wait has no positional defaults; verified Python 3.14.3"]
    - ["gather_is_function",          "asyncio.gather.__class__.__name__.__eq__",               ["function"], true, "asyncio.gather.__class__.__name__ == 'function' — gather is a Python coroutine function; verified Python 3.14.3"]
    - ["wait_is_function",            "asyncio.wait.__class__.__name__.__eq__",                 ["function"], true, "asyncio.wait.__class__.__name__ == 'function' — wait is a Python coroutine function; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.run __defaults__ and function name lengths
#
# asyncio.run.__defaults__ is None -> __class__.__name__ == 'NoneType'
# asyncio.sleep.__name__.__len__() == 5 ('sleep')
# asyncio.gather.__name__.__len__() == 6 ('gather')
# asyncio.run.__name__.__len__() == 3 ('run')
# ---------------------------------------------------------------------------

table asyncio_extra206.run_defaults_and_names:
  description: "asyncio.run __defaults__ and function name length checks in asynciodefaults206 namespace — run.__defaults__ is None (NoneType) because run's 'debug' and 'loop_factory' parameters are keyword-only; name lengths: sleep.__name__.__len__()==5 ('sleep': s-l-e-e-p); gather.__name__.__len__()==6 ('gather': g-a-t-h-e-r); run.__name__.__len__()==3 ('run': r-u-n); verified with Python 3.14.3"
  kind: python_call_eq
  category: run_defaults
  id_prefix: asynciodefaults206

  columns: [id, function, args, expected, description]
  rows:
    - ["run_defaults_is_nonetype",  "asyncio.run.__defaults__.__class__.__name__.__eq__", ["NoneType"], true, "asyncio.run.__defaults__.__class__.__name__ == 'NoneType' — run has no positional defaults; verified Python 3.14.3"]
    - ["sleep_name_len_5",          "asyncio.sleep.__name__.__len__",                     [],           5,    "asyncio.sleep.__name__.__len__() == 5 ('sleep': s-l-e-e-p); verified Python 3.14.3"]
    - ["gather_name_len_6",         "asyncio.gather.__name__.__len__",                    [],           6,    "asyncio.gather.__name__.__len__() == 6 ('gather': g-a-t-h-e-r); verified Python 3.14.3"]
    - ["run_name_len_3",            "asyncio.run.__name__.__len__",                       [],           3,    "asyncio.run.__name__.__len__() == 3 ('run': r-u-n); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra206
# ---------------------------------------------------------------------------

invariant asyncio_extra206.sleep_defaults_is_tuple:
  description: "asyncio.sleep.__defaults__.__class__.__name__.__eq__('tuple') == True — sleep is the only one of the four asyncio functions (sleep, gather, wait, run) that has a non-None __defaults__; the sole default is result=None; __defaults__ is always a tuple when present; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: sleep_defaults
  kind: python_call_eq
  function: asyncio.sleep.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra206.sleep_defaults_len_1:
  description: "asyncio.sleep.__defaults__.__len__() == 1 — sleep has exactly one default parameter value: result=None; sleep(delay, result=None) means delay is required and result has default None; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: sleep_defaults
  kind: python_call_eq
  function: asyncio.sleep.__defaults__.__len__
  args: []
  expected: 1

invariant asyncio_extra206.sleep_defaults0_is_nonetype:
  description: "asyncio.sleep.__defaults__[0].__class__.__name__.__eq__('NoneType') == True — the single default value in sleep's __defaults__ is None itself; when sleep is called as await asyncio.sleep(1) the result parameter defaults to None; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: sleep_defaults
  kind: python_call_eq
  function: "asyncio.sleep.__defaults__.__getitem__(0).__class__.__name__.__eq__"
  args: ["NoneType"]
  expected: true

invariant asyncio_extra206.gather_defaults_is_nonetype:
  description: "asyncio.gather.__defaults__.__class__.__name__.__eq__('NoneType') == True — gather's __defaults__ is None (not an empty tuple); Python sets __defaults__ to None rather than () when a function has no positional defaults; gather takes *coros_or_futures so there is nothing to default; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: gather_wait_defaults
  kind: python_call_eq
  function: asyncio.gather.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant asyncio_extra206.wait_defaults_is_nonetype:
  description: "asyncio.wait.__defaults__.__class__.__name__.__eq__('NoneType') == True — wait's __defaults__ is None; in Python 3.14.3 wait's parameters timeout and return_when are keyword-only (stored in __kwdefaults__), so __defaults__ is None; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: gather_wait_defaults
  kind: python_call_eq
  function: asyncio.wait.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant asyncio_extra206.run_defaults_is_nonetype:
  description: "asyncio.run.__defaults__.__class__.__name__.__eq__('NoneType') == True — run's __defaults__ is None; run's parameters debug and loop_factory are keyword-only, so no positional defaults exist; __defaults__ is None (not ()) when there are no positional defaults; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: run_defaults
  kind: python_call_eq
  function: asyncio.run.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant asyncio_extra206.sleep_is_function:
  description: "asyncio.sleep.__class__.__name__.__eq__('function') == True — sleep is a Python-level async function (coroutine function); its __class__.__name__ is 'function' just like regular functions; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: sleep_defaults
  kind: python_call_eq
  function: asyncio.sleep.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra206.sleep_name_len_5:
  description: "asyncio.sleep.__name__.__len__() == 5 — 'sleep' has 5 characters: s(1)l(2)e(3)e(4)p(5); sleep.__name__.__len__(5) > run.__name__.__len__(3) by 2; sleep.__name__.__len__(5) < gather.__name__.__len__(6) by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: run_defaults
  kind: python_call_eq
  function: asyncio.sleep.__name__.__len__
  args: []
  expected: 5

