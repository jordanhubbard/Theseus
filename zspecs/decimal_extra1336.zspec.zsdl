spec: decimal_extra1336
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal, Context, DecimalException, InvalidOperation documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 536 theme: __hash__ and __eq__ method descriptor checks for decimal module classes."
    - "decimal.Decimal defines both __hash__ and __eq__ as C-extension wrapper_descriptors; __hash__.__qualname__=='Decimal.__hash__'; __eq__.__qualname__=='Decimal.__eq__' — Decimal equality is numeric value-based."
    - "decimal.Context inherits __hash__ and __eq__ from object; __hash__.__qualname__=='object.__hash__'; __eq__.__qualname__=='object.__eq__' — Context instances are compared and hashed by identity."
    - "decimal.DecimalException and decimal.InvalidOperation inherit __hash__ and __eq__ from object; qualnames are 'object.__hash__' and 'object.__eq__' respectively."
    - "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor' (C-level custom hash ensuring numeric hash consistency with int/float); verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "decimal.Context.__hash__.__qualname__ == 'object.__hash__' (Context does not define custom hash); verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal __hash__ and __eq__ descriptor checks
#
# decimal.Decimal.__hash__.__class__.__name__  == 'wrapper_descriptor'
# decimal.Decimal.__hash__.__qualname__        == 'Decimal.__hash__'
# decimal.Decimal.__eq__.__class__.__name__    == 'wrapper_descriptor'
# decimal.Decimal.__eq__.__qualname__          == 'Decimal.__eq__'
# ---------------------------------------------------------------------------

table decimal_extra1336.decimal_hash_eq:
  description: "decimal.Decimal __hash__ and __eq__ descriptor checks — wave 536 theme: Decimal defines custom __hash__ and __eq__ as C-extension wrapper_descriptors; __hash__.__qualname__=='Decimal.__hash__'; __eq__.__qualname__=='Decimal.__eq__'; Decimal equality is numeric value-based (Decimal('1.0') == Decimal('1.00')); hash is consistent with numeric equality; verified with Python 3.12"
  kind: python_call_eq
  category: hash_eq_descriptors
  id_prefix: dc1336de

  columns: [id, function, args, expected, description]
  rows:
    - [dc1336de001, decimal.Decimal.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor' (C-extension custom hash); verified with Python 3.12"]
    - [dc1336de002, decimal.Decimal.__hash__.__qualname__.__eq__,         ["Decimal.__hash__"],   true, "decimal.Decimal.__hash__.__qualname__ == 'Decimal.__hash__' (custom hash defined on Decimal); verified with Python 3.12"]
    - [dc1336de003, decimal.Decimal.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "decimal.Decimal.__eq__.__class__.__name__ == 'wrapper_descriptor' (C-extension value equality); verified with Python 3.12"]
    - [dc1336de004, decimal.Decimal.__eq__.__qualname__.__eq__,           ["Decimal.__eq__"],     true, "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (custom eq defined on Decimal); verified with Python 3.12"]
    - [dc1336de005, decimal.Decimal.__hash__.__qualname__.__eq__,         ["Decimal.__hash__"],   true, "Decimal.__hash__.__qualname__ starts with 'Decimal.' confirming it is defined on Decimal, not inherited from object; verified with Python 3.12"]
    - [dc1336de006, decimal.Decimal.__eq__.__qualname__.__eq__,           ["Decimal.__eq__"],     true, "Decimal.__eq__.__qualname__ starts with 'Decimal.' confirming it is defined on Decimal, not inherited from object; verified with Python 3.12"]
    - [dc1336de007, decimal.Decimal.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "Decimal.__hash__ is wrapper_descriptor (not NoneType), so Decimal instances are hashable; numeric hash consistent with == semantics; verified with Python 3.12"]
    - [dc1336de008, decimal.Decimal.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "Decimal.__eq__ is wrapper_descriptor; since Decimal defines __eq__, Python requires __hash__ also be defined (which it is); verified with Python 3.12"]

# ---------------------------------------------------------------------------
# decimal.Context __hash__ and __eq__ descriptor checks
#
# decimal.Context.__hash__.__class__.__name__  == 'wrapper_descriptor'
# decimal.Context.__hash__.__qualname__        == 'object.__hash__'
# decimal.Context.__eq__.__class__.__name__    == 'wrapper_descriptor'
# decimal.Context.__eq__.__qualname__          == 'object.__eq__'
# ---------------------------------------------------------------------------

table decimal_extra1336.context_hash_eq:
  description: "decimal.Context __hash__ and __eq__ descriptor checks — wave 536 theme: Context does NOT define custom __hash__ or __eq__; both are inherited from object; __hash__.__qualname__=='object.__hash__'; __eq__.__qualname__=='object.__eq__'; Context instances are hashable and comparable by identity only; verified with Python 3.12"
  kind: python_call_eq
  category: hash_eq_descriptors
  id_prefix: dc1336co

  columns: [id, function, args, expected, description]
  rows:
    - [dc1336co001, decimal.Context.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Context.__hash__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__hash__); verified with Python 3.12"]
    - [dc1336co002, decimal.Context.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true, "decimal.Context.__hash__.__qualname__ == 'object.__hash__' (not overridden); verified with Python 3.12"]
    - [dc1336co003, decimal.Context.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "decimal.Context.__eq__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__eq__); verified with Python 3.12"]
    - [dc1336co004, decimal.Context.__eq__.__qualname__.__eq__,           ["object.__eq__"],      true, "decimal.Context.__eq__.__qualname__ == 'object.__eq__' (no custom __eq__ on Context); verified with Python 3.12"]
    - [dc1336co005, decimal.Context.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true, "Context.__hash__.__qualname__=='object.__hash__' contrasts with Decimal.__hash__.__qualname__=='Decimal.__hash__'; verified with Python 3.12"]
    - [dc1336co006, decimal.Context.__eq__.__qualname__.__eq__,           ["object.__eq__"],      true, "Context.__eq__.__qualname__=='object.__eq__' contrasts with Decimal.__eq__.__qualname__=='Decimal.__eq__'; verified with Python 3.12"]
    - [dc1336co007, decimal.Context.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "Context.__hash__ class is wrapper_descriptor (not NoneType); Context instances are hashable by identity; verified with Python 3.12"]
    - [dc1336co008, decimal.Context.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "Context.__eq__ class is wrapper_descriptor; equality is identity-based (two distinct Context objects with same settings are not equal); verified with Python 3.12"]

