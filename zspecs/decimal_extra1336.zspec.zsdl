    - [dc1336ex002, decimal.DecimalException.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true, "decimal.DecimalException.__hash__.__qualname__ == 'object.__hash__' (not overridden); verified with Python 3.12"]
    - [dc1336ex003, decimal.DecimalException.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "decimal.DecimalException.__eq__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__eq__); verified with Python 3.12"]
    - [dc1336ex004, decimal.DecimalException.__eq__.__qualname__.__eq__,           ["object.__eq__"],      true, "decimal.DecimalException.__eq__.__qualname__ == 'object.__eq__' (no custom __eq__); verified with Python 3.12"]
    - [dc1336ex005, decimal.InvalidOperation.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.InvalidOperation.__hash__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__hash__); verified with Python 3.12"]
    - [dc1336ex006, decimal.InvalidOperation.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true, "decimal.InvalidOperation.__hash__.__qualname__ == 'object.__hash__' (not overridden); verified with Python 3.12"]
