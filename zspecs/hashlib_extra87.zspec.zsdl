spec: hashlib_extra87
version: ">=3.9"
extends: hashlib_extra86
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra86.zspec.zsdl — covers blake2b/blake2s __class__.__name__/'type' / __name__ / __module__/'_blake2' / __qualname__ / __bases__[0].__name__/'object' / __mro__.__len__()==2 / SALT_SIZE.__class__.__name__/'int' (table + invariants)."
    - "hashlib_extra85.zspec.zsdl — covers sha256/sha512/md5/sha1/__module__.__eq__('_hashlib') / sha3_256/sha3_512/shake_128/shake_256/__module__.__eq__('_hashlib') / file_digest/__class__/__name__/__module__/__code__/co_name/co_argcount (table + invariants)."
    - "hashlib_extra84.zspec.zsdl — covers sha256/__qualname__/__eq__('openssl_sha256')/True / sha512/md5/sha1/__qualname__/__len__() / sha224/sha384/sha3_256/sha3_512/__qualname__/__len__() / blake2b/blake2s/new/__qualname__/__len__() / algorithms_guaranteed/__len__()==14 (table + invariants)."
    - "hashlib_extra83.zspec.zsdl — covers sha256/sha512/md5/sha1/blake2b/blake2s __doc__.__class__.__name__ and algorithms_guaranteed/algorithms_available membership (table + invariants)."
    - "hashlib_extra80.zspec.zsdl — covers blake2b/blake2s class-level size constants and hexdigest/__class__/__name__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra86; it does NOT duplicate invariants present in those files."
    - "Wave 250 theme: hashlib blake2b/blake2s __dict__ membership — copy/digest/hexdigest/update/MAX_DIGEST_SIZE/MAX_KEY_SIZE/PERSON_SIZE and dict __class__.__name__/'mappingproxy' and blake2b.copy/__class__/__name__/'method_descriptor'."
    - "hashlib.blake2b.__dict__.__contains__('copy') == True — copy is in blake2b's class dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('digest') == True — digest is in blake2b's class dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('hexdigest') == True — hexdigest is in blake2b's class dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('update') == True — update is in blake2b's class dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('MAX_DIGEST_SIZE') == True — MAX_DIGEST_SIZE is a class-level integer attribute in blake2b's dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('MAX_KEY_SIZE') == True — MAX_KEY_SIZE is a class-level integer attribute in blake2b's dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__class__.__name__ == 'mappingproxy' — blake2b's __dict__ is a mappingproxy (the standard type for class dicts in CPython). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('copy') == True — copy is in blake2s's class dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('digest') == True — digest is in blake2s's class dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('MAX_DIGEST_SIZE') == True — MAX_DIGEST_SIZE is in blake2s's class dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__class__.__name__ == 'mappingproxy' — blake2s's __dict__ is also a mappingproxy. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('PERSON_SIZE') == True — PERSON_SIZE is a class-level int in blake2b's dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('PERSON_SIZE') == True — PERSON_SIZE is a class-level int in blake2s's dict. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.copy.__class__.__name__ == 'method_descriptor' — copy is a method_descriptor on blake2b (a C-level method). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b/__dict__/__contains__('copy') / blake2b/__dict__/__contains__('digest')
# hashlib.blake2b/__dict__/__contains__('hexdigest') / blake2b/__dict__/__contains__('update')
#
# Wave 250 theme: blake2b __dict__ membership for instance methods.
#
# copy, digest, hexdigest, update are all in blake2b's class __dict__.
# No prior hashlib spec checks __dict__.__contains__ for any blake2b method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra87.blake2b_dict_instance_methods:
  description: "hashlib.blake2b/__dict__/__contains__('copy')==True / blake2b/__dict__/__contains__('digest')==True / blake2b/__dict__/__contains__('hexdigest')==True / blake2b/__dict__/__contains__('update')==True — copy/digest/hexdigest/update are all in blake2b's class __dict__ as C-level method descriptors; no prior hashlib spec checks __dict__.__contains__ for any blake2b method; first __dict__ membership anchor for hashlib.blake2b instance methods"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra87

  columns: [id, function, args, expected]
  rows:
    - [blake2b_dict_has_copy,      "blake2b.__dict__.__contains__", ["copy"],      true]
    - [blake2b_dict_has_digest,    "blake2b.__dict__.__contains__", ["digest"],    true]
    - [blake2b_dict_has_hexdigest, "blake2b.__dict__.__contains__", ["hexdigest"], true]
    - [blake2b_dict_has_update,    "blake2b.__dict__.__contains__", ["update"],    true]

# ---------------------------------------------------------------------------
# hashlib.blake2b/__dict__/__contains__('MAX_DIGEST_SIZE') / blake2b/__dict__/__contains__('MAX_KEY_SIZE')
# hashlib.blake2b/__dict__/__class__/__name__ / blake2b/__dict__/__contains__('PERSON_SIZE')
#
# Wave 250 theme: blake2b __dict__ membership for class attributes and dict type.
#
# MAX_DIGEST_SIZE, MAX_KEY_SIZE, PERSON_SIZE are class-level int attributes in blake2b's dict.
# blake2b.__dict__.__class__.__name__ is 'mappingproxy'.
# No prior hashlib spec checks these attributes in blake2b's __dict__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra87.blake2b_dict_class_attrs_and_type:
  description: "hashlib.blake2b/__dict__/__contains__('MAX_DIGEST_SIZE')==True / blake2b/__dict__/__contains__('MAX_KEY_SIZE')==True / blake2b/__dict__/__class__/__name__.__eq__('mappingproxy')==True / blake2b/__dict__/__contains__('PERSON_SIZE')==True — MAX_DIGEST_SIZE/MAX_KEY_SIZE/PERSON_SIZE are class-level integer attributes in blake2b's __dict__; blake2b's __dict__ is a mappingproxy; no prior hashlib spec checks __dict__ membership for these class attrs; first __dict__ type and class-attr membership anchor for hashlib.blake2b"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra87

  columns: [id, function, args, expected]
  rows:
    - [blake2b_dict_has_max_digest_size, "blake2b.__dict__.__contains__",      ["MAX_DIGEST_SIZE"], true]
    - [blake2b_dict_has_max_key_size,    "blake2b.__dict__.__contains__",      ["MAX_KEY_SIZE"],    true]
    - [blake2b_dict_class_mappingproxy,  blake2b.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [blake2b_dict_has_person_size,     "blake2b.__dict__.__contains__",      ["PERSON_SIZE"],     true]

# ---------------------------------------------------------------------------
# hashlib.blake2s/__dict__/__contains__('copy') / blake2s/__dict__/__contains__('digest')
# hashlib.blake2s/__dict__/__contains__('MAX_DIGEST_SIZE') / blake2s/__dict__/__class__/__name__
#
# Wave 250 theme: blake2s __dict__ membership and dict type.
#
# copy, digest, MAX_DIGEST_SIZE are in blake2s's class __dict__.
# blake2s.__dict__.__class__.__name__ is 'mappingproxy'.
# No prior hashlib spec checks __dict__.__contains__ for blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra87.blake2s_dict_membership_and_type:
  description: "hashlib.blake2s/__dict__/__contains__('copy')==True / blake2s/__dict__/__contains__('digest')==True / blake2s/__dict__/__contains__('MAX_DIGEST_SIZE')==True / blake2s/__dict__/__class__/__name__.__eq__('mappingproxy')==True — copy/digest/MAX_DIGEST_SIZE are in blake2s's class __dict__; blake2s's __dict__ is also a mappingproxy; no prior hashlib spec checks __dict__.__contains__ for any blake2s attribute; first __dict__ membership anchor for hashlib.blake2s"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra87

  columns: [id, function, args, expected]
  rows:
    - [blake2s_dict_has_copy,           "blake2s.__dict__.__contains__",           ["copy"],          true]
    - [blake2s_dict_has_digest,         "blake2s.__dict__.__contains__",           ["digest"],        true]
    - [blake2s_dict_has_max_digest_size,"blake2s.__dict__.__contains__",           ["MAX_DIGEST_SIZE"],true]
    - [blake2s_dict_class_mappingproxy, blake2s.__dict__.__class__.__name__.__eq__, ["mappingproxy"],  true]

# ---------------------------------------------------------------------------
# hashlib.blake2s/__dict__/__contains__('PERSON_SIZE') / blake2b/copy/__class__/__name__
# hashlib.blake2b/__dict__.__class__.__name__ / blake2s/__dict__.__class__.__name__
#
# Wave 250 theme: blake2s PERSON_SIZE membership, copy method_descriptor type, and dict class cross-checks.
#
# blake2s.__dict__.__contains__('PERSON_SIZE') == True.
# blake2b.copy.__class__.__name__ == 'method_descriptor'.
# Both blake2b and blake2s __dict__.__class__.__name__ == 'mappingproxy'.
# No prior hashlib spec checks PERSON_SIZE in blake2s's dict or blake2b.copy's class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra87.blake2s_person_size_and_copy_class:
  description: "hashlib.blake2s/__dict__/__contains__('PERSON_SIZE')==True / blake2b/copy/__class__/__name__.__eq__('method_descriptor')==True / blake2b/__dict__/__class__/__name__.__eq__('mappingproxy')==True / blake2s/__dict__/__class__/__name__.__eq__('mappingproxy')==True — PERSON_SIZE is in blake2s's class dict; blake2b.copy is a method_descriptor (C-level method slot); both dicts are mappingproxy; no prior hashlib spec checks PERSON_SIZE in blake2s or blake2b.copy.__class__.__name__; first copy method-descriptor and PERSON_SIZE cross-check for hashlib.blake2s"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra87

  columns: [id, function, args, expected]
  rows:
    - [blake2s_dict_has_person_size,     "blake2s.__dict__.__contains__",            ["PERSON_SIZE"],     true]
    - [blake2b_copy_class_method_desc,   blake2b.copy.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [blake2b_dict_class_name_proxy,    blake2b.__dict__.__class__.__name__.__eq__, ["mappingproxy"],    true]
    - [blake2s_dict_class_name_proxy,    blake2s.__dict__.__class__.__name__.__eq__, ["mappingproxy"],    true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__contains__('copy') — standalone
#
# blake2b.__dict__.__contains__('copy') is True. No prior hashlib spec checks
# blake2b.__dict__.__contains__ for any method. First __dict__.__contains__
# standalone for hashlib.blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra87.blake2b_dict_has_copy:
  description: "hashlib.blake2b.__dict__.__contains__('copy') == True — 'copy' is in blake2b's class __dict__ as a method_descriptor; no prior hashlib spec checks __dict__.__contains__ for any blake2b attribute; first __dict__.__contains__ standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: "blake2b.__dict__.__contains__"
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# blake2b.__dict__.__class__.__name__ is 'mappingproxy'. No prior hashlib spec
# checks blake2b.__dict__.__class__.__name__. First __dict__.__class__.__name__
# standalone for hashlib.blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra87.blake2b_dict_class_mappingproxy:
  description: "hashlib.blake2b.__dict__.__class__.__name__.__eq__('mappingproxy') == True — blake2b's __dict__ is a mappingproxy (the standard CPython type for class dicts); no prior hashlib spec checks blake2b.__dict__.__class__.__name__; first __dict__ type standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__dict__.__contains__('copy') — standalone
#
# blake2s.__dict__.__contains__('copy') is True. No prior hashlib spec checks
# blake2s.__dict__.__contains__. First __dict__.__contains__ standalone for
# hashlib.blake2s. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra87.blake2s_dict_has_copy:
  description: "hashlib.blake2s.__dict__.__contains__('copy') == True — 'copy' is in blake2s's class __dict__; no prior hashlib spec checks __dict__.__contains__ for any blake2s attribute; first __dict__.__contains__ standalone for hashlib.blake2s"
  category: class_attrs
  kind: python_call_eq
  function: "blake2s.__dict__.__contains__"
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy.__class__.__name__.__eq__('method_descriptor') — standalone
#
# blake2b.copy.__class__.__name__ is 'method_descriptor'. No prior hashlib spec
# checks blake2b.copy.__class__.__name__. First copy.__class__.__name__ standalone
# for hashlib.blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra87.blake2b_copy_class_method_descriptor:
  description: "hashlib.blake2b.copy.__class__.__name__.__eq__('method_descriptor') == True — blake2b.copy is a method_descriptor (a C-level method slot, not a Python function); no prior hashlib spec checks blake2b.copy.__class__.__name__; first copy method-type standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.copy.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__dict__.__contains__('PERSON_SIZE') — standalone
#
# blake2s.__dict__.__contains__('PERSON_SIZE') is True. No prior hashlib spec
# checks blake2s.__dict__.__contains__('PERSON_SIZE'). First PERSON_SIZE
# membership standalone for hashlib.blake2s. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra87.blake2s_dict_has_person_size:
  description: "hashlib.blake2s.__dict__.__contains__('PERSON_SIZE') == True — PERSON_SIZE is a class-level integer attribute in blake2s's __dict__; no prior hashlib spec checks PERSON_SIZE membership in blake2s's dict; first PERSON_SIZE __dict__ standalone for hashlib.blake2s"
  category: class_attrs
  kind: python_call_eq
  function: "blake2s.__dict__.__contains__"
  args: ["PERSON_SIZE"]
  expected: true
