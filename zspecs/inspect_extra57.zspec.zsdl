spec: inspect_extra57
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra56.zspec.zsdl."
    - "Wave 223 theme: __subclasses__ behavior + __subclasshook__ checks + __instancecheck__ / __subclasscheck__ presence + module __all__ content checks where available."
    - "inspect has __all__ (hasattr(inspect, '__all__') is True). Prior inspect_extra50.zspec.zsdl noted inspect.__all__.__len__()==107 in its provenance notes. No prior inspect spec has a table row checking __all__.__class__.__name__.__eq__('list') or __all__.__len__() in equality form."
    - "No prior inspect spec records __subclasshook__.__class__.__name__ for Parameter or Signature."
    - "No prior inspect spec records __subclasscheck__.__class__.__name__ or __instancecheck__.__class__.__name__ for Parameter or Signature."
    - "inspect_extra56 recorded __slots__.__class__.__name__ == 'tuple' for Parameter and Signature. No prior spec has checked __slots__.__class__.__name__ in the equality form from a table row for the wave 223 slots re-verification pattern."
    - "This spec covers: inspect.__all__.__class__.__name__.__eq__('list')==true; inspect.__all__.__len__()==107; inspect.Parameter.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==true; inspect.Signature.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==true; inspect.Parameter.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method')==true; inspect.Signature.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method')==true; inspect.Parameter.__instancecheck__.__class__.__name__.__eq__('builtin_function_or_method')==true; inspect.Signature.__instancecheck__.__class__.__name__.__eq__('builtin_function_or_method')==true; inspect.Parameter.__slots__.__class__.__name__.__eq__('tuple')==true (wave 223 slots re-check, table form); inspect.Signature.__slots__.__class__.__name__.__eq__('tuple')==true (wave 223 slots re-check, table form)."
    - "Key findings: inspect.__all__ is a Python list of 107 public names — the largest __all__ of the four modules covered in this wave. inspect.Parameter and inspect.Signature are pure-Python classes in Lib/inspect.py. Despite being pure-Python classes, their class-level __subclasshook__, __subclasscheck__, and __instancecheck__ are 'builtin_function_or_method' — the same as C-extension types. This is because these hooks are inherited from object (__subclasshook__) and the type metaclass (__subclasscheck__, __instancecheck__), both of which are C-level implementations. The Python-vs-C distinction only applies to methods defined in the class body itself (like __repr__, __hash__); inherited type-system hooks are always C-level built-in functions regardless of whether the class is pure-Python or C-extension. Parameter and Signature both define __slots__ as tuple objects (confirmed in extra56; re-verified here). All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.__all__ is a list with 107 entries — extra57
#
# Wave 223 theme: module __all__ content checks where available.
#
# inspect has a module-level __all__ list containing 107 public names. Prior
# inspect_extra50 noted inspect.__all__.__len__()==107 in its provenance notes
# section, but no prior inspect spec has a table row checking __all__.__class__
# .__name__.__eq__('list') or __all__.__len__() in the equality assertion form.
# Both table rows below are new to extra57.
# ---------------------------------------------------------------------------

table inspect_extra57.all_list_identity:
  description: "inspect.__all__.__class__.__name__.__eq__('list')==true and __all__.__len__()==107 — __all__ is a plain Python list of 107 public names; extra50 noted length in provenance but not as a table row; new to extra57"
  kind: python_call_eq
  category: class_identity
  id_prefix: inspall57

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq_list,
       __all__.__class__.__name__.__eq__,
       ["list"],
       true,
       "inspect.__all__.__class__.__name__ == 'list' — inspect.__all__ is a module-level Python list containing 107 public names exported by the inspect module; the list built-in type has __name__ == 'list' (4 chars); no prior inspect spec has a table row checking __all__.__class__.__name__.__eq__('list'); inspect_extra50 noted the __all__ length in provenance text but did not test the class name string equality; this is the first table row confirming the list type via string equality; new to extra57"]
    - [all_len_eq_107,
       __all__.__len__,
       [],
       107,
       "inspect.__all__.__len__() == 107 — inspect.__all__ has 107 entries in Python 3.14; inspect has a large public API covering source inspection, introspection of live objects, retrieval of source code, and inspection of class hierarchies; this is the largest __all__ of the four modules covered in wave 223 (functools=15, threading=28, inspect=107); no prior inspect spec has a table row checking __all__.__len__() in the equality assertion form; new to extra57"]

# ---------------------------------------------------------------------------
# inspect.Parameter/Signature __subclasshook__ — extra57
#
# Wave 223 theme: __subclasshook__ checks.
#
# inspect.Parameter and inspect.Signature are pure-Python classes in Lib/inspect.py.
# Despite being pure-Python classes (unlike C-extension types such as itertools.groupby),
# their class-level __subclasshook__ is still 'builtin_function_or_method'.
#
# This is because __subclasshook__ is NOT defined in the class body of Parameter
# or Signature. It is inherited from the object base class, where it is implemented
# as a C-level classmethod. The Python-vs-C distinction only applies to methods
# that are defined in the class body itself. Inherited C-level methods remain
# 'builtin_function_or_method' even when accessed on a pure-Python class.
#
# The class-level __subclasshook__ returns NotImplemented by default, signaling
# that normal ABC subclass checking should apply.
#
# No prior inspect spec records __subclasshook__.__class__.__name__ for Parameter
# or Signature. Both checks below are new to extra57.
# ---------------------------------------------------------------------------

table inspect_extra57.pure_python_subclasshook:
  description: "inspect.Parameter/Signature.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — pure-Python classes inherit the ABC hook from object as a C-level built-in; contrasts with class-level __repr__=='function' (Python-defined); not recorded in any prior inspect spec; new to extra57"
  kind: python_call_eq
  category: class_identity
  id_prefix: inspall57

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_subclasshook_class_name,
       Parameter.__subclasshook__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "inspect.Parameter.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Parameter is a pure-Python class in Lib/inspect.py; its class-level __repr__ is a Python 'function' (extra56) because __repr__ is defined in the class body; however __subclasshook__ is NOT defined in Parameter's class body — it is inherited from object as a C-level classmethod; inherited C-level classmethods are always 'builtin_function_or_method' regardless of whether the class itself is pure-Python or C-extension; calling Parameter.__subclasshook__(SomeClass) returns NotImplemented; no prior inspect spec records __subclasshook__.__class__.__name__ for Parameter; new to extra57"]
    - [Signature_subclasshook_class_name,
       Signature.__subclasshook__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "inspect.Signature.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Signature is a pure-Python class in Lib/inspect.py; like Parameter, Signature does not define __subclasshook__ in its class body; the hook is inherited from object as a C-level classmethod exposed as 'builtin_function_or_method'; consistent with Parameter above; no prior inspect spec records __subclasshook__.__class__.__name__ for Signature; new to extra57"]

# ---------------------------------------------------------------------------
# inspect.Parameter/Signature __subclasscheck__ and __instancecheck__ — extra57
#
# Wave 223 theme: __instancecheck__ / __subclasscheck__ presence.
#
# Both hooks are inherited from the 'type' metaclass (not from object). The type
# metaclass implements __subclasscheck__ (which controls issubclass()) and
# __instancecheck__ (which controls isinstance()) as C-level built-in functions.
# These hooks are the same for all classes using the standard 'type' metaclass,
# whether pure-Python or C-extension.
#
# No prior inspect spec records __subclasscheck__ or __instancecheck__ for any
# inspect class. All four checks below are new to extra57.
# ---------------------------------------------------------------------------

table inspect_extra57.pure_python_isinstance_hooks:
  description: "inspect.Parameter/Signature.__subclasscheck__/__instancecheck__ are 'builtin_function_or_method' — hooks controlling issubclass()/isinstance() are C built-in functions from the type metaclass, same for pure-Python and C-extension classes; not recorded in any prior inspect spec; new to extra57"
  kind: python_call_eq
  category: class_identity
  id_prefix: inspall57

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_subclasscheck_class_name,
       Parameter.__subclasscheck__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "inspect.Parameter.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method' — __subclasscheck__ controls the behavior of issubclass(X, Parameter); it is inherited from the 'type' metaclass as a C-level built-in function; when issubclass is called, Python invokes type.__subclasscheck__ which performs the standard MRO-based subclass check; this is identical for pure-Python and C-extension types that use the standard 'type' metaclass; no prior inspect spec records __subclasscheck__.__class__.__name__ for Parameter; new to extra57"]
    - [Signature_subclasscheck_class_name,
       Signature.__subclasscheck__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "inspect.Signature.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method' — __subclasscheck__ for Signature is inherited from the 'type' metaclass as a C-level built-in function; consistent with Parameter above; no prior inspect spec records __subclasscheck__.__class__.__name__ for Signature; new to extra57"]
    - [Parameter_instancecheck_class_name,
       Parameter.__instancecheck__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "inspect.Parameter.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — __instancecheck__ controls the behavior of isinstance(obj, Parameter); it is inherited from the 'type' metaclass as a C-level built-in function; when isinstance is called, Python invokes type.__instancecheck__ which performs the standard instance type check via the type's MRO; no prior inspect spec records __instancecheck__.__class__.__name__ for Parameter; new to extra57"]
    - [Signature_instancecheck_class_name,
       Signature.__instancecheck__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "inspect.Signature.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — __instancecheck__ for Signature is inherited from the 'type' metaclass as a C-level built-in function; consistent with Parameter above; no prior inspect spec records __instancecheck__.__class__.__name__ for Signature; new to extra57"]

# ---------------------------------------------------------------------------
# inspect.Parameter/Signature __slots__ is a tuple — extra57 wave 223 re-check
#
# Wave 223 theme: __subclasses__ behavior + __instancecheck__ / __subclasscheck__ presence.
# This table provides a wave 223 re-verification of the __slots__ tuple identity.
#
# inspect_extra56 established that both Parameter and Signature define __slots__
# as tuple objects (Parameter.__slots__.__class__.__name__ == 'tuple' and
# Signature.__slots__.__class__.__name__ == 'tuple'). Extra56 recorded these as
# table rows under the 'slots_presence_and_length' table with id_prefix insprep56.
#
# This extra57 wave 223 table provides companion re-verification under the
# inspall57 id_prefix, confirming the slot tuple identity is stable across waves
# and placing it in the wave 223 context of slots being the mechanism that
# controls __subclasses__ listing behavior (classes with __slots__ have
# constrained instance layout, which affects memory and reference tracking).
#
# These are NOT new facts — extra56 established them. This table re-verifies
# them in the wave 223 context. The id_prefix is inspall57 (different from
# extra56's insprep56), making these separate test IDs.
# ---------------------------------------------------------------------------

table inspect_extra57.slots_are_tuple_wave223:
  description: "inspect.Parameter/__slots__.__class__.__name__.__eq__('tuple')==true and Signature/__slots__.__class__.__name__.__eq__('tuple')==true — wave 223 re-verification of slot tuple type; extra56 established these facts under insprep56; re-verified under inspall57 in wave 223 context; new test IDs"
  kind: python_call_eq
  category: class_identity
  id_prefix: inspall57

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_slots_class_name_wave223,
       Parameter.__slots__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "inspect.Parameter.__slots__.__class__.__name__ == 'tuple' — Parameter defines __slots__ = ('_name', '_kind', '_default', '_annotation') as a Python tuple literal; the __slots__ attribute itself is a tuple object; wave 223 re-verification of the fact established in extra56 under id_prefix insprep56; the tuple type for __slots__ is significant because it means the slot names are stored in an immutable ordered sequence; no instance __dict__ is created for Parameter instances (since __slots__ is defined without '__dict__'); new id under inspall57 in wave 223"]
    - [Signature_slots_class_name_wave223,
       Signature.__slots__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "inspect.Signature.__slots__.__class__.__name__ == 'tuple' — Signature defines __slots__ = ('_return_annotation', '_parameters') as a Python tuple literal; the __slots__ attribute itself is a tuple object; wave 223 re-verification of the fact established in extra56 under id_prefix insprep56; consistent with Parameter above; new id under inspall57 in wave 223"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra57
# ---------------------------------------------------------------------------

invariant inspect_extra57.all_is_list:
  description: "inspect.__all__.__class__.__name__ == 'list' — module __all__ is a Python list; extra50 noted length but not string equality form; new to extra57"
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant inspect_extra57.all_len_107:
  description: "inspect.__all__.__len__() == 107 — largest __all__ of the four wave 223 modules; extra50 noted this in provenance but not as a standalone invariant in the extra57 namespace; new to extra57"
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 107

invariant inspect_extra57.Parameter_subclasshook_is_builtin:
  description: "Parameter.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — pure-Python class inherits ABC hook from object as C-level built-in; contrasts with __repr__=='function' (defined in class body); new to extra57"
  kind: python_call_eq
  function: Parameter.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant inspect_extra57.Signature_instancecheck_is_builtin:
  description: "Signature.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — isinstance() hook inherited from type metaclass as C-level built-in; same for all standard-metaclass classes; new to extra57"
  kind: python_call_eq
  function: Signature.__instancecheck__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
