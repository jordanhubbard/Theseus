spec: io_extra156
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.__dict__.__contains__ membership for io module-level names including concrete I/O classes, ABC wrappers, constants, and the open() function."
    - "io.__dict__ is a plain dict (not mappingproxy — module __dict__ attributes are regular dicts, unlike class __dict__ which are mappingproxy). len(io.__dict__) == 37."
    - "All concrete I/O classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper) are present in io.__dict__."
    - "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; the default buffer size used by open() and BufferedReader/BufferedWriter when no explicit buffer_size is given)."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 (the three POSIX seek constants re-exported from io for convenience alongside os.SEEK_*)."
    - "io.open is in io.__dict__ (the open() built-in is re-exported through the io module as well as the builtins module)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__dict__.__contains__ — concrete I/O class membership
# BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, BufferedRandom,
# TextIOWrapper are all True. len(io.__dict__) == 37.
# ---------------------------------------------------------------------------

table io_extra156.dict_contains_concrete_classes:
  description: "io.__dict__.__contains__: concrete I/O classes BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/BufferedRandom/TextIOWrapper are all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodict156

  columns: [id, function, args, expected, description]
  rows:
    - [has_BytesIO,         __dict__.__contains__, ["BytesIO"],         true, "io.__dict__.__contains__('BytesIO') == True (BytesIO is an in-memory binary stream implemented in C; it is exported at the top level of the io module)"]
    - [has_StringIO,        __dict__.__contains__, ["StringIO"],        true, "io.__dict__.__contains__('StringIO') == True (StringIO is an in-memory text stream; like BytesIO but for str rather than bytes)"]
    - [has_FileIO,          __dict__.__contains__, ["FileIO"],          true, "io.__dict__.__contains__('FileIO') == True (FileIO is a raw binary file I/O implementation; it wraps a file descriptor)"]
    - [has_BufferedReader,  __dict__.__contains__, ["BufferedReader"],  true, "io.__dict__.__contains__('BufferedReader') == True (BufferedReader adds read-buffering over a RawIOBase; used by open() in binary read mode)"]
    - [has_BufferedWriter,  __dict__.__contains__, ["BufferedWriter"],  true, "io.__dict__.__contains__('BufferedWriter') == True (BufferedWriter adds write-buffering over a RawIOBase; used by open() in binary write mode)"]
    - [has_BufferedRandom,  __dict__.__contains__, ["BufferedRandom"],  true, "io.__dict__.__contains__('BufferedRandom') == True (BufferedRandom provides buffered read/write access for seekable streams opened in rb+ or wb+ mode)"]
    - [has_TextIOWrapper,   __dict__.__contains__, ["TextIOWrapper"],   true, "io.__dict__.__contains__('TextIOWrapper') == True (TextIOWrapper is the buffered text I/O class wrapping a BufferedIOBase; the default type returned by open() in text mode)"]

# ---------------------------------------------------------------------------
# io.__dict__.__contains__ — ABC wrapper membership
# IOBase, RawIOBase, BufferedIOBase, TextIOBase are all True.
# ---------------------------------------------------------------------------

table io_extra156.dict_contains_abc_classes:
  description: "io.__dict__.__contains__: ABC wrappers IOBase/RawIOBase/BufferedIOBase/TextIOBase are all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodict156

  columns: [id, function, args, expected, description]
  rows:
    - [has_IOBase,         __dict__.__contains__, ["IOBase"],         true, "io.__dict__.__contains__('IOBase') == True (IOBase is the abstract base class of the io hierarchy; all I/O classes inherit from it directly or indirectly)"]
    - [has_RawIOBase,      __dict__.__contains__, ["RawIOBase"],      true, "io.__dict__.__contains__('RawIOBase') == True (RawIOBase is the ABC for raw binary I/O — reading and writing bytes directly without buffering)"]
    - [has_BufferedIOBase, __dict__.__contains__, ["BufferedIOBase"], true, "io.__dict__.__contains__('BufferedIOBase') == True (BufferedIOBase is the ABC for buffered binary I/O; sits between RawIOBase and TextIOBase in the hierarchy)"]
    - [has_TextIOBase,     __dict__.__contains__, ["TextIOBase"],     true, "io.__dict__.__contains__('TextIOBase') == True (TextIOBase is the ABC for text I/O; TextIOWrapper is its concrete implementation)"]

# ---------------------------------------------------------------------------
# io.__dict__.__contains__ — constants and open() membership
# DEFAULT_BUFFER_SIZE, SEEK_SET, SEEK_CUR, SEEK_END, open all True.
# io.__dict__.__len__() == 37.
# io.__dict__.__class__.__name__ == 'dict' (module __dict__ is a plain dict).
# ---------------------------------------------------------------------------

table io_extra156.dict_contains_constants_and_open:
  description: "io.__dict__.__contains__: DEFAULT_BUFFER_SIZE/SEEK_SET/SEEK_CUR/SEEK_END/open are all True; io.__dict__.__len__()==37; __dict__.__class__.__name__=='dict'"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodict156

  columns: [id, function, args, expected, description]
  rows:
    - [has_DEFAULT_BUFFER_SIZE, __dict__.__contains__, ["DEFAULT_BUFFER_SIZE"], true, "io.__dict__.__contains__('DEFAULT_BUFFER_SIZE') == True (DEFAULT_BUFFER_SIZE == 131072, i.e. 128 KiB; used as the default buffer_size argument for open() and BufferedReader/BufferedWriter)"]
    - [has_SEEK_SET,            __dict__.__contains__, ["SEEK_SET"],            true, "io.__dict__.__contains__('SEEK_SET') == True (SEEK_SET == 0; seek relative to the beginning of the stream; re-exported from _io for convenience)"]
    - [has_SEEK_CUR,            __dict__.__contains__, ["SEEK_CUR"],            true, "io.__dict__.__contains__('SEEK_CUR') == True (SEEK_CUR == 1; seek relative to the current stream position)"]
    - [has_SEEK_END,            __dict__.__contains__, ["SEEK_END"],            true, "io.__dict__.__contains__('SEEK_END') == True (SEEK_END == 2; seek relative to the end of the stream; negative offsets move backward from the end)"]
    - [has_open,                __dict__.__contains__, ["open"],                true, "io.__dict__.__contains__('open') == True (io.open is the same object as the open() built-in; the io module re-exports it alongside builtins.open)"]
    - [dict_len,                __dict__.__len__,      [],                      37,   "io.__dict__.__len__() == 37 (the io module exports 37 names at module level; includes all I/O classes, ABCs, constants, and functions)"]
    - [dict_cls_eq,             __dict__.__class__.__name__.__eq__, ["dict"], true,   "io.__dict__.__class__.__name__ == 'dict' (module __dict__ attributes are plain dicts, unlike class __dict__ attributes which are read-only mappingproxy objects)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra156.dict.has_IOBase:
  description: "io.__dict__.__contains__('IOBase') == True — IOBase is the root abstract base class of the entire io hierarchy; it defines the fundamental interface shared by all I/O objects (close, closed, flush, readline, readlines, seek, tell, truncate, writelines, __enter__, __exit__, __iter__, __next__); all concrete io classes inherit from IOBase directly or indirectly"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["IOBase"]
  expected: true

invariant io_extra156.dict.has_TextIOWrapper:
  description: "io.__dict__.__contains__('TextIOWrapper') == True — TextIOWrapper is the concrete text-mode I/O class returned by open() when mode='r' or mode='w' (text mode); it wraps a BufferedIOBase object, handles encoding/decoding, and supports reconfiguration of encoding settings on an already-open stream"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra156.dict.has_DEFAULT_BUFFER_SIZE:
  description: "io.__dict__.__contains__('DEFAULT_BUFFER_SIZE') == True — DEFAULT_BUFFER_SIZE is 131072 (128 KiB); it is the default value of the buffering parameter for open() and for BufferedReader/BufferedWriter when the underlying OS does not report a preferred block size via fstat()"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["DEFAULT_BUFFER_SIZE"]
  expected: true

invariant io_extra156.dict.has_SEEK_END:
  description: "io.__dict__.__contains__('SEEK_END') == True — SEEK_END == 2 is the seek constant for seeking relative to the end of a stream; io re-exports SEEK_SET (0), SEEK_CUR (1), and SEEK_END (2) from _io as convenience aliases alongside os.SEEK_SET/SEEK_CUR/SEEK_END which have the same numeric values"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["SEEK_END"]
  expected: true

invariant io_extra156.dict.len_37:
  description: "io.__dict__.__len__() == 37 — the io module exports 37 names at module level; this includes 4 ABCs (IOBase, RawIOBase, BufferedIOBase, TextIOBase), 7 concrete classes (BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper), 4 constants (DEFAULT_BUFFER_SIZE, SEEK_SET, SEEK_CUR, SEEK_END), the open() function, and standard dunder module attributes"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 37

invariant io_extra156.dict.class_is_plain_dict:
  description: "io.__dict__.__class__.__name__ == 'dict' — module __dict__ objects are plain Python dicts, unlike class __dict__ objects which are mappingproxy (read-only). This means io.__dict__ can be modified at runtime (though doing so is strongly discouraged), whereas io.IOBase.__dict__ cannot be directly assigned to."
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
