spec: pathlib_extra751
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs:
  summary: Verifies __qualname__ attributes of pathlib.Path class-level methods
  tags: [pathlib, qualname, stdlib]

provenance:
  derived_from:
    - https://docs.python.org/3/library/pathlib.html#pathlib.Path
  not_derived_from: []
  notes:
    - Covers Path method qualnames to detect MRO changes or method relocation across PurePath/Path hierarchy
  created_at: "2026-04-12"

table pathlib_extra751.name:
  description: pathlib.Path method __qualname__ equality checks
  kind: python_call_eq
  category: qualname
  id_prefix: pl751xx
  columns: [id, function, args, expected]
  rows:
    - [pl751xx001, pathlib.Path.cwd.__qualname__.__eq__, ["Path.cwd"], true]
    - [pl751xx002, pathlib.Path.home.__qualname__.__eq__, ["Path.home"], true]
    - [pl751xx003, pathlib.Path.absolute.__qualname__.__eq__, ["Path.absolute"], true]
    - [pl751xx004, pathlib.Path.is_dir.__qualname__.__eq__, ["Path.is_dir"], true]
    - [pl751xx005, pathlib.Path.is_file.__qualname__.__eq__, ["Path.is_file"], true]
    - [pl751xx006, pathlib.Path.is_symlink.__qualname__.__eq__, ["Path.is_symlink"], true]
    - [pl751xx007, pathlib.Path.is_mount.__qualname__.__eq__, ["Path.is_mount"], true]
    - [pl751xx008, pathlib.Path.is_absolute.__qualname__.__eq__, ["PurePath.is_absolute"], true]
    - [pl751xx009, pathlib.Path.samefile.__qualname__.__eq__, ["Path.samefile"], true]
    - [pl751xx010, pathlib.Path.lstat.__qualname__.__eq__, ["Path.lstat"], true]
    - [pl751xx011, pathlib.Path.owner.__qualname__.__eq__, ["Path.owner"], true]
    - [pl751xx012, pathlib.Path.group.__qualname__.__eq__, ["Path.group"], true]
