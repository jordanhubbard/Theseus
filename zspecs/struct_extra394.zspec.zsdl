spec: struct_extra394
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__new__.__name__ == '__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__name__ == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__name__ == '__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__new__ is a builtin_function_or_method; __qualname__ is 'Struct.__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__ and __repr__ are wrapper_descriptor objects; __qualname__ is 'Struct.__init__' and 'Struct.__repr__' respectively. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct is a C extension type defined in _struct. Its 'format' and 'size' attributes are getset_descriptor objects — C-level property-like descriptors that implement __get__ and optionally __set__ on C types. They differ from Python property objects. On the class (not an instance), accessing struct.Struct.format returns the descriptor object itself, whose __class__.__name__ is 'getset_descriptor'."
    - "Note: struct.Struct.__new__ is a builtin_function_or_method because it is a C function. __init__ and __repr__ are wrapper_descriptor objects — the C slot wrappers that expose C type slots (tp_init, tp_repr) as Python callables."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct instance attribute descriptor types
#
# Wave 394 theme: struct.Struct C-level attribute and method identity.
#
# struct.Struct is implemented in the _struct C extension. Its per-instance
# attributes 'format' (the format string) and 'size' (the packed byte size)
# are exposed via C-level getset_descriptor objects. When accessed on the
# class rather than an instance, they return the descriptor object itself.
# The descriptor's __class__.__name__ is 'getset_descriptor', distinguishing
# it from a Python property (__class__.__name__ == 'property') or a
# member_descriptor (__class__.__name__ == 'member_descriptor').
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra394.attribute_descriptor_types:
  description: "struct.Struct.format and .size are getset_descriptor objects — C-level descriptors on a C extension type; accessing on the class returns the descriptor; __class__.__name__ is 'getset_descriptor'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdt394

  columns: [id, function, args, expected]
  rows:
    - [format_descriptor, Struct.format.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [size_descriptor,   Struct.size.__class__.__name__.__eq__,   ["getset_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.Struct special method __name__ attributes
#
# struct.Struct.__new__ is a builtin_function_or_method (C function).
# struct.Struct.__init__ and __repr__ are wrapper_descriptor objects that
# wrap C type slots. All three carry the expected bare dunder name in __name__.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra394.special_method_names:
  description: "struct.Struct.__new__, __init__, __repr__ __name__ attributes — C extension type; __new__ is builtin_function_or_method; __init__ and __repr__ are wrapper_descriptor; all carry bare dunder name in __name__; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: structmn394

  columns: [id, function, args, expected]
  rows:
    - [new_name,   Struct.__new__.__name__.__eq__,   ["__new__"],   true]
    - [init_name,  Struct.__init__.__name__.__eq__,  ["__init__"],  true]
    - [repr_name,  Struct.__repr__.__name__.__eq__,  ["__repr__"],  true]
