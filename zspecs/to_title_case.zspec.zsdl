spec: to_title_case
version: ">=1.0.0"
backend: node(to-title-case)

docs: https://www.npmjs.com/package/to-title-case

provenance:
  derived_from:
    - "to-title-case README — https://www.npmjs.com/package/to-title-case"
    - "Test vectors verified with to-title-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "to-title-case source"
  notes:
    - "to-title-case is an npm package. Install: npm install to-title-case"
    - "Capitalizes the first letter of each word in a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_title_case.toTitleCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: titcase

  columns: [id, args, expected]
  rows:
    - [lower,  ["hello world"],  "Hello World"]
    - [three,  ["foo bar baz"],  "Foo Bar Baz"]
    - [single, ["hello"],        "Hello"]
