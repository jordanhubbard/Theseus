spec: uuid_extra100
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ code attributes (co_name, co_argcount) / UUID.__str__/__repr__ qualname equality and length / UUID.__eq__/__hash__/__lt__ qualname equality and length (table + invariants)."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) __class__.__name__, hex values, str() values, version attributes (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant / RFC field property qualname lengths / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ and __name__.__len__()==8 / SafeUUID.__bases__[0].__name__=='Enum' / UUID.hex/bytes/urn/fields/variant/version fget.__qualname__.__len__() (table + invariants)."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / UUID.__setattr__.__class__.__name__=='function' / uuid3/uuid5/getnode __qualname__.__len__() / SafeUUID metaclass/module/MRO depth (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 270 theme: UUID class-level property types for hex/bytes/bytes_le (all 'property') / UUID.int member_descriptor type and qualname / UUID.__slots__ type, length, and contents / UUID.__setattr__ qualname."
    - "type(uuid.UUID.hex).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.bytes).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.bytes_le).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.int).__name__ == 'member_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__qualname__ == 'UUID.int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.UUID.int.__qualname__) == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__objclass__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.__slots__).__name__ == 'tuple'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.UUID.__slots__) == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__[0] == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__[1] == 'is_safe'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__[2] == '__weakref__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__qualname__ == 'UUID.__setattr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.int is a member_descriptor (not a property) because it is declared in __slots__. Slot-based attributes are stored as member_descriptor objects in the class __dict__, not as property objects. UUID.hex/bytes/bytes_le are property objects because they are defined with @property in Lib/uuid.py."
    - "Note: UUID.__slots__ == ('int', 'is_safe', '__weakref__'). Only 3 slots. The 'int' slot stores the raw 128-bit integer; 'is_safe' stores SafeUUID enum; '__weakref__' enables weak references. uuid_extra94 anchors __slots__ type and length; this spec anchors the slot names and the member_descriptor for UUID.int."
    - "Note: UUID.int.__class__.__name__ is 'member_descriptor' (not 'property' or 'getset_descriptor'). This is the C-level type for __slots__-based data members. UUID.is_safe also has type member_descriptor."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# type(uuid.UUID.hex).__name__.__eq__('property')
# type(uuid.UUID.bytes).__name__.__eq__('property')
# type(uuid.UUID.bytes_le).__name__.__eq__('property')
# type(uuid.UUID.int).__name__.__eq__('member_descriptor')
# type(uuid.UUID.variant).__name__.__eq__('property')
#
# Wave 270 theme: UUID class-level descriptor type names for hex/bytes/bytes_le/int/variant.
#
# UUID.hex, UUID.bytes, UUID.bytes_le, and UUID.variant are property objects
# (defined with @property in Lib/uuid.py). UUID.int is a member_descriptor —
# it is declared in __slots__ rather than as a @property. uuid_extra97 anchors
# type(UUID.hex).__name__=='property' at table level; this spec anchors the full
# group of hex/bytes/bytes_le/int/variant descriptor types under uuidprop100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra100.UUID_property_and_member_descriptor_types:
  description: "type(UUID.hex).__name__.__eq__('property')==True / type(UUID.bytes).__name__.__eq__('property')==True / type(UUID.bytes_le).__name__.__eq__('property')==True / type(UUID.int).__name__.__eq__('member_descriptor')==True / type(UUID.variant).__name__.__eq__('property')==True — hex/bytes/bytes_le/variant are @property (defined in uuid.py); UUID.int is member_descriptor (declared in __slots__); extra97 anchors type(UUID.hex).__name__; this spec adds bytes/bytes_le/int/variant; first uuidprop100 anchor"
  kind: python_call_eq
  category: descriptor_types
  id_prefix: uuidprop100

  columns: [id, function, args, expected, description]
  rows:
    - [hex_type_property,     "UUID.hex.__class__.__name__.__eq__",      ["property"],          true, "type(UUID.hex) is 'property' (defined with @property in Lib/uuid.py; returns 32 hex chars)"]
    - [bytes_type_property,   "UUID.bytes.__class__.__name__.__eq__",    ["property"],          true, "type(UUID.bytes) is 'property' (defined with @property; returns 16-byte big-endian bytes)"]
    - [bytes_le_type,         "UUID.bytes_le.__class__.__name__.__eq__", ["property"],          true, "type(UUID.bytes_le) is 'property' (defined with @property; returns 16-byte little-endian bytes)"]
    - [int_type_member_desc,  "UUID.int.__class__.__name__.__eq__",      ["member_descriptor"], true, "type(UUID.int) is 'member_descriptor' (declared in __slots__; not @property; stores raw 128-bit integer)"]
    - [variant_type_property, "UUID.variant.__class__.__name__.__eq__",  ["property"],          true, "type(UUID.variant) is 'property' (defined with @property; returns RFC 4122/NCS/MICROSOFT/RESERVED)"]

# ---------------------------------------------------------------------------
# uuid.UUID.int.__qualname__.__eq__('UUID.int')
# uuid.UUID.int.__qualname__.__len__()==8
# uuid.UUID.int.__objclass__.__name__.__eq__('UUID')
# type(uuid.UUID.__slots__).__name__.__eq__('tuple')
# len(uuid.UUID.__slots__)==3
#
# Wave 270 theme: UUID.int member_descriptor qualname and __slots__ tuple properties.
#
# UUID.int.__qualname__ is 'UUID.int' (8 chars: 'UUID.'=5 + 'int'=3). The
# member_descriptor for the 'int' slot has the same qualname format as a
# method_descriptor ('ClassName.attrname'). UUID.int.__objclass__ is the UUID
# class itself. UUID.__slots__ is a tuple of 3 strings. uuid_extra94 anchors
# __slots__ type and length; this spec anchors UUID.int qualname equality,
# length, and __objclass__ as a grouped table under uuidprop100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra100.UUID_int_descriptor_and_slots_meta:
  description: "UUID.int.__qualname__.__eq__('UUID.int')==True / UUID.int.__qualname__.__len__()==8 / UUID.int.__objclass__.__name__.__eq__('UUID')==True / UUID.__slots__.__class__.__name__.__eq__('tuple')==True / UUID.__slots__.__len__()==3 — UUID.int is member_descriptor with qualname 'UUID.int' (8 chars); __objclass__ is UUID; __slots__ is a 3-element tuple; extra94 anchors slots type and length; this spec anchors UUID.int qualname and __objclass__; first uuidprop100 anchor"
  kind: python_call_eq
  category: descriptor_attributes
  id_prefix: uuidprop100

  columns: [id, function, args, expected, description]
  rows:
    - [int_qualname_eq,       "UUID.int.__qualname__.__eq__",                ["UUID.int"], true, "UUID.int.__qualname__ is 'UUID.int' (8 chars; member_descriptor uses 'ClassName.attrname' format)"]
    - [int_qualname_len,      "UUID.int.__qualname__.__len__",               [],           8,    "UUID.int.__qualname__.__len__() is 8 ('UUID.int' = 'UUID.'5 + 'int'3)"]
    - [int_objclass_name,     "UUID.int.__objclass__.__name__.__eq__",       ["UUID"],     true, "UUID.int.__objclass__.__name__ is 'UUID' (member_descriptor is bound to UUID class)"]
    - [slots_type_tuple,      "UUID.__slots__.__class__.__name__.__eq__",    ["tuple"],    true, "type(UUID.__slots__) is 'tuple' (slots are stored as an immutable tuple of strings)"]
    - [slots_len_3,           "UUID.__slots__.__len__",                      [],           3,    "UUID.__slots__.__len__() is 3 (slots: 'int', 'is_safe', '__weakref__')"]

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__[0].__eq__('int')
# uuid.UUID.__slots__[1].__eq__('is_safe')
# uuid.UUID.__slots__[2].__eq__('__weakref__')
# uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__')
# uuid.UUID.__setattr__.__class__.__name__.__eq__('function')
#
# Wave 270 theme: UUID.__slots__ element names and UUID.__setattr__ qualname.
#
# UUID.__slots__ is ('int', 'is_safe', '__weakref__'). The three slot names
# are 'int' (raw 128-bit integer), 'is_safe' (SafeUUID enum), and '__weakref__'
# (enables weak references to UUID instances). UUID.__setattr__ is a Python-
# level 'function' object defined in Lib/uuid.py to make UUID instances
# immutable (raises TypeError on attribute assignment). Its qualname is
# 'UUID.__setattr__'. uuid_extra94 anchors __setattr__.__class__.__name__==
# 'function'; this spec anchors the slot names and __setattr__ qualname equality.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra100.UUID_slots_names_and_setattr_qualname:
  description: "UUID.__slots__[0].__eq__('int')==True / UUID.__slots__[1].__eq__('is_safe')==True / UUID.__slots__[2].__eq__('__weakref__')==True / UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__')==True / UUID.__setattr__.__class__.__name__.__eq__('function')==True — slots are 'int'/'is_safe'/'__weakref__'; __setattr__ makes UUID immutable (raises TypeError on assignment); extra94 anchors __setattr__.__class__.__name__=='function'; this spec anchors slot names and __setattr__ qualname; first uuidprop100 anchor"
  kind: python_call_eq
  category: class_attributes
  id_prefix: uuidprop100

  columns: [id, function, args, expected, description]
  rows:
    - [slots_0_int,           "UUID.__slots__[0].__eq__",                    ["int"],              true, "UUID.__slots__[0] is 'int' (first slot; stores the raw 128-bit integer UUID value)"]
    - [slots_1_is_safe,       "UUID.__slots__[1].__eq__",                    ["is_safe"],          true, "UUID.__slots__[1] is 'is_safe' (second slot; stores SafeUUID enum for uuid1 multiprocessing safety)"]
    - [slots_2_weakref,       "UUID.__slots__[2].__eq__",                    ["__weakref__"],      true, "UUID.__slots__[2] is '__weakref__' (third slot; enables weak references to UUID instances)"]
    - [setattr_qualname_eq,   "UUID.__setattr__.__qualname__.__eq__",        ["UUID.__setattr__"], true, "UUID.__setattr__.__qualname__ is 'UUID.__setattr__' (Python function making UUID immutable)"]
    - [setattr_class_fn,      "UUID.__setattr__.__class__.__name__.__eq__",  ["function"],         true, "type(UUID.__setattr__) is 'function' (Python-level function; overrides default to prevent mutation)"]

# ---------------------------------------------------------------------------
# type(uuid.UUID.int).__name__.__eq__('member_descriptor') — standalone
#
# type(uuid.UUID.int).__name__ is 'member_descriptor'. UUID.int is declared in
# UUID.__slots__, so Python creates a member_descriptor for it in the class
# __dict__. This is different from @property (which creates a property object)
# and from method_descriptor (which is for C-level methods). The member_descriptor
# provides descriptor protocol access to the slot storage. uuid_extra94 anchors
# UUID.__slots__ type and length but does not anchor type(UUID.int).__name__
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra100.UUID_int_is_member_descriptor:
  description: "type(uuid.UUID.int).__name__.__eq__('member_descriptor') == True — UUID.int is a member_descriptor because 'int' is declared in __slots__; differs from @property (hex/bytes/etc.) and method_descriptor (C methods); member_descriptor provides descriptor protocol access to slot storage; extra94 anchors __slots__ type and length but not UUID.int type; first standalone under uuidprop100"
  category: descriptor_types
  kind: python_call_eq
  function: "UUID.int.__class__.__name__.__eq__"
  args: ["member_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.int.__qualname__.__eq__('UUID.int') — standalone
#
# uuid.UUID.int.__qualname__ is 'UUID.int' (8 chars). The member_descriptor
# for the 'int' slot uses the same 'ClassName.attrname' qualname format as
# method_descriptor objects. 'UUID.int' has 8 chars: 'UUID.' (5) + 'int' (3).
# This is the shortest qualname among UUID class-level descriptors (e.g.,
# 'UUID.hex' is 8 chars too — same length, since 'hex' is also 3 chars).
# No prior uuid spec anchors UUID.int.__qualname__ equality as a standalone
# under uuidprop100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra100.UUID_int_qualname_eq:
  description: "uuid.UUID.int.__qualname__.__eq__('UUID.int') == True — member_descriptor uses 'ClassName.attrname' format like method_descriptor; 'UUID.int' is 8 chars ('UUID.'5 + 'int'3); 'int' slot stores the raw 128-bit UUID integer value; no prior uuid spec anchors UUID.int qualname as standalone; first standalone under uuidprop100"
  category: descriptor_attributes
  kind: python_call_eq
  function: "UUID.int.__qualname__.__eq__"
  args: ["UUID.int"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__[0].__eq__('int') — standalone
#
# uuid.UUID.__slots__[0] is 'int'. The first element of the __slots__ tuple
# is 'int' — the name of the attribute that stores the raw 128-bit integer
# representation of the UUID. Naming a slot 'int' shadows the Python built-in
# 'int' type within UUID instances, which is why UUID.__setattr__ raises
# TypeError (preventing external code from overwriting the core state). The
# 'int' attribute is the single source of truth for the UUID value; all other
# attributes (hex, bytes, fields, etc.) are computed from it via @property.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra100.UUID_slots_first_is_int:
  description: "uuid.UUID.__slots__[0].__eq__('int') == True — first slot is 'int' (raw 128-bit integer; single source of truth for UUID value); all other attributes computed via @property from this slot; naming slot 'int' shadows the built-in within UUID; __setattr__ prevents mutation; no prior uuid spec anchors __slots__[0] equality as standalone; first standalone under uuidprop100"
  category: class_attributes
  kind: python_call_eq
  function: "UUID.__slots__[0].__eq__"
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__len__()==3 — standalone
#
# uuid.UUID.__slots__.__len__() is 3. UUID has exactly 3 slots: 'int',
# 'is_safe', and '__weakref__'. The minimal slot count reflects UUID's
# immutable design — only the raw integer value ('int') and safety flag
# ('is_safe') are stored; all other UUID representations are computed
# properties. uuid_extra94 anchors len(UUID.__slots__)==3 via a table row;
# this spec anchors it as a standalone under uuidprop100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra100.UUID_slots_len_3:
  description: "uuid.UUID.__slots__.__len__() == 3 — UUID has exactly 3 slots: 'int', 'is_safe', '__weakref__'; minimal slot design reflects UUID's immutable nature; all other UUID attributes are @property computed from 'int'; extra94 anchors __slots__ length via table row; first standalone under uuidprop100"
  category: class_attributes
  kind: python_call_eq
  function: "UUID.__slots__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') — standalone
#
# uuid.UUID.__setattr__.__qualname__ is 'UUID.__setattr__'. UUID overrides
# __setattr__ to make instances immutable — any attempt to set an attribute
# on a UUID instance raises TypeError. The qualname 'UUID.__setattr__' (17
# chars: 'UUID.'=5 + '__setattr__'=12) follows the standard 'ClassName.method'
# format for Python-level methods. uuid_extra94 anchors
# UUID.__setattr__.__class__.__name__=='function'; this spec anchors the
# qualname equality as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra100.UUID_setattr_qualname_eq:
  description: "uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') == True — qualname is 'UUID.__setattr__' (17 chars = 'UUID.'5 + '__setattr__'12); UUID overrides __setattr__ to make instances immutable (raises TypeError on any attr assignment); Python-level function (type is 'function'); extra94 anchors __setattr__.__class__.__name__=='function' but not qualname; first standalone under uuidprop100"
  category: class_attributes
  kind: python_call_eq
  function: "UUID.__setattr__.__qualname__.__eq__"
  args: ["UUID.__setattr__"]
  expected: true

