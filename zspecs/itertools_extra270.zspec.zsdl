spec: itertools_extra270
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools is a C built-in module; its __spec__.origin == 'built-in' (len=8) and __spec__.submodule_search_locations is None."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' (len=10); itertools.__loader__.__class__.__name__ == 'type' — BuiltinImporter is the class itself."
    - "itertools.__package__ == '' (empty string); type(itertools.__package__).__name__ == 'str'."
    - "itertools.__spec__.name == 'itertools' (len=9); functools.__spec__.name == 'functools' (len=9) — same length."
    - "functools.__spec__.origin is a filesystem path (str) ending in 'functools.py' — not 'built-in'."
    - "type(functools.__spec__.origin).__name__ == 'str'; type(itertools.__spec__.origin).__name__ == 'str'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools module __spec__ and __loader__ metadata
#
# itertools is a C built-in module: __spec__.origin == 'built-in'(8),
#   __spec__.submodule_search_locations is None,
#   __loader__.__class__.__name__ == 'type' (BuiltinImporter is the class itself).
# __package__ == '' (empty str); __spec__.__class__.__name__ == 'ModuleSpec'.
# ---------------------------------------------------------------------------

table itertools_extra270.itertools_module_spec:
  description: "itertools C built-in module metadata — __spec__.name='itertools'(9), origin='built-in'(8), submodule_search_locations=None, __loader__ class is 'type', __package__='' empty str, __spec__ class is 'ModuleSpec'(10); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex270ms

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,         __spec__.name.__eq__,                        ["itertools"],                  true, "itertools.__spec__.name == 'itertools' (len=9); verified with Python 3.14.3"]
    - [spec_name_len,        __spec__.name.__len__,                       [],                             9,    "itertools.__spec__.name.__len__() == 9; verified with Python 3.14.3"]
    - [spec_cls_eq,          __spec__.__class__.__name__.__eq__,          ["ModuleSpec"],                 true, "itertools.__spec__.__class__.__name__ == 'ModuleSpec' (len=10); verified with Python 3.14.3"]
    - [spec_cls_len,         __spec__.__class__.__name__.__len__,         [],                             10,   "itertools.__spec__.__class__.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [spec_origin_eq,       __spec__.origin.__eq__,                      ["built-in"],                   true, "itertools.__spec__.origin == 'built-in' (len=8) — C built-in module; verified with Python 3.14.3"]
    - [spec_origin_len,      __spec__.origin.__len__,                     [],                             8,    "itertools.__spec__.origin.__len__() == 8 — 'built-in' has 8 chars; verified with Python 3.14.3"]
    - [spec_origin_cls_eq,   __spec__.origin.__class__.__name__.__eq__,   ["str"],                        true, "type(itertools.__spec__.origin).__name__ == 'str'; verified with Python 3.14.3"]
    - [ldr_cls_eq,           __loader__.__class__.__name__.__eq__,        ["type"],                       true, "itertools.__loader__.__class__.__name__ == 'type' — BuiltinImporter is itself the class; verified with Python 3.14.3"]
    - [pkg_eq,               __package__.__eq__,                          [""],                           true, "itertools.__package__ == '' (empty string); verified with Python 3.14.3"]
    - [pkg_len,              __package__.__len__,                         [],                             0,    "itertools.__package__.__len__() == 0 — empty string package; verified with Python 3.14.3"]
    - [pkg_cls_eq,           __package__.__class__.__name__.__eq__,       ["str"],                        true, "type(itertools.__package__).__name__ == 'str'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools module __spec__ metadata (loaded via itertools backend context)
#
# functools is a pure-Python module: __spec__.origin is a filesystem path str.
# __spec__.name == 'functools' (len=9) — same length as 'itertools' (9).
# ---------------------------------------------------------------------------

table itertools_extra270.functools_module_spec:
  description: "functools pure-Python module __spec__ metadata — __spec__.name='functools'(9 same as itertools), origin is filesystem path str (not 'built-in'), __spec__ class is 'ModuleSpec'(10); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex270fms

  columns: [id, function, args, expected, description]
  rows:
    - [ft_spec_name_eq,      functools.__spec__.name.__eq__,              ["functools"],                  true, "functools.__spec__.name == 'functools' (len=9 — same as itertools); verified with Python 3.14.3"]
    - [ft_spec_name_len,     functools.__spec__.name.__len__,             [],                             9,    "functools.__spec__.name.__len__() == 9; verified with Python 3.14.3"]
    - [ft_spec_cls_eq,       functools.__spec__.__class__.__name__.__eq__, ["ModuleSpec"],                true, "functools.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [ft_origin_cls_eq,     functools.__spec__.origin.__class__.__name__.__eq__, ["str"],               true, "type(functools.__spec__.origin).__name__ == 'str' — origin is a filesystem path; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra270
# ---------------------------------------------------------------------------

invariant itertools_extra270.itertools_spec_name_is_itertools:
  description: "itertools.__spec__.name == 'itertools' (len=9) — module spec name matches module name"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra270.itertools_spec_origin_is_builtin:
  description: "itertools.__spec__.origin == 'built-in' — itertools is a C built-in module, not a filesystem module"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["built-in"]
  expected: true

invariant itertools_extra270.itertools_spec_class_is_modulespec:
  description: "itertools.__spec__.__class__.__name__ == 'ModuleSpec' (len=10) — the module spec is an importlib.machinery.ModuleSpec"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra270.itertools_loader_class_is_type:
  description: "itertools.__loader__.__class__.__name__ == 'type' — BuiltinImporter is a metaclass-level object, its __class__.__name__ is 'type'"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra270.itertools_package_is_empty_string:
  description: "itertools.__package__ == '' (empty string, len=0) — built-in modules have an empty package string"
  category: identity
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0

invariant itertools_extra270.functools_spec_name_same_len_as_itertools:
  description: "functools.__spec__.name.__len__() == 9 — 'functools' and 'itertools' both have 9-character module names"
  category: identity
  kind: python_call_eq
  function: functools.__spec__.name.__len__
  args: []
  expected: 9
