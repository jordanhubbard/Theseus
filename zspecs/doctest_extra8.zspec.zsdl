spec: doctest_extra8
version: ">=3.9"
backend: python_module(doctest)

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/doctest.html — Python doctest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/doctest.py"
    - "doctest_extra7.zspec.zsdl — covers remaining flag numeric values; Example/__qualname__; TestResults/__qualname__; UnexpectedException/__bases__[0].__name__; DocTestFailure/__bases__[0].__name__"
    - "doctest_extra6.zspec.zsdl — covers flag __class__.__name__ == 'int' checks via __eq__; class __name__ identity via __eq__"
    - "doctest_extra5.zspec.zsdl — covers OutputChecker/DebugRunner/DocTestCase/register_optionflag __qualname__; BLANKLINE_MARKER/ELLIPSIS_MARKER type and value"
    - "doctest_extra4.zspec.zsdl — covers class_qualnames table (DocTest/DocTestFinder/DocTestRunner/DocTestSuite/DocTestParser/Example/DocTestFailure/UnexpectedException); function_qualnames table (testmod/testfile/run_docstring_examples)"
  notes:
    - "This spec extends doctest_extra7.zspec.zsdl."
    - "Focus: standalone __qualname__ invariants for DocTest/DocTestRunner/DocTestFinder/DocTestParser/testmod/testfile/run_docstring_examples (all previously in extra4 tables but not as standalones); ELLIPSIS.__class__.__name__ == 'int' as a standalone invariant (extra6 covers it via __eq__ form as part of a larger set)."
    - "doctest.ELLIPSIS == 8 — the ELLIPSIS flag constant numeric value."
    - "doctest.ELLIPSIS.__class__.__name__ == 'int' — ELLIPSIS is an integer flag."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ standalone invariants
#
# doctest_extra4 covers __qualname__ for all major classes in a table.
# These standalone invariants re-anchor DocTest/DocTestRunner/DocTestFinder/
# DocTestParser under the extra8 namespace for independent direct coverage.
# ---------------------------------------------------------------------------

invariant doctest_extra8.DocTest.qualname:
  description: "doctest.DocTest.__qualname__ == 'DocTest' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: DocTest.__qualname__.__eq__
  args: ["DocTest"]
  expected: true

invariant doctest_extra8.DocTestRunner.qualname:
  description: "doctest.DocTestRunner.__qualname__ == 'DocTestRunner' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: DocTestRunner.__qualname__.__eq__
  args: ["DocTestRunner"]
  expected: true

invariant doctest_extra8.DocTestFinder.qualname:
  description: "doctest.DocTestFinder.__qualname__ == 'DocTestFinder' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: DocTestFinder.__qualname__.__eq__
  args: ["DocTestFinder"]
  expected: true

invariant doctest_extra8.DocTestParser.qualname:
  description: "doctest.DocTestParser.__qualname__ == 'DocTestParser' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: DocTestParser.__qualname__.__eq__
  args: ["DocTestParser"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ standalone invariants
#
# doctest_extra4 covers __qualname__ for testmod/testfile/run_docstring_examples
# in a table. These standalone invariants re-anchor them under the extra8
# namespace for independent direct coverage.
# ---------------------------------------------------------------------------

invariant doctest_extra8.testmod.qualname:
  description: "doctest.testmod.__qualname__ == 'testmod' — module-level function qualname"
  category: function_attrs
  kind: python_call_eq
  function: testmod.__qualname__.__eq__
  args: ["testmod"]
  expected: true

invariant doctest_extra8.testfile.qualname:
  description: "doctest.testfile.__qualname__ == 'testfile' — module-level function qualname"
  category: function_attrs
  kind: python_call_eq
  function: testfile.__qualname__.__eq__
  args: ["testfile"]
  expected: true

invariant doctest_extra8.run_docstring_examples.qualname:
  description: "doctest.run_docstring_examples.__qualname__ == 'run_docstring_examples' — module-level function qualname"
  category: function_attrs
  kind: python_call_eq
  function: run_docstring_examples.__qualname__.__eq__
  args: ["run_docstring_examples"]
  expected: true

# ---------------------------------------------------------------------------
# ELLIPSIS flag constant — class name and value
#
# doctest_extra6 covers ELLIPSIS.__class__.__name__.__eq__('int') as part of a
# flag-constants table. This spec adds a standalone invariant under the extra8
# namespace, and anchors the numeric value (8) as a separate invariant.
# doctest_extra2 covers ELLIPSIS==8 via the table; this re-anchors it standalone.
# ---------------------------------------------------------------------------

invariant doctest_extra8.ELLIPSIS.class_name:
  description: "doctest.ELLIPSIS.__class__.__name__ == 'int' — ELLIPSIS is an integer flag constant"
  category: flag_attrs
  kind: python_call_eq
  function: ELLIPSIS.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant doctest_extra8.ELLIPSIS.value:
  description: "doctest.ELLIPSIS == 8 — numeric value of the ELLIPSIS option flag"
  category: flag_attrs
  kind: python_call_eq
  function: ELLIPSIS.__eq__
  args: [8]
  expected: true
