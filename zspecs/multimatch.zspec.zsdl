spec: multimatch
version: ">=8.0.0"
backend: node(multimatch)

docs: https://www.npmjs.com/package/multimatch

provenance:
  derived_from:
    - "multimatch README — https://www.npmjs.com/package/multimatch"
    - "Test vectors verified with multimatch via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "multimatch source"
  notes:
    - "multimatch is an npm package. Install: npm install multimatch"
    - "Filters a list of strings by one or more glob patterns. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of matched strings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table multimatch.multimatch:
  kind: node_module_call_eq
  function: "default"
  category: filter
  id_prefix: mmatch

  columns: [id, args, expected]
  rows:
    - [all_js,    [["a.js", "b.js", "c.js"], ["*.js"]],   ["a.js", "b.js", "c.js"]]
    - [some_js,   [["a.js", "b.ts", "c.js"], ["*.js"]],   ["a.js", "c.js"]]
    - [exact,     [["foo", "bar"], ["foo"]],               ["foo"]]
