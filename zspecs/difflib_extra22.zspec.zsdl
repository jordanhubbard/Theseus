spec: difflib_extra22
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib_extra21.zspec.zsdl."
    - "Prior specs covered: SequenceMatcher/Differ/HtmlDiff __name__/__module__/__qualname__/__bases__[0].__name__, unified_diff/context_diff/ndiff/get_close_matches/diff_bytes __name__/__module__/__qualname__, SequenceMatcher/Differ/HtmlDiff __init__.__name__, various __qualname__ checks."
    - "This spec covers: difflib.SequenceMatcher.__module__.__len__(), difflib.Differ.__module__.__len__(), difflib.HtmlDiff.__module__.__len__(), difflib.SequenceMatcher.__name__.__len__(), difflib.Differ.__name__.__len__(), difflib.HtmlDiff.__name__.__len__(), difflib.unified_diff.__module__.__len__(), difflib.context_diff.__module__.__len__(), difflib.ndiff.__module__.__len__(), difflib.get_close_matches.__module__.__len__(), difflib.unified_diff.__name__.__len__(), difflib.context_diff.__name__.__len__()."
    - "difflib.SequenceMatcher.__module__ == 'difflib' — length 7. Verified at runtime."
    - "difflib.Differ.__module__ == 'difflib' — length 7. Verified at runtime."
    - "difflib.HtmlDiff.__module__ == 'difflib' — length 7. Verified at runtime."
    - "difflib.SequenceMatcher.__name__ == 'SequenceMatcher' — length 15. Verified at runtime."
    - "difflib.Differ.__name__ == 'Differ' — length 6. Verified at runtime."
    - "difflib.HtmlDiff.__name__ == 'HtmlDiff' — length 8. Verified at runtime."
    - "difflib.unified_diff.__module__ == 'difflib' — length 7. Verified at runtime."
    - "difflib.context_diff.__module__ == 'difflib' — length 7. Verified at runtime."
    - "difflib.ndiff.__module__ == 'difflib' — length 7. Verified at runtime."
    - "difflib.get_close_matches.__module__ == 'difflib' — length 7. Verified at runtime."
    - "difflib.unified_diff.__name__ == 'unified_diff' — length 12. Verified at runtime."
    - "difflib.context_diff.__name__ == 'context_diff' — length 12. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher.__module__ — __len__()
#
# Prior specs verify SequenceMatcher.__module__ == 'difflib'. No prior spec
# verifies the length of SequenceMatcher.__module__ as a standalone invariant.
# len('difflib') == 7. Verified at runtime: 7.
# ---------------------------------------------------------------------------

invariant difflib_extra22.SequenceMatcher.module_len:
  description: "len(difflib.SequenceMatcher.__module__) == 7 — 'difflib' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# difflib.Differ.__module__ — __len__()
#
