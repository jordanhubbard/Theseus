spec: re_extra278
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.match(), re.fullmatch(), and re.search() all return re.Match instances; __class__.__name__ == 'Match'."
    - "re.Match.__module__ == 're' and __class__.__name__ == 'type' — Match is a plain class."
    - "Match.group(0) returns the entire match; groups are 1-indexed."
    - "re.fullmatch() requires the entire string to match the pattern; partial strings return None."
    - "re.search() finds the first occurrence anywhere in the string."
    - "re.match(), re.search(), re.fullmatch() are all Python functions (not C builtins); __class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match class identity — __name__, __module__, __class__.__name__
# ---------------------------------------------------------------------------

table re_extra278.match_class_identity:
  description: "re.Match __name__, __module__, and metaclass identity"
  kind: python_call_eq
  category: identity
  id_prefix: mci

  columns: [id, function, args, expected, description]
  rows:
    - [match_name,   Match.__name__.__eq__,                ["Match"],    true, "re.Match.__name__ == 'Match'"]
    - [match_module, Match.__module__.__eq__,              ["re"],       true, "re.Match.__module__ == 're'"]
    - [match_meta,   Match.__class__.__name__.__eq__,      ["type"],     true, "re.Match.__class__.__name__ == 'type' — plain class object"]
    - [match_base,   "Match.__bases__[0].__name__.__eq__", ["object"],   true, "re.Match.__bases__[0].__name__ == 'object' — Match is a direct subclass of object"]

# ---------------------------------------------------------------------------
# Match.group(0) — full match string from match/fullmatch/search
# ---------------------------------------------------------------------------

table re_extra278.match_group0:
  description: "group(0) returns the full match for re.match(), re.fullmatch(), and re.search()"
  kind: python_call_eq
  category: match_result
  id_prefix: mg0
  function: match
  method: group
  method_args: [0]

  columns: [id, args, expected, description]
  rows:
    - [simple_x,    ["x",     "x"    ],   "x",     "re.match('x','x').group(0) == 'x'"]
    - [word_hello,  ["hello", "hello"],   "hello", "re.match('hello','hello').group(0) == 'hello'"]
    - [digits,      ["\\d+",  "42abc"],   "42",    "re.match('\\d+','42abc').group(0) == '42' — anchored at start"]

# ---------------------------------------------------------------------------
# re.fullmatch — group(0) is the entire string
# ---------------------------------------------------------------------------

invariant re_extra278.fullmatch.digits_group0:
  description: "re.fullmatch('\\d+','42').group(0) == '42' — fullmatch anchors both start and end"
  category: match_result
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "42"]
  method: group
  method_args: [0]
  expected: "42"

invariant re_extra278.fullmatch.word_group0:
  description: "re.fullmatch('\\w+','abc').group(0) == 'abc' — entire string is the match"
  category: match_result
  kind: python_call_eq
  function: fullmatch
  args: ["\\w+", "abc"]
  method: group
  method_args: [0]
  expected: "abc"

# ---------------------------------------------------------------------------
# re.search — finds first occurrence anywhere in the string
# ---------------------------------------------------------------------------

invariant re_extra278.search.middle_char:
  description: "re.search('y','xyz').group(0) == 'y' — search finds the match in the middle"
  category: match_result
  kind: python_call_eq
  function: search
  args: ["y", "xyz"]
  method: group
  method_args: [0]
  expected: "y"

invariant re_extra278.search.digits_in_text:
  description: "re.search('\\d+','abc123def').group(0) == '123' — first digit run in a mixed string"
  category: match_result
  kind: python_call_eq
  function: search
  args: ["\\d+", "abc123def"]
  method: group
  method_args: [0]
  expected: "123"

# ---------------------------------------------------------------------------
# Match result class name from live match object
# ---------------------------------------------------------------------------

invariant re_extra278.match.result_class_name:
  description: "re.match('x','x').__class__.__name__ == 'Match' — result is a Match instance"
  category: identity
  kind: python_call_eq
  function: match
  args: ["x", "x"]
  method: __class__.__name__
  expected: "Match"

invariant re_extra278.match.result_class_module:
  description: "re.match('x','x').__class__.__module__ == 're' — Match is in the 're' module"
  category: identity
  kind: python_call_eq
  function: match
  args: ["x", "x"]
  method: __class__.__module__
  expected: "re"
