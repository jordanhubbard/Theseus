spec: sndhdr_extra2
version: ">=3.9,<3.13"
backend: python_module(sndhdr)

docs: https://docs.python.org/3/library/sndhdr.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sndhdr.html — Python sndhdr documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sndhdr.py"
  notes:
    - "This spec extends sndhdr.zspec.zsdl and sndhdr_extra.zspec.zsdl."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# what() and whathdr() — __qualname__ (not covered in prior specs)
# ---------------------------------------------------------------------------

invariant sndhdr_extra2.what.qualname:
  description: "sndhdr.what.__qualname__ == 'what'"
  category: functions
  kind: python_call_eq
  function: what.__qualname__.__eq__
  args: ["what"]
  expected: true

invariant sndhdr_extra2.whathdr.qualname:
  description: "sndhdr.whathdr.__qualname__ == 'whathdr'"
  category: functions
  kind: python_call_eq
  function: whathdr.__qualname__.__eq__
  args: ["whathdr"]
  expected: true

# ---------------------------------------------------------------------------
# SndHeaders namedtuple — module, qualname, and is-a-type checks
# (sndhdr.zspec.zsdl covers __name__ and all 5 _fields;
#  these are new: __module__, __qualname__, is_type, _fields.__len__)
# ---------------------------------------------------------------------------

invariant sndhdr_extra2.SndHeaders.module:
  description: "sndhdr.SndHeaders.__module__ == 'sndhdr'"
  category: classnames
  kind: python_call_eq
  function: SndHeaders.__module__.__eq__
  args: ["sndhdr"]
  expected: true

invariant sndhdr_extra2.SndHeaders.qualname:
  description: "sndhdr.SndHeaders.__qualname__ == 'SndHeaders'"
  category: classnames
  kind: python_call_eq
  function: SndHeaders.__qualname__.__eq__
  args: ["SndHeaders"]
  expected: true

invariant sndhdr_extra2.SndHeaders.is_type:
  description: "sndhdr.SndHeaders.__class__.__name__ == 'type' — SndHeaders is a class object"
  category: classnames
  kind: python_call_eq
  function: SndHeaders.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant sndhdr_extra2.SndHeaders.fields_len:
  description: "len(sndhdr.SndHeaders._fields) == 5 — namedtuple has exactly 5 fields"
  category: classnames
  kind: python_call_eq
  function: SndHeaders._fields.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Table: qualname checks for what and whathdr in one place
# ---------------------------------------------------------------------------

table sndhdr_extra2.function_qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [what,    what.__qualname__.__eq__,    ["what"],    true, "sndhdr.what.__qualname__ == 'what'"]
    - [whathdr, whathdr.__qualname__.__eq__, ["whathdr"], true, "sndhdr.whathdr.__qualname__ == 'whathdr'"]
