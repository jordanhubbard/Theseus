{
  "schema_version": "0.1",
  "identity": {
    "canonical_name": "curl",
    "spec_for_versions": ">=7.0.0",
    "api_header": "",
    "public_docs_url": "https://curl.se/docs/manpage.html",
    "rfc_references": [
      {
        "rfc": "RFC 7230",
        "title": "HTTP/1.1 Message Syntax and Routing"
      },
      {
        "rfc": "RFC 3986",
        "title": "Uniform Resource Identifier (URI): Generic Syntax"
      }
    ]
  },
  "provenance": {
    "derived_from": [
      "curl man page — https://curl.se/docs/manpage.html",
      "curl --help output",
      "curl exit code reference — https://curl.se/docs/manpage.html#EXIT_CODES",
      "Test vectors verified with curl 8.13.0 on macOS/Darwin 25.3.0, 2026-03-31"
    ],
    "not_derived_from": [
      "curl source: lib/transfer.c, lib/url.c"
    ],
    "notes": [
      "All invariants in this spec are offline-safe: they use --version, --help, file://, or connect to localhost on a port that is guaranteed to refuse connections. No external network access is required.",
      "Exit code 1 = unsupported protocol; exit code 7 = connection refused / failed to connect.",
      "file:// protocol is supported on all major platforms (macOS, Linux, FreeBSD).",
      "The stdin_b64 trick is not used here; curl reads from URLs, not stdin by default.",
      "version_string invariants test that key substrings appear in 'curl --version' stdout. The exact version number is intentionally not tested so the spec works across versions."
    ],
    "created_at": "2026-03-31T00:00:00Z",
    "spec_authors": [
      "Theseus Z-layer"
    ]
  },
  "library": {
    "backend": "cli",
    "command": "curl",
    "soname_patterns": []
  },
  "constants": {},
  "types": {},
  "wire_formats": {},
  "functions": {},
  "invariants": [
    {
      "id": "curl.version.exits_0",
      "kind": "cli_exits_with",
      "description": "--version exits with code 0",
      "category": "health",
      "spec": {
        "args": [
          "--version"
        ],
        "expected_exit": 0
      }
    },
    {
      "id": "curl.version.contains_curl",
      "kind": "cli_stdout_contains",
      "description": "--version stdout contains 'curl'",
      "category": "health",
      "spec": {
        "args": [
          "--version"
        ],
        "expected_substring": "curl"
      }
    },
    {
      "id": "curl.version.contains_libcurl",
      "kind": "cli_stdout_contains",
      "description": "--version stdout contains 'libcurl'",
      "category": "health",
      "spec": {
        "args": [
          "--version"
        ],
        "expected_substring": "libcurl"
      }
    },
    {
      "id": "curl.version.contains_protocols",
      "kind": "cli_stdout_contains",
      "description": "--version stdout contains 'Protocols:' listing",
      "category": "health",
      "spec": {
        "args": [
          "--version"
        ],
        "expected_substring": "Protocols:"
      }
    },
    {
      "id": "curl.version.contains_http",
      "kind": "cli_stdout_contains",
      "description": "--version Protocols: section lists http",
      "category": "health",
      "spec": {
        "args": [
          "--version"
        ],
        "expected_substring": " http"
      }
    },
    {
      "id": "curl.help.exits_0",
      "kind": "cli_exits_with",
      "description": "--help exits with code 0",
      "category": "health",
      "spec": {
        "args": [
          "--help"
        ],
        "expected_exit": 0
      }
    },
    {
      "id": "curl.help.contains_usage",
      "kind": "cli_stdout_contains",
      "description": "--help stdout contains 'Usage:'",
      "category": "health",
      "spec": {
        "args": [
          "--help"
        ],
        "expected_substring": "Usage:"
      }
    },
    {
      "id": "curl.file.read_exits_0",
      "kind": "cli_exits_with",
      "description": "curl can read a local file via file:// and exits 0",
      "category": "file_protocol",
      "spec": {
        "args": [
          "--silent",
          "--output",
          "/dev/null",
          "file:///etc/hosts"
        ],
        "expected_exit": 0
      }
    },
    {
      "id": "curl.file.read_stdout",
      "kind": "cli_stdout_contains",
      "description": "curl file:// output contains the file contents",
      "category": "file_protocol",
      "spec": {
        "args": [
          "--silent",
          "file:///etc/hosts"
        ],
        "expected_substring": "localhost"
      }
    },
    {
      "id": "curl.error.unsupported_protocol_exits_1",
      "kind": "cli_exits_with",
      "description": "An unsupported protocol scheme causes exit code 1",
      "category": "error_behavior",
      "spec": {
        "args": [
          "--silent",
          "badproto://example.com"
        ],
        "expected_exit": 1
      }
    },
    {
      "id": "curl.error.unsupported_protocol_stderr",
      "kind": "cli_stderr_contains",
      "description": "An unsupported protocol scheme writes a message containing 'Protocol' to stderr",
      "category": "error_behavior",
      "spec": {
        "args": [
          "badproto://example.com"
        ],
        "expected_substring": "Protocol"
      }
    },
    {
      "id": "curl.error.connection_refused_exits_7",
      "kind": "cli_exits_with",
      "description": "Connecting to a port with no listener exits with code 7 (connection refused)",
      "category": "error_behavior",
      "spec": {
        "args": [
          "--silent",
          "--max-time",
          "2",
          "http://localhost:19999"
        ],
        "expected_exit": 7,
        "timeout": 5
      }
    }
  ],
  "error_model": {
    "return_code_semantics": "",
    "stream_error_field": "null",
    "error_stickiness": "N/A",
    "error_codes": []
  }
}
