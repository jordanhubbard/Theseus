table hashlib_extra1921.hash_type_known_attrs:
  description: "HASH C extension type known method/attr presence via constructor class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1921

  columns: [id, function, args, expected]
  rows:
    - ["hl1921041", "hashlib.md5.__class__.__dict__.__contains__", ["digest"], false]
    - ["hl1921042", "hashlib.md5.__class__.__dict__.__contains__", ["hexdigest"], false]
    - ["hl1921043", "hashlib.md5.__class__.__dict__.__contains__", ["update"], false]
    - ["hl1921044", "hashlib.md5.__class__.__dict__.__contains__", ["__doc__"], true]
    - ["hl1921045", "hashlib.md5.__class__.__dict__.__contains__", ["__class__"], false]
    - ["hl1921046", "hashlib.md5.__class__.__dict__.__contains__", ["__dict__"], false]
    - ["hl1921047", "hashlib.md5.__class__.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl1921048", "hashlib.md5.__class__.__dict__.__contains__", ["__isabstractmethod__"], false]
