    - ["hl1921014", "hashlib.sha256.__class__.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["hl1921015", "hashlib.sha384.__class__.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["hl1921016", "hashlib.sha512.__class__.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["hl1921017", "hashlib.new.__class__.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["hl1921018", "hashlib.sha3_256.__class__.__dict__.__contains__", ["__abstractmethods__"], false]

