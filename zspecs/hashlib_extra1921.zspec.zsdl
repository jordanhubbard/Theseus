spec: hashlib_extra1921
version: ">=3.9"
backend: python_module(hashlib)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "hashlib.md5 is a builtin_function_or_method (C-level constructor); its __class__.__dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__."
    - "type(hashlib.new('md5')) is _hashlib.HASH — a C extension type; its __dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__."
    - "HASH is a pure C extension type; it exposes update, digest, hexdigest, copy, block_size, digest_size, name, __repr__, __doc__, __module__ in its __dict__."
    - "hashlib.sha256 and hashlib.sha512 constructors share the same C-level class as md5; all __dict__ membership checks are identical."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table hashlib_extra1921.slots_protocol:
  description: "hashlib HASH type __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1921

  columns: [id, function, args, expected]
  rows:
    - ["hl1921001", "hashlib.md5.__class__.__dict__.__contains__", ["__slots__"], false]
    - ["hl1921002", "hashlib.sha1.__class__.__dict__.__contains__", ["__slots__"], false]
    - ["hl1921003", "hashlib.sha224.__class__.__dict__.__contains__", ["__slots__"], false]
    - ["hl1921004", "hashlib.sha256.__class__.__dict__.__contains__", ["__slots__"], false]
    - ["hl1921005", "hashlib.sha384.__class__.__dict__.__contains__", ["__slots__"], false]
    - ["hl1921006", "hashlib.sha512.__class__.__dict__.__contains__", ["__slots__"], false]
    - ["hl1921007", "hashlib.new.__class__.__dict__.__contains__", ["__slots__"], false]
    - ["hl1921008", "hashlib.sha3_256.__class__.__dict__.__contains__", ["__slots__"], false]

