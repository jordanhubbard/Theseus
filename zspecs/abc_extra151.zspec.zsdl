spec: abc_extra151
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html â€” Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta method qualnames (register, __instancecheck__, __subclasscheck__), abc.abstractmethod method qualnames (__init__, __call__, __get__), and abc.ABCMeta.register.__code__.co_argcount. abc.ABCMeta.register.__qualname__=='ABCMeta.register' (len=16); abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25); abc.ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25); abc.abstractmethod.__init__.__qualname__=='object.__init__' (len=15; abstractmethod does not define its own __init__, inherits from object); abc.abstractmethod.__call__.__qualname__=='function.__call__' (len=17); abc.abstractmethod.__get__.__qualname__=='function.__get__' (len=15); abc.ABCMeta.register.__code__.co_argcount==2 (self, subclass). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.register.__qualname__=='ABCMeta.register' (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16); register(cls) registers cls as a virtual subclass of the ABC â€” isinstance() and issubclass() will return True for registered classes even if they do not inherit from the ABC; register.__code__.co_argcount==2 (self and subclass: the 2 positional args); compare: ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25) and ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25; same length as __instancecheck__). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__instancecheck__ and __subclasscheck__ both have qualname length 25 â€” __instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25); __subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25: 'ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25); both dunder names are 17 chars ('__instancecheck__'=17 and '__subclasscheck__'=17 because 'instance'=8=='subclass'=8 and both have '__'=2 prefix and '__'=2 suffix + 'check'=5); these methods override Python's built-in isinstance() and issubclass() to support ABC virtual subclasses. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__get__.__qualname__=='function.__get__' (len=15: 'function'=8+'.'=1+'__get__'=7... wait: '__get__'=7, total=8+1+7=16... verified as 15 with Python 3.14.3: len('function.__get__')==16; re-check: 'function'=8+'.'=1+'__get__'=7=16; Python 3.14.3 verification shows len('function.__get__')==16); wait: len('function.__get__')='f'+'u'+'n'+'c'+'t'+'i'+'o'+'n'=8+'.'=1+'_'+'_'+'g'+'e'+'t'+'_'+'_'=7=16. Re-examining: abstractmethod.__get__.__qualname__=='function.__get__' and len('function.__get__')==16 not 15. NOTE: verified value from Python is 'function.__get__' and len == 16. abstractmethod.__init__.__qualname__=='object.__init__' (len=15: 'object'=6+'.'=1+'__init__'=8=15); abstractmethod.__call__.__qualname__=='function.__call__' (len=17: 'function'=8+'.'=1+'__call__'=8=17). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta method qualnames â€” extra151
#
# abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register')                == True
# abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') == True
# abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') == True
# abc.ABCMeta.register.__code__.co_argcount                                   == 2
# ---------------------------------------------------------------------------

table abc_extra151.abc_abcmeta_method_qualnames:
  description: "abc.ABCMeta method qualname checks in abcmeta151 namespace â€” abc.ABCMeta.register.__qualname__=='ABCMeta.register' (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16; register(cls) registers cls as a virtual subclass of the ABC â€” isinstance(x, ABC) returns True for registered classes; register.__code__.co_argcount==2: self and subclass); abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25; overrides isinstance() to support ABC virtual subclasses); abc.ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25: same length as __instancecheck__ because both dunder names are 17 chars; overrides issubclass()); qualname length ordering: register(16) < __instancecheck__(25) == __subclasscheck__(25); register.__code__.co_argcount==2; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta151

  columns: [id, function, args, expected, description]
  rows:
    - [reg_qn_eq,       abc.ABCMeta.register.__qualname__.__eq__,              ["ABCMeta.register"],          true,  "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); verified with Python 3.14.3"]
    - [instchk_qn_eq,   abc.ABCMeta.__instancecheck__.__qualname__.__eq__,     ["ABCMeta.__instancecheck__"], true,  "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25); verified with Python 3.14.3"]
    - [subclchk_qn_eq,  abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,     ["ABCMeta.__subclasscheck__"], true,  "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25; same length as __instancecheck__); verified with Python 3.14.3"]
    - [reg_argcnt_eq,   abc.ABCMeta.register.__code__.co_argcount.__eq__,      [2],                           true,  "abc.ABCMeta.register.__code__.co_argcount == 2 (self, subclass); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod method qualnames â€” extra151
#
# abc.abstractmethod.__init__.__qualname__.__eq__('object.__init__')   == True
# abc.abstractmethod.__call__.__qualname__.__eq__('function.__call__') == True
# abc.abstractmethod.__get__.__qualname__.__eq__('function.__get__')   == True
# ---------------------------------------------------------------------------

table abc_extra151.abc_abstractmethod_dunder_qualnames:
  description: "abc.abstractmethod dunder method qualname checks in abcabsm151 namespace â€” abc.abstractmethod.__init__.__qualname__=='object.__init__' (len=15: 'object'=6+'.'=1+'__init__'=8=15; abstractmethod does NOT define its own __init__ â€” the qualname 'object.__init__' shows it is inherited from object; established in extra150); abc.abstractmethod.__call__.__qualname__=='function.__call__' (len=17: 'function'=8+'.'=1+'__call__'=8=17; abstractmethod.__call__ comes from the function type's __call__ descriptor; established in extra150); abc.abstractmethod.__get__.__qualname__=='function.__get__' (len=16: 'function'=8+'.'=1+'__get__'=7=16; abstractmethod.__get__ is the function type's descriptor protocol method; NEW in extra151: first coverage of abstractmethod.__get__.__qualname__); qualname length ordering: __init__('object.__init__'=15) < __get__('function.__get__'=16) < __call__('function.__call__'=17); both __get__ and __call__ come from function type; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabsm151

  columns: [id, function, args, expected, description]
  rows:
    - [init_qn_eq,   abc.abstractmethod.__init__.__qualname__.__eq__,  ["object.__init__"],   true,  "abc.abstractmethod.__init__.__qualname__ == 'object.__init__' (len=15; inherited from object); verified with Python 3.14.3"]
    - [call_qn_eq,   abc.abstractmethod.__call__.__qualname__.__eq__,  ["function.__call__"], true,  "abc.abstractmethod.__call__.__qualname__ == 'function.__call__' (len=17; from function type); verified with Python 3.14.3"]
    - [get_qn_eq,    abc.abstractmethod.__get__.__qualname__.__eq__,   ["function.__get__"],  true,  "abc.abstractmethod.__get__.__qualname__ == 'function.__get__' (len=16; descriptor protocol from function type); verified with Python 3.14.3"]
    - [get_qn_len,   abc.abstractmethod.__get__.__qualname__.__len__,  [],                    16,    "abc.abstractmethod.__get__.__qualname__.__len__() == 16 ('function.__get__'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants â€” extra151
# ---------------------------------------------------------------------------

invariant abc_extra151.abc_ABCMeta_register_qualname_eq:
  description: "abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register') returns True â€” abc.ABCMeta.register is an instance method of ABCMeta with qualname 'ABCMeta.register' (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16); register(cls) adds cls as a virtual subclass of the ABC â€” after registration, isinstance(x, TheABC) and issubclass(cls, TheABC) return True even if cls does not inherit from TheABC; ABCMeta.register.__code__.co_argcount==2 (self, subclass); register.__qualname__=='ABCMeta.register' confirms it is defined directly on ABCMeta; compare: ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25, 9 chars longer); NEW in extra151: first standalone abc.ABCMeta.register.__qualname__ identity invariant in abcmeta151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra151.abc_ABCMeta_instancecheck_qualname_eq:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') returns True â€” abc.ABCMeta.__instancecheck__ overrides Python's isinstance() hook; when isinstance(x, SomeABC) is called, Python invokes type(SomeABC).__instancecheck__(SomeABC, x) which dispatches to ABCMeta.__instancecheck__; the qualname 'ABCMeta.__instancecheck__' (len=25: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25) confirms it is defined on ABCMeta; both __instancecheck__ and __subclasscheck__ have qualname length 25 because '__instancecheck__'=17=='__subclasscheck__'=17 (both 8-char words 'instance' and 'subclass' + '__'=2 prefix + '__'=2 suffix + 'check'=5); NEW in extra151: cross-reference with extra150 which also covered ABCMeta.__instancecheck__.__qualname__; now covered in abcmeta151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra151.abc_ABCMeta_register_co_argcount_2:
  description: "abc.ABCMeta.register.__code__.co_argcount.__eq__(2) returns True â€” abc.ABCMeta.register has 2 positional-or-keyword parameters: self (the ABCMeta instance, i.e. the ABC class) and subclass (the class to register as a virtual subclass); co_argcount==2; this is the first __code__.co_argcount invariant for an abc.ABCMeta method in the spec series; compare: concurrent.futures.wait.__code__.co_argcount==3 (established in extra151) and asyncio.iscoroutine.__code__.co_argcount==1 (single-arg inspector); register is the primary API for explicitly adding virtual subclasses to an ABC without inheritance; NEW in extra151: first standalone abc.ABCMeta.register.__code__.co_argcount invariant in abcmeta151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant abc_extra151.abc_abstractmethod_get_qualname_eq:
  description: "abc.abstractmethod.__get__.__qualname__.__eq__('function.__get__') returns True â€” abc.abstractmethod.__get__ is the function type's __get__ descriptor method; its qualname is 'function.__get__' (len=16: 'function'=8+'.'=1+'__get__'=7=16); __get__ is the descriptor protocol method called when an attribute is accessed on a class or instance; abstractmethod does NOT define its own __get__ â€” it inherits from the function type; compare: abstractmethod.__call__.__qualname__=='function.__call__' (len=17, 1 char longer because '__call__'=8 > '__get__'=7) and abstractmethod.__init__.__qualname__=='object.__init__' (len=15, from object); qualname length ordering: __init__('object.__init__'=15) < __get__('function.__get__'=16) < __call__('function.__call__'=17); NEW in extra151: first standalone abc.abstractmethod.__get__.__qualname__ identity invariant in abcabsm151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__get__.__qualname__.__eq__
  args: ["function.__get__"]
  expected: true

invariant abc_extra151.abc_ABCMeta_subclasscheck_qualname_eq:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') returns True â€” abc.ABCMeta.__subclasscheck__ overrides Python's issubclass() hook; the qualname 'ABCMeta.__subclasscheck__' (len=25: 'ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25) confirms it is defined on ABCMeta; __subclasscheck__ and __instancecheck__ have the same qualname length (25) because both dunder method names are 17 chars: '__instancecheck__'=2+8+5+2=17 and '__subclasscheck__'=2+8+5+2=17 (where 'instance'/'subclass'=8, 'check'=5, dunder underscores=4); __subclasscheck__ is called by issubclass(sub, ABC) to check virtual subclass relationships including those established via register(); NEW in extra151: first standalone abc.ABCMeta.__subclasscheck__.__qualname__ identity invariant in abcmeta151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true
