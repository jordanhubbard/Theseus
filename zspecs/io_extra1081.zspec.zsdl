spec: io_extra1081
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module FileIO, BytesIO, and StringIO method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks FileIO, BytesIO, and StringIO method __qualname__ values; these concrete classes expose their qualnames directly (not via private C-layer classes like RawIOBase/BufferedIOBase)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1081.fileio_method_qualnames:
  description: "io.FileIO method __qualname__ checks"
  kind: python_call_eq
  category: fileio_method_qualnames
  id_prefix: io1081fi
  columns: [id, function, args, expected]
  rows:
    - [io1081fi001, io.FileIO.read.__qualname__.__eq__,      ["FileIO.read"],      true]
    - [io1081fi002, io.FileIO.readinto.__qualname__.__eq__,  ["FileIO.readinto"],  true]
    - [io1081fi003, io.FileIO.write.__qualname__.__eq__,     ["FileIO.write"],     true]
    - [io1081fi004, io.FileIO.seek.__qualname__.__eq__,      ["FileIO.seek"],      true]
    - [io1081fi005, io.FileIO.tell.__qualname__.__eq__,      ["FileIO.tell"],      true]
    - [io1081fi006, io.FileIO.truncate.__qualname__.__eq__,  ["FileIO.truncate"],  true]
    - [io1081fi007, io.FileIO.read.__class__.__name__.__eq__, ["method_descriptor"], true]

table io_extra1081.bytesio_method_qualnames:
  description: "io.BytesIO method __qualname__ checks"
  kind: python_call_eq
  category: bytesio_method_qualnames
  id_prefix: io1081by
  columns: [id, function, args, expected]
  rows:
    - [io1081by001, io.BytesIO.read.__qualname__.__eq__,      ["BytesIO.read"],      true]
    - [io1081by002, io.BytesIO.write.__qualname__.__eq__,     ["BytesIO.write"],     true]
    - [io1081by003, io.BytesIO.seek.__qualname__.__eq__,      ["BytesIO.seek"],      true]
    - [io1081by004, io.BytesIO.tell.__qualname__.__eq__,      ["BytesIO.tell"],      true]
    - [io1081by005, io.BytesIO.getvalue.__qualname__.__eq__,  ["BytesIO.getvalue"],  true]
    - [io1081by006, io.BytesIO.getbuffer.__qualname__.__eq__, ["BytesIO.getbuffer"], true]
    - [io1081by007, io.BytesIO.read.__class__.__name__.__eq__, ["method_descriptor"], true]

table io_extra1081.stringio_method_qualnames:
  description: "io.StringIO method __qualname__ checks"
  kind: python_call_eq
  category: stringio_method_qualnames
  id_prefix: io1081si
  columns: [id, function, args, expected]
  rows:
    - [io1081si001, io.StringIO.read.__qualname__.__eq__,     ["StringIO.read"],     true]
    - [io1081si002, io.StringIO.write.__qualname__.__eq__,    ["StringIO.write"],    true]
    - [io1081si003, io.StringIO.seek.__qualname__.__eq__,     ["StringIO.seek"],     true]
    - [io1081si004, io.StringIO.tell.__qualname__.__eq__,     ["StringIO.tell"],     true]
    - [io1081si005, io.StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true]
    - [io1081si006, io.StringIO.read.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [io1081si007, io.StringIO.__module__.__eq__,            ["io"],                true]
