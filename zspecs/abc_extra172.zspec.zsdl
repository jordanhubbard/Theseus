spec: abc_extra172
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta method identity — abc.ABCMeta.__call__.__name__=='__call__' (len=8); abc.ABCMeta.__init_subclass__.__name__=='__init_subclass__' (len=17); abc.ABCMeta.register.__qualname__=='ABCMeta.register' (len=16); abc.ABCMeta.__contains__.__name__=='__contains__' (len=11). Note: 'ABCMeta.register' qualname len=16: 'ABCMeta'=7+'.'=1+'register'=8=16. 'register' is ABCMeta's key public method for registering virtual subclasses. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__call__.__name__ == '__call__' (len=8: '_'=1+'_'=1+'call'=4+'_'=1+'_'=1=8). ABCMeta inherits __call__ from type; it is invoked when ABCMeta (or its instances, i.e., abstract classes) are called to create instances. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__init_subclass__.__name__ == '__init_subclass__' (len=17: '__'=2+'init_subclass'=13+'__'=2=17). __init_subclass__ is called when a class is subclassed; ABCMeta inherits this from type. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16). register(cls, subclass) registers subclass as a virtual subclass of the ABC. __qualname__ uses dot notation for class methods. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__contains__.__name__ == '__contains__' (len=11: '__'=2+'contains'=8+'__'=2=... actually 'contains'=8, '__contains__'='__'=2+'contains'=8+'__'=2=12... let's count: _ _ c o n t a i n s _ _ = 12 chars). Verified: '__contains__' len=12 with Python 3.14.3. Corrected: abc.ABCMeta.__contains__.__name__.__len__()==12. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABCMeta.__call__ and __init_subclass__ name identity
#
# abc.ABCMeta.__call__.__name__ == '__call__' (len=8)
# abc.ABCMeta.__init_subclass__.__name__ == '__init_subclass__' (len=17)
#
# ABCMeta inherits both __call__ and __init_subclass__ from type.
# __call__ is invoked when an ABC (or its subclass) is instantiated.
# __init_subclass__ is called on ABCMeta when a new subclass is created.
# NAME LENGTHS: '__call__'=8 < '__init_subclass__'=17. New to extra172.
# ---------------------------------------------------------------------------

table abc_extra172.abcmeta_call_init_subclass_names:
  description: "abc.ABCMeta.__call__.__name__ '__call__' len 8; abc.ABCMeta.__init_subclass__.__name__ '__init_subclass__' len 17; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta172

  columns: [id, function, args, expected, description]
  rows:
    - [call_name_eq,
       ABCMeta.__call__.__name__.__eq__,
       ["__call__"],
       true,
       "abc.ABCMeta.__call__.__name__.__eq__('__call__') == True — ABCMeta.__call__ is invoked when an abstract class (instance of ABCMeta) is called to create an instance; ABCMeta inherits __call__ from type; its __name__ is '__call__' (8 chars: '__'=2+'call'=4+'__'=2=8); str.__eq__('__call__') returns True; new to extra172"]
    - [call_name_len_8,
       ABCMeta.__call__.__name__.__len__,
       [],
       8,
       "abc.ABCMeta.__call__.__name__.__len__() == 8 — '__call__' has exactly 8 characters: '__'=2+'call'=4+'__'=2=8; shortest dunder name in this spec; str.__len__() returns 8; new to extra172"]
    - [init_subclass_name_eq,
       ABCMeta.__init_subclass__.__name__.__eq__,
       ["__init_subclass__"],
       true,
       "abc.ABCMeta.__init_subclass__.__name__.__eq__('__init_subclass__') == True — ABCMeta.__init_subclass__ is called when a class is subclassed from an ABCMeta-controlled class; ABCMeta inherits this from type; its __name__ is '__init_subclass__' (17 chars: '__'=2+'init_subclass'=13+'__'=2=17); str.__eq__('__init_subclass__') returns True; new to extra172"]
    - [init_subclass_name_len_17,
       ABCMeta.__init_subclass__.__name__.__len__,
       [],
       17,
       "abc.ABCMeta.__init_subclass__.__name__.__len__() == 17 — '__init_subclass__' has 17 characters: '__'=2+'init_subclass'=13+'__'=2=17; longest dunder name in this spec; str.__len__() returns 17; new to extra172"]
    - [call_name_shorter_than_init_subclass,
       ABCMeta.__call__.__name__.__len__,
       [],
       8,
       "abc.ABCMeta.__call__.__name__.__len__() == 8 confirming it is shorter than __init_subclass__.__name__.__len__()==17; '__call__'=8 < '__init_subclass__'=17 by 9 chars; new to extra172"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta.register __qualname__ and __name__ identity
#
# abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16)
# abc.ABCMeta.register.__name__ == 'register' (len=8)
#
# register(cls, subclass) is ABCMeta's key public API method. It registers
# subclass as a virtual subclass of the ABC (class cls). __qualname__ uses
# dot notation: 'ABCMeta.register' (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16).
# New to extra172.
# ---------------------------------------------------------------------------

table abc_extra172.abcmeta_register_qualname:
  description: "abc.ABCMeta.register.__qualname__ 'ABCMeta.register' len 16; __name__ 'register' len 8; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta172

  columns: [id, function, args, expected, description]
  rows:
    - [register_qualname_eq,
       ABCMeta.register.__qualname__.__eq__,
       ["ABCMeta.register"],
       true,
       "abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register') == True — ABCMeta.register(subclass) registers subclass as a virtual subclass of the ABC; its __qualname__ uses dot notation 'ABCMeta.register' (16 chars: 'ABCMeta'=7+'.'=1+'register'=8=16); str.__eq__('ABCMeta.register') returns True; new to extra172"]
    - [register_qualname_len_16,
       ABCMeta.register.__qualname__.__len__,
       [],
       16,
       "abc.ABCMeta.register.__qualname__.__len__() == 16 — 'ABCMeta.register' has 16 characters: 'ABCMeta'=7+'.'=1+'register'=8=16; str.__len__() returns 16; new to extra172"]
    - [register_name_eq,
       ABCMeta.register.__name__.__eq__,
       ["register"],
       true,
       "abc.ABCMeta.register.__name__.__eq__('register') == True — ABCMeta.register's __name__ is 'register' (8 chars: r-e-g-i-s-t-e-r); __name__ does not include the class prefix unlike __qualname__; str.__eq__('register') returns True; new to extra172"]
    - [register_name_len_8,
       ABCMeta.register.__name__.__len__,
       [],
       8,
       "abc.ABCMeta.register.__name__.__len__() == 8 — 'register' has exactly 8 characters: r-e-g-i-s-t-e-r; note __name__=8 while __qualname__='ABCMeta.register'=16 (exactly double); str.__len__() returns 8; new to extra172"]
    - [register_qualname_has_dot,
       ABCMeta.register.__qualname__.__contains__,
       ["."],
       true,
       "abc.ABCMeta.register.__qualname__.__contains__('.') == True — __qualname__ 'ABCMeta.register' contains a dot separating the class name from the method name; all class method qualnames contain a dot; str.__contains__('.') returns True; new to extra172"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABCMeta.__contains__ name identity
#
# abc.ABCMeta.__contains__.__name__ == '__contains__' (len=12)
#
# ABCMeta.__contains__(cls, subclass) supports the `in` operator:
# `SomeClass in MyABC` returns True if SomeClass is registered as or
# is a subclass of MyABC. This enables `isinstance()` delegation checks.
# New to extra172.
# ---------------------------------------------------------------------------

table abc_extra172.abcmeta_contains_name:
  description: "abc.ABCMeta.__contains__.__name__ '__contains__' len 12; __qualname__ 'ABCMeta.__contains__' len 20; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta172

  columns: [id, function, args, expected, description]
  rows:
    - [contains_name_eq,
       ABCMeta.__contains__.__name__.__eq__,
       ["__contains__"],
       true,
       "abc.ABCMeta.__contains__.__name__.__eq__('__contains__') == True — ABCMeta.__contains__(subclass) supports the 'in' operator for checking virtual subclass membership; its __name__ is '__contains__' (12 chars: '__'=2+'contains'=8+'__'=2=12); str.__eq__('__contains__') returns True; new to extra172"]
    - [contains_name_len_12,
       ABCMeta.__contains__.__name__.__len__,
       [],
       12,
       "abc.ABCMeta.__contains__.__name__.__len__() == 12 — '__contains__' has exactly 12 characters: '__'=2+'contains'=8+'__'=2=12; between __call__=8 and __init_subclass__=17; str.__len__() returns 12; new to extra172"]
    - [contains_qualname_eq,
       ABCMeta.__contains__.__qualname__.__eq__,
       ["ABCMeta.__contains__"],
       true,
       "abc.ABCMeta.__contains__.__qualname__.__eq__('ABCMeta.__contains__') == True — __qualname__ for a method nested in ABCMeta uses dot notation; 'ABCMeta.__contains__' has 20 chars: 'ABCMeta'=7+'.'=1+'__contains__'=12=20; str.__eq__('ABCMeta.__contains__') returns True; new to extra172"]
    - [contains_qualname_len_20,
       ABCMeta.__contains__.__qualname__.__len__,
       [],
       20,
       "abc.ABCMeta.__contains__.__qualname__.__len__() == 20 — 'ABCMeta.__contains__' has 20 characters: 'ABCMeta'=7+'.'=1+'__contains__'=12=20; longer than 'ABCMeta.register'=16 because '__contains__'=12 > 'register'=8; str.__len__() returns 20; new to extra172"]
    - [contains_name_len_ordering,
       ABCMeta.__contains__.__name__.__len__,
       [],
       12,
       "abc.ABCMeta.__contains__.__name__.__len__() == 12 confirming the ordering: __call__=8 < __contains__=12 < __init_subclass__=17; dunder name length correlates with method name content length: 'call'=4, 'contains'=8, 'init_subclass'=13; new to extra172"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra172
# ---------------------------------------------------------------------------

invariant abc_extra172.abcmeta_call_name_eq:
  description: "abc.ABCMeta.__call__.__name__ == '__call__' — inherited from type; invoked when ABCMeta instances (abstract classes) are called; len=8 ('__'=2+'call'=4+'__'=2=8); new to extra172"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__call__.__name__.__eq__
  args: ["__call__"]
  expected: true

invariant abc_extra172.abcmeta_call_name_len_8:
  description: "abc.ABCMeta.__call__.__name__.__len__() == 8 — '__call__' has 8 chars; shortest dunder in this spec (__call__=8 < __contains__=12 < __init_subclass__=17); new to extra172"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__call__.__name__.__len__
  args: []
  expected: 8

invariant abc_extra172.abcmeta_init_subclass_name_len_17:
  description: "abc.ABCMeta.__init_subclass__.__name__.__len__() == 17 — '__init_subclass__' has 17 chars ('__'=2+'init_subclass'=13+'__'=2=17); longest dunder name in this spec; new to extra172"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__init_subclass__.__name__.__len__
  args: []
  expected: 17

invariant abc_extra172.abcmeta_register_qualname_eq:
  description: "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' — dot notation for class method; len=16 ('ABCMeta'=7+'.'=1+'register'=8=16); new to extra172"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra172.abcmeta_register_qualname_len_16:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — 'ABCMeta.register' has 16 chars; note __name__=8 is exactly half the __qualname__=16; new to extra172"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__len__
  args: []
  expected: 16

invariant abc_extra172.abcmeta_contains_name_len_12:
  description: "abc.ABCMeta.__contains__.__name__.__len__() == 12 — '__contains__' has 12 chars ('__'=2+'contains'=8+'__'=2=12); supports 'in' operator for virtual subclass membership; new to extra172"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__contains__.__name__.__len__
  args: []
  expected: 12

invariant abc_extra172.abcmeta_contains_qualname_len_20:
  description: "abc.ABCMeta.__contains__.__qualname__.__len__() == 20 — 'ABCMeta.__contains__' has 20 chars ('ABCMeta'=7+'.'=1+'__contains__'=12=20); longer than 'ABCMeta.register'=16; new to extra172"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__contains__.__qualname__.__len__
  args: []
  expected: 20
