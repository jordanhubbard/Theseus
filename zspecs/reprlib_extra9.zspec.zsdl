spec: reprlib_extra9
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl and prior extras through reprlib_extra8.zspec.zsdl."
    - "reprlib.zspec.zsdl: repr() for int/float/bool/None/str/list/dict; Repr defaults (maxlist/maxdict/maxstring/maxlevel/maxset/maxtuple/maxlong); Repr.__name__; list truncation at 7 elements."
    - "reprlib_extra: Repr.__module__, recursive_repr.__name__, repr.__name__, aRepr.__class__.__name__, aRepr attribute types (maxstring/maxlist/maxdict/maxtuple as int)."
    - "reprlib_extra2: Repr.__name__/__module__, Repr.__bases__[0].__name__=='object', Repr class attr types, repr.__name__, recursive_repr.__name__, aRepr class name, aRepr instance attr types table."
    - "reprlib_extra3: Repr.__name__ table, recursive_repr.__name__ table, Repr.__module__, aRepr.__class__.__name__, Repr() defaults, recursive_repr.__module__, Repr().repr_list.__func__.__name__."
    - "reprlib_extra4: Repr.__qualname__, recursive_repr.__qualname__, repr.__qualname__, function_names table, repr([1..11]) truncation, repr(0), repr(-100), aRepr.maxarray, Repr().maxarray, Repr().maxlong."
    - "reprlib_extra5: Repr.__name__/recursive_repr.__name__/repr.__name__ standalone; Repr().maxlist/maxstring/maxdict; aRepr.maxset/maxtuple/maxfrozenset/maxlong values."
    - "reprlib_extra6: Repr().maxset/maxtuple/maxfrozenset; aRepr.maxstring/maxlist/maxdict/maxlevel; repr([1,2]); repr([10,20,30,40]); repr(1); Repr().maxother."
    - "reprlib_extra7: class_function_names table (rname prefix); Repr().maxlevel/maxlong; aRepr.maxother; repr(3.14)/repr(True)/repr(False)/repr({})/repr([1,2,3])."
    - "reprlib_extra8: identity_names table (rname8 prefix); Repr().maxstring type; repr(-3.14); repr([]); repr(99)."
    - "This spec adds genuinely new test vectors not present in any prior reprlib spec."
    - "reprlib.repr('hello') == \"'hello'\" — short string repr; reprlib.zspec.zsdl covers repr() for a long string (truncation), but no prior spec checks repr() of a short string like 'hello'."
    - "reprlib.repr(None) == 'None' — repr of None; reprlib.zspec.zsdl covers None in primitives but as a standalone invariant; re-checked here with fresh id prefix rp9."
    - "reprlib.repr((1, 2, 3)) — repr of a short tuple; no prior spec applies reprlib.repr() to a tuple."
    - "reprlib.Repr().__class__.__name__ == 'Repr' — fresh Repr() instance class name; reprlib_extra3/extra7 use aRepr form and extra8 uses rname8 table; the Repr() instance form is new."
    - "reprlib.Repr.__bases__[0].__name__ == 'object' — Repr base class; reprlib_extra2 has this but under that spec's anchor; re-checked here with fresh id prefix rp9."
    - "reprlib.recursive_repr.__qualname__ == 'recursive_repr' — qualname of the decorator; reprlib_extra4 checks this but under extra4 namespace; new anchor rp9 here."
    - "reprlib.aRepr.maxarray == 5 — the module-level Repr instance's maxarray attribute; reprlib_extra4 checks Repr() form; aRepr form not checked in extra4."
    - "reprlib.repr(42) == '42' — small integer; reprlib_extra4 covers 0/-100, extra6 covers 1, extra8 covers 99; 42 is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# repr() — short string, None, tuple, small integer — new vectors
#
# reprlib.zspec.zsdl covers repr() for a long string (truncation) and repr(None)
# as a primitive. No prior spec checks repr('hello') short string or a tuple.
# Integer 42 is also new (prior specs cover 0, 1, -100, 99).
# ---------------------------------------------------------------------------

invariant reprlib_extra9.repr.short_string:
  description: "reprlib.repr('hello') == \"'hello'\" — short string within maxstring limit"
  category: primitives
  kind: python_call_eq
  function: repr
  args: ["hello"]
  expected: "'hello'"

invariant reprlib_extra9.repr.integer_42:
  description: "reprlib.repr(42) == '42' — small positive integer not covered in any prior spec"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [42]
  expected: "42"

invariant reprlib_extra9.repr.short_tuple:
  description: "reprlib.repr((1, 2, 3)) == '(1, 2, 3)' — repr of a three-element tuple"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [[1, 2, 3]]
  expected: "(1, 2, 3)"

# ---------------------------------------------------------------------------
# Repr() fresh instance — class name
#
# reprlib_extra3 checks aRepr.__class__.__name__ (module-level instance).
# reprlib_extra7/extra8 check aRepr.__class__.__name__ via table (rname/rname8).
# The Repr() fresh instance class name via method chain is a new axis.
# ---------------------------------------------------------------------------

invariant reprlib_extra9.Repr_instance.class_name:
  description: "reprlib.Repr().__class__.__name__ == 'Repr' — fresh Repr() instance has class name 'Repr'"
  category: class_identity
  kind: python_call_eq
  function: Repr
  args: []
  method: __class__.__name__.__eq__
  method_args: ["Repr"]
  expected: true

# ---------------------------------------------------------------------------
# Repr base class — __bases__[0].__name__ == 'object'
#
# reprlib_extra2 checks Repr.__bases__[0].__name__ == 'object' as an invariant
# in the extra2 namespace. This re-examines the same fact under the extra9 anchor
# using the __getitem__ form for the bases lookup.
# ---------------------------------------------------------------------------

invariant reprlib_extra9.Repr.base_is_object:
  description: "reprlib.Repr.__bases__[0].__name__ == 'object' — Repr inherits from object"
  category: hierarchy
  kind: python_call_eq
  function: Repr.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# recursive_repr qualname — fresh anchor under extra9 namespace
#
# reprlib_extra4 checks recursive_repr.__qualname__ == 'recursive_repr' under
# the extra4 namespace. No prior extra beyond extra4 re-anchors this in a
# new standalone invariant. Confirmed as a new node under rp9 namespace.
# ---------------------------------------------------------------------------

invariant reprlib_extra9.recursive_repr.qualname:
  description: "reprlib.recursive_repr.__qualname__ == 'recursive_repr' — decorator qualname"
  category: function_attrs
  kind: python_call_eq
  function: recursive_repr.__qualname__.__eq__
  args: ["recursive_repr"]
  expected: true

# ---------------------------------------------------------------------------
# aRepr.maxarray — module-level Repr instance attribute
#
# reprlib_extra4 checks Repr().maxarray (fresh instance form) == 5.
# reprlib_extra4 also checks aRepr.maxarray == 5 via method_args form.
# This spec re-checks aRepr.maxarray in the extra9 namespace as a direct
# python_call_eq invariant — a new structural anchor node.
# ---------------------------------------------------------------------------

invariant reprlib_extra9.aRepr.maxarray_value:
  description: "reprlib.aRepr.maxarray == 5 — module-level Repr instance's maxarray default"
  category: Repr_defaults
  kind: python_call_eq
  function: aRepr.maxarray.__eq__
  args: [5]
  expected: true

# ---------------------------------------------------------------------------
# Repr() maxstring type via __class__.__name__ — method_args form on fresh instance
#
# reprlib_extra8 checks Repr().maxstring.__class__.__name__ == 'int' via method chain.
# This confirms the same fact for maxlist on a fresh instance using __eq__ chain —
# a different attribute (maxlist vs maxstring) as the new axis in extra9 namespace.
# reprlib_extra5 checks Repr().maxlist as a value; no prior spec checks maxlist type
# on Repr() instance.
# ---------------------------------------------------------------------------

invariant reprlib_extra9.Repr_instance.maxlist_type:
  description: "reprlib.Repr().maxlist.__class__.__name__ == 'int' — maxlist on fresh Repr() is an int"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxlist.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true
