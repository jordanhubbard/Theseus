spec: twine_rust
version: ">=3.9"
backend: rust_module(twine_rust)

docs: https://twine.readthedocs.io/

provenance:
  derived_from:
    - "https://twine.readthedocs.io/ — twine upload tool"
  notes:
    - "twine uploads Python packages to PyPI."
    - "twine.upload is importable."
    - "twine.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant twine_rust.has_upload_module:
  description: "twine.upload is importable"
  category: presence
  kind: python_call_eq
  function: twine_has_upload_module
  args: []
  expected: true

invariant twine_rust.has_commands:
  description: "twine.commands is importable"
  category: presence
  kind: python_call_eq
  function: twine_has_commands
  args: []
  expected: true

invariant twine_rust.version_nonempty:
  description: "twine.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: twine_version_nonempty
  args: []
  expected: true

