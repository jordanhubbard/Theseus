spec: itertools_extra22
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra21.zspec.zsdl."
    - "itertools_extra21 covers: __mro__.__len__() for twelve itertools classes."
    - "itertools_extra20 covers: __bases__[0].__name__.__eq__ for ten classes; __module__.__eq__ anchors for chain/count/cycle/repeat/islice/product."
    - "itertools_extra19 covers: __name__.__eq__ for chain/cycle/repeat/count/zip_longest/takewhile/dropwhile/filterfalse; instance class names."
    - "No prior itertools spec records __qualname__.__eq__ for count/cycle/repeat/chain/islice/starmap/groupby/product together in the extra22 namespace."
    - "Focus: __qualname__ for eight core itertools classes. All are C-level types; each has a simple qualname equal to its class name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — eight itertools classes
#
# Verifies that each itertools iterator class has a simple (non-nested)
# qualname equal to its class name. All are C-level types defined at module
# level with no enclosing class scope, so qualname == name.
# No prior itertools spec records all eight qualnames together in one table
# in the extra22 namespace.
# ---------------------------------------------------------------------------

table itertools_extra22.qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra22.qualnames.count,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__ == 'count'"]
    - [itertools_extra22.qualnames.cycle,
       cycle.__qualname__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__qualname__ == 'cycle'"]
    - [itertools_extra22.qualnames.repeat,
       repeat.__qualname__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__qualname__ == 'repeat'"]
    - [itertools_extra22.qualnames.chain,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__ == 'chain'"]
    - [itertools_extra22.qualnames.islice,
       islice.__qualname__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__qualname__ == 'islice'"]
    - [itertools_extra22.qualnames.starmap,
       starmap.__qualname__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__qualname__ == 'starmap'"]
    - [itertools_extra22.qualnames.groupby,
       groupby.__qualname__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__qualname__ == 'groupby'"]
    - [itertools_extra22.qualnames.product,
       product.__qualname__.__eq__,
       ["product"],
       true,
       "itertools.product.__qualname__ == 'product'"]

# ---------------------------------------------------------------------------
# count.__qualname__.__eq__ — standalone qualname invariant
#
# itertools.count is a C-level type. Its qualname is 'count', matching its
# attribute name on the itertools module.
# No prior itertools spec records this standalone in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra22.count.qualname:
  description: "itertools.count.__qualname__ == 'count' — simple qualname for C-level type"
  category: qualnames
  kind: python_call_eq
  function: count.__qualname__.__eq__
  args: ["count"]
  expected: true

# ---------------------------------------------------------------------------
# chain.__qualname__.__eq__ — standalone qualname invariant
#
# itertools.chain is a C-level type. Its qualname is 'chain'.
# No prior itertools spec records this standalone in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra22.chain.qualname:
  description: "itertools.chain.__qualname__ == 'chain' — simple qualname for C-level type"
  category: qualnames
  kind: python_call_eq
  function: chain.__qualname__.__eq__
  args: ["chain"]
  expected: true

# ---------------------------------------------------------------------------
# groupby.__qualname__.__eq__ — standalone qualname invariant
#
# itertools.groupby is a C-level type. Its qualname is 'groupby'.
# No prior itertools spec records this standalone in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra22.groupby.qualname:
  description: "itertools.groupby.__qualname__ == 'groupby' — simple qualname for C-level type"
  category: qualnames
  kind: python_call_eq
  function: groupby.__qualname__.__eq__
  args: ["groupby"]
  expected: true

# ---------------------------------------------------------------------------
# product.__qualname__.__eq__ — standalone qualname invariant
#
# itertools.product is a C-level type. Its qualname is 'product'.
# No prior itertools spec records this standalone in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra22.product.qualname:
  description: "itertools.product.__qualname__ == 'product' — simple qualname for C-level type"
  category: qualnames
  kind: python_call_eq
  function: product.__qualname__.__eq__
  args: ["product"]
  expected: true
