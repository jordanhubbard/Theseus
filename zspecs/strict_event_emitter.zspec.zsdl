spec: strict_event_emitter
version: ">=0.5.0"
backend: node(strict-event-emitter)

docs: https://github.com/mswjs/strict-event-emitter#readme

provenance:
  derived_from:
    - "strict-event-emitter README — https://github.com/mswjs/strict-event-emitter#readme"
    - "Test vectors verified with strict-event-emitter via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "strict-event-emitter source"
  notes:
    - "Type-safe Node EventEmitter — used by MSW (mock-service-worker) for typed event bus integration."
    - "Install: npm install strict-event-emitter"
    - "v0.5 CJS; named exports Emitter class plus MemoryLeakError sentinel."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws MemoryLeakError when listener count exceeds maxListeners."
  stderr: "null"
  stickiness: "Each instance carries its own listener registry."
  codes:
    MemoryLeakError: "Too many listeners on a single event"

invariant strict_event_emitter.has_Emitter:
  description: "Emitter class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Emitter.constructor.name"}
  expected: "Function"

invariant strict_event_emitter.has_MemoryLeakError:
  description: "MemoryLeakError sentinel class exposed"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "MemoryLeakError.constructor.name"}
  expected: "Function"

invariant strict_event_emitter.proto_has_emit:
  description: "Emitter.prototype.emit defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Emitter.prototype.emit.constructor.name"}
  expected: "Function"

invariant strict_event_emitter.proto_has_on:
  description: "Emitter.prototype.on defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Emitter.prototype.on.constructor.name"}
  expected: "Function"

invariant strict_event_emitter.proto_has_once:
  description: "Emitter.prototype.once defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Emitter.prototype.once.constructor.name"}
  expected: "Function"

invariant strict_event_emitter.proto_has_addListener:
  description: "Emitter.prototype.addListener defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Emitter.prototype.addListener.constructor.name"}
  expected: "Function"

invariant strict_event_emitter.proto_has_removeListener:
  description: "Emitter.prototype.removeListener defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Emitter.prototype.removeListener.constructor.name"}
  expected: "Function"

invariant strict_event_emitter.proto_has_eventNames:
  description: "Emitter.prototype.eventNames defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Emitter.prototype.eventNames.constructor.name"}
  expected: "Function"

invariant strict_event_emitter.proto_has_setMaxListeners:
  description: "Emitter.prototype.setMaxListeners defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Emitter.prototype.setMaxListeners.constructor.name"}
  expected: "Function"

