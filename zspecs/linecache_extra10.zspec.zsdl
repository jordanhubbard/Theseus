spec: linecache_extra10
version: ">=3.9"
backend: python_module(linecache)

docs: https://docs.python.org/3/library/linecache.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/linecache.html — Python linecache module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/linecache.py"
  notes:
    - "This spec extends linecache.zspec.zsdl and linecache_extra through linecache_extra9.zspec.zsdl."
    - "linecache_extra9 covers: module __name__, __name__ last-character table for all six functions, __qualname__ length table, cache.__len__() return type."
    - "NEW in this spec: __name__ standalone invariants for getline/getlines/clearcache/checkcache/updatecache; __module__ table for those five functions (all 'linecache'); cache.__class__.__name__ == 'dict' as a standalone invariant."
    - "linecache.getline.__name__ == 'getline'; linecache.getlines.__name__ == 'getlines'; linecache.clearcache.__name__ == 'clearcache'; linecache.checkcache.__name__ == 'checkcache'; linecache.updatecache.__name__ == 'updatecache'."
    - "All five public functions have __module__ == 'linecache' — verified on Python 3.12 on macOS Darwin 25.4.0."
    - "linecache.cache.__class__.__name__ == 'dict' — verified on Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ standalone invariants for five public linecache functions
#
# linecache_extra8 covers __name__ first-character; extra9 covers last-character
# and __qualname__ lengths. These standalone invariants anchor the full __name__
# value for each of the five primary public functions in the extra10 namespace.
# ---------------------------------------------------------------------------

table linecache_extra10.function_names:
  description: "__name__ attribute for five public linecache functions"
  kind: python_call_eq
  category: function_names
  id_prefix: fname10

  columns: [id, function, args, expected]
  rows:
    - [getline,     getline.__name__.__eq__,     ["getline"],     true]
    - [getlines,    getlines.__name__.__eq__,    ["getlines"],    true]
    - [clearcache,  clearcache.__name__.__eq__,  ["clearcache"],  true]
    - [checkcache,  checkcache.__name__.__eq__,  ["checkcache"],  true]
    - [updatecache, updatecache.__name__.__eq__, ["updatecache"], true]

# ---------------------------------------------------------------------------
# __module__ table — five public linecache functions
#
# All five functions are defined in the linecache module.
# No prior linecache spec contains a __module__ table for these five functions
# (prior specs cover __module__ for getline and getlines only in isolated invariants).
# ---------------------------------------------------------------------------

table linecache_extra10.function_modules:
  description: "__module__ attribute for five public linecache functions — all 'linecache'"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod10

  columns: [id, function, args, expected]
  rows:
    - [getline,     getline.__module__.__eq__,     ["linecache"], true]
    - [getlines,    getlines.__module__.__eq__,    ["linecache"], true]
    - [clearcache,  clearcache.__module__.__eq__,  ["linecache"], true]
    - [checkcache,  checkcache.__module__.__eq__,  ["linecache"], true]
    - [updatecache, updatecache.__module__.__eq__, ["linecache"], true]

# ---------------------------------------------------------------------------
# linecache.cache — the module-level dict
#
# linecache.cache is the dict that holds cached file contents.
# Verified: type(linecache.cache).__name__ == 'dict'
# No prior spec verifies this as a standalone invariant in the extra10 namespace.
# ---------------------------------------------------------------------------

invariant linecache_extra10.cache.class_name:
  description: "linecache.cache.__class__.__name__ == 'dict' — the cache is a plain dict"
  category: module_attributes
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
