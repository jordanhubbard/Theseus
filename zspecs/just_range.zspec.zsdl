spec: just_range
version: ">=4.2.0"
backend: node(just-range)

docs: https://www.npmjs.com/package/just-range

provenance:
  derived_from:
    - "just-range README — https://www.npmjs.com/package/just-range"
    - "Test vectors verified with just-range via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-range source"
  notes:
    - "just-range is an npm package. Install: npm install just-range"
    - "The module exports a single function: range(stop), range(start, stop), range(start, stop, step)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of numbers."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_range.range:
  kind: node_module_call_eq
  function: ~
  category: generate
  id_prefix: jrange

  columns: [id, args, expected]
  rows:
    - [stop_only,     [5],         [0, 1, 2, 3, 4]]
    - [start_stop,    [1, 6],      [1, 2, 3, 4, 5]]
    - [with_step,     [0, 10, 2],  [0, 2, 4, 6, 8]]

