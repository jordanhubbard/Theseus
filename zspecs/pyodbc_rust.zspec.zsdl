spec: pyodbc_rust
version: ">=3.9"
backend: rust_module(pyodbc_rust)

docs: https://github.com/mkleehammer/pyodbc

provenance:
  derived_from:
    - "https://github.com/mkleehammer/pyodbc — pyodbc"
  notes:
    - "pyodbc provides ODBC database connectivity."
    - "pyodbc.connect is callable."
    - "pyodbc.version is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pyodbc_rust.has_connect:
  description: "pyodbc.connect is callable"
  category: presence
  kind: python_call_eq
  function: pyodbc_has_connect
  args: []
  expected: true

invariant pyodbc_rust.has_error:
  description: "pyodbc.Error is a class"
  category: presence
  kind: python_call_eq
  function: pyodbc_has_error
  args: []
  expected: true

invariant pyodbc_rust.version_nonempty:
  description: "pyodbc.version is non-empty"
  category: version
  kind: python_call_eq
  function: pyodbc_version_nonempty
  args: []
  expected: true

