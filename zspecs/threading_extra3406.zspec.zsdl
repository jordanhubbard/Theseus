spec: th3406
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 674 (th3406): __bool__, __str__, __repr__ dict-presence checks for threading types."
    - "Theme: __bool__/__str__/__repr__ dict-presence (bool(x), str(x), repr(x))."
    - "All values False — threading synchronization and thread-management types have no custom bool/str/repr conversion in their own __dict__."
    - "None of the threading types define __bool__, __str__, or __repr__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3406.bool:
  description: "threading types __bool__ dict-presence checks; wave 674"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3406
  columns: [id, function, args, expected]
  rows:
    - ["th3406001", operator.contains, [threading.Thread.__dict__,           "__bool__"], false]
    - ["th3406002", operator.contains, [threading.Event.__dict__,            "__bool__"], false]
    - ["th3406003", operator.contains, [threading.Condition.__dict__,        "__bool__"], false]
    - ["th3406004", operator.contains, [threading.Semaphore.__dict__,        "__bool__"], false]
    - ["th3406005", operator.contains, [threading.BoundedSemaphore.__dict__, "__bool__"], false]
    - ["th3406006", operator.contains, [threading.Timer.__dict__,            "__bool__"], false]
    - ["th3406007", operator.contains, [threading.Barrier.__dict__,          "__bool__"], false]
    - ["th3406008", operator.contains, [threading.local.__dict__,            "__bool__"], false]
    - ["th3406009", operator.contains, [type(threading.Lock()).__dict__,     "__bool__"], false]
    - ["th3406010", operator.contains, [type(threading.RLock()).__dict__,    "__bool__"], false]

