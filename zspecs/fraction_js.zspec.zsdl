spec: fraction_js
version: ">=4.0.0"
backend: node(fraction.js)

docs: https://github.com/rawify/Fraction.js#readme

provenance:
  derived_from:
    - "fraction.js README — https://github.com/rawify/Fraction.js#readme"
    - "Test vectors verified with fraction.js@4.3.8 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "fraction.js source"
  notes:
    - "fraction.js exports an object with .default = Fraction constructor and .Fraction = same."
    - "new Fraction(numerator, denominator) creates an exact rational number."
    - "toString() returns decimal (with repeating part in parens); toFraction() returns 'n/d'."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "toString/toFraction return strings. No errors for valid numeric inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fraction_js.toFraction:
  kind: node_constructor_call_eq
  class: default
  method: toFraction
  category: toFraction
  id_prefix: frac_f

  columns: [id, ctor_args, expected]
  rows:
    - [one_third,  [1, 3],  "1/3"]
    - [three_four, [3, 4],  "3/4"]
    - [one_half,   [1, 2],  "1/2"]

table fraction_js.toString:
  kind: node_constructor_call_eq
  class: default
  method: toString
  category: toString
  id_prefix: frac_s

  columns: [id, ctor_args, expected]
  rows:
    - [one_half,   [1, 2],  "0.5"]
    - [three_four, [3, 4],  "0.75"]
    - [one_third,  [1, 3],  "0.(3)"]
