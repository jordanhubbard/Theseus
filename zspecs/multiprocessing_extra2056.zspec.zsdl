spec: multiprocessing_extra2056
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-primitives"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "multiprocessing.Process and synchronize types are process/IPC primitives, not sequence/mapping/attribute-override types."
    - "multiprocessing.synchronize provides Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition."
    - "None of these types define __getitem__, __setitem__, __delitem__, __len__, __getattr__, __setattr__, or __delattr__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2056.getitem_protocol:
  description: "multiprocessing.Process and synchronize types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2056

  columns: [id, function, args, expected]
  rows:
    - ["mp2056001", "multiprocessing.Process.__dict__.__contains__", ["__getitem__"], false]
    - ["mp2056002", "multiprocessing.Process.__dict__.__contains__", ["__setitem__"], false]
    - ["mp2056003", "multiprocessing.Process.__dict__.__contains__", ["__delitem__"], false]
