spec: cli_width
version: ">=4.0.0"
backend: node(cli-width)

docs: https://github.com/knownasilya/cli-width#readme

provenance:
  derived_from:
    - "cli-width README — https://github.com/knownasilya/cli-width#readme"
    - "Test vectors verified with cli-width via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "cli-width source"
  notes:
    - "Get the terminal column width — falls through CLI flag → tty.columns → defaultWidth → 0."
    - "Install: npm install cli-width"
    - "v4 CJS; module export IS the function. With no TTY in headless tests, returns 0 unless defaultWidth/output is supplied."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "Reads process state on each call."
  codes: {}

invariant cli_width.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant cli_width.module_arity:
  description: "Module function takes 1 arg (options)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant cli_width.no_tty_returns_zero:
  description: "Headless invocation (no TTY, no defaultWidth) returns 0"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain: []
  expected: 0

invariant cli_width.defaultWidth_80:
  description: "defaultWidth: 80 is honored when nothing else is detected"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"defaultWidth": 80}]
  chain: []
  expected: 80

invariant cli_width.defaultWidth_120:
  description: "defaultWidth: 120 also honored"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"defaultWidth": 120}]
  chain: []
  expected: 120

invariant cli_width.output_columns_overrides_default:
  description: "output.columns wins over defaultWidth"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"output": {"columns": 100}, "defaultWidth": 80}]
  chain: []
  expected: 100
