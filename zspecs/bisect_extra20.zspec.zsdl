spec: bisect_extra20
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
    - "bisect_extra19.zspec.zsdl — covers __text_signature__.__len__() for all 6 callables."
    - "bisect_extra18.zspec.zsdl — covers __qualname__.__eq__ for all 6 callables."
    - "bisect_extra17.zspec.zsdl — covers __qualname__.__len__() for all 6 callables."
    - "bisect_extra12.zspec.zsdl — covers __module__.__len__() for bisect_left/bisect_right/insort_left/insort_right (four primary functions only)."
    - "bisect_extra14.zspec.zsdl — covers __name__.__len__() for all 6 callables including aliases."
  notes:
    - "This spec extends bisect.zspec.zsdl through bisect_extra19.zspec.zsdl."
    - "bisect_extra12 covers __module__.__len__() only for the four primary functions (bisect_left/bisect_right/insort_left/insort_right); not the aliases."
    - "NOT yet covered: bisect.__module__.__len__() and insort.__module__.__len__() for the alias callables."
    - "NOT yet covered: bisect module-level __name__.__len__() == 6 (len('bisect')); __package__.__len__() == 0."
    - "Focus: module-level __name__.__len__() and __package__.__len__(); alias callable __module__.__len__() table."
    - "bisect module __name__ == 'bisect'; len('bisect') == 6. Verified Python 3.12 macOS."
    - "bisect module __package__ == ''; len('') == 0. Verified."
    - "bisect.bisect.__module__ == '_bisect'; len('_bisect') == 7. Verified."
    - "bisect.insort.__module__ == '_bisect'; len('_bisect') == 7. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# bisect module-level __name__.__len__() and __package__.__len__()
#
# Prior specs (bisect_extra15, bisect_extra16) cover __name__.__eq__ and
# __package__.__eq__ at the module level. No prior bisect spec checks the
# length of the module's own __name__ or __package__ strings. len('bisect')==6;
# len('') == 0. Under python_module(bisect), __name__ and __package__ access
# the module-level attributes directly.
# ---------------------------------------------------------------------------

invariant bisect_extra20.module.name_len:
  description: "bisect.__name__.__len__() == 6 — len('bisect') == 6"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

invariant bisect_extra20.module.package_len:
  description: "bisect.__package__.__len__() == 0 — __package__ is the empty string for a top-level module"
  category: module_identity
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# __module__.__len__() for the bisect and insort alias callables
#
# bisect_extra12 covers __module__.__len__() for the four primary functions
# (bisect_left, bisect_right, insort_left, insort_right). It does NOT cover
# the aliases bisect and insort. The aliases point to bisect_right and
# insort_right respectively; both share __module__ == '_bisect', len == 7.
# id_prefix bsalmodlen20 does not conflict with any prior bisect spec.
# ---------------------------------------------------------------------------

table bisect_extra20.alias_module_lengths:
  description: "__module__.__len__() for bisect and insort alias callables — both == 7 (len('_bisect'))"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: bsalmodlen20

  columns: [id, function, args, expected]
  rows:
    - [bisect, bisect.__module__.__len__, [], 7]
    - [insort, insort.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# Consolidated __module__.__len__() for all 6 bisect callables — extra20 namespace
#
# bisect_extra12 covers __module__.__len__ for bisect_left/bisect_right/
# insort_left/insort_right as standalone invariants. Combined with the alias
# rows above, this table presents the complete picture for all 6 in one place.
# All 6 callables are C builtins from _bisect; __module__ == '_bisect', len == 7.
# id_prefix bsallmodlen20 provides a distinct namespace for the full-set table.
# ---------------------------------------------------------------------------

table bisect_extra20.all_module_lengths:
  description: "__module__.__len__() == 7 for all 6 bisect callables (all are from C extension _bisect)"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: bsallmodlen20

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__module__.__len__,  [], 7]
    - [bisect_right, bisect_right.__module__.__len__, [], 7]
    - [insort_left,  insort_left.__module__.__len__,  [], 7]
    - [insort_right, insort_right.__module__.__len__, [], 7]
    - [bisect,       bisect.__module__.__len__,       [], 7]
    - [insort,       insort.__module__.__len__,       [], 7]
