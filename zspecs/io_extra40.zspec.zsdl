spec: io_extra40
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra39.zspec.zsdl — covers FileIO/BufferedReader __mro__.__len__()==4; FileIO/BufferedReader __bases__[0].__name__.__len__(); FileIO/BufferedReader __name__/__qualname__.__len__(); BufferedReader method __qualname__.__len__() for read/readline/readinto/peek; FileIO method __qualname__.__len__() for read/write/seek/readinto."
  notes:
    - "This spec extends io_extra39.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__/__dict__.__class__.__name__/__reduce__.__name__/__init_subclass__.__qualname__ for all ten io classes; __mro__.__len__() for all ten classes; __bases__[0].__name__/__len__() for all ten classes; SEEK_*/DEFAULT_BUFFER_SIZE constants; StringIO/BytesIO/TextIOWrapper/BufferedReader/BufferedWriter/FileIO method qualname lengths; IOBase.close/__qualname__.__eq__()==true; IOBase.flush/readable/writable/seekable __qualname__.__eq__() (string equality, not lengths)."
    - "This spec covers: __qualname__.__len__() for IOBase.readable (16), IOBase.writable (16), IOBase.seekable (16), IOBase.tell (12), IOBase.flush (13), IOBase.close (13); RawIOBase.read (15), RawIOBase.readall (18), RawIOBase.readinto (19); BufferedIOBase.read (20), BufferedIOBase.write (21), BufferedIOBase.readinto (24); TextIOBase.read (16), TextIOBase.readline (20), TextIOBase.write (17). All novel — no prior io spec checks __qualname__.__len__() for any abstract base class (IOBase/RawIOBase/BufferedIOBase/TextIOBase) method."
    - "IMPORTANT: The io ABC classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) are aliases for C-extension types in _io. Their methods carry the internal C-level qualname with the private prefix (_IOBase, _RawIOBase, _BufferedIOBase, _TextIOBase). For example io.IOBase.readable.__qualname__ == '_IOBase.readable' (len 16), not 'IOBase.readable' (len 14). This asymmetry between __name__ and __qualname__ is the key distinguishing feature of this spec."
    - "io.IOBase.readable.__qualname__ == '_IOBase.readable' — len 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IOBase.tell.__qualname__ == '_IOBase.tell' — len 12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.RawIOBase.read.__qualname__ == '_RawIOBase.read' — len 15. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.RawIOBase.readall.__qualname__ == '_RawIOBase.readall' — len 18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.RawIOBase.readinto.__qualname__ == '_RawIOBase.readinto' — len 19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.read.__qualname__ == '_BufferedIOBase.read' — len 20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.write.__qualname__ == '_BufferedIOBase.write' — len 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.readinto.__qualname__ == '_BufferedIOBase.readinto' — len 24. This is the longest ABC method qualname in the io module. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.TextIOBase.read.__qualname__ == '_TextIOBase.read' — len 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.TextIOBase.readline.__qualname__ == '_TextIOBase.readline' — len 20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.TextIOBase.write.__qualname__ == '_TextIOBase.write' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IOBase ABC method __qualname__.__len__() — readable, writable, seekable,
# tell, flush, close
#
# io.IOBase is a public alias for _io.IOBase which itself wraps _io._IOBase.
# Methods accessed via io.IOBase carry the internal C-level qualname using the
# _IOBase prefix. No prior io spec checks __qualname__.__len__() for any of
# these IOBase methods (prior specs checked __qualname__.__eq__() in extra17/29
# but not the numeric lengths).
#
#   IOBase.readable -> '_IOBase.readable' -> 16
#   IOBase.writable -> '_IOBase.writable' -> 16
#   IOBase.seekable -> '_IOBase.seekable' -> 16
#   IOBase.tell     -> '_IOBase.tell'     -> 12
#   IOBase.flush    -> '_IOBase.flush'    -> 13
#   IOBase.close    -> '_IOBase.close'    -> 13
# ---------------------------------------------------------------------------

table io_extra40.IOBase_method_qualname_lens:
  description: "io.IOBase method __qualname__.__len__() — readable/writable/seekable(16), tell(12), flush/close(13); all carry _IOBase C-level prefix"
  kind: python_call_eq
  category: method_identity
  id_prefix: ibmq40

  columns: [id, function, args, expected]
  rows:
    - [readable, IOBase.readable.__qualname__.__len__, [], 16]
    - [writable, IOBase.writable.__qualname__.__len__, [], 16]
    - [seekable, IOBase.seekable.__qualname__.__len__, [], 16]
    - [tell,     IOBase.tell.__qualname__.__len__,     [], 12]
    - [flush,    IOBase.flush.__qualname__.__len__,    [], 13]
    - [close,    IOBase.close.__qualname__.__len__,    [], 13]

# ---------------------------------------------------------------------------
# RawIOBase ABC method __qualname__.__len__() — read, readall, readinto
#
# io.RawIOBase methods carry the _RawIOBase C-level prefix in their qualnames.
# No prior io spec checks __qualname__.__len__() for any RawIOBase method.
#
#   RawIOBase.read     -> '_RawIOBase.read'     -> 15
#   RawIOBase.readall  -> '_RawIOBase.readall'  -> 18
#   RawIOBase.readinto -> '_RawIOBase.readinto' -> 19
# ---------------------------------------------------------------------------

table io_extra40.RawIOBase_method_qualname_lens:
  description: "io.RawIOBase method __qualname__.__len__() — read(15)/readall(18)/readinto(19); all carry _RawIOBase C-level prefix"
  kind: python_call_eq
  category: method_identity
  id_prefix: ribmq40

  columns: [id, function, args, expected]
  rows:
    - [read,     RawIOBase.read.__qualname__.__len__,     [], 15]
    - [readall,  RawIOBase.readall.__qualname__.__len__,  [], 18]
    - [readinto, RawIOBase.readinto.__qualname__.__len__, [], 19]

# ---------------------------------------------------------------------------
# BufferedIOBase ABC method __qualname__.__len__() — read, write, readinto
#
# io.BufferedIOBase methods carry the _BufferedIOBase prefix (15 chars) which
# is the longest private prefix of any io ABC, yielding the longest qualnames.
# No prior io spec checks __qualname__.__len__() for any BufferedIOBase method.
#
#   BufferedIOBase.read     -> '_BufferedIOBase.read'     -> 20
#   BufferedIOBase.write    -> '_BufferedIOBase.write'    -> 21
#   BufferedIOBase.readinto -> '_BufferedIOBase.readinto' -> 24 (longest io ABC method qualname)
# ---------------------------------------------------------------------------

table io_extra40.BufferedIOBase_method_qualname_lens:
  description: "io.BufferedIOBase method __qualname__.__len__() — read(20)/write(21)/readinto(24); readinto is longest io ABC method qualname"
  kind: python_call_eq
  category: method_identity
  id_prefix: bibmq40

  columns: [id, function, args, expected]
  rows:
    - [read,     BufferedIOBase.read.__qualname__.__len__,     [], 20]
    - [write,    BufferedIOBase.write.__qualname__.__len__,    [], 21]
    - [readinto, BufferedIOBase.readinto.__qualname__.__len__, [], 24]

# ---------------------------------------------------------------------------
# TextIOBase ABC method __qualname__.__len__() — read, readline, write
#
# io.TextIOBase methods carry the _TextIOBase prefix (11 chars).
# No prior io spec checks __qualname__.__len__() for any TextIOBase method.
#
#   TextIOBase.read     -> '_TextIOBase.read'     -> 16
#   TextIOBase.readline -> '_TextIOBase.readline' -> 20
#   TextIOBase.write    -> '_TextIOBase.write'    -> 17
# ---------------------------------------------------------------------------

table io_extra40.TextIOBase_method_qualname_lens:
  description: "io.TextIOBase method __qualname__.__len__() — read(16)/readline(20)/write(17); all carry _TextIOBase C-level prefix"
  kind: python_call_eq
  category: method_identity
  id_prefix: tibmq40

  columns: [id, function, args, expected]
  rows:
    - [read,     TextIOBase.read.__qualname__.__len__,     [], 16]
    - [readline, TextIOBase.readline.__qualname__.__len__, [], 20]
    - [write,    TextIOBase.write.__qualname__.__len__,    [], 17]
