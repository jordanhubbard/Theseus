spec: abc_extra1726
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "Theme: which abc stdlib types define __lt__, __le__, __gt__, __ge__, __ne__ in their own __dict__."
    - "abc.ABCMeta: metaclass; no comparison operators defined in its own __dict__. ABCMeta inherits from type; type defines __eq__ but ABCMeta does NOT put __eq__ in its own __dict__ -> all False."
    - "abc.ABC: plain helper class with no instance state; no comparison operators in own __dict__ -> all False."
    - "abc.abstractmethod: decorator class; no comparison operators in own __dict__ -> all False."
    - "Note: abc.ABCMeta.__eq__ might resolve via inheritance from type, but it is NOT defined in ABCMeta's own __dict__ — the key check here is __dict__.__contains__, which only looks at the class's own namespace."
    - "Cross-check: __eq__ is absent from ABCMeta's own __dict__ (inherited from type, not redefined by ABCMeta) -> False."
    - "Cross-check: __hash__ is absent from ABCMeta's own __dict__ -> False."
    - "Cross-check: ABC.__dict__ contains neither __eq__ nor __hash__ -> both False."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: comparison operator dict-presence checks (__lt__, __le__, __gt__, __ge__, __ne__)
#
# Wave 562 theme: do abc types define ordering/comparison dunders in their own
# __dict__? ABCMeta is a metaclass for abstract base classes; its purpose is to
# track abstract methods and virtual subclasses, not to order class objects.
# ABC is a helper class providing a convenient syntax for defining ABCs; it
# adds no ordering semantics. abstractmethod is a decorator that marks methods
# abstract; it carries no ordering protocol. All checks return False.
#
# Important: the check is __dict__.__contains__ — it inspects the class's own
# namespace only. Even if ABCMeta instances (i.e., classes created with ABCMeta
# as their metaclass) were orderable, that would be about instance behavior, not
# what is in ABCMeta's own __dict__.
# ---------------------------------------------------------------------------

table abc_extra1726.comparison_protocol:
  description: "abc types: __lt__, __le__, __gt__, __ge__, __ne__ dict-presence checks (all False — no ordering semantics)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1726

  columns: [id, function, args, expected]
  rows:
    - ["ab1726001", "ABCMeta.__dict__.__contains__",        ["__lt__"], false]
    - ["ab1726002", "ABCMeta.__dict__.__contains__",        ["__le__"], false]
    - ["ab1726003", "ABCMeta.__dict__.__contains__",        ["__gt__"], false]
    - ["ab1726004", "ABCMeta.__dict__.__contains__",        ["__ge__"], false]
    - ["ab1726005", "ABCMeta.__dict__.__contains__",        ["__ne__"], false]
    - ["ab1726006", "ABC.__dict__.__contains__",            ["__lt__"], false]
    - ["ab1726007", "ABC.__dict__.__contains__",            ["__le__"], false]
    - ["ab1726008", "ABC.__dict__.__contains__",            ["__gt__"], false]
    - ["ab1726009", "ABC.__dict__.__contains__",            ["__ge__"], false]
    - ["ab1726010", "ABC.__dict__.__contains__",            ["__ne__"], false]

# ---------------------------------------------------------------------------
# Table 2: __eq__ and __hash__ dict-presence cross-checks
#
# Wave 562 cross-check: __eq__ and __hash__ are not defined in the own __dict__
# of ABCMeta, ABC, or abstractmethod. ABCMeta inherits __eq__ from type (which
# uses identity for class objects), but ABCMeta itself does not define __eq__
# in its own __dict__ — there is no reason for it to override class equality.
# ABC inherits __eq__ from object via ABCMeta's metaclass chain; it does not
# define __eq__ in its own __dict__. abstractmethod is a plain decorator class
# and likewise inherits __eq__ from object without defining it in its own __dict__.
# ---------------------------------------------------------------------------

table abc_extra1726.eq_hash_protocol:
  description: "abc types: __eq__ and __hash__ dict-presence cross-check (all inherited — not in own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1726

  columns: [id, function, args, expected]
  rows:
    - ["ab1726011", "ABCMeta.__dict__.__contains__",          ["__eq__"],   false]
    - ["ab1726012", "ABCMeta.__dict__.__contains__",          ["__hash__"], false]
    - ["ab1726013", "ABC.__dict__.__contains__",              ["__eq__"],   false]
    - ["ab1726014", "ABC.__dict__.__contains__",              ["__hash__"], false]
    - ["ab1726015", "abstractmethod.__dict__.__contains__",   ["__eq__"],   false]
    - ["ab1726016", "abstractmethod.__dict__.__contains__",   ["__hash__"], false]

# ---------------------------------------------------------------------------
# Table 3: abstractmethod ordering operators and additional cross-checks
#
# Wave 562 extension: extend the comparison/ordering protocol checks to
# abstractmethod and add __ne__ cross-checks for abstractmethod. abstractmethod
# is a decorator class whose sole purpose is to mark a method as abstract and
# store the wrapped function. It has no ordering semantics. Confirm that __lt__,
# __le__, __gt__, __ge__, and __ne__ are all absent from abstractmethod's own
# __dict__, and that ABCMeta's own __dict__ also lacks __ne__. The full picture:
# no abc type defines any ordering dunder in its own __dict__.
# ---------------------------------------------------------------------------

table abc_extra1726.abstractmethod_comparison_protocol:
  description: "abc.abstractmethod and ABCMeta: ordering operator dict-presence and __ne__ cross-checks (all False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1726

  columns: [id, function, args, expected]
  rows:
    - ["ab1726017", "abstractmethod.__dict__.__contains__", ["__lt__"], false]
    - ["ab1726018", "abstractmethod.__dict__.__contains__", ["__le__"], false]
    - ["ab1726019", "abstractmethod.__dict__.__contains__", ["__gt__"], false]
    - ["ab1726020", "abstractmethod.__dict__.__contains__", ["__ge__"], false]
    - ["ab1726021", "abstractmethod.__dict__.__contains__", ["__ne__"], false]
    - ["ab1726022", "ABCMeta.__dict__.__contains__",        ["__lt__"], false]
    - ["ab1726023", "ABCMeta.__dict__.__contains__",        ["__gt__"], false]
    - ["ab1726024", "ABC.__dict__.__contains__",            ["__lt__"], false]
    - ["ab1726025", "ABC.__dict__.__contains__",            ["__gt__"], false]
