spec: hashlib_extra78
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra77.zspec.zsdl — covers blake2b/__name__/__module__/__bases__[0]/__mro__.__len__()/__dict__.__class__/__name__ / blake2s/__name__/__module__/__bases__[0]/__mro__.__len__() / blake2b/__doc__.__class__.__name__ (table + invariants)."
    - "hashlib_extra76.zspec.zsdl — covers file_digest/__code__/co_argcount/__eq__(2) / sha3_256/__qualname__=='openssl_sha3_256' / blake2b/__qualname__=='blake2b' / blake2s/__qualname__=='blake2s' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra77; it does NOT duplicate invariants present in those files."
    - "Wave 242 theme: hashlib sha3 family and shake class identity."
    - "hashlib.sha3_256.__module__ == '_hashlib' — sha3_256 is defined in the _hashlib C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method' — sha3_256 is a C builtin callable. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__class__.__name__ == 'builtin_function_or_method' — sha3_512 is a C builtin callable. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__module__ == '_hashlib' — sha3_512 is in the _hashlib extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__class__.__name__ == 'builtin_function_or_method' — sha3_224 is a C builtin callable. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__class__.__name__ == 'builtin_function_or_method' — sha3_384 is a C builtin callable. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__module__ == '_hashlib' — shake_128 is defined in the _hashlib extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__class__.__name__ == 'builtin_function_or_method' — shake_256 is a C builtin callable. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__module__ == '_hashlib' — shake_256 is defined in the _hashlib extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_256 and sha3_512 __module__ identity
#
# Wave 242 theme: hashlib sha3 family class identity.
#
# hashlib.sha3_256 and sha3_512 are both defined in the _hashlib C extension
# module. Their __module__ attribute is '_hashlib'. No prior hashlib spec
# checks sha3_256.__module__ or sha3_512.__module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra78.sha3_256_sha3_512_module:
  description: "hashlib.sha3_256/__module__.__eq__('_hashlib')==True / sha3_512/__module__.__eq__('_hashlib')==True — sha3_256 and sha3_512 are both C builtins in the _hashlib extension; no prior hashlib spec checks sha3_256.__module__ or sha3_512.__module__; first __module__ anchor for sha3_256 and sha3_512"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore78

  columns: [id, function, args, expected]
  rows:
    - [sha3_256_module_hashlib, sha3_256.__module__.__eq__, ["_hashlib"], true]
    - [sha3_512_module_hashlib, sha3_512.__module__.__eq__, ["_hashlib"], true]

# ---------------------------------------------------------------------------
# hashlib.sha3_224 and sha3_384 __class__.__name__
#
# Wave 242 theme: hashlib sha3 family class identity (224 and 384 variants).
#
# hashlib.sha3_224 and sha3_384 are C builtins; their __class__.__name__ is
# 'builtin_function_or_method'. No prior hashlib spec checks sha3_224.__class__.__name__
# or sha3_384.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra78.sha3_224_sha3_384_class_name:
  description: "hashlib.sha3_224/__class__/__name__.__eq__('builtin_function_or_method')==True / sha3_384/__class__/__name__.__eq__('builtin_function_or_method')==True — sha3_224 and sha3_384 are C builtin callables; no prior hashlib spec checks sha3_224.__class__.__name__ or sha3_384.__class__.__name__; first __class__.__name__ anchor for sha3_224 and sha3_384"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore78

  columns: [id, function, args, expected]
  rows:
    - [sha3_224_class_builtin, sha3_224.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sha3_384_class_builtin, sha3_384.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.shake_128 and shake_256 __module__ identity
#
# Wave 242 theme: hashlib shake class identity.
#
# hashlib.shake_128 and shake_256 are both defined in the _hashlib C extension.
# Their __module__ is '_hashlib'. No prior hashlib spec checks shake_128.__module__
# or shake_256.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra78.shake_128_shake_256_module:
  description: "hashlib.shake_128/__module__.__eq__('_hashlib')==True / shake_256/__module__.__eq__('_hashlib')==True — shake_128 and shake_256 are C builtins in the _hashlib extension; no prior hashlib spec checks shake_128.__module__ or shake_256.__module__; first __module__ anchor for shake_128 and shake_256"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore78

  columns: [id, function, args, expected]
  rows:
    - [shake_128_module_hashlib, shake_128.__module__.__eq__, ["_hashlib"], true]
    - [shake_256_module_hashlib, shake_256.__module__.__eq__, ["_hashlib"], true]

# ---------------------------------------------------------------------------
# hashlib.sha3_256 __class__.__name__ + sha3_512 __class__.__name__ + shake_256 __class__.__name__
#
# Wave 242 theme: sha3/shake __class__.__name__ cross-check.
#
# sha3_256, sha3_512, and shake_256 all have __class__.__name__ equal to
# 'builtin_function_or_method'. No prior hashlib spec checks sha3_256.__class__.__name__
# or sha3_512.__class__.__name__ or shake_256.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra78.sha3_shake_class_name_cross:
  description: "hashlib.sha3_256/__class__/__name__.__eq__('builtin_function_or_method')==True / sha3_512/__class__/__name__.__eq__('builtin_function_or_method')==True / shake_256/__class__/__name__.__eq__('builtin_function_or_method')==True — sha3_256, sha3_512, and shake_256 are all C builtin callables; no prior hashlib spec checks these class names; first cross-check anchor for sha3_256/sha3_512/shake_256 class identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore78

  columns: [id, function, args, expected]
  rows:
    - [sha3_256_class_builtin, sha3_256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sha3_512_class_builtin, sha3_512.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [shake_256_class_builtin, shake_256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha3_256.__module__ is '_hashlib'. No prior hashlib spec checks
# sha3_256.__module__. First __module__ standalone for sha3_256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra78.sha3_256_module_hashlib:
  description: "hashlib.sha3_256.__module__.__eq__('_hashlib') == True — sha3_256 is defined in the _hashlib C extension; no prior hashlib spec checks sha3_256.__module__; first __module__ standalone for sha3_256"
  category: class_identity
  kind: python_call_eq
  function: sha3_256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.sha3_256.__class__.__name__ is 'builtin_function_or_method'. No prior
# hashlib spec checks sha3_256.__class__.__name__. First class name standalone
# for sha3_256. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra78.sha3_256_class_builtin:
  description: "hashlib.sha3_256.__class__.__name__.__eq__('builtin_function_or_method') == True — sha3_256 is a C builtin callable; no prior hashlib spec checks sha3_256.__class__.__name__; first class name standalone for sha3_256"
  category: class_identity
  kind: python_call_eq
  function: sha3_256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

