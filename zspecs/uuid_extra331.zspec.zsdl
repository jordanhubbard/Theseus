spec: uuid_extra331
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.__name__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__package__ == '' (empty string — uuid is a top-level module, not a package). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.name == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__doc__.__len__() == 1948. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS == 'reserved for NCS compatibility'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122 == 'specified in RFC 4122'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE == 'reserved for future definition'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The four variant string constants (RESERVED_NCS, RFC_4122, RESERVED_MICROSOFT, RESERVED_FUTURE) are plain str module-level attributes used to describe UUID variant fields. They are not enum members."
    - "Note: uuid.__doc__.__len__()==1948 was confirmed in prior work and re-verified here."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.__name__.__eq__('uuid')
# uuid.__package__.__eq__('')
# uuid.__spec__.name.__eq__('uuid')
# uuid.__doc__.__class__.__name__.__eq__('str')
# uuid.__doc__.__len__()==1948
#
# Wave 331 theme: uuid module-level identity and doc attributes.
#
# uuid.__name__ is 'uuid' — the canonical module name. uuid.__package__ is ''
# confirming uuid is a top-level module. uuid.__spec__.name is 'uuid'.
# uuid.__doc__.__class__.__name__ is 'str' — the module has a docstring.
# uuid.__doc__.__len__() is 1948 — the docstring describes UUID versions 1-5,
# the UUID class, namespace UUIDs, and helper functions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra331.module_identity_attrs:
  description: "uuid.__name__.__eq__('uuid')==True / __package__.__eq__('')==True / __spec__.name.__eq__('uuid')==True / __doc__.__class__.__name__.__eq__('str')==True / __doc__.__len__()==1948 — uuid is a top-level module (__package__==''); __spec__.name matches __name__; __doc__ is a 1948-char str; first uuidid331 anchor for module identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: uuidid331

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      "__name__.__eq__",               ["uuid"], true, "uuid.__name__ is 'uuid' — canonical module name"]
    - [package_eq,   "__package__.__eq__",            [""],     true, "uuid.__package__ is '' (empty string) — uuid is a top-level module, not a subpackage"]
    - [spec_name_eq, "__spec__.name.__eq__",          ["uuid"], true, "uuid.__spec__.name is 'uuid' — ModuleSpec name matches __name__"]
    - [doc_class_eq, "__doc__.__class__.__name__.__eq__", ["str"], true, "uuid.__doc__.__class__.__name__ is 'str' — module has a docstring"]
    - [doc_len,      __doc__.__len__,                 [],       1948, "uuid.__doc__.__len__() is 1948 — describes UUID versions 1-5, class, namespace UUIDs, helper functions"]

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS.__class__.__name__.__eq__('str')
# uuid.RESERVED_NCS.__eq__('reserved for NCS compatibility')
# uuid.RFC_4122.__class__.__name__.__eq__('str')
# uuid.RFC_4122.__eq__('specified in RFC 4122')
# uuid.RESERVED_MICROSOFT.__class__.__name__.__eq__('str')
#
# Wave 331 theme: uuid variant string constants — RESERVED_NCS, RFC_4122,
# RESERVED_MICROSOFT.
#
# RESERVED_NCS is a module-level str constant: 'reserved for NCS compatibility'.
# RFC_4122 is: 'specified in RFC 4122'. RESERVED_MICROSOFT is:
# 'reserved for Microsoft compatibility'. These describe the UUID variant bits.
# They are plain str attributes, not enum members. The UUID.variant property
# returns one of these four string constants.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra331.variant_constants_ncs_rfc_ms:
  description: "uuid.RESERVED_NCS/__class__.__name__.__eq__('str')==True / RESERVED_NCS.__eq__('reserved for NCS compatibility')==True / RFC_4122/__class__.__name__.__eq__('str')==True / RFC_4122.__eq__('specified in RFC 4122')==True / RESERVED_MICROSOFT/__class__.__name__.__eq__('str')==True — three of the four UUID variant string constants; plain str module-level attributes used by UUID.variant property; not enum members; first uuidid331 anchor for variant constants"
  kind: python_call_eq
  category: variant_constants
  id_prefix: uuidid331

  columns: [id, function, args, expected, description]
  rows:
    - [reserved_ncs_class,   "RESERVED_NCS.__class__.__name__.__eq__",      ["str"],                              true, "uuid.RESERVED_NCS is a str (not an enum member)"]
    - [reserved_ncs_eq,      "RESERVED_NCS.__eq__",                         ["reserved for NCS compatibility"],   true, "uuid.RESERVED_NCS == 'reserved for NCS compatibility'"]
    - [rfc_4122_class,       "RFC_4122.__class__.__name__.__eq__",          ["str"],                              true, "uuid.RFC_4122 is a str (not an enum member)"]
    - [rfc_4122_eq,          "RFC_4122.__eq__",                             ["specified in RFC 4122"],            true, "uuid.RFC_4122 == 'specified in RFC 4122'"]
    - [reserved_ms_class,    "RESERVED_MICROSOFT.__class__.__name__.__eq__", ["str"],                             true, "uuid.RESERVED_MICROSOFT is a str (not an enum member)"]

# ---------------------------------------------------------------------------
# uuid.RESERVED_MICROSOFT.__eq__('reserved for Microsoft compatibility')
# uuid.RESERVED_FUTURE.__class__.__name__.__eq__('str')
# uuid.RESERVED_FUTURE.__eq__('reserved for future definition')
#
# Wave 331 theme: uuid variant string constants — RESERVED_MICROSOFT value
# and RESERVED_FUTURE.
#
# RESERVED_MICROSOFT value is 'reserved for Microsoft compatibility' —
# the variant used by COM/DCOM (Microsoft) UUIDs. RESERVED_FUTURE is
# 'reserved for future definition' — the remaining variant value.
# Together with RESERVED_NCS and RFC_4122, these four constants cover all
# possible UUID variant bit patterns as described in RFC 4122 §4.1.1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra331.variant_constants_ms_future:
  description: "uuid.RESERVED_MICROSOFT.__eq__('reserved for Microsoft compatibility')==True / RESERVED_FUTURE/__class__.__name__.__eq__('str')==True / RESERVED_FUTURE.__eq__('reserved for future definition')==True — RESERVED_MICROSOFT covers COM/DCOM variant; RESERVED_FUTURE is the catch-all remaining variant; together with RESERVED_NCS and RFC_4122 these four str constants cover all UUID variant bit patterns (RFC 4122 §4.1.1); first uuidid331 anchor for RESERVED_MICROSOFT value and RESERVED_FUTURE"
  kind: python_call_eq
  category: variant_constants
  id_prefix: uuidid331

  columns: [id, function, args, expected, description]
  rows:
    - [reserved_ms_eq,      "RESERVED_MICROSOFT.__eq__",                    ["reserved for Microsoft compatibility"], true, "uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility'"]
    - [reserved_future_class, "RESERVED_FUTURE.__class__.__name__.__eq__",  ["str"],                                 true, "uuid.RESERVED_FUTURE is a str (not an enum member)"]
    - [reserved_future_eq,  "RESERVED_FUTURE.__eq__",                       ["reserved for future definition"],      true, "uuid.RESERVED_FUTURE == 'reserved for future definition'"]

# ---------------------------------------------------------------------------
# uuid.__name__.__eq__('uuid') — standalone
#
# uuid.__name__ is 'uuid'. This is the canonical module name assigned by
# the Python import system. For standard library modules, __name__ equals
# the module filename stem and the ModuleSpec name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra331.name_is_uuid:
  description: "uuid.__name__.__eq__('uuid') == True — uuid.__name__ is the canonical module name 'uuid', matching its filename stem and ModuleSpec name; first standalone for uuid.__name__ under uuidid331"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__doc__.__len__()==1948 — standalone
#
# uuid.__doc__.__len__() is 1948. The uuid module docstring describes the
# UUID class, uuid1/uuid3/uuid4/uuid5 constructor functions, the namespace
# UUID constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500),
# and the getnode() function. At 1948 chars it is a moderately detailed
# module-level docstring.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra331.doc_len_1948:
  description: "uuid.__doc__.__len__() == 1948 — uuid module docstring is 1948 chars; describes the UUID class, uuid1/3/4/5 functions, namespace UUID constants, and getnode(); moderately detailed module-level docstring; first standalone for uuid.__doc__.__len__() under uuidid331"
  category: module_identity
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1948

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS.__eq__('reserved for NCS compatibility') — standalone
#
# uuid.RESERVED_NCS is 'reserved for NCS compatibility'. NCS (Network
# Computing System) was the precursor UUID variant before RFC 4122. The
# NCS variant uses the most-significant bit of the clock-seq-and-reserved
# field set to 0. UUIDs generated by older NCS systems use this variant.
# RESERVED_NCS is a plain str constant used by UUID.variant to label such UUIDs.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra331.RESERVED_NCS_eq:
  description: "uuid.RESERVED_NCS.__eq__('reserved for NCS compatibility') == True — RESERVED_NCS is the variant label for pre-RFC-4122 NCS UUIDs (MSB of clock-seq byte is 0); plain str constant returned by UUID.variant for NCS-variant UUIDs; first standalone for RESERVED_NCS value under uuidid331"
  category: variant_constants
  kind: python_call_eq
  function: RESERVED_NCS.__eq__
  args: ["reserved for NCS compatibility"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RFC_4122.__eq__('specified in RFC 4122') — standalone
#
# uuid.RFC_4122 is 'specified in RFC 4122'. This is the variant for standard
# UUIDs as defined by RFC 4122. All UUIDs generated by uuid1/uuid3/uuid4/uuid5
# use this variant (bits 10 in the most-significant bits of the variant field).
# RFC_4122 is a plain str constant used by UUID.variant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra331.RFC_4122_eq:
  description: "uuid.RFC_4122.__eq__('specified in RFC 4122') == True — RFC_4122 is the variant label for standard RFC 4122 UUIDs (bits '10' in variant field); all uuid1/3/4/5-generated UUIDs use this variant; plain str constant returned by UUID.variant; first standalone for RFC_4122 value under uuidid331"
  category: variant_constants
  kind: python_call_eq
  function: RFC_4122.__eq__
  args: ["specified in RFC 4122"]
  expected: true
