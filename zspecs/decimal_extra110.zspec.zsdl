spec: decimal_extra110
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra109.zspec.zsdl."
    - "This spec covers: decimal.Context class method qualname STRING EQUALITY for six novel methods: create_decimal_from_float, clear_traps, Etiny, Etop, radix, and rotate."
    - "No prior decimal spec covers any of create_decimal_from_float, clear_traps, Etiny, Etop, radix, or rotate in any qualname context."
    - "Context.create_decimal_from_float.__qualname__ == 'Context.create_decimal_from_float' (len 33); longest Context method qualname."
    - "Context.clear_traps.__qualname__ == 'Context.clear_traps' (len 19); type 'method_descriptor'."
    - "Context.Etiny.__qualname__ == 'Context.Etiny' (len 13); type 'method_descriptor'."
    - "Context.Etop.__qualname__ == 'Context.Etop' (len 12); type 'method_descriptor'."
    - "Context.radix.__qualname__ == 'Context.radix' (len 13); type 'method_descriptor'."
    - "Context.rotate.__qualname__ == 'Context.rotate' (len 14); type 'method_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context.create_decimal_from_float and decimal.Context.clear_traps qualnames
# create_decimal_from_float: 'Context.create_decimal_from_float' (33 chars).
#   This is the longest Context method qualname in the entire decimal module.
#   It converts a Python float to a Decimal using the context's precision.
# clear_traps: 'Context.clear_traps' (19 chars); type 'method_descriptor'.
#   Resets all trap signals to zero (disabling exceptions for all signals).
#   decimal_extra97 covered Context.clear_flags.__qualname__ (19 chars);
#   clear_traps has the same length 19 but is distinct.
# No prior decimal spec covers either method in any qualname context.
# ---------------------------------------------------------------------------

table decimal_extra110.Context_create_decimal_from_float_clear_traps_qualnames:
  description: "decimal.Context.create_decimal_from_float qualname='Context.create_decimal_from_float'(33) longest Context method; Context.clear_traps qualname='Context.clear_traps'(19); both type 'method_descriptor'; no prior spec covers either"
  kind: python_call_eq
  category: qualnames
  id_prefix: decctx110a

  columns: [id, function, args, expected, description]
  rows:
    - [cdf_type,     "Context.create_decimal_from_float.__class__.__name__.__eq__",  ["method_descriptor"],                    true,  "type(decimal.Context.create_decimal_from_float).__name__ == 'method_descriptor' (C extension method)"]
    - [cdf_qn_eq,    "Context.create_decimal_from_float.__qualname__.__eq__",        ["Context.create_decimal_from_float"],     true,  "decimal.Context.create_decimal_from_float.__qualname__ == 'Context.create_decimal_from_float' (33 chars; converts float to Decimal using context precision)"]
    - [cdf_qn_len,   "Context.create_decimal_from_float.__qualname__.__len__",       [],                                        33,    "decimal.Context.create_decimal_from_float.__qualname__.__len__() == 33 ('Context.'(8)+'create_decimal_from_float'(25)==33; longest Context method qualname)"]
    - [ct_type,      "Context.clear_traps.__class__.__name__.__eq__",                ["method_descriptor"],                    true,  "type(decimal.Context.clear_traps).__name__ == 'method_descriptor' (C extension method)"]
    - [ct_qn_eq,     "Context.clear_traps.__qualname__.__eq__",                      ["Context.clear_traps"],                  true,  "decimal.Context.clear_traps.__qualname__ == 'Context.clear_traps' (19 chars; resets all trap signals to zero, disabling exceptions for all signals)"]
    - [ct_qn_len,    "Context.clear_traps.__qualname__.__len__",                     [],                                        19,    "decimal.Context.clear_traps.__qualname__.__len__() == 19 ('Context.'(8)+'clear_traps'(11)==19)"]
    - [cdf_gt_ct,    "Context.create_decimal_from_float.__qualname__.__len__.__gt__", [19],                                    true,  "len('Context.create_decimal_from_float') > len('Context.clear_traps') (33 > 19; create_decimal_from_float is the longest)"]
    - [cdf_ne_ct,    "Context.create_decimal_from_float.__qualname__.__eq__",        ["Context.clear_traps"],                  false, "decimal.Context.create_decimal_from_float.__qualname__ != 'Context.clear_traps' (distinct names: different purpose and length)"]

# ---------------------------------------------------------------------------
# decimal.Context.Etiny and decimal.Context.Etop qualnames
# Etiny: 'Context.Etiny' (13 chars); type 'method_descriptor'.
#   Returns the minimum exponent value Etiny() for the current context.
#   Etiny = Emin - (prec - 1); represents the minimum adjusted exponent
#   for subnormal results.
# Etop: 'Context.Etop' (12 chars); type 'method_descriptor'.
#   Returns the maximum exponent value Etop() for the current context.
#   Etop = Emax - (prec - 1); used in scaled arithmetic.
# No prior decimal spec covers either Etiny or Etop in any qualname context.
# ---------------------------------------------------------------------------

table decimal_extra110.Context_Etiny_Etop_qualnames:
  description: "decimal.Context.Etiny qualname='Context.Etiny'(13) type='method_descriptor'; Context.Etop qualname='Context.Etop'(12) type='method_descriptor'; Etiny returns min adjusted exponent for subnormals; Etop returns max exponent for scaled arithmetic"
  kind: python_call_eq
  category: qualnames
  id_prefix: decctx110b

  columns: [id, function, args, expected, description]
  rows:
    - [etiny_type,   "Context.Etiny.__class__.__name__.__eq__",   ["method_descriptor"],  true,  "type(decimal.Context.Etiny).__name__ == 'method_descriptor' (C extension method; computes minimum adjusted exponent Emin-(prec-1))"]
    - [etiny_qn_eq,  "Context.Etiny.__qualname__.__eq__",         ["Context.Etiny"],      true,  "decimal.Context.Etiny.__qualname__ == 'Context.Etiny' (13 chars; method not attribute; returns Emin-(prec-1) as integer)"]
    - [etiny_qn_len, "Context.Etiny.__qualname__.__len__",        [],                     13,    "decimal.Context.Etiny.__qualname__.__len__() == 13 ('Context.'(8)+'Etiny'(5)==13)"]
    - [etop_type,    "Context.Etop.__class__.__name__.__eq__",    ["method_descriptor"],  true,  "type(decimal.Context.Etop).__name__ == 'method_descriptor' (C extension method; computes maximum exponent Emax-(prec-1))"]
    - [etop_qn_eq,   "Context.Etop.__qualname__.__eq__",          ["Context.Etop"],       true,  "decimal.Context.Etop.__qualname__ == 'Context.Etop' (12 chars; method not attribute; returns Emax-(prec-1) as integer)"]
    - [etop_qn_len,  "Context.Etop.__qualname__.__len__",         [],                     12,    "decimal.Context.Etop.__qualname__.__len__() == 12 ('Context.'(8)+'Etop'(4)==12)"]
    - [etiny_gt_etop, "Context.Etiny.__qualname__.__len__.__gt__", [12],                  true,  "len('Context.Etiny') > len('Context.Etop') (13 > 12; Etiny is one char longer due to 'iny' vs 'op')"]
    - [etiny_ne_etop, "Context.Etiny.__qualname__.__eq__",        ["Context.Etop"],       false, "decimal.Context.Etiny.__qualname__ != 'Context.Etop' (distinct qualnames; Etiny computes minimum, Etop computes maximum exponent)"]

# ---------------------------------------------------------------------------
# decimal.Context.radix and decimal.Context.rotate qualnames
# radix: 'Context.radix' (13 chars); type 'method_descriptor'.
#   Returns the radix (base) of the decimal arithmetic — always 10.
#   Defined by the IEEE 754 specification.
# rotate: 'Context.rotate' (14 chars); type 'method_descriptor'.
#   Rotates the digits of the first operand by the number given by the second.
# No prior decimal spec covers either radix or rotate in any qualname context.
# ---------------------------------------------------------------------------

table decimal_extra110.Context_radix_rotate_qualnames:
  description: "decimal.Context.radix qualname='Context.radix'(13) type='method_descriptor'; Context.rotate qualname='Context.rotate'(14) type='method_descriptor'; radix always returns 10; rotate shifts digits cyclically"
  kind: python_call_eq
  category: qualnames
  id_prefix: decctx110c

  columns: [id, function, args, expected, description]
  rows:
    - [rdx_type,    "Context.radix.__class__.__name__.__eq__",    ["method_descriptor"],  true,  "type(decimal.Context.radix).__name__ == 'method_descriptor' (C extension method; always returns Decimal('10') per IEEE 754)"]
    - [rdx_qn_eq,   "Context.radix.__qualname__.__eq__",          ["Context.radix"],      true,  "decimal.Context.radix.__qualname__ == 'Context.radix' (13 chars; 'Context.'(8)+'radix'(5)==13; returns 10 as the base of decimal arithmetic)"]
    - [rdx_qn_len,  "Context.radix.__qualname__.__len__",         [],                     13,    "decimal.Context.radix.__qualname__.__len__() == 13 ('Context.radix' has 13 chars; same length as Context.Etiny and Context.power)"]
    - [rot_type,    "Context.rotate.__class__.__name__.__eq__",   ["method_descriptor"],  true,  "type(decimal.Context.rotate).__name__ == 'method_descriptor' (C extension method; rotates digits of first arg by count given by second arg)"]
    - [rot_qn_eq,   "Context.rotate.__qualname__.__eq__",         ["Context.rotate"],     true,  "decimal.Context.rotate.__qualname__ == 'Context.rotate' (14 chars; 'Context.'(8)+'rotate'(6)==14; rotates decimal digits cyclically)"]
    - [rot_qn_len,  "Context.rotate.__qualname__.__len__",        [],                     14,    "decimal.Context.rotate.__qualname__.__len__() == 14 ('Context.rotate' has 14 chars; same length as Context.divide and Context.is_nan)"]
    - [rot_gt_rdx,  "Context.rotate.__qualname__.__len__.__gt__", [13],                   true,  "len('Context.rotate') > len('Context.radix') (14 > 13; rotate is one char longer than radix)"]
    - [rdx_eq_etiny_len, "Context.radix.__qualname__.__len__.__eq__", [13],               true,  "len('Context.radix') == len('Context.Etiny') == 13 (radix and Etiny share identical qualname length)"]
    - [rdx_ne_rot,  "Context.radix.__qualname__.__eq__",          ["Context.rotate"],     false, "decimal.Context.radix.__qualname__ != 'Context.rotate' (distinct qualnames; radix(13) returns base, rotate(14) shifts digits)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra110.Context.create_decimal_from_float_qualname_eq:
  description: "decimal.Context.create_decimal_from_float.__qualname__ == 'Context.create_decimal_from_float' (length 33; type is 'method_descriptor'; 'Context.'(8)+'create_decimal_from_float'(25)==33; this is the longest Context method qualname in the decimal module, surpassing to_integral_value(25) and to_integral_exact(25) from decimal_extra32; create_decimal_from_float converts a Python float to a Decimal using the context's precision, equivalent to calling Decimal.from_float(f) but with the active context applied; no prior decimal spec covers this method)"
  category: qualnames
  kind: python_call_eq
  function: "Context.create_decimal_from_float.__qualname__.__eq__"
  args: ["Context.create_decimal_from_float"]
  expected: true

invariant decimal_extra110.Context.clear_traps_qualname_eq:
  description: "decimal.Context.clear_traps.__qualname__ == 'Context.clear_traps' (length 19; type is 'method_descriptor'; 'Context.'(8)+'clear_traps'(11)==19; clear_traps() resets all trap signals in the context to zero, meaning arithmetic operations will produce special values (NaN, Infinity) rather than raising exceptions; it is the counterpart to clear_flags() (also 19 chars, covered in decimal_extra97) — clear_flags clears the accumulated signal flags while clear_traps disables future exception trapping; no prior decimal spec covers clear_traps)"
  category: qualnames
  kind: python_call_eq
  function: "Context.clear_traps.__qualname__.__eq__"
  args: ["Context.clear_traps"]
  expected: true

invariant decimal_extra110.Context.Etiny_qualname_eq:
  description: "decimal.Context.Etiny.__qualname__ == 'Context.Etiny' (length 13; type is 'method_descriptor'; Etiny() returns the minimum adjusted exponent for subnormal numbers in the current context, computed as Emin - (prec - 1); for example with prec=28 and Emin=-999999999, Etiny() returns -999999999 - 27 == -1000000026; Etiny and Etop are the only Context methods with uppercase-starting names; no prior decimal spec covers Etiny in any qualname context)"
  category: qualnames
  kind: python_call_eq
  function: "Context.Etiny.__qualname__.__eq__"
  args: ["Context.Etiny"]
  expected: true

invariant decimal_extra110.Context.Etop_qualname_eq:
  description: "decimal.Context.Etop.__qualname__ == 'Context.Etop' (length 12; type is 'method_descriptor'; Etop() returns the maximum exponent for scaled arithmetic in the current context, computed as Emax - (prec - 1); for example with prec=28 and Emax=999999999, Etop() returns 999999999 - 27 == 999999972; Context.Etop at 12 chars is the same length as Context.Etop and Context.sqrt; Etop and Etiny are the only two Context methods that begin with an uppercase letter; no prior decimal spec covers Etop)"
  category: qualnames
  kind: python_call_eq
  function: "Context.Etop.__qualname__.__eq__"
  args: ["Context.Etop"]
  expected: true

invariant decimal_extra110.Context.radix_qualname_eq:
  description: "decimal.Context.radix.__qualname__ == 'Context.radix' (length 13; type is 'method_descriptor'; radix() always returns Decimal('10') for any context because the decimal module implements base-10 arithmetic per the IEEE 754 standard; the method exists for programmatic confirmation that the arithmetic base is 10; 'Context.'(8)+'radix'(5)==13; shares length 13 with Context.Etiny and Context.power; no prior decimal spec covers Context.radix in any qualname context)"
  category: qualnames
  kind: python_call_eq
  function: "Context.radix.__qualname__.__eq__"
  args: ["Context.radix"]
  expected: true
