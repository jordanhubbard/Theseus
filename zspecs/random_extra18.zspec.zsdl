spec: random_extra18
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra17.zspec.zsdl."
    - "random_extra16 covers Random.seed/random/randint/choice/shuffle/uniform __qualname__.__eq__ via class attribute path."
    - "random_extra17 covers Random.sample/gauss/normalvariate __qualname__.__eq__ via class attribute path."
    - "No prior spec records __qualname__.__len__ for any Random class method."
    - "No prior spec records random.__all__.__len__ or random.__all__.__class__.__name__.__len__."
    - "No prior spec records Random.__dict__.__class__.__name__.__len__ or SystemRandom.__dict__.__class__.__name__.__len__."
    - "No prior spec records __bases__[0].__name__.__len__ for Random or SystemRandom."
    - "random_extra15 covers Random.__bases__[0].__module__ and SystemRandom.__bases__[0].__module__, but NOT __name__.__len__."
    - "Random.__bases__[0].__name__ == 'Random' (the C-extension _random.Random) — len 6."
    - "SystemRandom.__bases__[0].__name__ == 'Random' (the pure-Python random.Random) — len 6."
    - "random.__all__.__len__() == 26; random.__all__.__class__.__name__ == 'list', len 4."
    - "Random.__dict__.__class__.__name__ == 'mappingproxy', len 12."
    - "NV_MAGICCONST is a float (len 5); BPF is an int (len 3)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# random.Random method __qualname__.__len__ via class attribute path
#
# random_extra16 covers seed/random/randint/choice/shuffle/uniform via
# __qualname__.__eq__. random_extra17 adds sample/gauss/normalvariate.
# No prior spec records the character length of any method's __qualname__.
# The qualname follows the pattern 'Random.<name>', so the length is
# len('Random.') + len(name) == 7 + len(name).
# ---------------------------------------------------------------------------

table random_extra18.class_method_qualname_lens:
  description: "__qualname__.__len__ for random.Random methods via class attribute path"
  kind: python_call_eq
  category: function_identity
  id_prefix: rmqlen18

  columns: [id, function, args, expected, description]
  rows:
    - [seed,        "Random.seed.__qualname__.__len__",        [], 11, "len('Random.seed') == 11"]
    - [random,      "Random.random.__qualname__.__len__",      [], 13, "len('Random.random') == 13"]
    - [randint,     "Random.randint.__qualname__.__len__",     [], 14, "len('Random.randint') == 14"]
    - [choice,      "Random.choice.__qualname__.__len__",      [], 13, "len('Random.choice') == 13"]
    - [shuffle,     "Random.shuffle.__qualname__.__len__",     [], 14, "len('Random.shuffle') == 14"]
    - [sample,      "Random.sample.__qualname__.__len__",      [], 13, "len('Random.sample') == 13"]
    - [uniform,     "Random.uniform.__qualname__.__len__",     [], 14, "len('Random.uniform') == 14"]
    - [gauss,       "Random.gauss.__qualname__.__len__",       [], 12, "len('Random.gauss') == 12"]
    - [randrange,   "Random.randrange.__qualname__.__len__",   [], 16, "len('Random.randrange') == 16"]
    - [getrandbits, "Random.getrandbits.__qualname__.__len__", [], 18, "len('Random.getrandbits') == 18"]

# ---------------------------------------------------------------------------
# random.__all__ metadata
#
# No prior spec covers random.__all__.__len__() or the class name of __all__.
# random.__all__ is a list with 26 entries; 'list' has 4 characters.
# ---------------------------------------------------------------------------

invariant random_extra18.all_len:
  description: "random.__all__.__len__() == 26 — the public API exports 26 names"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 26

invariant random_extra18.all_class_name_len:
  description: "random.__all__.__class__.__name__.__len__() == 4 — __all__ is a list, 'list' has 4 characters"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__ for Random and SystemRandom
#
# No prior random spec records __dict__.__class__.__name__.__len__ for
# either class. Both return 'mappingproxy' (12 characters).
# ---------------------------------------------------------------------------

invariant random_extra18.Random.dict_type_name_len:
  description: "random.Random.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  category: class_metadata
  kind: python_call_eq
  function: Random.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant random_extra18.SystemRandom.dict_type_name_len:
  description: "random.SystemRandom.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  category: class_metadata
  kind: python_call_eq
  function: SystemRandom.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__ for Random and SystemRandom
#
# random_extra15 covers __bases__[0].__module__ for both classes.
# No prior spec records __bases__[0].__name__.__len__.
# Random.__bases__[0] is _random.Random (C extension); its __name__ is 'Random'.
# SystemRandom.__bases__[0] is random.Random (pure Python); its __name__ is 'Random'.
# Both have __name__ 'Random', length 6.
# ---------------------------------------------------------------------------

invariant random_extra18.Random.base_name_len:
  description: "random.Random.__bases__[0].__name__.__len__() == 6 — C-extension base class name 'Random' has 6 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "Random.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant random_extra18.SystemRandom.base_name_len:
  description: "random.SystemRandom.__bases__[0].__name__.__len__() == 6 — pure-Python base class name 'Random' has 6 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "SystemRandom.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# NV_MAGICCONST and BPF constant type class name lengths
#
# No prior spec records __class__.__name__.__len__ for NV_MAGICCONST or BPF.
# random_extra12 confirms BPF.__class__.__name__.__eq__('int') == true.
# random_extra7 confirms RECIP_BPF.__class__.__name__ == 'float'.
# This spec records the character lengths: 'float' == 5, 'int' == 3.
# ---------------------------------------------------------------------------

invariant random_extra18.NV_MAGICCONST.class_name_len:
  description: "random.NV_MAGICCONST.__class__.__name__.__len__() == 5 — NV_MAGICCONST is a float, 'float' has 5 characters"
  category: constants
  kind: python_call_eq
  function: NV_MAGICCONST.__class__.__name__.__len__
  args: []
  expected: 5

invariant random_extra18.BPF.class_name_len:
  description: "random.BPF.__class__.__name__.__len__() == 3 — BPF is an int (53), 'int' has 3 characters"
  category: constants
  kind: python_call_eq
  function: BPF.__class__.__name__.__len__
  args: []
  expected: 3
