spec: struct_extra124
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra123.zspec.zsdl — covers Struct.pack/__objclass__/__module__.__eq__('_struct') / Struct.unpack/__objclass__/__module__.__eq__('_struct') / Struct.pack_into/__objclass__/__module__.__eq__('_struct') / Struct.pack/__objclass__/__qualname__.__eq__('Struct') / Struct.pack/__objclass__/__class__.__name__.__eq__('type') (table + invariants)."
    - "struct_extra122.zspec.zsdl — covers struct.error/__name__/__qualname__/__class__.__name__ equality / struct.error/__bases__[0]/__name__ / struct.error/__mro__/__len__()==4 / Struct/__name__/__qualname__/__class__.__name__ equality / Struct.size/format/__name__ equality (table + invariants)."
    - "struct_extra121.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__ string equality ('Struct.pack' etc.) / method __objclass__.__name__ equality (table + invariants)."
    - "struct_extra71.zspec.zsdl — covers Struct/__dict__/__contains__('__doc__') / Struct.__doc__/__contains__('fmt'/'Struct') / pack/unpack/calcsize/__doc__.__contains__('format') (table + invariants)."
    - "struct_extra70.zspec.zsdl — covers Struct/__dict__/__contains__('__init__'/'__new__'/'__repr__'/'__module__') (table + invariants)."
    - "struct_extra69.zspec.zsdl — covers Struct/__dict__/__contains__('__sizeof__') / Struct.size/__qualname__=='Struct.size' (table + invariants)."
    - "struct_extra65.zspec.zsdl — covers Struct/__dict__/__contains__ pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct_extra48.zspec.zsdl — covers Struct/error __dict__/__class__/__name__.__eq__('mappingproxy') and __qualname__/__module__ equality (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier struct specs."
    - "Wave 302 theme: Struct.__dict__ remaining key presence (__delattr__/__getattribute__/__setattr__) and struct.error.__dict__ key presence (__doc__/__module__/__weakref__)."
    - "struct.Struct.__dict__.__contains__('__delattr__') == True. Struct defines __delattr__ in its C extension class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__getattribute__') == True. Struct defines __getattribute__ in its C extension class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__setattr__') == True. Struct defines __setattr__ in its C extension class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__contains__('__doc__') == True. The error exception class has a docstring in its __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__contains__('__module__') == True. error stores its module name ('struct') in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__contains__('__weakref__') == True. error.__weakref__ getset_descriptor is in error.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__len__() == 3. The error exception class __dict__ contains exactly 3 keys: __doc__, __module__, __weakref__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__contains__('__init__') == False. error does NOT define __init__ in its own __dict__; it inherits __init__ from Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct.__dict__ has 17 keys total: pack/unpack/pack_into/unpack_from/iter_unpack (extra65), size/format (extra65), __sizeof__ (extra69), __init__/__new__/__repr__/__module__ (extra70), __doc__ (extra71), and the remaining three (__delattr__/__getattribute__/__setattr__) are anchored in this spec. This completes the coverage of all Struct.__dict__ keys."
    - "Note: error.__dict__ has only 3 keys (__doc__, __module__, __weakref__). error does NOT define __init__ in its own __dict__ — it inherits Exception.__init__. This is distinct from Struct which does define __init__ in its C-extension __dict__. No prior struct spec anchors error.__dict__ key presence at all."
    - "Note: error.__dict__.__len__()==3 is the smallest dict for any struct class — Struct has 17 keys while error has only 3. This reflects that error is a simple exception subclass with no additional methods beyond what it inherits from Exception."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__delattr__') == True
# struct.Struct.__dict__.__contains__('__getattribute__') == True
# struct.Struct.__dict__.__contains__('__setattr__') == True
#
# Wave 302 theme: Struct.__dict__ remaining key presence.
#
# The remaining uncovered Struct.__dict__ keys are __delattr__, __getattribute__,
# and __setattr__. These are C-level slot wrappers defined in the _struct.c
# extension for the Struct type. They are present in Struct.__dict__ as the
# C implementation of the attribute protocol for Struct objects. Extra specs 65,
# 69, 70, 71 cover all other Struct.__dict__ keys. This table completes the
# coverage. No prior struct spec anchors __delattr__/__getattribute__/__setattr__
# in Struct.__dict__ under structdict124.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra124.Struct_dict_attr_protocol:
  description: "struct.Struct/__dict__/__contains__('__delattr__')==True / Struct/__dict__/__contains__('__getattribute__')==True / Struct/__dict__/__contains__('__setattr__')==True — Struct defines all three attribute protocol methods as C-level slot wrappers in _struct.c; extra70 covers __init__/__new__/__repr__/__module__; extra69 covers __sizeof__; extra65 covers pack/unpack/size/format; these three complete Struct.__dict__ coverage; first structdict124 anchor"
  kind: python_call_eq
  category: dict_contents
  id_prefix: structdict124

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_dict_has_delattr,      "Struct.__dict__.__contains__", ["__delattr__"],      true, "Struct.__dict__.__contains__('__delattr__') is True; Struct defines __delattr__ as a C-level slot wrapper in _struct.c"]
    - [Struct_dict_has_getattribute, "Struct.__dict__.__contains__", ["__getattribute__"], true, "Struct.__dict__.__contains__('__getattribute__') is True; Struct defines __getattribute__ as a C-level slot wrapper"]
    - [Struct_dict_has_setattr,      "Struct.__dict__.__contains__", ["__setattr__"],      true, "Struct.__dict__.__contains__('__setattr__') is True; Struct defines __setattr__ as a C-level slot wrapper"]

# ---------------------------------------------------------------------------
# struct.error.__dict__.__contains__('__doc__') == True
# struct.error.__dict__.__contains__('__module__') == True
# struct.error.__dict__.__contains__('__weakref__') == True
# struct.error.__dict__.__len__() == 3
#
# Wave 302 theme: struct.error.__dict__ key presence and total count.
#
# struct.error is a simple exception subclass defined in the 'struct' Python
# module. Its __dict__ has exactly 3 keys: __doc__, __module__, and __weakref__.
# error does NOT define __init__ in its own __dict__ (inherits from Exception).
# This is the first spec to anchor any error.__dict__ key presence.
# No prior struct spec checks error.__dict__.__contains__ for any key.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra124.error_dict_keys:
  description: "struct.error/__dict__/__contains__('__doc__')==True / error/__dict__/__contains__('__module__')==True / error/__dict__/__contains__('__weakref__')==True / error/__dict__/__len__()==3 — error's __dict__ has exactly 3 keys; __doc__ is error's docstring (None); __module__ stores 'struct'; __weakref__ is a getset_descriptor; error does NOT define __init__ (inherits from Exception); no prior struct spec anchors any error.__dict__.__contains__; first structdict124 error dict anchor"
  kind: python_call_eq
  category: dict_contents
  id_prefix: structdict124

  columns: [id, function, args, expected, description]
  rows:
    - [error_dict_has_doc,      "error.__dict__.__contains__", ["__doc__"],      true, "error.__dict__.__contains__('__doc__') is True; error has a docstring (None) stored in its class __dict__"]
    - [error_dict_has_module,   "error.__dict__.__contains__", ["__module__"],   true, "error.__dict__.__contains__('__module__') is True; error.__module__ stores 'struct' (the Python module name)"]
    - [error_dict_has_weakref,  "error.__dict__.__contains__", ["__weakref__"],  true, "error.__dict__.__contains__('__weakref__') is True; error.__weakref__ is a getset_descriptor for weak reference support"]
    - [error_dict_len_3,        "error.__dict__.__len__",      [],               3,    "error.__dict__.__len__() is 3; error's class __dict__ has exactly 3 keys (__doc__, __module__, __weakref__)"]

# ---------------------------------------------------------------------------
# struct.error.__dict__.__contains__('__init__') == False (negative check)
# struct.error.__dict__.__len__() == 3 (cross-check)
# struct.Struct.__dict__.__contains__('__delattr__') == True (cross-check)
# struct.Struct.__dict__.__contains__('__getattribute__') == True (cross-check)
# struct.Struct.__dict__.__contains__('__setattr__') == True (cross-check)
#
# Wave 302 theme: negative check and cross-checks.
#
# error does NOT define __init__ in its own __dict__ — it inherits from Exception.
# This contrast with Struct (which does define __init__ in its __dict__) confirms
# that error is a simple subclass with no overridden constructor. This negative
# check is first for error.__dict__ in any struct spec. Cross-check table also
# confirms the Struct attr protocol and error count from earlier tables.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra124.error_no_init_and_crosschecks:
  description: "struct.error/__dict__/__contains__('__init__')==False / error/__dict__/__len__()==3 (cross-check) / Struct/__dict__/__contains__('__delattr__')==True (cross-check) / Struct/__dict__/__contains__('__getattribute__')==True (cross-check) / Struct/__dict__/__contains__('__setattr__')==True (cross-check) — error does NOT define __init__ in its own __dict__ (inherits from Exception); error dict count is 3; cross-checks confirm Struct attr protocol keys; first negative anchor for error.__dict__.__contains__('__init__')"
  kind: python_call_eq
  category: dict_contents
  id_prefix: structdict124

  columns: [id, function, args, expected, description]
  rows:
    - [error_no_init,           "error.__dict__.__contains__",  ["__init__"],        false, "error.__dict__.__contains__('__init__') is False; error does NOT define __init__ in its own __dict__; inherits Exception.__init__"]
    - [error_dict_len_xcheck,   "error.__dict__.__len__",       [],                  3,     "error.__dict__.__len__() is 3 (cross-check: __doc__/__module__/__weakref__ only; no __init__ or other methods)"]
    - [Struct_delattr_xcheck,   "Struct.__dict__.__contains__", ["__delattr__"],     true,  "Struct.__dict__.__contains__('__delattr__') cross-check (C-level slot wrapper for attribute deletion)"]
    - [Struct_getattr_xcheck,   "Struct.__dict__.__contains__", ["__getattribute__"], true, "Struct.__dict__.__contains__('__getattribute__') cross-check (C-level slot wrapper for attribute access)"]
    - [Struct_setattr_xcheck,   "Struct.__dict__.__contains__", ["__setattr__"],     true,  "Struct.__dict__.__contains__('__setattr__') cross-check (C-level slot wrapper for attribute assignment)"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__delattr__') == True — standalone
#
# struct.Struct.__dict__.__contains__('__delattr__') is True. Struct is a C
# extension type that defines __delattr__ as a slot wrapper (slot_tp_setattro
# in CPython). This C-level slot wrapper is exposed in Struct.__dict__ as a
# 'slot_wrapper' or 'wrapper_descriptor' object. extra70 covers __init__/__new__/
# __repr__/__module__; extra69 covers __sizeof__; extra65 covers pack/unpack etc.
# No prior struct spec anchors __delattr__ in Struct.__dict__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra124.Struct_dict_has_delattr:
  description: "struct.Struct.__dict__.__contains__('__delattr__') == True — Struct defines __delattr__ as a C-level slot wrapper in _struct.c; extra70 covers __init__/__new__/__repr__/__module__; no prior struct spec anchors __delattr__ in Struct.__dict__ as standalone; first standalone under structdict124"
  category: dict_contents
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["__delattr__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__getattribute__') == True — standalone
#
# struct.Struct.__dict__.__contains__('__getattribute__') is True. Struct
# defines __getattribute__ as a C-level slot wrapper (slot_tp_getattro). This
# is distinct from __getattr__ (which is not in Struct.__dict__). All three
# attribute protocol methods (__delattr__, __getattribute__, __setattr__) are
# present in Struct.__dict__ as C-level slot wrappers. No prior struct spec
# anchors __getattribute__ in Struct.__dict__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra124.Struct_dict_has_getattribute:
  description: "struct.Struct.__dict__.__contains__('__getattribute__') == True — Struct defines __getattribute__ as a C-level slot wrapper (distinct from __getattr__ which is not in Struct.__dict__); one of three attribute protocol methods in Struct.__dict__; no prior struct spec anchors __getattribute__ as standalone; first standalone under structdict124"
  category: dict_contents
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["__getattribute__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__dict__.__contains__('__module__') == True — standalone
#
# struct.error.__dict__.__contains__('__module__') is True. error stores its
# module name in its class __dict__ as the string 'struct'. This is the Python
# module name (not '_struct' — the C extension). The __module__ attribute
# reflects where the exception class was defined in Python source code.
# struct_extra122 anchors error.__module__.__eq__('struct') via direct access;
# this standalone anchors the same fact via error.__dict__.__contains__, which
# is the first error.__dict__.__contains__ standalone in any struct spec.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra124.error_dict_has_module:
  description: "struct.error.__dict__.__contains__('__module__') == True — error's __module__ is 'struct' (the Python module; extra122 anchors __module__.__eq__('struct') via direct access; this anchors via __dict__.__contains__); first error.__dict__.__contains__ standalone in any struct spec; first standalone under structdict124"
  category: dict_contents
  kind: python_call_eq
  function: "error.__dict__.__contains__"
  args: ["__module__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__dict__.__contains__('__init__') == False — standalone
#
# struct.error.__dict__.__contains__('__init__') is False. struct.error is a
# simple exception subclass that does NOT define its own __init__ method.
# It inherits __init__ from Exception (which accepts *args). This contrasts
# with struct.Struct, which does define __init__ in its C-extension __dict__
# (anchored in extra70). The absence of __init__ in error.__dict__ means any
# struct.error instance is initialized with the inherited Exception constructor.
# No prior struct spec anchors this negative check as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra124.error_dict_no_init:
  description: "struct.error.__dict__.__contains__('__init__') == False — error does NOT define __init__ in its own __dict__; inherits Exception.__init__; contrasts with Struct which does define __init__ (extra70 anchors Struct.__dict__.__contains__('__init__')==True); first negative standalone for error.__dict__.__contains__ under structdict124"
  category: dict_contents
  kind: python_call_eq
  function: "error.__dict__.__contains__"
  args: ["__init__"]
  expected: false

# ---------------------------------------------------------------------------
# struct.error.__dict__.__len__() == 3 — standalone
#
# struct.error.__dict__.__len__() is 3. The error exception class __dict__ has
# exactly 3 keys: __doc__, __module__, and __weakref__. This is the smallest
# possible practical class __dict__ for a Python exception subclass — just the
# bare minimum. Struct has 17 keys in its __dict__ (all covered across specs
# extra65/69/70/71/124); error has only 3. This count is the first integer
# check on error.__dict__.__len__() in any struct spec.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra124.error_dict_len_3:
  description: "struct.error.__dict__.__len__() == 3 — error's class __dict__ has exactly 3 keys (__doc__, __module__, __weakref__); smallest practical exception subclass __dict__; Struct has 17 keys by contrast; no prior struct spec anchors error.__dict__.__len__() as standalone; first standalone under structdict124"
  category: dict_contents
  kind: python_call_eq
  function: "error.__dict__.__len__"
  args: []
  expected: 3
