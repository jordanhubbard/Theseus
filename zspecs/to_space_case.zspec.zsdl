spec: to_space_case
version: ">=1.0.0"
backend: node(to-space-case)

docs: https://www.npmjs.com/package/to-space-case

provenance:
  derived_from:
    - "to-space-case README — https://www.npmjs.com/package/to-space-case"
    - "Test vectors verified with to-space-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "to-space-case source"
  notes:
    - "to-space-case is an npm package. Install: npm install to-space-case"
    - "Converts a string to space case (words separated by spaces, all lowercase)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_space_case.toSpaceCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: spacecase

  columns: [id, args, expected]
  rows:
    - [hyphen,  ["hello-world"],  "hello world"]
    - [camel,   ["fooBar"],       "foo bar"]
    - [snake,   ["foo_bar"],      "foo bar"]
