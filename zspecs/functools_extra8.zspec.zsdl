spec: functools_extra8
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl and functools_extra through functools_extra7."
    - "Focus: __qualname__ attributes for functools functions and classes, plus module-level constants."
    - "functools.reduce and functools.partial are C-level builtins from _functoolsmodule.c."
    - "functools.lru_cache, cache, total_ordering, singledispatch, wraps, cmp_to_key are Python functions."
    - "functools.partialmethod and functools.cached_property are Python classes."
    - "functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES are module-level tuples."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for functools functions and classes
# ---------------------------------------------------------------------------

table functools_extra8.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [reduce,          reduce.__qualname__.__eq__,          ["reduce"],          true]
    - [partial,         partial.__qualname__.__eq__,         ["partial"],         true]
    - [partialmethod,   partialmethod.__qualname__.__eq__,   ["partialmethod"],   true]
    - [lru_cache,       lru_cache.__qualname__.__eq__,       ["lru_cache"],       true]
    - [cache,           cache.__qualname__.__eq__,           ["cache"],           true]
    - [cached_property, cached_property.__qualname__.__eq__, ["cached_property"], true]
    - [total_ordering,  total_ordering.__qualname__.__eq__,  ["total_ordering"],  true]
    - [singledispatch,  singledispatch.__qualname__.__eq__,  ["singledispatch"],  true]
    - [wraps,           wraps.__qualname__.__eq__,           ["wraps"],           true]
    - [cmp_to_key,      cmp_to_key.__qualname__.__eq__,      ["cmp_to_key"],      true]

# ---------------------------------------------------------------------------
# Module-level constants: WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are tuples
# ---------------------------------------------------------------------------

invariant functools_extra8.WRAPPER_ASSIGNMENTS.class_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra8.WRAPPER_UPDATES.class_name:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
