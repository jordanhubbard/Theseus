spec: hashlib_extra520
backend: python_module(hashlib)

table hashlib_extra520.sha3_256_method_names:
  description: sha3_256 class method __name__ identity
  columns: [id, function, expected]
  rows:
    - [sha3_256_copy_name,      hashlib.sha3_256.copy.__name__.__eq__,      copy]
    - [sha3_256_digest_name,    hashlib.sha3_256.digest.__name__.__eq__,    digest]
    - [sha3_256_hexdigest_name, hashlib.sha3_256.hexdigest.__name__.__eq__, hexdigest]
    - [sha3_256_update_name,    hashlib.sha3_256.update.__name__.__eq__,    update]
  invariant_template:
    kind: python_call_eq
    function: "{function}"
    args: ["{expected}"]
    expected: true

table hashlib_extra520.sha3_512_method_names:
  description: sha3_512 class method __name__ identity
  columns: [id, function, expected]
  rows:
    - [sha3_512_copy_name,      hashlib.sha3_512.copy.__name__.__eq__,      copy]
    - [sha3_512_digest_name,    hashlib.sha3_512.digest.__name__.__eq__,    digest]
    - [sha3_512_hexdigest_name, hashlib.sha3_512.hexdigest.__name__.__eq__, hexdigest]
    - [sha3_512_update_name,    hashlib.sha3_512.update.__name__.__eq__,    update]
  invariant_template:
    kind: python_call_eq
    function: "{function}"
    args: ["{expected}"]
    expected: true

invariant hashlib_extra520.sha3_256_digest_size_class:
  kind: python_call_eq
  function: hashlib.sha3_256.digest_size.__class__.__name__.__eq__
  args: [getset_descriptor]
  expected: true

invariant hashlib_extra520.sha3_256_block_size_class:
  kind: python_call_eq
  function: hashlib.sha3_256.block_size.__class__.__name__.__eq__
  args: [getset_descriptor]
  expected: true

invariant hashlib_extra520.sha3_256_name_class:
  kind: python_call_eq
  function: hashlib.sha3_256.name.__class__.__name__.__eq__
  args: [getset_descriptor]
  expected: true

invariant hashlib_extra520.sha3_256_qualname:
  kind: python_call_eq
  function: hashlib.sha3_256.__qualname__.__eq__
  args: [sha3_256]
  expected: true
