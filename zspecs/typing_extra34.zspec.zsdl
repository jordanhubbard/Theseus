spec: typing_extra34
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra33.zspec.zsdl."
    - "Prior specs covered: TypeVar/__name__/__module__/__qualname__/__init__.__name__, Protocol/__module__/__qualname__/__bases__[0].__name__, Generic/__module__/__qualname__/__bases__[0].__name__, NamedTuple/__name__/__module__, TypedDict/__name__/__module__, get_type_hints/__name__, overload/__name__, cast/__name__, TYPE_CHECKING value, TypeVar/Protocol/Generic __module__.__len__() and __name__.__len__(), __qualname__.__len__() for overload/cast/get_type_hints/no_type_check/get_args/get_origin, __module__.__len__() and __name__.__len__() for Any/Union/Optional/Callable/ClassVar/Final/Literal, __mro__.__len__() for Protocol/Generic/TypeVar, __bases__[0].__name__.__len__() for Generic/TypeVar, AnyStr.__constraints__/__class__.__name__, Protocol.__slots__/__abstractmethods__/__class__.__name__, TYPE_CHECKING.__class__.__name__.__len__(), AnyStr.__class__.__name__.__len__()."
    - "This spec covers: typing.__all__.__len__() and .__class__.__name__.__len__(); __dict__.__class__.__name__.__len__() for TypeVar/Generic/Protocol (mappingproxy) and NamedTuple (dict — not mappingproxy); __qualname__.__len__() for final and runtime_checkable; TypeVar.__init__.__qualname__.__len__() (delegates to object.__init__); Protocol.__init_subclass__.__qualname__.__len__()."
    - "typing.__all__.__len__() == 105 — verified on Python 3.12."
    - "TypeVar/Generic/Protocol.__dict__.__class__.__name__ == 'mappingproxy' (length 12) — standard C-type descriptor."
    - "typing.NamedTuple.__dict__.__class__.__name__ == 'dict' (length 4), NOT 'mappingproxy' — NamedTuple is implemented as a Python class helper, so its __dict__ is a plain dict."
    - "typing.TypeVar.__init__.__qualname__ == 'object.__init__' (length 15) — TypeVar's C-level __init__ is inherited from object, so its qualname reports the object ancestor."
    - "typing.Protocol.__init_subclass__.__qualname__ == 'Protocol.__init_subclass__' (length 26)."
    - "typing.final.__qualname__ == 'final' (length 5); typing.runtime_checkable.__qualname__ == 'runtime_checkable' (length 17)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typing.__all__.__len__() and .__class__.__name__.__len__()
#
# typing.__all__ is a list with 105 entries (Python 3.12). The list class
# name 'list' has length 4. No prior typing spec records the total number of
# exports or the type of __all__.
# ---------------------------------------------------------------------------

table typing_extra34.all_list_attrs:
  description: "typing.__all__ length (105) and its class name length (4 — 'list')"
  kind: python_call_eq
  category: module_all_attrs
  id_prefix: all

  columns: [id, function, args, expected]
  rows:
    - [len,            __all__.__len__,                   [], 105]
    - [class_name_len, __all__.__class__.__name__.__len__, [], 4]

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for TypeVar/Generic/Protocol/NamedTuple
#
# TypeVar, Generic, and Protocol are C-implemented or heavily augmented classes;
# their __dict__ is a mappingproxy (length 12). NamedTuple is a Python-level
# helper class — its __dict__ is a plain dict (length 4). This asymmetry
# between 'mappingproxy' and 'dict' is the key finding here. No prior typing
# spec records __dict__.__class__.__name__.__len__() for any of these four.
# ---------------------------------------------------------------------------

table typing_extra34.class_dict_type_lens:
  description: "__dict__.__class__.__name__.__len__() for TypeVar/Generic/Protocol (mappingproxy=12) and NamedTuple (dict=4)"
  kind: python_call_eq
  category: dict_type_checks
  id_prefix: dict_class_name_len

  columns: [id, function, args, expected]
  rows:
    - [TypeVar,    TypeVar.__dict__.__class__.__name__.__len__,    [], 12]
    - [Generic,    Generic.__dict__.__class__.__name__.__len__,    [], 12]
    - [Protocol,   Protocol.__dict__.__class__.__name__.__len__,   [], 12]
    - [NamedTuple, NamedTuple.__dict__.__class__.__name__.__len__, [], 4]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for final and runtime_checkable
#
# typing.final is a decorator class; its __qualname__ == 'final' (length 5).
# typing.runtime_checkable is also a decorator; its __qualname__ ==
# 'runtime_checkable' (length 17). No prior typing spec records
# __qualname__.__len__() for either of these two decorators.
# ---------------------------------------------------------------------------

table typing_extra34.decorator_qualname_lens:
  description: "__qualname__.__len__() for final (5) and runtime_checkable (17)"
  kind: python_call_eq
  category: qualname_attr_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [final,               final.__qualname__.__len__,               [], 5]
    - [runtime_checkable,   runtime_checkable.__qualname__.__len__,   [], 17]

# ---------------------------------------------------------------------------
# typing.TypeVar.__init__.__qualname__.__len__() == 15 — standalone
#
# typing.TypeVar.__init__.__qualname__ == 'object.__init__' (length 15).
# TypeVar's C-level __init__ inherits directly from object rather than defining
# its own named slot, so Python reports the ancestor qualname 'object.__init__'
# (6 + 1 + 8 = 15). This contrasts with Protocol.__init_subclass__ which does
# carry Protocol's own name. No prior typing spec records this qualname length.
# ---------------------------------------------------------------------------

invariant typing_extra34.TypeVar.init_qualname_len:
  description: "typing.TypeVar.__init__.__qualname__.__len__() == 15 — reports 'object.__init__' (length 15) because TypeVar's C __init__ inherits the object slot"
  category: method_qualname_lengths
  kind: python_call_eq
  function: TypeVar.__init__.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# typing.Protocol.__init_subclass__.__qualname__.__len__() == 26 — standalone
#
# typing.Protocol.__init_subclass__.__qualname__ == 'Protocol.__init_subclass__'
# (length 26): 8 (Protocol) + 1 (.) + 17 (__init_subclass__) = 26.
# Protocol defines __init_subclass__ as a class method to intercept Protocol
# subclassing. No prior typing spec records this qualname length.
# ---------------------------------------------------------------------------

invariant typing_extra34.Protocol.init_subclass_qualname_len:
  description: "typing.Protocol.__init_subclass__.__qualname__.__len__() == 26 — 'Protocol.__init_subclass__' is 8 + 1 + 17 = 26 characters"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Protocol.__init_subclass__.__qualname__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# typing.NamedTuple.__dict__.__class__.__name__.__len__() == 4 — standalone
#
# typing.NamedTuple.__dict__.__class__.__name__ == 'dict' (length 4). Unlike
# TypeVar, Generic, and Protocol — which carry a 'mappingproxy' (12) as their
# __dict__ — NamedTuple is a Python-level helper implemented as a plain class,
# so its __dict__ is a regular dict. This is the only typing class in this
# series whose __dict__ is not a mappingproxy.
# ---------------------------------------------------------------------------

invariant typing_extra34.NamedTuple.dict_class_name_len:
  description: "typing.NamedTuple.__dict__.__class__.__name__.__len__() == 4 — 'dict' has length 4; NamedTuple's __dict__ is a plain dict, not a mappingproxy"
  category: dict_type_checks
  kind: python_call_eq
  function: NamedTuple.__dict__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# typing.__all__.__len__() == 105 — standalone
#
# typing.__all__ contains 105 exported names in Python 3.12. This is the
# largest __all__ among all modules covered in the typing_extra series and
# reflects the comprehensive scope of the typing module's public API.
# ---------------------------------------------------------------------------

invariant typing_extra34.all_len:
  description: "typing.__all__.__len__() == 105 — 105 public exports in Python 3.12; largest __all__ in the typing_extra series"
  category: module_all_attrs
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 105
