spec: multiprocessing_extra259
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#shared-ctypes-objects

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#shared-ctypes-objects — multiprocessing shared memory documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/sharedctypes.py"
  notes:
    - "multiprocessing.Value and multiprocessing.Array are context-bound methods; __class__.__name__ == 'method'."
    - "multiprocessing.Value.__qualname__ == 'BaseContext.Value' — bound to the default context's BaseContext."
    - "multiprocessing.sharedctypes.RawValue and RawArray are plain functions; __module__ == 'multiprocessing.sharedctypes'."
    - "multiprocessing.RawValue and multiprocessing.RawArray are also context-bound methods with __qualname__ carrying 'BaseContext.' prefix."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Value and Array context-bound method identity — table
#
# multiprocessing.Value and Array are bound to the default process context.
# __qualname__ carries 'BaseContext.' prefix; __class__.__name__ == 'method'.
# ---------------------------------------------------------------------------

table multiprocessing_extra259.value_array_identity:
  description: "multiprocessing.Value and Array context-bound method identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpval

  columns: [id, function, args, expected, description]
  rows:
    - [value_name,      Value.__name__.__eq__,               ["Value"],              true, "multiprocessing.Value.__name__ == 'Value'"]
    - [value_qualname,  Value.__qualname__.__eq__,           ["BaseContext.Value"],  true, "multiprocessing.Value.__qualname__ == 'BaseContext.Value'"]
    - [array_name,      Array.__name__.__eq__,               ["Array"],              true, "multiprocessing.Array.__name__ == 'Array'"]
    - [array_qualname,  Array.__qualname__.__eq__,           ["BaseContext.Array"],  true, "multiprocessing.Array.__qualname__ == 'BaseContext.Array'"]
    - [value_class,     Value.__class__.__name__.__eq__,     ["method"],             true, "type(multiprocessing.Value).__name__ == 'method'"]

# ---------------------------------------------------------------------------
# sharedctypes RawValue and RawArray identity — table
#
# multiprocessing.sharedctypes.RawValue and RawArray are plain functions
# defined in multiprocessing.sharedctypes.
# ---------------------------------------------------------------------------

table multiprocessing_extra259.rawvalue_rawarray_identity:
  description: "multiprocessing.sharedctypes RawValue and RawArray identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpraw

  columns: [id, function, args, expected, description]
  rows:
    - [rawval_name,     sharedctypes.RawValue.__name__.__eq__,    ["RawValue"],                    true, "sharedctypes.RawValue.__name__ == 'RawValue'"]
    - [rawval_mod,      sharedctypes.RawValue.__module__.__eq__,  ["multiprocessing.sharedctypes"], true, "sharedctypes.RawValue.__module__ == 'multiprocessing.sharedctypes'"]
    - [rawarr_name,     sharedctypes.RawArray.__name__.__eq__,    ["RawArray"],                    true, "sharedctypes.RawArray.__name__ == 'RawArray'"]
    - [rawarr_mod,      sharedctypes.RawArray.__module__.__eq__,  ["multiprocessing.sharedctypes"], true, "sharedctypes.RawArray.__module__ == 'multiprocessing.sharedctypes'"]
    - [array_class,     Array.__class__.__name__.__eq__,          ["method"],                      true, "type(multiprocessing.Array).__name__ == 'method'"]

# ---------------------------------------------------------------------------
# RawValue and RawArray context-bound __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra259.RawValue.qualname:
  description: "multiprocessing.RawValue.__qualname__ == 'BaseContext.RawValue'"
  category: identity
  kind: python_call_eq
  function: RawValue.__qualname__.__eq__
  args: ["BaseContext.RawValue"]
  expected: true

invariant multiprocessing_extra259.RawArray.qualname:
  description: "multiprocessing.RawArray.__qualname__ == 'BaseContext.RawArray'"
  category: identity
  kind: python_call_eq
  function: RawArray.__qualname__.__eq__
  args: ["BaseContext.RawArray"]
  expected: true

invariant multiprocessing_extra259.RawValue.name:
  description: "multiprocessing.RawValue.__name__ == 'RawValue'"
  category: identity
  kind: python_call_eq
  function: RawValue.__name__.__eq__
  args: ["RawValue"]
  expected: true

invariant multiprocessing_extra259.RawArray.name:
  description: "multiprocessing.RawArray.__name__ == 'RawArray'"
  category: identity
  kind: python_call_eq
  function: RawArray.__name__.__eq__
  args: ["RawArray"]
  expected: true

invariant multiprocessing_extra259.sharedctypes.RawValue.class_name:
  description: "type(multiprocessing.sharedctypes.RawValue).__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: sharedctypes.RawValue.__class__.__name__.__eq__
  args: ["function"]
  expected: true
