spec: prismjs
version: ">=1.0.0"
backend: node(prismjs)

docs: https://prismjs.com

provenance:
  derived_from:
    - "PrismJS docs — https://prismjs.com"
    - "Test vectors verified with prismjs via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "prismjs source"
  notes:
    - "Lightweight syntax highlighter — ships with markup, css, javascript, clike grammars built in."
    - "Install: npm install prismjs"
    - "v1 CJS; named exports highlight / tokenize / languages / util."
    - "Other languages can be loaded by requiring prismjs/components/prism-<lang>."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws if the requested language has no grammar registered."
  stderr: "null"
  stickiness: "N/A — each highlight call independent."
  codes: {}

invariant prismjs.javascript_keyword_is_array:
  description: "languages.javascript.keyword is an Array of pattern descriptors"
  category: languages
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "languages.javascript.keyword"}
    - {get: "constructor.name"}
  expected: "Array"

invariant prismjs.languages_javascript_present:
  description: "languages.javascript is a registered grammar (object)"
  category: languages
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: languages}
    - {method: hasOwnProperty, args: ["javascript"]}
  expected: true

invariant prismjs.languages_markup_present:
  description: "languages.markup is registered (alias for HTML/XML)"
  category: languages
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: languages}
    - {method: hasOwnProperty, args: ["markup"]}
  expected: true

invariant prismjs.languages_css_present:
  description: "languages.css is registered"
  category: languages
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: languages}
    - {method: hasOwnProperty, args: ["css"]}
  expected: true

invariant prismjs.languages_clike_present:
  description: "languages.clike is registered (base for many languages)"
  category: languages
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: languages}
    - {method: hasOwnProperty, args: ["clike"]}
  expected: true

invariant prismjs.tokenize_returns_array:
  description: "tokenize() returns an Array"
  category: tokenize
  kind: node_chain_eq
  entry: named
  function: tokenize
  entry_args: ["", {}]
  chain:
    - {get: "constructor.name"}
  expected: "Array"

invariant prismjs.html_alias_for_markup:
  description: "languages.html is the same as languages.markup (alias)"
  category: languages
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: languages}
    - {method: hasOwnProperty, args: ["html"]}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:53:15Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
