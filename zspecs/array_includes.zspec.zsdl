spec: array_includes
version: ">=3.1.9"
backend: node(array-includes)

docs: https://www.npmjs.com/package/array-includes

provenance:
  derived_from:
    - "array-includes README — https://www.npmjs.com/package/array-includes"
    - "Test vectors verified with array-includes via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-includes source"
  notes:
    - "array-includes is an npm package. Install: npm install array-includes"
    - "ES6-spec-compliant Array.prototype.includes shim. Returns true if the value is in the array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_includes.includes:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: ainc

  columns: [id, args, expected]
  rows:
    - [found,       [[1, 2, 3], 2],       true]
    - [not_found,   [[1, 2, 3], 9],       false]
    - [string,      [["a", "b", "c"], "b"],  true]

