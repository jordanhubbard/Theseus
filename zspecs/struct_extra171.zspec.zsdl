spec: struct_extra171
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra170.zspec.zsdl — covers struct format character byte sizes: calcsize('b')==1; calcsize('h')==2; calcsize('i')==4; calcsize('l')==4; calcsize('q')==8; calcsize('f')==4; calcsize('d')==8 (table + invariants)."
    - "struct_extra169.zspec.zsdl — covers struct.Struct.__name__/__module__ lengths / struct.error class name and module / error.__bases__[0].__name__=='Exception' / pack/calcsize __name__ strings (table + invariants)."
    - "struct_extra168.zspec.zsdl — covers struct.Struct.__mro__.__len__()==2 / struct.error.__mro__.__len__()==4 / function __qualname__ attributes (table + invariants)."
    - "struct_extra167.zspec.zsdl — covers struct.__name__/__package__/__spec__/__loader__/__doc__ module-level identity (table + invariants)."
    - "struct_extra166.zspec.zsdl — covers struct.Struct.__name__/__module__ via __eq__ calls (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__=='struct' and struct.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra170."
    - "Wave 354 theme: struct.Struct instance attributes — struct.Struct('i').size==4; struct.Struct('q').size==8; struct.Struct('2i').size==8 (two ints = 8 bytes); struct.Struct('i').format=='i'; struct.Struct('2i').format=='2i'; struct.Struct('i').__class__.__name__=='Struct'; struct.Struct('i').size.__class__.__name__=='int'. These anchor the instance-level size, format, and class identity attributes of Struct objects as novel content under structinstance171."
    - "struct.Struct('i').size == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct('i').size is the packed size in bytes for format 'i' (signed int = 4 bytes)."
    - "struct.Struct('q').size == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct('q').size is 8 (signed long long = 8 bytes)."
    - "struct.Struct('2i').size == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct('2i').size is 8 (two signed ints = 2 * 4 = 8 bytes)."
    - "struct.Struct('i').format == 'i'. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct stores the format string as-is in the format attribute."
    - "struct.Struct('2i').format == '2i'. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct stores '2i' as-is; the count prefix is preserved verbatim."
    - "struct.Struct('i').__class__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct instances are of class 'Struct'."
    - "struct.Struct('i').size.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0. The size attribute is a plain Python int."
    - "Note: struct.Struct('q').size==8 == struct.Struct('2i').size==8. Packing a single 'q' (long long, 8 bytes) produces the same byte count as packing two 'i' (int, 4+4=8 bytes) — an integer and a multi-element format with equal packed size."
    - "Note: struct.Struct('i').format=='i'(1 char) < struct.Struct('2i').format=='2i'(2 chars). The format attribute stores the format string verbatim; multi-element formats like '2i' are stored with their count prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct('i').size == 4
# struct.Struct('q').size == 8
# struct.Struct('2i').size == 8
#
# Wave 354 theme: Struct instance .size attribute values.
#
# Struct('i').size is 4 (one signed int = 4 bytes).
# Struct('q').size is 8 (one signed long long = 8 bytes).
# Struct('2i').size is 8 (two signed ints = 2 * 4 = 8 bytes; ties with 'q').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra171.Struct_size_attribute_values:
  description: "struct.Struct('i').size.__eq__(4)==True / struct.Struct('q').size.__eq__(8)==True / struct.Struct('2i').size.__eq__(8)==True — Struct('i').size is 4 (struct.Struct('i') creates a compiled Struct object for the 'i' format character (signed int); the size attribute gives the total packed size in bytes for one instance of the format; 'i' = 4 bytes (signed int on all modern platforms); novel anchor: no prior struct spec anchors Struct('i').size under structinstance171; first structinstance171 anchor for the integer 4 as Struct('i').size); Struct('q').size is 8 ('q' = signed long long = 8 bytes; Struct('q').size(8) > Struct('i').size(4) by 4: long long is twice the size of int; novel anchor: first structinstance171 anchor for Struct('q').size==8); Struct('2i').size is 8 ('2i' = two signed ints = 2 * 4 = 8 bytes; the count prefix multiplies the per-element size; Struct('2i').size(8) == Struct('q').size(8): packing two ints takes the same bytes as packing one long long; this 2-way size tie between a multi-element format and a single 8-byte type is a notable coincidence; novel anchor: first structinstance171 anchor for Struct('2i').size==8; Struct('2i') and Struct('q') have equal size but very different binary layouts)"
  kind: python_call_eq
  category: identity
  id_prefix: structinstance171

  columns: [id, function, args, expected, description]
  rows:
    - [struct_i_size_4,  "Struct('i').size.__eq__",  [4], true, "struct.Struct('i').size == 4 (one signed int; 4 bytes; novel anchor)"]
    - [struct_q_size_8,  "Struct('q').size.__eq__",  [8], true, "struct.Struct('q').size == 8 (one signed long long; 8 bytes; 8>4; novel anchor)"]
    - [struct_2i_size_8, "Struct('2i').size.__eq__", [8], true, "struct.Struct('2i').size == 8 (two ints; 2*4=8; ties with 'q'(8); novel anchor)"]

# ---------------------------------------------------------------------------
# struct.Struct('i').format == 'i'
# struct.Struct('2i').format == '2i'
# struct.Struct('i').format.__len__() == 1
# struct.Struct('2i').format.__len__() == 2
#
# Wave 354 theme: Struct instance .format attribute values and lengths.
#
# Struct('i').format is 'i' (1 char; stored verbatim).
# Struct('2i').format is '2i' (2 chars; count prefix preserved).
# Struct('i').format.__len__() is 1.
# Struct('2i').format.__len__() is 2.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra171.Struct_format_attribute_values:
  description: "struct.Struct('i').format.__eq__('i')==True / struct.Struct('2i').format.__eq__('2i')==True / struct.Struct('i').format.__len__()==1 / struct.Struct('2i').format.__len__()==2 — Struct('i').format is 'i' (the format attribute on a Struct instance stores the format string as passed to the constructor; Struct('i').format == 'i' (1 char): the single-character format string is preserved verbatim; the format attribute is a read-only string attribute exposed on the Struct object; novel anchor: no prior struct spec anchors Struct('i').format under structinstance171; first structinstance171 anchor for 'i' as Struct format); Struct('2i').format is '2i' (the multi-element format '2i' is also stored verbatim; the count prefix '2' is not expanded — the raw format string '2i' (2 chars) is stored as-is; Struct('2i').format.__len__()==2 > Struct('i').format.__len__()==1: multi-element formats have longer format strings; novel anchor: first structinstance171 anchor for '2i' as Struct format); Struct('i').format.__len__() is 1 (len('i')==1; integer confirmation; 1 = minimum format string length for a valid non-empty Struct; novel __len__ anchor); Struct('2i').format.__len__() is 2 (len('2i')==2; 2 > 1 by 1: the count+char format is 1 char longer than the bare char format; novel __len__ anchor)"
  kind: python_call_eq
  category: identity
  id_prefix: structinstance171

  columns: [id, function, args, expected, description]
  rows:
    - [struct_i_format_eq,    "Struct('i').format.__eq__",   ["i"],  true, "struct.Struct('i').format == 'i' (stored verbatim; 1 char; novel anchor)"]
    - [struct_2i_format_eq,   "Struct('2i').format.__eq__",  ["2i"], true, "struct.Struct('2i').format == '2i' (count prefix preserved; 2 chars; novel anchor)"]
    - [struct_i_format_len,   "Struct('i').format.__len__",  [],     1,    "struct.Struct('i').format.__len__() == 1 ('i'=1; minimum format len; novel anchor)"]
    - [struct_2i_format_len,  "Struct('2i').format.__len__", [],     2,    "struct.Struct('2i').format.__len__() == 2 ('2i'=2; 2>1; count+char longer; novel anchor)"]

# ---------------------------------------------------------------------------
# struct.Struct('i').__class__.__name__ == 'Struct'
# struct.Struct('i').size.__class__.__name__ == 'int'
# struct.Struct('i').format.__class__.__name__ == 'str'
#
# Wave 354 theme: Struct instance and attribute class identity.
#
# Struct('i').__class__.__name__ is 'Struct' (6 chars).
# Struct('i').size.__class__.__name__ is 'int' (3 chars).
# Struct('i').format.__class__.__name__ is 'str' (3 chars; ties with 'int').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra171.Struct_instance_class_identity:
  description: "struct.Struct('i').__class__.__name__.__eq__('Struct')==True / struct.Struct('i').size.__class__.__name__.__eq__('int')==True / struct.Struct('i').format.__class__.__name__.__eq__('str')==True — Struct('i').__class__.__name__ is 'Struct' (6 chars; struct.Struct('i') creates a compiled Struct object; the __class__.__name__ attribute of the returned object is 'Struct' — the class name of the struct.Struct type; 'Struct'(6 chars) — capital S; novel anchor: no prior struct spec anchors Struct('i').__class__.__name__ under structinstance171; first structinstance171 anchor for 'Struct' as __class__.__name__); Struct('i').size.__class__.__name__ is 'int' (3 chars; the size attribute is a plain Python int object; __class__.__name__=='int' (3 chars) confirms the size attribute type; size.__class__.__name__(3) < Struct.__class__.__name__(6) by 3: the attribute type name is shorter than the instance type name; novel anchor: first structinstance171 anchor for 'int' as size class name); Struct('i').format.__class__.__name__ is 'str' (3 chars; the format attribute is a plain Python str object; __class__.__name__=='str' (3 chars) confirms the format attribute type; format.__class__.__name__=='str'(3) == size.__class__.__name__=='int'(3): both size and format have 3-char type names — a 2-way tie; novel anchor: first structinstance171 anchor for 'str' as format class name)"
  kind: python_call_eq
  category: identity
  id_prefix: structinstance171

  columns: [id, function, args, expected, description]
  rows:
    - [struct_i_cls_Struct, "Struct('i').__class__.__name__.__eq__",        ["Struct"], true, "struct.Struct('i').__class__.__name__ == 'Struct' (6 chars; instance type; novel anchor)"]
    - [struct_size_cls_int, "Struct('i').size.__class__.__name__.__eq__",   ["int"],    true, "struct.Struct('i').size.__class__.__name__ == 'int' (3 chars; size is plain int; 3<6; novel anchor)"]
    - [struct_fmt_cls_str,  "Struct('i').format.__class__.__name__.__eq__", ["str"],    true, "struct.Struct('i').format.__class__.__name__ == 'str' (3 chars; tied with 'int'(3); novel anchor)"]

# ---------------------------------------------------------------------------
# struct.Struct('i').size.__eq__(4) — standalone
#
# struct.Struct('i').size is 4 (one signed int = 4 bytes). The size attribute
# on a Struct instance gives the total packed byte count. Struct('i').size(4)
# ties with Struct('f').size(4) and Struct('l').size(4).
# Novel anchor under structinstance171. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra171.Struct_i_size_4:
  description: "struct.Struct('i').size.__eq__(4) == True — 4 (struct.Struct('i') is a compiled Struct object for packing/unpacking signed 32-bit integers; the size attribute equals the number of bytes required to hold one packed 'i' value; 4 bytes = 32 bits: the signed int type ('i') stores values in the range -2,147,483,648 to 2,147,483,647; Struct('i').size(4) == calcsize('i')(4): the size attribute and calcsize() produce identical results for the same format string; Struct('i').size(4) < Struct('q').size(8): long long takes twice as many bytes as int; novel anchor: no prior struct spec anchors Struct('i').size under structinstance171; first structinstance171 standalone for Struct('i').size.__eq__(4)"
  category: identity
  kind: python_call_eq
  function: "Struct('i').size.__eq__"
  args: [4]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct('q').size.__eq__(8) — standalone
#
# struct.Struct('q').size is 8 (one signed long long = 8 bytes). Struct('q')
# and Struct('2i') both have size 8 — two different formats with equal packed size.
# Novel anchor under structinstance171. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra171.Struct_q_size_8:
  description: "struct.Struct('q').size.__eq__(8) == True — 8 (struct.Struct('q') is a compiled Struct object for packing/unpacking signed 64-bit integers (C long long); the size attribute equals 8 bytes (64 bits); Struct('q').size(8) == Struct('2i').size(8): a single long long ('q') and two ints ('2i') both occupy 8 bytes — they have the same size but different binary layouts (one 64-bit value vs two 32-bit values); Struct('q').size(8) == Struct('i').size(4) * 2: long long is exactly twice the size of int; novel anchor: no prior struct spec anchors Struct('q').size under structinstance171; first structinstance171 standalone for Struct('q').size.__eq__(8)"
  category: identity
  kind: python_call_eq
  function: "Struct('q').size.__eq__"
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct('i').format.__eq__('i') — standalone
#
# struct.Struct('i').format is 'i' (1 char). The format attribute stores the
# format string verbatim. Struct('i').format == 'i': a single character.
# Novel anchor under structinstance171. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra171.Struct_i_format_i:
  description: "struct.Struct('i').format.__eq__('i') == True — 'i' (1 char; struct.Struct stores the format string passed to the constructor in the format attribute as a read-only property; the format string 'i' is stored exactly as provided — it is not normalized, expanded, or transformed; Struct('i').format == 'i' means the single-character format string is preserved verbatim; this contrasts with Struct('2i').format == '2i': the count prefix is also stored as-is; Struct('i').format.__len__()==1: the minimum format string length for a non-empty Struct; novel anchor: no prior struct spec anchors Struct('i').format under structinstance171; first structinstance171 standalone for Struct('i').format.__eq__('i')"
  category: identity
  kind: python_call_eq
  function: "Struct('i').format.__eq__"
  args: ["i"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct('2i').format.__eq__('2i') — standalone
#
# struct.Struct('2i').format is '2i' (2 chars). The count prefix is preserved
# verbatim in the format attribute. Struct('2i').size == 8 (same as Struct('q')).
# Novel anchor under structinstance171. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra171.Struct_2i_format_2i:
  description: "struct.Struct('2i').format.__eq__('2i') == True — '2i' (2 chars; struct.Struct('2i') creates a compiled Struct object for packing/unpacking two signed ints; the format string '2i' is stored verbatim in the format attribute — the count prefix '2' is preserved and not expanded into 'ii'; this verbatim storage means Struct('2i').format == '2i', not 'ii'; '2i'(2 chars) > 'i'(1 char) by 1: multi-element formats with count prefixes have longer stored format strings; Struct('2i').format.__len__()==2: 2 chars (digit + letter); Struct('2i').size(8) == Struct('q').size(8): two ints pack to the same 8 bytes as one long long, despite the different format strings; novel anchor: no prior struct spec anchors Struct('2i').format under structinstance171; first structinstance171 standalone for Struct('2i').format.__eq__('2i')"
  category: identity
  kind: python_call_eq
  function: "Struct('2i').format.__eq__"
  args: ["2i"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct('i').__class__.__name__.__eq__('Struct') — standalone
#
# struct.Struct('i').__class__.__name__ is 'Struct' (6 chars). Struct instances
# are of the struct.Struct class. 'Struct'(6) > size_class_name 'int'(3) by 3.
# Novel anchor under structinstance171. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra171.Struct_i_class_name_Struct:
  description: "struct.Struct('i').__class__.__name__.__eq__('Struct') == True — 'Struct' (6 chars; struct.Struct('i') returns an instance of the struct.Struct compiled struct type; the __class__.__name__ attribute of this instance is 'Struct' — the unqualified class name; 'Struct' starts with a capital S, reflecting Python's convention that class names use CamelCase; 'Struct'(6) > 'int'(3) == 'str'(3): the instance class name is 3 chars longer than the size and format attribute class names; struct.Struct('i').__class__.__name__(6) confirms the Struct type is named 'Struct' rather than anything like 'pack_struct' or '_Struct'; novel anchor: no prior struct spec anchors Struct('i').__class__.__name__ under structinstance171; first structinstance171 standalone for Struct('i').__class__.__name__.__eq__('Struct')"
  category: identity
  kind: python_call_eq
  function: "Struct('i').__class__.__name__.__eq__"
  args: ["Struct"]
  expected: true
