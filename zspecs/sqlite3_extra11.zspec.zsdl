spec: sqlite3_extra11
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra10.zspec.zsdl."
    - "sqlite3_extra10 covers: Connection/Cursor/Row __class__.__name__ == 'type'; connect __class__.__name__ == 'builtin_function_or_method'."
    - "sqlite3_extra9 covers: SQLITE_ABORT/SQLITE_CONSTRAINT/SQLITE_RANGE; complete_statement __name__/__module__; DatabaseError/Error MRO[1]; PARSE_DECLTYPES/PARSE_COLNAMES type; version/__len__."
    - "sqlite3_extra8 covers: SQLITE_BUSY/SQLITE_LOCKED/SQLITE_MISUSE/SQLITE_NOTADB; connect/__name__/__module__; Warning/__name__/__module__."
    - "sqlite3_extra7 covers: SQLITE_OK/SQLITE_ERROR/SQLITE_INTERNAL; Connection/Row/Cursor __module__; exception __bases__[0]/__name__ table."
    - "sqlite3_extra5 covers: __qualname__ for Connection/Cursor/Row/Error/Warning/IntegrityError/OperationalError/connect/complete_statement."
    - "Focus: new axes not yet covered in any prior sqlite3 spec."
    - "sqlite3.sqlite_version.__class__.__name__ == 'str' — version string type check."
    - "sqlite3.apilevel == '2.0' — DB-API 2.0 compliance level constant."
    - "sqlite3.apilevel.__class__.__name__ == 'str' — apilevel is a string."
    - "sqlite3.threadsafety.__class__.__name__ == 'int' — threadsafety is an integer."
    - "sqlite3.threadsafety >= 1 — module is at least serialised (CPython 3.12: threadsafety == 3)."
    - "sqlite3.Error.__name__ == 'Error' — base exception class __name__."
    - "sqlite3.DatabaseError.__name__ == 'DatabaseError' — exception class __name__."
    - "sqlite3.IntegrityError.__name__ == 'IntegrityError' — exception class __name__."
    - "sqlite3.OperationalError.__name__ == 'OperationalError' — exception class __name__."
    - "sqlite3.NotSupportedError.__name__ == 'NotSupportedError' — exception class __name__."
    - "sqlite3.sqlite_version_info.__class__.__name__ == 'tuple' — version tuple type."
    - "sqlite3.sqlite_version_info.__len__() == 3 — version tuple has 3 components."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3.sqlite_version type check
#
# sqlite3_extra4 checks version.__class__.__name__ == 'str' (for the version
# attribute exposed from the sqlite3 module).
# sqlite3.sqlite_version is a distinct attribute (the SQLite C library version
# as a string). No prior spec checks sqlite_version.__class__.__name__.
# ---------------------------------------------------------------------------

invariant sqlite3_extra11.sqlite_version.class_name:
  description: "sqlite3.sqlite_version.__class__.__name__ == 'str' — library version string"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.apilevel — value and type
#
# sqlite3.apilevel is a DB-API 2.0 mandatory string constant with value '2.0'.
# No prior sqlite3 spec checks apilevel at all.
# ---------------------------------------------------------------------------

invariant sqlite3_extra11.apilevel.value:
  description: "sqlite3.apilevel == '2.0' — DB-API 2.0 compliance"
  category: module_attrs
  kind: python_call_eq
  function: apilevel.__eq__
  args: ["2.0"]
  expected: true

invariant sqlite3_extra11.apilevel.class_name:
  description: "sqlite3.apilevel.__class__.__name__ == 'str' — apilevel is a string"
  category: module_attrs
  kind: python_call_eq
  function: apilevel.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.threadsafety — type and lower bound
#
# sqlite3.threadsafety is a DB-API 2.0 mandatory integer constant.
# CPython 3.12 reports threadsafety == 3 (serialised + multi-thread safe).
# No prior sqlite3 spec checks threadsafety.
# ---------------------------------------------------------------------------

invariant sqlite3_extra11.threadsafety.class_name:
  description: "sqlite3.threadsafety.__class__.__name__ == 'int' — threadsafety is an integer"
  category: module_attrs
  kind: python_call_eq
  function: threadsafety.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sqlite3_extra11.threadsafety.ge1:
  description: "sqlite3.threadsafety >= 1 — module is at minimum serialised"
  category: module_attrs
  kind: python_call_eq
  function: threadsafety.__ge__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# Exception class __name__ attributes
#
# sqlite3_extra2 and sqlite3_extra4 test __name__ for Connection/Cursor/Row and
# selected exceptions via table rows. sqlite3_extra7 covers exception
# __bases__[0].__name__. No single prior spec checks __name__ directly via
# __eq__ for Error, DatabaseError, IntegrityError, OperationalError, and
# NotSupportedError together.
# ---------------------------------------------------------------------------

table sqlite3_extra11.exception_names:
  kind: python_call_eq
  category: class_names
  id_prefix: excname11

  columns: [id, function, args, expected]
  rows:
    - [Error,             Error.__name__.__eq__,             ["Error"],             true]
    - [DatabaseError,     DatabaseError.__name__.__eq__,     ["DatabaseError"],     true]
    - [IntegrityError,    IntegrityError.__name__.__eq__,    ["IntegrityError"],    true]
    - [OperationalError,  OperationalError.__name__.__eq__,  ["OperationalError"],  true]
    - [NotSupportedError, NotSupportedError.__name__.__eq__,  ["NotSupportedError"], true]

# ---------------------------------------------------------------------------
# sqlite3.sqlite_version_info — type and length
#
# sqlite3.sqlite_version_info is the SQLite C library version as a tuple of
# three integers, e.g. (3, 51, 3). No prior sqlite3 spec checks this attribute.
# ---------------------------------------------------------------------------

invariant sqlite3_extra11.sqlite_version_info.class_name:
  description: "sqlite3.sqlite_version_info.__class__.__name__ == 'tuple'"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version_info.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant sqlite3_extra11.sqlite_version_info.len:
  description: "sqlite3.sqlite_version_info has 3 components (major, minor, patch)"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version_info.__len__
  args: []
  expected: 3
