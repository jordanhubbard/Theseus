spec: inspect_extra206
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "Python inspect documentation — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra.zspec.zsdl — covers __name__ and __module__ checks for inspect functions; isclass/isbuiltin/isfunction behavioral cases; Parameter and Signature classnames"
    - "inspect_signature.zspec.zsdl — covers BoundArguments, Signature, Parameter module and kind checks"
  notes:
    - "inspect.getmembers.__defaults__.__class__.__name__ == 'tuple' — getmembers has one default (predicate=None); __defaults__ is a one-element tuple. Verified with Python 3.14.3."
    - "inspect.getmembers.__defaults__.__len__() == 1 — getmembers has exactly one positional default. Verified with Python 3.14.3."
    - "inspect.getmembers_static.__defaults__.__class__.__name__ == 'tuple' — getmembers_static follows the same signature as getmembers. Verified with Python 3.14.3."
    - "inspect.getclasstree.__defaults__.__class__.__name__ == 'tuple' — getclasstree has one default (unique=False). Verified with Python 3.14.3."
    - "inspect.getframeinfo.__defaults__.__class__.__name__ == 'tuple' — getframeinfo has one default (context=1). Verified with Python 3.14.3."
    - "inspect.signature.__defaults__.__class__.__name__ == 'NoneType' — signature has no positional defaults (all parameters are keyword-only in Python 3.14). Verified with Python 3.14.3."
    - "inspect.getsource.__defaults__.__class__.__name__ == 'NoneType' — getsource takes one required arg (object) with no default. Verified with Python 3.14.3."
    - "inspect.getfile.__defaults__.__class__.__name__ == 'NoneType' — getfile takes one required arg (object) with no default. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __defaults__.__class__.__name__ for inspect functions
#
# getmembers, getmembers_static, getclasstree, and getframeinfo have optional
# parameters with defaults, so __defaults__ is a tuple. signature, getsource,
# and getfile have no positional defaults, so __defaults__ is None.
# ---------------------------------------------------------------------------

table inspect_extra206.defaults_class_name:
  description: "__defaults__.__class__.__name__ for inspect module functions; new to extra206"
  kind: python_call_eq
  category: defaults
  id_prefix: inspectdefaults206

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_defaults_class,
       "getmembers.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.getmembers.__defaults__.__class__.__name__ == 'tuple' — getmembers(object, predicate=None) has one optional parameter; __defaults__ is a one-element tuple containing None; str.__eq__('tuple') returns True; new to extra206"]
    - [getmembers_static_defaults_class,
       "getmembers_static.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.getmembers_static.__defaults__.__class__.__name__ == 'tuple' — getmembers_static(object, predicate=None) mirrors getmembers and has one optional parameter; __defaults__ is a one-element tuple; str.__eq__('tuple') returns True; new to extra206"]
    - [getclasstree_defaults_class,
       "getclasstree.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.getclasstree.__defaults__.__class__.__name__ == 'tuple' — getclasstree(classes, unique=False) has one optional parameter (unique); __defaults__ is a one-element tuple containing False; str.__eq__('tuple') returns True; new to extra206"]
    - [signature_defaults_class,
       "signature.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "inspect.signature.__defaults__.__class__.__name__ == 'NoneType' — signature() has no positional defaults in Python 3.14 (parameters that were positional defaults became keyword-only); __defaults__ is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra206"]
    - [getsource_defaults_class,
       "getsource.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "inspect.getsource.__defaults__.__class__.__name__ == 'NoneType' — getsource(object) takes one required argument with no default; __defaults__ is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra206"]

# ---------------------------------------------------------------------------
# Table 2: __defaults__.__len__() for inspect functions with non-None defaults
#
# getmembers, getmembers_static, getclasstree, and getframeinfo each have
# exactly one positional default.
# ---------------------------------------------------------------------------

table inspect_extra206.defaults_len:
  description: "__defaults__.__len__() for inspect functions with non-None defaults; new to extra206"
  kind: python_call_eq
  category: defaults
  id_prefix: inspectdefaults206

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_defaults_len,
       "getmembers.__defaults__.__len__",
       [],
       1,
       "inspect.getmembers.__defaults__.__len__() == 1 — getmembers has exactly one positional default value (predicate=None); tuple.__len__() returns 1; new to extra206"]
    - [getmembers_static_defaults_len,
       "getmembers_static.__defaults__.__len__",
       [],
       1,
       "inspect.getmembers_static.__defaults__.__len__() == 1 — getmembers_static has exactly one positional default value (predicate=None); tuple.__len__() returns 1; new to extra206"]
    - [getclasstree_defaults_len,
       "getclasstree.__defaults__.__len__",
       [],
       1,
       "inspect.getclasstree.__defaults__.__len__() == 1 — getclasstree has exactly one positional default value (unique=False); tuple.__len__() returns 1; new to extra206"]
    - [getframeinfo_defaults_len,
       "getframeinfo.__defaults__.__len__",
       [],
       1,
       "inspect.getframeinfo.__defaults__.__len__() == 1 — getframeinfo(frame, context=1) has exactly one positional default value (context=1); tuple.__len__() returns 1; new to extra206"]

# ---------------------------------------------------------------------------
# Table 3: NoneType __defaults__ — confirm that required-only inspect functions
# have None for __defaults__; cross-check with tuple-bearing functions
#
# signature, getsource, and getfile all require exactly one positional arg
# with no default. isfunction and isclass similarly have no defaults.
# ---------------------------------------------------------------------------

table inspect_extra206.none_defaults_check:
  description: "signature, getsource, getfile have NoneType __defaults__; getmembers does not; new to extra206"
  kind: python_call_eq
  category: defaults
  id_prefix: inspectdefaults206

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_defaults_nonetype,
       "getfile.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "inspect.getfile.__defaults__.__class__.__name__ == 'NoneType' — getfile(object) takes one required argument; __defaults__ is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra206"]
    - [isfunction_defaults_nonetype,
       "isfunction.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "inspect.isfunction.__defaults__.__class__.__name__ == 'NoneType' — isfunction(object) takes one required argument; __defaults__ is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra206"]
    - [getmembers_defaults_not_nonetype,
       "getmembers.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "inspect.getmembers.__defaults__.__class__.__name__ != 'NoneType' — getmembers has one optional parameter so __defaults__ is a tuple, NOT None; str.__eq__('NoneType') returns False; new to extra206"]
    - [getclasstree_defaults_not_nonetype,
       "getclasstree.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "inspect.getclasstree.__defaults__.__class__.__name__ != 'NoneType' — getclasstree has one optional parameter (unique=False) so __defaults__ is a tuple, NOT None; str.__eq__('NoneType') returns False; new to extra206"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra206
# ---------------------------------------------------------------------------

invariant inspect_extra206.getmembers_defaults_class_tuple:
  description: "inspect.getmembers.__defaults__.__class__.__name__ == 'tuple' — predicate=None is the one optional default; new to extra206"
  kind: python_call_eq
  function: getmembers.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra206.getmembers_defaults_len_1:
  description: "inspect.getmembers.__defaults__.__len__() == 1 — getmembers has exactly one positional default; new to extra206"
  kind: python_call_eq
  function: getmembers.__defaults__.__len__
  args: []
  expected: 1

invariant inspect_extra206.signature_defaults_nonetype:
  description: "inspect.signature.__defaults__.__class__.__name__ == 'NoneType' — signature has no positional defaults in Python 3.14; new to extra206"
  kind: python_call_eq
  function: signature.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant inspect_extra206.getsource_defaults_nonetype:
  description: "inspect.getsource.__defaults__.__class__.__name__ == 'NoneType' — getsource requires one argument, no defaults; new to extra206"
  kind: python_call_eq
  function: getsource.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant inspect_extra206.getclasstree_defaults_class_tuple:
  description: "inspect.getclasstree.__defaults__.__class__.__name__ == 'tuple' — unique=False is the one optional default; new to extra206"
  kind: python_call_eq
  function: getclasstree.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra206.getframeinfo_defaults_len_1:
  description: "inspect.getframeinfo.__defaults__.__len__() == 1 — getframeinfo has exactly one positional default (context=1); new to extra206"
  kind: python_call_eq
  function: getframeinfo.__defaults__.__len__
  args: []
  expected: 1

invariant inspect_extra206.getmembers_static_defaults_class_tuple:
  description: "inspect.getmembers_static.__defaults__.__class__.__name__ == 'tuple' — getmembers_static predicate=None is the one optional default; new to extra206"
  kind: python_call_eq
  function: getmembers_static.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra206.getfile_defaults_nonetype:
  description: "inspect.getfile.__defaults__.__class__.__name__ == 'NoneType' — getfile requires one argument with no default; new to extra206"
  kind: python_call_eq
  function: getfile.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
