spec: lodash_pullall
version: ">=4.0.0"
backend: node(lodash.pullall)

docs: https://lodash.com/docs/#pullAll

provenance:
  derived_from:
    - "lodash.pullall README — https://www.npmjs.com/package/lodash.pullall"
    - "Test vectors verified with lodash.pullall@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.pullall exports the _.pullAll function directly as module.exports."
    - "pullAll(array, values) removes all occurrences of values from array in place."
    - "Returns the mutated array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the mutated array with all matching values removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_pullall.pullall:
  kind: node_module_call_eq
  function: ~
  category: pullall
  id_prefix: lpall

  columns: [id, args, expected]
  rows:
    - [remove_two,    [[1, 2, 3, 1, 2], [2]],    [1, 3, 1]]
    - [remove_multi,  [[1, 2, 3, 4, 5], [2, 4]], [1, 3, 5]]
    - [not_present,   [[1, 2, 3], [9]],           [1, 2, 3]]
