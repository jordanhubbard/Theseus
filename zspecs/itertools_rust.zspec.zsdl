spec: itertools_rust
version: ">=3.9"
backend: rust_module(itertools_rust)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation (API surface and semantics)"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Clean-room Rust reimplementation of selected Python itertools functions, exposed via PyO3."
    - "All functions return lists (not iterators) for ease of testing and PyO3 interop."
    - "chain(list1, list2, ...) -> list — concatenates multiple iterables."
    - "islice(lst, stop) -> list — first stop elements; islice(lst, start, stop) -> list — slice."
    - "product(lst1, lst2, ...) -> list[list] — Cartesian product (inner elements are lists, not tuples)."
    - "combinations(lst, r) -> list[list] — r-length combos in sorted order."
    - "permutations(lst, r) -> list[list] — r-length perms in all orders."
    - "repeat(value, n) -> list — list of n copies of value."
    - "flatten(list_of_lists) -> list — one level of nesting removed."
    - "takewhile(pred_name, lst) -> list — elements while predicate holds."
    - "dropwhile(pred_name, lst) -> list — skip while predicate holds."
    - "Note: product/combinations/permutations return lists-of-lists (not tuples) for PyO3 simplicity."
    - "All test vectors verified against Python 3.14.3."
  created_at: "2026-04-18T00:00:00Z"

error_model: python_exceptions

table itertools_rust.chain:
  kind: python_call_eq
  category: chain
  id_prefix: chain
  function: chain

  columns: [id, args, expected]
  rows:
    - [two_lists,    [[1, 2], [3, 4]],             [1, 2, 3, 4]      ]
    - [three_lists,  [[1], [2, 3], [4, 5, 6]],     [1, 2, 3, 4, 5, 6]]
    - [empty_first,  [[], [1, 2]],                  [1, 2]            ]
    - [empty_second, [[1, 2], []],                  [1, 2]            ]
    - [both_empty,   [[], []],                       []               ]
    - [strings,      [["a", "b"], ["c"]],           ["a", "b", "c"]  ]

