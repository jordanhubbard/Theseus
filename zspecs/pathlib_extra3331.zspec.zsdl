spec: pp3331
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 669 (pp3331): __iand__, __ior__, __ixor__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __iand__, __ior__, __ixor__ dict-presence (in-place &=, |=, ^=)."
    - "No pathlib class defines __iand__ in its own __dict__: path objects are filesystem path abstractions, not numeric or bitwise types; in-place bitwise AND has no meaning for paths."
    - "No pathlib class defines __ior__ in its own __dict__: path objects do not implement in-place bitwise OR; bitwise operators are not part of the path protocol."
    - "No pathlib class defines __ixor__ in its own __dict__: path objects do not implement in-place bitwise XOR; augmented bitwise assignment operators have no meaning for filesystem paths."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with waves 666/667/668 pattern: all in-place arithmetic/bitwise operators absent from pathlib class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iand__ dict-presence — operator.contains(Cls.__dict__, '__iand__')
#
# No pathlib class defines __iand__ in its own __dict__; all false.
# pathlib path objects are filesystem path abstractions, not numeric types;
# the &= operator has no semantic meaning for path objects.
# ---------------------------------------------------------------------------

table pp3331.iand:
  description: "pathlib types __iand__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3331

  columns: [id, function, args, expected]
  rows:
    - ["pp3331001", operator.contains, [pathlib.PurePath.__dict__,         "__iand__"], false]
    - ["pp3331002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__iand__"], false]
    - ["pp3331003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__iand__"], false]
    - ["pp3331004", operator.contains, [pathlib.Path.__dict__,             "__iand__"], false]
    - ["pp3331005", operator.contains, [pathlib.PosixPath.__dict__,        "__iand__"], false]

