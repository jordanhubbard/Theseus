spec: uuid_extra251
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra250.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__hash__/__eq__/__lt__/__int__ qualname and class_name identity."
  notes:
    - "uuid.NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500 are predefined UUID v1 instances per RFC 4122 Appendix C."
    - "All four namespace UUIDs have version==1 (version 1 UUID based on time and node)."
    - "All four namespace UUIDs have variant=='specified in RFC 4122' — the variant field is the string returned by uuid.UUID.variant property."
    - "uuid.NAMESPACE_DNS.bytes_le.__class__.__name__ == 'bytes' and len == 16 — bytes_le is the UUID bytes in little-endian (mixed-endian) byte order."
    - "All four namespace UUID objects share the same version and variant values; they differ only in their int field."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NAMESPACE_DNS / NAMESPACE_URL / NAMESPACE_OID / NAMESPACE_X500 — version
#
# All four predefined namespace UUIDs are version-1 UUIDs as specified in
# RFC 4122 Appendix C.  uuid.UUID.version returns the integer version number.
# ---------------------------------------------------------------------------

table uuid_extra251.namespaces_version:
  description: "uuid.NAMESPACE_DNS/URL/OID/X500 all have version==1 (RFC 4122 v1 UUID); verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: uuidns251

  columns: [id, function, args, expected, description]
  rows:
    - [dns_version,   NAMESPACE_DNS.version.__eq__,   [1], true, "uuid.NAMESPACE_DNS.version == 1 (RFC 4122 Appendix C)"]
    - [url_version,   NAMESPACE_URL.version.__eq__,   [1], true, "uuid.NAMESPACE_URL.version == 1 (RFC 4122 Appendix C)"]
    - [oid_version,   NAMESPACE_OID.version.__eq__,   [1], true, "uuid.NAMESPACE_OID.version == 1 (RFC 4122 Appendix C)"]
    - [x500_version,  NAMESPACE_X500.version.__eq__,  [1], true, "uuid.NAMESPACE_X500.version == 1 (RFC 4122 Appendix C)"]

# ---------------------------------------------------------------------------
# NAMESPACE_DNS / NAMESPACE_URL / NAMESPACE_OID / NAMESPACE_X500 — variant
#
# All four predefined namespace UUIDs have variant == 'specified in RFC 4122'.
# uuid.UUID.variant is a property returning one of the RESERVED_* or RFC_4122
# string constants defined in uuid.py.
# ---------------------------------------------------------------------------

table uuid_extra251.namespaces_variant:
  description: "uuid.NAMESPACE_DNS/URL/OID/X500 all have variant=='specified in RFC 4122'; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: uuidns251

  columns: [id, function, args, expected, description]
  rows:
    - [dns_variant,   NAMESPACE_DNS.variant.__eq__,   ["specified in RFC 4122"], true, "uuid.NAMESPACE_DNS.variant == 'specified in RFC 4122'"]
    - [url_variant,   NAMESPACE_URL.variant.__eq__,   ["specified in RFC 4122"], true, "uuid.NAMESPACE_URL.variant == 'specified in RFC 4122'"]
    - [oid_variant,   NAMESPACE_OID.variant.__eq__,   ["specified in RFC 4122"], true, "uuid.NAMESPACE_OID.variant == 'specified in RFC 4122'"]
    - [x500_variant,  NAMESPACE_X500.variant.__eq__,  ["specified in RFC 4122"], true, "uuid.NAMESPACE_X500.variant == 'specified in RFC 4122'"]

# ---------------------------------------------------------------------------
# NAMESPACE_DNS.bytes_le — class and length
#
# uuid.UUID.bytes_le is the UUID bytes in little-endian (mixed-endian) byte
# order as specified by RFC 4122 Section 4.1.2. It is always 16 bytes.
# ---------------------------------------------------------------------------

invariant uuid_extra251.NAMESPACE_DNS.bytes_le.class_name:
  description: "uuid.NAMESPACE_DNS.bytes_le.__class__.__name__ == 'bytes' — bytes_le is a bytes object"
  category: constants
  kind: python_call_eq
  function: NAMESPACE_DNS.bytes_le.__class__.__name__.__eq__
  args: ["bytes"]
  expected: true

invariant uuid_extra251.NAMESPACE_DNS.bytes_le.len:
  description: "len(uuid.NAMESPACE_DNS.bytes_le) == 16 — UUID bytes_le is always 16 bytes"
  category: constants
  kind: python_call_eq
  function: NAMESPACE_DNS.bytes_le.__len__
  args: []
  expected: 16
