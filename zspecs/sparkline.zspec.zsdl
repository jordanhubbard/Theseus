spec: sparkline
version: ">=0.2.0"
backend: node(sparkline)

docs: https://github.com/sindresorhus/sparkline#readme

provenance:
  derived_from:
    - "sparkline README — https://github.com/sindresorhus/sparkline#readme"
    - "Test vectors verified with sparkline via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "sparkline source"
  notes:
    - "Generates Unicode block-character sparklines from numeric arrays."
    - "Install: npm install sparkline"
    - "Module export IS the function: sparkline([1,2,3]) → '▁▂▄'."
    - "Uses 8 levels of Unicode block characters (▁▂▃▄▅▆▇█)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; throws on non-numeric input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table sparkline.draw:
  kind: node_module_call_eq
  category: draw
  function: ~
  id_prefix: spark

  columns: [id, args, expected]
  rows:
    - [ascending,
       [[1, 2, 3, 4, 5]],
       "▁▂▄▆█"]

    - [descending,
       [[5, 4, 3, 2, 1]],
       "█▆▄▂▁"]

    - [all_equal,
       [[1, 1, 1, 1]],
       "▁▁▁▁"]

    - [single_value,
       [[42]],
       "▁"]

    - [zero_to_max,
       [[0, 100]],
       "▁█"]

    - [empty_array,
       [[]],
       ""]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:08:09Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
