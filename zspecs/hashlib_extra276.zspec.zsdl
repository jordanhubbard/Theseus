spec: hashlib_extra276
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra275.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest test vectors and digest_size/block_size attributes."
    - "hashlib_extra274.zspec.zsdl — covers BLAKE2 constructor identity and hmac.HMAC method identity."
    - "hashlib_extra273.zspec.zsdl — covers hmac module identity and HMAC class/function identity."
  notes:
    - "hashlib.sha512(b'').hexdigest() == 'cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e' — well-known SHA-512 digest of the empty byte string (128 hex chars / 64 bytes). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha224(b'').hexdigest() == 'd14a028c2a3a2bc9476102bb288234c415a2b01f828ea62ac5b3e42f' — well-known SHA-224 digest of the empty byte string (56 hex chars / 28 bytes). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256(b'').digest_size == 32 — SHA-256 output is 256 bits / 32 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha512(b'').digest_size == 64 — SHA-512 output is 512 bits / 64 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha224(b'').digest_size == 28 — SHA-224 output is 224 bits / 28 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha512(b'').block_size == 128 — SHA-512 internal block size is 1024 bits / 128 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha224(b'').block_size == 64 — SHA-224 shares the SHA-256 block size of 512 bits / 64 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha512(b'').name == 'sha512' — .name attribute returns the algorithm name string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha224(b'').name == 'sha224' — .name attribute returns the algorithm name string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Empty-input hexdigest values for SHA-512 and SHA-224
# These are universal test vectors: the hexdigest of b'' is a fixed,
# well-known value for each algorithm.
# SHA-512 produces 128 hex chars (64 bytes); SHA-224 produces 56 hex chars
# (28 bytes). Both are truncations of the SHA-2 family Merkle–Damgård design.
# ---------------------------------------------------------------------------

table hashlib_extra276.sha512_sha224_empty_hexdigest:
  description: "hashlib SHA-512 and SHA-224 empty-input hexdigest test vectors — sha512(b'')/sha224(b'') produce well-known fixed hex strings; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: emptydig276

  columns: [id, function, args, expected, description]
  rows:
    - [sha512_hex,  sha512_hexdigest_of_empty.__eq__,  ["cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"], true, "hashlib.sha512(b'').hexdigest() == known SHA-512 of empty bytes (128 hex chars)"]
    - [sha224_hex,  sha224_hexdigest_of_empty.__eq__,  ["d14a028c2a3a2bc9476102bb288234c415a2b01f828ea62ac5b3e42f"],                             true, "hashlib.sha224(b'').hexdigest() == known SHA-224 of empty bytes (56 hex chars)"]
    - [sha512_name, sha512_name_attr.__eq__,           ["sha512"],                                                                                    true, "hashlib.sha512(b'').name == 'sha512' — algorithm name attribute"]
    - [sha224_name, sha224_name_attr.__eq__,           ["sha224"],                                                                                    true, "hashlib.sha224(b'').name == 'sha224' — algorithm name attribute"]

# ---------------------------------------------------------------------------
# digest_size and block_size for SHA-512, SHA-224, and SHA-256
# SHA-512 uses a 1024-bit (128-byte) block and produces 64-byte digests.
# SHA-224 shares the SHA-256 compression function (64-byte block) but
# truncates output to 28 bytes. SHA-256 produces 32 bytes.
# ---------------------------------------------------------------------------

table hashlib_extra276.sha512_sha224_sizes:
  description: "hashlib SHA-512/SHA-224/SHA-256 digest_size and block_size — sha512: 64/128; sha224: 28/64; sha256: 32/64; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sizes276

  columns: [id, function, args, expected, description]
  rows:
    - [sha512_dsize,  sha512_digest_size.__eq__,  [64],  true, "hashlib.sha512(b'').digest_size == 64 — SHA-512 output is 64 bytes"]
    - [sha224_dsize,  sha224_digest_size.__eq__,  [28],  true, "hashlib.sha224(b'').digest_size == 28 — SHA-224 output is 28 bytes"]
    - [sha256_dsize,  sha256_digest_size.__eq__,  [32],  true, "hashlib.sha256(b'').digest_size == 32 — SHA-256 output is 32 bytes"]
    - [sha512_bsize,  sha512_block_size.__eq__,   [128], true, "hashlib.sha512(b'').block_size == 128 — SHA-512 internal block is 128 bytes"]
    - [sha224_bsize,  sha224_block_size.__eq__,   [64],  true, "hashlib.sha224(b'').block_size == 64 — SHA-224 shares SHA-256 block size of 64 bytes"]

# ---------------------------------------------------------------------------
# Standalone invariants — SHA-512/SHA-224 test vectors and size attributes
# ---------------------------------------------------------------------------

invariant hashlib_extra276.sha512_empty_hexdigest_eq:
  description: "hashlib.sha512(b'').hexdigest() == 'cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e' — canonical SHA-512 test vector for the empty byte string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: sha512_hexdigest_of_empty.__eq__
  args: ["cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"]
  expected: true

invariant hashlib_extra276.sha224_empty_hexdigest_eq:
  description: "hashlib.sha224(b'').hexdigest() == 'd14a028c2a3a2bc9476102bb288234c415a2b01f828ea62ac5b3e42f' — canonical SHA-224 test vector for the empty byte string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: sha224_hexdigest_of_empty.__eq__
  args: ["d14a028c2a3a2bc9476102bb288234c415a2b01f828ea62ac5b3e42f"]
  expected: true

invariant hashlib_extra276.sha512_digest_size_eq:
  description: "hashlib.sha512(b'').digest_size == 64 — SHA-512 produces a 512-bit / 64-byte digest; this is the largest output among the SHA-2 variants; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha512_digest_size.__eq__
  args: [64]
  expected: true

invariant hashlib_extra276.sha224_digest_size_eq:
  description: "hashlib.sha224(b'').digest_size == 28 — SHA-224 produces a 224-bit / 28-byte digest; it is a truncated variant of SHA-256; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha224_digest_size.__eq__
  args: [28]
  expected: true

invariant hashlib_extra276.sha256_digest_size_eq:
  description: "hashlib.sha256(b'').digest_size == 32 — SHA-256 produces a 256-bit / 32-byte digest; this attribute is fixed for the algorithm; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha256_digest_size.__eq__
  args: [32]
  expected: true

invariant hashlib_extra276.sha512_block_size_eq:
  description: "hashlib.sha512(b'').block_size == 128 — SHA-512 operates on 1024-bit / 128-byte input blocks; this is twice the block size of SHA-256; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha512_block_size.__eq__
  args: [128]
  expected: true

invariant hashlib_extra276.sha224_block_size_eq:
  description: "hashlib.sha224(b'').block_size == 64 — SHA-224 shares the SHA-256 compression function and therefore the same 512-bit / 64-byte block size; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha224_block_size.__eq__
  args: [64]
  expected: true

invariant hashlib_extra276.sha512_name_eq:
  description: "hashlib.sha512(b'').name == 'sha512' — the .name attribute of a hash object is the lowercase algorithm name string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha512_name_attr.__eq__
  args: ["sha512"]
  expected: true

invariant hashlib_extra276.sha224_name_eq:
  description: "hashlib.sha224(b'').name == 'sha224' — the .name attribute of a hash object is the lowercase algorithm name string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha224_name_attr.__eq__
  args: ["sha224"]
  expected: true
