    - ["as3406009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__bool__"], false]
    - ["as3406010", operator.contains, [asyncio.LifoQueue.__dict__,        "__bool__"], false]

# ---------------------------------------------------------------------------
# __str__ dict-presence — operator.contains(Cls.__dict__, '__str__')
#
# All 10 asyncio classes return false for __str__.
# str() delegates to __str__ when defined in the class's own __dict__.
# asyncio types rely on inherited __str__ from object — none of the 10
#   classes define a custom __str__ in their own __dict__.
# asyncio.Task/Future: produce informative runtime representations but do
#   not override __str__ in their own __dict__; string rendering falls back
#   to inherited behavior.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: synchronization
#   guards with no __str__ customization in their own __dict__.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores with no __str__
#   defined at the class level.
# ---------------------------------------------------------------------------

