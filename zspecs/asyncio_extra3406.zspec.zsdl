# ---------------------------------------------------------------------------
# __repr__ dict-presence — operator.contains(Cls.__dict__, '__repr__')
#
# All 10 asyncio classes return false for __repr__.
# repr() delegates to __repr__ when defined in the class's own __dict__.
# CPython implements asyncio.Task and asyncio.Future repr via C-level
#   tp_repr slots — not via a Python-level __repr__ entry in __dict__.
#   As a result operator.contains(asyncio.Task.__dict__, '__repr__') and
#   operator.contains(asyncio.Future.__dict__, '__repr__') both return false.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: no __repr__
#   entry in their own __dict__; repr falls back to inherited object repr.
# asyncio.Queue/PriorityQueue/LifoQueue: no __repr__ entry in their own
#   __dict__; repr falls back to inherited behavior.
# ---------------------------------------------------------------------------

