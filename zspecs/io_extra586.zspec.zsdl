spec: io_extra586
version: ">=3.9"
backend: python_module(io)
docs: "Behavioral spec covering io class __module__ and method __qualname__ identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module class hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All classes in the io module should report __module__ == 'io'"
    - "Method __qualname__ must match the canonical dotted class.method form"
  created_at: "2026-04-12T00:00:00Z"

table io586md:
  description: "io class __module__ identity checks"
  columns: [id, function, args, expected]
  rows:
    - [io586md01, io.IOBase.__module__.__eq__, ["io"], true]
    - [io586md02, io.RawIOBase.__module__.__eq__, ["io"], true]
    - [io586md03, io.BufferedIOBase.__module__.__eq__, ["io"], true]
    - [io586md04, io.TextIOBase.__module__.__eq__, ["io"], true]
    - [io586md05, io.FileIO.__module__.__eq__, ["io"], true]
    - [io586md06, io.BytesIO.__module__.__eq__, ["io"], true]
    - [io586md07, io.StringIO.__module__.__eq__, ["io"], true]
    - [io586md08, io.TextIOWrapper.__module__.__eq__, ["io"], true]

table io586qn:
  description: "io method __qualname__ identity checks"
  columns: [id, function, args, expected]
  rows:
    - [io586qn01, io.BytesIO.__init__.__qualname__.__eq__, ["BytesIO.__init__"], true]
    - [io586qn02, io.BytesIO.read.__qualname__.__eq__, ["BytesIO.read"], true]
    - [io586qn03, io.BytesIO.write.__qualname__.__eq__, ["BytesIO.write"], true]
    - [io586qn04, io.StringIO.__init__.__qualname__.__eq__, ["StringIO.__init__"], true]
    - [io586qn05, io.StringIO.read.__qualname__.__eq__, ["StringIO.read"], true]
    - [io586qn06, io.StringIO.write.__qualname__.__eq__, ["StringIO.write"], true]
