spec: threading_extra1021
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading class __weakref__ descriptor identity and module-level attribute class names"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1021.weakref_descriptor_classes:
  description: "threading class __weakref__.__class__.__name__ is 'getset_descriptor'"
  kind: python_call_eq
  category: weakref_descriptor
  id_prefix: th1021wd
  columns: [id, function, args, expected]
  rows:
    - [th1021wd001, threading.Thread.__weakref__.__class__.__name__.__eq__,    ["getset_descriptor"], true]
    - [th1021wd002, threading.Event.__weakref__.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [th1021wd003, threading.Semaphore.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [th1021wd004, threading.Condition.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [th1021wd005, threading.Timer.__weakref__.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [th1021wd006, threading.Barrier.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]

table threading_extra1021.module_attributes:
  description: "threading module-level attribute class names"
  kind: python_call_eq
  category: module_attributes
  id_prefix: th1021ma
  columns: [id, function, args, expected]
  rows:
    - [th1021ma001, threading.__all__.__class__.__name__.__eq__,           ["list"],   true]
    - [th1021ma002, threading.__name__.__eq__,                             ["threading"], true]
    - [th1021ma003, threading.__spec__.__class__.__name__.__eq__,          ["ModuleSpec"], true]
    - [th1021ma004, threading.Thread.__class__.__name__.__eq__,            ["type"],   true]
    - [th1021ma005, threading.Event.__class__.__name__.__eq__,             ["type"],   true]
    - [th1021ma006, threading.Semaphore.__class__.__name__.__eq__,         ["type"],   true]
    - [th1021ma007, threading.Condition.__class__.__name__.__eq__,         ["type"],   true]

table threading_extra1021.class_modules:
  description: "threading class __module__ identity"
  kind: python_call_eq
  category: class_modules
  id_prefix: th1021cm
  columns: [id, function, args, expected]
  rows:
    - [th1021cm001, threading.Thread.__module__.__eq__,    ["threading"], true]
    - [th1021cm002, threading.Event.__module__.__eq__,     ["threading"], true]
    - [th1021cm003, threading.Semaphore.__module__.__eq__, ["threading"], true]
    - [th1021cm004, threading.Condition.__module__.__eq__, ["threading"], true]
    - [th1021cm005, threading.Timer.__module__.__eq__,     ["threading"], true]
    - [th1021cm006, threading.Barrier.__module__.__eq__,   ["threading"], true]
    - [th1021cm007, threading.Lock.__module__.__eq__,      ["threading"], true]
