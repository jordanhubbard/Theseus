spec: lodash_omitby
version: ">=4.0.0"
backend: node(lodash.omitby)

docs: https://lodash.com/docs/#omitBy

provenance:
  derived_from:
    - "lodash.omitby README — https://www.npmjs.com/package/lodash.omitby"
    - "Test vectors verified with lodash.omitby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.omitby exports the _.omitBy function directly as module.exports."
    - "omitBy(object) with no iteratee omits properties with truthy values."
    - "Complement of pickBy."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns new object without omitted properties."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_omitby.omitby:
  kind: node_module_call_eq
  function: ~
  category: omitby
  id_prefix: loby

  columns: [id, args, expected]
  rows:
    - [falsy_only,   [{"a": 1, "b": 0, "c": "hello", "d": null}],
       {"b": 0, "d": null}]
    - [all_truthy,   [{"x": 1, "y": 2}],
       {}]
    - [none_truthy,  [{"a": 0, "b": null}],
       {"a": 0, "b": null}]

