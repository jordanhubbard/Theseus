spec: struct_extra1801
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python struct documentation — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — covers pack/unpack/calcsize vectors and roundtrip invariants"
    - "struct_extra.zspec.zsdl — covers additional struct format and error checks"
    - "struct_extra1786.zspec.zsdl — covers __class_getitem__/__init_subclass__ hooks; Struct __weakref__, base class, size/format/pack/unpack/pack_into/unpack_from/iter_unpack; error __weakref__, base class"
    - "struct_extra1771.zspec.zsdl — covers async protocol dict-presence checks for struct.Struct"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value protocol; container and context manager protocol presence."
    - "Theme: which struct types define __bool__/__len__ and context-manager/container protocol methods in their own __dict__."
    - "struct.Struct.__dict__.__contains__('__bool__') -> False — Struct is a C extension type; it does not define a custom truth value; bool(s) defers to object.__bool__ which returns True."
    - "struct.Struct.__dict__.__contains__('__len__') -> False — Struct is not a sized container; there is no meaningful len(s) for a format-compiled struct."
    - "struct.error.__dict__.__contains__('__bool__') -> False — struct.error is an exception; exceptions do not define __bool__ in their own __dict__."
    - "struct.error.__dict__.__contains__('__len__') -> False — struct.error is not a container."
    - "struct.Struct.__dict__.__contains__('__enter__') -> False — Struct does not implement the context manager protocol."
    - "struct.Struct.__dict__.__contains__('__exit__') -> False — Struct does not implement the context manager protocol."
    - "struct.Struct.__dict__.__contains__('__iter__') -> False — Struct is not iterable; iteration is done via iter_unpack(), not the struct object itself."
    - "struct.Struct.__dict__.__contains__('__contains__') -> False — Struct is not a container."
    - "struct.Struct.__dict__.__contains__('__getitem__') -> False — Struct does not support subscript access."
    - "struct.Struct.__dict__.__contains__('pack') -> True — pack is a C-level method defined directly on Struct."
    - "struct.Struct.__dict__.__contains__('unpack') -> True — unpack is a C-level method."
    - "struct.Struct.__dict__.__contains__('pack_into') -> True — pack_into writes into a writable buffer."
    - "struct.Struct.__dict__.__contains__('unpack_from') -> True — unpack_from reads from a buffer at an offset."
    - "struct.Struct.__dict__.__contains__('iter_unpack') -> True — iter_unpack yields successive tuples."
    - "struct.Struct.__dict__.__contains__('format') -> True — format is a read-only C-level descriptor exposing the format string."
    - "struct.Struct.__dict__.__contains__('size') -> True — size is a read-only C-level descriptor exposing the byte size."
    - "struct.Struct.__dict__.__contains__('__repr__') -> False — Struct inherits __repr__ from object; it is not in Struct's own __dict__."
    - "struct.Struct.__dict__.__contains__('__doc__') -> True — C extension types define __doc__ in their own __dict__."
    - "struct.Struct.__dict__.__contains__('__new__') -> True — Struct defines __new__ to handle format string compilation."
    - "All expected values verified by running Python 3.14 struct module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra1801.truth_protocol:
  description: "struct.Struct and struct.error __bool__/__len__ dict-presence checks — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1801

  columns: [id, function, args, expected]
  rows:
    - ["st1801001", "struct.Struct.__dict__.__contains__", ["__bool__"], false]
    - ["st1801002", "struct.Struct.__dict__.__contains__", ["__len__"],  false]
    - ["st1801003", "struct.error.__dict__.__contains__",  ["__bool__"], false]
    - ["st1801004", "struct.error.__dict__.__contains__",  ["__len__"],  false]

table struct_extra1801.context_manager_protocol:
  description: "struct.Struct context manager and container protocol dict-presence checks — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1801

  columns: [id, function, args, expected]
  rows:
    - ["st1801005", "struct.Struct.__dict__.__contains__", ["__enter__"],    false]
    - ["st1801006", "struct.Struct.__dict__.__contains__", ["__exit__"],     false]
    - ["st1801007", "struct.Struct.__dict__.__contains__", ["__iter__"],     false]
    - ["st1801008", "struct.Struct.__dict__.__contains__", ["__contains__"], false]
    - ["st1801009", "struct.Struct.__dict__.__contains__", ["__getitem__"],  false]

table struct_extra1801.struct_attrs:
  description: "struct.Struct method and property dict-presence checks — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1801

  columns: [id, function, args, expected]
  rows:
    - ["st1801010", "struct.Struct.__dict__.__contains__", ["pack"],         true]
    - ["st1801011", "struct.Struct.__dict__.__contains__", ["unpack"],       true]
    - ["st1801012", "struct.Struct.__dict__.__contains__", ["pack_into"],    true]
    - ["st1801013", "struct.Struct.__dict__.__contains__", ["unpack_from"],  true]
    - ["st1801014", "struct.Struct.__dict__.__contains__", ["iter_unpack"],  true]
    - ["st1801015", "struct.Struct.__dict__.__contains__", ["format"],       true]
    - ["st1801016", "struct.Struct.__dict__.__contains__", ["size"],         true]
    - ["st1801017", "struct.Struct.__dict__.__contains__", ["__repr__"],     false]
    - ["st1801018", "struct.Struct.__dict__.__contains__", ["__doc__"],      true]
    - ["st1801019", "struct.Struct.__dict__.__contains__", ["__new__"],      true]
