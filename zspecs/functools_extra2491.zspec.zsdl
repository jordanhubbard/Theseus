  category: boolean_identity
  id_prefix: ft2491

  columns: [id, function, args, expected]
  rows:
    - ["ft2491-013", "singledispatchmethod.__dict__.__contains__", ["__setitem__"], false]
    - ["ft2491-014", "singledispatchmethod.__dict__.__contains__", ["__delitem__"], false]
    - ["ft2491-015", "singledispatchmethod.__dict__.__contains__", ["__missing__"], false]
    - ["ft2491-016", "itemgetter.__dict__.__contains__", ["__setitem__"], false]
    - ["ft2491-017", "itemgetter.__dict__.__contains__", ["__delitem__"], false]
    - ["ft2491-018", "itemgetter.__dict__.__contains__", ["__missing__"], false]
