spec: functools_extra2491
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: __setitem__, __delitem__, and __missing__ dict-presence checks for functools classes."
    - "Theme: mutable item access and missing-key protocol — checking class __dict__ membership via __contains__."
    - "functools.partial, functools.partialmethod, functools.cached_property, functools.MappingProxyType, functools._lru_cache_wrapper, functools.singledispatchmethod, functools.itemgetter, functools.RLock, functools.MappingProxyType — none define __setitem__, __delitem__, or __missing__."
    - "MappingProxyType is a read-only view: it defines __getitem__ but deliberately omits __setitem__ and __delitem__ to enforce immutability. Verified with Python 3.14."
    - "functools.partial is a C extension type; it holds func, args, keywords but does not implement the mutable mapping protocol. Verified with Python 3.14."
    - "functools.partialmethod is a pure-Python descriptor class; it has no item-access methods. Verified with Python 3.14."
    - "functools.cached_property is a pure-Python descriptor; it caches values in the instance __dict__, not via __setitem__. Verified with Python 3.14."
    - "functools._lru_cache_wrapper is a C extension type wrapping an lru_cache-decorated function; no item-access protocol. Verified with Python 3.14."
    - "functools.singledispatchmethod is a pure-Python descriptor; no item-access methods. Verified with Python 3.14."
    - "functools.itemgetter is a C extension type; it retrieves items via __getitem__ on targets, but does not itself define __setitem__, __delitem__, or __missing__. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — __setitem__, __delitem__, __missing__
#
# Theme: dict-presence of mutable item-access dunder methods on functools.partial.
# partial is a C extension type; it wraps a callable with pre-applied args/kwargs.
# None of the three mutation-protocol methods appear in partial.__dict__.
# ---------------------------------------------------------------------------

table functools_extra2491.partial_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from functools.partial.__dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2491

  columns: [id, function, args, expected]
  rows:
    - ["ft2491-001", "partial.__dict__.__contains__", ["__setitem__"], false]
    - ["ft2491-002", "partial.__dict__.__contains__", ["__delitem__"], false]
    - ["ft2491-003", "partial.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 2: functools.partialmethod — __setitem__, __delitem__, __missing__
#
# Theme: dict-presence of mutable item-access dunder methods on functools.partialmethod.
# partialmethod is a pure-Python descriptor for use in class bodies.
# It holds no item-access methods.
# ---------------------------------------------------------------------------

table functools_extra2491.partialmethod_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from functools.partialmethod.__dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2491

  columns: [id, function, args, expected]
  rows:
    - ["ft2491-004", "partialmethod.__dict__.__contains__", ["__setitem__"], false]
    - ["ft2491-005", "partialmethod.__dict__.__contains__", ["__delitem__"], false]
    - ["ft2491-006", "partialmethod.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property — __setitem__, __delitem__, __missing__
#
# Theme: dict-presence of mutable item-access dunder methods on functools.cached_property.
# cached_property stores computed values in the instance __dict__ directly,
# bypassing __setitem__; the class itself defines no item-access protocol.
# ---------------------------------------------------------------------------

table functools_extra2491.cached_property_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from functools.cached_property.__dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2491

  columns: [id, function, args, expected]
  rows:
    - ["ft2491-007", "cached_property.__dict__.__contains__", ["__setitem__"], false]
    - ["ft2491-008", "cached_property.__dict__.__contains__", ["__delitem__"], false]
    - ["ft2491-009", "cached_property.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 4: functools.MappingProxyType — __setitem__, __delitem__, __missing__
#
# Theme: dict-presence of mutable item-access dunder methods on MappingProxyType.
# MappingProxyType is an immutable read-only view of a mapping; it deliberately
# omits __setitem__ and __delitem__ to enforce immutability. No __missing__ either.
# ---------------------------------------------------------------------------

table functools_extra2491.mappingproxytype_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from functools.MappingProxyType.__dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2491

  columns: [id, function, args, expected]
  rows:
    - ["ft2491-010", "MappingProxyType.__dict__.__contains__", ["__setitem__"], false]
    - ["ft2491-011", "MappingProxyType.__dict__.__contains__", ["__delitem__"], false]
    - ["ft2491-012", "MappingProxyType.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 5: functools.singledispatchmethod and functools.itemgetter
#
# Theme: dict-presence of mutable item-access dunder methods on two further
# functools classes — singledispatchmethod (pure-Python descriptor) and
# itemgetter (C extension that reads items from targets, not itself a mapping).
# ---------------------------------------------------------------------------

table functools_extra2491.singledispatch_itemgetter_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from functools.singledispatchmethod and functools.itemgetter __dict__; wave 2491"
