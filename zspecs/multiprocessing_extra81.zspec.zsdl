spec: multiprocessing_extra81
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra80.zspec.zsdl."
    - "This spec covers: wave 245 theme — multiprocessing Process __dict__ membership. NEW in extra81: Process.__dict__.__contains__('start')==False (start is on BaseProcess not Process); Process.__dict__.__contains__('run')==False (run is on BaseProcess); Process.__dict__.__contains__('join')==False (join is on BaseProcess); Process.__dict__.__contains__('terminate')==False (terminate is on BaseProcess); Process.__dict__.__contains__('kill')==False (kill is on BaseProcess); Process.__dict__.__contains__('is_alive')==False (is_alive is on BaseProcess); Process.__dict__.__contains__('__init__')==False (__init__ is on BaseProcess); Process.__dict__.__class__.__name__=='mappingproxy'; Process.__qualname__=='Process'; Process.__name__=='Process'; Process.__module__=='multiprocessing.context'; Process.__bases__[0].__name__=='BaseProcess'. On macOS, multiprocessing.Process is created dynamically in the context module as a subclass of BaseProcess; all the main process lifecycle methods live on BaseProcess, not on the Process proxy class itself. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('start') == False. start is defined on BaseProcess, not on the context-specific Process subclass. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('run') == False. run is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('join') == False. join is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('terminate') == False. terminate is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('kill') == False. kill is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('is_alive') == False. is_alive is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('__init__') == False. __init__ is defined on BaseProcess, not on Process. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__class__.__name__ == 'mappingproxy'. Like all class __dict__ attributes, it is a mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__qualname__ == 'Process'. Simple class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__name__ == 'Process'. Simple class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context'. Process is defined in the multiprocessing.context submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'. Process directly subclasses BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process __dict__ membership (BaseProcess methods absent) — extra81
#
# Wave 245 theme: multiprocessing Process __dict__ membership.
#
# Process.__dict__.__contains__('start') == False  (on BaseProcess)
# Process.__dict__.__contains__('run') == False
# Process.__dict__.__contains__('join') == False
# Process.__dict__.__contains__('terminate') == False
# ---------------------------------------------------------------------------

table multiprocessing_extra81.Process_dict_baseprocess_methods_absent:
  description: "multiprocessing Process __dict__ membership checks — BaseProcess lifecycle methods absent in cfextra81 namespace — wave 245 theme: multiprocessing Process __dict__ membership; Process.__dict__.__contains__('start')==False (start is on BaseProcess); Process.__dict__.__contains__('run')==False; Process.__dict__.__contains__('join')==False; Process.__dict__.__contains__('terminate')==False; on macOS multiprocessing.Process is a thin context-specific subclass; all lifecycle methods live on BaseProcess; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra81

  columns: [id, function, args, expected, description]
  rows:
    - [proc_no_start,     "Process.__dict__.__contains__", ["start"],     false, "Process.__dict__.__contains__('start') == False — start is on BaseProcess not Process; verified with Python 3.14.3"]
    - [proc_no_run,       "Process.__dict__.__contains__", ["run"],       false, "Process.__dict__.__contains__('run') == False — run is on BaseProcess not Process; verified with Python 3.14.3"]
    - [proc_no_join,      "Process.__dict__.__contains__", ["join"],      false, "Process.__dict__.__contains__('join') == False — join is on BaseProcess not Process; verified with Python 3.14.3"]
    - [proc_no_terminate, "Process.__dict__.__contains__", ["terminate"], false, "Process.__dict__.__contains__('terminate') == False — terminate is on BaseProcess not Process; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process __dict__ membership (more BaseProcess methods) — extra81
#
# Process.__dict__.__contains__('kill') == False
# Process.__dict__.__contains__('is_alive') == False
# Process.__dict__.__contains__('__init__') == False
# Process.__dict__.__class__.__name__ == 'mappingproxy'
# ---------------------------------------------------------------------------

table multiprocessing_extra81.Process_dict_more_absences_and_proxy:
  description: "multiprocessing Process __dict__ membership checks — more absent BaseProcess methods and mappingproxy type in mpextra81 namespace — wave 245 theme: multiprocessing Process __dict__ membership; Process.__dict__.__contains__('kill')==False; Process.__dict__.__contains__('is_alive')==False; Process.__dict__.__contains__('__init__')==False (__init__ is on BaseProcess); Process.__dict__.__class__.__name__=='mappingproxy' (all class __dict__ are mappingproxy objects); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra81a

  columns: [id, function, args, expected, description]
  rows:
    - [proc_no_kill,       "Process.__dict__.__contains__",     ["kill"],      false,        "Process.__dict__.__contains__('kill') == False — kill is on BaseProcess not Process; verified with Python 3.14.3"]
    - [proc_no_is_alive,   "Process.__dict__.__contains__",     ["is_alive"],  false,        "Process.__dict__.__contains__('is_alive') == False — is_alive is on BaseProcess not Process; verified with Python 3.14.3"]
    - [proc_no_init,       "Process.__dict__.__contains__",     ["__init__"],  false,        "Process.__dict__.__contains__('__init__') == False — __init__ is on BaseProcess not Process; verified with Python 3.14.3"]
    - [proc_dict_class,    Process.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Process.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process identity attributes — extra81
#
# Process.__qualname__ == 'Process'
# Process.__name__ == 'Process'
# Process.__module__ == 'multiprocessing.context'
# ---------------------------------------------------------------------------

table multiprocessing_extra81.Process_identity_attributes:
  description: "multiprocessing Process __qualname__, __name__, and __module__ checks in mpextra81 namespace — wave 245 theme: multiprocessing Process identity attributes; Process.__qualname__=='Process'; Process.__name__=='Process'; Process.__module__=='multiprocessing.context' (Process is defined in multiprocessing.context submodule on macOS); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra81b

  columns: [id, function, args, expected, description]
  rows:
    - [proc_qualname,  Process.__qualname__.__eq__, ["Process"],                   true, "Process.__qualname__ == 'Process' — simple class qualname; verified with Python 3.14.3"]
    - [proc_name,      Process.__name__.__eq__,     ["Process"],                   true, "Process.__name__ == 'Process' — simple class name; verified with Python 3.14.3"]
    - [proc_module,    Process.__module__.__eq__,   ["multiprocessing.context"],   true, "Process.__module__ == 'multiprocessing.context' — defined in multiprocessing.context submodule; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process __bases__ and cross-checks — extra81
#
# Process.__bases__[0].__name__ == 'BaseProcess'
# ---------------------------------------------------------------------------

table multiprocessing_extra81.Process_bases_and_cross_checks:
  description: "multiprocessing Process __bases__ and cross-check table in mpextra81 namespace — wave 245 theme: multiprocessing Process hierarchy; Process.__bases__[0].__name__=='BaseProcess' (Process directly subclasses BaseProcess); Process.__qualname__=='Process' (cross-check); Process.__module__=='multiprocessing.context' (cross-check); Process.__dict__.__contains__('start')==False (cross-check: start absent from Process.__dict__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra81c

  columns: [id, function, args, expected, description]
  rows:
    - [proc_base_name,        "Process.__bases__[0].__name__.__eq__",  ["BaseProcess"],             true,  "Process.__bases__[0].__name__ == 'BaseProcess' — Process directly subclasses BaseProcess; verified with Python 3.14.3"]
    - [proc_qualname_cross,   Process.__qualname__.__eq__,             ["Process"],                 true,  "Process.__qualname__ == 'Process' — cross-check; verified with Python 3.14.3"]
    - [proc_module_cross,     Process.__module__.__eq__,               ["multiprocessing.context"], true,  "Process.__module__ == 'multiprocessing.context' — cross-check; verified with Python 3.14.3"]
    - [proc_no_start_cross,   "Process.__dict__.__contains__",         ["start"],                   false, "Process.__dict__.__contains__('start') == False — cross-check: start on BaseProcess not Process; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra81
# ---------------------------------------------------------------------------

invariant multiprocessing_extra81.Process_base_name:
  description: "multiprocessing.Process.__bases__[0].__name__.__eq__('BaseProcess') returns True — Process directly subclasses BaseProcess which holds all the main lifecycle methods; NEW in extra81: first standalone __bases__[0].__name__ invariant for Process in mpextra81 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__bases__[0].__name__.__eq__
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra81.Process_qualname:
  description: "multiprocessing.Process.__qualname__.__eq__('Process') returns True — Process is a top-level class with a simple unqualified name; NEW in extra81: first standalone __qualname__ invariant for Process in mpextra81 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__qualname__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra81.Process_module:
  description: "multiprocessing.Process.__module__.__eq__('multiprocessing.context') returns True — Process is defined in the multiprocessing.context submodule on macOS, not in multiprocessing directly; NEW in extra81: first standalone __module__ invariant for Process in mpextra81 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra81.Process_no_start:
  description: "multiprocessing.Process.__dict__.__contains__('start') returns False — start is defined on BaseProcess not on the context-specific Process subclass; this demonstrates that Process is a thin proxy that inherits all lifecycle methods from BaseProcess; NEW in extra81: first standalone __dict__.__contains__ False invariant for Process.start in mpextra81 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__dict__.__contains__
  args: ["start"]
  expected: false

invariant multiprocessing_extra81.Process_dict_class_name:
  description: "multiprocessing.Process.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — the __dict__ attribute of any Python class is a mappingproxy, a read-only view of the class namespace; NEW in extra81: first standalone __dict__.__class__.__name__ invariant for Process in mpextra81 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
