spec: theseus_queue_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_queue_cr2)
blocks: queue

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html"
  notes:
    - "Clean-room extended queue utilities. Do NOT import queue."
    - "PriorityQueue(): min-heap queue where items are (priority, value) tuples."
    - "SimpleQueue(): simple FIFO queue with put/get, no blocking timeout."
    - "queue2_priority(): put (2,'b') and (1,'a'); get() returns (1,'a') — first item."
    - "queue2_simple_get(): SimpleQueue put then get returns same item — returns True."
    - "queue2_empty(): new Queue().empty() == True."
    - "Zero-arg invariant signatures — def queue2_priority(): return hardcoded_result"
    - "PriorityQueue.put(item), get() -> item, empty() -> bool."
    - "SimpleQueue.put(item), get() -> item."
    - "Export: Queue, PriorityQueue, SimpleQueue, Empty (exception)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_queue_cr2.priority:
  description: "PriorityQueue returns items in priority order"
  category: PriorityQueue
  kind: python_call_eq
  function: queue2_priority
  args: []
  expected: [1, "a"]

invariant theseus_queue_cr2.simple_get:
  description: "SimpleQueue put then get returns same item"
  category: SimpleQueue
  kind: python_call_eq
  function: queue2_simple_get
  args: []
  expected: true

invariant theseus_queue_cr2.empty:
  description: "new Queue().empty() == True"
  category: empty
  kind: python_call_eq
  function: queue2_empty
  args: []
  expected: true
