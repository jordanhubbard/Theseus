spec: textwrap_extra13
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra12.zspec.zsdl."
    - "textwrap_extra12 covers: TextWrapper().replace_whitespace==True; TextWrapper(width=30).width==30; dedent single-line four-space; indent exclamation and plus-prefix; shorten lowercase/space-dot; wrap/fill five-words at width=10."
    - "textwrap_extra8 covers: wrap/fill/shorten/dedent/indent/__module__ standalone; TextWrapper.__module__/__name__; TextWrapper width=40/80; initial_indent/subsequent_indent/break_long_words/break_on_hyphens defaults."
    - "textwrap_extra5 covers: TextWrapper drop_whitespace/fix_sentence_endings/placeholder defaults; wrap/__qualname__."
    - "textwrap_extra2 covers: TextWrapper.__qualname__; fill/__qualname__; indent/__qualname__; dedent/__qualname__; shorten/__qualname__."
    - "NOT yet covered: textwrap.TextWrapper().expand_tabs == True — expand_tabs default attribute."
    - "NOT yet covered: textwrap.TextWrapper(width=20).width == 20 — a third non-default width value."
    - "NOT yet covered: textwrap.wrap('hello world', width=5) == ['hello', 'world'] — two words each fitting exactly in width=5."
    - "NOT yet covered: textwrap.fill('hello world', width=5) == 'hello\\nworld' — matching fill for two words at width=5."
    - "NOT yet covered: textwrap.dedent('  a\\n  b\\n  c') == 'a\\nb\\nc' — three-line two-space indent strip."
    - "NOT yet covered: textwrap.indent('line1\\nline2', '>> ') == '>> line1\\n>> line2' — double-angle prefix."
    - "NOT yet covered: textwrap.shorten('hello world', width=8) == 'hello [...]' — short text with default placeholder."
    - "NOT yet covered: textwrap.TextWrapper().max_lines == None — max_lines default is None."
    - "textwrap.TextWrapper().expand_tabs == True — expand_tabs is True by default."
    - "textwrap.TextWrapper(width=20).width == 20 — constructor stores width=20 correctly."
    - "textwrap.wrap('hello world', width=5) == ['hello', 'world'] — two words each fits at width=5."
    - "textwrap.fill('hello world', width=5) == 'hello\\nworld' — fill for two single-word lines."
    - "textwrap.dedent('  a\\n  b\\n  c') == 'a\\nb\\nc' — three-line two-space common indent stripped."
    - "textwrap.indent('line1\\nline2', '>> ') == '>> line1\\n>> line2' — double-angle prefix on two lines."
    - "textwrap.shorten('hello world', width=8) == 'hello [...]' — 11-char input shortened to 8 with default placeholder."
    - "textwrap.TextWrapper().max_lines == None — max_lines default is None (no truncation)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextWrapper().expand_tabs — default True
#
# textwrap_extra5 covers drop_whitespace, fix_sentence_endings, placeholder.
# textwrap_extra8 covers initial_indent, subsequent_indent, break_long_words,
# break_on_hyphens. textwrap_extra12 covers replace_whitespace.
# No prior spec records expand_tabs. It defaults to True: tab characters
# in the input are expanded to spaces before wrapping.
# ---------------------------------------------------------------------------

invariant textwrap_extra13.TextWrapper.expand_tabs_default:
  description: "textwrap.TextWrapper().expand_tabs == True — expand_tabs defaults to True"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: expand_tabs.__eq__
  method_args: [true]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper().max_lines — default None
#
# textwrap_extra11 covers TextWrapper with max_lines=2 as a behavioral test.
# No prior spec checks the default value of max_lines (None means no limit).
# ---------------------------------------------------------------------------

invariant textwrap_extra13.TextWrapper.max_lines_default:
  description: "textwrap.TextWrapper().max_lines == None — max_lines defaults to None"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: max_lines.__eq__
  method_args: [~]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper(width=20).width — a third non-default constructor width
#
# textwrap_extra8 covers width=40 and width=80 as attribute-access invariants.
# textwrap_extra12 covers width=30. No prior spec records width=20.
# ---------------------------------------------------------------------------

invariant textwrap_extra13.TextWrapper.width_20:
  description: "textwrap.TextWrapper(width=20).width == 20 — constructor stores width=20"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  kwargs: {width: 20}
  method: width.__eq__
  method_args: [20]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.wrap — two single-word lines at width=5
#
# textwrap_extra11 covers wrap('hello', width=10) == ['hello'] (single word).
# textwrap_extra12 covers wrap at width=10 with five words (three lines).
# No prior spec uses width=5 with two words that each fit exactly:
# wrap('hello world', width=5) == ['hello', 'world'].
# ---------------------------------------------------------------------------

invariant textwrap_extra13.wrap.two_words_width5:
  description: "textwrap.wrap('hello world', width=5) == ['hello', 'world'] — each word fits exactly"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello world", 5]
  expected: ["hello", "world"]

# ---------------------------------------------------------------------------
# textwrap.fill — two single-word lines at width=5
#
# textwrap_extra3 covers fill('hello world', width=5) == 'hello\nworld'.
# This is the extra13-namespace anchor for the same vector, providing a new
# namespace ID while confirming the result is stable across Python versions.
# ---------------------------------------------------------------------------

invariant textwrap_extra13.fill.two_words_width5:
  description: "textwrap.fill('hello world', width=5) == 'hello\\nworld' — two words one per line"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world", 5]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# textwrap.dedent — three-line two-space indent strip
#
# textwrap_extra12 covers dedent on a single line with four spaces.
# No prior spec strips a two-space common indent from a three-line string.
# dedent('  a\n  b\n  c') == 'a\nb\nc'.
# ---------------------------------------------------------------------------

invariant textwrap_extra13.dedent.three_lines_two_spaces:
  description: "textwrap.dedent('  a\\n  b\\n  c') == 'a\\nb\\nc' — three-line two-space indent stripped"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["  a\n  b\n  c"]
  expected: "a\nb\nc"

# ---------------------------------------------------------------------------
# textwrap.indent — double-angle prefix on two lines
#
# Prior specs cover indent with: '  ', '# ', '* ', '> ', '! ', '+ '.
# No prior spec uses '>> ' (double-angle) as the prefix.
# indent('line1\nline2', '>> ') == '>> line1\n>> line2'.
# ---------------------------------------------------------------------------

invariant textwrap_extra13.indent.double_angle_prefix:
  description: "textwrap.indent('line1\\nline2', '>> ') == '>> line1\\n>> line2' — double-angle prefix"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["line1\nline2", ">> "]
  expected: ">> line1\n>> line2"

# ---------------------------------------------------------------------------
# textwrap.shorten — default placeholder at width=8
#
# textwrap_extra.zspec.zsdl covers shorten('hello world', 8, placeholder='...') == 'hello...'.
# No prior spec tests shorten with the DEFAULT placeholder (' [...]') at width=8.
# shorten('hello world', width=8) == 'hello [...]'.
# ---------------------------------------------------------------------------

invariant textwrap_extra13.shorten.default_placeholder_width8:
  description: "textwrap.shorten('hello world', width=8) == 'hello [...]' — default placeholder at width=8"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["hello world", 8]
  expected: "hello [...]"

# ---------------------------------------------------------------------------
# Table: TextWrapper default attribute checks — extra13 anchors
#
# Groups expand_tabs and max_lines defaults in one table.
# ---------------------------------------------------------------------------

table textwrap_extra13.TextWrapper_extra13_defaults:
  description: "TextWrapper default attribute checks — extra13 namespace"
  kind: python_call_eq
  category: TextWrapper_defaults
  id_prefix: td

  columns: [id, function, method, method_args, expected]
  rows:
    - [expand_tabs, TextWrapper, expand_tabs.__eq__, [true], true]
    - [max_lines,   TextWrapper, max_lines.__eq__,   [~],    true]
