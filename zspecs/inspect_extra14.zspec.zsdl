spec: inspect_extra14
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra13.zspec.zsdl."
    - "inspect_extra13 covers isasyncgen/iscoroutine __module__/__qualname__; getattr_static/classify_class_attrs __module__/__qualname__; Parameter.POSITIONAL_ONLY.value==0, KEYWORD_ONLY.value==3."
    - "inspect_extra12 covers __bases__[0].__name__ for Parameter/Signature/FullArgSpec/BoundArguments."
    - "NOT yet covered: Parameter.POSITIONAL_OR_KEYWORD.value == 1 as a standalone invariant."
    - "NOT yet covered: Parameter.VAR_POSITIONAL.value == 2 as a standalone invariant."
    - "NOT yet covered: Parameter.VAR_KEYWORD.value == 4 as a standalone invariant."
    - "NOT yet covered: Parameter.empty.__class__.__name__ == 'type' as a standalone invariant."
    - "NOT yet covered: getmembers.__qualname__ == 'getmembers' as a standalone invariant."
    - "NOT yet covered: getmodule.__qualname__ == 'getmodule' as a standalone invariant."
    - "NOT yet covered: getfile.__qualname__ == 'getfile' as a standalone invariant."
    - "NOT yet covered: getsource.__qualname__ == 'getsource' as a standalone invariant."
    - "NOT yet covered: getsourcelines.__qualname__ == 'getsourcelines' as a standalone invariant."
    - "NOT yet covered: classify_class_attrs.__qualname__ == 'classify_class_attrs' as a standalone invariant."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD is enum kind with value 1."
    - "inspect.Parameter.VAR_POSITIONAL is enum kind with value 2."
    - "inspect.Parameter.VAR_KEYWORD is enum kind with value 4."
    - "inspect.Parameter.empty is a sentinel class used to indicate missing defaults."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Parameter kind enum .value checks — POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, VAR_KEYWORD
#
# inspect_extra13 covers POSITIONAL_ONLY.value==0 and KEYWORD_ONLY.value==3.
# No prior inspect spec verifies integer .value for the other three Parameter kinds.
# POSITIONAL_OR_KEYWORD.value==1, VAR_POSITIONAL.value==2, VAR_KEYWORD.value==4.
# ---------------------------------------------------------------------------

invariant inspect_extra14.Parameter.positional_or_keyword_value:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.value.__eq__
  args: [1]
  expected: true

invariant inspect_extra14.Parameter.var_positional_value:
  description: "inspect.Parameter.VAR_POSITIONAL.value == 2"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.value.__eq__
  args: [2]
  expected: true

invariant inspect_extra14.Parameter.var_keyword_value:
  description: "inspect.Parameter.VAR_KEYWORD.value == 4"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.value.__eq__
  args: [4]
  expected: true

# ---------------------------------------------------------------------------
# Parameter.empty sentinel class — class name check
#
# inspect.Parameter.empty is the sentinel for missing defaults and annotations.
# Its __class__.__name__ == 'type' since it is a class object.
# No prior inspect spec checks Parameter.empty.__class__.__name__.
# ---------------------------------------------------------------------------

invariant inspect_extra14.Parameter.empty_class_name:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — empty sentinel is a class"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ checks for utility functions not yet covered
#
# inspect_extra13 covers getattr_static and classify_class_attrs __qualname__.
# No prior inspect spec covers __qualname__ for getmembers, getmodule, getfile,
# getsource, or getsourcelines as standalone invariants.
# ---------------------------------------------------------------------------

table inspect_extra14.utility_func_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [getmembers,      getmembers.__qualname__.__eq__,      ["getmembers"],      true]
    - [getmodule,       getmodule.__qualname__.__eq__,       ["getmodule"],       true]
    - [getfile,         getfile.__qualname__.__eq__,         ["getfile"],         true]
    - [getsource,       getsource.__qualname__.__eq__,       ["getsource"],       true]
    - [getsourcelines,  getsourcelines.__qualname__.__eq__,  ["getsourcelines"],  true]

# ---------------------------------------------------------------------------
# Signature and BoundArguments __bases__.__len__ == 1
#
# inspect_extra12 covers __bases__[0].__name__ for these classes.
# No prior inspect spec checks __bases__.__len__ for Signature or BoundArguments.
# Both have exactly one direct base class (object).
# ---------------------------------------------------------------------------

invariant inspect_extra14.Signature.bases_len:
  description: "inspect.Signature.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Signature.__bases__.__len__
  args: []
  expected: 1

invariant inspect_extra14.BoundArguments.bases_len:
  description: "inspect.BoundArguments.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: BoundArguments.__bases__.__len__
  args: []
  expected: 1

invariant inspect_extra14.Parameter.bases_len:
  description: "inspect.Parameter.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Parameter.__bases__.__len__
  args: []
  expected: 1
