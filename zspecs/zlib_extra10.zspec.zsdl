spec: zlib_extra10
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib_extra9.zspec.zsdl — covers error.__bases__[0].__name__=='Exception' bool-form; error.__module__ standalone; compressobj/__module__ standalone; decompressobj/__module__ standalone; function __module__ table (fmod9); ZLIB_VERSION exact value."
    - "zlib_extra7.zspec.zsdl — covers compress/decompress/crc32/adler32/compressobj/decompressobj __name__ standalone; compress/decompress/crc32/adler32 __module__ table (fmod7); Z_DEFAULT_COMPRESSION type; ZLIB_VERSION type re-anchor."
    - "zlib_extra4.zspec.zsdl — covers MAX_WBITS, Z_NO_FLUSH/Z_SYNC_FLUSH/Z_FINISH, ZLIB_VERSION type, adler32/crc32 known values, error.__qualname__."
    - "zlib_extra3.zspec.zsdl — covers constant values and compress/decompress __module__."
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type names, DEF_MEM_LEVEL, level/strategy tables, error module/MRO."
    - "zlib_extra.zspec.zsdl — covers function names, error class, DEFLATED/Z_DEFAULT_COMPRESSION int type, checksum edge cases, roundtrip."
  notes:
    - "This spec extends zlib through zlib_extra9; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__ standalone invariants for compress, decompress, compressobj, decompressobj, crc32, adler32 (extra10 namespace); error.__qualname__ standalone (extra10 namespace anchor); zlib.__name__ standalone (extra10 anchor)."
    - "zlib_extra4 covers error.__qualname__ from extra4. This standalone re-anchors it from the extra10 namespace."
    - "No prior zlib spec covers compress/decompress/compressobj/decompressobj/crc32/adler32 __qualname__ in any form. For C builtin functions, __qualname__ equals __name__. Verified 2026-04-09."
    - "zlib.__name__ == 'zlib': no prior zlib spec checks the module-level __name__ as a standalone invariant. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ — compress, decompress, compressobj, decompressobj,
# crc32, adler32 (standalone, extra10 anchors)
#
# No prior zlib spec covers __qualname__ for any of these C builtin functions.
# For C-level builtins, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant zlib_extra10.compress.qualname:
  description: "zlib.compress.__qualname__ == 'compress' — C builtin function qualname (extra10 anchor)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

invariant zlib_extra10.decompress.qualname:
  description: "zlib.decompress.__qualname__ == 'decompress' — C builtin function qualname (extra10 anchor)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

invariant zlib_extra10.compressobj.qualname:
  description: "zlib.compressobj.__qualname__ == 'compressobj' — C builtin function qualname (extra10 anchor)"
  category: qualnames
  kind: python_call_eq
  function: compressobj.__qualname__.__eq__
  args: ["compressobj"]
  expected: true

invariant zlib_extra10.decompressobj.qualname:
  description: "zlib.decompressobj.__qualname__ == 'decompressobj' — C builtin function qualname (extra10 anchor)"
  category: qualnames
  kind: python_call_eq
  function: decompressobj.__qualname__.__eq__
  args: ["decompressobj"]
  expected: true

invariant zlib_extra10.crc32.qualname:
  description: "zlib.crc32.__qualname__ == 'crc32' — C builtin function qualname (extra10 anchor)"
  category: qualnames
  kind: python_call_eq
  function: crc32.__qualname__.__eq__
  args: ["crc32"]
  expected: true

invariant zlib_extra10.adler32.qualname:
  description: "zlib.adler32.__qualname__ == 'adler32' — C builtin function qualname (extra10 anchor)"
  category: qualnames
  kind: python_call_eq
  function: adler32.__qualname__.__eq__
  args: ["adler32"]
  expected: true

# ---------------------------------------------------------------------------
# error.__qualname__ == 'error' — standalone (extra10 anchor)
#
# zlib_extra4 covers error.__qualname__ from extra4. This standalone re-anchors
# the same property from the extra10 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra10.error.qualname:
  description: "zlib.error.__qualname__ == 'error' — module-level class qualname (extra10 anchor)"
  category: qualnames
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# zlib.__name__ == 'zlib' — module-level __name__ (extra10 anchor)
#
# No prior zlib spec checks the module object's own __name__ attribute as a
# standalone invariant. The zlib C extension module's __name__ is 'zlib'.
# ---------------------------------------------------------------------------

invariant zlib_extra10.module.name:
  description: "zlib.__name__ == 'zlib' — the module object's __name__ attribute (extra10 anchor)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — all six functions and error class together (extra10)
#
# No prior zlib spec presents function __qualname__ values together in a table.
# This table anchors all seven identifiers from the extra10 namespace.
# ---------------------------------------------------------------------------

table zlib_extra10.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn10

  columns: [id, function, args, expected]
  rows:
    - [compress,      compress.__qualname__.__eq__,      ["compress"],      true]
    - [decompress,    decompress.__qualname__.__eq__,    ["decompress"],    true]
    - [compressobj,   compressobj.__qualname__.__eq__,   ["compressobj"],   true]
    - [decompressobj, decompressobj.__qualname__.__eq__, ["decompressobj"], true]
    - [crc32,         crc32.__qualname__.__eq__,         ["crc32"],         true]
    - [adler32,       adler32.__qualname__.__eq__,       ["adler32"],       true]
    - [error,         error.__qualname__.__eq__,         ["error"],         true]
