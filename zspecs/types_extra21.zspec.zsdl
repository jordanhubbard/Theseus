spec: types_extra21
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends types_extra20.zspec.zsdl."
    - "Focus: __qualname__ standalone invariants for FunctionType/LambdaType/GeneratorType/CoroutineType/ModuleType/MethodType/SimpleNamespace/MappingProxyType in the extra21 namespace."
    - "types_extra17 covers __qualname__.__eq__ for FunctionType/LambdaType/CodeType/MappingProxyType/SimpleNamespace/GeneratorType/CoroutineType in a combined table."
    - "types_extra16 covers FunctionType/ModuleType/MethodType __qualname__.__eq__ as standalone invariants."
    - "types_extra20 covers __qualname__.__len__() for AsyncGeneratorType/BuiltinFunctionType/MappingProxyType/SimpleNamespace/FrameType/TracebackType/CoroutineType/GeneratorType/ModuleType/FunctionType in a combined table."
    - "types_extra15 covers __qualname__.__len__ for NoneType/SimpleNamespace/MappingProxyType/DynamicClassAttribute/GeneratorType/CoroutineType standalone; __qualname__.__eq__ for NoneType/GeneratorType/CoroutineType standalone."
    - "types_extra14 covers __qualname__.__len__ for FunctionType/LambdaType/MethodType/BuiltinFunctionType/ModuleType/TracebackType/FrameType/CodeType/CellType/AsyncGeneratorType in a combined table."
    - "types_extra5 covers __qualname__.__eq__ for FunctionType/MethodType/GeneratorType/CoroutineType/ModuleType in a table."
    - "types.FunctionType.__qualname__ == 'function' (same as LambdaType — both refer to the same C type)."
    - "types.LambdaType is types.FunctionType — they are the same object."
    - "Focus of this spec: standalone __qualname__.__eq__ invariants for FunctionType/LambdaType/GeneratorType/CoroutineType/ModuleType/MethodType/SimpleNamespace/MappingProxyType in the extra21 namespace (not previously collected as standalones in this namespace)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ combined table for core types module classes
# (types_extra21 namespace)
#
# types_extra17 covers this group in the extra17 namespace. No prior spec
# collects FunctionType/LambdaType/GeneratorType/CoroutineType/ModuleType/
# MethodType/SimpleNamespace/MappingProxyType __qualname__.__eq__ together
# in the extra21 namespace.
# ---------------------------------------------------------------------------

table types_extra21.qualnames:
  description: "__qualname__.__eq__ for core types module class types"
  kind: python_call_eq
  category: type_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,     FunctionType.__qualname__.__eq__,     ["function"],        true]
    - [LambdaType,       LambdaType.__qualname__.__eq__,       ["function"],        true]
    - [GeneratorType,    GeneratorType.__qualname__.__eq__,    ["generator"],       true]
    - [CoroutineType,    CoroutineType.__qualname__.__eq__,    ["coroutine"],       true]
    - [ModuleType,       ModuleType.__qualname__.__eq__,       ["module"],          true]
    - [MethodType,       MethodType.__qualname__.__eq__,       ["method"],          true]
    - [SimpleNamespace,  SimpleNamespace.__qualname__.__eq__,  ["SimpleNamespace"], true]
    - [MappingProxyType, MappingProxyType.__qualname__.__eq__, ["mappingproxy"],    true]

# ---------------------------------------------------------------------------
# types.FunctionType.__qualname__ == 'function' — standalone invariant
# (types_extra21 namespace)
#
# types_extra16 covers this as a standalone in the extra16 namespace.
# Providing a standalone in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant types_extra21.FunctionType.qualname:
  description: "types.FunctionType.__qualname__ == 'function' — C-level type name"
  category: type_qualnames
  kind: python_call_eq
  function: FunctionType.__qualname__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# types.LambdaType.__qualname__ == 'function' — standalone invariant
# (types_extra21 namespace)
#
# types_extra14 covers LambdaType.__qualname__.__eq__('function') standalone.
# Providing a standalone in the extra21 namespace.
# LambdaType is FunctionType — same object, same qualname.
# ---------------------------------------------------------------------------

invariant types_extra21.LambdaType.qualname:
  description: "types.LambdaType.__qualname__ == 'function' — LambdaType is FunctionType, same C type"
  category: type_qualnames
  kind: python_call_eq
  function: LambdaType.__qualname__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# types.SimpleNamespace.__qualname__ == 'SimpleNamespace' — standalone invariant
# (types_extra21 namespace)
#
# types_extra17 covers SimpleNamespace.__qualname__.__eq__ in a table.
# types_extra15 covers SimpleNamespace.__qualname__.__len__==15 standalone.
# Providing a standalone __qualname__.__eq__ invariant in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant types_extra21.SimpleNamespace.qualname:
  description: "types.SimpleNamespace.__qualname__ == 'SimpleNamespace'"
  category: type_qualnames
  kind: python_call_eq
  function: SimpleNamespace.__qualname__.__eq__
  args: ["SimpleNamespace"]
  expected: true

# ---------------------------------------------------------------------------
# types.MappingProxyType.__qualname__ == 'mappingproxy' — standalone invariant
# (types_extra21 namespace)
#
# types_extra17 covers MappingProxyType.__qualname__.__eq__ in a table.
# types_extra15 covers MappingProxyType.__qualname__.__len__==12 standalone.
# Providing a standalone __qualname__.__eq__ invariant in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant types_extra21.MappingProxyType.qualname:
  description: "types.MappingProxyType.__qualname__ == 'mappingproxy' — C-level type name"
  category: type_qualnames
  kind: python_call_eq
  function: MappingProxyType.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true
