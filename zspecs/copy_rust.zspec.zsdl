spec: copy_rust
version: ">=3.9"
backend: rust_module(copy_rust)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy documentation"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "Clean-room Rust reimplementation of Python copy module, exposed via PyO3."
    - "copy(x) creates a shallow copy; for immutables returns the same value."
    - "deepcopy(x) creates a deep (recursive) copy; for immutables returns the same value."
    - "copy(42) == 42, copy('hello') == 'hello' — scalars are identity copies."
    - "copy([1, 2, 3]) == [1, 2, 3] — list contents are equal."
    - "deepcopy([1, 2, 3]) == [1, 2, 3] — deep copy preserves values."
    - "deepcopy({'a': 1, 'b': 2}) == {'a': 1, 'b': 2} — dicts are recursively copied."
    - "All test vectors verified against Python 3.14.3 copy module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# copy — shallow copy of scalars (returns equal value)
table copy_rust.copy.scalars:
  kind: python_call_eq
  category: copy
  id_prefix: copy
  function: copy

  columns: [id, args, expected]
  rows:
    - [int_val,   [42],      42]
    - [neg_int,   [-7],      -7]
    - [zero,      [0],        0]
    - [string,    ["hello"], "hello"]
    - [empty_str, [""],      ""]
    - [true_val,  [true],    true]
    - [false_val, [false],   false]
    - [none_val,  [null],    null]

# copy — shallow copy of collections
table copy_rust.copy.collections:
  kind: python_call_eq
  category: copy
  id_prefix: copy
  function: copy

  columns: [id, args, expected]
  rows:
    - [int_list,   [[1, 2, 3]],      [1, 2, 3]]
    - [empty_list, [[]],             []]
    - [single,     [[99]],           [99]]

# deepcopy — deep copy of scalars
table copy_rust.deepcopy.scalars:
  kind: python_call_eq
  category: deepcopy
  id_prefix: deepcopy
  function: deepcopy

  columns: [id, args, expected]
  rows:
    - [int_val,  [42],      42]
    - [neg_int,  [-7],      -7]
    - [string,   ["hello"], "hello"]
    - [none_val, [null],    null]

# deepcopy — deep copy of collections
table copy_rust.deepcopy.collections:
  kind: python_call_eq
  category: deepcopy
  id_prefix: deepcopy
  function: deepcopy

  columns: [id, args, expected]
  rows:
    - [int_list,    [[1, 2, 3]],      [1, 2, 3]]
    - [empty_list,  [[]],             []]
    - [nested_list, [[1, [2, 3]]],    [1, [2, 3]]]

