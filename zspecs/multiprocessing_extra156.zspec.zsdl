  expected: true

invariant multiprocessing_extra156.init_cofilename_type_str:
  description: "multiprocessing.Process.__init__.__code__.co_filename.__class__.__name__.__eq__('str') returns True — co_filename is the source file path string; Process.__init__ is defined in Lib/multiprocessing/process.py; co_filename.__class__.__name__ is 'str' (len=3: s-t-r); multiprocessing is not a frozen module so co_filename is a real filesystem path (unlike abc whose co_filename is '<frozen abc>'); NEW in extra156; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
