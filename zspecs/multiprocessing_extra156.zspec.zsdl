invariant multiprocessing_extra156.init_coflags_type_int:
  description: "multiprocessing.Process.__init__.__code__.co_flags.__class__.__name__.__eq__('int') returns True — Process.__init__ is a regular method defined in Lib/multiprocessing/process.py; co_flags is always an integer bitmask; __init__.co_flags==134217731 (different from start/run co_flags of 201326595 because __init__ has a different compilation profile); co_flags.__class__.__name__ is 'int' (len=3: i-n-t); NEW in extra156: first standalone mp.Process.__init__ co_flags type invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant multiprocessing_extra156.init_costacksize_type_int:
  description: "multiprocessing.Process.__init__.__code__.co_stacksize.__class__.__name__.__eq__('int') returns True — Process.__init__.co_stacksize==5; co_stacksize is always an integer; the same stack depth as Process.run.co_stacksize (both 5); Process.start.co_stacksize==3 (smaller, start is a thin wrapper); __init__.co_flags==134217731; __init__ is defined in process.py alongside start and run; NEW in extra156; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__code__.co_stacksize.__class__.__name__.__eq__
