spec: multiprocessing_extra156
version: ">=3.9"
backend: python_module(multiprocessing.queues)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec covers: multiprocessing.queues module class identity — Queue, SimpleQueue, JoinableQueue, and the module __name__. multiprocessing.queues.Queue.__name__=='Queue' (len=5); multiprocessing.queues.Queue.__module__=='multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22); multiprocessing.queues.Queue.__bases__[0].__name__=='object' (Queue inherits from object directly); multiprocessing.queues.SimpleQueue.__name__=='SimpleQueue' (len=11); multiprocessing.queues.JoinableQueue.__name__=='JoinableQueue' (len=13); multiprocessing.queues.JoinableQueue.__bases__[0].__name__=='Queue' (JoinableQueue inherits from Queue — it adds join() and task_done() methods); multiprocessing.queues.__name__=='multiprocessing.queues' (len=22; module __name__ matches the dotted import path). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.queues.Queue.__module__=='multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22); len('multiprocessing.queues')==22; compare module name lengths: multiprocessing.pool (len=20) < multiprocessing.queues (len=22) < multiprocessing.context (len=23) < multiprocessing.managers (len=24) < multiprocessing.shared_memory (len=29); queues module (len=22) sits between pool (len=20) and context (len=23) in length ordering. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.queues.JoinableQueue.__bases__[0].__name__=='Queue' — JoinableQueue inherits from Queue and adds the ability to track task completion: put() increments a counter, task_done() decrements it, and join() blocks until the counter reaches zero; this is the multiprocessing analogue of queue.Queue (the threading-safe standard library queue which also has JoinableQueue-like join() and task_done()); Queue.__bases__[0].__name__=='object' (Queue itself inherits from object). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.queues.SimpleQueue.__name__=='SimpleQueue' (len=11: 'Simple'=6+'Queue'=5=11; a simplified process-safe queue without the full feature set of Queue; SimpleQueue only supports put() and get() with no size limit, no timeout, and no task_done/join tracking); SimpleQueue.__module__=='multiprocessing.queues' (same module as Queue and JoinableQueue). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.queues.Queue class identity — extra156
#
# multiprocessing.queues.Queue.__name__.__eq__('Queue')                       == True
# multiprocessing.queues.Queue.__module__.__eq__('multiprocessing.queues')    == True
# multiprocessing.queues.Queue.__bases__[0].__name__.__eq__('object')         == True
# ---------------------------------------------------------------------------

table multiprocessing_extra156.mp_queues_queue_identity:
  description: "multiprocessing.queues.Queue class identity checks in mpqueue156 namespace — multiprocessing.queues.Queue.__name__=='Queue' (len=5: 'Q'+'u'+'e'+'u'+'e'=5; the multiprocessing-safe inter-process queue built on top of a Pipe and OS semaphores; supports put(), get(), empty(), qsize(), close(), join_thread()); multiprocessing.queues.Queue.__module__=='multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22; defined in Lib/multiprocessing/queues.py); multiprocessing.queues.Queue.__bases__[0].__name__=='object' (Queue inherits directly from object; it is NOT a subclass of queue.Queue from the standard library); Queue.__name__.__len__()==5; compare: multiprocessing.queues.SimpleQueue.__name__.__len__()==11 (6 longer) and multiprocessing.queues.JoinableQueue.__name__.__len__()==13 (8 longer); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueue156

  columns: [id, function, args, expected, description]
  rows:
    - [q_name_eq,   multiprocessing.queues.Queue.__name__.__eq__,                ["Queue"],                  true,  "multiprocessing.queues.Queue.__name__ == 'Queue' (len=5); verified with Python 3.14.3"]
    - [q_mod_eq,    multiprocessing.queues.Queue.__module__.__eq__,               ["multiprocessing.queues"],  true,  "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues' (len=22); verified with Python 3.14.3"]
    - [q_base_eq,   "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__",  ["object"],                  true,  "multiprocessing.queues.Queue.__bases__[0].__name__ == 'object' (inherits from object directly); verified with Python 3.14.3"]
    - [q_name_len,  multiprocessing.queues.Queue.__name__.__len__,                [],                          5,     "multiprocessing.queues.Queue.__name__.__len__() == 5 ('Queue'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.queues.SimpleQueue class identity — extra156
#
# multiprocessing.queues.SimpleQueue.__name__.__eq__('SimpleQueue')  == True
# ---------------------------------------------------------------------------

table multiprocessing_extra156.mp_queues_simple_queue_identity:
  description: "multiprocessing.queues.SimpleQueue class identity checks in mpsqueue156 namespace — multiprocessing.queues.SimpleQueue.__name__=='SimpleQueue' (len=11: 'Simple'=6+'Queue'=5=11; the simplified inter-process queue that only supports put() and get() without size limits, qsize(), or task_done/join semantics; simpler and lower overhead than multiprocessing.queues.Queue); multiprocessing.queues.SimpleQueue.__module__=='multiprocessing.queues' (len=22; same module as Queue and JoinableQueue); SimpleQueue.__name__.__len__()==11 (6 chars longer than Queue=5 because 'Simple'=6 prefix added); compare: JoinableQueue.__name__.__len__()==13 (2 longer than SimpleQueue=11 because 'Joinable'=8 > 'Simple'=6); name length ordering: Queue(5) < SimpleQueue(11) < JoinableQueue(13); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsqueue156

  columns: [id, function, args, expected, description]
  rows:
    - [sq_name_eq,   multiprocessing.queues.SimpleQueue.__name__.__eq__,    ["SimpleQueue"],            true,  "multiprocessing.queues.SimpleQueue.__name__ == 'SimpleQueue' (len=11); verified with Python 3.14.3"]
    - [sq_mod_eq,    multiprocessing.queues.SimpleQueue.__module__.__eq__,   ["multiprocessing.queues"],  true,  "multiprocessing.queues.SimpleQueue.__module__ == 'multiprocessing.queues' (len=22; same module as Queue); verified with Python 3.14.3"]
    - [sq_name_len,  multiprocessing.queues.SimpleQueue.__name__.__len__,   [],                          11,    "multiprocessing.queues.SimpleQueue.__name__.__len__() == 11 ('SimpleQueue'); verified with Python 3.14.3"]
    - [q_mod_len,    multiprocessing.queues.Queue.__module__.__len__,        [],                          22,    "multiprocessing.queues.Queue.__module__.__len__() == 22 ('multiprocessing.queues'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.queues.JoinableQueue class identity and module __name__ — extra156
#
# multiprocessing.queues.JoinableQueue.__name__.__eq__('JoinableQueue')           == True
# multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__('Queue')      == True
# multiprocessing.queues.__name__.__eq__('multiprocessing.queues')                == True
# ---------------------------------------------------------------------------

table multiprocessing_extra156.mp_queues_joinable_and_module:
  description: "multiprocessing.queues.JoinableQueue class identity and module __name__ checks in mpjqueue156 namespace — multiprocessing.queues.JoinableQueue.__name__=='JoinableQueue' (len=13: 'Joinable'=8+'Queue'=5=13; JoinableQueue extends Queue with task tracking: put() increments the unfinished task count, task_done() decrements it, and join() blocks until the count reaches zero — the multiprocessing analogue of queue.Queue.join()); multiprocessing.queues.JoinableQueue.__bases__[0].__name__=='Queue' (JoinableQueue inherits from Queue — NOT from object directly; Queue.__bases__[0].__name__=='object'); multiprocessing.queues.__name__=='multiprocessing.queues' (len=22; the module's __name__ equals the fully-qualified import path — standard Python behavior for submodules); JoinableQueue.__name__.__len__()==13; name length: Queue(5) < SimpleQueue(11) < JoinableQueue(13); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpjqueue156

  columns: [id, function, args, expected, description]
  rows:
    - [jq_name_eq,    multiprocessing.queues.JoinableQueue.__name__.__eq__,               ["JoinableQueue"],           true,  "multiprocessing.queues.JoinableQueue.__name__ == 'JoinableQueue' (len=13); verified with Python 3.14.3"]
    - [jq_base_eq,    "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__", ["Queue"],                   true,  "multiprocessing.queues.JoinableQueue.__bases__[0].__name__ == 'Queue' (inherits from Queue, not object); verified with Python 3.14.3"]
    - [mod_name_eq,   multiprocessing.queues.__name__.__eq__,                              ["multiprocessing.queues"],  true,  "multiprocessing.queues.__name__ == 'multiprocessing.queues' (len=22; module __name__ == import path); verified with Python 3.14.3"]
    - [jq_name_len,   multiprocessing.queues.JoinableQueue.__name__.__len__,               [],                          13,    "multiprocessing.queues.JoinableQueue.__name__.__len__() == 13 ('JoinableQueue'; longest queue name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra156
# ---------------------------------------------------------------------------

invariant multiprocessing_extra156.mp_Queue_name_eq:
  description: "multiprocessing.queues.Queue.__name__.__eq__('Queue') returns True — multiprocessing.queues.Queue is the inter-process queue class built on Pipe and OS semaphores; Queue.__name__=='Queue' (len=5: 'Q'+'u'+'e'+'u'+'e'=5); Queue supports put(obj, block=True, timeout=None), get(block=True, timeout=None), empty(), qsize(), close(), cancel_join_thread(), and join_thread(); Queue.__module__=='multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22; defined in Lib/multiprocessing/queues.py); Queue.__bases__[0].__name__=='object' (Queue inherits from object directly — it is NOT a subclass of queue.Queue from the threading standard library); name length: Queue(5) < SimpleQueue(11) < JoinableQueue(13); NEW in extra156: first standalone multiprocessing.queues.Queue.__name__ identity invariant in mpqueue156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra156.mp_Queue_module_eq:
  description: "multiprocessing.queues.Queue.__module__.__eq__('multiprocessing.queues') returns True — multiprocessing.queues.Queue is defined in Lib/multiprocessing/queues.py; its __module__ is 'multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22); compare module name lengths across multiprocessing submodules: pool (len=20) < queues (len=22) < context (len=23) < managers (len=24) < shared_memory (len=29); the queues module (len=22) sits between pool and context; module __name__=='multiprocessing.queues' (len=22) matches Queue.__module__=='multiprocessing.queues'; NEW in extra156: first standalone multiprocessing.queues.Queue.__module__ identity invariant in mpqueue156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__module__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra156.mp_JoinableQueue_base_is_Queue:
  description: "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__('Queue') returns True — JoinableQueue inherits from Queue (NOT from object or SimpleQueue directly); __bases__[0].__name__=='Queue' (len=5); JoinableQueue adds task-done tracking on top of Queue: put() increments an internal unfinished-tasks counter; task_done() signals that a formerly enqueued task is complete by decrementing the counter; join() blocks until the counter reaches zero (all tasks finished); this mirrors the threading-safe queue.Queue.task_done()/join() API but for inter-process use; by inheriting from Queue, JoinableQueue inherits all Queue methods (get, put, empty, qsize, close, etc.) and adds task_done() and join(); contrast: SimpleQueue does NOT inherit from Queue (it is an independent simpler class); NEW in extra156: first standalone JoinableQueue.__bases__[0].__name__ identity invariant in mpjqueue156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra156.mp_queues_module_name_eq:
  description: "multiprocessing.queues.__name__.__eq__('multiprocessing.queues') returns True — the module's __name__ attribute equals its fully-qualified import path 'multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22); this is standard Python behavior for submodules (module.__name__ == the dotted import path); all three queue classes (Queue, SimpleQueue, JoinableQueue) have __module__=='multiprocessing.queues' matching this value; compare: multiprocessing.shared_memory.__name__=='multiprocessing.shared_memory' (len=29; 7 chars longer because 'shared_memory'=13 > 'queues'=6); multiprocessing.pool.__name__=='multiprocessing.pool' (len=20; 2 chars shorter because 'pool'=4 < 'queues'=6); queues (len=22) sits between pool (len=20) and context (len=23); NEW in extra156: first standalone multiprocessing.queues.__name__ identity invariant in mpjqueue156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.__name__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra156.mp_Queue_base_is_object:
  description: "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__('object') returns True — multiprocessing.queues.Queue inherits directly from object; __bases__[0].__name__=='object' (len=6); this is in contrast to multiprocessing.queues.JoinableQueue which inherits from Queue (not object); Queue is the root of the multiprocessing queue class hierarchy in the queues submodule; SimpleQueue is also independent (not a subclass of Queue); Queue.__bases__[0].__name__=='object' follows the same pattern as multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__=='object' and multiprocessing.context.BaseContext.__bases__[0].__name__=='object' — all root multiprocessing classes inherit from object; NEW in extra156: first standalone Queue.__bases__[0].__name__ identity invariant in mpqueue156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
