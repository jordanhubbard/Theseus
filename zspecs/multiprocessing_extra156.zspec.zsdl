spec: multiprocessing_extra156
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.Process.__init__.__code__.co_flags == 134217731 — Process.__init__ is a regular method; co_flags.__class__.__name__ == 'int'; value includes CO_OPTIMIZED (0x1), CO_NEWLOCALS (0x2), and high-order interpreter flags."
    - "multiprocessing.Process.__init__.__code__.co_stacksize == 5 — __init__ requires a stack depth of 5 slots; co_stacksize.__class__.__name__ == 'int'."
    - "multiprocessing.Process.__init__.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the path to Lib/multiprocessing/process.py."
    - "multiprocessing.Process.start.__code__.co_flags == 201326595 — start is a regular method with different interpreter optimization flags than __init__."
    - "multiprocessing.Process.run.__code__.co_flags == 201326595 — run has the same co_flags value as start; both are simple regular methods in process.py."
    - "multiprocessing.Process.start co_stacksize == 3; run co_stacksize == 5 — run has a larger stack depth than start."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

