spec: decimal_extra2326
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 602 (_extra2326): numeric constants and fixed-size attribute checks."
    - "decimal.MAX_PREC == decimal.MAX_EMAX == 999999999999999999 on 64-bit platforms."
    - "decimal.MIN_EMIN == -999999999999999999 on 64-bit platforms."
    - "decimal.MIN_ETINY == MIN_EMIN - MAX_PREC + 1 == -1999999999999999997 on 64-bit platforms."
    - "ROUND_* constants are plain str objects naming the rounding mode."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Precision and exponent limit integer constants
# ---------------------------------------------------------------------------

table decimal_extra2326.precision_constants:
  description: "decimal module precision and exponent limit integer constants"
  kind: python_call_eq
  category: constants
  id_prefix: dc2326

  columns: [id, function, args, expected]
  rows:
    - ["dc2326001", "decimal.MAX_PREC",  [], 999999999999999999]
    - ["dc2326002", "decimal.MAX_EMAX",  [], 999999999999999999]
    - ["dc2326003", "decimal.MIN_EMIN",  [], -999999999999999999]
    - ["dc2326004", "decimal.MIN_ETINY", [], -1999999999999999997]

# ---------------------------------------------------------------------------
# Table 2: Precision constant type checks — all are plain int
# ---------------------------------------------------------------------------

table decimal_extra2326.precision_constant_types:
  description: "decimal precision constants have __class__.__name__ == 'int'"
  kind: python_call_eq
  category: constants
  id_prefix: dc2326

  columns: [id, function, args, expected]
  rows:
    - ["dc2326005", "decimal.MAX_PREC.__class__.__name__",  [], "int"]
    - ["dc2326006", "decimal.MAX_EMAX.__class__.__name__",  [], "int"]
    - ["dc2326007", "decimal.MIN_EMIN.__class__.__name__",  [], "int"]
    - ["dc2326008", "decimal.MIN_ETINY.__class__.__name__", [], "int"]

# ---------------------------------------------------------------------------
# Table 3: Rounding mode string constants — value identity
# ---------------------------------------------------------------------------

table decimal_extra2326.rounding_mode_values:
  description: "decimal.ROUND_* string constants equal their own name"
  kind: python_call_eq
  category: constants
  id_prefix: dc2326

  columns: [id, function, args, expected]
  rows:
    - ["dc2326009", "decimal.ROUND_UP",        [], "ROUND_UP"]
    - ["dc2326010", "decimal.ROUND_DOWN",      [], "ROUND_DOWN"]
    - ["dc2326011", "decimal.ROUND_CEILING",   [], "ROUND_CEILING"]
    - ["dc2326012", "decimal.ROUND_FLOOR",     [], "ROUND_FLOOR"]
    - ["dc2326013", "decimal.ROUND_HALF_UP",   [], "ROUND_HALF_UP"]
    - ["dc2326014", "decimal.ROUND_HALF_DOWN", [], "ROUND_HALF_DOWN"]
    - ["dc2326015", "decimal.ROUND_HALF_EVEN", [], "ROUND_HALF_EVEN"]
    - ["dc2326016", "decimal.ROUND_05UP",      [], "ROUND_05UP"]

# ---------------------------------------------------------------------------
# Table 4: Rounding mode type checks — all are plain str
# ---------------------------------------------------------------------------

table decimal_extra2326.rounding_mode_types:
  description: "decimal.ROUND_* constants have __class__.__name__ == 'str'"
  kind: python_call_eq
  category: constants
  id_prefix: dc2326

  columns: [id, function, args, expected]
  rows:
    - ["dc2326017", "decimal.ROUND_UP.__class__.__name__",        [], "str"]
    - ["dc2326018", "decimal.ROUND_DOWN.__class__.__name__",      [], "str"]
    - ["dc2326019", "decimal.ROUND_HALF_EVEN.__class__.__name__", [], "str"]
    - ["dc2326020", "decimal.ROUND_05UP.__class__.__name__",      [], "str"]

# ---------------------------------------------------------------------------
# Table 5: Precision constant ordering — positivity and sign checks
# ---------------------------------------------------------------------------

table decimal_extra2326.precision_ordering:
  description: "decimal precision constant ordering and sign checks"
  kind: python_call_eq
  category: constants
  id_prefix: dc2326

  columns: [id, function, args, expected]
  rows:
    - ["dc2326021", "decimal.MAX_PREC.__gt__",      [0],                    true]
    - ["dc2326022", "decimal.MAX_EMAX.__gt__",      [0],                    true]
    - ["dc2326023", "decimal.MIN_EMIN.__lt__",      [0],                    true]
    - ["dc2326024", "decimal.MIN_ETINY.__lt__",     [0],                    true]
    - ["dc2326025", "decimal.MAX_PREC.__eq__",      [999999999999999999],    true]
    - ["dc2326026", "decimal.MIN_EMIN.__eq__",      [-999999999999999999],   true]
