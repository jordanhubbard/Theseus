spec: functools_extra188
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.wraps and functools.update_wrapper identity — functools.wraps.__name__=='wraps' (len=5); functools.wraps.__module__=='functools'; functools.wraps.__qualname__=='wraps'; functools.wraps.__class__.__name__=='function'; functools.update_wrapper.__name__=='update_wrapper' (len=14); functools.update_wrapper.__module__=='functools'; functools.update_wrapper.__qualname__=='update_wrapper'; functools.update_wrapper.__class__.__name__=='function'."
    - "functools.wraps.__name__ == 'wraps' — wraps is a convenience decorator in Lib/functools.py that applies update_wrapper to the decorated function; its __name__ is 'wraps', 5 characters. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' — wraps is defined in the pure-Python functools module (Lib/functools.py); its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' — wraps is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'wraps' (5 chars). Verified with Python 3.14.3."
    - "functools.wraps.__class__.__name__ == 'function' — wraps is implemented as a regular Python function in Lib/functools.py, so type(wraps).__name__ is 'function'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__name__ == 'update_wrapper' — update_wrapper is the lower-level function in Lib/functools.py that copies __name__, __module__, __qualname__, __doc__, __dict__, and __wrapped__ from the wrapped function to the wrapper; its __name__ is 'update_wrapper', 14 characters. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__ == 'functools' — update_wrapper is defined in the pure-Python functools module (Lib/functools.py); its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper' — update_wrapper is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'update_wrapper' (14 chars). Verified with Python 3.14.3."
    - "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is implemented as a regular Python function in Lib/functools.py, so type(update_wrapper).__name__ is 'function'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.wraps __name__, __module__, __qualname__
#
# functools.wraps.__name__ == 'wraps'
# functools.wraps.__name__.__len__() == 5
# functools.wraps.__module__ == 'functools'
# functools.wraps.__qualname__ == 'wraps'
#
# functools.wraps is a convenience decorator in Lib/functools.py that applies
# update_wrapper to the decorated function so it copies __name__, __module__,
# __qualname__, __doc__, __dict__, and __wrapped__. Its __name__ is 'wraps'
# (5 chars). New to extra188.
# ---------------------------------------------------------------------------

table functools_extra188.wraps_identity:
  description: "functools.wraps.__name__ 'wraps' len 5; __module__ 'functools'; __qualname__ 'wraps' equals __name__; new to extra188"
  kind: python_call_eq
  category: identity
  id_prefix: functwraps188

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_name_eq,
       wraps.__name__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__name__.__eq__('wraps') == True — wraps is a convenience decorator in Lib/functools.py that applies update_wrapper to the decorated function, copying __name__, __module__, __qualname__, __doc__, __dict__, and __wrapped__; its __name__ is 'wraps'; str.__eq__('wraps') returns True; new to extra188"]
    - [wraps_name_len_5,
       wraps.__name__.__len__,
       [],
       5,
       "functools.wraps.__name__.__len__() == 5 — the name 'wraps' has exactly 5 characters: w-r-a-p-s; str.__len__() returns 5; new to extra188"]
    - [wraps_module_eq,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined in the pure-Python functools module (Lib/functools.py), not the C extension _functools; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra188"]
    - [wraps_qualname_eq,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is a module-level Python function (not nested or a method), so its __qualname__ equals its __name__ 'wraps' (5 chars); str.__eq__('wraps') returns True; new to extra188"]

# ---------------------------------------------------------------------------
# Table 2: functools.wraps __class__ and functools.update_wrapper
#          __name__, __module__
#
# functools.wraps.__class__.__name__ == 'function'
# functools.update_wrapper.__name__ == 'update_wrapper'
# functools.update_wrapper.__name__.__len__() == 14
# functools.update_wrapper.__module__ == 'functools'
#
# wraps is a regular Python function so its __class__ is 'function'.
# update_wrapper is the lower-level helper with __name__ 'update_wrapper'
# (14 chars) and __module__ 'functools'. New to extra188.
# ---------------------------------------------------------------------------

table functools_extra188.wraps_class_and_update_wrapper_name:
  description: "functools.wraps.__class__.__name__=='function'; functools.update_wrapper.__name__=='update_wrapper' len 14; __module__=='functools'; new to extra188"
  kind: python_call_eq
  category: identity
  id_prefix: functwraps188

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_class_eq,
       wraps.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is implemented as a regular Python function in Lib/functools.py (not a class or callable object), so type(wraps).__name__ is 'function'; str.__eq__('function') returns True; new to extra188"]
    - [uwrapper_name_eq,
       update_wrapper.__name__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__name__.__eq__('update_wrapper') == True — update_wrapper is the lower-level function in Lib/functools.py that copies __name__, __module__, __qualname__, __doc__, __dict__, and __wrapped__ from wrapped to wrapper; its __name__ is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra188"]
    - [uwrapper_name_len_14,
       update_wrapper.__name__.__len__,
       [],
       14,
       "functools.update_wrapper.__name__.__len__() == 14 — the name 'update_wrapper' has exactly 14 characters: u-p-d-a-t-e-_-w-r-a-p-p-e-r; str.__len__() returns 14; new to extra188"]
    - [uwrapper_module_eq,
       update_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is defined in the pure-Python functools module (Lib/functools.py); its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra188"]

# ---------------------------------------------------------------------------
# Table 3: functools.update_wrapper __qualname__ and __class__
#
# functools.update_wrapper.__qualname__ == 'update_wrapper'
# functools.update_wrapper.__class__.__name__ == 'function'
#
# update_wrapper is a module-level Python function so __qualname__ == __name__.
# It is a regular function (not a class), so its __class__.__name__ == 'function'.
# New to extra188.
# ---------------------------------------------------------------------------

table functools_extra188.update_wrapper_qualname_and_class:
  description: "functools.update_wrapper.__qualname__=='update_wrapper' equals __name__; __class__.__name__=='function'; new to extra188"
  kind: python_call_eq
  category: identity
  id_prefix: functwraps188

  columns: [id, function, args, expected, description]
  rows:
    - [uwrapper_qualname_eq,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — update_wrapper is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'update_wrapper' (14 chars); str.__eq__('update_wrapper') returns True; new to extra188"]
    - [uwrapper_qualname_len_14,
       update_wrapper.__qualname__.__len__,
       [],
       14,
       "functools.update_wrapper.__qualname__.__len__() == 14 — the qualname 'update_wrapper' has exactly 14 characters, equal to the __name__ length; str.__len__() returns 14; new to extra188"]
    - [uwrapper_class_eq,
       update_wrapper.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__.__eq__('function') == True — update_wrapper is implemented as a regular Python function in Lib/functools.py (not a class), so type(update_wrapper).__name__ is 'function'; str.__eq__('function') returns True; new to extra188"]
    - [wraps_qualname_len_check,
       wraps.__qualname__.__len__,
       [],
       5,
       "functools.wraps.__qualname__.__len__() == 5 — cross-check: 'wraps' qualname is 5 chars (same as __name__) while 'update_wrapper' qualname is 14 chars; confirmed by str.__len__(); new to extra188"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra188
# ---------------------------------------------------------------------------

invariant functools_extra188.wraps_name_is_wraps:
  description: "functools.wraps.__name__ == 'wraps' — convenience decorator in Lib/functools.py that applies update_wrapper; __name__ is 'wraps' (5 chars); new to extra188"
  category: identity
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra188.wraps_module_is_functools:
  description: "functools.wraps.__module__ == 'functools' — wraps is defined in the pure-Python functools module Lib/functools.py, not the C extension _functools; new to extra188"
  category: identity
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra188.wraps_qualname_equals_name:
  description: "functools.wraps.__qualname__ == 'wraps' — module-level Python function has __qualname__ == __name__ == 'wraps' (5 chars); new to extra188"
  category: identity
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra188.wraps_class_is_function:
  description: "functools.wraps.__class__.__name__ == 'function' — wraps is a regular Python function (not a class), so type(wraps).__name__ == 'function'; new to extra188"
  category: identity
  kind: python_call_eq
  function: wraps.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra188.update_wrapper_name_is_update_wrapper:
  description: "functools.update_wrapper.__name__ == 'update_wrapper' — lower-level helper in Lib/functools.py copying dunder attributes from wrapped to wrapper; __name__ is 'update_wrapper' (14 chars); new to extra188"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra188.update_wrapper_module_is_functools:
  description: "functools.update_wrapper.__module__ == 'functools' — update_wrapper is defined in the pure-Python functools module Lib/functools.py; its __module__ is 'functools'; new to extra188"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra188.update_wrapper_qualname_equals_name:
  description: "functools.update_wrapper.__qualname__ == 'update_wrapper' — module-level Python function has __qualname__ == __name__ == 'update_wrapper' (14 chars); new to extra188"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__qualname__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra188.update_wrapper_class_is_function:
  description: "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is a regular Python function (not a class), so type(update_wrapper).__name__ == 'function'; new to extra188"
  category: identity
  kind: python_call_eq
