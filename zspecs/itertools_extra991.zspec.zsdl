spec: itertools_extra991
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks itertools iterator class __reduce__ and related method qualnames, and chain.from_iterable qualname"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra991.chain_qualnames:
  description: "itertools.chain method __qualname__ identity"
  kind: python_call_eq
  category: chain_qualnames
  id_prefix: it991ch
  columns: [id, function, args, expected]
  rows:
    - [it991ch001, itertools.chain.__qualname__.__eq__,                             ["chain"],                            true]
    - [it991ch002, itertools.chain.from_iterable.__qualname__.__eq__,              ["chain.from_iterable"],              true]
    - [it991ch003, itertools.chain.__reduce__.__qualname__.__eq__,                  ["chain.__reduce__"],                 true]
    - [it991ch004, itertools.chain.__setstate__.__qualname__.__eq__,               ["chain.__setstate__"],               true]
    - [it991ch005, itertools.chain.__class__.__name__.__eq__,                      ["type"],                             true]
    - [it991ch006, itertools.chain.__module__.__eq__,                              ["itertools"],                        true]

table itertools_extra991.count_repeat_cycle_qualnames:
  description: "itertools.count, repeat, and cycle __reduce__ method __qualname__ identity"
  kind: python_call_eq
  category: count_repeat_cycle_qualnames
  id_prefix: it991cr
  columns: [id, function, args, expected]
  rows:
    - [it991cr001, itertools.count.__qualname__.__eq__,                            ["count"],                            true]
    - [it991cr002, itertools.count.__reduce__.__qualname__.__eq__,                 ["count.__reduce__"],                 true]
    - [it991cr003, itertools.repeat.__qualname__.__eq__,                           ["repeat"],                           true]
    - [it991cr004, itertools.repeat.__reduce__.__qualname__.__eq__,                ["repeat.__reduce__"],                true]
    - [it991cr005, itertools.cycle.__qualname__.__eq__,                            ["cycle"],                            true]
    - [it991cr006, itertools.cycle.__reduce__.__qualname__.__eq__,                 ["cycle.__reduce__"],                 true]

table itertools_extra991.accumulate_compress_qualnames:
  description: "itertools.accumulate and compress __reduce__ method __qualname__ identity"
  kind: python_call_eq
  category: accumulate_compress_qualnames
  id_prefix: it991ac
  columns: [id, function, args, expected]
  rows:
    - [it991ac001, itertools.accumulate.__qualname__.__eq__,                       ["accumulate"],                       true]
    - [it991ac002, itertools.accumulate.__reduce__.__qualname__.__eq__,            ["accumulate.__reduce__"],            true]
    - [it991ac003, itertools.compress.__qualname__.__eq__,                         ["compress"],                         true]
    - [it991ac004, itertools.compress.__reduce__.__qualname__.__eq__,              ["compress.__reduce__"],              true]
    - [it991ac005, itertools.__spec__.name.__eq__,                                 ["itertools"],                        true]
    - [it991ac006, itertools.__name__.__eq__,                                      ["itertools"],                        true]
    - [it991ac007, itertools.chain.__doc__.__class__.__name__.__eq__,              ["str"],                              true]
