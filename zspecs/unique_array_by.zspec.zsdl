table unique_array_by.unique:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: uaby

  columns: [id, args, expected]
  rows:
    - [by_id,   [[{"id": 1, "name": "a"}, {"id": 2, "name": "b"}, {"id": 1, "name": "c"}], "id"],     [{"id": 1, "name": "a"}, {"id": 2, "name": "b"}]]
    - [by_type, [[{"type": "cat"}, {"type": "dog"}, {"type": "cat"}], "type"],                         [{"type": "cat"}, {"type": "dog"}]]

