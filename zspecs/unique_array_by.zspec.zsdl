    - "Test vectors verified with unique-array-by via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "unique-array-by source"
  notes:
    - "unique-array-by is an npm package. Install: npm install unique-array-by"
    - "Returns unique objects from an array based on a specified property key."
    - "Keeps the first occurrence when duplicates are found."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
