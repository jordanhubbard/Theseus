spec: decimal_extra102
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra101.zspec.zsdl."
    - "This spec covers: decimal.Decimal comparison operator __qualname__ values and lengths, and decimal exception hierarchy class identity."
    - "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (length 14)."
    - "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__' (length 14)."
    - "decimal.Decimal.__gt__.__qualname__ == 'Decimal.__gt__' (length 14)."
    - "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__' (length 14)."
    - "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__' (length 14)."
    - "decimal.Decimal.__ne__.__qualname__ == 'Decimal.__ne__' (length 14)."
    - "All six comparison operator __qualname__ strings have length 14 (Decimal=7 + dot=1 + __XX__=6)."
    - "type(decimal.Decimal.__eq__).__name__ == 'wrapper_descriptor' (C extension slot wrapper)."
    - "decimal.DecimalException.__name__ == 'DecimalException'; __bases__[0].__name__ == 'ArithmeticError'; __mro__.__len__() == 5."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException'; __mro__.__len__() == 6."
    - "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException'; __mro__.__len__() == 7 (includes ZeroDivisionError in MRO)."
    - "decimal.Overflow.__bases__[0].__name__ == 'Inexact'; __mro__.__len__() == 8."
    - "len('DecimalException') == 16; len('InvalidOperation') == 16; len('DivisionByZero') == 14; len('Overflow') == 8."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal comparison operator __qualname__ string equality
# The six comparison dunder methods (__eq__, __lt__, __gt__, __le__, __ge__, __ne__)
# are wrapper_descriptor objects (C extension slot wrappers).
# Each method's __qualname__ is 'Decimal.<dunder_name>'.
# All six have length 14: 'Decimal.' (8) + 4-char dunder (4+2 underscores = 6).
# ---------------------------------------------------------------------------

table decimal_extra102.Decimal_cmp_operator_qualnames:
  description: "decimal.Decimal comparison operator __qualname__ values: __eq__='Decimal.__eq__', __lt__='Decimal.__lt__', __gt__='Decimal.__gt__', __le__='Decimal.__le__', __ge__='Decimal.__ge__', __ne__='Decimal.__ne__'"
  kind: python_call_eq
  category: qualnames
  id_prefix: deccmp102a

  columns: [id, function, args, expected, description]
  rows:
    - [dec_eq_qn,  "Decimal.__eq__.__qualname__.__eq__", ["Decimal.__eq__"], true,  "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__'"]
    - [dec_lt_qn,  "Decimal.__lt__.__qualname__.__eq__", ["Decimal.__lt__"], true,  "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__'"]
    - [dec_gt_qn,  "Decimal.__gt__.__qualname__.__eq__", ["Decimal.__gt__"], true,  "decimal.Decimal.__gt__.__qualname__ == 'Decimal.__gt__'"]
    - [dec_le_qn,  "Decimal.__le__.__qualname__.__eq__", ["Decimal.__le__"], true,  "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__'"]
    - [dec_ge_qn,  "Decimal.__ge__.__qualname__.__eq__", ["Decimal.__ge__"], true,  "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__'"]
    - [dec_ne_qn,  "Decimal.__ne__.__qualname__.__eq__", ["Decimal.__ne__"], true,  "decimal.Decimal.__ne__.__qualname__ == 'Decimal.__ne__'"]
    - [dec_eq_not_lt, "Decimal.__eq__.__qualname__.__eq__", ["Decimal.__lt__"], false, "decimal.Decimal.__eq__.__qualname__ != 'Decimal.__lt__' (__eq__ and __lt__ are distinct comparison operators)"]

# ---------------------------------------------------------------------------
# decimal.Decimal comparison operator __qualname__ lengths
# All six comparison operators (__eq__, __lt__, __gt__, __le__, __ge__, __ne__)
# have __qualname__ length 14: 'Decimal.__XX__' where XX is 2 chars.
# Compare: __truediv__ (from decimal_extra101) has length 19.
# ---------------------------------------------------------------------------

table decimal_extra102.Decimal_cmp_operator_qualname_lengths:
  description: "decimal.Decimal comparison operator __qualname__ lengths: __eq__/__lt__/__gt__/__le__/__ge__/__ne__ all have length 14"
  kind: python_call_eq
  category: qualnames
  id_prefix: deccmp102b

  columns: [id, function, args, expected, description]
  rows:
    - [dec_eq_qn_len,  "Decimal.__eq__.__qualname__.__len__", [], 14, "decimal.Decimal.__eq__.__qualname__.__len__() == 14 ('Decimal.__eq__' has 14 chars)"]
    - [dec_lt_qn_len,  "Decimal.__lt__.__qualname__.__len__", [], 14, "decimal.Decimal.__lt__.__qualname__.__len__() == 14 ('Decimal.__lt__' has 14 chars)"]
    - [dec_gt_qn_len,  "Decimal.__gt__.__qualname__.__len__", [], 14, "decimal.Decimal.__gt__.__qualname__.__len__() == 14 ('Decimal.__gt__' has 14 chars)"]
    - [dec_le_qn_len,  "Decimal.__le__.__qualname__.__len__", [], 14, "decimal.Decimal.__le__.__qualname__.__len__() == 14 ('Decimal.__le__' has 14 chars)"]
    - [dec_ge_qn_len,  "Decimal.__ge__.__qualname__.__len__", [], 14, "decimal.Decimal.__ge__.__qualname__.__len__() == 14 ('Decimal.__ge__' has 14 chars)"]
    - [dec_ne_qn_len,  "Decimal.__ne__.__qualname__.__len__", [], 14, "decimal.Decimal.__ne__.__qualname__.__len__() == 14 ('Decimal.__ne__' has 14 chars)"]

# ---------------------------------------------------------------------------
# decimal exception hierarchy class identity
# DecimalException inherits from ArithmeticError; mro len=5.
# InvalidOperation inherits from DecimalException; mro len=6.
# DivisionByZero inherits from DecimalException (also ZeroDivisionError in MRO); mro len=7.
# Overflow inherits from Inexact (which inherits from DecimalException); mro len=8.
# ---------------------------------------------------------------------------

table decimal_extra102.DecimalException_hierarchy:
  description: "decimal exception hierarchy: DecimalException(ArithmeticError,mro=5), InvalidOperation(DecimalException,mro=6), DivisionByZero(DecimalException,mro=7), Overflow(Inexact,mro=8)"
  kind: python_call_eq
  category: class_names
  id_prefix: deccmp102c

  columns: [id, function, args, expected, description]
  rows:
    - [decexc_name_eq,    DecimalException.__name__.__eq__,               ["DecimalException"],   true,  "decimal.DecimalException.__name__ == 'DecimalException'"]
    - [decexc_base_eq,    "DecimalException.__bases__[0].__name__.__eq__", ["ArithmeticError"],    true,  "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError'"]
    - [decexc_mro_len,    "DecimalException.__mro__.__len__",              [],                     5,     "decimal.DecimalException.__mro__.__len__() == 5 (DecimalException, ArithmeticError, Exception, BaseException, object)"]
    - [invop_name_eq,     InvalidOperation.__name__.__eq__,                ["InvalidOperation"],   true,  "decimal.InvalidOperation.__name__ == 'InvalidOperation'"]
    - [invop_base_eq,     "InvalidOperation.__bases__[0].__name__.__eq__", ["DecimalException"],   true,  "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException'"]
    - [invop_mro_len,     "InvalidOperation.__mro__.__len__",              [],                     6,     "decimal.InvalidOperation.__mro__.__len__() == 6"]
    - [divz_name_eq,      DivisionByZero.__name__.__eq__,                  ["DivisionByZero"],     true,  "decimal.DivisionByZero.__name__ == 'DivisionByZero'"]
    - [divz_base_eq,      "DivisionByZero.__bases__[0].__name__.__eq__",   ["DecimalException"],   true,  "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException'"]
    - [divz_mro_len,      "DivisionByZero.__mro__.__len__",                [],                     7,     "decimal.DivisionByZero.__mro__.__len__() == 7 (includes ZeroDivisionError in MRO)"]
    - [overflow_base_eq,  "Overflow.__bases__[0].__name__.__eq__",         ["Inexact"],            true,  "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (Overflow is more specific than plain Inexact)"]
    - [overflow_mro_len,  "Overflow.__mro__.__len__",                      [],                     8,     "decimal.Overflow.__mro__.__len__() == 8 (Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra102.Decimal.eq_qualname:
  description: "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (C extension wrapper_descriptor; the comparison operator __qualname__ uses the bare class name 'Decimal', length 14; all six comparison operators share this 14-character qualname pattern)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__eq__.__qualname__.__eq__"
  args: ["Decimal.__eq__"]
  expected: true

invariant decimal_extra102.Decimal.cmp_qualname_len_14:
  description: "decimal.Decimal.__lt__.__qualname__.__len__() == 14 ('Decimal.__lt__' has 14 characters; all six comparison operators __eq__/__lt__/__gt__/__le__/__ge__/__ne__ share this length, in contrast to __truediv__ which has length 19)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__lt__.__qualname__.__len__"
  args: []
  expected: 14

invariant decimal_extra102.DecimalException.bases_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (DecimalException is the root of the decimal exception hierarchy; it directly subclasses the built-in ArithmeticError, giving an MRO of 5 entries)"
  category: class_names
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra102.InvalidOperation.mro_len_6:
  description: "decimal.InvalidOperation.__mro__.__len__() == 6 (InvalidOperation's MRO is (InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object); it adds one entry beyond DecimalException's 5-entry MRO)"
  category: class_names
  kind: python_call_eq
  function: "InvalidOperation.__mro__.__len__"
  args: []
  expected: 6

invariant decimal_extra102.Overflow.bases_is_Inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (Overflow is a specific kind of Inexact result; its MRO of 8 entries is the longest among the decimal exceptions tested here, reflecting its deep position in the exception hierarchy)"
  category: class_names
  kind: python_call_eq
  function: "Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

