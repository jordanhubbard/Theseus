spec: decimal_extra1366
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal, Context, DecimalException, InvalidOperation documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks for decimal module classes."
    - "decimal.Decimal and decimal.Context are C extension types from the _decimal module; decimal.DecimalException and decimal.InvalidOperation are pure-Python exception classes."
    - "All four classes have integer-typed __flags__, __basicsize__, and __itemsize__ attributes."
    - "Only the type (int) is checked — exact values are platform-specific and intentionally not tested."
    - "decimal.Decimal.__flags__.__class__.__name__ == 'int'; decimal.Context.__flags__.__class__.__name__ == 'int'; decimal.DecimalException.__flags__.__class__.__name__ == 'int'; decimal.InvalidOperation.__flags__.__class__.__name__ == 'int'; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1366.decimal_context_flags_basicsize_itemsize:
  description: "decimal.Decimal and decimal.Context __flags__, __basicsize__, __itemsize__ type checks — wave 538 theme: both are C extension types from _decimal; __flags__, __basicsize__, and __itemsize__ are all integer-typed; only the type name 'int' is checked, not exact platform-specific values; verified with Python 3.12"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: dc1366dc
  columns: [id, function, args, expected, description]
  rows:
    - [dc1366dc001, decimal.Decimal.__flags__.__class__.__name__.__eq__,      ["int"], true, "decimal.Decimal.__flags__.__class__.__name__ == 'int' (C extension type attribute); verified with Python 3.12"]
    - [dc1366dc002, decimal.Decimal.__basicsize__.__class__.__name__.__eq__,  ["int"], true, "decimal.Decimal.__basicsize__.__class__.__name__ == 'int' (C extension type attribute); verified with Python 3.12"]
    - [dc1366dc003, decimal.Decimal.__itemsize__.__class__.__name__.__eq__,   ["int"], true, "decimal.Decimal.__itemsize__.__class__.__name__ == 'int' (C extension type attribute); verified with Python 3.12"]
    - [dc1366dc004, decimal.Context.__flags__.__class__.__name__.__eq__,      ["int"], true, "decimal.Context.__flags__.__class__.__name__ == 'int' (C extension type attribute); verified with Python 3.12"]
    - [dc1366dc005, decimal.Context.__basicsize__.__class__.__name__.__eq__,  ["int"], true, "decimal.Context.__basicsize__.__class__.__name__ == 'int' (C extension type attribute); verified with Python 3.12"]
    - [dc1366dc006, decimal.Context.__itemsize__.__class__.__name__.__eq__,   ["int"], true, "decimal.Context.__itemsize__.__class__.__name__ == 'int' (C extension type attribute); verified with Python 3.12"]

table decimal_extra1366.decimal_exception_flags_basicsize_itemsize:
  description: "decimal.DecimalException __flags__, __basicsize__, __itemsize__ type checks — wave 538 theme: decimal.DecimalException is a pure-Python exception class at the top of the decimal exception hierarchy; it still carries integer-typed C-slot attributes via Python's type machinery; only the type name 'int' is checked; verified with Python 3.12"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: dc1366de
  columns: [id, function, args, expected, description]
  rows:
    - [dc1366de001, decimal.DecimalException.__flags__.__class__.__name__.__eq__,      ["int"], true, "decimal.DecimalException.__flags__.__class__.__name__ == 'int' (C-slot attribute on exception class); verified with Python 3.12"]
    - [dc1366de002, decimal.DecimalException.__basicsize__.__class__.__name__.__eq__,  ["int"], true, "decimal.DecimalException.__basicsize__.__class__.__name__ == 'int' (C-slot attribute on exception class); verified with Python 3.12"]
    - [dc1366de003, decimal.DecimalException.__itemsize__.__class__.__name__.__eq__,   ["int"], true, "decimal.DecimalException.__itemsize__.__class__.__name__ == 'int' (C-slot attribute on exception class); verified with Python 3.12"]
    - [dc1366de004, decimal.InvalidOperation.__flags__.__class__.__name__.__eq__,      ["int"], true, "decimal.InvalidOperation.__flags__ is int (cross-check: direct subclass of DecimalException also uses int); verified with Python 3.12"]
    - [dc1366de005, decimal.Decimal.__flags__.__class__.__name__.__eq__,               ["int"], true, "decimal.Decimal.__flags__ is int (cross-check: C extension type consistent with exception classes); verified with Python 3.12"]
    - [dc1366de006, decimal.Context.__flags__.__class__.__name__.__eq__,               ["int"], true, "decimal.Context.__flags__ is int (cross-check: all decimal classes use int for __flags__); verified with Python 3.12"]

