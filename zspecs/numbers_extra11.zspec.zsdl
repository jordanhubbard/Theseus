spec: numbers_extra11
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers.zspec.zsdl and prior extras (numbers_extra through numbers_extra10)."
    - "numbers_extra7 covers: all five __module__ == 'numbers' as __eq__ invariants."
    - "numbers_extra2 covers: Number.__module__/Complex.__module__/Real.__module__ == 'numbers'."
    - "numbers_extra3 covers: Rational.__module__/Integral.__module__ == 'numbers'."
    - "numbers_extra5 covers: MRO lengths for all five tower classes."
    - "numbers_extra6 covers: MRO[0].__name__ == class name for all five classes."
    - "numbers_extra10 covers: MRO[1] (Complex/Real/Rational) and terminal MRO entries."
    - "No prior spec covers Number.__name__ via __eq__ invariant form."
    - "No prior spec covers Complex.__name__, Real.__name__, Rational.__name__, Integral.__name__ in a unified table."
    - "No prior spec covers numbers.Number.__module__ == 'numbers' via __eq__ as a table row alongside all five classes in this combination."
    - "No prior spec covers Complex.__bases__[0].__name__ == 'Number' via __getitem__+method form."
    - "No prior spec covers Real.__bases__[0].__name__ == 'Complex' via __getitem__+method form."
    - "Number.__name__ == 'Number' — the top of the numeric tower."
    - "Complex.__name__ == 'Complex' — second level of the numeric tower."
    - "Real.__name__ == 'Real' — third level of the numeric tower."
    - "Rational.__name__ == 'Rational' — fourth level of the numeric tower."
    - "Integral.__name__ == 'Integral' — fifth (bottom) level of the numeric tower."
    - "numbers.Number.__module__ == 'numbers' — all tower classes are defined in the numbers module."
    - "Complex.__bases__[0].__name__ == 'Number' — Complex directly inherits from Number."
    - "Real.__bases__[0].__name__ == 'Complex' — Real directly inherits from Complex."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for all five numeric tower classes
#
# numbers.zspec and prior extras confirm tower structure via MRO and module.
# No prior spec covers all five __name__ attributes in a unified table.
# Number.__name__ == 'Number', Complex.__name__ == 'Complex', etc.
# ---------------------------------------------------------------------------

invariant numbers_extra11.Number.name:
  description: "numbers.Number.__name__ == 'Number' — top of the numeric tower"
  category: class_identity
  kind: python_call_eq
  function: Number.__name__.__eq__
  args: ["Number"]
  expected: true

table numbers_extra11.tower_class_names:
  description: "__name__ attributes for Complex/Real/Rational/Integral"
  kind: python_call_eq
  category: class_identity
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [Complex,  Complex.__name__.__eq__,  ["Complex"],  true]
    - [Real,     Real.__name__.__eq__,     ["Real"],     true]
    - [Rational, Rational.__name__.__eq__, ["Rational"], true]
    - [Integral, Integral.__name__.__eq__, ["Integral"], true]

# ---------------------------------------------------------------------------
# numbers.Number.__module__ == 'numbers'
#
# numbers_extra2/extra3/extra7 cover __module__ for all five classes.
# This invariant re-expresses Number.__module__ as a standalone check
# for completeness and consistency with the name invariant above.
# ---------------------------------------------------------------------------

invariant numbers_extra11.Number.module:
  description: "numbers.Number.__module__ == 'numbers' — Number is defined in the numbers module"
  category: class_identity
  kind: python_call_eq
  function: Number.__module__.__eq__
  args: ["numbers"]
  expected: true

# ---------------------------------------------------------------------------
# Complex.__bases__[0].__name__ == 'Number'
#
# The direct (non-MRO) base class of Complex is Number. numbers_extra10
# covers MRO[1] for Complex which is Number, but not __bases__[0] directly.
# __bases__ is the tuple of immediate base classes; for Complex it is (Number,).
# ---------------------------------------------------------------------------

invariant numbers_extra11.Complex.base_name:
  description: "numbers.Complex.__bases__[0].__name__ == 'Number' — Complex directly inherits from Number"
  category: class_hierarchy
  kind: python_call_eq
  function: Complex.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Number"

# ---------------------------------------------------------------------------
# Real.__bases__[0].__name__ == 'Complex'
#
# The direct base class of Real is Complex. numbers_extra10 covers MRO[1] for
# Real (which is Complex) but not __bases__[0] directly.
# ---------------------------------------------------------------------------

invariant numbers_extra11.Real.base_name:
  description: "numbers.Real.__bases__[0].__name__ == 'Complex' — Real directly inherits from Complex"
  category: class_hierarchy
  kind: python_call_eq
  function: Real.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Complex"
