spec: io_extra131
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/rawio.c"
  notes:
    - "This spec covers: io.RawIOBase and io.BufferedIOBase method __qualname__ values and lengths."
    - "RawIOBase and BufferedIOBase are pure-Python ABCs in io; their methods are defined in the ABC layer."
    - "io.RawIOBase.read.__qualname__ = '_RawIOBase.read' (length 15) — the underlying C ABC name is _RawIOBase."
    - "io.RawIOBase.readall.__qualname__ = '_RawIOBase.readall' (length 18)."
    - "io.RawIOBase.readinto.__qualname__ = '_RawIOBase.readinto' (length 19)."
    - "io.RawIOBase.write.__qualname__ = '_RawIOBase.write' (length 16)."
    - "io.BufferedIOBase.read.__qualname__ = '_BufferedIOBase.read' (length 20)."
    - "io.BufferedIOBase.read1.__qualname__ = '_BufferedIOBase.read1' (length 21)."
    - "io.BufferedIOBase.write.__qualname__ = '_BufferedIOBase.write' (length 21)."
    - "io.BufferedIOBase.detach.__qualname__ = '_BufferedIOBase.detach' (length 22)."
    - "The qualname prefix is '_RawIOBase' and '_BufferedIOBase' (with leading underscore) because io.RawIOBase and io.BufferedIOBase are aliases for the private C types _io._RawIOBase and _io._BufferedIOBase."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.RawIOBase method __qualname__ values and lengths
# RawIOBase is an alias for the C type _io._RawIOBase, so method qualnames
# use the '_RawIOBase' prefix rather than 'RawIOBase'.
# read=15, readall=18, readinto=19, write=16.
# ---------------------------------------------------------------------------

table io_extra131.RawIOBase_method_qualnames:
  description: "io.RawIOBase method __qualname__ values and lengths: read, readall, readinto, write"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iorawbuf131

  columns: [id, function, args, expected, description]
  rows:
    - [raw_read_qname_eq,     RawIOBase.read.__qualname__.__eq__,     ["_RawIOBase.read"],     true,  "RawIOBase.read.__qualname__ == '_RawIOBase.read' (uses private C type name)"]
    - [raw_read_qname_len,    RawIOBase.read.__qualname__.__len__,    [],                       15,    "RawIOBase.read.__qualname__ has 15 characters"]
    - [raw_readall_qname_eq,  RawIOBase.readall.__qualname__.__eq__,  ["_RawIOBase.readall"],  true,  "RawIOBase.readall.__qualname__ == '_RawIOBase.readall'"]
    - [raw_readall_qname_len, RawIOBase.readall.__qualname__.__len__, [],                       18,    "RawIOBase.readall.__qualname__ has 18 characters"]
    - [raw_readinto_qname_eq, RawIOBase.readinto.__qualname__.__eq__, ["_RawIOBase.readinto"], true,  "RawIOBase.readinto.__qualname__ == '_RawIOBase.readinto'"]
    - [raw_readinto_qname_len,RawIOBase.readinto.__qualname__.__len__,[],                       19,    "RawIOBase.readinto.__qualname__ has 19 characters"]
    - [raw_write_qname_eq,    RawIOBase.write.__qualname__.__eq__,    ["_RawIOBase.write"],    true,  "RawIOBase.write.__qualname__ == '_RawIOBase.write'"]
    - [raw_write_qname_len,   RawIOBase.write.__qualname__.__len__,   [],                       16,    "RawIOBase.write.__qualname__ has 16 characters"]
    - [raw_read_not_bare,     RawIOBase.read.__qualname__.__eq__,     ["read"],                false, "RawIOBase.read.__qualname__ != 'read' (includes class prefix)"]

# ---------------------------------------------------------------------------
# io.BufferedIOBase method __qualname__ values and lengths
# BufferedIOBase is an alias for _io._BufferedIOBase; method qualnames use
# '_BufferedIOBase' prefix.
# read=20, read1=21, write=21, detach=22.
# ---------------------------------------------------------------------------

table io_extra131.BufferedIOBase_method_qualnames:
  description: "io.BufferedIOBase method __qualname__ values and lengths: read, read1, write, detach"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iorawbuf131

  columns: [id, function, args, expected, description]
  rows:
    - [buf_read_qname_eq,    BufferedIOBase.read.__qualname__.__eq__,    ["_BufferedIOBase.read"],   true,  "BufferedIOBase.read.__qualname__ == '_BufferedIOBase.read'"]
    - [buf_read_qname_len,   BufferedIOBase.read.__qualname__.__len__,   [],                          20,    "BufferedIOBase.read.__qualname__ has 20 characters"]
    - [buf_read1_qname_eq,   BufferedIOBase.read1.__qualname__.__eq__,   ["_BufferedIOBase.read1"],  true,  "BufferedIOBase.read1.__qualname__ == '_BufferedIOBase.read1'"]
    - [buf_read1_qname_len,  BufferedIOBase.read1.__qualname__.__len__,  [],                          21,    "BufferedIOBase.read1.__qualname__ has 21 characters"]
    - [buf_write_qname_eq,   BufferedIOBase.write.__qualname__.__eq__,   ["_BufferedIOBase.write"],  true,  "BufferedIOBase.write.__qualname__ == '_BufferedIOBase.write'"]
    - [buf_write_qname_len,  BufferedIOBase.write.__qualname__.__len__,  [],                          21,    "BufferedIOBase.write.__qualname__ has 21 characters"]
    - [buf_detach_qname_eq,  BufferedIOBase.detach.__qualname__.__eq__,  ["_BufferedIOBase.detach"], true,  "BufferedIOBase.detach.__qualname__ == '_BufferedIOBase.detach'"]
    - [buf_detach_qname_len, BufferedIOBase.detach.__qualname__.__len__, [],                          22,    "BufferedIOBase.detach.__qualname__ has 22 characters"]
    - [buf_read_not_raw,     BufferedIOBase.read.__qualname__.__eq__,    ["_RawIOBase.read"],        false, "BufferedIOBase.read.__qualname__ != '_RawIOBase.read' (different base class prefix)"]

# ---------------------------------------------------------------------------
# Cross-check: qualname prefix comparison between RawIOBase and BufferedIOBase
# read1 exists only on BufferedIOBase (not RawIOBase).
# detach exists only on BufferedIOBase (not RawIOBase).
# readinto exists only on RawIOBase (not BufferedIOBase).
# ---------------------------------------------------------------------------

table io_extra131.cross_checks:
  description: "Cross-check qualname lengths: RawIOBase methods are shorter than BufferedIOBase due to prefix length difference"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iorawbuf131

  columns: [id, function, args, expected, description]
  rows:
    - [raw_read_len_15,    RawIOBase.read.__qualname__.__len__,    [], 15, "RawIOBase.read qualname len 15 ('_RawIOBase.read')"]
    - [buf_read_len_20,    BufferedIOBase.read.__qualname__.__len__,[],20, "BufferedIOBase.read qualname len 20 ('_BufferedIOBase.read')"]
    - [raw_write_len_16,   RawIOBase.write.__qualname__.__len__,   [], 16, "RawIOBase.write qualname len 16 ('_RawIOBase.write')"]
    - [buf_write_len_21,   BufferedIOBase.write.__qualname__.__len__,[],21,"BufferedIOBase.write qualname len 21 ('_BufferedIOBase.write')"]
    - [raw_readall_len_18, RawIOBase.readall.__qualname__.__len__, [], 18, "RawIOBase.readall qualname len 18 ('_RawIOBase.readall')"]
    - [buf_detach_len_22,  BufferedIOBase.detach.__qualname__.__len__,[],22,"BufferedIOBase.detach qualname len 22 ('_BufferedIOBase.detach')"]
    - [buf_read1_len_21,   BufferedIOBase.read1.__qualname__.__len__,[],21,"BufferedIOBase.read1 qualname len 21 ('_BufferedIOBase.read1')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra131.RawIOBase.read_qualname:
  description: "io.RawIOBase.read.__qualname__ == '_RawIOBase.read' (the public alias io.RawIOBase maps to the private C type _io._RawIOBase, so method qualnames carry the underscore prefix)"
  category: method_qualnames
  kind: python_call_eq
  function: RawIOBase.read.__qualname__.__eq__
  args: ["_RawIOBase.read"]
  expected: true

invariant io_extra131.RawIOBase.readinto_qualname_len:
  description: "io.RawIOBase.readinto.__qualname__.__len__() == 19 ('_RawIOBase.readinto' has 19 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: RawIOBase.readinto.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra131.BufferedIOBase.detach_qualname:
  description: "io.BufferedIOBase.detach.__qualname__ == '_BufferedIOBase.detach' (length 22)"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedIOBase.detach.__qualname__.__eq__
  args: ["_BufferedIOBase.detach"]
  expected: true

invariant io_extra131.BufferedIOBase.read1_qualname_len:
  description: "io.BufferedIOBase.read1.__qualname__.__len__() == 21 ('_BufferedIOBase.read1' has 21 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedIOBase.read1.__qualname__.__len__
  args: []
  expected: 21

invariant io_extra131.BufferedIOBase.write_qualname:
  description: "io.BufferedIOBase.write.__qualname__ == '_BufferedIOBase.write' (length 21; same length as read1 despite different method name because 'write' has one more letter than 'read1')"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedIOBase.write.__qualname__.__eq__
  args: ["_BufferedIOBase.write"]
  expected: true

