spec: fflate
version: ">=0.8.0"
backend: node(fflate)

docs: https://github.com/101arrowz/fflate#readme

provenance:
  derived_from:
    - "fflate README — https://github.com/101arrowz/fflate#readme"
    - "RFC 1950/1951/1952 (zlib/deflate/gzip)"
    - "Test vectors verified with fflate via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "fflate source"
  notes:
    - "fflate is a high-performance pure-JS deflate/zlib/gzip implementation, smaller and faster than pako."
    - "Install: npm install fflate"
    - "Sync helpers: deflateSync, inflateSync, gzipSync, gunzipSync, zlibSync, unzlibSync — each takes a Uint8Array and returns a Uint8Array."
  rfcs:
    - "RFC 1950 — ZLIB Compressed Data Format"
    - "RFC 1951 — DEFLATE Compressed Data Format"
    - "RFC 1952 — GZIP File Format"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; throws on malformed input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# inflateSync(deflated_bytes) recovers the input. Vectors via known compressed payloads.

invariant fflate.inflate_known_hello:
  description: "inflateSync recovers 'hello' from known DEFLATE bytes"
  category: inflate
  kind: node_chain_eq
  entry: named
  function: inflateSync
  entry_args: [[203, 72, 205, 201, 201, 7, 0]]
  chain:
    - {method: at, args: [0]}
  expected: 104

invariant fflate.inflate_hello_length:
  description: "inflateSync of 'hello' yields 5-byte output"
  category: inflate
  kind: node_chain_eq
  entry: named
  function: inflateSync
  entry_args: [[203, 72, 205, 201, 201, 7, 0]]
  chain:
    - {get: length}
  expected: 5



# gzipSync output starts with the gzip magic 0x1f 0x8b
invariant fflate.gzip_magic_byte_one:
  description: "gzipSync output begins with magic byte 0x1f"
  category: gzip
  kind: node_chain_eq
  entry: named
  function: gzipSync
  entry_args: [[104, 101, 108, 108, 111]]
  chain:
    - {method: at, args: [0]}
  expected: 31

invariant fflate.gzip_magic_byte_two:
  description: "gzipSync output's second magic byte is 0x8b"
  category: gzip
  kind: node_chain_eq
  entry: named
  function: gzipSync
  entry_args: [[104, 101, 108, 108, 111]]
  chain:
    - {method: at, args: [1]}
  expected: 139



# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:59:00Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
