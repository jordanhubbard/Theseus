spec: csv_extra5
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl, _csv.zspec.zsdl, _csv_extra.zspec.zsdl, csv_extra.zspec.zsdl, csv_extra2.zspec.zsdl, csv_extra3.zspec.zsdl, and csv_extra4.zspec.zsdl."
    - "Focus: __qualname__ checks for csv classes and functions, and __class__.__name__ checks for quote constants."
    - "csv.QUOTE_ALL and csv.QUOTE_MINIMAL are plain ints in CPython."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# qualname — major csv classes (table)
# ---------------------------------------------------------------------------

table csv_extra5.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [DictReader, DictReader.__qualname__.__eq__, ["DictReader"], true]
    - [DictWriter, DictWriter.__qualname__.__eq__, ["DictWriter"], true]
    - [Dialect,    Dialect.__qualname__.__eq__,    ["Dialect"],    true]
    - [Sniffer,    Sniffer.__qualname__.__eq__,    ["Sniffer"],    true]
    - [Error,      Error.__qualname__.__eq__,      ["Error"],      true]

# ---------------------------------------------------------------------------
# qualname — module-level functions
# ---------------------------------------------------------------------------

invariant csv_extra5.reader.qualname:
  description: "csv.reader.__qualname__ == 'reader'"
  category: qualnames
  kind: python_call_eq
  function: reader.__qualname__.__eq__
  args: ["reader"]
  expected: true

invariant csv_extra5.writer.qualname:
  description: "csv.writer.__qualname__ == 'writer'"
  category: qualnames
  kind: python_call_eq
  function: writer.__qualname__.__eq__
  args: ["writer"]
  expected: true

invariant csv_extra5.field_size_limit.qualname:
  description: "csv.field_size_limit.__qualname__ == 'field_size_limit'"
  category: qualnames
  kind: python_call_eq
  function: field_size_limit.__qualname__.__eq__
  args: ["field_size_limit"]
  expected: true

invariant csv_extra5.get_dialect.qualname:
  description: "csv.get_dialect.__qualname__ == 'get_dialect'"
  category: qualnames
  kind: python_call_eq
  function: get_dialect.__qualname__.__eq__
  args: ["get_dialect"]
  expected: true

invariant csv_extra5.list_dialects.qualname:
  description: "csv.list_dialects.__qualname__ == 'list_dialects'"
  category: qualnames
  kind: python_call_eq
  function: list_dialects.__qualname__.__eq__
  args: ["list_dialects"]
  expected: true

invariant csv_extra5.register_dialect.qualname:
  description: "csv.register_dialect.__qualname__ == 'register_dialect'"
  category: qualnames
  kind: python_call_eq
  function: register_dialect.__qualname__.__eq__
  args: ["register_dialect"]
  expected: true

invariant csv_extra5.unregister_dialect.qualname:
  description: "csv.unregister_dialect.__qualname__ == 'unregister_dialect'"
  category: qualnames
  kind: python_call_eq
  function: unregister_dialect.__qualname__.__eq__
  args: ["unregister_dialect"]
  expected: true

# ---------------------------------------------------------------------------
# QUOTE_* constants — class name checks (they are plain ints in CPython)
# ---------------------------------------------------------------------------

invariant csv_extra5.QUOTE_ALL.class_name:
  description: "csv.QUOTE_ALL.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: QUOTE_ALL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant csv_extra5.QUOTE_MINIMAL.class_name:
  description: "csv.QUOTE_MINIMAL.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: QUOTE_MINIMAL.__class__.__name__.__eq__
  args: ["int"]
  expected: true
