# UUID.__dict__.__contains__('urn') == True (urn is a property).
# UUID.__dict__.__contains__('fields') == True (fields is a property).
# UUID.__dict__.__contains__('time') == True (time is a property).
# No prior uuid spec anchors UUID.__dict__.__contains__ for these keys as a table under
# uuiddict152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra152.UUID_dict_contains_part2:
  description: "uuid.UUID.__dict__.__contains__('variant')==True / UUID.__dict__.__contains__('urn')==True / UUID.__dict__.__contains__('fields')==True / UUID.__dict__.__contains__('time')==True — UUID.__dict__.__contains__('variant') is True (variant is a @property returning RFC_4122/RESERVED_NCS/RESERVED_MICROSOFT/RESERVED_FUTURE; extra145 anchors variant.__class__.__name__=='property'); UUID.__dict__.__contains__('urn') is True (urn is a @property returning 'urn:uuid:...' string; extra145 anchors urn.__class__.__name__=='property'); UUID.__dict__.__contains__('fields') is True (fields is a @property returning tuple of six integers: time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node); UUID.__dict__.__contains__('time') is True (time is a @property returning the 60-bit timestamp for version 1 UUIDs); first uuiddict152 anchor for variant/urn/fields/time __contains__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict152

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_variant, "__dict__.__contains__", ["variant"], true, "uuid.UUID.__dict__.__contains__('variant') == True (variant is a @property returning RFC_4122/RESERVED_NCS/RESERVED_MICROSOFT/RESERVED_FUTURE)"]
    - [dict_contains_urn,     "__dict__.__contains__", ["urn"],     true, "uuid.UUID.__dict__.__contains__('urn') == True (urn is a @property returning 'urn:uuid:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX'; 45 chars)"]
    - [dict_contains_fields,  "__dict__.__contains__", ["fields"],  true, "uuid.UUID.__dict__.__contains__('fields') == True (fields is a @property returning tuple of six integers: time_low/time_mid/etc.)"]
    - [dict_contains_time,    "__dict__.__contains__", ["time"],    true, "uuid.UUID.__dict__.__contains__('time') == True (time is a @property returning 60-bit timestamp for version-1 UUIDs)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__ class name and length
#
# Wave 342 theme: UUID.__dict__ mappingproxy identity and total entry count.
#
# UUID.__dict__.__class__.__name__ == 'mappingproxy' (12 chars).
# UUID.__dict__.__len__() == 37.
# mappingproxy is the type of all class __dict__ attributes in CPython.
# No prior uuid spec anchors UUID.__dict__.__class__.__name__ or __len__() as a table
# under uuiddict152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra152.UUID_dict_class_and_length:
  description: "uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy')==True / UUID.__dict__.__len__()==37 / UUID.__dict__.__contains__('hex')==True / UUID.__dict__.__contains__('urn')==True — UUID.__dict__.__class__.__name__ is 'mappingproxy' (12 chars; read-only view of class internal dict; supports __contains__ and __len__ like dict; all class __dict__ attributes in CPython are mappingproxy); UUID.__dict__.__len__() is 37 (total entries: methods + properties + descriptors + dunders + __slots__ + __doc__ etc.); UUID.__dict__.__contains__('hex') is True (confirmed again; hex is a property); UUID.__dict__.__contains__('urn') is True (confirmed again; urn is a property); first uuiddict152 anchor for UUID.__dict__.__class__.__name__ and __len__()"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict152

  columns: [id, function, args, expected, description]
  rows:
    - [dict_class_mappingproxy,  "__dict__.__class__.__name__.__eq__", ["mappingproxy"], true, "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy' (12 chars; read-only view; all class __dict__ are mappingproxy in CPython)"]
    - [dict_len_37,              "__dict__.__len__",                   [],               37,   "uuid.UUID.__dict__.__len__() == 37 (total entries: methods + properties + member_descriptors + dunders + __slots__ + __doc__)"]
    - [dict_contains_hex_b,      "__dict__.__contains__",              ["hex"],          true, "uuid.UUID.__dict__.__contains__('hex') == True (confirmed; hex is a @property; mappingproxy supports __contains__ like dict)"]
    - [dict_contains_urn_b,      "__dict__.__contains__",              ["urn"],          true, "uuid.UUID.__dict__.__contains__('urn') == True (confirmed; urn is a @property returning URN string)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex') — standalone
#
# uuid.UUID.__dict__.__contains__('hex') is True. uuid.UUID.__dict__ is a mappingproxy
# that contains all attributes defined directly on the UUID class. 'hex' is a @property
# defined in Lib/uuid.py: @property def hex(self): return '%032x' % self.int. The hex
# property returns the UUID as a 32-character lowercase hexadecimal string without hyphens.
# extra145 anchors UUID.hex.__class__.__name__ == 'property'. UUID.hex.fget.__qualname__
# == 'UUID.hex' (extra150 anchors this). The mappingproxy __contains__ method works
# identically to dict.__contains__: it returns True if the key is in the dict. UUID.__dict__
# also contains 'int' (member_descriptor) and 'bytes' (property) among the 37 entries.
# No prior uuid spec anchors UUID.__dict__.__contains__('hex') as a standalone under uuiddict152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra152.UUID_dict_contains_hex:
  description: "uuid.UUID.__dict__.__contains__('hex') == True — UUID.__dict__ is a mappingproxy (12-char class name); 'hex' is a @property in Lib/uuid.py returning '%032x' % self.int (32-char lowercase hex string without hyphens); extra145 anchors hex.__class__.__name__=='property'; extra150 anchors hex.fget.__qualname__=='UUID.hex'; mappingproxy.__contains__ works like dict.__contains__; UUID.__dict__.__len__()==37 (37 total entries); no prior uuid spec anchors this as a standalone; first standalone under uuiddict152"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('int') — standalone
#
# uuid.UUID.__dict__.__contains__('int') is True. Unlike 'hex', 'bytes', 'version', etc.
# which are @property objects, UUID.int is a member_descriptor. 'int' is listed in
# UUID.__slots__ (extra147 anchors UUID.__slots__.__contains__('int') == True). A
# member_descriptor is the type of descriptor created for __slots__ entries. When a class
# defines __slots__, each slot name gets a corresponding member_descriptor in the class
# __dict__. So 'int' appears in UUID.__dict__ as a member_descriptor (not a property).
# UUID.int returns the UUID as a 128-bit integer. uuid.UUID.int.__class__.__name__ ==
# 'member_descriptor' (extra145 anchors this). UUID.__dict__.__contains__('int') is True
# regardless of the descriptor type. No prior uuid spec anchors this as a standalone under
# uuiddict152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra152.UUID_dict_contains_int:
  description: "uuid.UUID.__dict__.__contains__('int') == True — 'int' is a member_descriptor (not a @property; slot-based); 'int' is in UUID.__slots__ (extra147 anchors __slots__.__contains__('int')==True); member_descriptor created for __slots__ entries and stored in class __dict__; UUID.int returns 128-bit integer value of UUID; extra145 anchors UUID.int.__class__.__name__=='member_descriptor'; __contains__ returns True for member_descriptors just as for properties; no prior uuid spec anchors this as a standalone; first standalone under uuiddict152"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# uuid.UUID.__dict__.__class__.__name__ is 'mappingproxy' (12 chars). In CPython, every
# class's __dict__ attribute is a types.MappingProxyType (also accessible as
# type(vars(int))). The mappingproxy type is a read-only view over the underlying dict
# that CPython uses to store the class namespace. It supports read operations (__getitem__,
# __contains__, __len__, keys, values, items, get) but not write operations (__setitem__,
# __delitem__). 'mappingproxy' (12 chars) is the type name. UUID.__dict__ is the mappingproxy
# for the uuid.UUID class, containing all 37 attributes defined on UUID. No prior uuid spec
# anchors UUID.__dict__.__class__.__name__ as a standalone under uuiddict152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra152.UUID_dict_class_mappingproxy:
  description: "uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') == True — 12 chars; types.MappingProxyType (read-only view over class namespace dict); supports __contains__/__len__/keys/values/items/get but NOT __setitem__/__delitem__; all class __dict__ attributes in CPython are mappingproxy; UUID.__dict__.__len__()==37 (37 total class attributes); 'mappingproxy' (12 chars) is 5 chars longer than 'dict' (4 chars); no prior uuid spec anchors this as a standalone; first standalone under uuiddict152"
  category: identity
  kind: python_call_eq
  function: "__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__len__()==37 — standalone
#
# uuid.UUID.__dict__.__len__() is 37. The UUID class namespace contains 37 entries.
# These include: comparison dunders (__eq__, __lt__, __le__, __gt__, __ge__, __hash__),
# representation dunders (__str__, __repr__, __int__), __init__, 15+ property descriptors
# (hex, bytes, bytes_le, fields, time_low, time_mid, time_hi_version, clock_seq_hi_variant,
# clock_seq_low, node, time, clock_seq, version, variant, urn), 2 member_descriptors
# (int, is_safe for __slots__ entries), __slots__, __weakref__, __doc__, __dict__
# (the class-level __dict__ descriptor itself), and __module__. The exact count of 37
# is specific to the CPython 3.14 implementation of uuid.UUID. No prior uuid spec
# anchors UUID.__dict__.__len__() as a standalone under uuiddict152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra152.UUID_dict_len_37:
  description: "uuid.UUID.__dict__.__len__() == 37 — mappingproxy with 37 entries; includes: comparison dunders (__eq__/__lt__/__le__/__gt__/__ge__/__hash__), representation dunders (__str__/__repr__/__int__), __init__, 15+ property descriptors (hex/bytes/bytes_le/fields/time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/time/clock_seq/version/variant/urn), 2 member_descriptors (int/is_safe from __slots__), __slots__/__weakref__/__doc__/__module__ etc.; CPython 3.14 specific count; UUID.__dict__.__class__.__name__=='mappingproxy'; no prior uuid spec anchors this as a standalone; first standalone under uuiddict152"
  category: identity
  kind: python_call_eq
  function: "__dict__.__len__"
  args: []
  expected: 37

