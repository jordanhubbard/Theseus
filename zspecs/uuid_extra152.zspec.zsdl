spec: uuid_extra152
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra151.zspec.zsdl — covers uuid.UUID.__lt__/__le__/__gt__/__ge__ qualname strings and lengths; ordering dunder qualname length ordering (table + invariants)."
    - "uuid_extra150.zspec.zsdl — covers uuid.UUID property fget qualnames: hex.fget.__qualname__.__eq__('UUID.hex') / bytes.fget.__qualname__ / version.fget.__qualname__ / variant.fget.__qualname__ / urn.fget.__qualname__ / fields.fget.__qualname__ (table + invariants)."
    - "uuid_extra149.zspec.zsdl — covers uuid.UUID.__init__/__qualname__/__code__.co_argcount==7/__code__.co_name / __str__/__repr__/__hash__/__eq__ co_name and co_argcount ordering (table + invariants)."
    - "uuid_extra147.zspec.zsdl — covers uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') / UUID.__slots__.__len__()==3 / UUID.__hash__/__str__/__repr__/__eq__ qualname lengths (table + invariants)."
    - "uuid_extra145.zspec.zsdl — covers uuid.UUID.hex/__bytes/__version/__variant/__node/__time/__class__.__name__.__eq__('property') / UUID.int/__class__.__name__.__eq__('member_descriptor') (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra151."
    - "Wave 342 theme: uuid.UUID.__dict__ membership checks using __contains__ — UUID.__dict__.__contains__('hex') / __dict__.__contains__('int') / __dict__.__contains__('bytes') / __dict__.__contains__('version') / __dict__.__contains__('variant') / __dict__.__contains__('urn') / __dict__.__contains__('fields') / __dict__.__contains__('time'); UUID.__dict__.__class__.__name__ == 'mappingproxy'."
    - "uuid.UUID.__dict__.__contains__('hex') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('int') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('version') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('variant') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('urn') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('fields') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('time') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__len__() == 37. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__dict__ is a mappingproxy (not a plain dict). Class __dict__ attributes in Python are always mappingproxy objects (read-only views of the underlying dict). mappingproxy supports the same __contains__ method as dict, returning True if the key is present. UUID.__dict__ contains all methods, properties, and descriptors defined directly on the UUID class: __init__, __str__, __repr__, __hash__, __eq__, __lt__, __le__, __gt__, __ge__, hex, bytes, bytes_le, fields, time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node, time, clock_seq, version, variant, urn, int (member_descriptor), is_safe (member_descriptor), __slots__, __weakref__, and others."
    - "Note: uuid.UUID.__dict__.__contains__('int') == True. uuid.UUID.int is a member_descriptor (not a property), because 'int' is listed in __slots__ (extra147 anchors UUID.__slots__.__contains__('int')==True). Despite being a member_descriptor rather than a property, 'int' is still present in UUID.__dict__ as a descriptor object. Similarly, 'is_safe' is in __slots__ and in __dict__. This contrasts with 'hex', 'bytes', 'version', 'variant', 'urn', 'fields', 'time', which are properties (@property) defined in Lib/uuid.py."
    - "Note: uuid.UUID.__dict__.__len__() == 37. The UUID class dict contains 37 entries covering all methods, properties, and descriptors. This count includes: 5 comparison dunders (__eq__/__lt__/__le__/__gt__/__ge__), 3 representation dunders (__str__/__repr__/__hash__), __init__, 15+ property descriptors (hex/bytes/bytes_le/fields/time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/time/clock_seq/version/variant/urn), 2 member_descriptors (int/is_safe), __slots__, __weakref__, __doc__, etc."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex')
# uuid.UUID.__dict__.__contains__('int')
# uuid.UUID.__dict__.__contains__('bytes')
# uuid.UUID.__dict__.__contains__('version')
#
# Wave 342 theme: UUID.__dict__ membership checks for property and descriptor keys.
#
# UUID.__dict__.__contains__('hex') == True (hex is a property in UUID.__dict__).
# UUID.__dict__.__contains__('int') == True (int is a member_descriptor in __slots__).
# UUID.__dict__.__contains__('bytes') == True (bytes is a property).
# UUID.__dict__.__contains__('version') == True (version is a property).
# No prior uuid spec anchors UUID.__dict__.__contains__ as a table under uuiddict152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra152.UUID_dict_contains_part1:
  description: "uuid.UUID.__dict__.__contains__('hex')==True / UUID.__dict__.__contains__('int')==True / UUID.__dict__.__contains__('bytes')==True / UUID.__dict__.__contains__('version')==True — UUID.__dict__.__contains__('hex') is True (hex is a @property in Lib/uuid.py; UUID.__dict__ is a mappingproxy; extra145 anchors hex.__class__.__name__=='property'); UUID.__dict__.__contains__('int') is True (int is a member_descriptor listed in __slots__; extra147 anchors __slots__.__contains__('int')==True; __contains__ on __dict__ finds the descriptor); UUID.__dict__.__contains__('bytes') is True (bytes is a @property; extra145 anchors bytes.__class__.__name__=='property'); UUID.__dict__.__contains__('version') is True (version is a @property; extra145 anchors version.__class__.__name__=='property'); UUID.__dict__.__class__.__name__=='mappingproxy'; first uuiddict152 anchor for UUID.__dict__.__contains__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict152

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_hex,     "__dict__.__contains__", ["hex"],     true, "uuid.UUID.__dict__.__contains__('hex') == True (hex is a @property in UUID; returns 32-char hex string without hyphens; extra145 anchors property class)"]
    - [dict_contains_int,     "__dict__.__contains__", ["int"],     true, "uuid.UUID.__dict__.__contains__('int') == True (int is a member_descriptor listed in __slots__; extra147 anchors __slots__.__contains__('int')==True)"]
    - [dict_contains_bytes,   "__dict__.__contains__", ["bytes"],   true, "uuid.UUID.__dict__.__contains__('bytes') == True (bytes is a @property in UUID; returns UUID as 16-byte big-endian bytes object)"]
    - [dict_contains_version, "__dict__.__contains__", ["version"], true, "uuid.UUID.__dict__.__contains__('version') == True (version is a @property returning UUID version 1-5 or None for non-RFC 4122)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('variant')
# uuid.UUID.__dict__.__contains__('urn')
# uuid.UUID.__dict__.__contains__('fields')
# uuid.UUID.__dict__.__contains__('time')
#
# Wave 342 theme: UUID.__dict__ membership checks for remaining properties.
