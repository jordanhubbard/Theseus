spec: secrets_extra7
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra.zspec.zsdl — covers function __name__/__module__; return type class checks"
    - "secrets_extra2.zspec.zsdl — covers function __name__ table; SystemRandom __name__/__module__/__bases__; token_bytes len32; token_hex len 2*n"
    - "secrets_extra3.zspec.zsdl — covers function __module__ invariants; DEFAULT_ENTROPY class and >= 16"
    - "secrets_extra4.zspec.zsdl — covers __qualname__ table; DEFAULT_ENTROPY == 32; token_urlsafe len 24/32; token_bytes len 4/8/64; token_hex len 4/32"
    - "secrets_extra5.zspec.zsdl — covers SystemRandom MRO[0]/[1], zero-length tokens, return class anchors"
    - "secrets_extra6.zspec.zsdl — covers token_bytes n=2/3; token_hex n=2/3; token_urlsafe n=6/8/12; DEFAULT_ENTROPY*8==256; SystemRandom.__bases__.__len__()==1; choice([7])/choice([0])"
  notes:
    - "This spec extends the secrets chain; it does NOT duplicate invariants present in any prior spec."
    - "Focus: additional token length axes, SystemRandom MRO[3], and deterministic randbits(0) and randbelow(1)."
    - "Prior specs cover token_bytes at n=0,1,2,3,4,8,16,32,64. NOT yet covered: n=5, n=10, n=20."
    - "Prior specs cover token_hex at n=0,2,3,4,8,16,32. NOT yet covered: n=5 (->10), n=10 (->20), n=20 (->40)."
    - "Prior specs cover token_urlsafe at n=0,6,8,9,12,16,24,32. NOT yet covered: n=4 (->6), n=15 (->20), n=20 (->27)."
    - "secrets.randbits(0) == 0 — deterministic because 0 random bits always yields 0."
    - "secrets.randbelow(1) == 0 — deterministic because the only integer in [0,1) is 0."
    - "secrets.SystemRandom.__mro__[3].__name__ == 'object' — the terminal entry in the MRO."
    - "secrets_extra5 covers mro[0]/__name__=='SystemRandom' and mro[1]/__name__=='Random'. NOT yet covered: mro[3]/__name__=='object'."
    - "token_urlsafe(4) -> 6 chars: ceil(4*4/3) = 6."
    - "token_urlsafe(15) -> 20 chars: ceil(15*4/3) = 20."
    - "token_urlsafe(20) -> 27 chars: ceil(20*4/3) = ceil(26.67) = 27."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# token_bytes — length at n=5, n=10, n=20
#
# Prior specs cover n=0,1,2,3,4,8,16,32,64. NOT covered: n=5, n=10, n=20.
# ---------------------------------------------------------------------------

table secrets_extra7.token_bytes_lengths:
  kind: python_call_eq
  category: token_bytes
  id_prefix: tb_len

  columns: [id, function, args, method, expected]
  rows:
    - [5,  token_bytes, [5],  __len__, 5]
    - [10, token_bytes, [10], __len__, 10]
    - [20, token_bytes, [20], __len__, 20]

# ---------------------------------------------------------------------------
# token_hex — length at n=5, n=10, n=20
#
# Prior specs cover n=0,2,3,4,8,16,32. NOT covered: n=5 (->10), n=10 (->20),
# n=20 (->40). Each byte produces exactly 2 hex characters.
# ---------------------------------------------------------------------------

table secrets_extra7.token_hex_lengths:
  kind: python_call_eq
  category: token_hex
  id_prefix: th_len

  columns: [id, function, args, method, expected]
  rows:
    - [5,  token_hex, [5],  __len__, 10]
    - [10, token_hex, [10], __len__, 20]
    - [20, token_hex, [20], __len__, 40]

# ---------------------------------------------------------------------------
# token_urlsafe — length at n=4, n=15, n=20
#
# Prior specs cover n=0,6,8,12,16,24,32. NOT covered: n=4 (->6), n=15 (->20),
# n=20 (->27). Length formula: ceil(n * 4 / 3) — no padding, URL-safe base64.
# ---------------------------------------------------------------------------

table secrets_extra7.token_urlsafe_lengths:
  kind: python_call_eq
  category: token_urlsafe
  id_prefix: tu_len

  columns: [id, function, args, method, expected]
  rows:
    - [4,  token_urlsafe, [4],  __len__, 6]
    - [15, token_urlsafe, [15], __len__, 20]
    - [20, token_urlsafe, [20], __len__, 27]

# ---------------------------------------------------------------------------
# randbits(0) == 0 — deterministic edge case
#
# secrets.randbits(k) returns a random integer with k random bits.
# With k=0, there are zero bits, so the result is always 0. No prior secrets
# spec asserts this deterministic behavior.
# ---------------------------------------------------------------------------

invariant secrets_extra7.randbits.zero_bits:
  description: "secrets.randbits(0) == 0 — zero random bits always yields zero"
  category: randbits
  kind: python_call_eq
  function: randbits
  args: [0]
  expected: 0

# ---------------------------------------------------------------------------
# randbelow(1) == 0 — deterministic edge case
#
# secrets.randbelow(n) returns an integer in [0, n). With n=1, the only
# possible value is 0. No prior secrets spec asserts this deterministic case.
# ---------------------------------------------------------------------------

invariant secrets_extra7.randbelow.one_exclusive_upper:
  description: "secrets.randbelow(1) == 0 — only integer in [0, 1) is 0"
  category: randbelow
  kind: python_call_eq
  function: randbelow
  args: [1]
  expected: 0

# ---------------------------------------------------------------------------
# SystemRandom.__mro__[3] — terminal MRO entry is 'object'
#
# secrets_extra5 covers mro[0] ('SystemRandom') and mro[1] ('Random').
# secrets_extra6 verifies len(__mro__) == 1 for __bases__ (not __mro__).
# No prior spec checks mro[3].__name__ == 'object', the terminal MRO entry.
# ---------------------------------------------------------------------------

invariant secrets_extra7.SystemRandom.mro_last:
  description: "secrets.SystemRandom.__mro__[3].__name__ == 'object' — terminal MRO entry is object"
  category: SystemRandom
  kind: python_call_eq
  function: SystemRandom.__mro__.__getitem__
  args: [3]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# choice — single-element list with a string
#
# Prior specs cover choice([99]), choice([42]), choice([7]), choice([0]).
# Not yet covered: choice(['x']) == 'x' — single-element string list.
# ---------------------------------------------------------------------------

invariant secrets_extra7.choice.single_string:
  description: "secrets.choice(['x']) == 'x' — single-element string list always returns that element"
  category: choice
  kind: python_call_eq
  function: choice
  args: [["x"]]
  expected: "x"
