spec: hl3001
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib: Secure hashes and message digests"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (hl3001): __getitem__, __setitem__, __delitem__ dict-presence checks for hashlib types."
    - "hashlib hash classes are cryptographic digest objects, not mappings or sequences — none define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "Verified types: type(hashlib.md5()), type(hashlib.sha256()), hashlib.blake2b, hashlib.blake2s."
    - "type(hashlib.md5()) and type(hashlib.sha256()) both yield the C-level HASH type from _hashlib."
    - "hashlib.blake2b and hashlib.blake2s are C extension types exposed directly from _blake2."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3001.getitem:
  description: "hashlib types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3001
  columns: [id, function, args, expected]
  rows:
    - ["hl3001001", operator.contains, [type(hashlib.md5()).__dict__,     "__getitem__"], false]
    - ["hl3001002", operator.contains, [type(hashlib.sha256()).__dict__,  "__getitem__"], false]
    - ["hl3001003", operator.contains, [hashlib.blake2b.__dict__,         "__getitem__"], false]
    - ["hl3001004", operator.contains, [hashlib.blake2s.__dict__,         "__getitem__"], false]

