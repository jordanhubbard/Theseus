spec: decimal_extra2521
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 2521 theme: __bool__, __index__, __int__ dict-presence in decimal classes."
    - "decimal.Decimal DOES define __bool__ and __int__ in its own __dict__ — it is a full numeric type."
    - "decimal.Decimal does NOT define __index__ — Decimal values cannot be used directly as sequence indices because they support non-integer values and NaN/Infinity."
    - "decimal.Decimal also defines __float__ and __complex__ — it is a full numeric tower participant."
    - "decimal.Decimal defines all standard numeric unary operators: __abs__, __neg__, __pos__, __ceil__, __floor__, __round__, __trunc__."
    - "decimal.Context does NOT define __bool__, __int__, or __index__ — Context is a configuration object, not a numeric value."
    - "decimal.DecimalException does NOT define __bool__, __int__, or __index__ — it is an exception class."
    - "Decimal.__bool__ returns False for zero (Decimal('0'), Decimal('0.0'), Decimal('-0')) and True for all nonzero finite values; raises InvalidOperation for NaN."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __bool__ dict-presence — Decimal defines it; Context and DecimalException do not
# ---------------------------------------------------------------------------

table decimal_extra2521.bool_protocol:
  description: "__bool__ is present in decimal.Decimal.__dict__ (numeric type) but absent from Context and DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2521

  columns: [id, function, args, expected]
  rows:
    - ["dc2521001", "decimal.Decimal.__dict__.__contains__",          ["__bool__"], true]
    - ["dc2521002", "decimal.Context.__dict__.__contains__",          ["__bool__"], false]
    - ["dc2521003", "decimal.DecimalException.__dict__.__contains__", ["__bool__"], false]

# ---------------------------------------------------------------------------
# __int__ dict-presence — Decimal defines it; Context and DecimalException do not
# ---------------------------------------------------------------------------

table decimal_extra2521.int_protocol:
  description: "__int__ is present in decimal.Decimal.__dict__ (numeric coercion) but absent from Context and DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2521

  columns: [id, function, args, expected]
  rows:
    - ["dc2521004", "decimal.Decimal.__dict__.__contains__",          ["__int__"], true]
    - ["dc2521005", "decimal.Context.__dict__.__contains__",          ["__int__"], false]
    - ["dc2521006", "decimal.DecimalException.__dict__.__contains__", ["__int__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — absent from ALL decimal classes
# Decimal supports non-integer values and NaN/Infinity, so __index__ is not defined
# ---------------------------------------------------------------------------

table decimal_extra2521.index_protocol:
  description: "__index__ is absent from all decimal class __dict__s — Decimal cannot be safely used as a sequence index"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2521

  columns: [id, function, args, expected]
  rows:
    - ["dc2521007", "decimal.Decimal.__dict__.__contains__",          ["__index__"], false]
    - ["dc2521008", "decimal.Context.__dict__.__contains__",          ["__index__"], false]
    - ["dc2521009", "decimal.DecimalException.__dict__.__contains__", ["__index__"], false]

# ---------------------------------------------------------------------------
# Full numeric tower — __float__ and __complex__ also defined on Decimal
# ---------------------------------------------------------------------------

table decimal_extra2521.numeric_coercion_protocol:
  description: "decimal.Decimal defines the full numeric coercion set: __float__ and __complex__ are also present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2521

  columns: [id, function, args, expected]
  rows:
    - ["dc2521010", "decimal.Decimal.__dict__.__contains__", ["__float__"],   true]
    - ["dc2521011", "decimal.Decimal.__dict__.__contains__", ["__complex__"], true]

# ---------------------------------------------------------------------------
# Unary arithmetic operators — all standard unary ops defined on Decimal
# ---------------------------------------------------------------------------

table decimal_extra2521.unary_arithmetic:
