    - ["dc2521012", "decimal.Decimal.__dict__.__contains__", ["__abs__"],   true]
    - ["dc2521013", "decimal.Decimal.__dict__.__contains__", ["__neg__"],   true]
    - ["dc2521014", "decimal.Decimal.__dict__.__contains__", ["__pos__"],   true]
