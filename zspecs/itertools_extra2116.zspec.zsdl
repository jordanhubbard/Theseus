    - ["it2116044", "itertools.accumulate.__dict__.__contains__", ["__rxor__"], false]
    - ["it2116045", "itertools.accumulate.__dict__.__contains__", ["__ixor__"], false]
    - ["it2116046", "itertools.takewhile.__dict__.__contains__", ["__xor__"], false]
    - ["it2116047", "itertools.takewhile.__dict__.__contains__", ["__rxor__"], false]
    - ["it2116048", "itertools.takewhile.__dict__.__contains__", ["__ixor__"], false]
