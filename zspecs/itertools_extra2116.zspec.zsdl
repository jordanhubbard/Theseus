spec: itertools_extra2116
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2116 (_extra2116): __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks for itertools types."
    - "Theme: set/dict merge operators (union, intersection, symmetric-difference) — NOT numeric bitwise ops."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All itertools iterator types (chain, cycle, count, zip_longest, product, combinations, permutations, islice, repeat, starmap, compress, dropwhile, filterfalse, groupby, accumulate, takewhile, pairwise) are lazy sequence producers — none implement set or dict semantics."
    - "None of the 17 itertools iterator classes define any of the nine merge/set/xor operators in their own __dict__."
    - "These are C extension types; their __dict__ is a mappingproxy containing only the slots and methods explicitly defined for each iterator's iteration protocol."
    - "The absence of __or__/__and__/__xor__ family is expected: itertools types produce streams of values, not sets or mappings that can be unioned, intersected, or diffed."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __or__ / __ror__ / __ior__ dict-presence (dict-merge / set-union)
#
# Checks chain, cycle, count, zip_longest, product, combinations — all False.
# None of these iterator types implement the set-union / dict-merge protocol.
# ---------------------------------------------------------------------------

table itertools_extra2116.or_operator:
  description: "itertools types __or__/__ror__/__ior__ dict-presence checks — all False (no dict-merge/set-union protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2116

  columns: [id, function, args, expected]
  rows:
    - ["it2116001", "itertools.chain.__dict__.__contains__", ["__or__"], false]
    - ["it2116002", "itertools.chain.__dict__.__contains__", ["__ror__"], false]
    - ["it2116003", "itertools.chain.__dict__.__contains__", ["__ior__"], false]
    - ["it2116004", "itertools.cycle.__dict__.__contains__", ["__or__"], false]
    - ["it2116005", "itertools.cycle.__dict__.__contains__", ["__ror__"], false]
    - ["it2116006", "itertools.cycle.__dict__.__contains__", ["__ior__"], false]
    - ["it2116007", "itertools.count.__dict__.__contains__", ["__or__"], false]
    - ["it2116008", "itertools.count.__dict__.__contains__", ["__ror__"], false]
    - ["it2116009", "itertools.count.__dict__.__contains__", ["__ior__"], false]
    - ["it2116010", "itertools.zip_longest.__dict__.__contains__", ["__or__"], false]
    - ["it2116011", "itertools.zip_longest.__dict__.__contains__", ["__ror__"], false]
    - ["it2116012", "itertools.zip_longest.__dict__.__contains__", ["__ior__"], false]
    - ["it2116013", "itertools.product.__dict__.__contains__", ["__or__"], false]
    - ["it2116014", "itertools.product.__dict__.__contains__", ["__ror__"], false]
    - ["it2116015", "itertools.product.__dict__.__contains__", ["__ior__"], false]
    - ["it2116016", "itertools.combinations.__dict__.__contains__", ["__or__"], false]
    - ["it2116017", "itertools.combinations.__dict__.__contains__", ["__ror__"], false]
    - ["it2116018", "itertools.combinations.__dict__.__contains__", ["__ior__"], false]
    - ["it2116019", "itertools.permutations.__dict__.__contains__", ["__or__"], false]
    - ["it2116020", "itertools.permutations.__dict__.__contains__", ["__ror__"], false]
    - ["it2116021", "itertools.permutations.__dict__.__contains__", ["__ior__"], false]

