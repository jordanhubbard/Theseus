    - ["it2116051", "itertools.pairwise.__dict__.__contains__", ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 4: cross-operator checks for remaining itertools types
#
# Spot-checks all nine operators on chain, repeat, pairwise, and accumulate
# to confirm the uniform absence of the merge operator protocol.
# ---------------------------------------------------------------------------

table itertools_extra2116.inplace_operators:
  description: "itertools cross-type all-operator dict-presence checks — all False (no merge/set protocol on any itertools type)"
