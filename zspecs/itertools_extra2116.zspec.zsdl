# ---------------------------------------------------------------------------
# Table 3: __xor__ / __rxor__ / __ixor__ dict-presence (set-symmetric-difference)
#
# Checks groupby, accumulate, takewhile, pairwise — all False.
# No itertools type implements symmetric-difference semantics.
# ---------------------------------------------------------------------------

table itertools_extra2116.xor_operator:
  description: "itertools types __xor__/__rxor__/__ixor__ dict-presence checks — all False (no set-symmetric-difference protocol)"
  kind: python_call_eq
