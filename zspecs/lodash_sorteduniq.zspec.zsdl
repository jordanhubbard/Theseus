spec: lodash_sorteduniq
version: ">=4.0.0"
backend: node(lodash.sorteduniq)

docs: https://lodash.com/docs/#sortedUniq

provenance:
  derived_from:
    - "lodash.sorteduniq README — https://www.npmjs.com/package/lodash.sorteduniq"
    - "Test vectors verified with lodash.sorteduniq@4.5.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.sorteduniq exports the _.sortedUniq function directly as module.exports."
    - "sortedUniq(array) removes consecutive duplicates from a sorted array."
    - "More efficient than _.uniq for sorted arrays since it assumes order."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array with consecutive duplicates removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_sorteduniq.sorteduniq:
  kind: node_module_call_eq
  function: ~
  category: sorteduniq
  id_prefix: lsu

  columns: [id, args, expected]
  rows:
    - [dups,     [[1, 1, 2, 2, 3]],    [1, 2, 3]]
    - [no_dups,  [[1, 2, 3]],          [1, 2, 3]]
    - [strings,  [["a", "a", "b"]],    ["a", "b"]]
