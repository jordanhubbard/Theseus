spec: urllib_parse_extra_rust
version: ">=3.9"
backend: rust_module(urllib_parse_extra_rust)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse documentation"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
  notes:
    - "Additional urllib.parse functions not covered in urllib_parse_rust."
    - "urlencode({'q': 'hello world'}) == 'q=hello+world'."
    - "urlencode({'a': '1', 'b': '2'}) == 'a=1&b=2'."
    - "parse_qs('a=1&b=2') == {'a': ['1'], 'b': ['2']}."
    - "parse_qs('q=hello+world') == {'q': ['hello world']}."
    - "parse_qs('x=1&x=2') == {'x': ['1', '2']} — multiple values for same key."
    - "All test vectors verified against Python 3.14.3 urllib.parse module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# urlencode — encode dict as URL query string
table urllib_parse_extra_rust.urlencode.vectors:
  kind: python_call_eq
  category: urlencode
  id_prefix: up_enc
  function: urlencode

  columns: [id, args, expected]
  rows:
    - [space_to_plus, [{q: "hello world"}],     "q=hello+world"]
    - [single_kv,     [{n: "42"}],              "n=42"]
    - [two_kv,        [{a: "1", b: "2"}],       "a=1&b=2"]
    - [special_chars, [{v: "foo&bar"}],         "v=foo%26bar"]

# parse_qs — parse URL query string into dict of lists
table urllib_parse_extra_rust.parse_qs.vectors:
  kind: python_call_eq
  category: parse_qs
  id_prefix: up_pqs
  function: parse_qs

  columns: [id, args, expected]
  rows:
    - [two_params,     ["a=1&b=2"],        {a: ["1"], b: ["2"]}]
    - [plus_encoded,   ["q=hello+world"],  {q: ["hello world"]}]
    - [single,         ["n=42"],           {n: ["42"]}]
    - [multi_value,    ["x=1&x=2"],        {x: ["1", "2"]}]

