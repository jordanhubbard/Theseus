spec: inspect_extra1456
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra1441.zspec.zsdl — covers __subclasshook__, __instancecheck__, __subclasscheck__ ABC-machinery checks"
    - "inspect_extra1426.zspec.zsdl — covers __format__ and __dir__ checks for inspect classes"
  notes:
    - "Wave 544 (_extra1456): focuses on __contains__ and __iter__ container/iterable protocol method presence checks for inspect classes."
    - "inspect.Parameter does not define '__contains__' in its own __dict__ — Parameter is a value-object, not a container. Verified Python 3.14.4."
    - "inspect.Signature does not define '__contains__' in its own __dict__ — Signature is a value-object wrapping an ordered mapping of parameters; it does not directly expose __contains__. Verified Python 3.14.4."
    - "inspect.BoundArguments does not define '__contains__' in its own __dict__ — BoundArguments is a result object, not a container. Verified Python 3.14.4."
    - "inspect.Parameter does not define '__iter__' in its own __dict__ — Parameter is not iterable as a class. Verified Python 3.14.4."
    - "inspect.Signature does not define '__iter__' in its own __dict__ — Signature iteration is not exposed as __iter__ on the class itself. Verified Python 3.14.4."
    - "inspect.BoundArguments does not define '__iter__' in its own __dict__ — BoundArguments is not directly iterable. Verified Python 3.14.4."
    - "None of Parameter, Signature, BoundArguments define '__next__' in their own __dict__ — none implement the iterator protocol. Verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect class __contains__ dict absence
#
# Wave 544 theme: '__contains__' not in own __dict__ for inspect classes.
# Parameter, Signature, and BoundArguments are all value-objects or result
# objects — none implement the container protocol.
# ---------------------------------------------------------------------------

table inspect_extra1456.contains_dict_membership:
  description: "inspect classes: '__contains__' not in own __dict__ for Parameter, Signature, BoundArguments; wave 544; new to extra1456"
  kind: python_call_eq
  category: contains_dict_membership
  id_prefix: in1456cd

  columns: [id, function, args, expected, description]
  rows:
    - [in1456cd001,
       "Parameter.__dict__.__contains__",
       ["__contains__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__contains__') == False — Parameter is a value-object, not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [in1456cd002,
       "Signature.__dict__.__contains__",
       ["__contains__"],
       false,
       "inspect.Signature.__dict__.__contains__('__contains__') == False — Signature is a value-object wrapping an ordered param mapping; no __contains__ in own class __dict__; new to extra1456"]
    - [in1456cd003,
       "BoundArguments.__dict__.__contains__",
       ["__contains__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__contains__') == False — BoundArguments is a result object, not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [in1456cd004,
       "Parameter.__dict__.__contains__",
       ["__iter__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__iter__') == False — Parameter is not iterable; no __iter__ in own class __dict__; new to extra1456"]
    - [in1456cd005,
       "Signature.__dict__.__contains__",
       ["__iter__"],
       false,
       "inspect.Signature.__dict__.__contains__('__iter__') == False — Signature does not expose __iter__ on the class; no __iter__ in own class __dict__; new to extra1456"]
    - [in1456cd006,
       "BoundArguments.__dict__.__contains__",
       ["__iter__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__iter__') == False — BoundArguments is not directly iterable; no __iter__ in own class __dict__; new to extra1456"]
    - [in1456cd007,
       "Parameter.__dict__.__contains__",
       ["__next__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__next__') == False — Parameter does not implement the iterator protocol; no __next__ in own class __dict__; new to extra1456"]
    - [in1456cd008,
       "Signature.__dict__.__contains__",
       ["__next__"],
       false,
       "inspect.Signature.__dict__.__contains__('__next__') == False — Signature does not implement the iterator protocol; no __next__ in own class __dict__; new to extra1456"]

# ---------------------------------------------------------------------------
# Table 2: inspect class __next__ dict absence
#
# Wave 544 theme: '__next__' not in own __dict__ for inspect classes.
# None of Parameter, Signature, BoundArguments define __next__ — they are
# value-objects and result-objects, not iterators.
# ---------------------------------------------------------------------------

table inspect_extra1456.next_dict_membership:
  description: "inspect classes: '__next__' not in own __dict__ for Parameter, Signature, BoundArguments; wave 544; new to extra1456"
  kind: python_call_eq
  category: next_dict_membership
  id_prefix: in1456nd

  columns: [id, function, args, expected, description]
  rows:
    - [in1456nd001,
       "Parameter.__dict__.__contains__",
       ["__next__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__next__') == False — Parameter does not implement the iterator protocol; no __next__ in own class __dict__; new to extra1456"]
    - [in1456nd002,
       "Signature.__dict__.__contains__",
       ["__next__"],
       false,
       "inspect.Signature.__dict__.__contains__('__next__') == False — Signature does not implement the iterator protocol; no __next__ in own class __dict__; new to extra1456"]
    - [in1456nd003,
       "BoundArguments.__dict__.__contains__",
       ["__next__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__next__') == False — BoundArguments does not implement the iterator protocol; no __next__ in own class __dict__; new to extra1456"]
    - [in1456nd004,
       "Parameter.__dict__.__contains__",
       ["__contains__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__contains__') == False — cross-check: container protocol absent from Parameter; new to extra1456"]
    - [in1456nd005,
       "Signature.__dict__.__contains__",
       ["__contains__"],
       false,
       "inspect.Signature.__dict__.__contains__('__contains__') == False — cross-check: container protocol absent from Signature; new to extra1456"]
    - [in1456nd006,
       "BoundArguments.__dict__.__contains__",
       ["__contains__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__contains__') == False — cross-check: container protocol absent from BoundArguments; new to extra1456"]
    - [in1456nd007,
       "Parameter.__dict__.__contains__",
       ["__iter__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__iter__') == False — cross-check: iterable protocol absent from Parameter; new to extra1456"]
    - [in1456nd008,
       "BoundArguments.__dict__.__contains__",
       ["__iter__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__iter__') == False — cross-check: iterable protocol absent from BoundArguments; new to extra1456"]

# ---------------------------------------------------------------------------
# Table 3: inspect class combined container/iterator protocol absence
#
# Wave 544 theme: combined absence of '__contains__', '__iter__', and '__next__'
# for all three inspect classes in a single table. None of these classes
# implement either the container protocol or the iterator protocol.
# ---------------------------------------------------------------------------

table inspect_extra1456.container_iterator_protocol_absence:
  description: "inspect classes: combined absence of '__contains__', '__iter__', '__next__' in own __dict__ for Parameter, Signature, BoundArguments; wave 544; new to extra1456"
  kind: python_call_eq
  category: container_iterator_protocol_absence
  id_prefix: in1456ci

  columns: [id, function, args, expected, description]
  rows:
    - [in1456ci001,
       "Parameter.__dict__.__contains__",
       ["__contains__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__contains__') == False — Parameter: container protocol absent; combined check; new to extra1456"]
    - [in1456ci002,
       "Parameter.__dict__.__contains__",
       ["__iter__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__iter__') == False — Parameter: iterable protocol absent; combined check; new to extra1456"]
    - [in1456ci003,
       "Parameter.__dict__.__contains__",
       ["__next__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__next__') == False — Parameter: iterator protocol absent; combined check; new to extra1456"]
    - [in1456ci004,
       "Signature.__dict__.__contains__",
       ["__contains__"],
       false,
       "inspect.Signature.__dict__.__contains__('__contains__') == False — Signature: container protocol absent; combined check; new to extra1456"]
    - [in1456ci005,
       "Signature.__dict__.__contains__",
       ["__iter__"],
       false,
       "inspect.Signature.__dict__.__contains__('__iter__') == False — Signature: iterable protocol absent; combined check; new to extra1456"]
    - [in1456ci006,
       "Signature.__dict__.__contains__",
       ["__next__"],
       false,
       "inspect.Signature.__dict__.__contains__('__next__') == False — Signature: iterator protocol absent; combined check; new to extra1456"]
    - [in1456ci007,
       "BoundArguments.__dict__.__contains__",
       ["__contains__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__contains__') == False — BoundArguments: container protocol absent; combined check; new to extra1456"]
    - [in1456ci008,
       "BoundArguments.__dict__.__contains__",
       ["__iter__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__iter__') == False — BoundArguments: iterable protocol absent; combined check; new to extra1456"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1456
# ---------------------------------------------------------------------------

invariant inspect_extra1456.Parameter_contains_not_in_dict:
  description: "'__contains__' not in inspect.Parameter.__dict__ — Parameter does not define the container protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__contains__"]
  expected: false

invariant inspect_extra1456.Parameter_iter_not_in_dict:
  description: "'__iter__' not in inspect.Parameter.__dict__ — Parameter does not define the iterable protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__iter__"]
  expected: false

invariant inspect_extra1456.Signature_contains_not_in_dict:
  description: "'__contains__' not in inspect.Signature.__dict__ — Signature does not define the container protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__contains__"]
  expected: false

invariant inspect_extra1456.BoundArguments_next_not_in_dict:
  description: "'__next__' not in inspect.BoundArguments.__dict__ — BoundArguments does not implement the iterator protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__next__"]
  expected: false
