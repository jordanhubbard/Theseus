spec: uuid_extra1801
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID constructor, str(), int, bytes attributes"
    - "uuid_extra1786.zspec.zsdl — covers __class_getitem__/__init_subclass__ hooks; UUID __slots__, hex, urn, variant, time, fields, is_safe, int, bytes, bytes_le, node, version; SafeUUID base class"
    - "uuid_extra1771.zspec.zsdl — covers async protocol dict-presence checks for uuid.UUID"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value protocol; container and context manager protocol presence."
    - "Theme: which uuid types define __bool__/__len__ and context-manager/container protocol methods in their own __dict__."
    - "uuid.UUID.__dict__.__contains__('__bool__') -> False — UUID does not define custom truth-value; bool(uuid) defers to object's __bool__ which returns True for all objects."
    - "uuid.UUID.__dict__.__contains__('__len__') -> False — UUID is not a sized container; there is no meaningful len(uuid)."
    - "uuid.SafeUUID.__dict__.__contains__('__bool__') -> False — SafeUUID is an IntEnum; truthiness is handled by int, not a custom __bool__ in SafeUUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('__enter__') -> False — UUID is not a context manager."
    - "uuid.UUID.__dict__.__contains__('__exit__') -> False — UUID is not a context manager."
    - "uuid.UUID.__dict__.__contains__('__iter__') -> False — UUID is not iterable."
    - "uuid.UUID.__dict__.__contains__('__contains__') -> False — UUID does not support 'in' operator."
    - "uuid.UUID.__dict__.__contains__('__getitem__') -> False — UUID does not support subscript access."
    - "uuid.UUID.__dict__.__contains__('__index__') -> False — UUID is not an integer type; __index__ is absent."
    - "uuid.UUID.__dict__.__contains__('__int__') -> True — UUID defines __int__ to return its 128-bit integer value."
    - "uuid.UUID.__dict__.__contains__('__format__') -> True — UUID defines __format__ for custom string formatting."
    - "uuid.UUID.__dict__.__contains__('__str__') -> True — UUID defines __str__ to return the canonical hyphenated string."
    - "uuid.UUID.__dict__.__contains__('__repr__') -> True — UUID defines __repr__."
    - "uuid.UUID.__dict__.__contains__('__eq__') -> True — UUID defines __eq__ for value comparison."
    - "uuid.UUID.__dict__.__contains__('__hash__') -> True — UUID defines __hash__ consistent with __eq__."
    - "uuid.UUID.__dict__.__contains__('__lt__') -> True — UUID defines __lt__ for ordering."
    - "uuid.UUID.__dict__.__contains__('__gt__') -> False — UUID only defines __lt__; __gt__ is reflected from __lt__."
    - "uuid.UUID.__dict__.__contains__('__le__') -> False — UUID does not define __le__."
    - "uuid.UUID.__dict__.__contains__('__ge__') -> False — UUID does not define __ge__."
    - "uuid.UUID.__dict__.__contains__('__ne__') -> False — Python 3 derives __ne__ from __eq__ via object; UUID does not redefine it."
    - "All expected values verified by running Python 3.14 uuid module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra1801.truth_protocol:
  description: "uuid.UUID and uuid.SafeUUID __bool__/__len__ dict-presence checks — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1801

  columns: [id, function, args, expected]
  rows:
    - ["uu1801001", "uuid.UUID.__dict__.__contains__",     ["__bool__"], false]
    - ["uu1801002", "uuid.UUID.__dict__.__contains__",     ["__len__"],  false]
    - ["uu1801003", "uuid.SafeUUID.__dict__.__contains__", ["__bool__"], false]
    - ["uu1801004", "uuid.SafeUUID.__dict__.__contains__", ["__len__"],  false]

table uuid_extra1801.context_manager_protocol:
  description: "uuid.UUID context manager and container protocol dict-presence checks — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1801

  columns: [id, function, args, expected]
  rows:
    - ["uu1801005", "uuid.UUID.__dict__.__contains__", ["__enter__"],    false]
    - ["uu1801006", "uuid.UUID.__dict__.__contains__", ["__exit__"],     false]
    - ["uu1801007", "uuid.UUID.__dict__.__contains__", ["__iter__"],     false]
    - ["uu1801008", "uuid.UUID.__dict__.__contains__", ["__contains__"], false]
    - ["uu1801009", "uuid.UUID.__dict__.__contains__", ["__getitem__"],  false]
    - ["uu1801010", "uuid.UUID.__dict__.__contains__", ["__index__"],    false]
    - ["uu1801011", "uuid.UUID.__dict__.__contains__", ["__int__"],      true]
    - ["uu1801012", "uuid.UUID.__dict__.__contains__", ["__format__"],   true]

table uuid_extra1801.uuid_numeric_attrs:
  description: "uuid.UUID numeric and comparison protocol dict-presence checks — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1801

  columns: [id, function, args, expected]
  rows:
    - ["uu1801013", "uuid.UUID.__dict__.__contains__", ["__int__"],  true]
    - ["uu1801014", "uuid.UUID.__dict__.__contains__", ["__str__"],  true]
    - ["uu1801015", "uuid.UUID.__dict__.__contains__", ["__repr__"], true]
    - ["uu1801016", "uuid.UUID.__dict__.__contains__", ["__eq__"],   true]
    - ["uu1801017", "uuid.UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu1801018", "uuid.UUID.__dict__.__contains__", ["__lt__"],   true]
    - ["uu1801019", "uuid.UUID.__dict__.__contains__", ["__gt__"],   false]
    - ["uu1801020", "uuid.UUID.__dict__.__contains__", ["__le__"],   false]
    - ["uu1801021", "uuid.UUID.__dict__.__contains__", ["__ge__"],   false]
    - ["uu1801022", "uuid.UUID.__dict__.__contains__", ["__ne__"],   false]
