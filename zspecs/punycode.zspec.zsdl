spec: punycode
version: ">=2.0.0"
backend: node(punycode)

docs: https://www.npmjs.com/package/punycode

provenance:
  derived_from:
    - "punycode README — https://www.npmjs.com/package/punycode"
    - "Test vectors verified with punycode via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "punycode source"
  notes:
    - "punycode is an npm package. Install: npm install punycode"
    - "toASCII(domain) converts an internationalized domain to its ASCII-compatible encoding (ACE)."
    - "toUnicode(domain) converts an ACE domain back to Unicode."
    - "encode(label) / decode(label) operate on a single domain label (no dots)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns converted string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table punycode.toASCII:
  kind: node_module_call_eq
  function: toASCII
  category: toASCII
  id_prefix: pnasc

  columns: [id, args, expected]
  rows:
    - [ascii,   ["example.com"],   "example.com"]
    - [manana,  ["mañana.com"],    "xn--maana-pta.com"]
    - [munchen, ["münchen.de"],    "xn--mnchen-3ya.de"]

table punycode.toUnicode:
  kind: node_module_call_eq
  function: toUnicode
  category: toUnicode
  id_prefix: pnuni

  columns: [id, args, expected]
  rows:
    - [ascii,   ["example.com"],          "example.com"]
    - [manana,  ["xn--maana-pta.com"],    "mañana.com"]
    - [munchen, ["xn--mnchen-3ya.de"],    "münchen.de"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:06:47Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
