spec: sysconfig_extra
version: ">=3.2"
backend: python_module(sysconfig)

docs: https://docs.python.org/3/library/sysconfig.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sysconfig.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sysconfig.py"
  notes:
    - "This spec extends sysconfig.zspec.zsdl with additional function name and return-type checks."
    - "get_python_version() returns a string like '3.12' (MAJOR.MINOR only, no patch component)."
    - "get_platform() returns a string like 'macosx-14.0-arm64' identifying the build platform."
    - "get_scheme_names() returns a tuple of installation scheme name strings (e.g. 'posix_prefix')."
    - "get_path_names() returns a tuple of path category name strings (e.g. 'stdlib', 'platlib', 'purelib')."
    - "get_config_var(key) returns the value for a single Makefile variable, or None if not defined."
    - "get_config_vars() returns a dict mapping all known Makefile variable names to their values."
    - "get_path(name) returns the installation path for the named category as a string."
    - "get_paths() returns a dict mapping all path category names to their resolved paths."
    - "is_python_build() returns True if running from a CPython build tree, False in a normal install."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table sysconfig_extra.func_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [get_python_version, "get_python_version.__name__.__eq__", ["get_python_version"], true]
    - [get_platform,       "get_platform.__name__.__eq__",       ["get_platform"],       true]
    - [get_config_var,     "get_config_var.__name__.__eq__",     ["get_config_var"],     true]
    - [get_config_vars,    "get_config_vars.__name__.__eq__",    ["get_config_vars"],    true]
    - [get_path,           "get_path.__name__.__eq__",           ["get_path"],           true]
    - [get_paths,          "get_paths.__name__.__eq__",          ["get_paths"],          true]
    - [get_scheme_names,   "get_scheme_names.__name__.__eq__",   ["get_scheme_names"],   true]
    - [get_path_names,     "get_path_names.__name__.__eq__",     ["get_path_names"],     true]
    - [is_python_build,    "is_python_build.__name__.__eq__",    ["is_python_build"],    true]

# ---------------------------------------------------------------------------
# Return-type checks — verify each function returns the documented type
# ---------------------------------------------------------------------------

invariant sysconfig_extra.get_python_version.returns_str:
  description: "sysconfig.get_python_version().__class__.__name__ == 'str' — returns version string like '3.12'"
  category: runtime
  kind: python_call_eq
  function: get_python_version
  args: []
  method: __class__
  method_chain: __name__
  expected: "str"

invariant sysconfig_extra.get_platform.returns_str:
  description: "sysconfig.get_platform().__class__.__name__ == 'str' — returns platform identifier string"
  category: runtime
  kind: python_call_eq
  function: get_platform
  args: []
  method: __class__
  method_chain: __name__
  expected: "str"

invariant sysconfig_extra.get_scheme_names.returns_tuple:
  description: "sysconfig.get_scheme_names().__class__.__name__ == 'tuple' — returns tuple of scheme name strings"
  category: runtime
  kind: python_call_eq
  function: get_scheme_names
  args: []
  method: __class__
  method_chain: __name__
  expected: "tuple"

invariant sysconfig_extra.get_path_names.returns_tuple:
  description: "sysconfig.get_path_names().__class__.__name__ == 'tuple' — returns tuple of path category strings"
  category: runtime
  kind: python_call_eq
  function: get_path_names
  args: []
  method: __class__
  method_chain: __name__
  expected: "tuple"
