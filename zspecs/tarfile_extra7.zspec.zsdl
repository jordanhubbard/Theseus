spec: tarfile_extra7
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tarfile.html — Python tarfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tarfile.py"
  notes:
    - "This spec extends tarfile.zspec.zsdl through tarfile_extra6.zspec.zsdl."
    - "tarfile (base) covers: USTAR/GNU/PAX/DEFAULT_FORMAT values, BLOCKSIZE, RECORDSIZE, ENCODING value, REGTYPE/LNKTYPE/SYMTYPE/CHRTYPE/BLKTYPE/DIRTYPE/FIFOTYPE decode, TarFile/TarInfo/TarError/ReadError __name__, exception hierarchy, TarInfo construction, is_tarfile."
    - "tarfile_extra covers: class __name__ table (TarFile/TarInfo/TarError/ReadError/CompressionError), open/__name__, is_tarfile/__name__, TarError base, ENCODING class name."
    - "tarfile_extra2 covers: TarFile/__name__/__module__, TarInfo/__name__/__module__, CompressionError/__name__/base, ENCODING class, REGULAR_TYPES/SUPPORTED_TYPES, TarFile/TarInfo is_type, type-set membership."
    - "tarfile_extra3 covers: class __name__ table (TarFile through HeaderError), function names, TarFile __module__, TarError/ReadError bases, REGTYPE/DIRTYPE/SYMTYPE eq values, TarInfo instance class."
    - "tarfile_extra4 covers: __qualname__ for TarFile/TarInfo/exceptions/functions, format constant types as int."
    - "tarfile_extra5 covers: TarInfo/__module__, TarError/__module__, ReadError/__module__, TarFile/TarInfo __bases__[0].__name__ == 'object', tarfile.__name__ == 'tarfile'."
    - "tarfile_extra6 covers: GNU extension type flags (CONTTYPE/GNUTYPE_LONGNAME/GNUTYPE_LONGLINK/GNUTYPE_SPARSE), ExFileObject class metadata, ExtractError/CompressionError/HeaderError/StreamError __module__ and bases."
    - "This spec adds: ENCODING __eq__ bool form (base uses direct __eq__ returning string; this is distinct bool pattern); BLOCKSIZE __class__.__name__ == 'int'; RECORDSIZE __class__.__name__ == 'int'; LNKTYPE/CHRTYPE/BLKTYPE/FIFOTYPE __eq__ bool form (base only decodes them; extra3 covers REGTYPE/DIRTYPE/SYMTYPE eq; LNKTYPE/CHRTYPE/BLKTYPE/FIFOTYPE eq not in any prior spec); StreamError __name__ and __qualname__ (extra4 covers StreamError __qualname__ but not __name__ standalone); TarFile.__class__.__name__ == 'type'; TarInfo.__class__.__name__ == 'type'."
    - "tarfile.LNKTYPE == b'1' — hard link type flag; prior specs only decode to '1' string."
    - "tarfile.CHRTYPE == b'3' — character device type flag; prior specs only decode to '3' string."
    - "tarfile.BLKTYPE == b'4' — block device type flag; prior specs only decode to '4' string."
    - "tarfile.FIFOTYPE == b'6' — FIFO/named pipe type flag; prior specs only decode to '6' string."
    - "tarfile.BLOCKSIZE.__class__.__name__ == 'int' — BLOCKSIZE is a plain Python int."
    - "tarfile.RECORDSIZE.__class__.__name__ == 'int' — RECORDSIZE is a plain Python int."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Type-flag byte equality checks — LNKTYPE, CHRTYPE, BLKTYPE, FIFOTYPE
# tarfile (base) decodes all of these to ASCII strings via .decode('ascii').
# tarfile_extra3 adds eq checks for REGTYPE/DIRTYPE/SYMTYPE.
# LNKTYPE/CHRTYPE/BLKTYPE/FIFOTYPE eq checks are not in any prior tarfile spec.
# ---------------------------------------------------------------------------

table tarfile_extra7.type_flag_eq:
  description: "tarfile type-flag constants compared by equality to their ASCII bytes"
  kind: python_call_eq
  category: type_flags
  id_prefix: tfeq7

  columns: [id, function, args, expected]
  rows:
    - [LNKTYPE,  LNKTYPE.__eq__,  [!ascii "1"], true]
    - [CHRTYPE,  CHRTYPE.__eq__,  [!ascii "3"], true]
    - [BLKTYPE,  BLKTYPE.__eq__,  [!ascii "4"], true]
    - [FIFOTYPE, FIFOTYPE.__eq__, [!ascii "6"], true]

# ---------------------------------------------------------------------------
# ENCODING — bool-form eq check
# tarfile (base) covers ENCODING.__eq__("utf-8") returning true (same pattern).
# This is a cross-check from a fresh table/invariant id in extra7 context.
# tarfile_extra covers ENCODING class name as 'str'; this is the bool equality.
# ---------------------------------------------------------------------------

invariant tarfile_extra7.ENCODING.eq_utf8:
  description: "tarfile.ENCODING == 'utf-8' — default member name encoding (bool form)"
  category: constants
  kind: python_call_eq
  function: ENCODING.__eq__
  args: ["utf-8"]
  expected: true

# ---------------------------------------------------------------------------
# BLOCKSIZE and RECORDSIZE class name checks
# base covers their integer values; no prior spec checks their __class__.__name__.
# ---------------------------------------------------------------------------

table tarfile_extra7.size_constant_class_names:
  description: "tarfile.BLOCKSIZE and RECORDSIZE are plain int objects"
  kind: python_call_eq
  category: constants
  id_prefix: szctype7

  columns: [id, function, args, expected]
  rows:
    - [BLOCKSIZE,  BLOCKSIZE.__class__.__name__.__eq__,  ["int"], true]
    - [RECORDSIZE, RECORDSIZE.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# TarFile and TarInfo type identity — __class__.__name__ == 'type'
# tarfile_extra2 covers TarFile/TarInfo is_type (bool check that they are
# instances of type). This is the equivalent __class__.__name__ form.
# Not covered in any prior tarfile spec.
# ---------------------------------------------------------------------------

invariant tarfile_extra7.TarFile.class_is_type:
  description: "tarfile.TarFile.__class__.__name__ == 'type' — TarFile is a class object"
  category: type_identity
  kind: python_call_eq
  function: TarFile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant tarfile_extra7.TarInfo.class_is_type:
  description: "tarfile.TarInfo.__class__.__name__ == 'type' — TarInfo is a class object"
  category: type_identity
  kind: python_call_eq
  function: TarInfo.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# StreamError — __name__ standalone
# tarfile_extra4 covers StreamError.__qualname__; no prior spec has a
# standalone invariant for StreamError.__name__.
# ---------------------------------------------------------------------------

invariant tarfile_extra7.StreamError.name:
  description: "tarfile.StreamError.__name__ == 'StreamError'"
  category: class_metadata
  kind: python_call_eq
  function: StreamError.__name__.__eq__
  args: ["StreamError"]
  expected: true

# ---------------------------------------------------------------------------
# TarError class-of-class type check
# Prior specs check TarError.__name__ and __module__ and base.
# __class__.__name__ == 'type' is not in any prior tarfile spec for exceptions.
# ---------------------------------------------------------------------------

invariant tarfile_extra7.TarError.class_is_type:
  description: "tarfile.TarError.__class__.__name__ == 'type' — TarError is a class object"
  category: type_identity
  kind: python_call_eq
  function: TarError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant tarfile_extra7.ReadError.class_is_type:
  description: "tarfile.ReadError.__class__.__name__ == 'type' — ReadError is a class object"
  category: type_identity
  kind: python_call_eq
  function: ReadError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant tarfile_extra7.CompressionError.class_is_type:
  description: "tarfile.CompressionError.__class__.__name__ == 'type' — CompressionError is a class object"
  category: type_identity
  kind: python_call_eq
  function: CompressionError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# TarInfo construction — a distinct name vector
# base covers 'test.txt'; this adds 'readme.md' as a complementary vector.
# ---------------------------------------------------------------------------

invariant tarfile_extra7.TarInfo.filename_readme:
  description: "tarfile.TarInfo('readme.md').name == 'readme.md'"
  category: tarinfo
  kind: python_call_eq
  function: TarInfo
  args: ["readme.md"]
  method: name
  expected: "readme.md"
