spec: bisect_extra2
version: ">=3.2"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "Python bisect documentation — https://docs.python.org/3/library/bisect.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec covers bisect invariants not already in bisect.zspec.zsdl or bisect_extra.zspec.zsdl."
    - "insort is an alias for insort_right; insort.__name__ == 'insort_right'."
    - "insort_left.__name__ == 'insort_left' — left-side in-place insertion."
    - "insort_right.__name__ == 'insort_right' — right-side in-place insertion."
    - "bisect is an alias for bisect_right; bisect.__name__ == 'bisect_right'."
    - "bisect_left([1,3,5,7], 4) == 2 — insertion point between index 1 (value 3) and index 2 (value 5)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# insort — function name (alias for insort_right)
# ---------------------------------------------------------------------------

invariant bisect_extra2.insort.name:
  description: "bisect.insort.__name__ == 'insort_right' — insort is an alias for insort_right"
  category: identity
  kind: python_call_eq
  function: insort.__name__.__eq__
  args: ["insort_right"]
  expected: true

# ---------------------------------------------------------------------------
# insort_left — function name
# ---------------------------------------------------------------------------

invariant bisect_extra2.insort_left.name:
  description: "bisect.insort_left.__name__ == 'insort_left'"
  category: identity
  kind: python_call_eq
  function: insort_left.__name__.__eq__
  args: ["insort_left"]
  expected: true

# ---------------------------------------------------------------------------
# insort_right — function name
# ---------------------------------------------------------------------------

invariant bisect_extra2.insort_right.name:
  description: "bisect.insort_right.__name__ == 'insort_right'"
  category: identity
  kind: python_call_eq
  function: insort_right.__name__.__eq__
  args: ["insort_right"]
  expected: true

# ---------------------------------------------------------------------------
# bisect — function name (alias for bisect_right)
# ---------------------------------------------------------------------------

invariant bisect_extra2.bisect.name:
  description: "bisect.bisect.__name__ == 'bisect_right' — bisect is an alias for bisect_right"
  category: identity
  kind: python_call_eq
  function: bisect.__name__.__eq__
  args: ["bisect_right"]
  expected: true

# ---------------------------------------------------------------------------
# bisect_left — index for gap between elements
#
# bisect_left([1,3,5,7], 4) == 2
# The value 4 falls between index 1 (value 3) and index 2 (value 5).
# ---------------------------------------------------------------------------

invariant bisect_extra2.bisect_left.gap_in_sorted:
  description: "bisect_left([1,3,5,7], 4) == 2 — insertion point between 3 and 5"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 3, 5, 7], 4]
  expected: 2
