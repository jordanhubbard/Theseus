spec: importlib_extra15
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "importlib_extra5.zspec.zsdl — covers __qualname__ for util.find_spec/util.module_from_spec/util.spec_from_file_location and abc.Loader.__qualname__."
    - "importlib_extra6.zspec.zsdl — covers util.spec_from_loader.__qualname__."
    - "importlib_extra8.zspec.zsdl — covers util.resolve_name.__qualname__; util.cache_from_source __name__/__module__."
    - "importlib_extra9.zspec.zsdl — covers abc.MetaPathFinder.__qualname__; abc.PathEntryFinder.__name__/__module__."
    - "importlib_extra14.zspec.zsdl — covers util.cache_from_source/__qualname__ and util.source_from_cache/__qualname__."
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra14.zspec.zsdl."
    - "Focus: __class__.__name__ and __class__.__qualname__ for importlib.abc abstract base classes (Loader, MetaPathFinder, PathEntryFinder) — none covered in any prior importlib spec."
    - "All three classes are created by ABCMeta, so their __class__.__name__ and __class__.__qualname__ are both 'ABCMeta'."
    - "importlib.abc.Loader.__class__.__name__ == 'ABCMeta' — Loader is an abstract base class created via ABCMeta; verified at runtime."
    - "importlib.abc.MetaPathFinder.__class__.__name__ == 'ABCMeta' — MetaPathFinder is an abstract base class; verified at runtime."
    - "importlib.abc.PathEntryFinder.__class__.__name__ == 'ABCMeta' — PathEntryFinder is an abstract base class; verified at runtime."
    - "importlib.abc.Loader.__class__.__qualname__ == 'ABCMeta' — qualname of the metaclass type; verified at runtime."
    - "importlib.abc.MetaPathFinder.__class__.__qualname__ == 'ABCMeta' — qualname of the metaclass type; verified at runtime."
    - "importlib.abc.PathEntryFinder.__class__.__qualname__ == 'ABCMeta' — qualname of the metaclass type; verified at runtime."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib.abc class metaclass — __class__.__name__ table
#
# All three importlib.abc abstract base classes (Loader, MetaPathFinder,
# PathEntryFinder) are instances of ABCMeta. No prior importlib spec checks
# __class__.__name__ for any of these three classes. This table covers all
# three in a compact cross-reference in the extra15 namespace.
# ---------------------------------------------------------------------------

table importlib_extra15.abc_class_names:
  description: "__class__.__name__ for importlib.abc abstract base classes is 'ABCMeta'"
  kind: python_call_eq
  category: type_attrs
  id_prefix: cname15

  columns: [id, function, args, expected]
  rows:
    - [Loader,           abc.Loader.__class__.__name__.__eq__,           ["ABCMeta"], true]
    - [MetaPathFinder,   abc.MetaPathFinder.__class__.__name__.__eq__,   ["ABCMeta"], true]
    - [PathEntryFinder,  abc.PathEntryFinder.__class__.__name__.__eq__,  ["ABCMeta"], true]

# ---------------------------------------------------------------------------
# importlib.abc class metaclass — __class__.__qualname__ table
#
# Parallel to the __class__.__name__ table above, this table covers
# __class__.__qualname__ for the same three abstract base classes. Since
# ABCMeta is a top-level class in the abc module, its __qualname__ equals
# its __name__: 'ABCMeta'. No prior importlib spec covers any of these.
# ---------------------------------------------------------------------------

table importlib_extra15.abc_class_qualnames:
  description: "__class__.__qualname__ for importlib.abc abstract base classes is 'ABCMeta'"
  kind: python_call_eq
  category: type_attrs
  id_prefix: cqname15

  columns: [id, function, args, expected]
  rows:
    - [Loader,           abc.Loader.__class__.__qualname__.__eq__,           ["ABCMeta"], true]
    - [MetaPathFinder,   abc.MetaPathFinder.__class__.__qualname__.__eq__,   ["ABCMeta"], true]
    - [PathEntryFinder,  abc.PathEntryFinder.__class__.__qualname__.__eq__,  ["ABCMeta"], true]

# ---------------------------------------------------------------------------
# Standalone invariants — abc.Loader metaclass type
#
# importlib_extra5 covers abc.Loader.__qualname__ (the class's own qualname).
# No prior spec covers abc.Loader.__class__.__name__ or
# abc.Loader.__class__.__qualname__ (the metaclass type attributes).
# ---------------------------------------------------------------------------

invariant importlib_extra15.abc_Loader.class_name:
  description: "importlib.abc.Loader.__class__.__name__ == 'ABCMeta' — Loader is an ABCMeta instance"
  category: type_attrs
  kind: python_call_eq
  function: abc.Loader.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant importlib_extra15.abc_Loader.class_qualname:
  description: "importlib.abc.Loader.__class__.__qualname__ == 'ABCMeta' — metaclass qualname equals name"
  category: type_attrs
  kind: python_call_eq
  function: abc.Loader.__class__.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — abc.MetaPathFinder metaclass type
#
# importlib_extra9 covers abc.MetaPathFinder.__qualname__ and __name__.
# No prior spec covers abc.MetaPathFinder.__class__.__name__ or
# abc.MetaPathFinder.__class__.__qualname__.
# ---------------------------------------------------------------------------

invariant importlib_extra15.abc_MetaPathFinder.class_name:
  description: "importlib.abc.MetaPathFinder.__class__.__name__ == 'ABCMeta' — MetaPathFinder is an ABCMeta instance"
  category: type_attrs
  kind: python_call_eq
  function: abc.MetaPathFinder.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant importlib_extra15.abc_MetaPathFinder.class_qualname:
  description: "importlib.abc.MetaPathFinder.__class__.__qualname__ == 'ABCMeta' — metaclass qualname equals name"
  category: type_attrs
  kind: python_call_eq
  function: abc.MetaPathFinder.__class__.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true
