spec: operator_extra3
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "Python operator documentation — https://docs.python.org/3/library/operator.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl, operator_extra.zspec.zsdl, operator_extra2.zspec.zsdl."
    - "Previous specs cover: __name__ and call results for all arithmetic/comparison/logical/sequence/inplace operators; attrgetter/itemgetter/methodcaller class names and instances; length_hint/index/concat/abs/pos/iadd/truth/is_."
    - "This spec adds: __module__ checks for add/sub/mul/truediv/floordiv/mod/pow/neg/eq/ne/lt/le/gt/ge — all == '_operator' (C implementation) on CPython."
    - "Also adds __module__ for not_/and_/or_/xor/getitem/setitem/delitem/contains/lshift/rshift/abs — all == '_operator'."
    - "operator.add.__module__ == '_operator' — operator functions are implemented in the C extension _operator."
    - "The public 'operator' module re-exports all these symbols from '_operator'; __module__ reflects the C origin."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ table — arithmetic and comparison operators
#
# All CPython operator functions are C builtins from the _operator extension;
# their __module__ is '_operator'.
# ---------------------------------------------------------------------------

table operator_extra3.module_checks.arithmetic:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [add,      add.__module__.__eq__,      ["_operator"], true]
    - [sub,      sub.__module__.__eq__,      ["_operator"], true]
    - [mul,      mul.__module__.__eq__,      ["_operator"], true]
    - [truediv,  truediv.__module__.__eq__,  ["_operator"], true]
    - [floordiv, floordiv.__module__.__eq__, ["_operator"], true]
    - [mod,      mod.__module__.__eq__,      ["_operator"], true]
    - [pow,      pow.__module__.__eq__,      ["_operator"], true]
    - [neg,      neg.__module__.__eq__,      ["_operator"], true]
    - [abs,      abs.__module__.__eq__,      ["_operator"], true]

# ---------------------------------------------------------------------------
# __module__ table — comparison operators
# ---------------------------------------------------------------------------

table operator_extra3.module_checks.comparison:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [eq, eq.__module__.__eq__, ["_operator"], true]
    - [ne, ne.__module__.__eq__, ["_operator"], true]
    - [lt, lt.__module__.__eq__, ["_operator"], true]
    - [le, le.__module__.__eq__, ["_operator"], true]
    - [gt, gt.__module__.__eq__, ["_operator"], true]
    - [ge, ge.__module__.__eq__, ["_operator"], true]

# ---------------------------------------------------------------------------
# __module__ standalone invariants — logical and bitwise operators
# ---------------------------------------------------------------------------

invariant operator_extra3.not_.module:
  description: "operator.not_.__module__ == '_operator'"
  category: module_checks
  kind: python_call_eq
  function: not_.__module__.__eq__
  args: ["_operator"]
  expected: true

invariant operator_extra3.and_.module:
  description: "operator.and_.__module__ == '_operator'"
  category: module_checks
  kind: python_call_eq
  function: and_.__module__.__eq__
  args: ["_operator"]
