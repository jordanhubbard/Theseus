spec: itertools_extra41
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra40.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all; chain.__name__=='chain'; chain.__qualname__=='chain'; chain.from_iterable.__qualname__=='chain.from_iterable'; zip_longest/__name__/__qualname__=='zip_longest'; islice/__name__/__qualname__=='islice'; accumulate/__name__/__qualname__=='accumulate'; groupby/__name__/__qualname__; compress/__name__/__qualname__; dropwhile/__name__/__qualname__; takewhile/__name__/__qualname__; starmap/__name__/__qualname__; filterfalse/__name__/__qualname__."
    - "This spec covers: itertools.pairwise.__name__ == 'pairwise' (Python 3.10+, verified present on this system); itertools.pairwise.__qualname__ == 'pairwise'; itertools.batched.__name__ == 'batched' (Python 3.12+, verified present on this system); itertools.batched.__qualname__ == 'batched'; itertools.count.__name__ == 'count'; itertools.count.__qualname__ == 'count'; itertools.product.__name__ == 'product'; itertools.product.__qualname__ == 'product'; itertools.permutations.__name__ == 'permutations'; itertools.combinations.__name__ == 'combinations'."
    - "Key findings: itertools.pairwise.__name__ and __qualname__ are both 'pairwise' (8 chars) — pairwise is a C-extension type added in Python 3.10; __qualname__ == __name__ because it is a top-level type definition. itertools.batched.__name__ and __qualname__ are both 'batched' (7 chars) — batched is a C-extension type added in Python 3.12; __qualname__ == __name__ for the same reason. itertools.count.__name__ and __qualname__ are both 'count' (5 chars). itertools.product.__name__ and __qualname__ are both 'product' (7 chars) — same length as batched. itertools.permutations.__name__ and __qualname__ are both 'permutations' (12 chars). itertools.combinations.__name__ and __qualname__ are both 'combinations' (12 chars) — same length as permutations. All itertools C-extension types share the invariant that __qualname__ == __name__ because they are top-level type definitions. NOTE: pairwise requires Python >=3.10 and batched requires Python >=3.12; these invariants will raise AttributeError on older Python versions. Prior specs recorded __qualname__.__len__() for count, permutations, and combinations but not the string equality invariants; pairwise and batched are entirely new to this namespace."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.pairwise identity metadata — extra41 namespace (Python 3.10+)
#
# itertools.pairwise.__name__ is 'pairwise' (8 chars) and itertools.pairwise.
# __qualname__ is 'pairwise' (8 chars). pairwise is a C-extension type added
# in Python 3.10 (PEP 618 / bpo-40682). As a top-level C type, __qualname__
# == __name__. These invariants will raise AttributeError on Python < 3.10.
# No prior itertools spec records these invariants in the extra41 namespace.
# NOTE: version constraint for this file is ">=3.9" (project minimum), but
# these two invariants only apply on Python >=3.10.
# ---------------------------------------------------------------------------

invariant itertools_extra41.pairwise_name:
  description: "itertools.pairwise.__name__ == 'pairwise' — C-extension type added in Python 3.10; yields overlapping pairs (a,b),(b,c),(c,d) from an iterable; 8-char name"
  category: identity
  kind: python_call_eq
  function: pairwise.__name__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra41.pairwise_qualname:
  description: "itertools.pairwise.__qualname__ == 'pairwise' — top-level C type (Python 3.10+); __qualname__ == __name__ (no enclosing class scope); 8 chars"
  category: identity
  kind: python_call_eq
  function: pairwise.__qualname__.__eq__
  args: ["pairwise"]
  expected: true

# ---------------------------------------------------------------------------
# itertools.batched identity metadata — extra41 namespace (Python 3.12+)
#
# itertools.batched.__name__ is 'batched' (7 chars) and itertools.batched.
# __qualname__ is 'batched' (7 chars). batched is a C-extension type added
# in Python 3.12 (PEP 618 / bpo-98363). As a top-level C type, __qualname__
# == __name__. These invariants will raise AttributeError on Python < 3.12.
# No prior itertools spec records these invariants in the extra41 namespace.
# batched and product share the same 7-char __name__ length.
# ---------------------------------------------------------------------------

invariant itertools_extra41.batched_name:
  description: "itertools.batched.__name__ == 'batched' — C-extension type added in Python 3.12; batches an iterable into fixed-length tuples; 7-char name; same length as product.__name__"
  category: identity
  kind: python_call_eq
  function: batched.__name__.__eq__
  args: ["batched"]
  expected: true

invariant itertools_extra41.batched_qualname:
  description: "itertools.batched.__qualname__ == 'batched' — top-level C type (Python 3.12+); __qualname__ == __name__ (no enclosing class scope); 7 chars; same as product.__qualname__"
  category: identity
  kind: python_call_eq
  function: batched.__qualname__.__eq__
  args: ["batched"]
  expected: true

# ---------------------------------------------------------------------------
# itertools.count and itertools.product identity metadata — extra41 namespace
#
# itertools.count.__name__ and __qualname__ are both 'count' (5 chars).
# itertools.product.__name__ and __qualname__ are both 'product' (7 chars).
# Both are top-level C-extension types in itertoolsmodule.c; __qualname__
# == __name__ for all such types. count has the shortest __name__ (5 chars)
# among the types covered in this spec, equal to itertools.chain.__name__.
# Prior specs recorded __qualname__.__len__() for count but not the string
# equality invariants; product equality invariants are new to this namespace.
# ---------------------------------------------------------------------------

table itertools_extra41.count_product_name_qualname:
  description: "itertools.count and itertools.product __name__ and __qualname__ string equality — both are top-level C types with __qualname__ == __name__"
  kind: python_call_eq
  category: identity
  id_prefix: cpnq41

  columns: [id, function, args, expected, description]
  rows:
    - [count_name,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__ == 'count' — C-extension type; 5-char name; same length as chain.__name__; infinite arithmetic progression iterator"]
    - [count_qualname,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__ == 'count' — top-level C type; __qualname__ == __name__ (no enclosing class scope); 5 chars"]
    - [product_name,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__ == 'product' — C-extension type; 7-char name; same length as batched.__name__; Cartesian product of input iterables"]
    - [product_qualname,
       product.__qualname__.__eq__,
       ["product"],
       true,
       "itertools.product.__qualname__ == 'product' — top-level C type; __qualname__ == __name__ (no enclosing class scope); 7 chars; same as batched.__qualname__"]

# ---------------------------------------------------------------------------
# itertools.permutations and itertools.combinations identity — extra41 namespace
#
# itertools.permutations.__name__ and __qualname__ are both 'permutations'
# (12 chars). itertools.combinations.__name__ and __qualname__ are both
# 'combinations' (12 chars). Both are top-level C-extension types and share
# the same 12-char __name__ length. Prior specs recorded __qualname__.__len__()
# for both; the string equality invariants are new to the extra41 namespace.
# ---------------------------------------------------------------------------

table itertools_extra41.permutations_combinations_names:
  description: "itertools.permutations and itertools.combinations __name__ and __qualname__ string equality — both 12 chars; top-level C types"
  kind: python_call_eq
  category: identity
  id_prefix: pcname41

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_name,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__ == 'permutations' — C-extension type; 12-char name; same length as combinations.__name__; successive r-length permutations"]
    - [permutations_qualname,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__ == 'permutations' — top-level C type; __qualname__ == __name__; 12 chars; same as combinations.__qualname__"]
    - [combinations_name,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__ == 'combinations' — C-extension type; 12-char name; same length as permutations.__name__; r-length subsequences without repetition"]
    - [combinations_qualname,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__ == 'combinations' — top-level C type; __qualname__ == __name__; 12 chars; same as permutations.__qualname__"]
