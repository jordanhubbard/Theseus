spec: functools_extra2
version: ">=3.8"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "Python functools documentation — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.reduce.__name__ == 'reduce'."
    - "functools.total_ordering.__name__ == 'total_ordering'."
    - "functools.singledispatch.__name__ == 'singledispatch'."
    - "functools.cached_property.__name__ == 'cached_property'."
    - "functools.wraps.__name__ == 'wraps'."
    - "functools.reduce(operator.add, [1,2,3,4]) == 10 — sum via operator.add."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function / class name identity
# ---------------------------------------------------------------------------

invariant functools_extra2.reduce.dunder_name:
  description: "functools.reduce.__name__ == 'reduce'"
  category: function_identity
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra2.total_ordering.dunder_name:
  description: "functools.total_ordering.__name__ == 'total_ordering'"
  category: function_identity
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra2.singledispatch.dunder_name:
  description: "functools.singledispatch.__name__ == 'singledispatch'"
  category: function_identity
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra2.cached_property.dunder_name:
  description: "functools.cached_property.__name__ == 'cached_property'"
  category: class_identity
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra2.wraps.dunder_name:
  description: "functools.wraps.__name__ == 'wraps'"
  category: function_identity
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

# ---------------------------------------------------------------------------
# reduce — sum via operator.add
# ---------------------------------------------------------------------------

invariant functools_extra2.reduce.sum:
  description: "functools.reduce(operator.add, [1,2,3,4]) == 10"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: [{type: module_attr, module: "operator", attr: "add"}, [1, 2, 3, 4]]
  expected: 10
