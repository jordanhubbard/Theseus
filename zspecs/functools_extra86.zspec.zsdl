spec: functools_extra86
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra85

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra85.zspec.zsdl."
    - "This spec covers: functools reduce/cmp_to_key C-type __doc__ class name, __qualname__ lengths, cached_property dict presence, singledispatch/total_ordering __qualname__ lengths (Wave 245)."
    - "reduce.__doc__.__class__.__name__ == 'str' — reduce is a C builtin; its __doc__ is a str. Verified with Python 3.14.3."
    - "cmp_to_key.__doc__.__class__.__name__ == 'str' — cmp_to_key is a C builtin; its __doc__ is a str. Verified with Python 3.14.3."
    - "reduce.__qualname__ == 'reduce' (len 6) — C builtin function; __qualname__ is just the name. Verified with Python 3.14.3."
    - "cmp_to_key.__qualname__ == 'cmp_to_key' (len 10) — C builtin function; __qualname__ is just the name. Verified with Python 3.14.3."
    - "cached_property.__dict__.__contains__('__get__') == True — __get__ is defined on cached_property. Verified with Python 3.14.3."
    - "cached_property.__dict__.__contains__('__set__') == False — cached_property has no __set__ defined; it is a non-data descriptor. Verified with Python 3.14.3."
    - "cached_property.__dict__.__contains__('__set_name__') == True — __set_name__ is defined on cached_property. Verified with Python 3.14.3."
    - "cached_property.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy. Verified with Python 3.14.3."
    - "singledispatch.__qualname__ == 'singledispatch' (len 14) — pure-Python decorator; __qualname__ equals the function name. Verified with Python 3.14.3."
    - "total_ordering.__qualname__ == 'total_ordering' (len 14) — pure-Python class decorator; __qualname__ equals the function name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reduce and cmp_to_key __doc__ class name and __qualname__ lengths — extra86
#
# Wave 245 theme: C-type builtins __doc__.__class__.__name__ and __qualname__ lengths.
#
# functools.reduce.__doc__.__class__.__name__     == 'str'
# functools.cmp_to_key.__doc__.__class__.__name__ == 'str'
# functools.reduce.__qualname__.__len__()         == 6
# functools.cmp_to_key.__qualname__.__len__()     == 10
#
# No prior functools spec checks reduce/cmp_to_key __doc__ class names via functoolsextra86. New to extra86.
# ---------------------------------------------------------------------------

table functools_extra86.reduce_cmp_to_key_doc_qualname:
  description: "reduce.__doc__.__class__.__name__=='str'; cmp_to_key.__doc__.__class__.__name__=='str'; reduce.__qualname__ len==6; cmp_to_key.__qualname__ len==10; wave 245 C-type __doc__ and __qualname__; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra86

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_class_name_eq_str,
       reduce.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce is a C builtin function defined in Modules/_functoolsmodule.c; its __doc__ is a plain Python str; str.__class__.__name__ is 'str' (3 chars); str.__eq__('str') returns True; no prior functools spec checks reduce.__doc__.__class__.__name__ via functoolsextra86; new to extra86"]
    - [cmp_to_key_doc_class_name_eq_str,
       cmp_to_key.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.cmp_to_key.__doc__.__class__.__name__.__eq__('str') == True — cmp_to_key is a C builtin function; its __doc__ is a plain Python str; str.__class__.__name__ is 'str' (3 chars); str.__eq__('str') returns True; no prior functools spec checks cmp_to_key.__doc__.__class__.__name__ via functoolsextra86; new to extra86"]
    - [reduce_qualname_len_eq_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — reduce is a C builtin function; __qualname__ equals 'reduce' (6 chars: 'r','e','d','u','c','e'); str.__len__() returns 6; no prior functools spec checks reduce.__qualname__.__len__() via functoolsextra86; new to extra86"]
    - [cmp_to_key_qualname_len_eq_10,
       "cmp_to_key.__qualname__.__len__",
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — cmp_to_key is a C builtin function; __qualname__ equals 'cmp_to_key' (10 chars: 'c','m','p','_','t','o','_','k','e','y'); str.__len__() returns 10; no prior functools spec checks cmp_to_key.__qualname__.__len__() via functoolsextra86; new to extra86"]

# ---------------------------------------------------------------------------
# cached_property __dict__ membership checks — extra86
#
# Wave 245 theme: cached_property descriptor presence in __dict__.
#
# functools.cached_property.__dict__.__contains__('__get__')      == True
# functools.cached_property.__dict__.__contains__('__set__')      == False
# functools.cached_property.__dict__.__contains__('__set_name__') == True
# functools.cached_property.__dict__.__class__.__name__           == 'mappingproxy'
#
# No prior functools spec checks cached_property __dict__ membership via functoolsextra86. New to extra86.
# ---------------------------------------------------------------------------

table functools_extra86.cached_property_dict:
  description: "cached_property.__dict__.__contains__('__get__')==True; '__set__'==False; '__set_name__'==True; __dict__.__class__.__name__=='mappingproxy'; wave 245 cached_property dict membership; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra86

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_dict_contains___get___eq_True,
       "cached_property.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property is a pure-Python class in Lib/functools.py that implements the descriptor protocol; __get__ is explicitly defined and appears in the class __dict__; dict.__contains__('__get__') returns True; no prior functools spec checks cached_property.__dict__.__contains__('__get__') via functoolsextra86; new to extra86"]
    - [cached_property_dict_contains___set___eq_False,
       "cached_property.__dict__.__contains__",
       ["__set__"],
       false,
       "functools.cached_property.__dict__.__contains__('__set__') == False — cached_property is a non-data descriptor; it intentionally does not define __set__ so the instance __dict__ takes precedence; dict.__contains__('__set__') returns False; no prior functools spec checks cached_property.__dict__.__contains__('__set__') via functoolsextra86; new to extra86"]
    - [cached_property_dict_contains___set_name___eq_True,
       "cached_property.__dict__.__contains__",
       ["__set_name__"],
       true,
       "functools.cached_property.__dict__.__contains__('__set_name__') == True — cached_property defines __set_name__ to store the attribute name; __set_name__ is explicitly defined and appears in the class __dict__; dict.__contains__('__set_name__') returns True; no prior functools spec checks cached_property.__dict__.__contains__('__set_name__') via functoolsextra86; new to extra86"]
    - [cached_property_dict_class_name_eq_mappingproxy,
       cached_property.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.cached_property.__dict__.__class__.__name__.__eq__('mappingproxy') == True — class __dict__ attributes are always wrapped in a types.MappingProxyType; its __class__.__name__ is 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior functools spec checks cached_property.__dict__.__class__.__name__ via functoolsextra86; new to extra86"]

# ---------------------------------------------------------------------------
# singledispatch and total_ordering __qualname__ lengths — extra86
#
# Wave 245 theme: pure-Python decorator __qualname__ lengths.
#
# functools.singledispatch.__qualname__.__len__() == 14
# functools.total_ordering.__qualname__.__len__() == 14
#
# No prior functools spec checks singledispatch/total_ordering __qualname__ lengths via functoolsextra86. New to extra86.
# ---------------------------------------------------------------------------

table functools_extra86.singledispatch_total_ordering_qualname:
  description: "singledispatch.__qualname__.__len__()==14; total_ordering.__qualname__.__len__()==14; wave 245 pure-Python decorator __qualname__ lengths; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra86

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_qualname_len_eq_14,
       "singledispatch.__qualname__.__len__",
       [],
       14,
       "functools.singledispatch.__qualname__.__len__() == 14 — singledispatch is a pure-Python decorator defined in Lib/functools.py; its __qualname__ equals 'singledispatch' (14 chars); str.__len__() returns 14; no prior functools spec checks singledispatch.__qualname__.__len__() via functoolsextra86; new to extra86"]
    - [total_ordering_qualname_len_eq_14,
       "total_ordering.__qualname__.__len__",
       [],
       14,
       "functools.total_ordering.__qualname__.__len__() == 14 — total_ordering is a pure-Python class decorator defined in Lib/functools.py; its __qualname__ equals 'total_ordering' (14 chars); str.__len__() returns 14; no prior functools spec checks total_ordering.__qualname__.__len__() via functoolsextra86; new to extra86"]

# ---------------------------------------------------------------------------
# reduce and cmp_to_key __qualname__ string equality — extra86
#
# Wave 245 theme: C-type builtin __qualname__ string equality checks.
#
# functools.reduce.__qualname__.__eq__('reduce')         == True
# functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True
#
# No prior functools spec checks reduce/cmp_to_key __qualname__ string equality via functoolsextra86. New to extra86.
# ---------------------------------------------------------------------------

table functools_extra86.reduce_cmp_to_key_qualname_eq:
  description: "reduce.__qualname__.__eq__('reduce')==True; cmp_to_key.__qualname__.__eq__('cmp_to_key')==True; wave 245 C-type builtin __qualname__ string equality; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra86

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_eq_reduce,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a C builtin function; its __qualname__ attribute is the string 'reduce' (6 chars); str.__eq__('reduce') returns True; no prior functools spec checks reduce.__qualname__.__eq__ via functoolsextra86; new to extra86"]
    - [cmp_to_key_qualname_eq_cmp_to_key,
       cmp_to_key.__qualname__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — cmp_to_key is a C builtin function; its __qualname__ attribute is the string 'cmp_to_key' (10 chars); str.__eq__('cmp_to_key') returns True; no prior functools spec checks cmp_to_key.__qualname__.__eq__ via functoolsextra86; new to extra86"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra86
# ---------------------------------------------------------------------------

invariant functools_extra86.reduce_doc_class_name:
  description: "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce C builtin __doc__ is a str; wave 245 C-type __doc__ class name; new to extra86"
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra86.reduce_qualname_len:
  description: "functools.reduce.__qualname__.__len__() == 6 — reduce.__qualname__ is 'reduce' (6 chars); wave 245 C-type __qualname__ length; new to extra86"
  kind: python_call_eq
  function: "reduce.__qualname__.__len__"
  args: []
  expected: 6

invariant functools_extra86.cmp_to_key_qualname_len:
  description: "functools.cmp_to_key.__qualname__.__len__() == 10 — cmp_to_key.__qualname__ is 'cmp_to_key' (10 chars); wave 245 C-type __qualname__ length; new to extra86"
  kind: python_call_eq
  function: "cmp_to_key.__qualname__.__len__"
  args: []
  expected: 10

invariant functools_extra86.cached_property_dict_contains___get__:
  description: "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property defines __get__; wave 245 cached_property dict membership; new to extra86"
  kind: python_call_eq
  function: "cached_property.__dict__.__contains__"
  args: ["__get__"]
  expected: true

invariant functools_extra86.singledispatch_qualname_len:
  description: "functools.singledispatch.__qualname__.__len__() == 14 — singledispatch.__qualname__ is 'singledispatch' (14 chars); wave 245 decorator __qualname__ length; new to extra86"
  kind: python_call_eq
  function: "singledispatch.__qualname__.__len__"
  args: []
  expected: 14
