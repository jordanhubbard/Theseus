spec: pathlib_extra272
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the pure path hierarchy."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — POSIX pure path inherits directly from PurePath."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — Windows pure path inherits directly from PurePath."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — on Python 3.12+, Path's direct base is PurePath."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — on macOS, PosixPath inherits from Path."
    - "All classes have __module__ == 'pathlib' and __qualname__ equal to their __name__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: PurePath hierarchy identity — name, module, qualname
# ---------------------------------------------------------------------------

table pathlib_extra272.purepath_hierarchy:
  description: "PurePath, PurePosixPath, PureWindowsPath __name__, __module__, __qualname__"
  kind: python_call_eq
  category: identity
  id_prefix: pure

  columns: [id, function, args, expected, description]
  rows:
    - [PurePath_name,          PurePath.__name__.__eq__,          ["PurePath"],          true, "pathlib.PurePath.__name__ == 'PurePath'"]
    - [PurePath_module,        PurePath.__module__.__eq__,        ["pathlib"],           true, "pathlib.PurePath.__module__ == 'pathlib'"]
    - [PurePath_qualname,      PurePath.__qualname__.__eq__,      ["PurePath"],          true, "pathlib.PurePath.__qualname__ == 'PurePath'"]
    - [PurePosixPath_name,     PurePosixPath.__name__.__eq__,     ["PurePosixPath"],     true, "pathlib.PurePosixPath.__name__ == 'PurePosixPath'"]
    - [PurePosixPath_module,   PurePosixPath.__module__.__eq__,   ["pathlib"],           true, "pathlib.PurePosixPath.__module__ == 'pathlib'"]
    - [PurePosixPath_qualname, PurePosixPath.__qualname__.__eq__, ["PurePosixPath"],     true, "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath'"]
    - [PureWinPath_name,       PureWindowsPath.__name__.__eq__,   ["PureWindowsPath"],   true, "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'"]
    - [PureWinPath_module,     PureWindowsPath.__module__.__eq__, ["pathlib"],           true, "pathlib.PureWindowsPath.__module__ == 'pathlib'"]
    - [PureWinPath_qualname,   PureWindowsPath.__qualname__.__eq__, ["PureWindowsPath"], true, "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath'"]

# ---------------------------------------------------------------------------
# Table: concrete Path hierarchy identity — name, module, qualname
# ---------------------------------------------------------------------------

table pathlib_extra272.path_hierarchy:
  description: "Path and PosixPath __name__, __module__, __qualname__"
  kind: python_call_eq
  category: identity
  id_prefix: conc

  columns: [id, function, args, expected, description]
  rows:
    - [Path_name,       Path.__name__.__eq__,       ["Path"],      true, "pathlib.Path.__name__ == 'Path'"]
    - [Path_module,     Path.__module__.__eq__,     ["pathlib"],   true, "pathlib.Path.__module__ == 'pathlib'"]
    - [Path_qualname,   Path.__qualname__.__eq__,   ["Path"],      true, "pathlib.Path.__qualname__ == 'Path'"]
    - [Posix_name,      PosixPath.__name__.__eq__,  ["PosixPath"], true, "pathlib.PosixPath.__name__ == 'PosixPath'"]
    - [Posix_module,    PosixPath.__module__.__eq__, ["pathlib"],  true, "pathlib.PosixPath.__module__ == 'pathlib'"]
    - [Posix_qualname,  PosixPath.__qualname__.__eq__, ["PosixPath"], true, "pathlib.PosixPath.__qualname__ == 'PosixPath'"]

# ---------------------------------------------------------------------------
# Standalone invariants: __bases__[0].__name__ for the hierarchy
# ---------------------------------------------------------------------------

invariant pathlib_extra272.PurePath.base_name:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath root inherits from object"
  category: identity
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra272.PurePosixPath.base_name:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — POSIX pure path inherits from PurePath"
  category: identity
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra272.PureWindowsPath.base_name:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — Windows pure path inherits from PurePath"
  category: identity
  kind: python_call_eq
  function: "PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra272.Path.base_name:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — concrete Path inherits directly from PurePath"
  category: identity
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra272.PosixPath.base_name:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits from Path"
  category: identity
  kind: python_call_eq
  function: "PosixPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true
