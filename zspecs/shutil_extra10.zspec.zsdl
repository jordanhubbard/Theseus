spec: shutil_extra10
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "This spec extends shutil.zspec.zsdl through shutil_extra9.zspec.zsdl."
    - "shutil_extra9 covers: copyfileobj.__module__; Error.__mro__[3].__name__=='BaseException'; ExecError.__name__=='RuntimeError'; get_archive_formats/__ge__/4; get_unpack_formats/__ge__/4."
    - "shutil_extra8 covers: copy2/copyfile/copyfileobj/copytree/make_archive/unpack_archive/chown/get_terminal_size __class__.__name__; Error.__mro__[1].__name__=='OSError'; Error.__mro__[2].__name__=='Exception'; SameFileError.__mro__[2].__name__=='OSError'; disk_usage('/tmp') total/used/fields."
    - "shutil_extra7 covers: copy/rmtree/move/which __class__.__name__=='function'; copymode/copystat/chown/get_unpack_formats/get_terminal_size metadata."
    - "shutil_extra6 covers: Error/SameFileError/ReadError __name__ table; __module__ table; __qualname__ standalones; bases."
    - "No prior spec covers: SameFileError.__mro__[3].__name__ == 'Exception' — SameFileError MRO depth 3."
    - "No prior spec covers: SameFileError.__mro__[4].__name__ == 'BaseException' — SameFileError MRO depth 4."
    - "No prior spec covers: ReadError.__mro__[1].__name__ == 'OSError' — ReadError MRO depth 1."
    - "No prior spec covers: ReadError.__mro__[2].__name__ == 'Exception' — ReadError MRO depth 2."
    - "No prior spec covers: Error.__mro__[4].__name__ == 'object' — Error MRO depth 4 (terminal object entry)."
    - "No prior spec covers: disk_usage('/')._fields.__getitem__(0) == 'total' — element access on _fields."
    - "No prior spec covers: disk_usage('/')._fields.__getitem__(1) == 'used' — element access on _fields."
    - "No prior spec covers: disk_usage('/')._fields.__getitem__(2) == 'free' — element access on _fields."
    - "shutil.SameFileError.__mro__: [SameFileError, Error, OSError, Exception, BaseException, object]."
    - "shutil.ReadError.__mro__: [ReadError, OSError, Exception, BaseException, object]."
    - "shutil.Error.__mro__: [Error, OSError, Exception, BaseException, object]; index 4 is 'object'."
    - "disk_usage returns a named tuple with _fields == ('total', 'used', 'free')."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SameFileError MRO depth 3 and depth 4
# shutil_extra8 covers SameFileError.__mro__[2].__name__ == 'OSError'.
# Depths 3 (Exception) and 4 (BaseException) are not in any prior shutil spec.
# SameFileError.__mro__: [SameFileError, Error, OSError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant shutil_extra10.SameFileError.mro_index3:
  description: "shutil.SameFileError.__mro__[3].__name__ == 'Exception' — SameFileError MRO depth 3"
  category: class_hierarchy
  kind: python_call_eq
  function: SameFileError.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "Exception"

invariant shutil_extra10.SameFileError.mro_index4:
  description: "shutil.SameFileError.__mro__[4].__name__ == 'BaseException' — SameFileError MRO depth 4"
  category: class_hierarchy
  kind: python_call_eq
  function: SameFileError.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "BaseException"

# ---------------------------------------------------------------------------
# ReadError MRO depth 1 and depth 2
# shutil_extra6 covers ReadError.__bases__[0].__name__ == 'OSError' (__bases__ form).
# No prior spec checks ReadError.__mro__[N].__name__ for any N.
# ReadError.__mro__: [ReadError, OSError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant shutil_extra10.ReadError.mro_index1:
  description: "shutil.ReadError.__mro__[1].__name__ == 'OSError' — ReadError inherits from OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: ReadError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OSError"

invariant shutil_extra10.ReadError.mro_index2:
  description: "shutil.ReadError.__mro__[2].__name__ == 'Exception' — ReadError MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: ReadError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Error MRO depth 4 — terminal 'object' entry
# shutil_extra9 covers Error.__mro__[3].__name__ == 'BaseException'.
# Index 4 is 'object' — the terminal entry. Not in any prior shutil spec.
# Error.__mro__: [Error, OSError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant shutil_extra10.Error.mro_index4:
  description: "shutil.Error.__mro__[4].__name__ == 'object' — Error MRO terminal entry"
  category: class_hierarchy
  kind: python_call_eq
  function: Error.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# disk_usage _fields element access — individual field names by index
# shutil.zspec.zsdl checks _fields == ('total', 'used', 'free') as a tuple eq.
# shutil_extra8 checks _fields.__len__() == 3.
# No prior spec checks _fields.__getitem__(N) for individual field names.
# ---------------------------------------------------------------------------

table shutil_extra10.disk_usage_fields_elements:
  description: "shutil.disk_usage('/') _fields elements by index: total/used/free"
  kind: python_call_eq
  category: disk_usage
  id_prefix: dfelem10

  columns: [id, function, args, expected, method, method_args]
  rows:
    - [field0, disk_usage, ["/"], "total", _fields.__getitem__, [0]]
    - [field1, disk_usage, ["/"], "used",  _fields.__getitem__, [1]]
    - [field2, disk_usage, ["/"], "free",  _fields.__getitem__, [2]]

# ---------------------------------------------------------------------------
# get_archive_formats — returns a list (not a tuple or set)
# Prior specs check len >= 4 and the list contents indirectly.
# No prior spec checks the __class__.__name__ of the return value itself.
# get_archive_formats() returns a list of (name, extensions) tuples.
# ---------------------------------------------------------------------------

invariant shutil_extra10.get_archive_formats.return_type:
  description: "shutil.get_archive_formats() returns a list object"
  category: archive_formats
  kind: python_call_eq
  function: get_archive_formats
  args: []
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# get_unpack_formats — returns a list (not a tuple or set)
# Complementary axis to get_archive_formats return type check above.
# No prior spec checks the __class__.__name__ of get_unpack_formats() return.
# ---------------------------------------------------------------------------

invariant shutil_extra10.get_unpack_formats.return_type:
  description: "shutil.get_unpack_formats() returns a list object"
  category: archive_formats
  kind: python_call_eq
  function: get_unpack_formats
  args: []
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true
