spec: struct_extra856
python: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Modules/_struct.c"
    - "cpython/Lib/struct.py"
  not_derived_from:
    - "any third-party binary packing library"
  notes:
    - "Covers __class__.__name__ checks on struct module functions and types"
    - "Top-level struct functions are builtin_function_or_method (implemented in C)"
    - "struct.Struct and struct.error are type objects with __module__ == 'struct'"
  created_at: "2026-04-12"

table struct_extra856.class_names:
  description: "Verify __class__.__name__ and __module__ attributes of struct module members"
  kind: python_call_eq
  category: introspection
  id_prefix: st856xx
  columns: [id, function, args, expected]
  rows:
    - [st856xx001, "struct.pack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [st856xx002, "struct.unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [st856xx003, "struct.pack_into.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [st856xx004, "struct.unpack_from.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [st856xx005, "struct.iter_unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [st856xx006, "struct.calcsize.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [st856xx007, "struct.Struct.__class__.__name__.__eq__", ["type"], true]
    - [st856xx008, "struct.error.__class__.__name__.__eq__", ["type"], true]
    - [st856xx009, "struct.Struct.__module__.__eq__", ["struct"], true]
    - [st856xx010, "struct.error.__module__.__eq__", ["struct"], true]
    - [st856xx011, "struct.pack.__module__.__eq__", ["struct"], true]
    - [st856xx012, "struct.calcsize.__module__.__eq__", ["struct"], true]
