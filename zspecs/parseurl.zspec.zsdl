spec: parseurl
version: ">=1.3.0"
backend: node(parseurl)

docs: https://github.com/pillarjs/parseurl#readme

provenance:
  derived_from:
    - "parseurl README — https://github.com/pillarjs/parseurl#readme"
    - "Test vectors verified with parseurl via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "parseurl source"
  notes:
    - "Cache-aware url.parse for express-style middleware — parses req.url and stashes the result on req."
    - "Install: npm install parseurl"
    - "v1 CJS; module export is parseurl(req); .original(req) parses req.originalUrl."
    - "Spec drives the function with synthetic request objects ({url})."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws TypeError on missing req or non-string url."
  stderr: "null"
  stickiness: "Caches parsed result on req._parsedUrl."
  codes: {}

invariant parseurl.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant parseurl.has_original:
  description: ".original() helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "original.constructor.name"}
  expected: "Function"

invariant parseurl.parses_pathname:
  description: "parseurl({url:'/foo?bar=1'}).pathname is '/foo'"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [{"url": "/foo?bar=1"}]
  chain:
    - {get: pathname}
  expected: "/foo"

invariant parseurl.parses_search:
  description: "parseurl({url:'/foo?bar=1'}).search is '?bar=1'"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [{"url": "/foo?bar=1"}]
  chain:
    - {get: search}
  expected: "?bar=1"

invariant parseurl.parses_query:
  description: "parseurl({url:'/foo?bar=1'}).query is 'bar=1' (string, not parsed)"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [{"url": "/foo?bar=1"}]
  chain:
    - {get: query}
  expected: "bar=1"

invariant parseurl.parses_path:
  description: ".path is '/foo?bar=1'"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [{"url": "/foo?bar=1"}]
  chain:
    - {get: path}
  expected: "/foo?bar=1"

invariant parseurl.no_query_keeps_pathname:
  description: "URL without query — pathname is the entire URL"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [{"url": "/just/path"}]
  chain:
    - {get: pathname}
  expected: "/just/path"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:37:22Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
