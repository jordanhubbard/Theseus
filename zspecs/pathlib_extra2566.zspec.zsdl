spec: pathlib_extra2566
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2566 (_extra2566): __getattr__, __setattr__, __delattr__ dict-presence checks for pathlib classes."
    - "pathlib.Path objects are intended to be immutable-ish but do not define custom __setattr__ or __delattr__ in their class __dict__."
    - "PurePath, PurePosixPath, PureWindowsPath, and Path all delegate attribute access to object defaults."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table pathlib_extra2566.getattr_protocol:
  description: "pathlib classes __getattr__ dict-presence — all False (no custom __getattr__ defined)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2566

  columns: [id, function, args, expected]
  rows:
    - ["pp2566001", "pathlib.PurePath.__dict__.__contains__",        ["__getattr__"], false]
    - ["pp2566002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__getattr__"], false]
    - ["pp2566003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__getattr__"], false]
    - ["pp2566004", "pathlib.Path.__dict__.__contains__",            ["__getattr__"], false]

table pathlib_extra2566.setattr_protocol:
  description: "pathlib classes __setattr__ dict-presence — all False (no custom __setattr__ despite immutability intent)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2566s

  columns: [id, function, args, expected]
  rows:
    - ["pp2566s001", "pathlib.PurePath.__dict__.__contains__",        ["__setattr__"], false]
    - ["pp2566s002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__setattr__"], false]
    - ["pp2566s003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__setattr__"], false]
    - ["pp2566s004", "pathlib.Path.__dict__.__contains__",            ["__setattr__"], false]

table pathlib_extra2566.delattr_protocol:
  description: "pathlib classes __delattr__ dict-presence — all False (no custom __delattr__ defined)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2566d

  columns: [id, function, args, expected]
  rows:
    - ["pp2566d001", "pathlib.PurePath.__dict__.__contains__",        ["__delattr__"], false]
    - ["pp2566d002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__delattr__"], false]
    - ["pp2566d003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__delattr__"], false]
    - ["pp2566d004", "pathlib.Path.__dict__.__contains__",            ["__delattr__"], false]

table pathlib_extra2566.all_three_combined:
  description: "pathlib classes: combined check that none of the three attr-access dunders appear in any class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2566x

  columns: [id, function, args, expected]
  rows:
    - ["pp2566x001", "pathlib.PurePath.__dict__.__contains__",        ["__getattr__"], false]
    - ["pp2566x002", "pathlib.PurePath.__dict__.__contains__",        ["__setattr__"], false]
    - ["pp2566x003", "pathlib.PurePath.__dict__.__contains__",        ["__delattr__"], false]
    - ["pp2566x004", "pathlib.Path.__dict__.__contains__",            ["__getattr__"], false]
    - ["pp2566x005", "pathlib.Path.__dict__.__contains__",            ["__setattr__"], false]
    - ["pp2566x006", "pathlib.Path.__dict__.__contains__",            ["__delattr__"], false]
    - ["pp2566x007", "pathlib.PurePosixPath.__dict__.__contains__",   ["__getattr__"], false]
    - ["pp2566x008", "pathlib.PurePosixPath.__dict__.__contains__",   ["__setattr__"], false]
    - ["pp2566x009", "pathlib.PurePosixPath.__dict__.__contains__",   ["__delattr__"], false]
