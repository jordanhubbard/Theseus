# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra242
# ---------------------------------------------------------------------------

invariant abc_extra242.abc_doc_class_is_str:
  description: "abc.ABC.__doc__.__class__.__name__.__eq__('str') returns True — ABC.__doc__ is a str object (len=78); 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'; ABC.__doc__ contains 'Helper', 'ABC', 'standard', 'inheritance' but NOT 'abstract' (lowercase); ABCMeta.__doc__.__len__()==576 (much longer); abstractmethod.__doc__.__len__()==537; NEW in extra242: first standalone ABC doc class invariant in abc242doc namespace; verified with Python 3.14.3"
  category: abc_doc_contracts
  kind: python_call_eq
  function: ABC.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra242.abcmeta_doc_class_is_str:
  description: "abc.ABCMeta.__doc__.__class__.__name__.__eq__('str') returns True — ABCMeta.__doc__ is a str object (len=576); starts with 'Metaclass for defining Abstract Base Classes (ABCs).'; contains 'Abstract' (capital A), 'metaclass', 'class', 'method'; ABCMeta.__doc__.__contains__('abstract')==False (only 'Abstract' with capital A); ABC.__doc__.__len__()==78 (much shorter); NEW in extra242: first standalone ABCMeta doc class invariant; verified with Python 3.14.3"
  category: abcmeta_doc_contracts
  kind: python_call_eq
  function: ABCMeta.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra242.abstractmethod_doc_class_is_str:
  description: "abc.abstractmethod.__doc__.__class__.__name__.__eq__('str') returns True — abstractmethod.__doc__ is a str object (len=537); starts with 'A decorator indicating abstract methods.'; contains 'abstract', 'decorator', 'ABCMeta', 'Requires'; abstractmethod.__doc__.__len__()==537 is close to ABCMeta.__doc__.__len__()==576 but slightly shorter; ABC.__doc__.__len__()==78 is much shorter than both; NEW in extra242: first standalone abstractmethod doc class invariant; verified with Python 3.14.3"
  category: abstractmethod_doc_contracts
  kind: python_call_eq
  function: abstractmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
