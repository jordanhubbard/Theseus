spec: abc_extra242
version: ">=3.4"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.ABC — ABC class"
    - "https://docs.python.org/3/library/abc.html#abc.ABCMeta — ABCMeta metaclass"
    - "https://docs.python.org/3/library/abc.html#abc.abstractmethod — abstractmethod decorator"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py (internal implementation)"
    - "CPython source: Modules/_abc.c (C-level accelerators)"
  notes:
    - "This spec covers abc.ABC, abc.ABCMeta, and abc.abstractmethod __doc__ string contracts."
    - "ABC.__doc__ is a str (len=78): 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'."
    - "ABC.__doc__ contains 'Helper', 'standard', 'inheritance', 'ABC' — but NOT 'abstract'."
    - "ABCMeta.__doc__ is a str (len=576) and contains 'Abstract', 'metaclass', 'Base', 'class', 'method'."
    - "abstractmethod.__doc__ is a str (len=537) and contains 'abstract', 'decorator', 'ABCMeta', 'Requires'."
    - "ABC.__doc__.__class__.__name__ == 'str'; ABCMeta.__doc__.__class__.__name__ == 'str'; abstractmethod.__doc__.__class__.__name__ == 'str'."
    - "ABCMeta.__doc__.__contains__('abstract') == False — the doc uses 'Abstract' (capital A)."
    - "ABCMeta.__doc__.__contains__('Abstract') == True — 'Abstract Base Classes (ABCs)'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__doc__ contracts
#
# ABC.__doc__.__class__.__name__ == 'str'
# ABC.__doc__.__len__() == 78
# ABC.__doc__.__contains__('Helper') == True
# ABC.__doc__.__contains__('ABC') == True
# ABC.__doc__.__contains__('standard') == True
# ABC.__doc__.__contains__('inheritance') == True
# ---------------------------------------------------------------------------

table abc_extra242.abc_doc_contracts:
  description: "abc.ABC.__doc__ contracts — ABC.__doc__.__class__.__name__.__eq__('str')==True (doc is a str); ABC.__doc__.__len__()==78 (full text: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'); ABC.__doc__.__contains__('Helper')==True; ABC.__doc__.__contains__('ABC')==True; ABC.__doc__.__contains__('standard')==True; ABC.__doc__.__contains__('inheritance')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: abc_doc_contracts
  id_prefix: abc242doc

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_cls,      ABC.__doc__.__class__.__name__.__eq__, ["str"],         true, "abc.ABC.__doc__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [abc_doc_len,      ABC.__doc__.__len__,                   [],              78,   "abc.ABC.__doc__.__len__() == 78; verified with Python 3.14.3"]
    - [abc_doc_helper,   ABC.__doc__.__contains__,              ["Helper"],      true, "abc.ABC.__doc__.__contains__('Helper') == True; verified with Python 3.14.3"]
    - [abc_doc_abc,      ABC.__doc__.__contains__,              ["ABC"],         true, "abc.ABC.__doc__.__contains__('ABC') == True; verified with Python 3.14.3"]
    - [abc_doc_std,      ABC.__doc__.__contains__,              ["standard"],    true, "abc.ABC.__doc__.__contains__('standard') == True; verified with Python 3.14.3"]
    - [abc_doc_inherit,  ABC.__doc__.__contains__,              ["inheritance"], true, "abc.ABC.__doc__.__contains__('inheritance') == True; verified with Python 3.14.3"]

