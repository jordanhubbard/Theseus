spec: decimal_extra222
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal module __dict__ membership for all public classes, functions, exceptions, and rounding constants."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module __dict__ membership — core classes and functions
# ---------------------------------------------------------------------------

table decimal_extra222.dict_membership_core:
  description: "decimal.__dict__ contains the expected core classes and context functions"
  kind: python_call_eq
  category: module_membership
  id_prefix: decimaldictcore222

  columns: [id, function, args, expected]
  rows:
    - [decimal_present,      "__dict__.__contains__", ["Decimal"],      true]
    - [context_present,      "__dict__.__contains__", ["Context"],      true]
    - [getcontext_present,   "__dict__.__contains__", ["getcontext"],   true]
    - [setcontext_present,   "__dict__.__contains__", ["setcontext"],   true]
    - [localcontext_present, "__dict__.__contains__", ["localcontext"], true]

# ---------------------------------------------------------------------------
# decimal module __dict__ membership — exception hierarchy
# ---------------------------------------------------------------------------

table decimal_extra222.dict_membership_exceptions:
  description: "decimal.__dict__ contains the expected exception classes"
  kind: python_call_eq
  category: module_membership
  id_prefix: decimaldictexc222

  columns: [id, function, args, expected]
  rows:
    - [decimalexception_present, "__dict__.__contains__", ["DecimalException"], true]
    - [invalidoperation_present, "__dict__.__contains__", ["InvalidOperation"], true]
    - [divisionbyzero_present,   "__dict__.__contains__", ["DivisionByZero"],   true]
    - [overflow_present,         "__dict__.__contains__", ["Overflow"],         true]
    - [underflow_present,        "__dict__.__contains__", ["Underflow"],        true]
    - [inexact_present,          "__dict__.__contains__", ["Inexact"],          true]
    - [rounded_present,          "__dict__.__contains__", ["Rounded"],          true]

# ---------------------------------------------------------------------------
# decimal module __dict__ membership — rounding constants
# ---------------------------------------------------------------------------

table decimal_extra222.dict_membership_rounding:
  description: "decimal.__dict__ contains the expected rounding mode constants"
  kind: python_call_eq
  category: module_membership
  id_prefix: decimaldictround222

  columns: [id, function, args, expected]
  rows:
    - [round_half_even_present, "__dict__.__contains__", ["ROUND_HALF_EVEN"], true]
    - [round_up_present,        "__dict__.__contains__", ["ROUND_UP"],        true]
    - [round_down_present,      "__dict__.__contains__", ["ROUND_DOWN"],      true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra222.dict_contains_Decimal:
  description: "decimal.__dict__.__contains__('Decimal') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Decimal"]
  expected: true

invariant decimal_extra222.dict_contains_Context:
  description: "decimal.__dict__.__contains__('Context') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Context"]
  expected: true

invariant decimal_extra222.dict_contains_DecimalException:
  description: "decimal.__dict__.__contains__('DecimalException') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra222.dict_contains_ROUND_HALF_EVEN:
  description: "decimal.__dict__.__contains__('ROUND_HALF_EVEN') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["ROUND_HALF_EVEN"]
  expected: true
