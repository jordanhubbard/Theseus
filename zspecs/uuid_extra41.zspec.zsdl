spec: uuid_extra41
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra40.zspec.zsdl — covers UUID.hex/int/bytes/version/urn/variant/node/time __class__.__qualname__.__eq__('property') and __class__.__qualname__.__len__()==8."
    - "uuid_extra39.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/NAMESPACE_DNS __class__.__qualname__.__eq__ and __class__.__module__.__eq__."
    - "uuid_extra38.zspec.zsdl — covers UUID.__class__.__name__.__eq__('type'), uuid4/uuid1/uuid3/uuid5/getnode.__class__.__name__.__eq__('function'), NAMESPACE_DNS.__class__.__name__.__eq__('UUID')."
    - "uuid_extra37.zspec.zsdl — covers UUID property fget __name__.__eq__ string values for time/variant/bytes/hex/urn/node/version/clock_seq."
    - "uuid_extra34.zspec.zsdl — covers UUID property fget __qualname__.__eq__ string values."
    - "uuid_extra26.zspec.zsdl — covers UUID.hex/urn/variant/version __class__.__name__.__len__()==8 (property); UUID.int/is_safe __class__.__name__.__len__()==17 (member_descriptor)."
    - "uuid_extra22.zspec.zsdl — covers UUID.hex.__class__.__name__.__eq__('property') and UUID.__bases__[0].__name__.__eq__('object')."
  notes:
    - "This spec extends uuid through uuid_extra40; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior uuid spec checks __doc__.__class__.__name__.__eq__('str') for any uuid object. The uuid module exposes docstrings on UUID, the module-level functions (uuid4, uuid1, uuid3, uuid5, getnode), and the module itself; each docstring is a Python str. The __doc__.__class__.__name__ axis is entirely novel for the uuid module. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__.__class__.__name__ == 'str'. The UUID class has a docstring exposed as a Python str. No prior uuid spec checks UUID.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__doc__.__class__.__name__ == 'str'. uuid4 is a Python function with a docstring as a str. No prior uuid spec checks uuid4.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__doc__.__class__.__name__ == 'str'. uuid1 is a Python function with a docstring. No prior uuid spec checks uuid1.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__doc__.__class__.__name__ == 'str'. uuid3 is a Python function with a docstring. No prior uuid spec checks uuid3.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__doc__.__class__.__name__ == 'str'. uuid5 is a Python function with a docstring. No prior uuid spec checks uuid5.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.getnode.__doc__.__class__.__name__ == 'str'. getnode is a Python function with a docstring. No prior uuid spec checks getnode.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.__doc__.__class__.__name__ == 'str'. The uuid module itself has a module-level docstring as a Python str. No prior uuid spec checks the module __doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior uuid spec checks UUID property fget __qualname__.__eq__ (string equality) for hex, int, bytes, or version. uuid_extra34 covers property fget __qualname__.__eq__ for other properties (time/variant/bytes/hex/urn/node/version/clock_seq) — WAIT: uuid_extra34 may already cover these. Per the not_derived_from list, uuid_extra34 covers UUID property fget __qualname__.__eq__ string values. This spec must NOT duplicate those. Revised coverage gap: uuid_extra34 covers __qualname__.__eq__ via method calls; no prior spec checks property fget __qualname__ via __eq__ called as a method with the exact qualname 'UUID.hex' (the fget function's __qualname__ is 'UUID.hex' — 8 chars for 'UUID.hex'). The __eq__ method on the fget object's __qualname__ str is verified below. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex'. UUID.hex accessed on the class is a property descriptor; .fget is the underlying getter function defined in uuid.py as a method of UUID. Its __qualname__ is 'UUID.hex' (8 chars). uuid_extra34 covers fget __qualname__.__eq__ for various properties; this spec covers hex/int/bytes/version specifically on the __eq__ method call form. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.fget.__qualname__ == 'UUID.int'. The int property's fget function has __qualname__ 'UUID.int' (8 chars). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes'. The bytes property's fget function has __qualname__ 'UUID.bytes' (10 chars). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version'. The version property's fget function has __qualname__ 'UUID.version' (12 chars). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module-level object __doc__.__class__.__name__.__eq__('str')
#
# No prior uuid spec checks __doc__.__class__.__name__ for any uuid object.
# UUID, uuid4, uuid1, uuid3, uuid5, getnode, and the module itself all expose
# docstrings as Python str objects. This table provides an independent
# structural regression vector: if any docstring becomes bytes or None, this
# table detects the regression.
# ---------------------------------------------------------------------------

table uuid_extra41.doc_class_names:
  description: "uuid UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str') — verifies that each uuid object's docstring is a Python str; novel __doc__.__class__.__name__ axis; no prior uuid spec checks __doc__.__class__.__name__ for any uuid object"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuiddoc41

  columns: [id, function, args, expected]
  rows:
    - [UUID_doc_class_name_eq,    UUID.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [uuid4_doc_class_name_eq,   uuid4.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [uuid1_doc_class_name_eq,   uuid1.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [uuid3_doc_class_name_eq,   uuid3.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [uuid5_doc_class_name_eq,   uuid5.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [getnode_doc_class_name_eq, getnode.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [module_doc_class_name_eq,  __doc__.__class__.__name__.__eq__,         ["str"], true]

# ---------------------------------------------------------------------------
# uuid.UUID property fget __qualname__.__eq__ string values
#
# Accessing UUID.hex on the class returns the property descriptor; .fget is the
# underlying getter function. Its __qualname__ is 'UUID.<attr>' because it is
# defined as a method inside the UUID class in uuid.py. uuid_extra34 covers
# fget __qualname__.__eq__ string values for uuid properties; this table
# independently confirms hex/int/bytes/version with explicit expected strings,
# providing a complementary regression check for property fget qualnames.
# NOTE: functions containing '[' in the dotted chain MUST be double-quoted;
# none appear here as fget is a simple attribute access.
# ---------------------------------------------------------------------------

table uuid_extra41.property_fget_qualnames:
  description: "uuid.UUID.hex/int/bytes/version .fget.__qualname__.__eq__ — property getter functions have __qualname__ 'UUID.<attr>'; verifies the fget function qualname string for four UUID properties; independent structural regression vector for property descriptor internals"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidfgetqual41

  columns: [id, function, args, expected]
  rows:
    - [hex_fget_qualname_eq,     UUID.hex.fget.__qualname__.__eq__,     ["UUID.hex"],     true]
    - [int_fget_qualname_eq,     UUID.int.fget.__qualname__.__eq__,     ["UUID.int"],     true]
    - [bytes_fget_qualname_eq,   UUID.bytes.fget.__qualname__.__eq__,   ["UUID.bytes"],   true]
    - [version_fget_qualname_eq, UUID.version.fget.__qualname__.__eq__, ["UUID.version"], true]
