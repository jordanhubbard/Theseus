spec: struct_extra63
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra62.zspec.zsdl — covers Struct.pack/__qualname__/__len__()==11 / Struct.unpack/__qualname__/__len__()==13 / Struct.pack_into/__qualname__/__len__()==16 / Struct.unpack_from/__qualname__/__len__()==18 / Struct.iter_unpack/__qualname__/__len__()==18 / Struct.pack/__qualname__.__eq__('Struct.pack') / Struct.unpack/__qualname__.__eq__('Struct.unpack') / Struct.pack_into/__qualname__.__eq__('Struct.pack_into') / struct.__name__.__eq__('struct') / struct.__spec__.name.__eq__('struct') / Struct.pack/__class__/__name__=='method_descriptor' / Struct.unpack/__class__/__name__=='method_descriptor' (table + invariants)."
    - "struct_extra61.zspec.zsdl — covers struct.Struct.__name__=='Struct' / Struct.__module__=='_struct' / Struct.__qualname__=='Struct' / Struct.__bases__[0].__name__=='object' / Struct.__mro__.__len__()==2 (table + invariants)."
    - "struct_extra60.zspec.zsdl — covers struct.error.__bases__[0].__name__=='Exception' / error.__mro__.__len__()==4 (table + invariants)."
    - "struct_extra8.zspec.zsdl — covers function __module__ (all '_struct' except error 'struct')."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra62; it does NOT duplicate invariants present in those files."
    - "Wave 234 theme: module-level C function __qualname__ and __module__ identity + Struct.unpack_from and Struct.iter_unpack __qualname__ equality + module-level C function class identity."
    - "struct.pack.__qualname__ == 'pack' — struct.pack is a module-level C builtin function; in Python 3.3+ C builtins have __qualname__ equal to __name__; __qualname__ is 'pack'. No prior struct spec checks pack.__qualname__.__eq__('pack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack' — same reasoning as pack; __qualname__ is 'unpack'. No prior struct spec checks unpack.__qualname__.__eq__('unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize' — same reasoning; __qualname__ is 'calcsize'. No prior struct spec checks calcsize.__qualname__.__eq__('calcsize'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == 'struct' — struct.pack is exposed in the struct module namespace; __module__ is 'struct'. No prior struct spec checks pack.__module__.__eq__('struct') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__ == 'struct' — same reasoning; __module__ is 'struct'. No prior struct spec checks unpack.__module__.__eq__('struct') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__module__ == 'struct' — same reasoning; __module__ is 'struct'. No prior struct spec checks calcsize.__module__.__eq__('struct') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' — struct_extra62 covers __qualname__.__len__()==18 for unpack_from; this spec covers the __qualname__.__eq__ form (new axis). No prior struct spec checks Struct.unpack_from.__qualname__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' — struct_extra62 covers __qualname__.__len__()==18 for iter_unpack; this spec covers the __qualname__.__eq__ form (new axis). No prior struct spec checks Struct.iter_unpack.__qualname__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method' — struct.pack is a C builtin function exposed at module level; its class is 'builtin_function_or_method'. No prior struct spec checks pack.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__class__.__name__ == 'builtin_function_or_method' — same reasoning. No prior struct spec checks unpack.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' — same reasoning. No prior struct spec checks calcsize.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level C function __qualname__ equality
#
# Wave 234 theme: struct.pack / unpack / calcsize __qualname__ string values.
#
# struct.pack, struct.unpack, and struct.calcsize are C builtin functions
# exposed at module level. In Python 3.3+ C builtins have __qualname__ equal
# to __name__ for module-level functions. __qualname__ is 'pack', 'unpack',
# and 'calcsize' respectively. No prior struct spec checks __qualname__.__eq__
# for pack, unpack, or calcsize. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra63.module_level_function_qualnames:
  description: "struct.pack/__qualname__.__eq__('pack')==True / struct.unpack/__qualname__.__eq__('unpack')==True / struct.calcsize/__qualname__.__eq__('calcsize')==True — pack/unpack/calcsize are C builtin functions at module level; in Python 3.3+ module-level C builtins have __qualname__==__name__; no prior struct spec checks pack/unpack/calcsize __qualname__.__eq__; first module-level function qualname equality anchor for struct"
  kind: python_call_eq
  category: qualnames
  id_prefix: structfunc63

  columns: [id, function, args, expected]
  rows:
    - [pack_qualname_eq_pack,         pack.__qualname__.__eq__,      ["pack"],      true]
    - [unpack_qualname_eq_unpack,     unpack.__qualname__.__eq__,    ["unpack"],    true]
    - [calcsize_qualname_eq_calcsize, calcsize.__qualname__.__eq__,  ["calcsize"],  true]

# ---------------------------------------------------------------------------
# struct module-level C function __module__ equality
#
# Wave 234 theme: struct.pack / unpack / calcsize __module__ == 'struct'.
#
# struct.pack, struct.unpack, and struct.calcsize are exposed in the struct
# module namespace. Their __module__ attribute is 'struct'. No prior struct
# spec checks pack/__module__.__eq__('struct'), unpack/__module__.__eq__, or
# calcsize/__module__.__eq__ in call form. struct_extra8 covers __module__ on
# the attribute-read (non-call) axis. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table struct_extra63.module_level_function_modules:
  description: "struct.pack/__module__.__eq__('struct')==True / struct.unpack/__module__.__eq__('struct')==True / struct.calcsize/__module__.__eq__('struct')==True — pack/unpack/calcsize are module-level C builtins exposed in the struct namespace; __module__ is 'struct'; struct_extra8 covers __module__ on the attribute-read axis; this spec adds the call form; no prior struct spec checks pack/unpack/calcsize __module__.__eq__ in call form; first __module__ call-form anchor for struct module-level functions"
  kind: python_call_eq
  category: module_identity
  id_prefix: structfunc63

  columns: [id, function, args, expected]
  rows:
    - [pack_module_eq_struct,     pack.__module__.__eq__,     ["struct"], true]
    - [unpack_module_eq_struct,   unpack.__module__.__eq__,   ["struct"], true]
    - [calcsize_module_eq_struct, calcsize.__module__.__eq__, ["struct"], true]

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from and Struct.iter_unpack __qualname__ equality
#
# Wave 234 theme: Struct.unpack_from and Struct.iter_unpack __qualname__ eq.
#
# struct_extra62 covers __qualname__.__len__()==18 for both unpack_from and
# iter_unpack. This spec adds the __qualname__.__eq__ call form for these two
# methods, which is a distinct axis not covered by any prior struct spec.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra63.Struct_method_qualname_eq_extended:
  description: "Struct.unpack_from/__qualname__.__eq__('Struct.unpack_from')==True / Struct.iter_unpack/__qualname__.__eq__('Struct.iter_unpack')==True — struct_extra62 covers __qualname__.__len__()==18 for both; this spec adds the __eq__ call form (new axis); no prior struct spec checks Struct.unpack_from/__qualname__.__eq__ or Struct.iter_unpack/__qualname__.__eq__; first qualname equality anchor for Struct.unpack_from and Struct.iter_unpack"
  kind: python_call_eq
  category: qualnames
  id_prefix: structfunc63

  columns: [id, function, args, expected]
  rows:
    - [Struct_unpack_from_qualname_eq,  Struct.unpack_from.__qualname__.__eq__,  ["Struct.unpack_from"],  true]
    - [Struct_iter_unpack_qualname_eq,  Struct.iter_unpack.__qualname__.__eq__,  ["Struct.iter_unpack"],  true]

# ---------------------------------------------------------------------------
# struct module-level C function __class__.__name__ == 'builtin_function_or_method'
#
# Wave 234 theme: struct.pack / unpack / calcsize class identity.
#
# struct.pack, struct.unpack, and struct.calcsize are module-level C builtin
# functions. Their __class__.__name__ is 'builtin_function_or_method'. No prior
# struct spec checks pack/__class__.__name__, unpack/__class__.__name__, or
# calcsize/__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table struct_extra63.struct_function_class_names:
  description: "struct.pack/__class__/__name__=='builtin_function_or_method' / struct.unpack/__class__/__name__=='builtin_function_or_method' / struct.calcsize/__class__/__name__=='builtin_function_or_method' — pack/unpack/calcsize are module-level C builtin functions; their class is 'builtin_function_or_method'; no prior struct spec checks __class__/__name__ for pack/unpack/calcsize; first C builtin class identity anchor for struct module-level functions"
  kind: python_call_eq
  category: class_identity
  id_prefix: structfunc63

  columns: [id, function, args, expected]
  rows:
    - [pack_class_builtin_function,     pack.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [unpack_class_builtin_function,   unpack.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [calcsize_class_builtin_function, calcsize.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack') — standalone
#
# struct.pack is a C builtin function exposed at module level in the struct
# namespace. In Python 3.3+ module-level C builtins have __qualname__ equal
# to __name__. __qualname__ is 'pack'. No prior struct spec checks
# pack.__qualname__.__eq__. First qualname equality anchor for struct.pack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra63.pack_qualname_pack:
  description: "struct.pack.__qualname__.__eq__('pack') == True — pack is a module-level C builtin; __qualname__=='pack' (equals __name__); no prior struct spec checks pack.__qualname__.__eq__; first qualname equality anchor for struct.pack"
  category: qualnames
  kind: python_call_eq
  function: pack.__qualname__.__eq__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack.__qualname__.__eq__('unpack') — standalone
#
# struct.unpack is a C builtin function at module level. __qualname__ is
# 'unpack'. No prior struct spec checks unpack.__qualname__.__eq__. First
# qualname equality anchor for struct.unpack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra63.unpack_qualname_unpack:
  description: "struct.unpack.__qualname__.__eq__('unpack') == True — unpack is a module-level C builtin; __qualname__=='unpack'; no prior struct spec checks unpack.__qualname__.__eq__; first qualname equality anchor for struct.unpack"
  category: qualnames
  kind: python_call_eq
  function: unpack.__qualname__.__eq__
  args: ["unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__module__.__eq__('struct') — standalone
#
# struct.pack is exposed in the struct module namespace. __module__ is 'struct'.
# struct_extra8 covers __module__ on the attribute-read axis. This standalone
# confirms pack.__module__.__eq__('struct') in call form. No prior struct spec
# checks pack.__module__.__eq__. First __module__ call-form anchor for struct.pack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra63.pack_module_struct:
  description: "struct.pack.__module__.__eq__('struct') == True — pack is a module-level C builtin in the struct namespace; __module__ is 'struct'; struct_extra8 covers __module__ on attribute-read axis; this standalone adds the call form; no prior struct spec checks pack.__module__.__eq__; first __module__ call-form anchor for struct.pack"
  category: module_identity
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') — standalone
#
# struct.Struct.unpack_from is a C method descriptor on the Struct type. Its
# __qualname__ is 'Struct.unpack_from'. struct_extra62 covers the __len__==18
# axis; this standalone confirms the __eq__ form. No prior struct spec checks
# Struct.unpack_from.__qualname__.__eq__. First qualname equality standalone
# for struct.Struct.unpack_from. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra63.Struct_unpack_from_qualname:
  description: "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — Struct.unpack_from is a C method descriptor; __qualname__ is 'Struct.unpack_from'; struct_extra62 covers __qualname__.__len__()==18; this standalone adds the __eq__ form; no prior struct spec checks Struct.unpack_from.__qualname__.__eq__; first qualname equality standalone for struct.Struct.unpack_from"
  category: qualnames
  kind: python_call_eq
  function: Struct.unpack_from.__qualname__.__eq__
  args: ["Struct.unpack_from"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.pack is a module-level C builtin function. Its __class__.__name__ is
# 'builtin_function_or_method'. No prior struct spec checks
# pack.__class__.__name__. First C builtin class identity standalone for
# struct.pack. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra63.pack_class_builtin:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — pack is a module-level C builtin function; its class is 'builtin_function_or_method'; no prior struct spec checks pack.__class__.__name__; first C builtin class identity standalone for struct.pack"
  category: class_identity
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
