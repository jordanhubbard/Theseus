spec: io_extra258
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers io.BufferedReader and io.TextIOWrapper method identity: __name__, __qualname__, and __class__.__name__."
    - "All io.BufferedReader methods (read, read1, peek, readline, seek, tell) are C-level method_descriptor objects; their __class__.__name__ is 'method_descriptor'."
    - "All io.TextIOWrapper methods (read, readline, write) are C-level method_descriptor objects; their __class__.__name__ is 'method_descriptor'."
    - "io.TextIOWrapper.encoding is a member_descriptor (type(io.TextIOWrapper.encoding).__name__ == 'member_descriptor')."
    - "io.TextIOWrapper.errors is a getset_descriptor (type(io.TextIOWrapper.errors).__name__ == 'getset_descriptor')."
    - "io.BufferedReader.read.__qualname__ == 'BufferedReader.read'; all BufferedReader methods use the 'BufferedReader.' prefix."
    - "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read'; all TextIOWrapper methods use the 'TextIOWrapper.' prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.BufferedReader method __name__ identity
#
# read, read1, peek, readline, seek, tell are all method_descriptor objects
# implemented in the _io C extension. Their __name__ values match the method
# name exactly.
# ---------------------------------------------------------------------------

table io_extra258.bufferedreader_method_names:
  description: "io.BufferedReader method __name__ identity — read, read1, peek, readline, seek, tell; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: ioxbrmn258

  columns: [id, function, args, expected, description]
  rows:
    - [read_name,
       "BufferedReader.read.__name__.__eq__",
       ["read"],
       true,
       "io.BufferedReader.read.__name__.__eq__('read') == True — BufferedReader.read is a method_descriptor for reading and returning up to n bytes; its __name__ is 'read'; str.__eq__('read') returns True; new to extra258"]
    - [read1_name,
       "BufferedReader.read1.__name__.__eq__",
       ["read1"],
       true,
       "io.BufferedReader.read1.__name__.__eq__('read1') == True — BufferedReader.read1 is a method_descriptor for reading up to n bytes with at most one raw read call; its __name__ is 'read1'; str.__eq__('read1') returns True; new to extra258"]
    - [peek_name,
       "BufferedReader.peek.__name__.__eq__",
       ["peek"],
       true,
       "io.BufferedReader.peek.__name__.__eq__('peek') == True — BufferedReader.peek is a method_descriptor for returning buffered bytes without advancing the position; its __name__ is 'peek'; str.__eq__('peek') returns True; new to extra258"]
    - [readline_name,
       "BufferedReader.readline.__name__.__eq__",
       ["readline"],
       true,
       "io.BufferedReader.readline.__name__.__eq__('readline') == True — BufferedReader.readline is a method_descriptor for reading up to the next newline or n bytes; its __name__ is 'readline'; str.__eq__('readline') returns True; new to extra258"]
    - [seek_name,
       "BufferedReader.seek.__name__.__eq__",
       ["seek"],
       true,
       "io.BufferedReader.seek.__name__.__eq__('seek') == True — BufferedReader.seek is a method_descriptor for repositioning the stream; its __name__ is 'seek'; str.__eq__('seek') returns True; new to extra258"]
    - [tell_name,
       "BufferedReader.tell.__name__.__eq__",
       ["tell"],
       true,
       "io.BufferedReader.tell.__name__.__eq__('tell') == True — BufferedReader.tell is a method_descriptor for returning the current stream position; its __name__ is 'tell'; str.__eq__('tell') returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Table 2: io.BufferedReader method __qualname__ identity
#
# All BufferedReader methods are defined directly on BufferedReader, so their
# __qualname__ values carry the 'BufferedReader.' prefix.
# ---------------------------------------------------------------------------

table io_extra258.bufferedreader_method_qualnames:
  description: "io.BufferedReader method __qualname__ identity — all use 'BufferedReader.' prefix; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: ioxbrmq258

  columns: [id, function, args, expected, description]
  rows:
    - [read_qualname,
       "BufferedReader.read.__qualname__.__eq__",
       ["BufferedReader.read"],
       true,
       "io.BufferedReader.read.__qualname__.__eq__('BufferedReader.read') == True — BufferedReader.read is defined directly on BufferedReader; its __qualname__ is 'BufferedReader.read'; str.__eq__('BufferedReader.read') returns True; new to extra258"]
    - [read1_qualname,
       "BufferedReader.read1.__qualname__.__eq__",
       ["BufferedReader.read1"],
       true,
       "io.BufferedReader.read1.__qualname__.__eq__('BufferedReader.read1') == True — BufferedReader.read1 is defined directly on BufferedReader; its __qualname__ is 'BufferedReader.read1'; str.__eq__('BufferedReader.read1') returns True; new to extra258"]
    - [peek_qualname,
       "BufferedReader.peek.__qualname__.__eq__",
       ["BufferedReader.peek"],
       true,
       "io.BufferedReader.peek.__qualname__.__eq__('BufferedReader.peek') == True — BufferedReader.peek is defined directly on BufferedReader; its __qualname__ is 'BufferedReader.peek'; str.__eq__('BufferedReader.peek') returns True; new to extra258"]
    - [readline_qualname,
       "BufferedReader.readline.__qualname__.__eq__",
       ["BufferedReader.readline"],
       true,
       "io.BufferedReader.readline.__qualname__.__eq__('BufferedReader.readline') == True — BufferedReader.readline is defined directly on BufferedReader; its __qualname__ is 'BufferedReader.readline'; str.__eq__('BufferedReader.readline') returns True; new to extra258"]
    - [seek_qualname,
       "BufferedReader.seek.__qualname__.__eq__",
       ["BufferedReader.seek"],
       true,
       "io.BufferedReader.seek.__qualname__.__eq__('BufferedReader.seek') == True — BufferedReader.seek is defined directly on BufferedReader; its __qualname__ is 'BufferedReader.seek'; str.__eq__('BufferedReader.seek') returns True; new to extra258"]
    - [tell_qualname,
       "BufferedReader.tell.__qualname__.__eq__",
       ["BufferedReader.tell"],
       true,
       "io.BufferedReader.tell.__qualname__.__eq__('BufferedReader.tell') == True — BufferedReader.tell is defined directly on BufferedReader; its __qualname__ is 'BufferedReader.tell'; str.__eq__('BufferedReader.tell') returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Table 3: io.BufferedReader method __class__.__name__ — all are method_descriptor
# ---------------------------------------------------------------------------

table io_extra258.bufferedreader_method_class_names:
  description: "io.BufferedReader method __class__.__name__ — all are 'method_descriptor'; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: ioxbrmcn258

  columns: [id, function, args, expected, description]
  rows:
    - [read_class,
       "BufferedReader.read.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedReader.read.__class__.__name__.__eq__('method_descriptor') == True — BufferedReader.read is a C-level method_descriptor, not a Python function or wrapper_descriptor; str.__eq__('method_descriptor') returns True; new to extra258"]
    - [read1_class,
       "BufferedReader.read1.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedReader.read1.__class__.__name__.__eq__('method_descriptor') == True — BufferedReader.read1 is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra258"]
    - [peek_class,
       "BufferedReader.peek.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedReader.peek.__class__.__name__.__eq__('method_descriptor') == True — BufferedReader.peek is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra258"]
    - [seek_class,
       "BufferedReader.seek.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedReader.seek.__class__.__name__.__eq__('method_descriptor') == True — BufferedReader.seek is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra258"]
    - [tell_class,
       "BufferedReader.tell.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedReader.tell.__class__.__name__.__eq__('method_descriptor') == True — BufferedReader.tell is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra258"]
    - [readline_class,
       "BufferedReader.readline.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedReader.readline.__class__.__name__.__eq__('method_descriptor') == True — BufferedReader.readline is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Table 4: io.TextIOWrapper method __name__ identity
#
# read, readline, write are method_descriptor objects on TextIOWrapper.
# encoding is a member_descriptor; errors is a getset_descriptor.
# ---------------------------------------------------------------------------

table io_extra258.textiowrapper_method_names:
  description: "io.TextIOWrapper method __name__ identity — read, readline, write; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: ioxtwmn258

  columns: [id, function, args, expected, description]
  rows:
    - [read_name,
       "TextIOWrapper.read.__name__.__eq__",
       ["read"],
       true,
       "io.TextIOWrapper.read.__name__.__eq__('read') == True — TextIOWrapper.read is a method_descriptor for reading and decoding up to n characters; its __name__ is 'read'; str.__eq__('read') returns True; new to extra258"]
    - [readline_name,
       "TextIOWrapper.readline.__name__.__eq__",
       ["readline"],
       true,
       "io.TextIOWrapper.readline.__name__.__eq__('readline') == True — TextIOWrapper.readline is a method_descriptor for reading up to the next newline or n characters; its __name__ is 'readline'; str.__eq__('readline') returns True; new to extra258"]
    - [write_name,
       "TextIOWrapper.write.__name__.__eq__",
       ["write"],
       true,
       "io.TextIOWrapper.write.__name__.__eq__('write') == True — TextIOWrapper.write is a method_descriptor for encoding and writing a string to the underlying buffer; its __name__ is 'write'; str.__eq__('write') returns True; new to extra258"]
    - [read_qualname,
       "TextIOWrapper.read.__qualname__.__eq__",
       ["TextIOWrapper.read"],
       true,
       "io.TextIOWrapper.read.__qualname__.__eq__('TextIOWrapper.read') == True — TextIOWrapper.read is defined directly on TextIOWrapper; its __qualname__ is 'TextIOWrapper.read'; str.__eq__('TextIOWrapper.read') returns True; new to extra258"]
    - [readline_qualname,
       "TextIOWrapper.readline.__qualname__.__eq__",
       ["TextIOWrapper.readline"],
       true,
       "io.TextIOWrapper.readline.__qualname__.__eq__('TextIOWrapper.readline') == True — TextIOWrapper.readline is defined directly on TextIOWrapper; its __qualname__ is 'TextIOWrapper.readline'; str.__eq__('TextIOWrapper.readline') returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Table 5: io.TextIOWrapper descriptor __class__.__name__ identity
#
# encoding is a member_descriptor; errors is a getset_descriptor.
# These are data descriptors stored on the class object itself.
# ---------------------------------------------------------------------------

table io_extra258.textiowrapper_descriptor_class_names:
  description: "io.TextIOWrapper attribute descriptor __class__.__name__ — encoding is member_descriptor, errors is getset_descriptor; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: ioxtwdcn258

  columns: [id, function, args, expected, description]
  rows:
    - [encoding_class,
       "TextIOWrapper.encoding.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "io.TextIOWrapper.encoding.__class__.__name__.__eq__('member_descriptor') == True — TextIOWrapper.encoding is a C-level member_descriptor, which provides direct struct member access; its __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra258"]
    - [errors_class,
       "TextIOWrapper.errors.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "io.TextIOWrapper.errors.__class__.__name__.__eq__('getset_descriptor') == True — TextIOWrapper.errors is a C-level getset_descriptor, which uses getter/setter functions rather than direct struct access; its __class__.__name__ is 'getset_descriptor'; str.__eq__('getset_descriptor') returns True; new to extra258"]
    - [read_class,
       "TextIOWrapper.read.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.TextIOWrapper.read.__class__.__name__.__eq__('method_descriptor') == True — TextIOWrapper.read is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra258"]
    - [write_class,
       "TextIOWrapper.write.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.TextIOWrapper.write.__class__.__name__.__eq__('method_descriptor') == True — TextIOWrapper.write is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra258"]
    - [write_qualname,
       "TextIOWrapper.write.__qualname__.__eq__",
       ["TextIOWrapper.write"],
       true,
       "io.TextIOWrapper.write.__qualname__.__eq__('TextIOWrapper.write') == True — TextIOWrapper.write is defined directly on TextIOWrapper; its __qualname__ is 'TextIOWrapper.write'; str.__eq__('TextIOWrapper.write') returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Standalone invariants — io_extra258
# ---------------------------------------------------------------------------

invariant io_extra258.bufferedreader_read_name:
  description: "io.BufferedReader.read.__name__ == 'read' — BufferedReader.read is a C-level method_descriptor; new to extra258"
  kind: python_call_eq
  function: BufferedReader.read.__name__.__eq__
  args: ["read"]
  expected: true

invariant io_extra258.bufferedreader_read1_name:
  description: "io.BufferedReader.read1.__name__ == 'read1' — BufferedReader.read1 reads with at most one raw read call; new to extra258"
  kind: python_call_eq
  function: BufferedReader.read1.__name__.__eq__
  args: ["read1"]
  expected: true

invariant io_extra258.bufferedreader_read_qualname:
  description: "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' — read is defined directly on BufferedReader; new to extra258"
  kind: python_call_eq
  function: BufferedReader.read.__qualname__.__eq__
  args: ["BufferedReader.read"]
  expected: true

invariant io_extra258.bufferedreader_read_is_method_descriptor:
  description: "io.BufferedReader.read.__class__.__name__ == 'method_descriptor' — all BufferedReader methods are C-level method_descriptors; new to extra258"
  kind: python_call_eq
  function: BufferedReader.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra258.textiowrapper_write_name:
  description: "io.TextIOWrapper.write.__name__ == 'write' — TextIOWrapper.write encodes and writes a string to the buffer; new to extra258"
  kind: python_call_eq
  function: TextIOWrapper.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant io_extra258.textiowrapper_encoding_is_member_descriptor:
  description: "io.TextIOWrapper.encoding.__class__.__name__ == 'member_descriptor' — encoding exposes a C struct member directly; new to extra258"
  kind: python_call_eq
  function: TextIOWrapper.encoding.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant io_extra258.textiowrapper_errors_is_getset_descriptor:
  description: "io.TextIOWrapper.errors.__class__.__name__ == 'getset_descriptor' — errors uses C getter/setter functions; new to extra258"
  kind: python_call_eq
  function: TextIOWrapper.errors.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true
