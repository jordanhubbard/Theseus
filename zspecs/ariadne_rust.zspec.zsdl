spec: ariadne_rust
version: ">=3.9"
backend: rust_module(ariadne_rust)

docs: https://ariadnegraphql.org/

provenance:
  derived_from:
    - "https://ariadnegraphql.org/ — Ariadne GraphQL"
  notes:
    - "Ariadne provides schema-first GraphQL for Python."
    - "ariadne.make_executable_schema is callable."
    - "ariadne.QueryType is a class."
    - "ariadne.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant ariadne_rust.has_make_executable_schema:
  description: "ariadne.make_executable_schema is callable"
  category: presence
  kind: python_call_eq
  function: ariadne_has_make_executable_schema
  args: []
  expected: true

invariant ariadne_rust.has_query_type:
  description: "ariadne.QueryType is a class"
  category: presence
  kind: python_call_eq
  function: ariadne_has_query_type
  args: []
  expected: true

invariant ariadne_rust.version_nonempty:
  description: "ariadne.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: ariadne_version_nonempty
  args: []
  expected: true

