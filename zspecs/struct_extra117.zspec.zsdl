spec: struct_extra117
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra116.zspec.zsdl — covers Struct.__new__/__sizeof__/__reduce__/__reduce_ex__ bare __name__ equality/length (table + invariants)."
    - "struct_extra112.zspec.zsdl — covers Struct.__new__/__repr__/__sizeof__/__reduce_ex__/__reduce__ __qualname__.__eq__ and __qualname__.__len__() / __new__/__sizeof__/__reduce__ __class__.__name__.__eq__ (table + invariants)."
    - "struct_extra101.zspec.zsdl — covers Struct.__init__.__qualname__.__eq__('Struct.__init__') / Struct.__init__.__qualname__.__len__()==15 / Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct.__hash__.__class__.__name__.__eq__('wrapper_descriptor') / Struct.__eq__.__class__.__name__.__eq__('wrapper_descriptor') as table rows (table + invariants)."
    - "struct_extra115.zspec.zsdl — covers Struct.__doc__.__class__.__name__.__eq__('str') as a table row."
  notes:
    - "This spec extends struct through struct_extra116; it does NOT duplicate invariants present in those files."
    - "Wave 281 theme: Struct.__hash__ and __eq__ qualnames and bare names not yet covered — extra112 anchors __new__/__repr__/__sizeof__/__reduce_ex__/__reduce__ qualnames; extra101 anchors __init__ qualname; extra94 anchors Struct.__hash__ and Struct.__eq__ __class__.__name__.__eq__('wrapper_descriptor'); NOT YET covered: __hash__.__qualname__.__eq__('object.__hash__') and __len__()==15; __eq__.__qualname__.__eq__('object.__eq__') and __len__()==13; __hash__.__name__.__eq__('__hash__') and __len__()==8; __eq__.__name__.__eq__('__eq__') and __len__()==6; Struct.__doc__.__class__.__module__.__eq__('builtins')."
    - "struct.Struct.__hash__.__qualname__ == 'object.__hash__'. len('object.__hash__')==15. Struct inherits __hash__ from object (no custom __hash__); qualname reflects the defining class ('object'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__eq__.__qualname__ == 'object.__eq__'. len('object.__eq__')==13. Struct inherits __eq__ from object; qualname reflects the defining class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__hash__.__name__ == '__hash__'. len('__hash__')==8. The bare __name__ stores only the method name (no class prefix). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__eq__.__name__ == '__eq__'. len('__eq__')==6. Shortest dunder name in this spec (6 chars: '__'=2 + 'eq'=2 + '__'=2). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__module__ == 'builtins'. len('builtins')==8. Struct.__doc__ is a Python str; str type __module__ is 'builtins'. extra115 anchors __doc__.__class__.__name__.__eq__('str'); no prior spec anchors __doc__.__class__.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct.__hash__ and Struct.__eq__ are wrapper_descriptor objects inherited from object. Their __qualname__ includes the defining class prefix 'object.' (e.g., 'object.__hash__'), while their bare __name__ has no prefix (e.g., '__hash__'). The qualname lengths are 15 for __hash__ and 13 for __eq__ — a difference of 2 that reflects len('__hash__')-len('__eq__')==8-6==2 (the body of __hash__ is 2 chars longer than 'eq'). Also, 'object.__hash__'=15 coincidentally equals 'Struct.__init__'=15 and 'Struct.__repr__'=15. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__hash__.__qualname__.__eq__('object.__hash__') == True
# struct.Struct.__hash__.__qualname__.__len__() == 15
# struct.Struct.__eq__.__qualname__.__eq__('object.__eq__') == True
# struct.Struct.__eq__.__qualname__.__len__() == 13
# struct.Struct.__doc__.__class__.__module__.__eq__('builtins') == True
#
# Wave 281 theme: Struct inherited __hash__ and __eq__ qualnames.
#
# Struct is a C extension type that does not define __eq__ or __hash__ explicitly;
# both are inherited from object. Their __qualname__ includes the defining class prefix:
# 'object.__hash__' (15 chars) and 'object.__eq__' (13 chars). extra112 anchors
# qualnames for __new__/__repr__/__sizeof__/__reduce__/__reduce_ex__ but NOT __hash__ or
# __eq__. extra101 anchors __init__ qualname (15 chars). The qualname 'object.__hash__'
# coincidentally has the same length (15) as 'Struct.__init__' and 'Struct.__repr__'.
# No prior struct spec anchors __hash__ or __eq__ qualname values or lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra117.Struct_hash_and_eq_qualnames:
  description: "Struct.__hash__.__qualname__.__eq__('object.__hash__')==True / Struct.__hash__.__qualname__.__len__()==15 / Struct.__eq__.__qualname__.__eq__('object.__eq__')==True / Struct.__eq__.__qualname__.__len__()==13 / Struct.__doc__.__class__.__module__.__eq__('builtins')==True — inherited __hash__/__eq__ have qualnames with 'object.' prefix reflecting defining class; len 15 for __hash__ qualname coincides with 'Struct.__init__'=15 (extra101); len 13 for __eq__ qualname; extra94 anchors class names; no prior spec anchors qualnames or lengths for __hash__/__eq__; first structslot117 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structslot117

  columns: [id, function, args, expected, description]
  rows:
    - [hash_qualname_eq,    "Struct.__hash__.__qualname__.__eq__",    ["object.__hash__"], true, "Struct.__hash__.__qualname__ is 'object.__hash__' (inherited from object; qualname includes defining class prefix; extra94 anchors class name; no prior spec anchors qualname eq)"]
    - [hash_qualname_len,   "Struct.__hash__.__qualname__.__len__",   [],                  15,   "Struct.__hash__.__qualname__.__len__() is 15 (len('object.__hash__')==15; coincidentally same as len('Struct.__init__')==15 and len('Struct.__repr__')==15)"]
    - [eq_qualname_eq,      "Struct.__eq__.__qualname__.__eq__",      ["object.__eq__"],   true, "Struct.__eq__.__qualname__ is 'object.__eq__' (inherited from object; qualname includes defining class prefix; extra94 anchors class name; no prior spec anchors qualname eq)"]
    - [eq_qualname_len,     "Struct.__eq__.__qualname__.__len__",     [],                  13,   "Struct.__eq__.__qualname__.__len__() is 13 (len('object.__eq__')==13; 2 chars shorter than __hash__ qualname=15, mirroring '__hash__' > '__eq__' length difference)"]
    - [doc_cls_mod_eq,      "Struct.__doc__.__class__.__module__.__eq__", ["builtins"],    true, "Struct.__doc__.__class__.__module__ is 'builtins' (Struct has a str docstring; str type __module__=='builtins'; extra115 anchors __doc__.__class__.__name__.__eq__('str'); no prior spec anchors __module__)"]

# ---------------------------------------------------------------------------
# struct.Struct.__hash__.__name__.__eq__('__hash__') == True
# struct.Struct.__hash__.__name__.__len__() == 8
# struct.Struct.__eq__.__name__.__eq__('__eq__') == True
# struct.Struct.__eq__.__name__.__len__() == 6
# struct.Struct.__doc__.__class__.__module__.__len__() == 8
#
# Wave 281 theme: Struct inherited __hash__ and __eq__ bare names.
#
# The bare __name__ of a method descriptor stores only the method name without
# the class prefix. Struct.__hash__.__name__ is '__hash__' (8 chars) and
# Struct.__eq__.__name__ is '__eq__' (6 chars). extra116 anchors bare names for
# __new__/__sizeof__/__reduce__/__reduce_ex__; extra40 anchors __init__ bare name.
# No prior struct spec anchors the bare __name__ values or lengths for __hash__
# or __eq__. '__eq__' (6 chars) is the shortest dunder name in this spec.
# Struct.__doc__.__class__.__module__.__len__()==8 (len('builtins')==8).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra117.Struct_hash_and_eq_bare_names:
  description: "Struct.__hash__.__name__.__eq__('__hash__')==True / Struct.__hash__.__name__.__len__()==8 / Struct.__eq__.__name__.__eq__('__eq__')==True / Struct.__eq__.__name__.__len__()==6 / Struct.__doc__.__class__.__module__.__len__()==8 — bare __name__ for inherited __hash__ and __eq__ (no class prefix); '__hash__'=8 chars; '__eq__'=6 chars (shortest dunder in this spec); coincidence: __hash__ bare name len 8 equals doc class module len 8 ('builtins'); extra94 anchors class names; extra116 anchors bare names for other methods; no prior spec anchors __hash__/__eq__ bare names; first structslot117 bare-name anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structslot117

  columns: [id, function, args, expected, description]
  rows:
    - [hash_name_eq,       "Struct.__hash__.__name__.__eq__",      ["__hash__"], true, "Struct.__hash__.__name__ is '__hash__' (bare method name; no class prefix; qualname is 'object.__hash__' with prefix; extra94 anchors class name; no prior spec anchors __hash__ bare name)"]
    - [hash_name_len,      "Struct.__hash__.__name__.__len__",     [],           8,    "Struct.__hash__.__name__.__len__() is 8 (len('__hash__')==8; '__'=2 + 'hash'=4 + '__'=2; same length as len('builtins')==8 — coincidence)"]
    - [eq_name_eq,         "Struct.__eq__.__name__.__eq__",        ["__eq__"],   true, "Struct.__eq__.__name__ is '__eq__' (bare method name; no class prefix; qualname is 'object.__eq__' with prefix; no prior spec anchors __eq__ bare name)"]
    - [eq_name_len,        "Struct.__eq__.__name__.__len__",       [],           6,    "Struct.__eq__.__name__.__len__() is 6 (len('__eq__')==6; shortest dunder in this spec; '__'=2 + 'eq'=2 + '__'=2)"]
    - [doc_cls_mod_len,    "Struct.__doc__.__class__.__module__.__len__", [],    8,    "Struct.__doc__.__class__.__module__.__len__() is 8 (len('builtins')==8; str type __module__; same as __hash__ bare name len — coincidence; no prior spec anchors this length)"]

# ---------------------------------------------------------------------------
# struct.Struct.__hash__.__qualname__.__eq__('object.__hash__') == True
# struct.Struct.__eq__.__qualname__.__eq__('object.__eq__') == True
# struct.Struct.__hash__.__name__.__eq__('__hash__') == True
# struct.Struct.__eq__.__name__.__eq__('__eq__') == True
# struct.Struct.__doc__.__class__.__module__.__eq__('builtins') == True
#
# Wave 281 theme: cross-check grouping all five core __hash__/__eq__ identity facts.
#
# This table groups the four key equality assertions for __hash__ and __eq__ (qualname
# and bare name) together with the doc class module, confirming the complete identity
# picture for these inherited Struct methods. Both the qualname and bare name axes are
# verified together. The 'object.' prefix in qualnames confirms that neither __hash__
# nor __eq__ is defined by Struct itself — both are inherited from object.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra117.Struct_hash_eq_unified_cross_check:
  description: "Struct.__hash__.__qualname__.__eq__('object.__hash__')==True / Struct.__eq__.__qualname__.__eq__('object.__eq__')==True / Struct.__hash__.__name__.__eq__('__hash__')==True / Struct.__eq__.__name__.__eq__('__eq__')==True / Struct.__doc__.__class__.__module__.__eq__('builtins')==True — unified cross-check for all four identity assertions; 'object.' prefix in qualnames confirms neither method is defined by Struct (both inherited from object); str docstring from builtins; first structslot117 unified anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structslot117

  columns: [id, function, args, expected, description]
  rows:
    - [hash_qualname_eq2,   "Struct.__hash__.__qualname__.__eq__",        ["object.__hash__"], true, "Struct.__hash__.__qualname__ is 'object.__hash__' (unified cross-check; 'object.' prefix confirms inheritance from object)"]
    - [eq_qualname_eq2,     "Struct.__eq__.__qualname__.__eq__",          ["object.__eq__"],   true, "Struct.__eq__.__qualname__ is 'object.__eq__' (unified cross-check; 'object.' prefix confirms inheritance from object)"]
    - [hash_name_eq2,       "Struct.__hash__.__name__.__eq__",            ["__hash__"],        true, "Struct.__hash__.__name__ is '__hash__' (unified cross-check; bare name without class prefix; confirms extra94 class name anchor)"]
    - [eq_name_eq2,         "Struct.__eq__.__name__.__eq__",              ["__eq__"],          true, "Struct.__eq__.__name__ is '__eq__' (unified cross-check; bare name without class prefix; confirms extra94 class name anchor)"]
    - [doc_cls_mod_eq2,     "Struct.__doc__.__class__.__module__.__eq__", ["builtins"],        true, "Struct.__doc__.__class__.__module__ is 'builtins' (unified cross-check; Struct docstring is a str; str type __module__=='builtins')"]

# ---------------------------------------------------------------------------
# struct.Struct.__hash__.__qualname__.__len__() == 15 — standalone
#
# struct.Struct.__hash__.__qualname__.__len__() is 15. 'object.__hash__' has 15 chars:
# 'object'=6 + '.'=1 + '__hash__'=8 = 15. A notable coincidence: len('object.__hash__')
# == len('Struct.__init__') == len('Struct.__repr__') == 15. These three qualnames —
# for an inherited method from object and two Struct-defined methods — all share the
# 15-char length despite having completely different class prefixes. extra101 anchors
# Struct.__init__.__qualname__.__len__()==15; extra112 anchors __repr__.__qualname__
# .__len__()==15. No prior struct spec anchors Struct.__hash__.__qualname__.__len__()==15
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra117.Struct_hash_qualname_len_15:
  description: "struct.Struct.__hash__.__qualname__.__len__() == 15 — len('object.__hash__')==15 ('object'=6 + '.'=1 + '__hash__'=8; inherited from object; qualname includes 'object.' prefix; coincidentally same length as 'Struct.__init__'=15 and 'Struct.__repr__'=15; extra101 anchors __init__ qualname len==15; extra112 anchors __repr__ qualname len==15; no prior spec anchors __hash__ qualname length as standalone; first standalone under structslot117)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__hash__.__qualname__.__len__"
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# struct.Struct.__eq__.__qualname__.__len__() == 13 — standalone
#
# struct.Struct.__eq__.__qualname__.__len__() is 13. 'object.__eq__' has 13 chars:
# 'object'=6 + '.'=1 + '__eq__'=6 = 13. This is 2 chars shorter than the
# __hash__ qualname (15 chars) — the difference exactly mirrors the body length
# difference between '__hash__' (4-char body) and '__eq__' (2-char body). The
# length 13 also matches len('__reduce_ex__')==13 (a bare dunder name covered in
# extra116) — different contexts (qualname vs bare name) sharing the same length.
# No prior struct spec anchors Struct.__eq__.__qualname__.__len__()==13.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra117.Struct_eq_qualname_len_13:
  description: "struct.Struct.__eq__.__qualname__.__len__() == 13 — len('object.__eq__')==13 ('object'=6 + '.'=1 + '__eq__'=6; 2 chars shorter than __hash__ qualname=15; body length difference 'hash'=4 vs 'eq'=2 exactly accounts for the 2-char gap; coincidentally same as len('__reduce_ex__')==13 in a different context; no prior spec anchors __eq__ qualname length as standalone; first standalone under structslot117)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__eq__.__qualname__.__len__"
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# struct.Struct.__hash__.__name__.__len__() == 8 — standalone
#
# struct.Struct.__hash__.__name__.__len__() is 8. '__hash__' has 8 chars:
# '__'=2 + 'hash'=4 + '__'=2 = 8. The bare __name__ attribute stores only the
# method name without the defining class prefix. The length 8 coincidentally matches
# len('builtins')==8 (Struct.__doc__.__class__.__module__) and len('_struct')+1==8
# (close but not equal — '_struct' is 7 chars, not 8). extra116 anchors __init__
# bare name len 8 (from extra40 via extra116); no prior struct spec anchors
# Struct.__hash__.__name__.__len__()==8 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra117.Struct_hash_name_len_8:
  description: "struct.Struct.__hash__.__name__.__len__() == 8 — len('__hash__')==8 ('__'=2 + 'hash'=4 + '__'=2; bare method name without class prefix; coincidentally same as len('builtins')==8 (Struct doc class module) and len('__init__')==8 (extra40 anchors __init__ bare name len via extra116); no prior spec anchors __hash__ bare name length as standalone; first standalone under structslot117)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__hash__.__name__.__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# struct.Struct.__eq__.__name__.__len__() == 6 — standalone
#
# struct.Struct.__eq__.__name__.__len__() is 6. '__eq__' has 6 chars:
# '__'=2 + 'eq'=2 + '__'=2 = 6. This is the shortest dunder name in this spec.
# The 2-char body 'eq' is the shortest possible meaningful method body name. The
# length 6 also matches len('object')==6 (the defining class name in the qualname
# 'object.__eq__') — both the class prefix and the full bare name of __eq__ share
# the 6-char length. No prior struct spec anchors Struct.__eq__.__name__.__len__()==6
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra117.Struct_eq_name_len_6:
  description: "struct.Struct.__eq__.__name__.__len__() == 6 — len('__eq__')==6 ('__'=2 + 'eq'=2 + '__'=2; shortest dunder name in this spec; coincidentally same as len('object')==6 — the defining class prefix in 'object.__eq__' qualname has the same length as the full bare name '__eq__'; no prior spec anchors __eq__ bare name length as standalone; first standalone under structslot117)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__eq__.__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__module__.__eq__('builtins') — standalone
#
# struct.Struct.__doc__.__class__.__module__ is 'builtins'. Struct has a docstring
# ('Struct(fmt) --> compiled struct object\n\n...'). The type of this docstring is str,
# and str's __module__ is 'builtins' because the str type is defined in
# Objects/unicodeobject.c and attributed to the builtins module. extra115 anchors
# Struct.__doc__.__class__.__name__.__eq__('str') as a table row; no prior struct
# spec anchors Struct.__doc__.__class__.__module__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra117.Struct_doc_class_module_builtins:
  description: "struct.Struct.__doc__.__class__.__module__.__eq__('builtins') == True — Struct docstring is a str; str type __module__ is 'builtins' (Objects/unicodeobject.c; fundamental CPython runtime type); extra115 anchors __doc__.__class__.__name__.__eq__('str') as table row; no prior struct spec anchors Struct.__doc__.__class__.__module__ in any form; first standalone under structslot117)"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__doc__.__class__.__module__.__eq__"
  args: ["builtins"]
  expected: true
