spec: struct_extra245
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra.zspec.zsdl — covers calcsize for '>f'/'>d'/'>B'/'4s'/'>BHI' formats / Struct format/size attributes / pack_into method name (table + invariants)."
    - "struct_extra244.zspec.zsdl — covers Struct class identity (__name__/__module__/__qualname__/__bases__) / Struct.size for >I/<I/>IH/4s/!IH / module-level pack/unpack/calcsize __name__/__module__ (table + invariants)."
  notes:
    - "Wave 295 theme: struct pack/unpack for network byte order (!) integer formats / iter_unpack and pack_into function identity."
    - "struct.pack('!I', 1).__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('!Q', 1).__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('!H', 1).__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('!I', b'\\x00\\x00\\x00\\x01')[0] == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('!H', b'\\x00\\x01')[0] == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('!Q', b'\\x00\\x00\\x00\\x00\\x00\\x00\\x00\\x01')[0] == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('!IHB').size == 7 (4+2+1). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('!4sI').size == 8 (4+4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: '!' (network byte order) is equivalent to '>' (big-endian). It is defined in the socket/network convention as big-endian — the byte order used in network protocols. struct.pack('!I', 1) produces b'\\x00\\x00\\x00\\x01' (most significant byte first). struct.pack('!H', 1) produces b'\\x00\\x01'. struct.pack('!Q', 1) produces 8 bytes with 0x01 in the last byte."
    - "Note: struct.Struct('!IHB').size == 7: network-byte-order I (4 bytes) + H (2 bytes) + B (1 byte) = 7 bytes. struct_extra.zspec anchors calcsize('>BHI')==7 (same format, different byte-order prefix, same total size); this spec anchors Struct('!IHB').size via the Struct class interface."
    - "Note: struct.iter_unpack and struct.pack_into are C builtin functions from Modules/_struct.c. __module__=='_struct' for both (same as pack/unpack/calcsize). struct_extra anchors pack_into.__name__ in a table; this spec adds iter_unpack and provides additional pack/unpack network-byte-order test vectors."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct network byte order sizes: !I, !Q, !H, !IHB, !4sI
#
# Wave 295 theme: Struct.size for network byte order ('!') format strings.
#
# Network byte order '!' is identical to big-endian '>' for size calculations.
# !I (unsigned int) = 4 bytes, !H (unsigned short) = 2 bytes, !Q (unsigned
# long long) = 8 bytes. !IHB (4+2+1) = 7 bytes; !4sI (4+4) = 8 bytes.
# struct_extra anchors Struct('>BHI').size==7; struct_extra244 anchors
# Struct('!IH').size==6; no prior spec anchors !I/!Q/!H/!IHB/!4sI Struct.size
# together as a grouped table under structnet295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra245.Struct_network_byte_order_sizes:
  description: "Struct('!I').size.__eq__(4)==True / Struct('!Q').size.__eq__(8)==True / Struct('!H').size.__eq__(2)==True / Struct('!IHB').size.__eq__(7)==True / Struct('!4sI').size.__eq__(8)==True — '!' is network byte order (big-endian); I=4/Q=8/H=2 bytes; '!IHB'=7 (4+2+1); '!4sI'=8 (4-byte string + 4-byte uint); struct_extra anchors '>BHI'==7; extra244 anchors '!IH'==6; first structnet295 anchor for these network-byte-order Struct sizes"
  kind: python_call_eq
  category: struct_size
  id_prefix: structnet295

  columns: [id, function, args, expected, description]
  rows:
    - [size_net_I,    "Struct('!I').size.__eq__",    [4], true, "Struct('!I').size is 4 (network byte order unsigned int; 4 bytes)"]
    - [size_net_Q,    "Struct('!Q').size.__eq__",    [8], true, "Struct('!Q').size is 8 (network byte order unsigned long long; 8 bytes)"]
    - [size_net_H,    "Struct('!H').size.__eq__",    [2], true, "Struct('!H').size is 2 (network byte order unsigned short; 2 bytes)"]
    - [size_net_IHB,  "Struct('!IHB').size.__eq__",  [7], true, "Struct('!IHB').size is 7 (I=4 + H=2 + B=1; common protocol header pattern)"]
    - [size_net_4sI,  "Struct('!4sI').size.__eq__",  [8], true, "Struct('!4sI').size is 8 (4-byte string field + 4-byte uint; e.g. magic + length)"]

# ---------------------------------------------------------------------------
# struct pack/unpack round-trip for network byte order integer formats
#
# Wave 295 theme: struct.pack('!I/H/Q', 1) byte length and unpack round-trip.
#
# struct.pack('!I', 1) produces b'\x00\x00\x00\x01' (4 bytes, big-endian).
# struct.pack('!H', 1) produces b'\x00\x01' (2 bytes, big-endian).
# struct.pack('!Q', 1) produces 8 bytes with 0x01 in the last byte.
# Unpacking these byte strings recovers the integer 1. This table anchors
# both the packed length and the unpack round-trip result for the canonical
# value 1 in each network-byte-order integer format. No prior spec anchors
# these '!' pack byte lengths and unpack results as a grouped table under
# structnet295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra245.network_pack_unpack:
  description: "pack('!I',1).__len__().__eq__(4)==True / unpack('!I',b'\\x00\\x00\\x00\\x01')[0].__eq__(1)==True / pack('!H',1).__len__().__eq__(2)==True / unpack('!H',b'\\x00\\x01')[0].__eq__(1)==True / pack('!Q',1).__len__().__eq__(8)==True / unpack('!Q',b'\\x00\\x00\\x00\\x00\\x00\\x00\\x00\\x01')[0].__eq__(1)==True — network byte order pack/unpack round-trip for I/H/Q with value 1; big-endian byte layout; no prior spec anchors these '!' pack lengths and unpack results; first structnet295 anchor for network pack/unpack"
  kind: python_call_eq
  category: pack_unpack
  id_prefix: structnet295

  columns: [id, function, args, expected, description]
  rows:
    - [pack_I_len,     "pack('!I',1).__len__",                                             [],  4, "struct.pack('!I', 1) produces 4 bytes (network byte order unsigned int)"]
    - [unpack_I_val,   "unpack('!I',b'\\x00\\x00\\x00\\x01')[0].__eq__",                  [1], true, "struct.unpack('!I', b'\\x00\\x00\\x00\\x01')[0] == 1 (big-endian round-trip)"]
    - [pack_H_len,     "pack('!H',1).__len__",                                             [],  2, "struct.pack('!H', 1) produces 2 bytes (network byte order unsigned short)"]
    - [unpack_H_val,   "unpack('!H',b'\\x00\\x01')[0].__eq__",                            [1], true, "struct.unpack('!H', b'\\x00\\x01')[0] == 1 (big-endian round-trip)"]
    - [pack_Q_len,     "pack('!Q',1).__len__",                                             [],  8, "struct.pack('!Q', 1) produces 8 bytes (network byte order unsigned long long)"]
    - [unpack_Q_val,   "unpack('!Q',b'\\x00\\x00\\x00\\x00\\x00\\x00\\x00\\x01')[0].__eq__",  [1], true, "struct.unpack('!Q', 8-byte big-endian value)[0] == 1 (round-trip)"]

# ---------------------------------------------------------------------------
# struct.iter_unpack and struct.pack_into function identity
#
# Wave 295 theme: struct.iter_unpack and struct.pack_into __name__ and __module__.
#
# struct.iter_unpack returns an iterator that unpacks successive fixed-size chunks
# from a buffer. struct.pack_into packs values directly into a writable buffer
# (e.g., bytearray or memoryview) at a given offset. Both are C builtins from
# Modules/_struct.c with __module__=='_struct'. struct_extra anchors pack_into
# __name__ in a table; no prior spec anchors iter_unpack __name__ and __module__
# or pack_into __module__ as a grouped table under structnet295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra245.iter_unpack_pack_into_identity:
  description: "iter_unpack.__name__.__eq__('iter_unpack')==True / iter_unpack.__module__.__eq__('_struct')==True / pack_into.__name__.__eq__('pack_into')==True / pack_into.__module__.__eq__('_struct')==True — both are C builtins from Modules/_struct.c; iter_unpack returns an iterator over successive fixed-size chunks; pack_into writes into a mutable buffer at an offset; __module__=='_struct' for both (same as pack/unpack/calcsize); struct_extra anchors pack_into.__name__; first structnet295 anchor for iter_unpack identity and pack_into __module__"
  kind: python_call_eq
  category: function_identity
  id_prefix: structnet295

  columns: [id, function, args, expected, description]
  rows:
    - [iter_unpack_name_eq,    "iter_unpack.__name__.__eq__",    ["iter_unpack"], true, "struct.iter_unpack.__name__ is 'iter_unpack' (C builtin in _struct)"]
    - [iter_unpack_module_eq,  "iter_unpack.__module__.__eq__",  ["_struct"],     true, "struct.iter_unpack.__module__ is '_struct' (C extension module)"]
    - [pack_into_name_eq,      "pack_into.__name__.__eq__",      ["pack_into"],   true, "struct.pack_into.__name__ is 'pack_into' (C builtin in _struct)"]
    - [pack_into_module_eq,    "pack_into.__module__.__eq__",    ["_struct"],     true, "struct.pack_into.__module__ is '_struct' (C extension module)"]

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__.__eq__('iter_unpack') — standalone
#
# struct.iter_unpack.__name__ is 'iter_unpack'. iter_unpack(fmt, buffer) returns
# an iterator that reads successive struct.Struct(fmt).size chunks from buffer,
# yielding a tuple of values for each chunk. This is more memory-efficient than
# calling unpack_from() in a loop for large buffers. iter_unpack requires that
# the buffer size is an exact multiple of the format size; otherwise it raises
# struct.error. It was added in Python 3.4. struct_extra anchors pack_into.__name__
# but not iter_unpack; no prior spec anchors iter_unpack.__name__ as a standalone
# under structnet295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra245.iter_unpack_name_eq:
  description: "struct.iter_unpack.__name__.__eq__('iter_unpack') == True — iter_unpack(fmt, buffer) yields successive tuples from fixed-size chunks; more memory-efficient than unpack_from in a loop; buffer must be an exact multiple of format size (else struct.error); added in Python 3.4; C builtin from _struct.c; __module__=='_struct'; struct_extra anchors pack_into.__name__ but not iter_unpack; first standalone under structnet295"
  category: function_identity
  kind: python_call_eq
  function: "iter_unpack.__name__.__eq__"
  args: ["iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct('!IHB').size.__eq__(7) — standalone
#
# struct.Struct('!IHB').size is 7. The format '!IHB' specifies a network-byte-order
# unsigned int (I, 4 bytes), unsigned short (H, 2 bytes), and unsigned char
# (B, 1 byte), for a total of 7 bytes. This is a common network protocol header
# layout. '!' is network byte order (equivalent to big-endian '>'). struct_extra
# anchors calcsize('>BHI')==7 (same field types in different order, same total);
# struct_extra244 does not anchor '!IHB'; no prior spec anchors this as a
# standalone under structnet295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra245.Struct_IHB_network_size_7:
  description: "struct.Struct('!IHB').size.__eq__(7) == True — '!IHB' is network byte order I (4) + H (2) + B (1) = 7 bytes; common protocol header layout; '!'=='>' (big-endian) for size purposes; struct_extra anchors '>BHI'==7 (same fields, different order, same total); first standalone for '!IHB' size under structnet295"
  category: struct_size
  kind: python_call_eq
  function: "Struct('!IHB').size.__eq__"
  args: [7]
  expected: true
