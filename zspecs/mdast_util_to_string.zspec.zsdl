spec: mdast_util_to_string
version: ">=4.0.0"
backend: node(mdast-util-to-string)

docs: https://github.com/syntax-tree/mdast-util-to-string#readme

provenance:
  derived_from:
    - "mdast-util-to-string README — https://github.com/syntax-tree/mdast-util-to-string#readme"
    - "MDAST specification — https://github.com/syntax-tree/mdast"
    - "Test vectors verified with mdast-util-to-string via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "mdast-util-to-string source"
  notes:
    - "Recursively extracts plain-text from an MDAST tree."
    - "Install: npm install mdast-util-to-string"
    - "Named export 'toString' is the function."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; returns empty string for non-text or unknown nodes."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table mdast_util_to_string.toString:
  kind: node_module_call_eq
  category: toString
  function: toString
  id_prefix: toString

  columns: [id, args, expected]
  rows:
    - [text_node,
       [{type: "text", value: "hello"}],
       "hello"]

    - [paragraph_with_two_text_nodes,
       [{type: "paragraph", children: [{type: "text", value: "A"}, {type: "text", value: "B"}]}],
       "AB"]

    - [heading_with_text,
       [{type: "heading", depth: 1, children: [{type: "text", value: "Title"}]}],
       "Title"]

    - [emphasis_around_text,
       [{type: "emphasis", children: [{type: "text", value: "italic"}]}],
       "italic"]

    - [link_with_text_child,
       [{type: "link", url: "u", children: [{type: "text", value: "label"}]}],
       "label"]

    - [code_node_value,
       [{type: "code", value: "let x = 1", lang: "js"}],
       "let x = 1"]

    - [inline_code_value,
       [{type: "inlineCode", value: "fn()"}],
       "fn()"]

    - [empty_paragraph_returns_empty,
       [{type: "paragraph", children: []}],
       ""]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:10:09Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
