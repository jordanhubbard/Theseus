spec: threading_extra901
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.Thread __module__, Lock/RLock __class__.__name__, Event/Semaphore/Condition/Timer __module__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra901.thread_event_module:
  description: "threading.Thread and threading.Event __module__ identity"
  kind: python_call_eq
  category: thread_event_module
  id_prefix: th901te
  columns: [id, function, args, expected]
  rows:
    - [th901te001, threading.Thread.__module__.__eq__,                  ["threading"],               true]
    - [th901te002, threading.Thread.__qualname__.__eq__,                ["Thread"],                  true]
    - [th901te003, threading.Thread.__class__.__name__.__eq__,          ["type"],                    true]
    - [th901te004, threading.Event.__module__.__eq__,                   ["threading"],               true]
    - [th901te005, threading.Event.__qualname__.__eq__,                 ["Event"],                   true]
    - [th901te006, threading.Event.__class__.__name__.__eq__,           ["type"],                    true]

table threading_extra901.lock_rlock_class_names:
  description: "threading.Lock and threading.RLock __class__.__name__ identity"
  kind: python_call_eq
  category: lock_rlock_class_names
  id_prefix: th901lr
  columns: [id, function, args, expected]
  rows:
    - [th901lr001, threading.Lock.__class__.__name__.__eq__,            ["builtin_function_or_method"], true]
    - [th901lr002, threading.Lock.__name__.__eq__,                      ["allocate_lock"],           true]
    - [th901lr003, threading.Lock.__module__.__eq__,                    ["_thread"],                 true]
    - [th901lr004, threading.RLock.__module__.__eq__,                   ["threading"],               true]
    - [th901lr005, threading.RLock.__qualname__.__eq__,                 ["RLock"],                   true]
    - [th901lr006, threading.RLock.__class__.__name__.__eq__,           ["type"],                    true]

table threading_extra901.semaphore_condition_timer_module:
  description: "threading.Semaphore, threading.Condition, and threading.Timer __module__ identity"
  kind: python_call_eq
  category: semaphore_condition_timer_module
  id_prefix: th901sc
  columns: [id, function, args, expected]
  rows:
    - [th901sc001, threading.Semaphore.__module__.__eq__,               ["threading"],               true]
    - [th901sc002, threading.Semaphore.__qualname__.__eq__,             ["Semaphore"],               true]
    - [th901sc003, threading.Semaphore.__class__.__name__.__eq__,       ["type"],                    true]
    - [th901sc004, threading.Condition.__module__.__eq__,               ["threading"],               true]
    - [th901sc005, threading.Condition.__qualname__.__eq__,             ["Condition"],               true]
    - [th901sc006, threading.Condition.__class__.__name__.__eq__,       ["type"],                    true]
    - [th901sc007, threading.Timer.__module__.__eq__,                   ["threading"],               true]
    - [th901sc008, threading.Timer.__qualname__.__eq__,                 ["Timer"],                   true]
    - [th901sc009, threading.Timer.__class__.__name__.__eq__,           ["type"],                    true]
