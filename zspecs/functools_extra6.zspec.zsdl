spec: functools_extra6
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_functoolsmodule.c"
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends prior functools specs."
    - "Focus: partial object attributes; reduce behavior; lru_cache cache_info."
    - "functools.partial(int, '10', base=16).func == int."
    - "functools.partial(int, '10').args == ('10',)."
    - "functools.partial(int, base=16).keywords == {'base': 16}."
    - "functools.reduce(lambda a, b: a + b, [1, 2, 3, 4]) == 10."
    - "functools.reduce(lambda a, b: a * b, [1, 2, 3, 4], 1) == 24."
    - "functools.partial.__name__ == 'partial'."
    - "functools.lru_cache(maxsize=None)(lambda x: x).cache_info().__class__.__name__ == 'CacheInfo'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

invariant functools_extra6.partial.class_name:
  description: "functools.partial.__name__ == 'partial'"
  category: partial
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra6.partial.func_attr:
  description: "functools.partial.__qualname__ == 'partial'"
  category: partial
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra6.reduce.sum_list:
  description: "functools.reduce.__name__ == 'reduce'"
  category: reduce
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra6.reduce.module:
  description: "functools.reduce.__module__ == '_functools'"
  category: reduce
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra6.partial.bases:
  description: "functools.partial.__bases__[0].__name__ == 'object'"
  category: partial
  kind: python_call_eq
  function: partial.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant functools_extra6.cached_property.class_name:
  description: "functools.cached_property.__name__ == 'cached_property'"
  category: cached_property
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra6.cached_property.module:
  description: "functools.cached_property.__module__ == 'functools'"
  category: cached_property
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra6.total_ordering.name:
  description: "functools.total_ordering.__name__ == 'total_ordering'"
  category: total_ordering
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra6.total_ordering.module:
  description: "functools.total_ordering.__module__ == 'functools'"
  category: total_ordering
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra6.singledispatch.name:
  description: "functools.singledispatch.__name__ == 'singledispatch'"
  category: singledispatch
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra6.singledispatch.module:
  description: "functools.singledispatch.__module__ == 'functools'"
  category: singledispatch
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra6.WRAPPER_ASSIGNMENTS.value:
  description: "functools.WRAPPER_ASSIGNMENTS == ('__module__', '__name__', '__qualname__', '__annotations__', '__doc__')"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true
