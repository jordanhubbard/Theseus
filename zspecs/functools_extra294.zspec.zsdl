spec: functools_extra294
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module function and class identity attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py, Modules/_functoolsmodule.c"
  notes:
    - "lru_cache, cache, wraps, update_wrapper, singledispatch, total_ordering are Python functions (class 'function')"
    - "partial, partialmethod, singledispatchmethod, cached_property are types (class 'type')"
    - "reduce, cmp_to_key are C builtins (class 'builtin_function_or_method')"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra294.qualnames:
  description: "__qualname__ for top-level functools callables"
  kind: python_call_eq
  category: identity
  id_prefix: fte294q

  columns: [id, function, args, expected, description]
  rows:
    - [fte294q001, functools.lru_cache.__qualname__.__eq__, ["lru_cache"], true, "lru_cache qualname"]
    - [fte294q002, functools.cache.__qualname__.__eq__, ["cache"], true, "cache qualname"]
    - [fte294q003, functools.reduce.__qualname__.__eq__, ["reduce"], true, "reduce qualname"]
    - [fte294q004, functools.partial.__qualname__.__eq__, ["partial"], true, "partial qualname"]
    - [fte294q005, functools.partialmethod.__qualname__.__eq__, ["partialmethod"], true, "partialmethod qualname"]
    - [fte294q006, functools.singledispatch.__qualname__.__eq__, ["singledispatch"], true, "singledispatch qualname"]
    - [fte294q007, functools.singledispatchmethod.__qualname__.__eq__, ["singledispatchmethod"], true, "singledispatchmethod qualname"]
    - [fte294q008, functools.total_ordering.__qualname__.__eq__, ["total_ordering"], true, "total_ordering qualname"]
    - [fte294q009, functools.cached_property.__qualname__.__eq__, ["cached_property"], true, "cached_property qualname"]
    - [fte294q010, functools.wraps.__qualname__.__eq__, ["wraps"], true, "wraps qualname"]
    - [fte294q011, functools.update_wrapper.__qualname__.__eq__, ["update_wrapper"], true, "update_wrapper qualname"]
    - [fte294q012, functools.cmp_to_key.__qualname__.__eq__, ["cmp_to_key"], true, "cmp_to_key qualname"]

table functools_extra294.class_names:
  description: "__class__.__name__ for top-level functools callables"
  kind: python_call_eq
  category: identity
  id_prefix: fte294c

  columns: [id, function, args, expected, description]
  rows:
    - [fte294c001, functools.lru_cache.__class__.__name__.__eq__, ["function"], true, "lru_cache is a Python function"]
    - [fte294c002, functools.cache.__class__.__name__.__eq__, ["function"], true, "cache is a Python function"]
    - [fte294c003, functools.reduce.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "reduce is a C builtin"]
    - [fte294c004, functools.partial.__class__.__name__.__eq__, ["type"], true, "partial is a type"]
    - [fte294c005, functools.partialmethod.__class__.__name__.__eq__, ["type"], true, "partialmethod is a type"]
    - [fte294c006, functools.singledispatch.__class__.__name__.__eq__, ["function"], true, "singledispatch is a Python function"]
    - [fte294c007, functools.singledispatchmethod.__class__.__name__.__eq__, ["type"], true, "singledispatchmethod is a type"]
    - [fte294c008, functools.total_ordering.__class__.__name__.__eq__, ["function"], true, "total_ordering is a Python function"]
    - [fte294c009, functools.cached_property.__class__.__name__.__eq__, ["type"], true, "cached_property is a type"]
    - [fte294c010, functools.wraps.__class__.__name__.__eq__, ["function"], true, "wraps is a Python function"]
    - [fte294c011, functools.update_wrapper.__class__.__name__.__eq__, ["function"], true, "update_wrapper is a Python function"]
    - [fte294c012, functools.cmp_to_key.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "cmp_to_key is a C builtin"]

invariant functools_extra294.lru_cache_qualname:
  description: "lru_cache __qualname__ confirmed"
  category: identity
  kind: python_call_eq
  function: functools.lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra294.reduce_class:
  description: "reduce is a builtin_function_or_method (C extension)"
  category: identity
  kind: python_call_eq
  function: functools.reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra294.partial_is_type:
  description: "partial is a type, not a plain function"
  category: identity
  kind: python_call_eq
  function: functools.partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra294.cmp_to_key_qualname:
  description: "cmp_to_key __qualname__ confirmed"
  category: identity
  kind: python_call_eq
  function: functools.cmp_to_key.__qualname__.__eq__
  args: ["cmp_to_key"]
  expected: true
