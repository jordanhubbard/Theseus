spec: concurrent_futures_extra103
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra102.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures exception subclass hierarchy. NEW in extra103: concurrent.futures.BrokenExecutor.__bases__[0].__name__=='RuntimeError' (BrokenExecutor MRO length=5: [BrokenExecutor, RuntimeError, Exception, BaseException, object]); BrokenProcessPool.__name__=='BrokenProcessPool', BrokenProcessPool.__bases__[0].__name__=='BrokenExecutor', BrokenProcessPool.__mro__.__len__()==6, BrokenProcessPool.__module__=='concurrent.futures.process'; BrokenThreadPool.__name__=='BrokenThreadPool', BrokenThreadPool.__bases__[0].__name__=='BrokenExecutor', BrokenThreadPool.__mro__.__len__()==6, BrokenThreadPool.__module__=='concurrent.futures.thread'; concurrent.futures.InvalidStateError.__mro__.__len__()==5, __module__=='concurrent.futures._base'; concurrent.futures.Executor.__mro__.__len__()==2 (inherits directly from object); concurrent.futures.Future.__mro__.__len__()==2, __module__=='concurrent.futures._base'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'. BrokenExecutor's MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object] (length=5); it inherits directly from RuntimeError, not from Exception directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "BrokenProcessPool and BrokenThreadPool both have MRO length 6: [BrokenProcessPool/BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]. They are the deepest exception classes in this spec (length=6). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__mro__.__len__() == 5. InvalidStateError's MRO is [InvalidStateError, Error, Exception, BaseException, object]. Note the intermediate 'Error' class (not RuntimeError). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__mro__.__len__() == 2 and Future.__mro__.__len__() == 2. Both Executor and Future inherit directly from object — the shortest MRO depth in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures exception hierarchy — BrokenExecutor MRO — extra103
#
# Wave 254 theme: concurrent.futures exception subclass hierarchy.
#
# concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'      (mro len=5)
# concurrent.futures.BrokenExecutor.__module__            == 'concurrent.futures._base'
# concurrent.futures.BrokenExecutor.__qualname__          == 'BrokenExecutor'    (len=14)
# ---------------------------------------------------------------------------

table concurrent_futures_extra103.cf_broken_executor_hierarchy:
  description: "concurrent.futures.BrokenExecutor exception hierarchy checks in cfexc103 namespace — wave 254 theme: BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError')==True (BrokenExecutor inherits from RuntimeError, not directly from Exception); MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object] (length=5); BrokenExecutor.__mro__.__len__()==5; BrokenExecutor.__module__.__eq__('concurrent.futures._base')==True (defined in Lib/concurrent/futures/_base.py); BrokenExecutor.__qualname__.__eq__('BrokenExecutor')==True (len=14: 'BrokenExecutor'=14); compare: BrokenProcessPool.__mro__.__len__()==6 (one deeper than BrokenExecutor); Executor.__mro__.__len__()==2 (shortest); BrokenExecutor is the base exception for all broken executor types; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cfexc103

  columns: [id, function, args, expected, description]
  rows:
    - [be_base_eq,    "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__", ["RuntimeError"],              true, "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'; verified with Python 3.14.3"]
    - [be_mro_len,    concurrent.futures.BrokenExecutor.__mro__.__len__,                [],                            5,    "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5 ([BrokenExecutor, RuntimeError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [be_module,     "concurrent.futures.BrokenExecutor.__module__.__eq__",            ["concurrent.futures._base"],  true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [be_qn_eq,      "concurrent.futures.BrokenExecutor.__qualname__.__eq__",          ["BrokenExecutor"],            true, "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14); verified with Python 3.14.3"]
    - [be_qn_len,     concurrent.futures.BrokenExecutor.__qualname__.__len__,           [],                            14,   "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14 ('BrokenExecutor'=14); verified with Python 3.14.3"]
    - [exec_mro_len,  concurrent.futures.Executor.__mro__.__len__,                      [],                            2,    "concurrent.futures.Executor.__mro__.__len__() == 2 ([Executor, object]); shortest MRO in spec; verified with Python 3.14.3"]
    - [fut_mro_len,   concurrent.futures.Future.__mro__.__len__,                        [],                            2,    "concurrent.futures.Future.__mro__.__len__() == 2 ([Future, object]); tied with Executor for shortest; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BrokenProcessPool and BrokenThreadPool hierarchy — extra103
#
# Wave 254 theme: broken pool exception subclasses.
#
# BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor'  (mro len=6, deepest)
# BrokenProcessPool.__module__            == 'concurrent.futures.process'
# BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'   (mro len=6, deepest)
# BrokenThreadPool.__module__             == 'concurrent.futures.thread'
# ---------------------------------------------------------------------------

table concurrent_futures_extra103.cf_broken_pool_hierarchy:
  description: "BrokenExecutor, Future, Executor, and InvalidStateError hierarchy checks in cfexc103 namespace — wave 254 theme: BrokenExecutor.__bases__[0].__name__=='RuntimeError' (inherits from RuntimeError, not Exception directly); Future.__bases__[0].__name__=='object' (inherits directly from object — shortest MRO length=2); Executor.__bases__[0].__name__=='object' (also inherits directly from object — MRO length=2); InvalidStateError.__mro__.__len__()==5 (MRO [InvalidStateError, Error, Exception, BaseException, object]); all four classes have __module__=='concurrent.futures._base'; BrokenExecutor.__mro__.__len__()==5 (same depth as InvalidStateError but different branch); Executor.__mro__.__len__()==2; Future.__mro__.__len__()==2; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cfexc103a

  columns: [id, function, args, expected, description]
  rows:
    - [be_base_eq2,   "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__",  ["RuntimeError"],              true, "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (inherits from RuntimeError); verified with Python 3.14.3"]
    - [fut_module,    "concurrent.futures.Future.__module__.__eq__",                     ["concurrent.futures._base"],  true, "concurrent.futures.Future.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [fut_base_eq,   "concurrent.futures.Future.__bases__[0].__name__.__eq__",          ["object"],                    true, "concurrent.futures.Future.__bases__[0].__name__ == 'object' (Future inherits directly from object); verified with Python 3.14.3"]
    - [exec_base_eq,  "concurrent.futures.Executor.__bases__[0].__name__.__eq__",        ["object"],                    true, "concurrent.futures.Executor.__bases__[0].__name__ == 'object' (Executor inherits directly from object); verified with Python 3.14.3"]
    - [exec_mro_len2, concurrent.futures.Executor.__mro__.__len__,                       [],                            2,    "concurrent.futures.Executor.__mro__.__len__() == 2 ([Executor, object]); tied for shortest MRO in spec; verified with Python 3.14.3"]
    - [ise_mro_len,   concurrent.futures.InvalidStateError.__mro__.__len__,              [],                            5,    "concurrent.futures.InvalidStateError.__mro__.__len__() == 5 ([InvalidStateError, Error, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [ise_module,    "concurrent.futures.InvalidStateError.__module__.__eq__",          ["concurrent.futures._base"],  true, "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures class __qualname__ lengths — extra103
#
# Wave 254 theme: exception and executor class qualname lengths.
#
# concurrent.futures.Executor.__qualname__          == 'Executor'         (len=8)
# concurrent.futures.Future.__qualname__            == 'Future'           (len=6)
# concurrent.futures.BrokenExecutor.__qualname__    == 'BrokenExecutor'   (len=14)
# concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError' (len=17, longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra103.cf_class_qualname_lengths:
  description: "concurrent.futures class __qualname__ length checks in cfexc103 namespace — wave 254 theme: comparing qualname lengths of key concurrent.futures classes; Future.__qualname__.__eq__('Future')==True (len=6: 'Future'=6, shortest qualname); Executor.__qualname__.__eq__('Executor')==True (len=8: 'Executor'=8); BrokenExecutor.__qualname__.__eq__('BrokenExecutor')==True (len=14: 'BrokenExecutor'=14); InvalidStateError.__qualname__.__eq__('InvalidStateError')==True (len=17: 'InvalidStateError'=17, longest qualname in spec); Future.__qualname__.__len__()==6; Executor.__qualname__.__len__()==8; BrokenExecutor.__qualname__.__len__()==14; InvalidStateError.__qualname__.__len__()==17; compare: BrokenProcessPool qualname len=16, BrokenThreadPool len=15, BrokenExecutor len=14; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexc103b

  columns: [id, function, args, expected, description]
  rows:
    - [fut_qn_eq,   "concurrent.futures.Future.__qualname__.__eq__",            ["Future"],           true, "concurrent.futures.Future.__qualname__ == 'Future' (len=6, shortest in spec); verified with Python 3.14.3"]
    - [fut_qn_len,  concurrent.futures.Future.__qualname__.__len__,             [],                   6,    "concurrent.futures.Future.__qualname__.__len__() == 6 ('Future'=6); verified with Python 3.14.3"]
    - [exec_qn_eq,  "concurrent.futures.Executor.__qualname__.__eq__",          ["Executor"],         true, "concurrent.futures.Executor.__qualname__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [exec_qn_len, concurrent.futures.Executor.__qualname__.__len__,           [],                   8,    "concurrent.futures.Executor.__qualname__.__len__() == 8 ('Executor'=8); verified with Python 3.14.3"]
    - [be_qn_len2,  concurrent.futures.BrokenExecutor.__qualname__.__len__,     [],                   14,   "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14 ('BrokenExecutor'=14); verified with Python 3.14.3"]
    - [ise_qn_eq,   "concurrent.futures.InvalidStateError.__qualname__.__eq__", ["InvalidStateError"], true, "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError' (len=17, longest in spec); verified with Python 3.14.3"]
    - [ise_qn_len,  concurrent.futures.InvalidStateError.__qualname__.__len__,  [],                   17,   "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17 ('InvalidStateError'=17, longest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra103
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra103.BrokenExecutor_base_is_RuntimeError:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') returns True — BrokenExecutor inherits from RuntimeError (not directly from Exception); its MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object] (length=5); this placement in the RuntimeError branch means catching RuntimeError also catches BrokenExecutor; BrokenExecutor.__module__=='concurrent.futures._base'; BrokenExecutor.__qualname__=='BrokenExecutor' (len=14); BrokenProcessPool and BrokenThreadPool then inherit from BrokenExecutor (MRO length=6); NEW in extra103: first standalone BrokenExecutor base invariant in cfexc103 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

invariant concurrent_futures_extra103.BrokenExecutor_mro_len_5:
  description: "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5 — BrokenExecutor's MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object] (5 elements); compare MRO depths: Executor=2, Future=2 (shortest), InvalidStateError=5, BrokenExecutor=5, BrokenProcessPool=6, BrokenThreadPool=6 (deepest); BrokenExecutor.__bases__[0].__name__=='RuntimeError'; BrokenExecutor.__module__=='concurrent.futures._base'; BrokenExecutor is the abstract base for all pool-broken exception types — callers catching it will also catch BrokenProcessPool and BrokenThreadPool; NEW in extra103: first standalone BrokenExecutor MRO length invariant in cfexc103 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures.BrokenExecutor.__mro__.__len__
  args: []
  expected: 5

invariant concurrent_futures_extra103.InvalidStateError_mro_len_5:
  description: "concurrent.futures.InvalidStateError.__mro__.__len__() == 5 — InvalidStateError's MRO is [InvalidStateError, Error, Exception, BaseException, object] (5 elements); note the intermediate 'Error' class (not RuntimeError, unlike BrokenExecutor); InvalidStateError.__module__=='concurrent.futures._base'; InvalidStateError.__qualname__=='InvalidStateError' (len=17, longest qualname in this spec); both BrokenExecutor and InvalidStateError have MRO length=5, but with different intermediate classes (RuntimeError vs Error); NEW in extra103: first standalone InvalidStateError MRO length invariant in cfexc103 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures.InvalidStateError.__mro__.__len__
  args: []
  expected: 5

invariant concurrent_futures_extra103.Future_mro_len_2:
  description: "concurrent.futures.Future.__mro__.__len__() == 2 — Future inherits directly from object; its MRO is [Future, object] (2 elements — the shortest MRO in this spec, tied with Executor); concurrent.futures.Future.__module__=='concurrent.futures._base'; Future.__qualname__=='Future' (len=6, shortest qualname in this spec); Future.__bases__[0].__name__=='object'; Future represents the result of an asynchronous computation — it is thread-safe and provides get(), cancel(), and done() methods; compare: BrokenProcessPool.__mro__.__len__()==6 (deepest, three times longer than Future); NEW in extra103: first standalone Future MRO length invariant in cfexc103 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures.Future.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra103.InvalidStateError_qualname_len_17:
  description: "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17 — 'InvalidStateError' = 17 chars: 'Invalid'=7 + 'State'=5 + 'Error'=5 = 17; this is the longest class qualname in this spec; compare qualname lengths: Future=6 (shortest), Executor=8, BrokenExecutor=14, InvalidStateError=17 (longest); concurrent.futures.InvalidStateError.__module__=='concurrent.futures._base'; InvalidStateError.__mro__.__len__()==5; InvalidStateError is raised when a Future is in the wrong state for an operation (e.g., setting a result on an already-done Future); NEW in extra103: first standalone InvalidStateError qualname length invariant in cfexc103 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.InvalidStateError.__qualname__.__len__
  args: []
  expected: 17
