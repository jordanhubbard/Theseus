spec: io_extra112
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io_extra111.zspec.zsdl."
    - "This spec covers: io abstract base class (IOBase, RawIOBase, BufferedIOBase, TextIOBase) class identity:"
    - "  __name__, __qualname__, __module__, __bases__[0].__name__, __mro__.__len__(), and __class__.__name__."
    - "io.IOBase.__module__ == 'io' (Python-level ABC); concrete types like FileIO/BytesIO have __module__ == '_io' (C extension)."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' (the C extension base; the Python ABC wraps it)."
    - "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase'; BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase'; TextIOBase.__bases__[0].__name__ == '_TextIOBase'."
    - "io.IOBase.__mro__.__len__() == 3 (IOBase, _IOBase, object)."
    - "io.RawIOBase.__mro__.__len__() == 5 (RawIOBase, _RawIOBase, IOBase, _IOBase, object)."
    - "io.BufferedIOBase.__mro__.__len__() == 5; io.TextIOBase.__mro__.__len__() == 5."
    - "io.IOBase.__class__.__name__ == 'ABCMeta' (IOBase is registered as an abstract base class)."
    - "io.IOBase.close.__qualname__ == '_IOBase.close' (method_descriptor; qualname uses the C-level class '_IOBase', not 'IOBase')."
    - "io.IOBase.readable.__qualname__ == '_IOBase.readable'; flush.__qualname__ == '_IOBase.flush'."
    - "type(io.IOBase.close).__name__ == 'method_descriptor' (C extension slot wrapper)."
    - "len('IOBase') == 6; len('RawIOBase') == 9; len('BufferedIOBase') == 14; len('TextIOBase') == 10."
    - "io.FileIO.__module__ == '_io'; io.BufferedReader.__module__ == '_io'; io.TextIOWrapper.__module__ == '_io'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io abstract base class __name__ and __module__ identity
# IOBase, RawIOBase, BufferedIOBase, TextIOBase are Python-level ABCs defined
# in Lib/io.py. Their __module__ is 'io' (not '_io').
# Their __name__ and __qualname__ are equal to the bare class name.
# Concrete types (FileIO, BytesIO, etc.) have __module__ == '_io'.
# ---------------------------------------------------------------------------

table io_extra112.ABC_name_module:
  description: "io abstract base class __name__ and __module__: IOBase.__module__='io', RawIOBase.__module__='io', BufferedIOBase.__module__='io', TextIOBase.__module__='io'"
  kind: python_call_eq
  category: class_names
  id_prefix: ioabc112a

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_name_eq,      IOBase.__name__.__eq__,          ["IOBase"],         true,  "io.IOBase.__name__ == 'IOBase'"]
    - [iobase_module_eq,    IOBase.__module__.__eq__,         ["io"],             true,  "io.IOBase.__module__ == 'io' (Python-level ABC, not '_io')"]
    - [rawio_name_eq,       RawIOBase.__name__.__eq__,        ["RawIOBase"],      true,  "io.RawIOBase.__name__ == 'RawIOBase'"]
    - [rawio_module_eq,     RawIOBase.__module__.__eq__,      ["io"],             true,  "io.RawIOBase.__module__ == 'io' (Python-level ABC)"]
    - [bufio_name_eq,       BufferedIOBase.__name__.__eq__,   ["BufferedIOBase"], true,  "io.BufferedIOBase.__name__ == 'BufferedIOBase'"]
    - [bufio_module_eq,     BufferedIOBase.__module__.__eq__, ["io"],             true,  "io.BufferedIOBase.__module__ == 'io' (Python-level ABC)"]
    - [textio_name_eq,      TextIOBase.__name__.__eq__,       ["TextIOBase"],     true,  "io.TextIOBase.__name__ == 'TextIOBase'"]
    - [textio_module_eq,    TextIOBase.__module__.__eq__,     ["io"],             true,  "io.TextIOBase.__module__ == 'io' (Python-level ABC)"]
    - [iobase_mod_not_cio,  IOBase.__module__.__eq__,         ["_io"],            false, "io.IOBase.__module__ != '_io' (the ABC is defined in Python's io module, not in the C extension _io)"]
    - [fileio_module_eq,    FileIO.__module__.__eq__,         ["_io"],            true,  "io.FileIO.__module__ == '_io' (concrete type, implemented in C extension)"]

# ---------------------------------------------------------------------------
# io abstract base class __bases__[0].__name__ and __mro__.__len__
# IOBase inherits from _IOBase (C extension), giving mro len 3.
# RawIOBase, BufferedIOBase, TextIOBase each inherit from their _*IOBase C
# counterpart which itself inherits from IOBase, giving mro len 5.
# ---------------------------------------------------------------------------

table io_extra112.ABC_bases_mro:
  description: "io abstract base class __bases__[0].__name__ and __mro__ lengths: IOBase._IOBase(mro=3), RawIOBase._RawIOBase(mro=5), BufferedIOBase._BufferedIOBase(mro=5), TextIOBase._TextIOBase(mro=5)"
  kind: python_call_eq
  category: class_names
  id_prefix: ioabc112b

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_base_name,    "IOBase.__bases__[0].__name__.__eq__",         ["_IOBase"],         true, "io.IOBase.__bases__[0].__name__ == '_IOBase' (C extension base class)"]
    - [rawio_base_name,     "RawIOBase.__bases__[0].__name__.__eq__",      ["_RawIOBase"],      true, "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' (C extension base class)"]
    - [bufio_base_name,     "BufferedIOBase.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true, "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (C extension base class)"]
    - [textio_base_name,    "TextIOBase.__bases__[0].__name__.__eq__",     ["_TextIOBase"],     true, "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' (C extension base class)"]
    - [iobase_mro_len,      "IOBase.__mro__.__len__",                       [],                 3,    "io.IOBase.__mro__.__len__() == 3 (IOBase, _IOBase, object)"]
    - [rawio_mro_len,       "RawIOBase.__mro__.__len__",                    [],                 5,    "io.RawIOBase.__mro__.__len__() == 5 (RawIOBase, _RawIOBase, IOBase, _IOBase, object)"]
    - [bufio_mro_len,       "BufferedIOBase.__mro__.__len__",               [],                 5,    "io.BufferedIOBase.__mro__.__len__() == 5 (BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object)"]
    - [textio_mro_len,      "TextIOBase.__mro__.__len__",                   [],                 5,    "io.TextIOBase.__mro__.__len__() == 5 (TextIOBase, _TextIOBase, IOBase, _IOBase, object)"]

# ---------------------------------------------------------------------------
# io.IOBase method __qualname__ and type
# Methods like close, flush, readable are inherited from _IOBase (C extension).
# Their __qualname__ uses '_IOBase.' prefix, not 'IOBase.'.
# type(io.IOBase.close).__name__ == 'method_descriptor'.
# Also: io.IOBase.__class__.__name__ == 'ABCMeta'.
# ---------------------------------------------------------------------------

table io_extra112.IOBase_method_qualnames_types:
  description: "io.IOBase method __qualname__ (uses '_IOBase.' prefix) and type: close='_IOBase.close', flush='_IOBase.flush', readable='_IOBase.readable'; type == 'method_descriptor'; IOBase.__class__ == 'ABCMeta'"
  kind: python_call_eq
  category: qualnames
  id_prefix: ioabc112c

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_close_qn,    IOBase.close.__qualname__.__eq__,    ["_IOBase.close"],    true,  "io.IOBase.close.__qualname__ == '_IOBase.close' (method is defined on _IOBase, not IOBase)"]
    - [iobase_flush_qn,    IOBase.flush.__qualname__.__eq__,    ["_IOBase.flush"],    true,  "io.IOBase.flush.__qualname__ == '_IOBase.flush' (inherited from C extension _IOBase)"]
    - [iobase_readable_qn, IOBase.readable.__qualname__.__eq__, ["_IOBase.readable"], true,  "io.IOBase.readable.__qualname__ == '_IOBase.readable' (inherited from C extension _IOBase)"]
    - [iobase_close_not_io, IOBase.close.__qualname__.__eq__,   ["IOBase.close"],     false, "io.IOBase.close.__qualname__ != 'IOBase.close' (qualname reflects the defining class _IOBase, not the accessing class IOBase)"]
    - [iobase_class_name,   IOBase.__class__.__name__.__eq__,   ["ABCMeta"],          true,  "io.IOBase.__class__.__name__ == 'ABCMeta' (IOBase uses ABCMeta as its metaclass)"]
    - [iobase_name_len,     IOBase.__name__.__len__,             [],                  6,     "io.IOBase.__name__.__len__() == 6 ('IOBase' has 6 characters)"]
    - [bufio_name_len,      BufferedIOBase.__name__.__len__,     [],                  14,    "io.BufferedIOBase.__name__.__len__() == 14 ('BufferedIOBase' has 14 characters; longest of the four ABCs)"]
    - [rawio_name_len,      RawIOBase.__name__.__len__,          [],                  9,     "io.RawIOBase.__name__.__len__() == 9 ('RawIOBase' has 9 characters)"]
    - [textio_name_len,     TextIOBase.__name__.__len__,         [],                  10,    "io.TextIOBase.__name__.__len__() == 10 ('TextIOBase' has 10 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra112.IOBase.module_is_io:
  description: "io.IOBase.__module__ == 'io' (the four abstract base classes IOBase/RawIOBase/BufferedIOBase/TextIOBase are Python-level ABCs defined in Lib/io.py; their __module__ is 'io', not '_io' like the concrete C extension types)"
  category: class_names
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra112.IOBase.bases_is_IOBase:
  description: "io.IOBase.__bases__[0].__name__ == '_IOBase' (the Python ABC IOBase directly subclasses the C extension type _IOBase from the _io module; this two-layer design lets the ABC register in Python's ABC machinery while delegating implementation to C)"
  category: class_names
  kind: python_call_eq
  function: "IOBase.__bases__[0].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

invariant io_extra112.IOBase.mro_len_3:
  description: "io.IOBase.__mro__.__len__() == 3 (IOBase's MRO is (IOBase, _IOBase, object); the two-layer Python/C ABC design yields a 3-entry MRO, shorter than the 5-entry MRO of the subclasses RawIOBase/BufferedIOBase/TextIOBase)"
  category: class_names
  kind: python_call_eq
  function: "IOBase.__mro__.__len__"
  args: []
  expected: 3

invariant io_extra112.IOBase.close_qualname_uses_underscored:
  description: "io.IOBase.close.__qualname__ == '_IOBase.close' (the method is actually defined on the C extension type _IOBase; when accessed via the Python ABC IOBase, the __qualname__ still reflects the defining class _IOBase, not the accessing class IOBase)"
  category: qualnames
  kind: python_call_eq
  function: IOBase.close.__qualname__.__eq__
  args: ["_IOBase.close"]
  expected: true

invariant io_extra112.BufferedIOBase.name_len_14:
  description: "io.BufferedIOBase.__name__.__len__() == 14 ('BufferedIOBase' is the longest __name__ among the four IO abstract base classes; IOBase=6, RawIOBase=9, TextIOBase=10, BufferedIOBase=14)"
  category: class_names
  kind: python_call_eq
  function: BufferedIOBase.__name__.__len__
  args: []
  expected: 14

