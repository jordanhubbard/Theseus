spec: bisect_extra9
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl and prior extras through bisect_extra8.zspec.zsdl."
    - "bisect.zspec.zsdl covers: bisect_left/bisect_right tables on [1,3,5,7,9]; duplicates on [1,3,5,5,5,7]; bisect alias; lo/hi args; function __name__ identity."
    - "bisect_extra.zspec.zsdl covers: bisect_left/__module__=='_bisect'; bisect_right/__name__; insort_left/insort_right/__name__; bisect/__name__; insort/__name__; behavioral on [1,2,3,4,5] and [1,2,3,3,3,4]."
    - "bisect_extra2.zspec.zsdl covers: insort/__name__; insort_left/__name__; insort_right/__name__; bisect/__name__; bisect_left([1,3,5,7],4)==2."
    - "bisect_extra3.zspec.zsdl covers: __module__ for bisect/bisect_right/insort/insort_left/insort_right; __name__ for bisect_left/bisect_right/insort_left/insort_right; behavioral on [1,2,3,4,5]."
    - "bisect_extra4.zspec.zsdl covers: bisect module __name__; behavioral on [1,2,3,3,4] and [2,4,6,8,10]."
    - "bisect_extra5.zspec.zsdl covers: __qualname__ for all bisect functions; behavioral on [1,3,5,7] (multiple search values)."
    - "bisect_extra6.zspec.zsdl covers: __name__ table (id_prefix bname); module identity table; behavioral on [10,20,30,40,50]."
    - "bisect_extra7.zspec.zsdl covers: bisect_left/bisect_right __module__ standalone; bisect_left/bisect_right/insort_left/insort_right __qualname__ standalone; behavioral on [5,10,15,20,25]."
    - "bisect_extra8.zspec.zsdl covers: insort_left/insort_right/bisect/insort __module__ standalone; behavioral on [3,6,9,12,15]."
    - "This spec adds: __name__ for bisect_left/bisect_right/insort/insort_left as a grouped table under id_prefix bname9 (extra9 namespace, distinct structural anchor from bisect_extra6 id_prefix bname); behavioral on [4,8,12,16,20] (multiples of 4, not used in any prior spec)."
    - "bisect.bisect_left.__name__ == 'bisect_left' — C extension function; grouped in bname9 table (extra9 namespace anchor)."
    - "bisect.bisect_right.__name__ == 'bisect_right' — C extension function; grouped in bname9 table (extra9 namespace anchor)."
    - "bisect.insort.__name__ == 'insort_right' — insort is an alias for insort_right; __name__ reflects the canonical name."
    - "bisect.insort_left.__name__ == 'insort_left' — C extension function; grouped in bname9 table (extra9 namespace anchor)."
    - "bisect_left([4,8,12,16,20], 10) == 2 — 10 falls between 8 (index 1) and 12 (index 2); left insertion at index 2."
    - "bisect_right([4,8,12,16,20], 12) == 3 — 12 at index 2; right insertion point is 3."
    - "bisect_left([4,8,12,16,20], 12) == 2 — 12 at index 2; left insertion point is 2 (element present)."
    - "bisect_left([4,8,12,16,20], 4) == 0 — 4 at index 0; left insertion point is 0."
    - "bisect_right([4,8,12,16,20], 3) == 0 — 3 is less than all elements; insertion at index 0."
    - "bisect_right([4,8,12,16,20], 20) == 5 — 20 at index 4; right insertion point is 5."
    - "bisect_left([4,8,12,16,20], 21) == 5 — 21 is after all elements; insertion at end."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ grouped table — extra9 namespace, id_prefix bname9
#
# bisect_extra6 uses id_prefix bname in a __name__ table covering bisect_left,
# bisect_right, bisect, insort_left, insort_right, and insort.
# This table uses id_prefix bname9 (extra9 namespace) and focuses on the four
# assigned axes: bisect_left/__name__, bisect_right/__name__,
# insort/__name__, insort_left/__name__. This provides a distinct structural
# anchor in the extra9 namespace.
# ---------------------------------------------------------------------------

table bisect_extra9.function_names:
  kind: python_call_eq
  category: function_identity
  id_prefix: bname9

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__name__.__eq__,  ["bisect_left"],  true]
    - [bisect_right, bisect_right.__name__.__eq__,  ["bisect_right"], true]
    - [insort,       insort.__name__.__eq__,        ["insort_right"], true]
    - [insort_left,  insort_left.__name__.__eq__,   ["insort_left"],  true]

# ---------------------------------------------------------------------------
# Behavioral invariants — [4, 8, 12, 16, 20] (multiples of 4)
#
# This input is distinct from all prior spec inputs:
#   bisect        uses [1,3,5,7,9] and [1,3,5,5,5,7]
#   bisect_extra  uses [1,2,3,4,5] and [1,2,3,3,3,4]
#   bisect_extra2 uses [1,3,5,7]
#   bisect_extra3 uses [1,2,3,4,5]
#   bisect_extra4 uses [1,2,3,3,4] and [2,4,6,8,10]
#   bisect_extra5 uses [1,3,5,7]
#   bisect_extra6 uses [10,20,30,40,50]
#   bisect_extra7 uses [5,10,15,20,25]
#   bisect_extra8 uses [3,6,9,12,15]
# [4,8,12,16,20] is a new fixture not used in any prior spec.
# ---------------------------------------------------------------------------

invariant bisect_extra9.bisect_left.fours_gap:
  description: "bisect_left([4,8,12,16,20], 10) == 2 — 10 falls between 8 and 12; left insertion at index 2"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[4, 8, 12, 16, 20], 10]
  expected: 2

invariant bisect_extra9.bisect_right.fours_present_twelve:
  description: "bisect_right([4,8,12,16,20], 12) == 3 — 12 at index 2; right insertion point is 3"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[4, 8, 12, 16, 20], 12]
  expected: 3

invariant bisect_extra9.bisect_left.fours_present_twelve:
  description: "bisect_left([4,8,12,16,20], 12) == 2 — 12 at index 2; left insertion point is 2"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[4, 8, 12, 16, 20], 12]
  expected: 2

invariant bisect_extra9.bisect_left.fours_first:
  description: "bisect_left([4,8,12,16,20], 4) == 0 — 4 at index 0; left insertion at beginning"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[4, 8, 12, 16, 20], 4]
  expected: 0

invariant bisect_extra9.bisect_right.fours_before_all:
  description: "bisect_right([4,8,12,16,20], 3) == 0 — 3 is less than all elements; insertion at index 0"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[4, 8, 12, 16, 20], 3]
  expected: 0

invariant bisect_extra9.bisect_right.fours_present_last:
  description: "bisect_right([4,8,12,16,20], 20) == 5 — 20 at index 4; right insertion point is 5"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[4, 8, 12, 16, 20], 20]
  expected: 5

invariant bisect_extra9.bisect_left.fours_after_all:
  description: "bisect_left([4,8,12,16,20], 21) == 5 — 21 exceeds all elements; insertion at end"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[4, 8, 12, 16, 20], 21]
  expected: 5
