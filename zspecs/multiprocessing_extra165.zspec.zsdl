table multiprocessing_extra165.mp_sync_manager_identity:
  description: "multiprocessing.managers.SyncManager class name and module identity checks in mpsmid165 namespace — multiprocessing.managers.SyncManager.__name__.__eq__('SyncManager')==True (SyncManager.__name__=='SyncManager' (len=11: 'Sync'=4+'Manager'=7=11); SyncManager is the concrete manager class pre-registered with synchronization primitive types; use multiprocessing.Manager() as a factory to create a SyncManager instance started in its own process; SyncManager provides: Lock(), RLock(), Semaphore(), BoundedSemaphore(), Event(), Condition(), Queue(), Namespace(), Value(), Array(), dict(), list() — all as cross-process proxies); multiprocessing.managers.SyncManager.__name__.__len__()==11 ('SyncManager'=11: 'Sync'=4+'Manager'=7=11; KEY: same length as BaseManager=11 because 'Base'=4=='Sync'=4 — both prefixes are exactly 4 chars followed by the shared 'Manager'=7 suffix); multiprocessing.managers.SyncManager.__module__.__eq__('multiprocessing.managers')==True (__module__=='multiprocessing.managers' (len=24; same module as BaseManager — both in the same managers.py file)); multiprocessing.managers.SyncManager.__module__.__len__()==24; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsmid165

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name_eq,  multiprocessing.managers.SyncManager.__name__.__eq__,    ["SyncManager"],               true,  "SyncManager.__name__ == 'SyncManager' (len=11: 'Sync'=4+'Manager'=7=11; same len as BaseManager); verified with Python 3.14.3"]
    - [sm_name_len, multiprocessing.managers.SyncManager.__name__.__len__,   [],                            11,    "SyncManager.__name__.__len__() == 11 ('SyncManager'=11; same as BaseManager=11: 'Base'=4=='Sync'=4); verified with Python 3.14.3"]
    - [sm_mod_eq,   multiprocessing.managers.SyncManager.__module__.__eq__,  ["multiprocessing.managers"],  true,  "SyncManager.__module__ == 'multiprocessing.managers' (len=24; same module as BaseManager); verified with Python 3.14.3"]
    - [sm_mod_len,  multiprocessing.managers.SyncManager.__module__.__len__, [],                            24,    "SyncManager.__module__.__len__() == 24 ('multiprocessing.managers'=24; same as BaseManager module=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.managers.SyncManager base class — extra165
#
# multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') == True
# multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__()             == 11
# ---------------------------------------------------------------------------

table multiprocessing_extra165.mp_sync_manager_base_and_comparison:
  description: "multiprocessing.managers.SyncManager base class and BaseManager/SyncManager cross-comparison in mpsmbase165 namespace — multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager')==True (SyncManager.__bases__ == (<class 'multiprocessing.managers.BaseManager'>,); __bases__[0].__name__=='BaseManager' (len=11: 'BaseManager'=11; the base class name IS the parent class name 'BaseManager')); multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__()==11 ('BaseManager'=11; KEY: the base class name len(11) equals the derived class name len(11) — SyncManager(11) inherits from BaseManager(11); both names have the same length because 'Base'=4=='Sync'=4 and both share 'Manager'=7); BaseManager.__name__.__len__()==11 (cross-check; same as SyncManager=11 — both are 11-char names); BaseManager.__module__.__len__()==24 (cross-check; same as SyncManager module=24); KEY PATTERN: BaseManager and SyncManager have equal name lengths (11) and equal module path lengths (24) — the only difference is their prefix: 'Base' vs 'Sync'; MRO for SyncManager is SyncManager -> BaseManager -> object (len=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsmbase165

  columns: [id, function, args, expected, description]
  rows:
    - [sm_base_name_eq,  "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__",  ["BaseManager"],  true,  "SyncManager.__bases__[0].__name__ == 'BaseManager' (SyncManager IS-A BaseManager; inherits all manager machinery); verified with Python 3.14.3"]
    - [sm_base_name_len, "multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__", [],               11,    "SyncManager.__bases__[0].__name__.__len__() == 11 ('BaseManager'=11; same as SyncManager name len=11); verified with Python 3.14.3"]
    - [bm_name_len3,     multiprocessing.managers.BaseManager.__name__.__len__,                [],               11,    "BaseManager.__name__.__len__() == 11 (cross-check; same as SyncManager=11; both 4-char prefix + Manager=7); verified with Python 3.14.3"]
    - [sm_name_len2,     multiprocessing.managers.SyncManager.__name__.__len__,                [],               11,    "SyncManager.__name__.__len__() == 11 (cross-check; same as BaseManager=11); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra165
# ---------------------------------------------------------------------------

invariant multiprocessing_extra165.mp_BaseManager_name_eq:
  description: "multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager') returns True — multiprocessing.managers.BaseManager.__name__=='BaseManager' (len=11: 'Base'=4+'Manager'=7=11); BaseManager is the root class of the multiprocessing manager system; it provides the infrastructure for running a server process that owns shared objects and exposes them via proxies to client processes; BaseManager.start() starts the manager server process; BaseManager.connect() connects a remote manager; BaseManager.__enter__/__exit__ enable the context manager protocol (with multiprocessing.Manager() as m: m.Queue()); users extend BaseManager by calling register() at the class level to add managed type factories; multiprocessing.Manager() is a factory function that creates a SyncManager (a pre-configured subclass); BaseManager.__module__=='multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24); compare: multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20; 4 shorter because 'pool'=4 vs 'managers'=8); NEW in extra165: first standalone BaseManager.__name__ identity invariant in mpbmid165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__name__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra165.mp_BaseManager_module_eq:
  description: "multiprocessing.managers.BaseManager.__module__.__eq__('multiprocessing.managers') returns True — multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24); BaseManager and SyncManager are both defined in Lib/multiprocessing/managers.py — they share the same module path; 'multiprocessing.managers' (len=24) is longer than 'multiprocessing.pool' (len=20) by 4 chars because 'managers'=8 > 'pool'=4 by 4; compare: 'concurrent.futures._base'=24 has the same length as 'multiprocessing.managers'=24 — both are 24-char module paths for base/manager classes in their respective frameworks; the 'managers' submodule (len=8) is the longest single component in the multiprocessing package's submodule paths (compare: 'pool'=4, 'queues'=6, 'context'=7, 'process'=7); NEW in extra165: first standalone BaseManager.__module__ identity invariant in mpbmid165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra165.mp_BaseManager_base_is_object:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object') returns True — multiprocessing.managers.BaseManager.__bases__[0] is object; BaseManager.__bases__[0].__name__=='object' (len=6); BaseManager inherits from object directly — it is the root of the manager class hierarchy with no intermediate base class; compare: SyncManager.__bases__[0].__name__=='BaseManager' (SyncManager inherits from BaseManager — not object; there IS an intermediate class in SyncManager's hierarchy); the base class pattern: BaseManager -> object (direct inheritance), SyncManager -> BaseManager -> object (one intermediate); compare: multiprocessing.pool.Pool.__bases__[0].__name__=='object' (from extra164: Pool also inherits from object directly; both Pool and BaseManager are multiprocessing root classes); compare: concurrent.futures.Executor.__bases__[0].__name__=='object' (Executor also inherits from object — all three framework base classes root at object directly); NEW in extra165: first standalone BaseManager.__bases__[0].__name__ invariant in mpbmbase165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra165.mp_SyncManager_name_eq:
  description: "multiprocessing.managers.SyncManager.__name__.__eq__('SyncManager') returns True — multiprocessing.managers.SyncManager.__name__=='SyncManager' (len=11: 'Sync'=4+'Manager'=7=11); SyncManager is the concrete manager class returned by the multiprocessing.Manager() convenience function; SyncManager pre-registers proxies for Python synchronization and collection types: Lock(), RLock(), Semaphore(), BoundedSemaphore(), Event(), Condition(), Barrier(), Queue(), Namespace(), Value(typecode, value), Array(typecode, sequence), dict(), list(); SyncManager allows multiple processes to share these objects safely by proxying method calls through the manager server process; SyncManager.__name__.__len__()==11 == BaseManager.__name__.__len__()==11 — a KEY COINCIDENCE: both have the same 11-char name length because 'Sync'=4=='Base'=4 and both share the 'Manager'=7 suffix; NEW in extra165: first standalone SyncManager.__name__ identity invariant in mpsmid165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.SyncManager.__name__.__eq__
  args: ["SyncManager"]
  expected: true

invariant multiprocessing_extra165.mp_SyncManager_base_is_BaseManager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — multiprocessing.managers.SyncManager.__bases__[0] is multiprocessing.managers.BaseManager; SyncManager.__bases__[0].__name__=='BaseManager' (len=11); SyncManager inherits all of BaseManager's manager infrastructure (start(), connect(), register(), __enter__/__exit__) and adds pre-registered type factories for synchronization primitives; the MRO is SyncManager -> BaseManager -> object (len=3); SyncManager IS-A BaseManager — isinstance checks against BaseManager return True for SyncManager instances; SyncManager.__bases__[0].__name__.__len__()==11 == SyncManager.__name__.__len__()==11 (the base class name length equals the derived class name length — both are 11-char names because 'Base'=4=='Sync'=4 and 'Manager'=7 is shared); compare: concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__=='Executor' (len=8; TPE also embeds its base class name 'Executor' as a suffix in 'ThreadPoolExecutor'=18); NEW in extra165: first standalone SyncManager.__bases__[0].__name__ invariant in mpsmbase165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra165.mp_SyncManager_module_eq:
  description: "multiprocessing.managers.SyncManager.__module__.__eq__('multiprocessing.managers') returns True — multiprocessing.managers.SyncManager.__module__=='multiprocessing.managers' (len=24: same module as BaseManager; both are defined in Lib/multiprocessing/managers.py); SyncManager and BaseManager share the same 24-char module path — they are co-located in the same source file; 'multiprocessing.managers' (len=24): 'multiprocessing'=15 is the longest component, 'managers'=8 is the submodule; BaseManager.__module__ == SyncManager.__module__ == 'multiprocessing.managers' — module equality; compare: multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20; 4 shorter than multiprocessing.managers=24 because 'pool'=4 vs 'managers'=8 differs by 4 chars); NEW in extra165: first standalone SyncManager.__module__ identity invariant in mpsmid165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.SyncManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true
