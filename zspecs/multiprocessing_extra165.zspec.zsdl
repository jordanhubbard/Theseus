spec: multiprocessing_extra165
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#managers

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers — Python multiprocessing managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec covers: multiprocessing.managers.BaseManager class name, module, and base class identity; multiprocessing.managers.SyncManager class name, module, and base class identity. Both are defined in Lib/multiprocessing/managers.py: __module__=='multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24). BaseManager.__bases__[0].__name__=='object'; SyncManager.__bases__[0].__name__=='BaseManager'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.managers.BaseManager.__name__=='BaseManager' (len=11: 'Base'=4+'Manager'=7=11); __module__=='multiprocessing.managers' (len=24); __bases__[0].__name__=='object' (inherits from object directly; BaseManager is the base class for all manager classes; it provides the server/proxy mechanism for sharing objects across process boundaries using sockets and pickling). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.managers.SyncManager.__name__=='SyncManager' (len=11: 'Sync'=4+'Manager'=7=11; same length as BaseManager=11: 'Base'=4=='Sync'=4 in prefix length, sharing 'Manager'=7 suffix); __module__=='multiprocessing.managers' (len=24; same module as BaseManager); __bases__[0].__name__=='BaseManager' (len=11; SyncManager inherits from BaseManager; SyncManager provides managed proxies for synchronization primitives: Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Queue, Namespace, Value, Array, and dict/list). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseManager class identity — extra165
#
# multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager') == True
# multiprocessing.managers.BaseManager.__name__.__len__()             == 11
# multiprocessing.managers.BaseManager.__module__.__eq__('multiprocessing.managers') == True
# multiprocessing.managers.BaseManager.__module__.__len__()           == 24
# ---------------------------------------------------------------------------

table multiprocessing_extra165.mp_base_manager_identity:
  description: "multiprocessing.managers.BaseManager class name and module identity checks in mpbmid165 namespace — multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager')==True (BaseManager.__name__=='BaseManager' (len=11: 'Base'=4+'Manager'=7=11); BaseManager is the foundational class for multiprocessing's shared-state manager system; it starts a server process that owns shared objects and provides proxies that marshal method calls across process boundaries via sockets and pickle; users subclass BaseManager and call cls.register('type_name', TypeClass) to register types that the manager can create and proxy); multiprocessing.managers.BaseManager.__name__.__len__()==11 ('BaseManager'=11: 'Base'=4+'Manager'=7=11; same length as SyncManager=11: 'Sync'=4+'Manager'=7=11 — both use a 4-char prefix followed by 'Manager'=7); multiprocessing.managers.BaseManager.__module__.__eq__('multiprocessing.managers')==True (__module__=='multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24)); multiprocessing.managers.BaseManager.__module__.__len__()==24 ('multiprocessing.managers'=24; compare: 'multiprocessing.pool'=20 is 4 shorter; 'concurrent.futures._base'=24 is the same length); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbmid165

  columns: [id, function, args, expected, description]
  rows:
    - [bm_name_eq,  multiprocessing.managers.BaseManager.__name__.__eq__,    ["BaseManager"],                  true,  "BaseManager.__name__ == 'BaseManager' (len=11: 'Base'=4+'Manager'=7=11); verified with Python 3.14.3"]
    - [bm_name_len, multiprocessing.managers.BaseManager.__name__.__len__,   [],                               11,    "BaseManager.__name__.__len__() == 11 ('BaseManager'=11; same as SyncManager=11); verified with Python 3.14.3"]
    - [bm_mod_eq,   multiprocessing.managers.BaseManager.__module__.__eq__,  ["multiprocessing.managers"],     true,  "BaseManager.__module__ == 'multiprocessing.managers' (len=24; 'managers'=8 submodule); verified with Python 3.14.3"]
    - [bm_mod_len,  multiprocessing.managers.BaseManager.__module__.__len__, [],                               24,    "BaseManager.__module__.__len__() == 24 ('multiprocessing.managers'=24; same as cf._base=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseManager base class — extra165
#
# multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object') == True
# multiprocessing.managers.BaseManager.__bases__[0].__name__.__len__()        == 6
# ---------------------------------------------------------------------------

table multiprocessing_extra165.mp_base_manager_base_class:
  description: "multiprocessing.managers.BaseManager base class checks in mpbmbase165 namespace — multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object')==True (BaseManager.__bases__ == (<class 'object'>,); __bases__[0].__name__=='object' (len=6: 'o'+'b'+'j'+'e'+'c'+'t'=6); BaseManager inherits from object directly with no intermediate base class; as the root of the manager hierarchy, BaseManager provides all the machinery for starting the manager server process, registering managed types, creating proxies, and managing connections; compare: SyncManager.__bases__[0].__name__=='BaseManager' (SyncManager inherits from BaseManager, not object — SyncManager IS-A BaseManager, adding registered types for synchronization primitives)); multiprocessing.managers.BaseManager.__bases__[0].__name__.__len__()==6 ('object'=6; same as asyncio.Future.__name__.__len__()==6 (from extra166) — the base class name 'object' equals Future's name in length); bm_name_len cross-check: BaseManager.__name__.__len__()==11; bm_mod_len cross-check: BaseManager.__module__.__len__()==24; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbmbase165

  columns: [id, function, args, expected, description]
  rows:
    - [bm_base_name_eq,  "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__",  ["object"],  true,  "BaseManager.__bases__[0].__name__ == 'object' (BaseManager inherits from object; root of manager hierarchy); verified with Python 3.14.3"]
    - [bm_base_name_len, "multiprocessing.managers.BaseManager.__bases__[0].__name__.__len__", [],          6,     "BaseManager.__bases__[0].__name__.__len__() == 6 ('object'=6; same as asyncio.Future name len=6); verified with Python 3.14.3"]
    - [bm_name_len2,     multiprocessing.managers.BaseManager.__name__.__len__,                [],          11,    "BaseManager.__name__.__len__() == 11 (cross-check; 'BaseManager'=11); verified with Python 3.14.3"]
    - [bm_mod_len2,      multiprocessing.managers.BaseManager.__module__.__len__,               [],          24,    "BaseManager.__module__.__len__() == 24 (cross-check; 'multiprocessing.managers'=24); verified with Python 3.14.3"]

