    - ["mp3286021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__imul__"], false]
    - ["mp3286022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__imul__"], false]
    - ["mp3286023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__imul__"], false]
    - ["mp3286024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__imul__"], false]

# ---------------------------------------------------------------------------
# combined — __iadd__, __isub__, __imul__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __iadd__: false for all 8 — not in any type's own __dict__.
# __isub__: false for all 8 — not in any type's own __dict__.
# __imul__: false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# BaseListProxy asymmetry — the central finding of this wave:
#   Wave 658: BaseListProxy.__add__ = true (list concatenation is forwarded).
#   Wave 658: BaseListProxy.__mul__ = true (list repetition is forwarded).
#   Wave 666: BaseListProxy.__iadd__ = false (in-place extend NOT forwarded).
#   Wave 666: BaseListProxy.__imul__ = false (in-place repeat NOT forwarded).
#   The proxy infrastructure forwards read-like and value-returning operations
#   (__add__, __mul__) but does not forward mutating in-place operations
#   (__iadd__, __imul__) that would require modifying the server-side object
#   and returning self through the IPC callthrough mechanism.
# _BaseSetProxy note: set defines __isub__ only through MutableSet ABC default
#   implementation (not in set.__dict__ itself), so _BaseSetProxy has nothing
#   to proxy for __isub__ either.
# multiprocessing is a process-based concurrency library; its types interact
#   exclusively through explicit method calls, subprocess lifecycle management,
#   and IPC — never through Python's in-place augmented assignment operators.
# ---------------------------------------------------------------------------

