spec: decimal_extra159
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal.__dict__ membership for key methods using __dict__.__contains__, and Decimal.__dict__.__len__()."
    - "decimal.Decimal.__dict__.__contains__('quantize') == True (len('quantize')=8)."
    - "decimal.Decimal.__dict__.__contains__('sqrt') == True (len('sqrt')=4)."
    - "decimal.Decimal.__dict__.__contains__('compare') == True (len('compare')=7)."
    - "decimal.Decimal.__dict__.__contains__('normalize') == True (len('normalize')=9)."
    - "decimal.Decimal.__dict__.__contains__('fma') == True (len('fma')=3)."
    - "decimal.Decimal.__dict__.__contains__('ln') == True (len('ln')=2)."
    - "decimal.Decimal.__dict__.__contains__('log10') == True (len('log10')=5)."
    - "decimal.Decimal.__dict__.__len__() == 101 — the Decimal class dict contains 101 entries."
    - "Key name length ranking among the first group: sqrt=4, log10=5, compare=7, quantize=8, normalize=9."
    - "fma (3 chars) and ln (2 chars) are the shortest key names checked."
    - "ln (2 chars) is the shortest key name: 'logarithm natural' abbreviated to just 2 characters."
    - "Decimal has no __slots__ — Decimal.__dict__ exists and has 101 entries."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ membership for mathematical methods
# quantize (len=8), sqrt (len=4), compare (len=7), normalize (len=9)
# All return True from __dict__.__contains__
# ---------------------------------------------------------------------------

table decimal_extra159.Decimal_dict_math_methods:
  description: "decimal.Decimal.__dict__ membership: quantize (len=8), sqrt (len=4), compare (len=7), normalize (len=9) — all present; ascending key name lengths: sqrt=4, compare=7, quantize=8, normalize=9"
  kind: python_call_eq
  category: identity
  id_prefix: ddict159

  columns: [id, function, args, expected, description]
  rows:
    - [dec_quantize_in,   "decimal.Decimal.__dict__.__contains__",  ["quantize"],   true, "decimal.Decimal.__dict__.__contains__('quantize') == True (quantize is directly defined in Decimal.__dict__; Decimal.quantize(exp) returns a value equal to the first operand after rounding and having the exponent of exp; Decimal('1.41421356').quantize(Decimal('0.01')) == Decimal('1.41'); 'quantize' has 8 characters: 'q-u-a-n-t-i-z-e'; quantize is the primary method for controlling decimal precision and scale; quantize (8) is the second-longest key name in this table after normalize (9); quantize is one of the most important Decimal methods for financial calculations requiring exact decimal rounding)"]
    - [dec_sqrt_in,       "decimal.Decimal.__dict__.__contains__",  ["sqrt"],       true, "decimal.Decimal.__dict__.__contains__('sqrt') == True (sqrt is directly defined in Decimal.__dict__; Decimal.sqrt() returns the square root with full precision using the current context; Decimal('2').sqrt() == Decimal('1.414213562373095048801688724'); 'sqrt' has 4 characters — the shortest mathematical method name in this table; sqrt (4) < log10 (5) < compare (7) < quantize (8) < normalize (9) in key name length; the short name 'sqrt' is a standard mathematical abbreviation for 'square root'; Decimal.sqrt() produces a correctly-rounded result according to the current context precision)"]
    - [dec_compare_in,    "decimal.Decimal.__dict__.__contains__",  ["compare"],    true, "decimal.Decimal.__dict__.__contains__('compare') == True (compare is directly defined in Decimal.__dict__; Decimal.compare(other) performs a numeric comparison and returns Decimal('-1'), Decimal('0'), or Decimal('1') based on whether self is less than, equal to, or greater than other; unlike Python's < operator, compare() follows IEEE 754 total ordering; 'compare' has 7 characters: 'c-o-m-p-a-r-e'; compare (7) sits between log10 (5) and quantize (8) in key name length; compare() is distinct from __lt__/__eq__/__gt__ in that it returns a Decimal result rather than a bool)"]
    - [dec_normalize_in,  "decimal.Decimal.__dict__.__contains__",  ["normalize"],  true, "decimal.Decimal.__dict__.__contains__('normalize') == True (normalize is directly defined in Decimal.__dict__; Decimal.normalize() reduces the Decimal to its simplest form by removing trailing zeros from the coefficient and adjusting the exponent; Decimal('1.00').normalize() == Decimal('1'); 'normalize' has 9 characters: 'n-o-r-m-a-l-i-z-e'; normalize (9) is the longest key name in this table and the longest among the eight keys checked in this spec; normalize (9) is one longer than quantize (8) — a close pair; normalize() is useful for canonical representation and comparison of Decimal values)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ membership for short-name methods: fma, ln, log10
# Also check Decimal.__dict__.__len__() == 101
# fma (len=3), ln (len=2), log10 (len=5)
# ---------------------------------------------------------------------------

table decimal_extra159.Decimal_dict_short_methods_and_len:
  description: "decimal.Decimal.__dict__ membership: fma (len=3), ln (len=2), log10 (len=5) — all present; also Decimal.__dict__.__len__()==101; ln (2) is the shortest key name checked; log10 (5) sits between fma (3) and compare (7)"
  kind: python_call_eq
  category: identity
  id_prefix: ddict159

  columns: [id, function, args, expected, description]
  rows:
    - [dec_fma_in,      "decimal.Decimal.__dict__.__contains__",  ["fma"],    true, "decimal.Decimal.__dict__.__contains__('fma') == True (fma is directly defined in Decimal.__dict__; Decimal.fma(other, third) computes the fused multiply-add: (self * other) + third with a single rounding step; 'fma' stands for Fused Multiply-Add — an IEEE 754 operation that avoids intermediate rounding errors; 'fma' has 3 characters — an acronym-style abbreviation; fma (3) is the second-shortest key name in this spec after ln (2); fma is important in numerical computing where avoiding the double rounding of a separate multiply-then-add is critical; Decimal.fma() is rare in everyday Python code but required for strict IEEE 754 compliance)"]
    - [dec_ln_in,       "decimal.Decimal.__dict__.__contains__",  ["ln"],     true, "decimal.Decimal.__dict__.__contains__('ln') == True (ln is directly defined in Decimal.__dict__; Decimal.ln() returns the natural logarithm (base e) of the Decimal using the current context precision; Decimal('1').ln() == Decimal('0'); 'ln' has 2 characters — the shortest key name among all keys checked in this spec; 'ln' is the traditional mathematical abbreviation for 'logarithmus naturalis' (natural logarithm); ln (2) stands alone as the minimum key name length in this spec; contrast with log10 (5 chars) which uses the longer form with the base appended; Decimal.ln() computes transcendental functions to arbitrary precision)"]
    - [dec_log10_in,    "decimal.Decimal.__dict__.__contains__",  ["log10"],  true, "decimal.Decimal.__dict__.__contains__('log10') == True (log10 is directly defined in Decimal.__dict__; Decimal.log10() returns the base-10 logarithm of the Decimal using the current context precision; Decimal('100').log10() == Decimal('2'); 'log10' has 5 characters: 'log' (3) + '10' (2) = 5; log10 (5) sits between fma (3) and compare (7) in key name length; log10 is commonly used in financial and scientific calculations; the digit '10' in the name makes log10 (5) longer than ln (2) but shorter than the word-based names compare (7), quantize (8), normalize (9))"]
    - [dec_dict_len,    "decimal.Decimal.__dict__.__len__",        [],         101,  "decimal.Decimal.__dict__.__len__() == 101 — the Decimal class dictionary contains exactly 101 entries on Python 3.14.3; this count includes all methods, dunders, and properties defined directly on Decimal: arithmetic operations (__add__, __sub__, __mul__, __truediv__, __mod__, __pow__), comparison dunders (__lt__, __le__, __eq__, __ge__, __gt__), unary operations (__neg__, __pos__, __abs__), conversion dunders (__int__, __float__, __complex__, __bool__, __str__, __repr__, __format__), mathematical methods (sqrt, ln, log10, exp, quantize, compare, normalize, fma, remainder_near), predicate methods (is_finite, is_nan, is_zero, is_signed, etc.), and more; 101 entries reflects the comprehensive IEEE 754 decimal arithmetic API"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra159.Decimal_quantize_in_dict:
  description: "decimal.Decimal.__dict__.__contains__('quantize') == True — quantize is directly defined on Decimal (not inherited from object); 'quantize' has 8 characters; quantize is the primary method for controlling Decimal precision and rounding to a specific exponent; it is essential in financial applications where values must be rounded to a fixed number of decimal places (e.g., monetary amounts to 2 decimal places); quantize (8) is the second-longest key name among the eight keys checked in this spec, after normalize (9); Decimal has no __slots__, so its __dict__ with 101 entries is accessible; confirmed True on Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__contains__"
  args: ["quantize"]
  expected: true

invariant decimal_extra159.Decimal_ln_is_shortest_key_at_2:
  description: "decimal.Decimal.__dict__.__contains__('ln') == True — 'ln' (2 chars) is the shortest key name among all eight keys checked in this spec; the ascending key name length sequence: ln=2, fma=3, sqrt=4, log10=5, compare=7, quantize=8, normalize=9; 'ln' (2 chars) is an extreme abbreviation — the natural logarithm is abbreviated to just two characters in the Decimal API; Decimal.ln() computes the natural logarithm to arbitrary precision using the current decimal context; 'ln' (2 chars) is shorter than any re module function qualname except re.sub (3 chars); confirmed True on Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__contains__"
  args: ["ln"]
  expected: true

invariant decimal_extra159.Decimal_dict_has_101_entries:
  description: "decimal.Decimal.__dict__.__len__() == 101 — Decimal's class dictionary has exactly 101 entries on Python 3.14.3; this large count (101) reflects the comprehensive IEEE 754 decimal arithmetic standard that Decimal implements; Decimal has no __slots__ (hasattr(Decimal, '__slots__') is False), so its __dict__ is the standard mappingproxy of all class-level attributes; 101 entries is significantly more than a typical Python class — the extensive mathematical, comparison, and formatting method set contributes to this count; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__len__"
  args: []
  expected: 101

invariant decimal_extra159.Decimal_normalize_longest_checked_key:
  description: "decimal.Decimal.__dict__.__contains__('normalize') == True — 'normalize' (9 chars) is the longest key name among all eight keys checked in this spec; the ascending sequence: ln=2, fma=3, sqrt=4, log10=5, compare=7, quantize=8, normalize=9; normalize stands alone at 9 — the unique maximum; normalize() reduces a Decimal to its simplest canonical form by stripping trailing zeros; 'normalize' (9 chars) is longer than 'quantize' (8 chars) by 1; the 9-character method name 'normalize' contrasts with the ultra-short 'ln' (2 chars) — the two extremes spanning a factor-4.5 difference in key name length within the same Decimal.__dict__; confirmed True on Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__contains__"
  args: ["normalize"]
  expected: true

