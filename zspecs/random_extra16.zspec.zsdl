spec: random_extra16
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra15.zspec.zsdl."
    - "random_extra6 covers __qualname__ for module-level functions: random/randint/randrange/choice/choices/shuffle/sample/uniform/seed/getstate/setstate."
    - "random_extra13 covers __qualname__ for Random and SystemRandom classes."
    - "random_extra15 covers shuffle/__qualname__ and choices/__qualname__ as standalone invariants."
    - "No prior spec accesses __qualname__ via the class attribute path Random.seed, Random.randint, etc."
    - "random.Random.seed.__qualname__ == 'Random.seed' — method qualname includes class prefix."
    - "random.Random.random.__qualname__ == 'Random.random' — C method_descriptor qualname."
    - "random.Random.randint.__qualname__ == 'Random.randint' — method qualname includes class prefix."
    - "random.Random.choice.__qualname__ == 'Random.choice' — method qualname includes class prefix."
    - "random.Random.shuffle.__qualname__ == 'Random.shuffle' — method qualname includes class prefix."
    - "random.Random.uniform.__qualname__ == 'Random.uniform' — method qualname includes class prefix."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# random.Random method __qualname__ attributes via class attribute path
#
# Prior specs cover module-level function __qualname__ (random_extra6) and
# class __qualname__ (random_extra13). No prior spec accesses __qualname__
# via the class attribute path random.Random.<method>. These invariants
# confirm that the method qualname includes the class name prefix 'Random.'
# regardless of whether the method is a pure-Python function or a
# C method_descriptor (e.g., random.Random.random).
# ---------------------------------------------------------------------------

table random_extra16.class_method_qualnames:
  description: "__qualname__ for random.Random methods accessed via class attribute path"
  kind: python_call_eq
  category: function_identity
  id_prefix: rmqn

  columns: [id, function, args, expected]
  rows:
    - [seed,    "Random.seed.__qualname__.__eq__",    ["Random.seed"],    true]
    - [random,  "Random.random.__qualname__.__eq__",  ["Random.random"],  true]
    - [randint, "Random.randint.__qualname__.__eq__", ["Random.randint"], true]
    - [choice,  "Random.choice.__qualname__.__eq__",  ["Random.choice"],  true]
    - [shuffle, "Random.shuffle.__qualname__.__eq__", ["Random.shuffle"], true]
    - [uniform, "Random.uniform.__qualname__.__eq__", ["Random.uniform"], true]
