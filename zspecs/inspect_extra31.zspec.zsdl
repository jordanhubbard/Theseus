spec: inspect_extra31
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra30.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/__name__, getmembers/signature/Parameter/Signature/BoundArguments identity, Parameter kind class names, empty sentinel class names, class __bases__[0].__name__ for Parameter/Signature/BoundArguments, various __qualname__ and __module__ checks, method __qualname__.__len__() for Parameter.replace/__init__, Signature.bind/bind_partial/replace, BoundArguments.apply_defaults/__init__/__repr__, __mro__.__len__() for Parameter/Signature/BoundArguments (all 2), Parameter.empty.__qualname__.__len__()."
    - "This spec covers: inspect.__all__.__len__() (107) and .__class__.__name__.__len__() (4); __dict__.__class__.__name__.__len__() (12) for Parameter, Signature, BoundArguments, and FrameInfo; FrameInfo.__qualname__.__len__() (9) and .__mro__.__len__() (4); _ParameterKind.__qualname__.__len__() and .__name__.__len__() (both 14); CO_OPTIMIZED.__class__.__name__.__len__() (3); __qualname__.__len__() for iscode (6), isframe (7), isgenerator (11), iscoroutine (11), isasyncgen (10)."
    - "Key findings: inspect.__all__ has 107 entries (a list). All four key classes (Parameter, Signature, BoundArguments, FrameInfo) have mappingproxy __dict__ (len 12). FrameInfo.__mro__ has length 4 — FrameInfo -> _FrameInfo -> tuple -> object — unlike Parameter/Signature/BoundArguments which have __mro__ length 2. _ParameterKind (the enum backing Parameter.POSITIONAL_ONLY etc.) has __qualname__ and __name__ both 'l_ParameterKind' (14 chars). CO_OPTIMIZED, CO_NEWLOCALS etc. are plain ints."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table — mappingproxy for key classes
#
# inspect.Parameter.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# The same holds for inspect.Signature, inspect.BoundArguments, and
# inspect.FrameInfo — all four key inspect classes store their class namespace
# in a mappingproxy object. This is consistent with the standard CPython behavior
# for all type objects. No prior inspect spec records these four
# __dict__.__class__.__name__.__len__() values together in a combined table
# in the extra31 namespace.
# ---------------------------------------------------------------------------

table inspect_extra31.class_dict_typename_lengths:
  description: "__dict__.__class__.__name__.__len__() for key inspect classes — all 12 ('mappingproxy')"
  kind: python_call_eq
  category: class_dict_types
  id_prefix: dict_type_len

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter,
       Parameter.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(inspect.Parameter.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [Signature,
       Signature.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(inspect.Signature.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [BoundArguments,
       BoundArguments.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(inspect.BoundArguments.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [FrameInfo,
       FrameInfo.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(inspect.FrameInfo.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — async/generator predicate functions
#
# inspect.iscode has __qualname__ 'iscode' (6 chars). inspect.isframe has
# __qualname__ 'isframe' (7 chars). inspect.isgenerator and inspect.iscoroutine
# both have __qualname__ length 11. inspect.isasyncgen has __qualname__
# 'isasyncgen' (10 chars). These predicates test for code objects, frame objects,
# generator objects, coroutine objects, and async generator objects respectively.
# No prior inspect spec records these five __qualname__.__len__() values together
# in a combined table in the extra31 namespace.
# ---------------------------------------------------------------------------

table inspect_extra31.async_gen_predicate_qualname_lengths:
  description: "__qualname__.__len__() for code/frame/generator/coroutine/asyncgen predicates"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [iscode,
       iscode.__qualname__.__len__,
       [],
       6,
       "len(inspect.iscode.__qualname__) == 6 — 'iscode'"]
    - [isframe,
       isframe.__qualname__.__len__,
       [],
       7,
       "len(inspect.isframe.__qualname__) == 7 — 'isframe'"]
    - [isgenerator,
       isgenerator.__qualname__.__len__,
       [],
       11,
       "len(inspect.isgenerator.__qualname__) == 11 — 'isgenerator'"]
    - [iscoroutine,
       iscoroutine.__qualname__.__len__,
       [],
       11,
       "len(inspect.iscoroutine.__qualname__) == 11 — 'iscoroutine'"]
    - [isasyncgen,
       isasyncgen.__qualname__.__len__,
       [],
       10,
       "len(inspect.isasyncgen.__qualname__) == 10 — 'isasyncgen'"]

# ---------------------------------------------------------------------------
# inspect.__all__.__len__() — standalone invariant
#
# inspect.__all__ is a list of 107 public names exported by the inspect module.
# This is the largest __all__ list among the standard library modules tracked
# by this spec series, reflecting inspect's broad API surface covering predicates,
# source retrieval, stack introspection, signature analysis, and more. No prior
# inspect spec records inspect.__all__.__len__() as a standalone in the extra31
# namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra31.all_len:
  description: "len(inspect.__all__) == 107 — inspect exports 107 public names"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 107

# ---------------------------------------------------------------------------
# inspect.__all__.__class__.__name__.__len__() — standalone invariant
#
# inspect.__all__.__class__.__name__ is 'list' (4 chars). Like all standard
# library __all__ attributes, inspect.__all__ is a plain Python list (not a
# tuple or frozenset). Its class name length of 4 is the same as itertools and
# operator __all__ class name lengths. No prior inspect spec records
# __all__.__class__.__name__.__len__() as a standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra31.all_classname_len:
  description: "len(inspect.__all__.__class__.__name__) == 4 — '__all__' is a 'list'"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# inspect.FrameInfo.__qualname__.__len__() — standalone invariant
#
# inspect.FrameInfo.__qualname__ is 'FrameInfo' (9 chars). FrameInfo is a
# named-tuple-like class used as the return type of inspect.getouterframes and
# related functions. Its __qualname__ is the unqualified class name, matching
# its __name__. No prior inspect spec records FrameInfo.__qualname__.__len__()
# as a standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra31.FrameInfo_qualname_len:
  description: "len(inspect.FrameInfo.__qualname__) == 9 — 'FrameInfo' is 9 chars"
  category: string_properties
  kind: python_call_eq
  function: FrameInfo.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# inspect.FrameInfo.__mro__.__len__() — standalone invariant
#
# inspect.FrameInfo.__mro__ has length 4: [FrameInfo, _FrameInfo, tuple, object].
# This is notably different from Parameter, Signature, and BoundArguments which
# each have __mro__ length 2 (direct subclasses of object). FrameInfo inherits
# from the private _FrameInfo class which itself inherits from tuple, making
# it a namedtuple-style type with a deeper hierarchy. No prior inspect spec
# records FrameInfo.__mro__.__len__() as a standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra31.FrameInfo_mro_len:
  description: "len(inspect.FrameInfo.__mro__) == 4 — FrameInfo -> _FrameInfo -> tuple -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: FrameInfo.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# inspect._ParameterKind.__qualname__.__len__() — standalone invariant
#
# inspect._ParameterKind.__qualname__ is '_ParameterKind' (14 chars). This is
# the private enum class underlying inspect.Parameter.POSITIONAL_ONLY,
# KEYWORD_ONLY, VAR_POSITIONAL, VAR_KEYWORD, and POSITIONAL_OR_KEYWORD constants.
# The enum members themselves (e.g. Parameter.POSITIONAL_ONLY) do not have their
# own __qualname__ attribute; the class __qualname__ is 14 chars. No prior inspect
# spec records _ParameterKind.__qualname__.__len__() as a standalone in the
# extra31 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra31._ParameterKind_qualname_len:
  description: "len(inspect._ParameterKind.__qualname__) == 14 — '_ParameterKind'"
  category: string_properties
  kind: python_call_eq
  function: _ParameterKind.__qualname__.__len__
  args: []
  expected: 14
