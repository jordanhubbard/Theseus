spec: theseus_fnmatch_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_fnmatch_cr2)
blocks: fnmatch

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html"
  notes:
    - "Clean-room extended fnmatch utilities. Do NOT import fnmatch."
    - "filter(names, pattern): return sublist of names matching pattern."
    - "fnmatchcase(name, pattern): case-sensitive shell pattern matching."
    - "translate(pattern): convert shell pattern to regex pattern string."
    - "fnmatch2_filter(): filter(['a.py','b.txt','c.py'], '*.py') == ['a.py','c.py']."
    - "fnmatch2_case(): fnmatchcase('Hello.py', '*.PY') == False (case sensitive)."
    - "fnmatch2_translate(): '*' not in translate('*.py') — translate returns a regex, not a glob."
    - "Zero-arg invariant signatures — def fnmatch2_filter(): return hardcoded_result"
    - "* matches any sequence of characters; ? matches any single character; [seq] matches chars in seq."
    - "filter is case-sensitive on Unix, case-insensitive on Windows — implement case-sensitive."
    - "Export: fnmatch(name, pat), fnmatchcase(name, pat), filter(names, pat), translate(pat)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_fnmatch_cr2.filter:
  description: "filter(['a.py','b.txt','c.py'], '*.py') == ['a.py','c.py']"
  category: filter
  kind: python_call_eq
  function: fnmatch2_filter
  args: []
  expected: ["a.py", "c.py"]

invariant theseus_fnmatch_cr2.case:
  description: "fnmatchcase('Hello.py', '*.PY') == False"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatch2_case
  args: []
  expected: false

invariant theseus_fnmatch_cr2.translate:
  description: "translate('*.py') returns a regex string (not a glob with *)"
  category: translate
  kind: python_call_eq
  function: fnmatch2_translate
  args: []
  expected: true
