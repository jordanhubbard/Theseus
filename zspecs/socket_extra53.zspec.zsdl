spec: socket_extra53
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra52.zspec.zsdl — covers AF_INET6/AF_UNIX __class__.__qualname__/__module__/__qualname__.__len__()."
    - "socket_extra51.zspec.zsdl — covers AF_INET/SOCK_STREAM/SOCK_DGRAM __class__.__module__.__eq__('socket') and __class__.__module__.__len__()==6; SOCK_DGRAM __class__.__qualname__.__eq__('SocketKind')."
    - "socket_extra31.zspec.zsdl — covers socket.timeout/herror/gaierror __dict__.__class__.__name__.__eq__('mappingproxy') and __len__()==12."
    - "socket_extra30.zspec.zsdl — covers socket.socket/__dict__/__class__/__name__.__eq__('mappingproxy') and __len__()==12; socket.error/__dict__/__class__/__name__.__eq__('mappingproxy') and __len__()==12."
    - "socket_extra24.zspec.zsdl — covers AF_INET/__class__/__qualname__.__eq__('AddressFamily') and SOCK_STREAM/__class__/__qualname__.__eq__('SocketKind'); socket.socket.__qualname__.__eq__('socket')."
    - "socket_extra21.zspec.zsdl — covers gaierror/__qualname__.__eq__('gaierror') and herror/__qualname__.__eq__('herror') as standalone invariants."
    - "socket_extra19.zspec.zsdl — covers gaierror/__name__.__eq__('gaierror') and herror/__name__.__eq__('herror')."
    - "socket_extra11.zspec.zsdl — covers socket.socket/__name__.__eq__('socket') and __qualname__.__eq__('socket') and __module__.__eq__('socket')."
    - "socket_extra8.zspec.zsdl — covers socket.socket/__qualname__.__eq__('socket'); gaierror/__qualname__.__eq__('gaierror'); herror/__qualname__.__eq__('herror')."
  notes:
    - "This spec extends socket through socket_extra52; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior socket spec checks __dict__.__class__.__qualname__ for socket.socket, herror, gaierror, or timeout. socket_extra30 covers socket.socket/__dict__/__class__/__name__.__eq__('mappingproxy') and socket.error same. socket_extra31 covers herror/gaierror/timeout/__dict__/__class__/__name__.__eq__('mappingproxy'). But __class__.__qualname__ is a distinct attribute chain from __class__.__name__ — for the non-nested C type mappingproxy, __qualname__ == __name__ == 'mappingproxy', but the access path is an independent regression vector. No prior socket spec checks __dict__.__class__.__qualname__ for any of these classes. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__class__.__qualname__ == 'mappingproxy'. socket.socket is a class; its namespace dict is a mappingproxy. socket_extra30 covers __dict__.__class__.__name__.__eq__('mappingproxy') (the __name__ chain). No prior spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for socket.socket. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.herror.__dict__.__class__.__qualname__ == 'mappingproxy'. socket_extra31 covers herror.__dict__.__class__.__name__.__eq__('mappingproxy') (__name__ chain). No prior spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for herror. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gaierror.__dict__.__class__.__qualname__ == 'mappingproxy'. socket_extra31 covers gaierror.__dict__.__class__.__name__.__eq__('mappingproxy') (__name__ chain). No prior spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for gaierror. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.timeout.__dict__.__class__.__qualname__ == 'mappingproxy'. socket_extra31 covers timeout.__dict__.__class__.__name__.__eq__('mappingproxy') (__name__ chain). No prior spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for timeout. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior socket spec checks the socket module's own __dict__.__class__.__name__ or __qualname__. socket_extra30 and socket_extra31 cover __dict__.__class__.__name__ for socket.socket and exception classes (class dicts). But the module-level __dict__.__class__.__name__ — i.e. socket.__dict__.__class__.__name__ — has never been checked. Under python_module(socket), function: __dict__.__class__.__name__.__eq__ resolves to socket.__dict__.__class__.__name__.__eq__('mappingproxy'). Module namespaces are mappingproxy objects in CPython. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.__dict__.__class__.__name__ == 'mappingproxy'. The socket module's namespace dict is a mappingproxy. No prior socket spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for the module itself. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.__dict__.__class__.__qualname__ == 'mappingproxy'. The mappingproxy type's __qualname__ for the module namespace. Independent of __name__ axis. No prior socket spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for the socket module. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket, herror, gaierror, timeout __dict__.__class__.__qualname__
#
# socket_extra30 covers socket.socket/__dict__/__class__/__name__.__eq__('mappingproxy')
#   and socket.error same (__name__ chain).
# socket_extra31 covers herror/gaierror/timeout __dict__/__class__/__name__.__eq__
#   ('mappingproxy') (__name__ chain).
# No prior socket spec checks __dict__.__class__.__qualname__ for any of these
# classes. For mappingproxy (a non-nested C type), __qualname__ == __name__,
# but the __qualname__ access path is an independent regression vector.
# ---------------------------------------------------------------------------

table socketdict53.class_dict_class_qualname_eq:
  description: "socket.socket/herror/gaierror/timeout __dict__/__class__/__qualname__.__eq__('mappingproxy') — novel __class__.__qualname__ axis for class namespace dicts; extra30 covers socket.socket __dict__/__class__/__name__.__eq__ (__name__ chain); extra31 covers herror/gaierror/timeout __dict__/__class__/__name__.__eq__; no prior spec checks __dict__.__class__.__qualname__.__eq__ for any of these classes"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketdict53

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_class_qualname_eq,  "socket.__dict__.__class__.__qualname__.__eq__",  ["mappingproxy"], true]
    - [herror_dict_class_qualname_eq,  herror.__dict__.__class__.__qualname__.__eq__,   ["mappingproxy"], true]
    - [gaierror_dict_class_qualname_eq, gaierror.__dict__.__class__.__qualname__.__eq__, ["mappingproxy"], true]
    - [timeout_dict_class_qualname_eq,  timeout.__dict__.__class__.__qualname__.__eq__,  ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# socket module __dict__.__class__.__name__ and __qualname__
#
# No prior socket spec checks the socket module's own __dict__.__class__.__name__
# or __qualname__. socket_extra30 and socket_extra31 cover __dict__.__class__.__name__
# for class objects (socket.socket, error, timeout, herror, gaierror).
# The module-level __dict__.__class__.__name__ — socket.__dict__.__class__.__name__
# — is a distinct check: it accesses the namespace mapping of the module object
# itself, not any class within the module.
# Under python_module(socket), function: __dict__.__class__.__name__.__eq__
# resolves to socket.__dict__.__class__.__name__.__eq__('mappingproxy').
# ---------------------------------------------------------------------------

invariant socket_extra53.module.dict_class_name_eq:
  description: "socket.__dict__.__class__.__name__ == 'mappingproxy' — the socket module's namespace dict is a mappingproxy; distinct from socket.socket.__dict__ and exception class dicts covered in extra30/extra31; no prior socket spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for the module itself"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant socket_extra53.module.dict_class_qualname_eq:
  description: "socket.__dict__.__class__.__qualname__ == 'mappingproxy' — the mappingproxy type's __qualname__ for the module namespace; independent of __name__ axis; no prior socket spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for the socket module"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true
