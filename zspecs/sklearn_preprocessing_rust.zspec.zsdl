spec: sklearn_preprocessing_rust
version: ">=3.9"
backend: rust_module(sklearn_preprocessing_rust)

docs: https://scikit-learn.org/stable/modules/preprocessing.html

provenance:
  derived_from:
    - "https://scikit-learn.org/stable/modules/preprocessing.html — sklearn preprocessing"
  not_derived_from:
    - "sklearn source: sklearn/preprocessing/_data.py"
  notes:
    - "scikit-learn preprocessing provides data normalization and encoding."
    - "LabelEncoder().fit_transform(['cat', 'dog', 'cat']) == [0, 1, 0]."
    - "LabelEncoder().fit(['a','b','c']).classes_ == ['a','b','c']."
    - "MinMaxScaler().fit_transform([[0],[5],[10]]).tolist() == [[0.0],[0.5],[1.0]]."
    - "Expose label_encode(labels) -> list: LabelEncoder().fit_transform(labels).tolist()."
    - "Expose label_classes(labels) -> list: LabelEncoder().fit(labels).classes_.tolist()."
    - "label_encode(['cat','dog','cat']) == [0, 1, 0]."
    - "label_classes(['a','b','c']) == ['a','b','c']."
    - "All test vectors verified against scikit-learn 1.6.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# label_encode — encode string labels to integers
table sklearn_preprocessing_rust.label_encoder.encode:
  kind: python_call_eq
  category: encode
  id_prefix: skp_enc
  function: label_encode

  columns: [id, args, expected]
  rows:
    - [cat_dog, [["cat", "dog", "cat"]], [0, 1, 0]]
    - [abc,     [["a", "b", "c"]],       [0, 1, 2]]
    - [one_class, [["x", "x"]],          [0, 0]]

# label_classes — list of unique classes in order
table sklearn_preprocessing_rust.label_encoder.classes:
  kind: python_call_eq
  category: classes
  id_prefix: skp_cls
  function: label_classes

  columns: [id, args, expected]
  rows:
    - [abc,    [["a", "b", "c"]],       ["a", "b", "c"]]
    - [sorted, [["cat", "dog", "bird"]], ["bird", "cat", "dog"]]
    - [one,    [["x"]],                 ["x"]]

