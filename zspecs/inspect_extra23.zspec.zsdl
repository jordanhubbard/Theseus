spec: inspect_extra23
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra22.zspec.zsdl."
    - "Focus: __qualname__ values for inspect.Parameter and inspect.Signature instance methods, and the __qualname__ of the inspect._empty sentinel class in the extra23 namespace."
    - "inspect_extra22 covers __qualname__.__len__() for inspect predicate/utility functions and Parameter/Signature class types."
    - "inspect_extra7 covers Parameter.__qualname__.__eq__ and Signature.__qualname__.__eq__ (the class qualnames) as standalones."
    - "No prior inspect spec records method-level qualnames such as Parameter.__repr__.__qualname__, Parameter.__eq__.__qualname__, Parameter.replace.__qualname__, Signature.replace.__qualname__, Signature.__eq__.__qualname__, Signature.__init__.__qualname__, or Parameter.__init__.__qualname__."
    - "inspect.Parameter.empty is the inspect._empty class (not an instance); its __qualname__ is '_empty'."
    - "inspect.Signature.empty is the same object as inspect.Parameter.empty (identity check: True)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Parameter method __qualname__ values — combined table
#
# Parameter defines __repr__, __eq__, __hash__, replace, and __init__.
# Their __qualname__ values follow 'Parameter.<method>' pattern.
# No prior inspect spec records any of these method qualnames.
# ---------------------------------------------------------------------------

table inspect_extra23.Parameter_method_qualnames:
  description: "__qualname__.__eq__ for inspect.Parameter instance methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [repr,    "Parameter.__repr__.__qualname__.__eq__",    ["Parameter.__repr__"],    true]
    - [eq,      "Parameter.__eq__.__qualname__.__eq__",      ["Parameter.__eq__"],      true]
    - [hash,    "Parameter.__hash__.__qualname__.__eq__",    ["Parameter.__hash__"],    true]
    - [replace, "Parameter.replace.__qualname__.__eq__",     ["Parameter.replace"],     true]
    - [init,    "Parameter.__init__.__qualname__.__eq__",    ["Parameter.__init__"],    true]

# ---------------------------------------------------------------------------
# inspect.Signature method __qualname__ values — combined table
#
# Signature defines __eq__, replace, and __init__ among others.
# Their __qualname__ values follow 'Signature.<method>' pattern.
# No prior inspect spec records any of these method qualnames.
# ---------------------------------------------------------------------------

table inspect_extra23.Signature_method_qualnames:
  description: "__qualname__.__eq__ for inspect.Signature instance methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [eq,      "Signature.__eq__.__qualname__.__eq__",      ["Signature.__eq__"],      true]
    - [replace, "Signature.replace.__qualname__.__eq__",     ["Signature.replace"],     true]
    - [init,    "Signature.__init__.__qualname__.__eq__",    ["Signature.__init__"],    true]

# ---------------------------------------------------------------------------
# inspect.Parameter method __qualname__.__len__() values — combined table
#
# Verifies the string length of each Parameter method __qualname__:
#   Parameter.__repr__ -> 18, Parameter.__eq__ -> 16, Parameter.__hash__ -> 18,
#   Parameter.replace -> 17, Parameter.__init__ -> 18
# No prior inspect spec collects these method qualname lengths together.
# ---------------------------------------------------------------------------

table inspect_extra23.Parameter_method_qualname_lens:
  description: "__qualname__.__len__() for inspect.Parameter instance methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [repr,    "Parameter.__repr__.__qualname__.__len__",    [], 18]
    - [eq,      "Parameter.__eq__.__qualname__.__len__",      [], 16]
    - [hash,    "Parameter.__hash__.__qualname__.__len__",    [], 18]
    - [replace, "Parameter.replace.__qualname__.__len__",     [], 17]
    - [init,    "Parameter.__init__.__qualname__.__len__",    [], 18]

# ---------------------------------------------------------------------------
# inspect.Parameter.empty.__qualname__ == '_empty' — standalone invariant
#
# inspect.Parameter.empty is the inspect._empty class itself (not an instance).
# Its __qualname__ is '_empty'. No prior inspect spec records this.
# ---------------------------------------------------------------------------

invariant inspect_extra23.Parameter.empty_qualname:
  description: "inspect.Parameter.empty.__qualname__ == '_empty' — empty sentinel is the _empty class"
  category: sentinel_attrs
  kind: python_call_eq
  function: "Parameter.empty.__qualname__.__eq__"
  args: ["_empty"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.Parameter.empty.__name__ == '_empty' — standalone invariant
#
# The _empty class's __name__ attribute is '_empty'.
# No prior inspect spec records Parameter.empty.__name__ directly.
# ---------------------------------------------------------------------------

invariant inspect_extra23.Parameter.empty_name:
  description: "inspect.Parameter.empty.__name__ == '_empty' — _empty class name"
  category: sentinel_attrs
  kind: python_call_eq
  function: "Parameter.empty.__name__.__eq__"
  args: ["_empty"]
  expected: true
