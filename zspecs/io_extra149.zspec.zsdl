spec: io_extra149
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, and io.BufferedWriter concrete class identity — __name__ lengths, __module__ (all '_io'; the concrete classes come from the C extension _io, unlike the ABCs covered in io_extra148 which report 'io'), __class__.__name__ (all 'type', unlike the ABCs which are 'ABCMeta'), __bases__[0].__name__, MRO lengths, and __doc__ lengths."
    - "io.FileIO.__module__ == '_io' (not 'io'); the concrete classes FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter are implemented in C and registered under the '_io' extension module; they differ from the io ABC classes (IOBase etc.) whose __module__ == 'io'."
    - "io.FileIO.__doc__ len == 778 (longest among the five covered concrete classes); io.BufferedWriter.__doc__ len == 196; io.StringIO.__doc__ len == 174; io.BufferedReader.__doc__ len == 68; io.BytesIO.__doc__ len == 60."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase'; io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase'; io.StringIO.__bases__[0].__name__ == '_TextIOBase'; io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase'; io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase'."
    - "All five concrete classes have MRO length 4: [ConcreteClass, _CBase, _IOBase, object]."
    - "io.FileIO.__name__ len == 6; io.BytesIO.__name__ len == 7; io.StringIO.__name__ len == 8; io.BufferedReader.__name__ len == 14; io.BufferedWriter.__name__ len == 14."
    - "io.BufferedReader and io.BufferedWriter share __name__ length 14 and __module__ '_io' and both have '_BufferedIOBase' as their first MRO entry after themselves."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io concrete class __doc__ lengths
# FileIO.__doc__ == 778 chars (longest; describes open modes r/w/x/a and flags).
# BufferedWriter.__doc__ == 196 chars (second longest; describes writable sequential RawIO).
# StringIO.__doc__ == 174 chars (third; in-memory text buffer with initial_value).
# BufferedReader.__doc__ == 68 chars (fourth; 'Create a new buffered reader...').
# BytesIO.__doc__ == 60 chars (shortest; single-sentence in-memory bytes buffer).
# ---------------------------------------------------------------------------

table io_extra149.concrete_doc_lengths:
  description: "io concrete class __doc__ lengths: FileIO=778, BufferedWriter=196, StringIO=174, BufferedReader=68, BytesIO=60; all are str"
  kind: python_call_eq
  category: doc_identity
  id_prefix: iocon149

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_doc_cls,   FileIO.__doc__.__class__.__name__.__eq__,        ["str"], true, "io.FileIO.__doc__ is a str (non-None; describes open modes r/w/x/a and the binary file interface)"]
    - [fileio_doc_len,   FileIO.__doc__.__len__,                          [],      778, "io.FileIO.__doc__.__len__() == 778 (longest __doc__ among the five covered concrete classes; opens with 'Open a file.')"]
    - [bwriter_doc_cls,  BufferedWriter.__doc__.__class__.__name__.__eq__, ["str"], true, "io.BufferedWriter.__doc__ is a str (describes writable sequential RawIO objects)"]
    - [bwriter_doc_len,  BufferedWriter.__doc__.__len__,                  [],      196, "io.BufferedWriter.__doc__.__len__() == 196 (second longest; describes buffer_size parameter and constructor)"]
    - [stringio_doc_cls, StringIO.__doc__.__class__.__name__.__eq__,      ["str"], true, "io.StringIO.__doc__ is a str (in-memory text buffer; describes initial_value and newline handling)"]
    - [stringio_doc_len, StringIO.__doc__.__len__,                        [],      174, "io.StringIO.__doc__.__len__() == 174 (third longest; 22 chars shorter than BufferedWriter)"]
    - [breader_doc_cls,  BufferedReader.__doc__.__class__.__name__.__eq__, ["str"], true, "io.BufferedReader.__doc__ is a str (one-liner describing creation from a readable raw IO object)"]
    - [breader_doc_len,  BufferedReader.__doc__.__len__,                  [],      68,  "io.BufferedReader.__doc__.__len__() == 68 (second shortest; 'Create a new buffered reader using the given readable raw IO object.')"]
    - [bytesio_doc_cls,  BytesIO.__doc__.__class__.__name__.__eq__,       ["str"], true, "io.BytesIO.__doc__ is a str (single-sentence description of in-memory bytes buffer)"]
    - [bytesio_doc_len,  BytesIO.__doc__.__len__,                         [],      60,  "io.BytesIO.__doc__.__len__() == 60 (shortest __doc__ among the five; 'Buffered I/O implementation using an in-memory bytes buffer.')"]

# ---------------------------------------------------------------------------
# io concrete class __name__ lengths and __module__ identity
# All five concrete classes have __module__ == '_io' (the C extension module).
# FileIO.__name__ len == 6; BytesIO == 7; StringIO == 8;
# BufferedReader == 14; BufferedWriter == 14 (tied longest).
# All five have __class__.__name__ == 'type' (regular classes, not ABCMeta).
# ---------------------------------------------------------------------------

table io_extra149.concrete_name_and_module:
  description: "io concrete class __name__ lengths: FileIO=6, BytesIO=7, StringIO=8, BufferedReader=14, BufferedWriter=14; all __module__='_io'; all __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: iocon149

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_name_len,   FileIO.__name__.__len__,                    [], 6,    "io.FileIO.__name__.__len__() == 6 ('FileIO' has 6 characters; the shortest name among the five concrete classes)"]
    - [fileio_module_eq,  FileIO.__module__.__eq__,                   ["_io"], true, "io.FileIO.__module__ == '_io' (concrete classes come from the C extension _io, unlike the ABCs which report 'io')"]
    - [fileio_cls_eq,     FileIO.__class__.__name__.__eq__,           ["type"], true, "io.FileIO.__class__.__name__ == 'type' (a regular class; concrete IO classes are not abstract)"]
    - [bytesio_name_len,  BytesIO.__name__.__len__,                   [], 7,    "io.BytesIO.__name__.__len__() == 7 ('BytesIO' has 7 characters)"]
    - [bytesio_module_eq, BytesIO.__module__.__eq__,                  ["_io"], true, "io.BytesIO.__module__ == '_io'"]
    - [stringio_name_len, StringIO.__name__.__len__,                  [], 8,    "io.StringIO.__name__.__len__() == 8 ('StringIO' has 8 characters)"]
    - [stringio_module_eq,StringIO.__module__.__eq__,                 ["_io"], true, "io.StringIO.__module__ == '_io'"]
    - [breader_name_len,  BufferedReader.__name__.__len__,            [], 14,   "io.BufferedReader.__name__.__len__() == 14 ('BufferedReader' has 14 characters; tied longest with BufferedWriter)"]
    - [breader_module_eq, BufferedReader.__module__.__eq__,           ["_io"], true, "io.BufferedReader.__module__ == '_io'"]
    - [bwriter_name_len,  BufferedWriter.__name__.__len__,            [], 14,   "io.BufferedWriter.__name__.__len__() == 14 ('BufferedWriter' has 14 characters; tied with BufferedReader)"]
    - [bwriter_module_eq, BufferedWriter.__module__.__eq__,           ["_io"], true, "io.BufferedWriter.__module__ == '_io'"]

# ---------------------------------------------------------------------------
# io concrete class MRO lengths and __bases__ structure
# All five have MRO length 4: [ConcreteClass, _CBase, _IOBase, object].
# FileIO.__bases__[0].__name__ == '_RawIOBase'.
# BytesIO.__bases__[0].__name__ == '_BufferedIOBase'.
# StringIO.__bases__[0].__name__ == '_TextIOBase'.
# BufferedReader and BufferedWriter both have __bases__[0] == '_BufferedIOBase'.
# MRO[2] for all five is '_IOBase'; MRO[3] is 'object'.
# ---------------------------------------------------------------------------

table io_extra149.concrete_mro_and_bases:
  description: "io concrete classes all have MRO length 4; FileIO bases _RawIOBase; BytesIO/BufferedReader/BufferedWriter base _BufferedIOBase; StringIO bases _TextIOBase"
  kind: python_call_eq
  category: class_identity
  id_prefix: iocon149

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_mro_len,     "FileIO.__mro__.__len__",                           [], 4, "io.FileIO.__mro__.__len__() == 4 ([FileIO, _RawIOBase, _IOBase, object])"]
    - [fileio_base0_eq,    "FileIO.__bases__[0].__name__.__eq__",    ["_RawIOBase"],      true, "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (FileIO is a raw binary IO class)"]
    - [fileio_mro2_eq,     "FileIO.__mro__[2].__name__.__eq__",      ["_IOBase"],         true, "io.FileIO.__mro__[2].__name__ == '_IOBase' (the common C-layer root for all io classes)"]
    - [bytesio_mro_len,    "BytesIO.__mro__.__len__",                          [], 4, "io.BytesIO.__mro__.__len__() == 4 ([BytesIO, _BufferedIOBase, _IOBase, object])"]
    - [bytesio_base0_eq,   "BytesIO.__bases__[0].__name__.__eq__",   ["_BufferedIOBase"], true, "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' (BytesIO is a buffered IO class despite being in-memory)"]
    - [stringio_mro_len,   "StringIO.__mro__.__len__",                         [], 4, "io.StringIO.__mro__.__len__() == 4 ([StringIO, _TextIOBase, _IOBase, object])"]
    - [stringio_base0_eq,  "StringIO.__bases__[0].__name__.__eq__",  ["_TextIOBase"],     true, "io.StringIO.__bases__[0].__name__ == '_TextIOBase' (StringIO is a text IO class over an in-memory buffer)"]
    - [breader_mro_len,    "BufferedReader.__mro__.__len__",                   [], 4, "io.BufferedReader.__mro__.__len__() == 4 ([BufferedReader, _BufferedIOBase, _IOBase, object])"]
    - [breader_base0_eq,   "BufferedReader.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true, "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase'"]
    - [bwriter_mro_len,    "BufferedWriter.__mro__.__len__",                   [], 4, "io.BufferedWriter.__mro__.__len__() == 4 ([BufferedWriter, _BufferedIOBase, _IOBase, object])"]
    - [bwriter_base0_eq,   "BufferedWriter.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true, "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' (both BufferedReader and BufferedWriter share this base)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra149.FileIO.doc_len_778:
  description: "io.FileIO.__doc__.__len__() == 778 (the longest __doc__ among the five covered concrete IO classes; FileIO's docstring opens with 'Open a file.' and then exhaustively describes the mode parameter — 'r', 'w', 'x', 'a' — and binary/text options, making it 582 characters longer than BytesIO.__doc__ (60))"
  category: doc_identity
  kind: python_call_eq
  function: FileIO.__doc__.__len__
  args: []
  expected: 778

invariant io_extra149.BytesIO.doc_len_60:
  description: "io.BytesIO.__doc__.__len__() == 60 (the shortest __doc__ among the five covered concrete classes; a single sentence: 'Buffered I/O implementation using an in-memory bytes buffer.'; shorter than the also-brief BufferedReader (68) by 8 characters)"
  category: doc_identity
  kind: python_call_eq
  function: BytesIO.__doc__.__len__
  args: []
  expected: 60

invariant io_extra149.FileIO.module_eq__io:
  description: "io.FileIO.__module__ == '_io' (the concrete IO classes FileIO, BytesIO, StringIO, BufferedReader, and BufferedWriter are all implemented in the C extension module _io, so their __module__ attribute records '_io' rather than 'io'; this distinguishes them from the abstract base classes IOBase etc., which are defined in Lib/io.py and report __module__ == 'io')"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra149.FileIO.class_is_type:
  description: "io.FileIO.__class__.__name__ == 'type' (concrete IO classes use the standard metaclass 'type', unlike the io ABC classes IOBase, RawIOBase, BufferedIOBase, TextIOBase which use 'ABCMeta'; this is the key structural difference between the abstract and concrete layers of the io module)"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra149.FileIO.mro_len_4:
  description: "io.FileIO.__mro__.__len__() == 4 (MRO is [FileIO, _RawIOBase, _IOBase, object]; all five covered concrete classes share MRO length 4, reflecting the two-level C extension hierarchy _XxxBase → _IOBase → object beneath each concrete class)"
  category: class_identity
  kind: python_call_eq
  function: "FileIO.__mro__.__len__"
  args: []
  expected: 4

invariant io_extra149.BufferedReader.name_len_14:
  description: "io.BufferedReader.__name__.__len__() == 14 ('BufferedReader' has 14 characters; tied with BufferedWriter (14) for the longest __name__ among the five covered concrete classes; FileIO=6, BytesIO=7, StringIO=8 are all shorter)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__name__.__len__
  args: []
  expected: 14

invariant io_extra149.StringIO.base_is__TextIOBase:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' (StringIO's direct C-layer base is the private _TextIOBase class; BytesIO's direct base is '_BufferedIOBase' and FileIO's is '_RawIOBase'; the naming pattern mirrors the ABC layer: TextIOBase → _TextIOBase, BufferedIOBase → _BufferedIOBase, RawIOBase → _RawIOBase)"
  category: class_identity
  kind: python_call_eq
  function: "StringIO.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

