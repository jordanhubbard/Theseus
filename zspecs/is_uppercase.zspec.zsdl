spec: is_uppercase
version: ">=1.0.0"
backend: node(is-uppercase)

docs: https://www.npmjs.com/package/is-uppercase

provenance:
  derived_from:
    - "is-uppercase README — https://www.npmjs.com/package/is-uppercase"
    - "Test vectors verified with is-uppercase via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-uppercase source"
  notes:
    - "is-uppercase is an npm package. Install: npm install is-uppercase"
    - "Returns true if every character in the string is uppercase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_uppercase.isUppercase:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: isup

  columns: [id, args, expected]
  rows:
    - [all_upper,  ["HELLO"],  true]
    - [all_lower,  ["hello"],  false]
    - [mixed,      ["Hello"],  false]

