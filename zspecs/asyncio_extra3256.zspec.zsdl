    - ["as3256020", operator.contains, [asyncio.LifoQueue.__dict__,        "__rlshift__"], false]

# ---------------------------------------------------------------------------
# __rrshift__ dict-presence — operator.contains(Cls.__dict__, '__rrshift__')
#
# All 10 asyncio classes return false for __rrshift__.
# Reflected right shift (__rrshift__) is the mirror of __rshift__; it is
#   invoked when the left operand's __rshift__ returns NotImplemented.
# asyncio types define no __rshift__ (confirmed false in wave 660), so
#   __rrshift__ is equally absent.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: synchronization
#   primitives with no shift semantics of any kind.
# asyncio.Task/Future: pending result handles; reflected right shift is
#   undefined for coroutine handles.
# asyncio.Queue/PriorityQueue/LifoQueue: queue types do not define
#   __rshift__ or __rrshift__ as a dequeue/pipe operator.
# ---------------------------------------------------------------------------

