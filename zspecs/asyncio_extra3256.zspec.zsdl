spec: as3256
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (as3256): __rpow__, __rlshift__, __rrshift__ dict-presence (reflected power/shift) for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: asyncio.Task, asyncio.Future, asyncio.Event, asyncio.Lock, asyncio.Semaphore, asyncio.BoundedSemaphore, asyncio.Condition, asyncio.Queue, asyncio.PriorityQueue, asyncio.LifoQueue."
    - "Key finding (__rpow__): all 10 asyncio classes return false for __rpow__. Reflected power (__rpow__) is invoked when the left operand's __pow__ returns NotImplemented — e.g., n ** obj triggers obj.__rpow__(n). asyncio types define no __pow__ (confirmed false in wave 660), so __rpow__ is equally absent. asyncio types are coroutine-based concurrency primitives — not numeric types. asyncio.Event/Lock/Condition are boolean-state synchronization objects; n ** event is not a defined Python expression. asyncio.Semaphore/BoundedSemaphore manage a permit counter fully encapsulated behind acquire()/release() coroutines; the counter is not exposed for power operations. asyncio.Task/Future are pending coroutine result handles; reflected power is undefined for them. asyncio.Queue/PriorityQueue/LifoQueue are ordered item stores with no numeric data model."
    - "Key finding (__rlshift__): all 10 asyncio classes return false for __rlshift__. Reflected left shift (__rlshift__) is invoked when the left operand's __lshift__ returns NotImplemented. asyncio types define no __lshift__ (confirmed false in wave 660), so __rlshift__ is equally absent. Bit-shift operations have no defined meaning for coroutine synchronization primitives, task handles, or queue types. asyncio.Queue does not support the << operator from either side; it is not a logging handler or similar type where __lshift__ might be used as a convenience method."
    - "Key finding (__rrshift__): all 10 asyncio classes return false for __rrshift__. Reflected right shift (__rrshift__) is the mirror of __rshift__. asyncio types define no __rshift__ (confirmed false in wave 660), so __rrshift__ is equally absent. No asyncio type defines a pipe, streaming, or right-shift interface. asyncio.Queue is an ordered item store but does not define __rshift__ or __rrshift__ as a dequeue/pipe operator."
    - "Continues the unbroken all-false run from wave 656 (__call__/__len__/__getitem__) through wave 664 (__rpow__/__rlshift__/__rrshift__) — nine consecutive waves of 100% false results for asyncio types."
    - "Cross-wave summary for asyncio subjects:"
    - "  Wave 652 (as3076): __get__ — Task/Future/Queue/Handle true; others false."
    - "  Wave 653 (as3091): __hash__/__eq__/__bool__ — selected true."
    - "  Wave 654 (as3106): __lt__/__le__/__gt__ — TimerHandle true; others false."
    - "  Wave 655 (as3121): __ge__ — TimerHandle true; __repr__ — 12 classes true."
    - "  Wave 656 (as3136): __call__/__len__/__getitem__ — all false for all 14."
    - "  Wave 657 (as3151): __setitem__/__delitem__/__contains__ — all false for all 14."
    - "  Wave 658 (as3166): __add__/__sub__/__mul__ — all false for all 14."
    - "  Wave 659 (as3181): __truediv__/__floordiv__/__mod__ — all false for all 14."
    - "  Wave 660 (as3196): __pow__/__lshift__/__rshift__ — all false for all 10."
    - "  Wave 661 (as3211): __and__/__or__/__xor__ — all false for all 10."
    - "  Wave 662 (as3226): __radd__/__rsub__/__rmul__ — all false for all 10."
    - "  Wave 663 (as3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 10."
    - "  Wave 664 (as3256): __rpow__/__rlshift__/__rrshift__ — all false for all 10."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rpow__ dict-presence — operator.contains(Cls.__dict__, '__rpow__')
#
# All 10 asyncio classes return false for __rpow__.
# Reflected power (__rpow__) is invoked when the left operand's __pow__
#   returns NotImplemented — e.g., n ** obj triggers obj.__rpow__(n).
# asyncio types define no __pow__ (confirmed false in wave 660), so
#   __rpow__ is equally absent.
# asyncio.Event/Lock/Condition: boolean-state synchronization guards;
#   n ** event is not a defined Python expression.
# asyncio.Semaphore/BoundedSemaphore: permit-counter objects; the counter
#   is fully encapsulated behind acquire()/release() coroutines.
# asyncio.Task/Future: pending coroutine result handles; reflected power
#   is undefined for them.
# asyncio.Queue/PriorityQueue/LifoQueue: ordered item stores with no
#   numeric or power semantics of any kind.
# ---------------------------------------------------------------------------

table as3256.rpow:
  description: "asyncio types __rpow__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3256

  columns: [id, function, args, expected]
  rows:
    - ["as3256001", operator.contains, [asyncio.Task.__dict__,             "__rpow__"], false]
    - ["as3256002", operator.contains, [asyncio.Future.__dict__,           "__rpow__"], false]
    - ["as3256003", operator.contains, [asyncio.Event.__dict__,            "__rpow__"], false]
    - ["as3256004", operator.contains, [asyncio.Lock.__dict__,             "__rpow__"], false]
    - ["as3256005", operator.contains, [asyncio.Semaphore.__dict__,        "__rpow__"], false]
    - ["as3256006", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__rpow__"], false]
    - ["as3256007", operator.contains, [asyncio.Condition.__dict__,        "__rpow__"], false]
    - ["as3256008", operator.contains, [asyncio.Queue.__dict__,            "__rpow__"], false]
    - ["as3256009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__rpow__"], false]
    - ["as3256010", operator.contains, [asyncio.LifoQueue.__dict__,        "__rpow__"], false]

# ---------------------------------------------------------------------------
# __rlshift__ dict-presence — operator.contains(Cls.__dict__, '__rlshift__')
#
# All 10 asyncio classes return false for __rlshift__.
# Reflected left shift (__rlshift__) is invoked when the left operand's
#   __lshift__ returns NotImplemented — e.g., n << obj triggers
#   obj.__rlshift__(n) if int's __lshift__ does not handle obj.
# asyncio types define no __lshift__ (confirmed false in wave 660), so
#   __rlshift__ is equally absent.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: synchronization
#   primitives with no bitwise or shift semantics.
# asyncio.Task/Future: pending coroutine results; left shift is undefined
#   from either side of the operator.
# asyncio.Queue/PriorityQueue/LifoQueue: ordered item stores; asyncio.Queue
#   does not define __lshift__ or __rlshift__ as a pipe/enqueue operator.
# ---------------------------------------------------------------------------

table as3256.rlshift:
  description: "asyncio types __rlshift__ dict-presence checks; wave 664"
