spec: os_path_extra16
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py, Lib/genericpath.py"
    - "os_path_extra14.zspec.zsdl — covers join three-arg/absolute-resets; normpath dotdot/singledot; lexists/realpath __name__"
    - "os_path_extra15.zspec.zsdl — covers sep/curdir/pardir/extsep values; altsep is None; pathsep/defpath values; sep/pathsep class names"
  notes:
    - "This spec extends os_path.zspec.zsdl and prior extras through os_path_extra15.zspec.zsdl."
    - "os.path.join.__qualname__ == 'join' — module-level functions have qualname equal to their simple name; no prior os.path spec covers join/__qualname__."
    - "os.path.split.__qualname__ == 'split' — no prior spec covers split/__qualname__."
    - "os.path.exists.__qualname__ == 'exists' — no prior spec covers exists/__qualname__."
    - "os.path.isfile.__qualname__ == 'isfile' — no prior spec covers isfile/__qualname__."
    - "os.path.isdir.__qualname__ == 'isdir' — no prior spec covers isdir/__qualname__."
    - "os.path.basename.__qualname__ == 'basename' — no prior spec covers basename/__qualname__."
    - "os.path.dirname.__qualname__ == 'dirname' — no prior spec covers dirname/__qualname__."
    - "os.path.join.__module__ == 'posixpath' — join is implemented in posixpath on POSIX systems; no prior spec covers join/__module__."
    - "os.path.exists.__module__ == 'genericpath' — exists is implemented in genericpath; no prior spec covers exists/__module__."
    - "os.path.isfile.__module__ == 'genericpath' — isfile is implemented in genericpath; no prior spec covers isfile/__module__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ table — join, split, exists, isfile, isdir,
#                               basename, dirname
#
# For module-level functions, __qualname__ equals the plain function name
# (no class prefix). No prior os.path spec covers __qualname__ for any of
# these functions. The table groups all seven in the extra16 namespace.
# ---------------------------------------------------------------------------

table os_path_extra16.function_qualnames:
  description: "__qualname__ for join/split/exists/isfile/isdir/basename/dirname — equals function name at module level"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqname16

  columns: [id, function, args, expected]
  rows:
    - [join,     join.__qualname__.__eq__,     ["join"],     true]
    - [split,    split.__qualname__.__eq__,    ["split"],    true]
    - [exists,   exists.__qualname__.__eq__,   ["exists"],   true]
    - [isfile,   isfile.__qualname__.__eq__,   ["isfile"],   true]
    - [isdir,    isdir.__qualname__.__eq__,    ["isdir"],    true]
    - [basename, basename.__qualname__.__eq__, ["basename"], true]
    - [dirname,  dirname.__qualname__.__eq__,  ["dirname"],  true]

# ---------------------------------------------------------------------------
# Function __module__ table — posixpath vs genericpath
#
# On POSIX, os.path is posixpath. However not all functions live there:
# join, split, basename, dirname are in posixpath; exists, isfile, isdir
# are in genericpath (the cross-platform implementations). No prior os.path
# spec covers __module__ for any of these functions.
# ---------------------------------------------------------------------------

table os_path_extra16.function_modules:
  description: "__module__ for os.path functions — posixpath for path manipulation, genericpath for existence tests"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmod16

  columns: [id, function, args, expected]
  rows:
    - [join,    join.__module__.__eq__,    ["posixpath"],   true]
    - [split,   split.__module__.__eq__,   ["posixpath"],   true]
    - [basename, basename.__module__.__eq__, ["posixpath"], true]
    - [dirname,  dirname.__module__.__eq__,  ["posixpath"], true]
    - [exists,  exists.__module__.__eq__,  ["genericpath"], true]
    - [isfile,  isfile.__module__.__eq__,  ["genericpath"], true]
    - [isdir,   isdir.__module__.__eq__,   ["genericpath"], true]

# ---------------------------------------------------------------------------
# os.path.join.__qualname__ — standalone extra16 invariant
#
# For module-level functions __qualname__ == function name. This standalone
# invariant anchors join's qualname independently of the table above.
# ---------------------------------------------------------------------------

invariant os_path_extra16.join.qualname:
  description: "os.path.join.__qualname__ == 'join' — module-level function qualname equals its name"
  category: function_identity
  kind: python_call_eq
  function: join.__qualname__.__eq__
  args: ["join"]
  expected: true

# ---------------------------------------------------------------------------
# os.path.exists.__module__ — standalone extra16 invariant
#
# exists is defined in genericpath, not posixpath. This is a subtle but
# important distinction. Standalone invariant anchors it independently.
# ---------------------------------------------------------------------------

invariant os_path_extra16.exists.module:
  description: "os.path.exists.__module__ == 'genericpath' — exists is implemented in the cross-platform genericpath module"
  category: function_identity
  kind: python_call_eq
  function: exists.__module__.__eq__
  args: ["genericpath"]
  expected: true

# ---------------------------------------------------------------------------
# os.path.join.__module__ — standalone extra16 invariant
#
# join is defined in posixpath on POSIX. Standalone invariant provides
# independent coverage of the posixpath module origin.
# ---------------------------------------------------------------------------

invariant os_path_extra16.join.module:
  description: "os.path.join.__module__ == 'posixpath' — join is implemented in the POSIX-specific posixpath module"
  category: function_identity
  kind: python_call_eq
  function: join.__module__.__eq__
  args: ["posixpath"]
  expected: true
