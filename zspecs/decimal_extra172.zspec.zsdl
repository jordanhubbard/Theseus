spec: decimal_extra172
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal rounding constants — ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN, ROUND_05UP."
    - "All rounding constants are plain Python strings (not IntEnum or IntFlag): __class__.__name__ == 'str'."
    - "decimal.ROUND_UP == 'ROUND_UP' (len=7: 'ROUND_' (6) + 'UP' (2) — wait: R-O-U-N-D-_-U-P = 8 chars)."
    - "decimal.ROUND_UP.__len__() == 8 — 'ROUND_UP': R(1)O(2)U(3)N(4)D(5)_(6)U(7)P(8) = 8 characters."
    - "decimal.ROUND_DOWN.__len__() == 10 — 'ROUND_DOWN': R(1)O(2)U(3)N(4)D(5)_(6)D(7)O(8)W(9)N(10) = 10."
    - "decimal.ROUND_CEILING.__len__() == 13 — 'ROUND_CEILING': R(1)O(2)U(3)N(4)D(5)_(6)C(7)E(8)I(9)L(10)I(11)N(12)G(13) = 13."
    - "decimal.ROUND_FLOOR.__len__() == 11 — 'ROUND_FLOOR': R(1)O(2)U(3)N(4)D(5)_(6)F(7)L(8)O(9)O(10)R(11) = 11."
    - "decimal.ROUND_HALF_UP.__len__() == 12 — 'ROUND_HALF_UP': R(1)O(2)U(3)N(4)D(5)_(6)H(7)A(8)L(9)F(10)_(11)U(12)P(13) — wait: 13 chars."
    - "decimal.ROUND_HALF_UP: R-O-U-N-D-_-H-A-L-F-_-U-P = 13 characters."
    - "decimal.ROUND_HALF_DOWN: R-O-U-N-D-_-H-A-L-F-_-D-O-W-N = 15 characters."
    - "decimal.ROUND_HALF_EVEN: R-O-U-N-D-_-H-A-L-F-_-E-V-E-N = 15 characters."
    - "decimal.ROUND_05UP: R-O-U-N-D-_-0-5-U-P = 10 characters."
    - "Name length ordering: ROUND_UP (8) < ROUND_DOWN=ROUND_05UP (10) < ROUND_FLOOR (11) < ROUND_HALF_UP=ROUND_CEILING (13) < ROUND_HALF_DOWN=ROUND_HALF_EVEN (15)."
    - "ROUND_DOWN (10) == ROUND_05UP (10): tie at 10."
    - "ROUND_HALF_UP (13) == ROUND_CEILING (13): tie at 13."
    - "ROUND_HALF_DOWN (15) == ROUND_HALF_EVEN (15): tie at 15 (co-maximum)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Short rounding constant values and class: ROUND_UP (8), ROUND_DOWN (10), ROUND_05UP (10)
# All are plain strings; values equal their own names
# ---------------------------------------------------------------------------

table decimal_extra172.short_rounding_constants:
  description: "Short decimal rounding constants: ROUND_UP=='ROUND_UP' (len=8; minimum); ROUND_DOWN=='ROUND_DOWN' (len=10); ROUND_05UP=='ROUND_05UP' (len=10; ties ROUND_DOWN); all are plain str instances; ROUND_UP (8) < ROUND_DOWN=ROUND_05UP (10) in string length"
  kind: python_call_eq
  category: identity
  id_prefix: decimalround172

  columns: [id, function, args, expected, description]
  rows:
    - [round_up_val,       ROUND_UP.__eq__,                    ["ROUND_UP"],   true, "decimal.ROUND_UP == 'ROUND_UP' — rounding constants are plain Python strings; 'ROUND_UP' has 8 characters: R(1)O(2)U(3)N(4)D(5)_(6)U(7)P(8) = 8; ROUND_UP (8) is the shortest rounding constant string in this spec; ROUND_UP (8) < ROUND_DOWN (10) by 2; ROUND_UP rounds away from zero; confirmed Python 3.14.3 macOS"]
    - [round_up_len,       ROUND_UP.__len__,                   [],             8,    "decimal.ROUND_UP.__len__() == 8 — 'ROUND_UP' has 8 characters; ROUND_UP (8) is the minimum string length among the decimal rounding constants in this spec; ROUND_UP (8) < ROUND_DOWN=ROUND_05UP (10) by 2; ROUND_UP (8) < ROUND_FLOOR (11) by 3; ROUND_UP (8) < ROUND_HALF_DOWN=ROUND_HALF_EVEN (15) by 7; confirmed Python 3.14.3 macOS"]
    - [round_up_class,     ROUND_UP.__class__.__name__.__eq__, ["str"],        true, "decimal.ROUND_UP.__class__.__name__ == 'str' — the decimal rounding constant ROUND_UP is a plain Python str object, not an IntEnum or IntFlag member; all rounding constants share __class__.__name__ == 'str'; confirmed Python 3.14.3 macOS"]
    - [round_down_val,     ROUND_DOWN.__eq__,                  ["ROUND_DOWN"], true, "decimal.ROUND_DOWN == 'ROUND_DOWN' — 'ROUND_DOWN' has 10 characters: R(1)O(2)U(3)N(4)D(5)_(6)D(7)O(8)W(9)N(10) = 10; ROUND_DOWN (10) == ROUND_05UP (10): tie at 10; ROUND_DOWN (10) > ROUND_UP (8) by 2; ROUND_DOWN rounds toward zero (truncates); confirmed Python 3.14.3 macOS"]
    - [round_down_len,     ROUND_DOWN.__len__,                 [],             10,   "decimal.ROUND_DOWN.__len__() == 10 — 'ROUND_DOWN' has 10 characters; ROUND_DOWN (10) == ROUND_05UP (10): the two 10-character rounding constants; ROUND_DOWN (10) > ROUND_UP (8) by 2; ROUND_DOWN (10) < ROUND_FLOOR (11) by 1; confirmed Python 3.14.3 macOS"]
    - [round_05up_val,     ROUND_05UP.__eq__,                  ["ROUND_05UP"], true, "decimal.ROUND_05UP == 'ROUND_05UP' — 'ROUND_05UP' has 10 characters: R(1)O(2)U(3)N(4)D(5)_(6)0(7)5(8)U(9)P(10) = 10; ROUND_05UP (10) == ROUND_DOWN (10): tie at 10; ROUND_05UP rounds toward zero; if the last digit is 0 or 5 after the rounding, it rounds up; confirmed Python 3.14.3 macOS"]
    - [round_05up_len,     ROUND_05UP.__len__,                 [],             10,   "decimal.ROUND_05UP.__len__() == 10 — 'ROUND_05UP' has 10 characters: the digits '05' replace 'DOWN' giving the same length; ROUND_05UP (10) == ROUND_DOWN (10): both are 10 characters; ROUND_05UP (10) > ROUND_UP (8) by 2; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Medium rounding constant string lengths: ROUND_FLOOR (11), ROUND_CEILING (13), ROUND_HALF_UP (13)
# ---------------------------------------------------------------------------

table decimal_extra172.medium_rounding_constants:
  description: "Medium decimal rounding constants: ROUND_FLOOR=='ROUND_FLOOR' (len=11); ROUND_CEILING=='ROUND_CEILING' (len=13); ROUND_HALF_UP=='ROUND_HALF_UP' (len=13; ties ROUND_CEILING); ROUND_FLOOR (11) < ROUND_CEILING=ROUND_HALF_UP (13) by 2"
  kind: python_call_eq
  category: identity
  id_prefix: decimalround172

  columns: [id, function, args, expected, description]
  rows:
    - [round_floor_val,    ROUND_FLOOR.__eq__,                   ["ROUND_FLOOR"],   true, "decimal.ROUND_FLOOR == 'ROUND_FLOOR' — 'ROUND_FLOOR' has 11 characters: R(1)O(2)U(3)N(4)D(5)_(6)F(7)L(8)O(9)O(10)R(11) = 11; ROUND_FLOOR (11) > ROUND_DOWN=ROUND_05UP (10) by 1; ROUND_FLOOR (11) < ROUND_CEILING=ROUND_HALF_UP (13) by 2; ROUND_FLOOR rounds toward negative infinity; confirmed Python 3.14.3 macOS"]
    - [round_floor_len,    ROUND_FLOOR.__len__,                  [],                11,   "decimal.ROUND_FLOOR.__len__() == 11 — 'ROUND_FLOOR' has 11 characters; ROUND_FLOOR (11) > ROUND_DOWN (10) by 1; ROUND_FLOOR (11) < ROUND_CEILING (13) by 2; ROUND_FLOOR (11) < ROUND_HALF_DOWN=ROUND_HALF_EVEN (15) by 4; confirmed Python 3.14.3 macOS"]
    - [round_ceiling_val,  ROUND_CEILING.__eq__,                 ["ROUND_CEILING"], true, "decimal.ROUND_CEILING == 'ROUND_CEILING' — 'ROUND_CEILING' has 13 characters: R(1)O(2)U(3)N(4)D(5)_(6)C(7)E(8)I(9)L(10)I(11)N(12)G(13) = 13; ROUND_CEILING (13) == ROUND_HALF_UP (13): tie at 13; ROUND_CEILING (13) > ROUND_FLOOR (11) by 2; ROUND_CEILING rounds toward positive infinity; confirmed Python 3.14.3 macOS"]
    - [round_ceiling_len,  ROUND_CEILING.__len__,                [],                13,   "decimal.ROUND_CEILING.__len__() == 13 — 'ROUND_CEILING' has 13 characters; ROUND_CEILING (13) == ROUND_HALF_UP (13): tie at 13; ROUND_CEILING (13) > ROUND_FLOOR (11) by 2; ROUND_CEILING (13) < ROUND_HALF_DOWN=ROUND_HALF_EVEN (15) by 2; confirmed Python 3.14.3 macOS"]
    - [round_half_up_val,  ROUND_HALF_UP.__eq__,                 ["ROUND_HALF_UP"], true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — 'ROUND_HALF_UP' has 13 characters: R(1)O(2)U(3)N(4)D(5)_(6)H(7)A(8)L(9)F(10)_(11)U(12)P(13) = 13; ROUND_HALF_UP (13) == ROUND_CEILING (13): tie at 13; ROUND_HALF_UP rounds to nearest with ties going away from zero; confirmed Python 3.14.3 macOS"]
    - [round_half_up_len,  ROUND_HALF_UP.__len__,                [],                13,   "decimal.ROUND_HALF_UP.__len__() == 13 — 'ROUND_HALF_UP' has 13 characters; ROUND_HALF_UP (13) == ROUND_CEILING (13): tie at 13; ROUND_HALF_UP (13) > ROUND_FLOOR (11) by 2; ROUND_HALF_UP (13) < ROUND_HALF_DOWN=ROUND_HALF_EVEN (15) by 2; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Long rounding constant string lengths: ROUND_HALF_DOWN (15), ROUND_HALF_EVEN (15)
# Both are 15 characters: co-maximum in this spec
# ---------------------------------------------------------------------------

table decimal_extra172.long_rounding_constants:
  description: "Longest decimal rounding constants: ROUND_HALF_DOWN=='ROUND_HALF_DOWN' (len=15; co-maximum); ROUND_HALF_EVEN=='ROUND_HALF_EVEN' (len=15; co-maximum); ROUND_HALF_DOWN (15) == ROUND_HALF_EVEN (15): a two-way tie at the maximum string length"
  kind: python_call_eq
  category: identity
  id_prefix: decimalround172

  columns: [id, function, args, expected, description]
  rows:
    - [round_half_down_val,  ROUND_HALF_DOWN.__eq__,                 ["ROUND_HALF_DOWN"],  true, "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN' — 'ROUND_HALF_DOWN' has 15 characters: R(1)O(2)U(3)N(4)D(5)_(6)H(7)A(8)L(9)F(10)_(11)D(12)O(13)W(14)N(15) = 15; ROUND_HALF_DOWN (15) == ROUND_HALF_EVEN (15): co-maximum; ROUND_HALF_DOWN (15) > ROUND_HALF_UP=ROUND_CEILING (13) by 2; rounds to nearest with ties going toward zero; confirmed Python 3.14.3 macOS"]
    - [round_half_down_len,  ROUND_HALF_DOWN.__len__,                [],                   15,   "decimal.ROUND_HALF_DOWN.__len__() == 15 — 'ROUND_HALF_DOWN' has 15 characters; ROUND_HALF_DOWN (15) == ROUND_HALF_EVEN (15): the two co-maximum rounding constant string lengths in this spec; ROUND_HALF_DOWN (15) > ROUND_HALF_UP=ROUND_CEILING (13) by 2; ROUND_HALF_DOWN (15) > ROUND_UP (8) by 7; confirmed Python 3.14.3 macOS"]
    - [round_half_down_cls,  ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"],            true, "decimal.ROUND_HALF_DOWN.__class__.__name__ == 'str' — ROUND_HALF_DOWN is a plain Python str; all decimal rounding constants are str objects; confirmed Python 3.14.3 macOS"]
    - [round_half_even_val,  ROUND_HALF_EVEN.__eq__,                 ["ROUND_HALF_EVEN"],  true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — 'ROUND_HALF_EVEN' has 15 characters: R(1)O(2)U(3)N(4)D(5)_(6)H(7)A(8)L(9)F(10)_(11)E(12)V(13)E(14)N(15) = 15; ROUND_HALF_EVEN (15) == ROUND_HALF_DOWN (15): co-maximum; ROUND_HALF_EVEN rounds to nearest with ties going to the nearest even digit (banker's rounding); confirmed Python 3.14.3 macOS"]
    - [round_half_even_len,  ROUND_HALF_EVEN.__len__,                [],                   15,   "decimal.ROUND_HALF_EVEN.__len__() == 15 — 'ROUND_HALF_EVEN' has 15 characters; ROUND_HALF_EVEN (15) == ROUND_HALF_DOWN (15): both are co-maximum at 15; ROUND_HALF_EVEN (15) > ROUND_HALF_UP (13) by 2 because 'EVEN' (4) > 'UP' (2) by 2; confirmed Python 3.14.3 macOS"]
    - [round_half_even_cls,  ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"],            true, "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — ROUND_HALF_EVEN is a plain Python str; ROUND_HALF_EVEN is the default rounding mode for the decimal module (used by DefaultContext); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra172.ROUND_UP_is_str:
  description: "decimal.ROUND_UP.__class__.__name__ == 'str' — ROUND_UP is a plain Python string, not an IntEnum or special type; all decimal rounding constants are plain str objects; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra172.ROUND_DOWN_val:
  description: "decimal.ROUND_DOWN == 'ROUND_DOWN' — the rounding constant is the string 'ROUND_DOWN' with 10 characters; ROUND_DOWN rounds toward zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_DOWN.__eq__
  args: ["ROUND_DOWN"]
  expected: true

invariant decimal_extra172.ROUND_CEILING_val:
  description: "decimal.ROUND_CEILING == 'ROUND_CEILING' — the rounding constant is the string 'ROUND_CEILING' with 13 characters; ROUND_CEILING rounds toward positive infinity; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_CEILING.__eq__
  args: ["ROUND_CEILING"]
  expected: true

invariant decimal_extra172.ROUND_FLOOR_val:
  description: "decimal.ROUND_FLOOR == 'ROUND_FLOOR' — the rounding constant is the string 'ROUND_FLOOR' with 11 characters; ROUND_FLOOR rounds toward negative infinity; ROUND_FLOOR (11) is between ROUND_DOWN (10) and ROUND_CEILING (13) in string length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_FLOOR.__eq__
  args: ["ROUND_FLOOR"]
  expected: true

invariant decimal_extra172.ROUND_HALF_UP_val:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — the rounding constant is the string 'ROUND_HALF_UP' with 13 characters; ROUND_HALF_UP (13) == ROUND_CEILING (13): tie at 13; rounds to nearest with ties away from zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra172.ROUND_HALF_DOWN_val:
  description: "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN' — the rounding constant is the string 'ROUND_HALF_DOWN' with 15 characters; ROUND_HALF_DOWN (15) == ROUND_HALF_EVEN (15): co-maximum; rounds to nearest with ties toward zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_HALF_DOWN.__eq__
  args: ["ROUND_HALF_DOWN"]
  expected: true

invariant decimal_extra172.ROUND_HALF_EVEN_val:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — the rounding constant is the string 'ROUND_HALF_EVEN' with 15 characters; ROUND_HALF_EVEN is the default rounding mode (banker's rounding); ROUND_HALF_EVEN (15) == ROUND_HALF_DOWN (15): co-maximum; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra172.ROUND_05UP_val:
  description: "decimal.ROUND_05UP == 'ROUND_05UP' — the rounding constant is the string 'ROUND_05UP' with 10 characters; ROUND_05UP (10) == ROUND_DOWN (10): tie at 10; ROUND_05UP rounds toward zero unless the last digit would be 0 or 5, in which case it rounds away from zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_05UP.__eq__
  args: ["ROUND_05UP"]
  expected: true

