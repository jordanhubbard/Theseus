spec: maturin_rust
version: ">=3.9"
backend: rust_module(maturin_rust)

docs: https://www.maturin.rs/

provenance:
  derived_from:
    - "https://www.maturin.rs/ — maturin build tool"
  notes:
    - "maturin builds Rust Python extensions."
    - "maturin.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant maturin_rust.has_version:
  description: "maturin has version attribute"
  category: presence
  kind: python_call_eq
  function: maturin_has_version
  args: []
  expected: true

invariant maturin_rust.version_is_string:
  description: "maturin.__version__ is a string"
  category: version
  kind: python_call_eq
  function: maturin_version_is_string
  args: []
  expected: true

invariant maturin_rust.version_nonempty:
  description: "maturin.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: maturin_version_nonempty
  args: []
  expected: true

