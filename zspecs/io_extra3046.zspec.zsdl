# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# io stream types do not implement the async context manager protocol;
# none define __aenter__ in their own __dict__; all false.
# ---------------------------------------------------------------------------

