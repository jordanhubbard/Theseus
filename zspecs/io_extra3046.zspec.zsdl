spec: io3046
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (io3046): __enter__, __exit__, __aenter__ dict-presence for io types."
    - "io.IOBase's __enter__ and __exit__ are defined in the C-level _io._IOBase, not in the Python-level io.IOBase.__dict__; all Python-level io classes return false."
    - "None of the io stream classes define __aenter__ in their own __dict__; async context manager support is not part of the io stream interface."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# io.__enter__ is implemented at the C level in _io._IOBase, not in the
# Python-level io classes; all Python-level io.__dict__ lookups return false.
# ---------------------------------------------------------------------------

table io3046.enter:
  description: "io types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io3046
  columns: [id, function, args, expected]
  rows:
    - ["io3046001", operator.contains, [io.IOBase.__dict__,          "__enter__"], false]
    - ["io3046002", operator.contains, [io.RawIOBase.__dict__,       "__enter__"], false]
    - ["io3046003", operator.contains, [io.BufferedIOBase.__dict__,  "__enter__"], false]
    - ["io3046004", operator.contains, [io.TextIOBase.__dict__,      "__enter__"], false]
    - ["io3046005", operator.contains, [io.BytesIO.__dict__,         "__enter__"], false]
    - ["io3046006", operator.contains, [io.StringIO.__dict__,        "__enter__"], false]
    - ["io3046007", operator.contains, [io.FileIO.__dict__,          "__enter__"], false]
    - ["io3046008", operator.contains, [io.BufferedReader.__dict__,  "__enter__"], false]
    - ["io3046009", operator.contains, [io.BufferedWriter.__dict__,  "__enter__"], false]
    - ["io3046010", operator.contains, [io.BufferedRandom.__dict__,  "__enter__"], false]
    - ["io3046011", operator.contains, [io.TextIOWrapper.__dict__,   "__enter__"], false]

# ---------------------------------------------------------------------------
