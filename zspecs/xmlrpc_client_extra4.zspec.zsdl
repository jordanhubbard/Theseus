spec: xmlrpc_client_extra4
version: ">=3.9"
backend: python_module(xmlrpc.client)

docs: https://docs.python.org/3/library/xmlrpc.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xmlrpc.client.html — Python xmlrpc.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xmlrpc/client.py"
  notes:
    - "This spec extends xmlrpc_client.zspec.zsdl through xmlrpc_client_extra3.zspec.zsdl."
    - "xmlrpc_client.zspec.zsdl covers: class __name__ table (ServerProxy/Fault/ProtocolError/MultiCall/Binary/DateTime/ResponseError/Unmarshaller/Marshaller); Fault/ProtocolError base hierarchy; loads/dumps __name__; type checks for ServerProxy/Fault/ProtocolError/Binary/DateTime; Binary.data roundtrip; Fault.faultCode/faultString; dumps returns str."
    - "xmlrpc_client_extra.zspec.zsdl covers: individual __name__ invariants for ServerProxy/Fault/ProtocolError/Binary/DateTime/Error; ServerProxy.__module__ and Error.__module__; Error.__bases__[0].__name__=='Exception'; Fault/ProtocolError base hierarchy; is_type checks for ServerProxy/Fault/Error/Binary/DateTime."
    - "xmlrpc_client_extra2.zspec.zsdl covers: Fault/ProtocolError/Binary/DateTime/ResponseError __module__; Unmarshaller/Marshaller/MultiCall __name__; __qualname__ table for ServerProxy/Fault/ProtocolError/ResponseError/Error/Binary/DateTime; loads/dumps __module__; ResponseError base hierarchy; MultiCall/Unmarshaller/Marshaller __module__."
    - "xmlrpc_client_extra3.zspec.zsdl covers: MultiCall/dumps/loads __qualname__."
    - "This spec adds: __qualname__ for Unmarshaller and Marshaller (not in any prior spec's qualname table); is_type checks for Unmarshaller/Marshaller/MultiCall/ResponseError (not in any prior spec); __name__ length checks for key classes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for Unmarshaller and Marshaller
# (xmlrpc_client_extra2's qualname table covers ServerProxy/Fault/ProtocolError/
#  ResponseError/Error/Binary/DateTime; extra3 adds MultiCall/dumps/loads.
#  Unmarshaller and Marshaller qualnames are not present in any prior spec.)
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra4.Unmarshaller.qualname:
  description: "xmlrpc.client.Unmarshaller.__qualname__ == 'Unmarshaller'"
  category: qualnames
  kind: python_call_eq
  function: Unmarshaller.__qualname__.__eq__
  args: ["Unmarshaller"]
  expected: true

invariant xmlrpc_client_extra4.Marshaller.qualname:
  description: "xmlrpc.client.Marshaller.__qualname__ == 'Marshaller'"
  category: qualnames
  kind: python_call_eq
  function: Marshaller.__qualname__.__eq__
  args: ["Marshaller"]
  expected: true

# ---------------------------------------------------------------------------
# is_type checks — Unmarshaller, Marshaller, MultiCall, ResponseError
# (xmlrpc_client_extra covers is_type for ServerProxy/Fault/Error/Binary/DateTime;
#  the four classes below are not in any prior is_type check)
# ---------------------------------------------------------------------------

table xmlrpc_client_extra4.type_identity:
  kind: python_call_eq
  category: type_identity
  id_prefix: istype

  columns: [id, function, args, expected]
  rows:
    - [Unmarshaller,  Unmarshaller.__class__.__name__.__eq__,  ["type"], true]
    - [Marshaller,    Marshaller.__class__.__name__.__eq__,    ["type"], true]
    - [MultiCall,     MultiCall.__class__.__name__.__eq__,     ["type"], true]
    - [ResponseError, ResponseError.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# __name__ length checks — spot-check that class names have no extra whitespace
# (no prior spec checks __name__ lengths for xmlrpc.client classes)
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra4.ServerProxy.name_len:
  description: "xmlrpc.client.ServerProxy.__name__.__len__() == 11 — 'ServerProxy' has 11 characters"
  category: class_identity
  kind: python_call_eq
  function: ServerProxy.__name__.__len__
  args: []
  expected: 11

invariant xmlrpc_client_extra4.ProtocolError.name_len:
  description: "xmlrpc.client.ProtocolError.__name__.__len__() == 13 — 'ProtocolError' has 13 characters"
  category: class_identity
  kind: python_call_eq
  function: ProtocolError.__name__.__len__
  args: []
  expected: 13

invariant xmlrpc_client_extra4.Unmarshaller.name_len:
  description: "xmlrpc.client.Unmarshaller.__name__.__len__() == 12 — 'Unmarshaller' has 12 characters"
  category: class_identity
  kind: python_call_eq
  function: Unmarshaller.__name__.__len__
  args: []
  expected: 12

invariant xmlrpc_client_extra4.Marshaller.name_len:
  description: "xmlrpc.client.Marshaller.__name__.__len__() == 10 — 'Marshaller' has 10 characters"
  category: class_identity
  kind: python_call_eq
  function: Marshaller.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Unmarshaller and Marshaller base class hierarchy
# (no prior spec checks the __bases__ of Unmarshaller or Marshaller)
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra4.Unmarshaller.base:
  description: "xmlrpc.client.Unmarshaller.__bases__[0].__name__ == 'object' — Unmarshaller has no framework base"
  category: hierarchy
  kind: python_call_eq
  function: Unmarshaller.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant xmlrpc_client_extra4.Marshaller.base:
  description: "xmlrpc.client.Marshaller.__bases__[0].__name__ == 'object' — Marshaller has no framework base"
  category: hierarchy
  kind: python_call_eq
  function: Marshaller.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
