spec: itertools_extra322
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.groupby is a C-level type: __name__ == 'groupby', __module__ == 'itertools'."
    - "groupby.__bases__[0].__name__ == 'object' — single base class is object."
    - "Doc lengths verified on Python 3.14.3: groupby=323, islice=453, starmap=126, takewhile=101, dropwhile=126, filterfalse=120, compress=164."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# groupby — identity checks
#
# itertools.groupby is a C-level type. Its __name__ is 'groupby', its
# __module__ is 'itertools', and its sole base class is object.
# ---------------------------------------------------------------------------

invariant itertools_extra322.groupby.name:
  description: "itertools.groupby.__name__ == 'groupby'"
  category: groupby_identity
  kind: python_call_eq
  function: groupby.__name__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra322.groupby.module:
  description: "itertools.groupby.__module__ == 'itertools'"
  category: groupby_identity
  kind: python_call_eq
  function: groupby.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra322.groupby.base_class:
  description: "itertools.groupby.__bases__[0].__name__ == 'object'"
  category: groupby_identity
  kind: python_call_eq
  function: groupby.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# __doc__ length checks
#
# These verify the exact byte-length of each C-level type's __doc__ string
# as observed on Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12.
#
# groupby     : 323
# islice      : 453
# starmap     : 126
# takewhile   : 101
# dropwhile   : 126
# filterfalse : 120
# compress    : 164
# ---------------------------------------------------------------------------

table itertools_extra322.doc_lengths:
  kind: python_call_eq
  category: doc_lengths
  id_prefix: doclen

  columns: [id, function, args, expected]
  rows:
    - [groupby,     groupby.__doc__.__len__,     [], 323]
    - [islice,      islice.__doc__.__len__,      [], 453]
    - [starmap,     starmap.__doc__.__len__,     [], 126]
    - [takewhile,   takewhile.__doc__.__len__,   [], 101]
    - [dropwhile,   dropwhile.__doc__.__len__,   [], 126]
    - [filterfalse, filterfalse.__doc__.__len__, [], 120]
    - [compress,    compress.__doc__.__len__,    [], 164]
