invariant asyncio_extra76.Queue_dict_has_put:
  description: "asyncio.Queue.__dict__.__contains__('put') returns True — Queue defines the put() coroutine directly in asyncio/queues.py; NEW in extra76: first standalone __contains__('put') invariant for Queue.__dict__ in asynciomore76 namespace; wave 242; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Queue.__dict__.__contains__
  args: ["put"]
  expected: true

invariant asyncio_extra76.Queue_dict_has_task_done:
  description: "asyncio.Queue.__dict__.__contains__('task_done') returns True — Queue defines the task_done() method directly in asyncio/queues.py; NEW in extra76: first standalone __contains__('task_done') invariant for Queue.__dict__ in asynciomore76 namespace; wave 242; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Queue.__dict__.__contains__
  args: ["task_done"]
  expected: true

invariant asyncio_extra76.Task_dict_class_name:
  description: "asyncio.Task.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — class __dict__ objects are always mappingproxy in CPython; NEW in extra76: first standalone __dict__.__class__.__name__ invariant for Task in asynciomore76 namespace; wave 242; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Task.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant asyncio_extra76.Task_dict_has_cancel:
