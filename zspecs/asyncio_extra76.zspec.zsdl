spec: asyncio_extra76
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queue"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec extends asyncio_extra75.zspec.zsdl."
    - "This spec covers: wave 242 theme — asyncio Queue.__dict__ content + Task.__dict__ content. NEW in extra76: Queue.__dict__.__class__.__name__=='mappingproxy'; Queue.__dict__.__contains__('put')==True; Queue.__dict__.__contains__('get')==True; Queue.__dict__.__contains__('put_nowait')==True; Queue.__dict__.__contains__('get_nowait')==True; Queue.__dict__.__contains__('qsize')==True; Queue.__dict__.__contains__('empty')==True; Queue.__dict__.__contains__('full')==True; Queue.__dict__.__contains__('join')==True; Queue.__dict__.__contains__('task_done')==True; Task.__dict__.__class__.__name__=='mappingproxy'; Task.__dict__.__contains__('cancel')==True; Task.__dict__.__contains__('done')==True; Task.__dict__.__contains__('result')==True; Task.__dict__.__contains__('get_name')==True; Task.__dict__.__contains__('set_name')==True."
    - "asyncio.Queue.__dict__.__class__.__name__ == 'mappingproxy'. The __dict__ of any Python class is a read-only mappingproxy; Queue.__dict__.__class__.__name__ is 'mappingproxy'. Prior specs captured __dict__.__class__.__name__.__eq__('mappingproxy') via extra54 but not __contains__ checks. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('put') == True. Queue defines put as a coroutine method in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('get') == True. Queue defines get as a coroutine method in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('put_nowait') == True. Queue defines put_nowait directly in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('get_nowait') == True. Queue defines get_nowait directly in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('qsize') == True. Queue defines qsize directly in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('empty') == True. Queue defines empty directly in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('full') == True. Queue defines full directly in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('join') == True. Queue defines join as a coroutine method in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('task_done') == True. Queue defines task_done directly in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__class__.__name__ == 'mappingproxy'. asyncio.Task is a Python class (backed by C extension in CPython 3.14 but still accessible as a type); its __dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('cancel') == True. Task defines cancel directly in its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('done') == True. Task defines done directly in its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('result') == True. Task defines result directly in its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('get_name') == True. Task defines get_name directly in its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('set_name') == True. Task defines set_name directly in its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue.__dict__ class name and put/get method content — extra76
#
# Wave 242 theme: asyncio Queue.__dict__ content + Task.__dict__ content.
#
# Queue.__dict__.__class__.__name__ == 'mappingproxy'
# Queue.__dict__.__contains__('put') == True
# Queue.__dict__.__contains__('get') == True
# Queue.__dict__.__contains__('put_nowait') == True
# Queue.__dict__.__contains__('get_nowait') == True
# ---------------------------------------------------------------------------

table asyncio_extra76.Queue_dict_class_and_put_get:
  description: "asyncio Queue.__dict__ class name and put/get method content checks in asynciomore76 namespace — wave 242 theme: Queue.__dict__ content; Queue.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is read-only mappingproxy in CPython); Queue.__dict__.__contains__('put')==True; Queue.__dict__.__contains__('get')==True; Queue.__dict__.__contains__('put_nowait')==True; Queue.__dict__.__contains__('get_nowait')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: asynciomore76

  columns: [id, function, args, expected, description]
  rows:
    - [queue_dict_class_name,    Queue.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Queue.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [queue_dict_has_put,       Queue.__dict__.__contains__,              ["put"],          true, "Queue.__dict__.__contains__('put') == True — Queue defines put coroutine in asyncio/queues.py; verified with Python 3.14.3"]
    - [queue_dict_has_get,       Queue.__dict__.__contains__,              ["get"],          true, "Queue.__dict__.__contains__('get') == True — Queue defines get coroutine in asyncio/queues.py; verified with Python 3.14.3"]
    - [queue_dict_has_put_nowait, Queue.__dict__.__contains__,             ["put_nowait"],   true, "Queue.__dict__.__contains__('put_nowait') == True — Queue defines put_nowait in asyncio/queues.py; verified with Python 3.14.3"]
    - [queue_dict_has_get_nowait, Queue.__dict__.__contains__,             ["get_nowait"],   true, "Queue.__dict__.__contains__('get_nowait') == True — Queue defines get_nowait in asyncio/queues.py; verified with Python 3.14.3"]

