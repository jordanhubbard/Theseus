spec: threading_extra1246
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading __doc__ class checks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "Wave 530 (_extra1246): checks that threading module, classes, and functions have str __doc__ attributes."
    - "threading.__doc__.__class__.__name__ == 'str' — module docstring is a str; verified Python 3.14.3."
    - "threading.Thread.__doc__.__class__.__name__ == 'str' — Thread is a Python class with a str docstring; verified Python 3.14.3."
    - "threading.Lock.__doc__.__class__.__name__ == 'str' — threading.Lock is a C type alias (_thread.lock) with a str docstring; verified Python 3.14.3."
    - "threading.RLock.__doc__.__class__.__name__ == 'str' — threading.RLock is a Python factory function with a str docstring; verified Python 3.14.3."
    - "threading.Condition.__doc__.__class__.__name__ == 'str' — Condition is a Python class with a str docstring; verified Python 3.14.3."
    - "threading.Event.__doc__.__class__.__name__ == 'str' — Event is a Python class with a str docstring; verified Python 3.14.3."
    - "threading.Semaphore.__doc__.__class__.__name__ == 'str' — Semaphore is a Python class with a str docstring; verified Python 3.14.3."
    - "threading.BoundedSemaphore.__doc__.__class__.__name__ == 'str' — BoundedSemaphore is a Python class with a str docstring; verified Python 3.14.3."
    - "threading.Barrier.__doc__.__class__.__name__ == 'str' — Barrier is a Python class with a str docstring; verified Python 3.14.3."
    - "threading.Timer.__doc__.__class__.__name__ == 'str' — Timer is a Python class with a str docstring; verified Python 3.14.3."
    - "threading.local.__doc__.__class__.__name__ == 'str' — threading.local is a C type with a str docstring; verified Python 3.14.3."
    - "threading.__doc__.__len__.__class__.__name__ == 'method-wrapper' — __len__ on a str is a C method-wrapper; verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading module and synchronization primitives __doc__ class == 'str'
#
# threading.__doc__.__class__.__name__           == 'str'
# threading.Thread.__doc__.__class__.__name__    == 'str'
# threading.Lock.__doc__.__class__.__name__      == 'str'
# threading.RLock.__doc__.__class__.__name__     == 'str'
# threading.Condition.__doc__.__class__.__name__ == 'str'
# threading.Event.__doc__.__class__.__name__     == 'str'
#
# threading.Lock is a C type (_thread.lock) exposed in threading, with a str
# docstring. threading.RLock is a Python factory function that returns an
# _RLock instance and itself carries a str docstring.
# ---------------------------------------------------------------------------

table threading_extra1246.module_and_primitives_doc_class:
  description: "threading module and sync primitives have str __doc__: module/Thread/Lock/RLock/Condition/Event; new to extra1246"
  kind: python_call_eq
  category: doc_class
  id_prefix: th1246mp

  columns: [id, function, args, expected, description]
  rows:
    - [th1246mp001,
       threading.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__doc__.__class__.__name__.__eq__('str') == True — the threading module docstring is a str; verified Python 3.14.3; new to extra1246"]
    - [th1246mp002,
       threading.Thread.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Thread.__doc__.__class__.__name__.__eq__('str') == True — Thread is a Python class with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [th1246mp003,
       threading.Lock.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Lock.__doc__.__class__.__name__.__eq__('str') == True — threading.Lock is a C type (_thread.lock) with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [th1246mp004,
       threading.RLock.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.RLock.__doc__.__class__.__name__.__eq__('str') == True — threading.RLock is a Python factory function with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [th1246mp005,
       threading.Condition.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Condition.__doc__.__class__.__name__.__eq__('str') == True — Condition is a Python class with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [th1246mp006,
       threading.Event.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Event.__doc__.__class__.__name__.__eq__('str') == True — Event is a Python class with a str docstring; verified Python 3.14.3; new to extra1246"]

# ---------------------------------------------------------------------------
# Table 2: threading semaphore, barrier, timer, and local __doc__ class == 'str'
#
# threading.Semaphore.__doc__.__class__.__name__        == 'str'
# threading.BoundedSemaphore.__doc__.__class__.__name__ == 'str'
# threading.Barrier.__doc__.__class__.__name__          == 'str'
# threading.Timer.__doc__.__class__.__name__            == 'str'
# threading.local.__doc__.__class__.__name__            == 'str'
#
# All five items are Python classes (or C types in the case of local) carrying
# str docstrings. BoundedSemaphore subclasses Semaphore; Timer subclasses Thread.
# ---------------------------------------------------------------------------

table threading_extra1246.semaphore_barrier_timer_local_doc_class:
  description: "threading Semaphore/BoundedSemaphore/Barrier/Timer/local have str __doc__; new to extra1246"
  kind: python_call_eq
  category: doc_class
  id_prefix: th1246sb

  columns: [id, function, args, expected, description]
  rows:
    - [th1246sb001,
       threading.Semaphore.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Semaphore.__doc__.__class__.__name__.__eq__('str') == True — Semaphore is a Python class with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [th1246sb002,
       threading.BoundedSemaphore.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.BoundedSemaphore.__doc__.__class__.__name__.__eq__('str') == True — BoundedSemaphore subclasses Semaphore and carries a str docstring; verified Python 3.14.3; new to extra1246"]
    - [th1246sb003,
       threading.Barrier.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Barrier.__doc__.__class__.__name__.__eq__('str') == True — Barrier is a Python class with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [th1246sb004,
       threading.Timer.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Timer.__doc__.__class__.__name__.__eq__('str') == True — Timer subclasses Thread and carries a str docstring; verified Python 3.14.3; new to extra1246"]
    - [th1246sb005,
       threading.local.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.local.__doc__.__class__.__name__.__eq__('str') == True — threading.local is a C type with a str docstring; verified Python 3.14.3; new to extra1246"]
    - [th1246sb006,
       threading.__doc__.__class__.__name__.__eq__,
       ["NoneType"],
       false,
       "threading.__doc__.__class__.__name__.__eq__('NoneType') == False — the threading module docstring is a str not NoneType; str.__eq__('NoneType') returns False; verified Python 3.14.3; new to extra1246"]

# ---------------------------------------------------------------------------
# Table 3: threading __doc__.__len__ structural class checks
#
# threading.__doc__.__len__.__class__.__name__            == 'method-wrapper'
# threading.Thread.__doc__.__len__.__class__.__name__     == 'method-wrapper'
# threading.Condition.__doc__.__len__.__class__.__name__  == 'method-wrapper'
# threading.Semaphore.__doc__.__len__.__class__.__name__  == 'method-wrapper'
# threading.Barrier.__doc__.__len__.__class__.__name__    == 'method-wrapper'
# threading.local.__doc__.__len__.__class__.__name__      == 'method-wrapper'
#
# str.__len__ is always a C method-wrapper. Verifies the structural class of
# the __len__ bound method on str docstrings, a wave-530 distinctive axis.
# ---------------------------------------------------------------------------

table threading_extra1246.doc_len_method_class:
  description: "threading __doc__.__len__.__class__.__name__ == 'method-wrapper' for module and key classes; new to extra1246"
  kind: python_call_eq
  category: doc_len_class
  id_prefix: th1246dl

  columns: [id, function, args, expected, description]
  rows:
    - [th1246dl001,
       threading.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "threading.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — __len__ on a str instance is a C method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [th1246dl002,
       threading.Thread.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "threading.Thread.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — Thread docstring __len__ is a method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [th1246dl003,
       threading.Condition.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "threading.Condition.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — Condition docstring __len__ is a method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [th1246dl004,
       threading.Semaphore.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "threading.Semaphore.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — Semaphore docstring __len__ is a method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [th1246dl005,
       threading.Barrier.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "threading.Barrier.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — Barrier docstring __len__ is a method-wrapper; verified Python 3.14.3; new to extra1246"]
    - [th1246dl006,
       threading.local.__doc__.__len__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true,
       "threading.local.__doc__.__len__.__class__.__name__.__eq__('method-wrapper') == True — local docstring __len__ is a method-wrapper; verified Python 3.14.3; new to extra1246"]
