spec: pathlib_extra435
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib class hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers class identity for PurePath, Path, and their platform-specific subclasses"
    - "__bases__[0] function fields are double-quoted per ZSDL rules for bracket expressions"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra435.class_names:
  description: "Class __name__ identity for pathlib classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: pln

  columns: [id, function, args, expected]
  rows:
    - [pln001, pathlib.Path.__name__.__eq__, ["Path"], true]
    - [pln002, pathlib.PurePath.__name__.__eq__, ["PurePath"], true]
    - [pln003, pathlib.PurePosixPath.__name__.__eq__, ["PurePosixPath"], true]
    - [pln004, pathlib.PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true]
    - [pln005, pathlib.PosixPath.__name__.__eq__, ["PosixPath"], true]
    - [pln006, pathlib.WindowsPath.__name__.__eq__, ["WindowsPath"], true]

table pathlib_extra435.class_modules:
  description: "Class __module__ identity for pathlib classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: plm

  columns: [id, function, args, expected]
  rows:
    - [plm001, pathlib.Path.__module__.__eq__, ["pathlib"], true]
    - [plm002, pathlib.PurePath.__module__.__eq__, ["pathlib"], true]
    - [plm003, pathlib.PurePosixPath.__module__.__eq__, ["pathlib"], true]
    - [plm004, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"], true]
    - [plm005, pathlib.PosixPath.__module__.__eq__, ["pathlib"], true]
    - [plm006, pathlib.WindowsPath.__module__.__eq__, ["pathlib"], true]

table pathlib_extra435.class_bases:
  description: "Base class identity for pathlib classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: plb

  columns: [id, function, args, expected]
  rows:
    - [plb001, "pathlib.PurePath.__bases__[0].__name__.__eq__", ["object"], true]
