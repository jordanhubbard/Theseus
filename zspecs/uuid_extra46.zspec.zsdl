spec: uuid_extra46
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra45.zspec.zsdl — covers UUID/__dict__/__class__/__name__/__qualname__.__eq__('mappingproxy'); uuid module __dict__/__class__/__name__/__qualname__.__eq__('mappingproxy'); NAMESPACE_DNS.__class__.__module__.__len__()==4."
    - "uuid_extra44.zspec.zsdl — covers NAMESPACE_OID/X500 __class__.__name__/__qualname__.__len__()==4; uuid.__name__.__eq__('uuid') and __name__.__len__()==4."
    - "uuid_extra43.zspec.zsdl — covers NAMESPACE_URL/OID/X500 __class__.__name__/__qualname__/__module__.__eq__ string values."
    - "uuid_extra42.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low fget.__qualname__.__eq__; getnode/__module__.__eq__; uuid4/getnode/UUID __module__.__class__.__name__.__eq__('str')."
    - "uuid_extra39.zspec.zsdl — covers UUID/uuid4 __class__.__module__.__eq__('builtins') and NAMESPACE_DNS __class__.__module__.__eq__('uuid') as three representative rows; does NOT cover uuid1/uuid3/uuid5 __class__.__module__ or NAMESPACE_URL/OID/X500 __class__.__module__."
  notes:
    - "This spec extends uuid through uuid_extra45; it does NOT duplicate invariants present in those files."
    - "Wave 221 theme: __class__.__module__ string equality checks + __init__.__class__ checks for class objects."
    - "Coverage gap 1: uuid_extra39 checks UUID/uuid4 __class__.__module__.__eq__('builtins') as representative rows, but does NOT cover uuid1, uuid3, or uuid5 on the __class__.__module__.__eq__('builtins') axis. uuid1/uuid3/uuid5 are all pure Python functions; their __class__ is the built-in function type with __module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__class__.__module__ == 'builtins'. uuid1 is a pure Python function; the built-in function type has __module__ == 'builtins'. uuid_extra39 covers UUID/uuid4 __class__.__module__.__eq__('builtins') but NOT uuid1. No prior uuid spec checks uuid1.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__class__.__module__ == 'builtins'. Same pattern as uuid1. No prior uuid spec checks uuid3.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__class__.__module__ == 'builtins'. Same pattern as uuid1. No prior uuid spec checks uuid5.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: uuid_extra39 checks NAMESPACE_DNS.__class__.__module__.__eq__('uuid') as one representative row for UUID instance constants, but does NOT cover NAMESPACE_URL, NAMESPACE_OID, or NAMESPACE_X500 on the __class__.__module__ axis. uuid_extra43 covers NAMESPACE_URL/OID/X500 __class__.__module__.__eq__ (the value axis), so that IS covered. However, NAMESPACE_URL/OID/X500 are covered by extra43, so this is not a new gap. Verifying: uuid_extra43 notes cover NAMESPACE_URL/OID/X500 __class__.__module__.__eq__."
    - "Re-examining coverage: uuid_extra43 covers NAMESPACE_URL/OID/X500 __class__.__name__/__qualname__/__module__.__eq__ — so NAMESPACE_URL/OID/X500 __class__.__module__.__eq__('uuid') IS already covered. Novel opportunity instead: no prior uuid spec checks __init__.__class__.__name__ or __init__.__class__.__module__ for uuid.UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__class__.__name__ == 'function'. UUID is a pure Python class defined in Lib/uuid.py; its __init__ is a Python function. The __class__ of a Python function is the built-in function type, whose __name__ is 'function'. No prior uuid spec checks UUID.__init__.__class__.__name__.__eq__('function'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__class__.__module__ == 'builtins'. The built-in function type has __module__ == 'builtins'. No prior uuid spec checks UUID.__init__.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1/uuid3/uuid5 __class__.__module__.__eq__('builtins')
#
# uuid_extra39 checks UUID/uuid4/__class__.__module__.__eq__('builtins') and
# NAMESPACE_DNS/__class__.__module__.__eq__('uuid') as three representative rows.
# It does NOT cover uuid1, uuid3, or uuid5. All three are pure Python functions
# defined in Lib/uuid.py; their __class__ is the built-in function type whose
# __module__ is 'builtins'. This table completes the __class__.__module__
# coverage for the four uuid generator functions.
# ---------------------------------------------------------------------------

table uuid_extra46.uuid_func_class_module_eq:
  description: "uuid.uuid1/uuid3/uuid5 __class__.__module__.__eq__('builtins') — pure Python functions whose __class__ (function type) has __module__ == 'builtins'; uuid_extra39 covers UUID/uuid4 __class__.__module__.__eq__('builtins') but NOT uuid1/uuid3/uuid5; novel extension of the __class__.__module__ axis for uuid generator functions"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidmod46

  columns: [id, function, args, expected]
  rows:
    - [uuid1_class_module_eq, uuid1.__class__.__module__.__eq__, ["builtins"], true]
    - [uuid3_class_module_eq, uuid3.__class__.__module__.__eq__, ["builtins"], true]
    - [uuid5_class_module_eq, uuid5.__class__.__module__.__eq__, ["builtins"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__class__.__name__.__eq__('function')
#
# No prior uuid spec checks __init__.__class__.__name__ for uuid.UUID.
# uuid.UUID is a pure Python class defined in Lib/uuid.py; its __init__ method
# is a Python function. The __class__ of any Python function is the built-in
# function type, whose __name__ is 'function'. This provides a novel regression
# vector on the __init__.__class__.__name__ axis for UUID.
# ---------------------------------------------------------------------------

invariant uuid_extra46.UUID.init_class_name_eq:
  description: "uuid.UUID.__init__.__class__.__name__ == 'function' — UUID is a pure Python class; __init__ is a Python function; the built-in function type has __name__ == 'function'; no prior uuid spec checks UUID.__init__.__class__.__name__.__eq__('function')"
  category: type_structure
  kind: python_call_eq
  function: UUID.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__class__.__module__.__eq__('builtins')
#
# No prior uuid spec checks __init__.__class__.__module__ for uuid.UUID.
# The built-in function type (to which all Python functions belong) has
# __module__ == 'builtins'. This is independent from the __class__.__name__
# check above: if the function type were moved to another module while retaining
# its name, __module__ would catch the change while __name__ would not.
# ---------------------------------------------------------------------------

invariant uuid_extra46.UUID.init_class_module_eq:
  description: "uuid.UUID.__init__.__class__.__module__ == 'builtins' — the built-in function type has __module__ == 'builtins'; independent from __class__.__name__ axis; no prior uuid spec checks UUID.__init__.__class__.__module__.__eq__('builtins')"
  category: type_structure
  kind: python_call_eq
  function: UUID.__init__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
