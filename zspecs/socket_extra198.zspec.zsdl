spec: socket_extra198
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.__name__ == 'socket' (len=6) — the module's own __name__ attribute."
    - "socket.socket.__name__ == 'socket' (len=6) — the socket class name; same as module name."
    - "socket.gethostname.__name__ == 'gethostname' (len=11) — the gethostname function name."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo' (len=11) — the getaddrinfo function name; same length as gethostname."
    - "socket.create_connection.__name__ == 'create_connection' (len=17) — the create_connection function name; longest covered here."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' (len=13) — AF_INET is an IntEnum member of AddressFamily."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (len=10) — SOCK_STREAM is an IntEnum member of SocketKind."
    - "socket.error.__name__ == 'OSError' (len=7) — socket.error is an alias for the built-in OSError."
    - "Name length ordering: socket/socket.socket(6) < OSError(7) < SocketKind(10) < gethostname/getaddrinfo(11) < AddressFamily(13) < create_connection(17)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module and class name lengths — group A
# socket.__name__, socket.socket.__name__, socket.gethostname.__name__
# ---------------------------------------------------------------------------

table socketnamelens198.module_and_basic_names_a:
  kind: python_call_eq
  category: name_lengths
  id_prefix: socketnamelens198

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len,      __name__.__len__,              [], 6,  "socket.__name__.__len__() == 6 ('socket' has 6 characters)"]
    - [socket_class_len,     socket.__name__.__len__,       [], 6,  "socket.socket.__name__.__len__() == 6 ('socket' has 6 characters, same as module name)"]
    - [gethostname_name_len, gethostname.__name__.__len__,  [], 11, "socket.gethostname.__name__.__len__() == 11 ('gethostname' has 11 characters)"]

# ---------------------------------------------------------------------------
# socket function and enum class name lengths — group B
# socket.getaddrinfo.__name__, socket.create_connection.__name__, socket.AF_INET class name
# ---------------------------------------------------------------------------

table socketnamelens198.function_and_enum_names_b:
  kind: python_call_eq
  category: name_lengths
  id_prefix: socketnamelens198

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_name_len,      getaddrinfo.__name__.__len__,              [], 11, "socket.getaddrinfo.__name__.__len__() == 11 ('getaddrinfo' has 11 characters, same length as gethostname)"]
    - [create_conn_name_len,      create_connection.__name__.__len__,        [], 17, "socket.create_connection.__name__.__len__() == 17 ('create_connection' has 17 characters; longest name in this spec)"]
    - [AF_INET_class_len,         AF_INET.__class__.__name__.__len__,        [], 13, "socket.AF_INET.__class__.__name__.__len__() == 13 ('AddressFamily' has 13 characters; AF_INET is an IntEnum member)"]

# ---------------------------------------------------------------------------
# socket SOCK_STREAM and error name lengths — group C
# socket.SOCK_STREAM.__class__.__name__, socket.error.__name__
# ---------------------------------------------------------------------------

table socketnamelens198.sockkind_and_error_names_c:
  kind: python_call_eq
  category: name_lengths
  id_prefix: socketnamelens198

  columns: [id, function, args, expected, description]
  rows:
    - [SOCK_STREAM_class_len,  SOCK_STREAM.__class__.__name__.__len__,  [], 10, "socket.SOCK_STREAM.__class__.__name__.__len__() == 10 ('SocketKind' has 10 characters; SOCK_STREAM is an IntEnum member)"]
    - [error_name_len,         error.__name__.__len__,                  [], 7,  "socket.error.__name__.__len__() == 7 ('OSError' has 7 characters; socket.error is an alias for OSError)"]
    - [module_name_eq,         __name__.__eq__,                         ["socket"], true, "socket.__name__ == 'socket' (the module's canonical name)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socketnamelens198.socket_module_name_len:
  description: "socket.__name__.__len__() == 6 — 'socket' has exactly 6 characters"
  category: name_lengths
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

invariant socketnamelens198.socket_class_name_len:
  description: "socket.socket.__name__.__len__() == 6 — 'socket' has 6 characters; the socket class shares the same name as the module"
  category: name_lengths
  kind: python_call_eq
  function: socket.__name__.__len__
  args: []
  expected: 6

invariant socketnamelens198.gethostname_name_len:
  description: "socket.gethostname.__name__.__len__() == 11 — 'gethostname' has 11 characters"
  category: name_lengths
  kind: python_call_eq
  function: gethostname.__name__.__len__
  args: []
  expected: 11

invariant socketnamelens198.getaddrinfo_name_len:
  description: "socket.getaddrinfo.__name__.__len__() == 11 — 'getaddrinfo' has 11 characters, same length as gethostname"
  category: name_lengths
  kind: python_call_eq
  function: getaddrinfo.__name__.__len__
  args: []
  expected: 11

invariant socketnamelens198.create_connection_name_len:
  description: "socket.create_connection.__name__.__len__() == 17 — 'create_connection' has 17 characters; longest name covered in this spec"
  category: name_lengths
  kind: python_call_eq
  function: create_connection.__name__.__len__
  args: []
  expected: 17

invariant socketnamelens198.AF_INET_class_name_len:
  description: "socket.AF_INET.__class__.__name__.__len__() == 13 — 'AddressFamily' has 13 characters; AF_INET is an IntEnum member of AddressFamily"
  category: name_lengths
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__len__
  args: []
  expected: 13

invariant socketnamelens198.SOCK_STREAM_class_name_len:
  description: "socket.SOCK_STREAM.__class__.__name__.__len__() == 10 — 'SocketKind' has 10 characters; SOCK_STREAM is an IntEnum member of SocketKind"
  category: name_lengths
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__len__
  args: []
  expected: 10

invariant socketnamelens198.error_name_len:
  description: "socket.error.__name__.__len__() == 7 — 'OSError' has 7 characters; socket.error is an alias for the built-in OSError"
  category: name_lengths
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 7
