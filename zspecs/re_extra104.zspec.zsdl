spec: re_extra104
version: ">=3.9"
backend: python_module(re)
extends: re_extra103

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra103.zspec.zsdl."
    - "This spec covers: re module __name__, __package__, __spec__ attrs and re.RegexFlag/re.PatternError identity."
    - "re.__package__ == 're' (re is organized as a package; __package__ equals the package name, not empty string)."
    - "re.__spec__.__class__.__name__ == 'ModuleSpec' (length 10)."
    - "re.__loader__.__class__.__name__ == 'SourceFileLoader' (re is a regular Python source file)."
    - "re.__spec__.has_location == True (re has an on-disk source file)."
    - "re.NOFLAG.value == 0, re.IGNORECASE.value == 2, re.MULTILINE.value == 8, re.DOTALL.value == 16."
    - "re.VERBOSE.value == 64, re.ASCII.value == 256."
    - "re.RegexFlag.__name__ == 'RegexFlag' (length 9)."
    - "re.RegexFlag.__module__ == 're' (length 2)."
    - "re.PatternError.__name__ == 'PatternError' (length 12; renamed from 'error' in Python 3.14)."
    - "re.PatternError.__module__ == 're' (length 2)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module identity: __name__, __package__, __spec__ attributes
# re is a source file module/package, so has_location is True.
# __package__ == 're' (not empty string — re is a package).
# __loader__.__class__.__name__ == 'SourceFileLoader'.
# ---------------------------------------------------------------------------

table re_extra104.module_identity:
  description: "re module identity: __name__ ('re', len 2), __package__ ('re'), __spec__.__class__.__name__ ('ModuleSpec'), __spec__.name ('re')"
  kind: python_call_eq
  category: module_identity
  id_prefix: remodid104

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        __name__.__eq__,                    ["re"],            true,  "re.__name__ == 're'"]
    - [name_len,       __name__.__len__,                   [],                2,     "re.__name__.__len__() == 2 ('re' has 2 characters)"]
    - [pkg_eq,         __package__.__eq__,                 ["re"],            true,  "re.__package__ == 're' (re is a package; __package__ equals the package name)"]
    - [pkg_not_empty,  __package__.__eq__,                 [""],              false, "re.__package__ != '' (re is a package, not a simple module; __package__ is 're', not empty string)"]
    - [spec_cls_name,  __spec__.__class__.__name__.__eq__, ["ModuleSpec"],    true,  "re.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_name_eq,   __spec__.name.__eq__,               ["re"],            true,  "re.__spec__.name == 're'"]
    - [spec_name_len,  __spec__.name.__len__,              [],                2,     "re.__spec__.name.__len__() == 2 ('re' has 2 characters)"]
    - [loader_cls,     __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "re.__loader__.__class__.__name__ == 'SourceFileLoader' (re is a regular Python source file)"]

# ---------------------------------------------------------------------------
# re module __spec__ source-file attribute and spec class name length
# has_location is True. __spec__.__class__.__name__.__len__() == 10.
# ---------------------------------------------------------------------------

table re_extra104.spec_source_attrs:
  description: "re.__spec__ source-module attributes: has_location (True), __spec__.__class__.__name__.__len__() (10 for 'ModuleSpec')"
  kind: python_call_eq
  category: module_identity
  id_prefix: remodid104

  columns: [id, function, args, expected, description]
  rows:
    - [has_loc_true,  __spec__.has_location.__eq__,            [true],  true, "re.__spec__.has_location == True (re has an on-disk source file)"]
    - [spec_cls_len,  __spec__.__class__.__name__.__len__,     [],      10,   "re.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec' has 10 characters)"]
    - [name_not_sre,  __name__.__eq__,                         ["sre"], false, "re.__name__ != 'sre' (the public module name is 're', not the internal 'sre' prefix)"]

# ---------------------------------------------------------------------------
# re.RegexFlag enum values
# re.NOFLAG.value == 0, re.IGNORECASE.value == 2, re.MULTILINE.value == 8,
# re.DOTALL.value == 16, re.VERBOSE.value == 64, re.ASCII.value == 256.
# ---------------------------------------------------------------------------

table re_extra104.RegexFlag_values:
  description: "re.RegexFlag enum values: NOFLAG=0, IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64, ASCII=256"
  kind: python_call_eq
  category: enum_values
  id_prefix: remodid104

  columns: [id, function, args, expected, description]
  rows:
    - [noflag_val,   NOFLAG.value.__eq__,     [0],   true, "re.NOFLAG.value == 0 (the null flag, no options set)"]
    - [ic_val,       IGNORECASE.value.__eq__,  [2],   true, "re.IGNORECASE.value == 2"]
    - [ml_val,       MULTILINE.value.__eq__,   [8],   true, "re.MULTILINE.value == 8"]
    - [dotall_val,   DOTALL.value.__eq__,      [16],  true, "re.DOTALL.value == 16"]
    - [verbose_val,  VERBOSE.value.__eq__,     [64],  true, "re.VERBOSE.value == 64"]
    - [ascii_val,    ASCII.value.__eq__,       [256], true, "re.ASCII.value == 256"]
    - [ic_not_1,     IGNORECASE.value.__eq__,  [1],   false, "re.IGNORECASE.value != 1 (IGNORECASE is 2, not 1)"]

# ---------------------------------------------------------------------------
# re.RegexFlag and re.PatternError class identity
# re.RegexFlag.__name__ == 'RegexFlag' (length 9), __module__ == 're' (length 2).
# re.PatternError.__name__ == 'PatternError' (length 12), __module__ == 're' (length 2).
# PatternError was renamed from 'error' in Python 3.14.
# ---------------------------------------------------------------------------

table re_extra104.RegexFlag_PatternError_identity:
  description: "re.RegexFlag identity: __name__ ('RegexFlag', len 9), __module__ ('re', len 2); re.PatternError identity: __name__ ('PatternError', len 12), __module__ ('re', len 2)"
  kind: python_call_eq
  category: class_identity
  id_prefix: remodid104

  columns: [id, function, args, expected, description]
  rows:
    - [rf_name_eq,    RegexFlag.__name__.__eq__,         ["RegexFlag"],    true,  "re.RegexFlag.__name__ == 'RegexFlag'"]
    - [rf_name_len,   RegexFlag.__name__.__len__,        [],               9,     "re.RegexFlag.__name__.__len__() == 9 ('RegexFlag' has 9 characters)"]
    - [rf_module_eq,  RegexFlag.__module__.__eq__,       ["re"],           true,  "re.RegexFlag.__module__ == 're'"]
    - [rf_module_len, RegexFlag.__module__.__len__,      [],               2,     "re.RegexFlag.__module__.__len__() == 2 ('re' has 2 characters)"]
    - [pe_name_eq,    PatternError.__name__.__eq__,      ["PatternError"], true,  "re.PatternError.__name__ == 'PatternError' (renamed from 'error' in Python 3.14)"]
    - [pe_name_len,   PatternError.__name__.__len__,     [],               12,    "re.PatternError.__name__.__len__() == 12 ('PatternError' has 12 characters)"]
    - [pe_module_eq,  PatternError.__module__.__eq__,    ["re"],           true,  "re.PatternError.__module__ == 're'"]
    - [pe_module_len, PatternError.__module__.__len__,   [],               2,     "re.PatternError.__module__.__len__() == 2 ('re' has 2 characters)"]
    - [pe_not_old,    PatternError.__name__.__eq__,      ["error"],        false, "re.PatternError.__name__ != 'error' (the class was renamed to 'PatternError' in Python 3.14)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra104.module_name_is_re:
  description: "re.__name__ == 're' (the public module name is 're', length 2; the module self-identifies as 're')"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["re"]
  expected: true

invariant re_extra104.package_is_re:
  description: "re.__package__ == 're' (re is organized as a package under Lib/re/; its __package__ attribute equals its own name, not empty string)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["re"]
  expected: true

invariant re_extra104.spec_has_location_true:
  description: "re.__spec__.has_location == True (re is a regular Python source module with an on-disk source file)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant re_extra104.NOFLAG_value_is_0:
  description: "re.NOFLAG.value == 0 (NOFLAG is the zero-value RegexFlag enum member representing no flags set)"
  category: enum_values
  kind: python_call_eq
  function: NOFLAG.value.__eq__
  args: [0]
  expected: true

invariant re_extra104.PatternError_name_is_PatternError:
  description: "re.PatternError.__name__ == 'PatternError' (Python 3.14 renamed re.error to re.PatternError; re.error still exists as a backward-compatible alias but __name__ is 'PatternError')"
  category: class_identity
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true
