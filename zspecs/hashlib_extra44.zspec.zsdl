spec: hashlib_extra44
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra43.zspec.zsdl — covers scrypt.__qualname__.__eq__('scrypt'); algorithms_available.__contains__('sha224') and ('sha384'); pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')."
    - "hashlib_extra42.zspec.zsdl — covers sha224/sha384/sha3_256/pbkdf2_hmac __module__.__eq__('_hashlib') string eq values."
    - "hashlib_extra41.zspec.zsdl — covers algorithms_guaranteed.__contains__ for sha256/md5/sha1/sha512; algorithms_guaranteed.__class__.__name__.__eq__('set')."
    - "hashlib_extra36.zspec.zsdl — covers shake_128/__qualname__.__len__()==17 and shake_256/__qualname__.__len__()==17 (length checks only, NOT string eq values)."
    - "hashlib_extra33.zspec.zsdl — covers sha3_512/shake_128/shake_256 __name__.__len__(); shake_128/__module__.__len__()==8 (length only, NOT string eq)."
    - "hashlib_extra28.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__()."
    - "hashlib_extra27.zspec.zsdl — covers Struct/__mro__.__len__()==2; error/__mro__.__len__()==4; Struct method __qualname__.__len__()."
    - "hashlib_extra13.zspec.zsdl — covers shake_256.__qualname__.__eq__('openssl_shake_256') and shake_256.__module__.__eq__('_hashlib')."
    - "hashlib_extra6.zspec.zsdl — covers blake2b/__module__.__eq__('_blake2') and blake2s/__module__.__eq__('_blake2')."
    - "hashlib_extra4.zspec.zsdl — covers new.__class__.__name__.__eq__('function')."
  notes:
    - "This spec extends hashlib through hashlib_extra43; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: hashlib_extra36 covers shake_128.__qualname__.__len__()==17 (length check only). hashlib_extra13 covers shake_256.__qualname__.__eq__('openssl_shake_256') and shake_256.__module__.__eq__('_hashlib') (string eq values). But NO prior spec checks shake_128.__qualname__.__eq__('openssl_shake_128') or shake_128.__module__.__eq__('_hashlib') as string eq values. These are the symmetric counterparts for SHAKE-128 that are covered for SHAKE-256 in extra13. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__qualname__ == 'openssl_shake_128'. On OpenSSL-backed CPython 3.12+, the SHAKE-128 constructor function has __qualname__ == __name__ == 'openssl_shake_128'. extra36 covers __qualname__.__len__()==17 (length only); no prior spec checks __qualname__.__eq__ for shake_128. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__module__ == '_hashlib'. The SHAKE-128 function lives in the _hashlib C extension, same as sha256/sha3_256/shake_256. extra33 covers __module__.__len__()==8 (length only); no prior spec checks __module__.__eq__('_hashlib') for shake_128 specifically. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: hashlib_extra28 covers blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__(). hashlib_extra6 covers blake2b/blake2s __module__.__eq__('_blake2'). hashlib_extra4 covers new.__class__.__name__.__eq__('function'). But NO prior spec checks blake2b.__class__.__name__ or blake2s.__class__.__name__. Unlike sha256/sha3_256 which are 'builtin_function_or_method', blake2b and blake2s are actual Python types (classes) so their __class__.__name__ == 'type'. This is a meaningful behavioral distinction. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__name__ == 'type'. blake2b is implemented as a genuine Python type (C extension type), not a builtin function like sha256. Its __class__ is the metaclass 'type'. No prior hashlib spec checks blake2b.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__class__.__name__ == 'type'. Same reasoning as blake2b — both blake2 variants are C extension types. No prior hashlib spec checks blake2s.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.shake_128 __qualname__ and __module__ string eq checks
#
# hashlib_extra36 covers shake_128.__qualname__.__len__()==17 (length only).
# hashlib_extra33 covers shake_128.__module__.__len__()==8 (length only).
# hashlib_extra13 covers shake_256.__qualname__.__eq__ and shake_256.__module__.__eq__
# as string eq values, but NO prior spec checks these for shake_128.
# ---------------------------------------------------------------------------

table hashlib_extra44.shake_128_qualname_module_eq:
  description: "hashlib.shake_128 __qualname__.__eq__('openssl_shake_128') and __module__.__eq__('_hashlib') — novel: extra36 covers __qualname__.__len__ only; extra33 covers __module__.__len__ only; extra13 covers shake_256 eq values but NOT shake_128"
  kind: python_call_eq
  category: function_names
  id_prefix: hsqme44

  columns: [id, function, args, expected]
  rows:
    - [shake_128_qualname_eq, shake_128.__qualname__.__eq__, ["openssl_shake_128"], true]
    - [shake_128_module_eq,   shake_128.__module__.__eq__,   ["_hashlib"],          true]

# ---------------------------------------------------------------------------
# hashlib.blake2b and blake2s __class__.__name__ string eq checks
#
# blake2b and blake2s are C extension types (metaclass 'type'), unlike sha256/
# sha3_256/shake_128 which are builtin_function_or_method instances.
# hashlib_extra28 covers blake2b/blake2s __qualname__.__eq__.
# hashlib_extra6 covers blake2b/blake2s __module__.__eq__('_blake2').
# hashlib_extra4 covers new.__class__.__name__.__eq__('function').
# No prior spec checks blake2b.__class__.__name__ or blake2s.__class__.__name__.
# ---------------------------------------------------------------------------

table hashlib_extra44.blake2_class_name_eq:
  description: "hashlib.blake2b/__class__/__name__.__eq__('type') and blake2s/__class__/__name__.__eq__('type') — blake2b/blake2s are C extension types (metaclass 'type'), distinct from sha256/shake_128 which are builtin_function_or_method; novel: no prior hashlib spec checks blake2b or blake2s __class__.__name__"
  kind: python_call_eq
  category: type_structure
  id_prefix: hbcne44

  columns: [id, function, args, expected]
  rows:
    - [blake2b_class_name_eq, blake2b.__class__.__name__.__eq__, ["type"], true]
    - [blake2s_class_name_eq, blake2s.__class__.__name__.__eq__, ["type"], true]
