spec: threading_extra215
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra214.zspec.zsdl — covers threading __doc__.__contains__ and __doc__.__len__ checks from the previous wave"
    - "threading.zspec.zsdl — covers core threading functional behavior"
  notes:
    - "threading.Thread.__doc__.__contains__('control') == True — Thread docstring says 'A class that represents a thread of control'. Verified with Python 3.14.3."
    - "threading.Thread.__doc__.__contains__('subclassed') == True — Thread docstring says 'This class can be safely subclassed in a limited fashion'. Verified with Python 3.14.3."
    - "threading.Lock.__doc__.__contains__('synchronization') == True — Lock docstring says 'A lock object is a synchronization primitive'. Verified with Python 3.14.3."
    - "threading.Lock.__doc__.__contains__('primitive') == True — Lock docstring says 'A lock object is a synchronization primitive'. Verified with Python 3.14.3."
    - "threading.Event.__doc__.__contains__('flag') == True — Event docstring says 'Events manage a flag that can be set to true with the set() method'. Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__.__contains__('counter') == True — Semaphore docstring says 'Semaphores manage a counter'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__doc__.__contains__('bounded') == True — BoundedSemaphore docstring says 'Implements a bounded semaphore'. Verified with Python 3.14.3."
    - "threading.Timer.__doc__.__contains__('seconds') == True — Timer docstring says 'Call a function after a specified number of seconds'. Verified with Python 3.14.3."
    - "threading.Condition.__doc__.__contains__('variable') == True — Condition docstring says 'Class that implements a condition variable'. Verified with Python 3.14.3."
    - "threading.RLock.__doc__.__contains__('reentrant') == True — RLock docstring says 'A reentrant lock must be released by the thread that acquired it'. Verified with Python 3.14.3."
    - "threading.Thread.__doc__.__len__() == 247 — Thread docstring has exactly 247 characters. Verified with Python 3.14.3."
    - "threading.Lock.__doc__.__len__() == 469 — Lock docstring has exactly 469 characters. Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__.__len__() == 307 — Semaphore docstring has exactly 307 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

