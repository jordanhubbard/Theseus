spec: io_extra69
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra68.zspec.zsdl — covers io.__doc__.__class__.__name__.__eq__('str') and __len__()==1473; BytesIO.__doc__.__contains__('bytes'); IOBase.__doc__.__contains__('I/O') and __contains__('abstract'); RawIOBase.__doc__.__contains__('raw'); BufferedIOBase.__doc__.__contains__('buffer')."
    - "io_extra67.zspec.zsdl — covers BytesIO.readable/writable/seekable/readlines/flush __qualname__.__eq__(); StringIO.readable/writable/seekable __qualname__.__eq__(); StringIO.readlines/__qualname__.__eq__('_IOBase.readlines') and StringIO.flush/__qualname__.__eq__('_IOBase.flush')."
    - "io_extra66.zspec.zsdl — covers io.__loader__/__spec__ class identity checks."
    - "io_extra65.zspec.zsdl — covers io.__loader__/__spec__/__file__ class identity checks."
  notes:
    - "This spec extends io_extra68.zspec.zsdl."
    - "Wave 229 theme: __defaults__ and __code__ checks for Python functions + __doc__ content checks for additional classes."
    - "io classes are C extensions — no __defaults__ or __code__ on their methods. Focus on __doc__.__contains__ content anchors for additional C extension classes."
    - "BytesIO.__doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.' (60 chars). It does NOT contain 'BytesIO' but does contain 'Buffered' and 'I/O'. No prior io spec checks BytesIO.__doc__.__contains__('Buffered') or __contains__('I/O') in the iodoc69 namespace. Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "StringIO.__doc__ begins 'Text I/O implementation using an in-memory buffer.' (174 chars). It does NOT contain 'StringIO' but does contain 'Text' and 'I/O'. No prior io spec checks StringIO.__doc__.__contains__('Text') or __contains__('I/O') in the iodoc69 namespace. Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "FileIO.__doc__ begins 'Open a file.' and contains 'file' and 'Open'. It does NOT contain 'FileIO'. No prior io spec checks FileIO.__doc__.__contains__('file') or __contains__('Open') in the iodoc69 namespace. Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "TextIOWrapper.__doc__ begins 'Character and line based layer over a BufferedIOBase object, buffer.' It does NOT contain 'TextIOWrapper' but does contain 'encoding' and 'buffer'. No prior io spec checks TextIOWrapper.__doc__.__contains__('encoding') or __contains__('buffer') in the iodoc69 namespace. Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BytesIO.__doc__.__len__()==60 — exact docstring length. Novel length anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "StringIO.__doc__.__len__()==174 — exact docstring length. Novel length anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BytesIO.__doc__.__contains__ content checks
#
# BytesIO.__doc__ is:
#   'Buffered I/O implementation using an in-memory bytes buffer.'
#
# BytesIO is a C extension — no __defaults__ or __code__ on its methods.
# The docstring contains 'Buffered' and 'I/O' but NOT 'BytesIO'.
# __doc__.__len__() is 60.
#
# No prior io spec checks BytesIO.__doc__.__contains__('Buffered') or
# __contains__('I/O') in the iodoc69 namespace. Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra69.bytesio_doc_contains:
  description: "BytesIO.__doc__.__contains__('Buffered') and __contains__('I/O') and __len__()==60 — BytesIO is a C extension; __doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.' (60 chars); contains 'Buffered' and 'I/O' but not 'BytesIO'; __len__()==60; no prior io spec checks BytesIO.__doc__.__contains__('Buffered') or __contains__('I/O') in iodoc69 namespace; novel content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: iodoc69biodoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_buffered, BytesIO.__doc__.__contains__, ["Buffered"], true]
    - [doc_contains_io,       BytesIO.__doc__.__contains__, ["I/O"],      true]
    - [doc_len_eq,            BytesIO.__doc__.__len__,      [],           60]

# ---------------------------------------------------------------------------
# StringIO.__doc__.__contains__ content checks
#
# StringIO.__doc__ is:
#   'Text I/O implementation using an in-memory buffer.\n\nThe initial_value
#    argument sets the value of object.  The newline\nargument is like the
#    one of TextIOWrapper\'s constructor.'
#
# StringIO is a C extension — no __defaults__ or __code__ on its methods.
# The docstring contains 'Text' and 'I/O' but NOT 'StringIO'.
# __doc__.__len__() is 174.
#
# No prior io spec checks StringIO.__doc__.__contains__('Text') or
# __contains__('I/O') in the iodoc69 namespace. Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra69.stringio_doc_contains:
  description: "StringIO.__doc__.__contains__('Text') and __contains__('I/O') and __len__()==174 — StringIO is a C extension; __doc__ begins 'Text I/O implementation using an in-memory buffer.' (174 chars); contains 'Text' and 'I/O' but not 'StringIO'; __len__()==174; no prior io spec checks StringIO.__doc__.__contains__('Text') or __contains__('I/O') in iodoc69 namespace; novel content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: iodoc69siodoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_text, StringIO.__doc__.__contains__, ["Text"],  true]
    - [doc_contains_io,   StringIO.__doc__.__contains__, ["I/O"],   true]
    - [doc_len_eq,        StringIO.__doc__.__len__,      [],        174]

# ---------------------------------------------------------------------------
# FileIO.__doc__.__contains__ content checks
#
# FileIO.__doc__ begins:
#   'Open a file.\n\nThe mode can be ...'
#
# FileIO is a C extension — no __defaults__ or __code__ on its methods.
# The docstring contains 'file' and 'Open' but NOT 'FileIO'.
#
# No prior io spec checks FileIO.__doc__.__contains__('file') or
# __contains__('Open') in the iodoc69 namespace. Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra69.fileio_doc_contains:
  description: "FileIO.__doc__.__contains__('file') and __contains__('Open') — FileIO is a C extension; __doc__ begins 'Open a file.' and describes file modes; contains 'file' and 'Open' but not 'FileIO'; no prior io spec checks FileIO.__doc__.__contains__('file') or __contains__('Open') in iodoc69 namespace; novel content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: iodoc69fiodoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_file, FileIO.__doc__.__contains__, ["file"], true]
    - [doc_contains_open, FileIO.__doc__.__contains__, ["Open"], true]

# ---------------------------------------------------------------------------
# TextIOWrapper.__doc__.__contains__ content checks
#
# TextIOWrapper.__doc__ begins:
#   'Character and line based layer over a BufferedIOBase object, buffer.\n\n
#    encoding gives the name of the encoding that the stream will be ...'
#
# TextIOWrapper is a C extension — no __defaults__ or __code__ on its methods.
# The docstring contains 'encoding' and 'buffer' but NOT 'TextIOWrapper'.
#
# No prior io spec checks TextIOWrapper.__doc__.__contains__('encoding') or
# __contains__('buffer') in the iodoc69 namespace. Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra69.textiowrapper_doc_contains:
  description: "TextIOWrapper.__doc__.__contains__('encoding') and __contains__('buffer') — TextIOWrapper is a C extension; __doc__ begins 'Character and line based layer over a BufferedIOBase object, buffer.' and discusses encoding; contains 'encoding' and 'buffer' but not 'TextIOWrapper'; no prior io spec checks TextIOWrapper.__doc__.__contains__('encoding') or __contains__('buffer') in iodoc69 namespace; novel content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: iodoc69tiwdoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_encoding, TextIOWrapper.__doc__.__contains__, ["encoding"], true]
    - [doc_contains_buffer,   TextIOWrapper.__doc__.__contains__, ["buffer"],   true]

invariant io_extra69.bytesio_doc_contains_buffered:
  description: "BytesIO.__doc__.__contains__('Buffered') == True — BytesIO is a C extension; __doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.'; 'Buffered' appears; no prior io spec checks BytesIO.__doc__.__contains__('Buffered') in iodoc69 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: BytesIO.__doc__.__contains__
  args: ["Buffered"]
  expected: true

invariant io_extra69.bytesio_doc_len:
  description: "BytesIO.__doc__.__len__() == 60 — BytesIO.__doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.' with exactly 60 characters; no prior io spec checks BytesIO.__doc__.__len__() in iodoc69 namespace; novel length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: BytesIO.__doc__.__len__
  args: []
  expected: 60

invariant io_extra69.stringio_doc_contains_text:
  description: "StringIO.__doc__.__contains__('Text') == True — StringIO is a C extension; __doc__ begins 'Text I/O implementation using an in-memory buffer.'; 'Text' appears; no prior io spec checks StringIO.__doc__.__contains__('Text') in iodoc69 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: StringIO.__doc__.__contains__
  args: ["Text"]
  expected: true

invariant io_extra69.stringio_doc_len:
  description: "StringIO.__doc__.__len__() == 174 — StringIO.__doc__ is the full text I/O description with exactly 174 characters; no prior io spec checks StringIO.__doc__.__len__() in iodoc69 namespace; novel length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: StringIO.__doc__.__len__
  args: []
  expected: 174

invariant io_extra69.fileio_doc_contains_file:
  description: "FileIO.__doc__.__contains__('file') == True — FileIO is a C extension; __doc__ begins 'Open a file.' and describes file modes; 'file' appears; no prior io spec checks FileIO.__doc__.__contains__('file') in iodoc69 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: FileIO.__doc__.__contains__
  args: ["file"]
  expected: true

invariant io_extra69.textiowrapper_doc_contains_encoding:
  description: "TextIOWrapper.__doc__.__contains__('encoding') == True — TextIOWrapper is a C extension; __doc__ begins 'Character and line based layer over a BufferedIOBase object, buffer.' and discusses encoding; 'encoding' appears; no prior io spec checks TextIOWrapper.__doc__.__contains__('encoding') in iodoc69 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: TextIOWrapper.__doc__.__contains__
  args: ["encoding"]
  expected: true
