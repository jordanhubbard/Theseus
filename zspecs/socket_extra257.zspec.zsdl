spec: socket_extra257
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "socket.AF_INET == 2 and socket.AF_UNIX == 1 are universal across all POSIX platforms."
    - "socket.AF_INET6 == 30 on macOS/Darwin; on Linux the value is 10. This spec asserts the macOS value only."
    - "socket.SOCK_STREAM == 1, SOCK_DGRAM == 2, SOCK_RAW == 3 are universal across POSIX platforms."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — Python 3.4+ wraps address family constants in an IntEnum."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — Python 3.4+ wraps socket type constants in an IntEnum."
    - "socket.AF_INET.__class__.__module__ == 'socket' — both IntEnum types live in the socket module."
    - "AF_INET6 value is macOS-specific (30). Linux users must skip or override the AF_INET6 invariant."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AF_* address family integer values
# AF_INET (2) and AF_UNIX (1) are universal; AF_INET6 (30) is macOS-specific
# ---------------------------------------------------------------------------

table socket_extra257.address_families.values:
  kind: python_call_eq
  category: constants
  id_prefix: af

  columns: [id, function, args, expected]
  rows:
    - [AF_INET,  AF_INET.__eq__,  [2],  true]
    - [AF_UNIX,  AF_UNIX.__eq__,  [1],  true]

invariant socket_extra257.AF_INET6.value_macos:
  description: "socket.AF_INET6 == 30 on macOS/Darwin — macOS-specific value; Linux uses 10"
  category: constants
  kind: python_call_eq
  function: AF_INET6.__eq__
  args: [30]
  expected: true

# ---------------------------------------------------------------------------
# SOCK_* socket type integer values (universal across POSIX platforms)
# ---------------------------------------------------------------------------

table socket_extra257.socket_types.values:
  kind: python_call_eq
  category: constants
  id_prefix: sock

  columns: [id, function, args, expected]
  rows:
    - [SOCK_STREAM, SOCK_STREAM.__eq__, [1], true]
    - [SOCK_DGRAM,  SOCK_DGRAM.__eq__,  [2], true]
    - [SOCK_RAW,    SOCK_RAW.__eq__,    [3], true]

# ---------------------------------------------------------------------------
# AF_INET and SOCK_STREAM class identity (IntEnum wrappers)
# ---------------------------------------------------------------------------

invariant socket_extra257.AF_INET.class_name:
  description: "socket.AF_INET.__class__.__name__ == 'AddressFamily'"
  category: type_identity
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra257.SOCK_STREAM.class_name:
  description: "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'"
  category: type_identity
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socket_extra257.AF_INET.class_module:
  description: "socket.AF_INET.__class__.__module__ == 'socket'"
  category: type_identity
  kind: python_call_eq
  function: AF_INET.__class__.__module__.__eq__
  args: ["socket"]
  expected: true
