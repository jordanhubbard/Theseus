spec: asyncio_extra59
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/importlib.html#importlib.machinery.SourceFileLoader — SourceFileLoader documentation"
    - "https://docs.python.org/3/reference/import.html#module-spec — ModuleSpec documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Lib/_bootstrap_external.py"
    - "CPython source: Lib/importlib/_bootstrap_external.py"
  notes:
    - "This spec extends asyncio_extra58.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ (extra/extra2/extra5), Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), BoundedSemaphore/__bases__[0].__qualname__=='Semaphore' (extra53), Condition/__bases__[0].__qualname__=='object' (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') for Queue/Lock/Event/Semaphore/Condition (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), class __weakref__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), Queue/Lock/Event/Semaphore __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), Queue/Lock/Event __subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') (extra57), asyncio.__all__.__contains__ membership checks for Queue/Lock/Event/Semaphore/gather/sleep/Task/Future (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58)."
    - "This spec covers (asyncioload59 namespace): wave 225 theme — __loader__ identity + __spec__ attribute chains + __file__/__cached__ checks. asyncio.__loader__.__class__.__name__.__eq__('SourceFileLoader') — asyncio is a pure Python package loaded from Lib/asyncio/__init__.py; its loader is a SourceFileLoader instance; __loader__.__class__.__name__ == 'SourceFileLoader'. asyncio.__spec__.__class__.__name__.__eq__('ModuleSpec') — Python's import machinery wraps module metadata in a ModuleSpec object; __spec__.__class__.__name__ == 'ModuleSpec'. asyncio.__file__.__class__.__name__.__eq__('str') — asyncio has a file path (__init__.py at Lib/asyncio/__init__.py); the path is a plain Python str; __file__.__class__.__name__ == 'str'. asyncio.__cached__.__class__.__name__.__eq__('str') — asyncio has a cached bytecode path (__pycache__/__init__.cpython-314.pyc); the path is a plain Python str; __cached__.__class__.__name__ == 'str'. No prior asyncio spec has captured __loader__.__class__.__name__, __spec__.__class__.__name__, __file__.__class__.__name__, or __cached__.__class__.__name__ as string equality checks."
    - "asyncio.__loader__.__class__.__name__ == 'SourceFileLoader'. asyncio is a pure Python package (directory Lib/asyncio/ with __init__.py). Python's import machinery uses a SourceFileLoader instance to load it. The loader is an instance of importlib.machinery.SourceFileLoader; __loader__.__class__.__name__ == 'SourceFileLoader'. __eq__('SourceFileLoader') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__spec__.__class__.__name__ == 'ModuleSpec'. Every loaded module has a __spec__ attribute containing a ModuleSpec object describing the module's import configuration. __spec__.__class__.__name__ == 'ModuleSpec'. __eq__('ModuleSpec') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__file__.__class__.__name__ == 'str'. asyncio has a file path pointing to Lib/asyncio/__init__.py. This path is a plain Python str; __file__.__class__.__name__ == 'str'. __eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__cached__.__class__.__name__ == 'str'. asyncio has a cached bytecode path pointing to the __pycache__/__init__.cpython-314.pyc file. This path is a plain Python str; __cached__.__class__.__name__ == 'str'. __eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.__loader__/__spec__/__file__/__cached__ class name checks — extra59
#
# Wave 225 theme: __loader__ identity + __spec__ attribute chains +
# __file__/__cached__ checks.
#
# asyncio is a pure Python package loaded from Lib/asyncio/__init__.py.
# Its loader is a SourceFileLoader instance:
#   asyncio.__loader__.__class__.__name__ == 'SourceFileLoader'
#
# Its module spec is a ModuleSpec object:
#   asyncio.__spec__.__class__.__name__ == 'ModuleSpec'
#
# Its file path is a plain Python str:
#   asyncio.__file__.__class__.__name__ == 'str'
#
# Its cached bytecode path is a plain Python str:
#   asyncio.__cached__.__class__.__name__ == 'str'
#
# No prior asyncio spec has captured any of these checks. Extra59 introduces
# this wave 225 theme in the asyncioload59 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra59.loader_spec_file_cached:
  description: "asyncio __loader__/__spec__/__file__/__cached__ class name checks in asyncioload59 namespace — asyncio is a pure Python package (Lib/asyncio/__init__.py); __loader__ is a SourceFileLoader instance; __spec__ is a ModuleSpec object; __file__ and __cached__ are plain Python str paths; all four __class__.__name__.__eq__ checks return True; wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ checks; first loader/spec/file/cached class name checks in any asyncio spec"
  kind: python_call_eq
  category: loader_identity
  id_prefix: asyncioload59

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name, __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true, "asyncio.__loader__.__class__.__name__ == 'SourceFileLoader' — asyncio is a pure Python package (Lib/asyncio/__init__.py); Python's import machinery uses a SourceFileLoader instance to load it; SourceFileLoader is defined in importlib._bootstrap_external; __loader__.__class__.__name__.__eq__('SourceFileLoader') returns True; wave 225 first __loader__.__class__.__name__ check in any asyncio spec"]
    - [spec_class_name,   __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true, "asyncio.__spec__.__class__.__name__ == 'ModuleSpec' — Python's import machinery stores module metadata in a ModuleSpec object; __spec__ is a ModuleSpec instance; __spec__.__class__.__name__.__eq__('ModuleSpec') returns True; wave 225 first __spec__.__class__.__name__ check in any asyncio spec"]
    - [file_class_name,   __file__.__class__.__name__.__eq__,    ["str"],              true, "asyncio.__file__.__class__.__name__ == 'str' — asyncio has a file path (Lib/asyncio/__init__.py); the path is a plain Python str; __file__.__class__.__name__.__eq__('str') returns True; wave 225 first __file__.__class__.__name__ check in any asyncio spec"]
    - [cached_class_name, __cached__.__class__.__name__.__eq__,  ["str"],              true, "asyncio.__cached__.__class__.__name__ == 'str' — asyncio has a cached bytecode path (__pycache__/__init__.cpython-314.pyc); the path is a plain Python str; __cached__.__class__.__name__.__eq__('str') returns True; wave 225 first __cached__.__class__.__name__ check in any asyncio spec"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra59
# ---------------------------------------------------------------------------

invariant asyncio_extra59.loader_class_name_eq:
  description: "asyncio.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — asyncio is a pure Python package (Lib/asyncio/__init__.py); its loader is a SourceFileLoader instance from importlib._bootstrap_external; __loader__.__class__.__name__ == 'SourceFileLoader'; wave 225 first __loader__.__class__.__name__ invariant in any asyncio spec"
  category: loader_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant asyncio_extra59.spec_class_name_eq:
  description: "asyncio.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — asyncio's module spec is a ModuleSpec object; __spec__.__class__.__name__ == 'ModuleSpec'; wave 225 first __spec__.__class__.__name__ invariant in any asyncio spec"
  category: loader_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant asyncio_extra59.file_class_name_eq:
  description: "asyncio.__file__.__class__.__name__.__eq__('str') returns True — asyncio has a file path (Lib/asyncio/__init__.py) which is a plain Python str; __file__.__class__.__name__ == 'str'; wave 225 first __file__.__class__.__name__ invariant in any asyncio spec"
  category: loader_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant asyncio_extra59.cached_class_name_eq:
  description: "asyncio.__cached__.__class__.__name__.__eq__('str') returns True — asyncio has a cached bytecode path (__pycache__/__init__.cpython-314.pyc) which is a plain Python str; __cached__.__class__.__name__ == 'str'; wave 225 first __cached__.__class__.__name__ invariant in any asyncio spec"
  category: loader_identity
  kind: python_call_eq
  function: __cached__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
