spec: time_extra18
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time_extra10.zspec.zsdl — covers __module__ table for core timing functions"
    - "time_extra15.zspec.zsdl — covers __module__ standalone invariants for sleep/time/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime"
    - "time_extra16.zspec.zsdl — covers __qualname__ for core timing and conversion functions; monotonic_ns/__name__"
    - "time_extra17.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for time/sleep/monotonic/perf_counter/process_time/struct_time"
  notes:
    - "This spec extends time_extra17.zspec.zsdl."
    - "Prior specs covered: time/sleep/monotonic/perf_counter/process_time/localtime/gmtime/mktime/strftime/strptime/ctime/struct_time __name__/__module__/__qualname__, struct_time/__name__/__module__, time.timezone/altzone/daylight __class__.__name__, monotonic_ns/__name__, __module__.__len__() and __name__.__len__() for six core symbols."
    - "This spec covers: __qualname__.__len__() for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime; __name__.__len__() for gmtime/localtime/mktime/strftime/strptime/ctime/clock_gettime/monotonic_ns/perf_counter_ns; __module__.__len__() for gmtime/localtime/mktime/strftime/clock_gettime/monotonic_ns/perf_counter_ns."
    - "No prior time spec checks time.time.__qualname__.__len__()."
    - "No prior time spec checks time.sleep.__qualname__.__len__()."
    - "No prior time spec checks time.monotonic.__qualname__.__len__()."
    - "No prior time spec checks time.perf_counter.__qualname__.__len__()."
    - "No prior time spec checks time.process_time.__qualname__.__len__()."
    - "No prior time spec checks time.gmtime.__qualname__.__len__()."
    - "No prior time spec checks time.localtime.__qualname__.__len__()."
    - "No prior time spec checks time.gmtime.__name__.__len__()."
    - "No prior time spec checks time.localtime.__name__.__len__()."
    - "No prior time spec checks time.mktime.__name__.__len__()."
    - "No prior time spec checks time.strftime.__name__.__len__()."
    - "No prior time spec checks time.strptime.__name__.__len__()."
    - "No prior time spec checks time.ctime.__name__.__len__()."
    - "No prior time spec checks time.clock_gettime.__name__.__len__()."
    - "No prior time spec checks time.monotonic_ns.__name__.__len__()."
    - "No prior time spec checks time.perf_counter_ns.__name__.__len__()."
    - "No prior time spec checks time.gmtime.__module__.__len__()."
    - "No prior time spec checks time.localtime.__module__.__len__()."
    - "No prior time spec checks time.mktime.__module__.__len__()."
    - "No prior time spec checks time.strftime.__module__.__len__()."
    - "No prior time spec checks time.clock_gettime.__module__.__len__()."
    - "No prior time spec checks time.monotonic_ns.__module__.__len__()."
    - "No prior time spec checks time.perf_counter_ns.__module__.__len__()."
    - "time.time.__qualname__ == 'time' — len 4 (same as __name__; C builtin)."
    - "time.sleep.__qualname__ == 'sleep' — len 5 (same as __name__; C builtin)."
    - "time.monotonic.__qualname__ == 'monotonic' — len 9 (same as __name__; C builtin)."
    - "time.perf_counter.__qualname__ == 'perf_counter' — len 12 (same as __name__; C builtin)."
    - "time.process_time.__qualname__ == 'process_time' — len 12 (same as __name__; C builtin)."
    - "time.gmtime.__qualname__ == 'gmtime' — len 6 (same as __name__; C builtin)."
    - "time.localtime.__qualname__ == 'localtime' — len 9 (same as __name__; C builtin)."
    - "time.gmtime.__name__ == 'gmtime' — len 6."
    - "time.localtime.__name__ == 'localtime' — len 9."
    - "time.mktime.__name__ == 'mktime' — len 6."
    - "time.strftime.__name__ == 'strftime' — len 8."
    - "time.strptime.__name__ == 'strptime' — len 8."
    - "time.ctime.__name__ == 'ctime' — len 5."
    - "time.clock_gettime.__name__ == 'clock_gettime' — len 13."
    - "time.monotonic_ns.__name__ == 'monotonic_ns' — len 12."
    - "time.perf_counter_ns.__name__ == 'perf_counter_ns' — len 15."
    - "All time module functions have __module__ == 'time' — len 4 (C extension)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for core timing and time-conversion functions
#
# The time module is a C extension; all builtin functions have flat
# __qualname__ values (no enclosing class, so __qualname__ == __name__).
# Prior spec time_extra17 checked __name__ lengths for six symbols; these
# invariants anchor the __qualname__ lengths for the seven most commonly
# used timing and conversion functions in the extra18 namespace.
#   time         -> 'time'         -> 4
#   sleep        -> 'sleep'        -> 5
#   monotonic    -> 'monotonic'    -> 9
#   perf_counter -> 'perf_counter' -> 12
#   process_time -> 'process_time' -> 12
#   gmtime       -> 'gmtime'       -> 6
#   localtime    -> 'localtime'    -> 9
# ---------------------------------------------------------------------------

invariant time_extra18.time.qualname_len:
  description: "time.time.__qualname__.__len__() == 4 — 'time' has 4 characters (C builtin, flat qualname)"
  category: function_identity
  kind: python_call_eq
  function: time.__qualname__.__len__
  args: []
  expected: 4

invariant time_extra18.sleep.qualname_len:
  description: "time.sleep.__qualname__.__len__() == 5 — 'sleep' has 5 characters (C builtin, flat qualname)"
  category: function_identity
  kind: python_call_eq
  function: sleep.__qualname__.__len__
  args: []
  expected: 5

invariant time_extra18.gmtime.qualname_len:
  description: "time.gmtime.__qualname__.__len__() == 6 — 'gmtime' has 6 characters (C builtin, flat qualname)"
  category: function_identity
  kind: python_call_eq
  function: gmtime.__qualname__.__len__
  args: []
  expected: 6

invariant time_extra18.localtime.qualname_len:
  description: "time.localtime.__qualname__.__len__() == 9 — 'localtime' has 9 characters (C builtin, flat qualname)"
  category: function_identity
  kind: python_call_eq
  function: localtime.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# __name__.__len__() for extended set of time functions
#
# These extend the coverage from time_extra17 (which checked six symbols)
# to additional time-module functions: gmtime, localtime, mktime, strftime,
# strptime, ctime, clock_gettime, monotonic_ns, perf_counter_ns. All are
# C builtins whose __name__ is the bare function name.
# ---------------------------------------------------------------------------

table time_extra18.function_qualname_lengths:
  description: "__qualname__.__len__() for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime — all C builtins with flat qualnames"
  kind: python_call_eq
  category: function_identity
  id_prefix: fql18

  columns: [id, function, args, expected]
  rows:
    - [time,         time.__qualname__.__len__,         [],  4]
    - [sleep,        sleep.__qualname__.__len__,        [],  5]
    - [monotonic,    monotonic.__qualname__.__len__,    [],  9]
    - [perf_counter, perf_counter.__qualname__.__len__, [], 12]
    - [process_time, process_time.__qualname__.__len__, [], 12]
    - [gmtime,       gmtime.__qualname__.__len__,       [],  6]
    - [localtime,    localtime.__qualname__.__len__,    [],  9]

table time_extra18.extended_function_name_lengths:
  description: "__name__.__len__() for gmtime/localtime/mktime/strftime/strptime/ctime/clock_gettime/monotonic_ns/perf_counter_ns"
  kind: python_call_eq
  category: function_identity
  id_prefix: efl18

  columns: [id, function, args, expected]
  rows:
    - [gmtime,          gmtime.__name__.__len__,          [],  6]
    - [localtime,       localtime.__name__.__len__,       [],  9]
    - [mktime,          mktime.__name__.__len__,          [],  6]
    - [strftime,        strftime.__name__.__len__,        [],  8]
    - [strptime,        strptime.__name__.__len__,        [],  8]
    - [ctime,           ctime.__name__.__len__,           [],  5]
    - [clock_gettime,   clock_gettime.__name__.__len__,   [], 13]
    - [monotonic_ns,    monotonic_ns.__name__.__len__,    [], 12]
    - [perf_counter_ns, perf_counter_ns.__name__.__len__, [], 15]

table time_extra18.extended_function_module_lengths:
  description: "__module__.__len__() for gmtime/localtime/mktime/strftime/clock_gettime/monotonic_ns/perf_counter_ns — all 4 ('time')"
  kind: python_call_eq
  category: function_identity
  id_prefix: efml18

  columns: [id, function, args, expected]
  rows:
    - [gmtime,          gmtime.__module__.__len__,          [], 4]
    - [localtime,       localtime.__module__.__len__,       [], 4]
    - [mktime,          mktime.__module__.__len__,          [], 4]
    - [strftime,        strftime.__module__.__len__,        [], 4]
    - [clock_gettime,   clock_gettime.__module__.__len__,   [], 4]
    - [monotonic_ns,    monotonic_ns.__module__.__len__,    [], 4]
    - [perf_counter_ns, perf_counter_ns.__module__.__len__, [], 4]
