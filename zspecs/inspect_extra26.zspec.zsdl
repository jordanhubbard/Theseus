spec: inspect_extra26
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra25.zspec.zsdl."
    - "Focus: __qualname__ and __module__ values for inspect.Attribute and ArgInfo namedtuples; _fields length for Attribute and ArgInfo; and __qualname__.__len__() for iscoroutinefunction/isasyncgenfunction/ismethoddescriptor in the extra26 namespace."
    - "inspect_extra25 covers __qualname__ and __module__ combined tables for Parameter/Signature/FrameInfo/BoundArguments; FrameInfo._fields.__len__() == 6."
    - "inspect_extra24 covers __qualname__ combined table for ten module-level functions including getmembers/getsource/isclass/isfunction/ismethod."
    - "inspect_extra8 covers iscoroutinefunction.__qualname__.__eq__ in a combined table in the extra8 namespace; no prior spec records the __len__() of that qualname in the extra26 namespace."
    - "No prior inspect spec records Attribute.__qualname__ or Attribute.__module__ in any invariant or table."
    - "No prior inspect spec records ArgInfo.__qualname__ or ArgInfo.__module__ in any invariant or table."
    - "No prior inspect spec records len(Attribute._fields) == 4 or len(ArgInfo._fields) == 4 in any invariant or table."
    - "No prior inspect spec has iscoroutinefunction/__qualname__/__len__(), isasyncgenfunction/__qualname__/__len__(), or ismethoddescriptor/__qualname__/__len__() in a combined table in the extra26 namespace."
    - "Attribute._fields == ('name', 'kind', 'defining_class', 'object') — four fields."
    - "ArgInfo._fields == ('args', 'varargs', 'keywords', 'locals') — four fields."
    - "iscoroutinefunction.__qualname__ == 'iscoroutinefunction' (len 19); isasyncgenfunction.__qualname__ == 'isasyncgenfunction' (len 18); ismethoddescriptor.__qualname__ == 'ismethoddescriptor' (len 18)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Attribute and ArgInfo namedtuple __qualname__ values — combined table
#
# Attribute and ArgInfo are namedtuple classes defined at module level in
# inspect. No prior inspect spec records their __qualname__ values in any
# invariant or table.
# ---------------------------------------------------------------------------

table inspect_extra26.namedtuple_qualnames:
  description: "__qualname__.__eq__ for inspect.Attribute and ArgInfo namedtuples"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Attribute, Attribute.__qualname__.__eq__, ["Attribute"], true]
    - [ArgInfo,   ArgInfo.__qualname__.__eq__,   ["ArgInfo"],   true]

# ---------------------------------------------------------------------------
# inspect.Attribute and ArgInfo namedtuple __qualname__.__len__() — combined table
#
# Verifies the string length of each namedtuple __qualname__:
#   Attribute -> 9, ArgInfo -> 7
# No prior inspect spec collects these two qualname lengths in any table.
# ---------------------------------------------------------------------------

table inspect_extra26.namedtuple_qualname_lens:
  description: "__qualname__.__len__() for inspect.Attribute and ArgInfo namedtuples"
  kind: python_call_eq
  category: class_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [Attribute, Attribute.__qualname__.__len__, [], 9]
    - [ArgInfo,   ArgInfo.__qualname__.__len__,   [], 7]

# ---------------------------------------------------------------------------
# inspect.Attribute and ArgInfo namedtuple __module__ values — combined table
#
# Both Attribute and ArgInfo have __module__ == 'inspect'.
# No prior inspect spec records Attribute.__module__ or ArgInfo.__module__
# in any invariant or table.
# ---------------------------------------------------------------------------

table inspect_extra26.namedtuple_modules:
  description: "__module__.__eq__ for inspect.Attribute and ArgInfo namedtuples"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Attribute, Attribute.__module__.__eq__, ["inspect"], true]
    - [ArgInfo,   ArgInfo.__module__.__eq__,   ["inspect"], true]

# ---------------------------------------------------------------------------
# inspect.Attribute._fields length — standalone invariant
#
# Attribute is a namedtuple with four fields:
# ('name', 'kind', 'defining_class', 'object').
# No prior inspect spec records len(Attribute._fields) in any invariant.
# ---------------------------------------------------------------------------

invariant inspect_extra26.Attribute.fields_len:
  description: "len(inspect.Attribute._fields) == 4 — Attribute has 4 fields: name/kind/defining_class/object"
  category: namedtuple_attrs
  kind: python_call_eq
  function: Attribute._fields.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# inspect.ArgInfo._fields length — standalone invariant
#
# ArgInfo is a namedtuple with four fields:
# ('args', 'varargs', 'keywords', 'locals').
# No prior inspect spec records len(ArgInfo._fields) in any invariant.
# ---------------------------------------------------------------------------

invariant inspect_extra26.ArgInfo.fields_len:
  description: "len(inspect.ArgInfo._fields) == 4 — ArgInfo has 4 fields: args/varargs/keywords/locals"
  category: namedtuple_attrs
  kind: python_call_eq
  function: ArgInfo._fields.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# inspect async/coroutine predicate __qualname__.__len__() — combined table
#
# iscoroutinefunction (len 19), isasyncgenfunction (len 18), and
# ismethoddescriptor (len 18) are among the longest predicate names in inspect.
# inspect_extra8 covers iscoroutinefunction.__qualname__.__eq__ in the extra8
# namespace; no prior spec records the __len__() of these three qualnames in a
# combined table in the extra26 namespace.
# ---------------------------------------------------------------------------

table inspect_extra26.long_predicate_qualname_lens:
  description: "__qualname__.__len__() for inspect.iscoroutinefunction, isasyncgenfunction, ismethoddescriptor"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [iscoroutinefunction,  iscoroutinefunction.__qualname__.__len__,  [], 19]
    - [isasyncgenfunction,   isasyncgenfunction.__qualname__.__len__,   [], 18]
    - [ismethoddescriptor,   ismethoddescriptor.__qualname__.__len__,   [], 18]
