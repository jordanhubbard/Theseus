spec: threading_extra234
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.Barrier class identity and method contracts."
    - "threading.Barrier.__name__ == 'Barrier' (len=7) — the class name. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' — Barrier is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Barrier.__qualname__ == 'Barrier' — top-level class with unqualified qualname. Verified with Python 3.14.3."
    - "threading.Barrier.__class__.__name__ == 'type' — Barrier is a Python class; its metaclass is the built-in type. Verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__name__ == 'wait' (len=4) — wait is a Python method on Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait' — wait qualname carries the class prefix. Verified with Python 3.14.3."
    - "threading.Barrier.reset.__name__ == 'reset' (len=5) — reset is a Python method on Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.reset.__qualname__ == 'Barrier.reset' — reset qualname carries the class prefix. Verified with Python 3.14.3."
    - "threading.Barrier.abort.__name__ == 'abort' (len=5) — abort is a Python method on Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.abort.__qualname__ == 'Barrier.abort' — abort qualname carries the class prefix. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Barrier class identity contracts
#
# threading.Barrier.__name__ == 'Barrier' (len=7)
# threading.Barrier.__module__ == 'threading'
# threading.Barrier.__qualname__ == 'Barrier'
# threading.Barrier.__class__.__name__ == 'type'
# threading.Barrier.__bases__[0].__name__ == 'object'
#
# Barrier is a Python class in Lib/threading.py for thread synchronization.
# New to extra234.
# ---------------------------------------------------------------------------

table threading_extra234.barrier_class_identity:
  description: "threading.Barrier class identity contracts: name, module, qualname, metaclass, base; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra234barrierclassid

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_name_eq,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is the class in Lib/threading.py for synchronizing a fixed number of threads; __name__ is 'Barrier' (len=7); new to extra234"]
    - [barrier_name_len_7,
       Barrier.__name__.__len__,
       [],
       7,
       "threading.Barrier.__name__.__len__() == 7 — 'Barrier' has exactly 7 characters (B-a-r-r-i-e-r); str.__len__() returns 7; new to extra234"]
    - [barrier_module_eq,
       Barrier.__module__.__eq__,
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; __module__ is 'threading'; new to extra234"]
    - [barrier_qualname_eq,
       Barrier.__qualname__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__qualname__.__eq__('Barrier') == True — Barrier is a top-level class with unqualified qualname 'Barrier'; str.__eq__('Barrier') returns True; new to extra234"]
    - [barrier_class_is_type,
       Barrier.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Barrier.__class__.__name__.__eq__('type') == True — Barrier is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; new to extra234"]

# ---------------------------------------------------------------------------
# Table 2: threading.Barrier.wait method contracts
#
# threading.Barrier.__bases__[0].__name__ == 'object'
# threading.Barrier.wait.__name__ == 'wait' (len=4)
# threading.Barrier.wait.__qualname__ == 'Barrier.wait'
# threading.Barrier.reset.__name__ == 'reset' (len=5)
# threading.Barrier.reset.__qualname__ == 'Barrier.reset'
#
# wait and reset are Python methods on the Barrier class. New to extra234.
# ---------------------------------------------------------------------------

table threading_extra234.barrier_wait_reset_methods:
  description: "threading.Barrier base is object; wait and reset method name and qualname contracts; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra234barrierwaitid

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_base_is_object,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; new to extra234"]
    - [wait_name_eq,
       Barrier.wait.__name__.__eq__,
       ["wait"],
       true,
       "threading.Barrier.wait.__name__.__eq__('wait') == True — wait is a Python method in Lib/threading.py that blocks until all parties have called wait; __name__ is 'wait' (len=4); new to extra234"]
    - [wait_name_len_4,
       Barrier.wait.__name__.__len__,
       [],
       4,
       "threading.Barrier.wait.__name__.__len__() == 4 — 'wait' has exactly 4 characters (w-a-i-t); str.__len__() returns 4; new to extra234"]
    - [wait_qualname_eq,
       Barrier.wait.__qualname__.__eq__,
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — wait is a method of the Barrier class; its __qualname__ carries the class prefix 'Barrier.wait'; new to extra234"]
    - [reset_name_eq,
       Barrier.reset.__name__.__eq__,
       ["reset"],
       true,
       "threading.Barrier.reset.__name__.__eq__('reset') == True — reset is a Python method in Lib/threading.py that resets the barrier to the empty state; __name__ is 'reset' (len=5); new to extra234"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier.reset and abort method contracts
#
# threading.Barrier.reset.__qualname__ == 'Barrier.reset'
# threading.Barrier.reset.__name__.__len__() == 5
# threading.Barrier.abort.__name__ == 'abort' (len=5)
# threading.Barrier.abort.__qualname__ == 'Barrier.abort'
# threading.Barrier.abort.__name__.__len__() == 5
#
# reset and abort are Python methods on the Barrier class. New to extra234.
# ---------------------------------------------------------------------------

table threading_extra234.barrier_reset_abort_methods:
  description: "threading.Barrier.reset qualname and abort method name and qualname contracts; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra234barrierabortid

  columns: [id, function, args, expected, description]
  rows:
    - [reset_qualname_eq,
       Barrier.reset.__qualname__.__eq__,
       ["Barrier.reset"],
       true,
       "threading.Barrier.reset.__qualname__.__eq__('Barrier.reset') == True — reset is a method of the Barrier class; its __qualname__ carries the class prefix 'Barrier.reset'; new to extra234"]
    - [reset_name_len_5,
       Barrier.reset.__name__.__len__,
       [],
       5,
       "threading.Barrier.reset.__name__.__len__() == 5 — 'reset' has exactly 5 characters (r-e-s-e-t); str.__len__() returns 5; new to extra234"]
    - [abort_name_eq,
       Barrier.abort.__name__.__eq__,
       ["abort"],
       true,
       "threading.Barrier.abort.__name__.__eq__('abort') == True — abort is a Python method in Lib/threading.py that puts the barrier into a broken state; __name__ is 'abort' (len=5); new to extra234"]
    - [abort_name_len_5,
       Barrier.abort.__name__.__len__,
       [],
       5,
       "threading.Barrier.abort.__name__.__len__() == 5 — 'abort' has exactly 5 characters (a-b-o-r-t); str.__len__() returns 5; new to extra234"]
    - [abort_qualname_eq,
       Barrier.abort.__qualname__.__eq__,
       ["Barrier.abort"],
       true,
       "threading.Barrier.abort.__qualname__.__eq__('Barrier.abort') == True — abort is a method of the Barrier class; its __qualname__ carries the class prefix 'Barrier.abort'; new to extra234"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra234
# ---------------------------------------------------------------------------

invariant threading_extra234.barrier_name_eq:
  description: "threading.Barrier.__name__ == 'Barrier' (len=7); new to extra234"
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra234.barrier_name_len_7:
  description: "threading.Barrier.__name__.__len__() == 7 — 'Barrier' has 7 characters; new to extra234"
  kind: python_call_eq
  function: Barrier.__name__.__len__
  args: []
  expected: 7

invariant threading_extra234.barrier_module_eq:
  description: "threading.Barrier.__module__ == 'threading'; new to extra234"
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra234.barrier_qualname_eq:
  description: "threading.Barrier.__qualname__ == 'Barrier'; new to extra234"
  kind: python_call_eq
  function: Barrier.__qualname__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra234.barrier_class_is_type:
  description: "threading.Barrier.__class__.__name__ == 'type'; new to extra234"
  kind: python_call_eq
  function: Barrier.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra234.barrier_base_is_object:
  description: "threading.Barrier.__bases__[0].__name__ == 'object'; new to extra234"
  kind: python_call_eq
  function: "Barrier.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra234.wait_name_eq:
  description: "threading.Barrier.wait.__name__ == 'wait' (len=4); new to extra234"
  kind: python_call_eq
  function: Barrier.wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant threading_extra234.wait_qualname_eq:
  description: "threading.Barrier.wait.__qualname__ == 'Barrier.wait'; new to extra234"
  kind: python_call_eq
  function: Barrier.wait.__qualname__.__eq__
  args: ["Barrier.wait"]
  expected: true

invariant threading_extra234.reset_name_eq:
  description: "threading.Barrier.reset.__name__ == 'reset' (len=5); new to extra234"
  kind: python_call_eq
  function: Barrier.reset.__name__.__eq__
  args: ["reset"]
  expected: true

invariant threading_extra234.reset_qualname_eq:
  description: "threading.Barrier.reset.__qualname__ == 'Barrier.reset'; new to extra234"
  kind: python_call_eq
  function: Barrier.reset.__qualname__.__eq__
  args: ["Barrier.reset"]
  expected: true

invariant threading_extra234.abort_name_eq:
  description: "threading.Barrier.abort.__name__ == 'abort' (len=5); new to extra234"
  kind: python_call_eq
  function: Barrier.abort.__name__.__eq__
  args: ["abort"]
  expected: true

invariant threading_extra234.abort_qualname_eq:
  description: "threading.Barrier.abort.__qualname__ == 'Barrier.abort'; new to extra234"
  kind: python_call_eq
  function: Barrier.abort.__qualname__.__eq__
  args: ["Barrier.abort"]
  expected: true
