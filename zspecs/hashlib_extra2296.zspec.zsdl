spec: hashlib_extra2296
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "hashlib.blake2b and hashlib.blake2s are C extension types from _blake2; __module__ == '_blake2'."
    - "hashlib.md5, sha1, sha256, sha512, sha3_256, sha224, sha384, sha3_512 are OpenSSL wrappers from _hashlib; __module__ == '_hashlib'."
    - "blake2b.__qualname__ == 'blake2b' and blake2s.__qualname__ == 'blake2s' (match __name__, top-level in C ext)."
    - "OpenSSL wrapper qualnames use the 'openssl_' prefix: e.g. openssl_sha256."
    - "hashlib module itself is pure Python: hashlib.__name__ == 'hashlib', hashlib.__package__ == ''."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2296.blake2b_module:
  description: "hashlib.blake2b __module__, __qualname__, __name__ — C extension from _blake2"
  kind: python_call_eq
  category: module_identity
  id_prefix: hl2296

  columns: [id, function, args, expected]
  rows:
    - ["hl2296001", "hashlib.blake2b.__module__", [], "_blake2"]
    - ["hl2296002", "hashlib.blake2b.__qualname__", [], "blake2b"]
    - ["hl2296003", "hashlib.blake2b.__name__", [], "blake2b"]

table hashlib_extra2296.blake2s_module:
  description: "hashlib.blake2s __module__, __qualname__, __name__ — C extension from _blake2"
  kind: python_call_eq
  category: module_identity
  id_prefix: hl2296

  columns: [id, function, args, expected]
  rows:
    - ["hl2296004", "hashlib.blake2s.__module__", [], "_blake2"]
    - ["hl2296005", "hashlib.blake2s.__qualname__", [], "blake2s"]
    - ["hl2296006", "hashlib.blake2s.__name__", [], "blake2s"]

table hashlib_extra2296.openssl_wrappers_module:
  description: "OpenSSL hash wrappers: __module__ == '_hashlib', qualnames use 'openssl_' prefix"
  kind: python_call_eq
  category: module_identity
  id_prefix: hl2296

  columns: [id, function, args, expected]
  rows:
    - ["hl2296007", "hashlib.md5.__module__", [], "_hashlib"]
    - ["hl2296008", "hashlib.md5.__qualname__", [], "openssl_md5"]
    - ["hl2296009", "hashlib.sha1.__module__", [], "_hashlib"]
    - ["hl2296010", "hashlib.sha1.__qualname__", [], "openssl_sha1"]
    - ["hl2296011", "hashlib.sha256.__module__", [], "_hashlib"]
    - ["hl2296012", "hashlib.sha256.__qualname__", [], "openssl_sha256"]
    - ["hl2296013", "hashlib.sha512.__module__", [], "_hashlib"]
    - ["hl2296014", "hashlib.sha512.__qualname__", [], "openssl_sha512"]
    - ["hl2296015", "hashlib.sha224.__module__", [], "_hashlib"]
    - ["hl2296016", "hashlib.sha224.__qualname__", [], "openssl_sha224"]
    - ["hl2296017", "hashlib.sha384.__module__", [], "_hashlib"]
    - ["hl2296018", "hashlib.sha384.__qualname__", [], "openssl_sha384"]
    - ["hl2296019", "hashlib.sha3_256.__module__", [], "_hashlib"]
    - ["hl2296020", "hashlib.sha3_256.__qualname__", [], "openssl_sha3_256"]
    - ["hl2296021", "hashlib.sha3_512.__module__", [], "_hashlib"]
    - ["hl2296022", "hashlib.sha3_512.__qualname__", [], "openssl_sha3_512"]

table hashlib_extra2296.module_level:
  description: "hashlib module-level identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: hl2296

  columns: [id, function, args, expected]
  rows:
    - ["hl2296023", "hashlib.__name__", [], "hashlib"]
    - ["hl2296024", "hashlib.__package__", [], ""]
