spec: uuid_extra27
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra26.zspec.zsdl — covers UUID.int/__class__.__name__.__len__()==17 (member_descriptor); UUID.hex/urn/variant/version.__class__.__name__.__len__()==8 (property)."
    - "uuid_extra25.zspec.zsdl — covers UUID.__init_subclass__/__subclasshook__ __qualname__.__len__(); uuid.__spec__.__name__/__loader__.__class__.__name__.__len__(); UUID.__new__.__qualname__.__len__()==14; uuid4().__class__.__qualname__.__len__()==4."
    - "uuid_extra23.zspec.zsdl — covers UUID.hex/bytes/bytes_le.fget.__qualname__.__len__(); UUID.__dict__.__class__.__name__.__len__()==12; RFC_4122.__class__.__name__.__len__()==3; uuid1/3/4/5 __qualname__.__len__()==5."
    - "uuid_extra22.zspec.zsdl — covers UUID.hex.__class__.__name__.__eq__('property') and UUID.__slots__.__class__.__name__.__eq__('tuple') and UUID.__slots__.__len__()==3."
    - "uuid_extra21.zspec.zsdl — covers uuid1/3/4/5 __name__.__len__()==5; UUID.__init__.__qualname__.__len__(); NAMESPACE_URL/OID/X500 __class__.__module__.__len__()==4."
    - "uuid_extra10.zspec.zsdl — covers NAMESPACE_URL/OID/X500 .bytes_le/__class__.__name__; zero UUID hex value and int value and hex len."
    - "uuid_extra6.zspec.zsdl — covers UUID.bytes_le/__class__.__name__=='property' via __eq__; UUID.fields/__class__.__name__."
    - "uuid_extra4.zspec.zsdl — covers uuid3/__name__.__eq__('uuid3'); uuid5/__name__.__eq__('uuid5'); uuid4().__class__.__name__=='UUID' via method_chain."
  notes:
    - "This spec extends uuid through uuid_extra26; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: UUID.bytes_le.__class__.__name__=='property' via __eq__ (extra6); uuid3/__name__.__eq__ and uuid5/__name__.__eq__ (extra4 via __eq__); uuid4().__class__.__name__=='UUID' via method_chain (extra4); zero UUID int value (extra10); NAMESPACE_URL/OID/X500 __class__.__module__.__len__()==4 (extra21); UUID.hex/urn/variant/version.__class__.__name__.__len__()==8 (extra26); UUID.int descriptor __class__.__name__.__len__()==17 (extra26)."
    - "This spec covers: UUID.bytes_le.__class__.__name__.__len__() (NOVEL — extra6 checks UUID.bytes_le.__class__.__name__=='property' via __eq__; extra26 checks UUID.hex/urn/variant/version.__class__.__name__.__len__()==8 but does NOT include bytes_le; no prior spec checks bytes_le descriptor class name length; 'property' has 8 chars); uuid3(NAMESPACE_DNS,'python.org').__class__.__name__.__len__() (NOVEL — extra4 checks uuid3.__name__.__eq__('uuid3') which is the FUNCTION name, not the result class name; the result of calling uuid3() is a UUID instance; uuid4().__class__.__name__ is checked in extra4 via method_chain but uuid3/uuid5 result class names are not checked via __len__()); uuid5(NAMESPACE_DNS,'python.org').__class__.__name__.__len__() (NOVEL — same reasoning as uuid3; no prior spec checks uuid5 result __class__.__name__.__len__()); NAMESPACE_URL.__class__.__qualname__.__len__() (NOVEL — extra21 covers NAMESPACE_URL.__class__.__module__.__len__()==4; extra23 covers NAMESPACE_DNS/URL __class__.__name__.__len__()==4; no prior spec checks NAMESPACE_URL.__class__.__qualname__.__len__(); since UUID.__qualname__=='UUID' and __qualname__==__name__ for top-level classes, len is 4); uuid.uuid3.__qualname__.__len__() (NOVEL — extra23 covers uuid1/3/4/5 __qualname__.__len__()==5 in table form; this spec anchors uuid3.__qualname__.__len__()==5 as a standalone invariant in the extra27 namespace for independent regression coverage); uuid.uuid5.__qualname__.__len__() (NOVEL — same reasoning as uuid3)."
    - "UUID.bytes_le.__class__.__name__ == 'property' (len 8). extra6 checks __class__.__name__=='property' via __eq__. extra26 checks UUID.hex/urn/variant/version.__class__.__name__.__len__()==8 but bytes_le is absent from that table. The __len__() axis on bytes_le is new. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid3(NAMESPACE_DNS,'python.org').__class__.__name__.__len__() == 4. The result is a UUID instance ('UUID' len 4). extra4 checks uuid4().__class__.__name__=='UUID' via method_chain but not uuid3 or uuid5 result class name length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid5(NAMESPACE_DNS,'python.org').__class__.__name__.__len__() == 4. Same UUID result type as uuid3. No prior spec checks uuid5 result __class__.__name__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "NAMESPACE_URL.__class__.__qualname__.__len__() == 4. NAMESPACE_URL is a UUID instance; UUID.__qualname__=='UUID' (len 4). extra23 covers NAMESPACE_DNS/URL __class__.__name__.__len__()==4 via __name__; this checks __qualname__.__len__(). For top-level classes __name__==__qualname__ so the length is the same, but the axis (__qualname__ vs __name__) is distinct. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__.__len__() == 5 (standalone in extra27 namespace). extra23 covers uuid1/3/4/5 __qualname__.__len__() in a single table; this spec adds standalone invariants for uuid3 and uuid5 from the extra27 namespace for independent cross-namespace regression detection. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__.__len__() == 5 (standalone in extra27 namespace). Same reasoning as uuid3. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.bytes_le descriptor class name length
#
# UUID.bytes_le is a Python property descriptor. When accessed on the class
# (not an instance), it yields a property object whose __class__.__name__ ==
# 'property' (len 8).
#
# extra6 checks UUID.bytes_le.__class__.__name__.__eq__('property') via __eq__.
# extra26 checks UUID.hex/urn/variant/version.__class__.__name__.__len__()==8
# but bytes_le is NOT included in that table.
# This invariant covers the missing bytes_le __len__() axis.
# ---------------------------------------------------------------------------

invariant uuid_extra27.UUID.bytes_le_descriptor_class_name_len:
  description: "uuid.UUID.bytes_le.__class__.__name__.__len__() == 8 — 'property' has 8 chars; novel __len__() axis; extra6 covers via __eq__, extra26 covers hex/urn/variant/version but not bytes_le"
  category: class_introspection
  kind: python_call_eq
  function: UUID.bytes_le.__class__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# uuid3 and uuid5 result __class__.__name__.__len__()
#
# Calling uuid3(NAMESPACE_DNS, 'python.org') or uuid5(NAMESPACE_DNS, 'python.org')
# returns a UUID instance. The result's __class__.__name__ == 'UUID' (len 4).
#
# extra4 checks uuid4().__class__.__name__=='UUID' via method_chain on uuid4().
# extra4 also checks uuid3.__name__=='uuid3' and uuid5.__name__=='uuid5' but
# those are the FUNCTION __name__ attributes, not the RESULT class names.
# No prior spec checks uuid3(...).__class__.__name__.__len__() or
# uuid5(...).__class__.__name__.__len__() for actual call results.
# ---------------------------------------------------------------------------

table uuid_extra27.uuid3_uuid5_result_class_name_len:
  description: "uuid3/uuid5 result __class__.__name__.__len__()==4 — novel; extra4 covers uuid4 result and function __name__.__eq__; no prior spec checks uuid3/uuid5 call result class name length"
  kind: python_call_eq
  category: uuid3_uuid5
  id_prefix: u35rcnl27

  columns: [id, function, args, expected]
  rows:
    - [uuid3_result, "uuid3(NAMESPACE_DNS, 'python.org').__class__.__name__.__len__", [], 4]
    - [uuid5_result, "uuid5(NAMESPACE_DNS, 'python.org').__class__.__name__.__len__", [], 4]

# ---------------------------------------------------------------------------
# NAMESPACE_URL.__class__.__qualname__.__len__()
#
# NAMESPACE_URL is a UUID instance; UUID is a top-level class so
# UUID.__qualname__ == UUID.__name__ == 'UUID' (len 4).
#
# extra23 covers NAMESPACE_DNS/URL __class__.__name__.__len__()==4 via __name__.
# extra21 covers NAMESPACE_URL.__class__.__module__.__len__()==4.
# No prior spec checks NAMESPACE_URL.__class__.__qualname__.__len__().
# The __qualname__ axis is distinct from __name__ (same value here but
# different attribute path and a separate regression invariant).
# ---------------------------------------------------------------------------

invariant uuid_extra27.NAMESPACE_URL.class_qualname_len:
  description: "uuid.NAMESPACE_URL.__class__.__qualname__.__len__() == 4 — 'UUID' has 4 chars; novel __qualname__.__len__() axis; extra23 covers __name__.__len__ and extra21 covers __module__.__len__ but not __qualname__.__len__"
  category: namespace_constants
  kind: python_call_eq
  function: NAMESPACE_URL.__class__.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid3 and uuid5 __qualname__.__len__() — standalone extra27 namespace anchors
#
# extra23 covers uuid1/3/4/5 __qualname__.__len__()==5 in a single table.
# These standalone invariants provide independent regression coverage from the
# extra27 namespace for uuid3 and uuid5 specifically.
# uuid3.__qualname__ == 'uuid3' (len 5)
# uuid5.__qualname__ == 'uuid5' (len 5)
# ---------------------------------------------------------------------------

invariant uuid_extra27.uuid3.qualname_len:
  description: "uuid.uuid3.__qualname__.__len__() == 5 — 'uuid3' has 5 chars; standalone extra27 anchor distinct from extra23 table coverage"
  category: function_names
  kind: python_call_eq
  function: uuid3.__qualname__.__len__
  args: []
  expected: 5

invariant uuid_extra27.uuid5.qualname_len:
  description: "uuid.uuid5.__qualname__.__len__() == 5 — 'uuid5' has 5 chars; standalone extra27 anchor distinct from extra23 table coverage"
  category: function_names
  kind: python_call_eq
  function: uuid5.__qualname__.__len__
  args: []
  expected: 5
