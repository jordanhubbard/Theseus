spec: typing_extra16
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 586 — Literal Types"
    - "PEP 591 — Adding a final qualifier to typing"
    - "PEP 593 — Flexible function and variable annotations"
    - "PEP 647 — User-defined type guards"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra15.zspec.zsdl."
    - "typing_extra15 covers: TypeVar.__bases__ len/[0]; Protocol __name__/__module__/__qualname__; NamedTuple/__name__; TypedDict/__name__; get_args/__qualname__; get_origin/__qualname__; cast/__qualname__."
    - "typing_extra14 covers: Any/__name__; Union/__name__; Callable/__name__; Optional/__name__; Callable/_name."
    - "typing_extra13 covers: overload/__module__/__qualname__; runtime_checkable/__module__; ParamSpec/__module__."
    - "typing_extra12 covers: overload/__name__."
    - "typing_extra9 covers: runtime_checkable/__name__."
    - "typing_extra4 covers: Literal/__class__/__name__; Annotated/__class__/__name__."
    - "typing_extra3 covers: ParamSpec/__name__/__module__/__qualname__; TypeGuard/__class__/__name__."
    - "typing_extra2 covers: Final/__class__/__name__; Literal/__class__/__name__; overload/__name__."
    - "NOT yet covered: typing.Literal.__name__ (direct __name__, not __class__.__name__)."
    - "NOT yet covered: typing.Final.__name__ (direct __name__)."
    - "NOT yet covered: typing.Annotated.__name__ (direct __name__)."
    - "NOT yet covered: typing.TypeGuard.__name__ (direct __name__)."
    - "NOT yet covered: typing.Literal.__module__ (standalone __eq__ invariant)."
    - "NOT yet covered: typing.Final.__module__ (standalone __eq__ invariant)."
    - "NOT yet covered: typing.Annotated.__module__ (standalone __eq__ invariant)."
    - "NOT yet covered: typing.TypeGuard.__module__ (standalone __eq__ invariant)."
    - "NOT yet covered: typing.Literal.__qualname__ (standalone __eq__ invariant)."
    - "NOT yet covered: typing.Final.__qualname__ (standalone __eq__ invariant)."
    - "NOT yet covered: typing.Annotated.__qualname__ (standalone __eq__ invariant)."
    - "NOT yet covered: typing.TypeGuard.__qualname__ (standalone __eq__ invariant)."
    - "NOT yet covered: typing.runtime_checkable.__qualname__ (standalone __eq__ invariant)."
    - "typing.Literal.__name__ == 'Literal' — direct __name__, not __class__.__name__."
    - "typing.Final.__name__ == 'Final' — _SpecialForm exposes __name__ directly."
    - "typing.Annotated.__name__ == 'Annotated' — _TypedCacheSpecialForm exposes __name__ directly."
    - "typing.TypeGuard.__name__ == 'TypeGuard' — _SpecialForm exposes __name__ directly."
    - "typing.Literal.__module__ == 'typing'; typing.Final.__module__ == 'typing'; typing.Annotated.__module__ == 'typing'; typing.TypeGuard.__module__ == 'typing'."
    - "typing.Literal.__qualname__ == 'Literal'; typing.Final.__qualname__ == 'Final'; typing.Annotated.__qualname__ == 'Annotated'; typing.TypeGuard.__qualname__ == 'TypeGuard'."
    - "typing.runtime_checkable.__qualname__ == 'runtime_checkable' — top-level function, qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Literal, Final, Annotated, TypeGuard — direct __name__ invariants
#
# Prior specs check __class__.__name__ for these (e.g., '_SpecialForm' or
# '_TypedCacheSpecialForm'). No prior spec accesses __name__ directly on
# Literal, Final, Annotated, or TypeGuard as a standalone invariant.
# Both _SpecialForm and _TypedCacheSpecialForm expose __name__ == the form's
# own display name (e.g., 'Literal').
# ---------------------------------------------------------------------------

invariant typing_extra16.Literal.name:
  description: "typing.Literal.__name__ == 'Literal' — direct __name__, distinct from __class__.__name__"
  category: special_form_names
  kind: python_call_eq
  function: Literal.__name__.__eq__
  args: ["Literal"]
  expected: true

invariant typing_extra16.Final.name:
  description: "typing.Final.__name__ == 'Final' — _SpecialForm exposes __name__ directly"
  category: special_form_names
  kind: python_call_eq
  function: Final.__name__.__eq__
  args: ["Final"]
  expected: true

invariant typing_extra16.Annotated.name:
  description: "typing.Annotated.__name__ == 'Annotated' — _TypedCacheSpecialForm exposes __name__ directly"
  category: special_form_names
  kind: python_call_eq
  function: Annotated.__name__.__eq__
  args: ["Annotated"]
  expected: true

invariant typing_extra16.TypeGuard.name:
  description: "typing.TypeGuard.__name__ == 'TypeGuard' — _SpecialForm exposes __name__ directly"
  category: special_form_names
  kind: python_call_eq
  function: TypeGuard.__name__.__eq__
  args: ["TypeGuard"]
  expected: true

# ---------------------------------------------------------------------------
# Literal, Final, Annotated, TypeGuard — __module__ standalone invariants
#
# No prior spec checks __module__ for these four special forms as standalone
# invariants. All live in the 'typing' module.
# ---------------------------------------------------------------------------

table typing_extra16.special_form_modules:
  description: "typing special forms have __module__ == 'typing'"
  kind: python_call_eq
  category: module_names
  id_prefix: sfmod

  columns: [id, function, args, expected]
  rows:
    - [Literal,    Literal.__module__.__eq__,    ["typing"], true]
    - [Final,      Final.__module__.__eq__,      ["typing"], true]
    - [Annotated,  Annotated.__module__.__eq__,  ["typing"], true]
    - [TypeGuard,  TypeGuard.__module__.__eq__,  ["typing"], true]

# ---------------------------------------------------------------------------
# Literal, Final, Annotated, TypeGuard — __qualname__ standalone invariants
#
# No prior spec checks __qualname__ for these four as standalone invariants.
# For _SpecialForm instances the __qualname__ equals the form name.
# ---------------------------------------------------------------------------

table typing_extra16.special_form_qualnames:
  description: "typing special forms have __qualname__ == their display name"
  kind: python_call_eq
  category: qualnames
  id_prefix: sfqualname

  columns: [id, function, args, expected]
  rows:
    - [Literal,    Literal.__qualname__.__eq__,    ["Literal"],    true]
    - [Final,      Final.__qualname__.__eq__,      ["Final"],      true]
    - [Annotated,  Annotated.__qualname__.__eq__,  ["Annotated"],  true]
    - [TypeGuard,  TypeGuard.__qualname__.__eq__,  ["TypeGuard"],  true]

# ---------------------------------------------------------------------------
# runtime_checkable __qualname__ — standalone invariant
#
# typing_extra9 covers runtime_checkable.__name__ == 'runtime_checkable'.
# typing_extra13 covers runtime_checkable.__module__ == 'typing'.
# No prior spec checks runtime_checkable.__qualname__ as a standalone
# invariant. For a top-level function __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant typing_extra16.runtime_checkable.qualname:
  description: "typing.runtime_checkable.__qualname__ == 'runtime_checkable' — top-level function qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: runtime_checkable.__qualname__.__eq__
  args: ["runtime_checkable"]
  expected: true
