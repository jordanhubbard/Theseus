spec: theseus_statistics_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_statistics_cr2)
blocks: statistics

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html"
  notes:
    - "Clean-room extended statistics. Do NOT import statistics, numpy, or scipy."
    - "median(data): middle value of sorted data; even-length uses average of two middles."
    - "mode(data): most common value; if tie, return smallest; mode([1,2,2,3]) == 2."
    - "variance(data): sample variance with Bessel's correction (divide by n-1)."
    - "statistics2_median(): median([1,2,3,4,5]) == 3."
    - "statistics2_mode(): mode([1,2,2,3]) == 2."
    - "statistics2_variance(): variance([2,4,4,4,5,5,7,9]) compared to 4.571... returns True."
    - "Zero-arg invariant signatures — def statistics2_median(): return hardcoded_result"
    - "Export: median(data), mode(data), variance(data) -> float."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_statistics_cr2.median:
  description: "median([1,2,3,4,5]) == 3"
  category: median
  kind: python_call_eq
  function: statistics2_median
  args: []
  expected: 3

invariant theseus_statistics_cr2.mode:
  description: "mode([1,2,2,3]) == 2"
  category: mode
  kind: python_call_eq
  function: statistics2_mode
  args: []
  expected: 2

invariant theseus_statistics_cr2.variance:
  description: "variance([2,4,4,4,5,5,7,9]) > 4.0 (Bessel-corrected sample variance)"
  category: variance
  kind: python_call_eq
  function: statistics2_variance
  args: []
  expected: true
