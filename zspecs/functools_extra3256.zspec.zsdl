spec: ft3256
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (ft3256): __rpow__, __rlshift__, __rrshift__ dict-presence checks for functools types."
    - "Theme: __rpow__/__rlshift__/__rrshift__ reflected power/shift dict-presence."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — callable/iterator/inspection/synchronization types have no reflected arithmetic."
    - "None of the four functools types define __rpow__, __rlshift__, or __rrshift__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3256.rpow:
  description: "functools types __rpow__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3256
  columns: [id, function, args, expected]
  rows:
    - ["ft3256001", operator.contains, [functools.partial.__dict__,                              "__rpow__"], false]
    - ["ft3256002", operator.contains, [functools.partialmethod.__dict__,                        "__rpow__"], false]
    - ["ft3256003", operator.contains, [functools.cached_property.__dict__,                      "__rpow__"], false]
    - ["ft3256004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,        "__rpow__"], false]

