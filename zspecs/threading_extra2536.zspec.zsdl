spec: threading_extra2536
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: __format__, __bytes__, and __fspath__ dict-presence checks for threading module classes."
    - "Theme: custom formatting, bytes conversion, and filesystem path protocol dict-presence — checking whether classes define __format__, __bytes__, or __fspath__ in their class __dict__."
    - "threading.Thread, Lock, Condition, Semaphore, BoundedSemaphore, Event, Barrier, Timer, local — none define __format__, __bytes__, or __fspath__."
    - "threading.Thread is a pure-Python class representing an OS-level thread of execution; its state is managed via name, daemon, ident, and start/join/run methods. It has no custom string formatting, bytes representation, or filesystem path semantics. Verified with Python 3.14."
    - "threading.Lock is the C-level _thread.lock type; it exposes acquire/release and a context-manager protocol only. No __format__, __bytes__, or __fspath__ in its class __dict__. Verified with Python 3.14."
    - "threading.Condition wraps a lock and provides wait/notify/wait_for semantics for thread coordination; it is a synchronization primitive with no string formatting, bytes conversion, or path role. Verified with Python 3.14."
    - "threading.Semaphore maintains an internal integer counter accessed via acquire() and release(); despite its counter it carries no __format__, __bytes__, or __fspath__ in its class __dict__. Verified with Python 3.14."
    - "threading.BoundedSemaphore is a Semaphore subclass that raises ValueError if the count exceeds the initial value; like Semaphore it defines no formatting, bytes, or path protocol in its own __dict__. Verified with Python 3.14."
    - "threading.Event is a simple flag-based synchronization primitive wrapping an internal Condition; it exposes set/clear/is_set/wait but defines no custom formatting, bytes conversion, or filesystem path protocol. Verified with Python 3.14."
    - "threading.Barrier synchronizes a fixed number of threads at a rendezvous point; it tracks phases and a broken state but exposes no __format__, __bytes__, or __fspath__ protocol. Verified with Python 3.14."
    - "threading.Timer is a Thread subclass that fires a function after a delay; it inherits no format/bytes/fspath protocol from Thread and adds none of its own. Verified with Python 3.14."
    - "threading.local provides per-thread attribute namespaces via attribute access; it defines no custom formatting, bytes conversion, or filesystem path protocol. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread and threading.Timer — format/bytes/fspath absence
#
# Theme: __format__, __bytes__, __fspath__ absent from Thread and Timer.__dict__.
# Thread manages OS threads via start/join/run; Timer is a Thread subclass for
# delayed execution. Neither is a data representation type and neither defines
# any custom formatting, bytes conversion, or filesystem path protocol.
# ---------------------------------------------------------------------------

table threading_extra2536.thread_timer_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from threading.Thread and threading.Timer __dict__; wave 2536"
  kind: python_call_eq
  category: format_bytes_fspath
  id_prefix: th2536

  columns: [id, function, args, expected]
  rows:
    - ["th2536-001", "Thread.__dict__.__contains__", ["__format__"], false]
    - ["th2536-002", "Thread.__dict__.__contains__", ["__bytes__"], false]
    - ["th2536-003", "Thread.__dict__.__contains__", ["__fspath__"], false]
    - ["th2536-004", "Timer.__dict__.__contains__", ["__format__"], false]
    - ["th2536-005", "Timer.__dict__.__contains__", ["__bytes__"], false]
    - ["th2536-006", "Timer.__dict__.__contains__", ["__fspath__"], false]

