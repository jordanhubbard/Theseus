    - ["th2536-009", "Lock.__dict__.__contains__", ["__fspath__"], false]
    - ["th2536-010", "Condition.__dict__.__contains__", ["__format__"], false]
    - ["th2536-011", "Condition.__dict__.__contains__", ["__bytes__"], false]
    - ["th2536-012", "Condition.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore and threading.BoundedSemaphore
#
# Theme: __format__, __bytes__, __fspath__ absent from Semaphore and
# BoundedSemaphore.__dict__.
# Semaphore maintains an internal integer count managed exclusively through
# acquire() and release(); BoundedSemaphore adds an upper-bound check. Both
# are concurrency control primitives that define no custom formatting, bytes
# conversion, or filesystem path protocol in their class __dict__.
# ---------------------------------------------------------------------------

table threading_extra2536.semaphore_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from threading.Semaphore and BoundedSemaphore __dict__; wave 2536"
