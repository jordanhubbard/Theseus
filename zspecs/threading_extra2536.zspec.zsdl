    - ["th2536-013", "Semaphore.__dict__.__contains__", ["__format__"], false]
    - ["th2536-014", "Semaphore.__dict__.__contains__", ["__bytes__"], false]
    - ["th2536-015", "Semaphore.__dict__.__contains__", ["__fspath__"], false]
    - ["th2536-016", "BoundedSemaphore.__dict__.__contains__", ["__format__"], false]
    - ["th2536-017", "BoundedSemaphore.__dict__.__contains__", ["__bytes__"], false]
