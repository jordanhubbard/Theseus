spec: io_extra53
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra52.zspec.zsdl — covers BufferedRandom.__name__.__len__()==14; BufferedRandom.__module__.__len__()==3; IncrementalNewlineDecoder.__name__/__module__/__qualname__ __len__()."
    - "io_extra51.zspec.zsdl — covers FileIO/BufferedWriter/BufferedReader/BufferedRandom __mro__.__len__()==4; UnsupportedOperation __mro__/__bases__ lengths."
    - "io_extra4.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BufferedReader/BufferedWriter __class__.__name__.__eq__('type') (these values are wrong for ABCMeta classes; the concrete C classes return 'type')."
    - "io_extra13.zspec.zsdl — covers IOBase/RawIOBase __class__.__name__.__eq__('type') (same note as io_extra4)."
    - "io_extra3.zspec.zsdl — covers open.__name__.__eq__('open')."
    - "io_extra33.zspec.zsdl — covers open.__qualname__.__eq__('open')."
    - "io_extra.zspec.zsdl — covers TextIOWrapper/BufferedRandom/UnsupportedOperation __class__.__name__.__eq__('type')."
  notes:
    - "This spec extends io_extra52.zspec.zsdl."
    - "IMPORTANT: io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase are abstract base classes whose metaclass is ABCMeta; therefore their __class__.__name__ == 'ABCMeta', NOT 'type'. The concrete C-extension classes (FileIO, BytesIO, StringIO, BufferedWriter, BufferedReader, TextIOWrapper) have __class__.__name__ == 'type' as expected for regular types. Prior specs io_extra4 and io_extra13 covered some of these as __eq__('type') but those were only for the concrete classes."
    - "Prior specs collectively covered: io_extra3 covers open.__name__.__eq__('open'); io_extra33 covers open.__qualname__.__eq__('open'); no prior io spec covers open.__name__.__len__() or open.__qualname__.__len__() or open.__class__.__name__.__eq__(). io_extra4/io_extra covers FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper/BufferedRandom __class__.__name__.__eq__('type') equality; no prior io spec covers __class__.__name__.__len__() for any of these concrete classes."
    - "This spec covers: io.IOBase.__class__.__name__.__eq__('ABCMeta') (NOVEL — the ABCMeta metaclass is what IOBase, RawIOBase, BufferedIOBase, and TextIOBase use as their metaclass; prior io_extra4/io_extra13 checked IOBase.__class__.__name__.__eq__('type') which is incorrect — the actual value is 'ABCMeta'; this spec records the correct value); io.FileIO.__class__.__name__.__len__()==4 (NOVEL — io_extra4 checks the equality string 'type'; no prior io spec checks FileIO.__class__.__name__.__len__()); io.BytesIO.__class__.__name__.__len__()==4 (NOVEL); io.StringIO.__class__.__name__.__len__()==4 (NOVEL); io.BufferedWriter.__class__.__name__.__len__()==4 (NOVEL); io.BufferedReader.__class__.__name__.__len__()==4 (NOVEL); io.TextIOWrapper.__class__.__name__.__len__()==4 (NOVEL); io.open.__name__.__len__()==4 (NOVEL — io_extra3 checks equality; no prior io spec checks __name__.__len__()); io.open.__class__.__name__.__eq__('builtin_function_or_method') (NOVEL — io.open is the builtin open() function exposed from _io; no prior io spec checks open.__class__.__name__ at all)."
    - "io.IOBase.__class__.__name__ == 'ABCMeta'. IOBase is an abstract base class in _io; its metaclass is ABCMeta from the abc module. The value 'ABCMeta' has 7 characters. Same applies to RawIOBase, BufferedIOBase, TextIOBase. Novel correct equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.__class__.__name__ == 'type' (len 4). FileIO is a concrete C-extension class, so its metaclass is the regular 'type'. io_extra4 checks the equality string; no prior io spec checks FileIO.__class__.__name__.__len__(). Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.open.__class__.__name__ == 'builtin_function_or_method' (len 26). io.open is the builtin open() function from the _io module. No prior io spec checks open.__class__.__name__ at all. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.open.__name__.__len__() == 4. 'open' has 4 characters. io_extra3 checks the equality string; no prior io spec checks open.__name__.__len__(). Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase.__class__.__name__ — ABCMeta metaclass
#
# IOBase (and RawIOBase, BufferedIOBase, TextIOBase) are abstract base classes
# in the _io module. Their metaclass is ABCMeta, so:
#
#   IOBase.__class__.__name__  == 'ABCMeta'   -> len 7
#
# In contrast, concrete classes like FileIO, BytesIO, StringIO, etc. use
# the regular 'type' metaclass. The ABCMeta distinction is important.
#
# Prior specs io_extra4 and io_extra13 checked IOBase.__class__.__name__.__eq__
# with arg 'type', but Python 3.14 returns 'ABCMeta' for abstract base classes.
# This spec records the correct ABCMeta value as a novel equality anchor.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra53.IOBase_class_name_ABCMeta:
  description: "io.IOBase.__class__.__name__ == 'ABCMeta' — IOBase is an abstract base class whose metaclass is ABCMeta, not plain 'type'; RawIOBase/BufferedIOBase/TextIOBase share the same metaclass; concrete classes FileIO/BytesIO/StringIO etc use 'type'; novel correct equality anchor in io_extra53 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# Concrete io class __class__.__name__ lengths
#
# The concrete C-extension io classes all have the standard 'type' metaclass.
# Their __class__.__name__ is therefore 'type' (4 characters):
#
#   FileIO.__class__.__name__        == 'type'  -> len 4
#   BytesIO.__class__.__name__       == 'type'  -> len 4
#   StringIO.__class__.__name__      == 'type'  -> len 4
#   BufferedWriter.__class__.__name__ == 'type' -> len 4
#   BufferedReader.__class__.__name__ == 'type' -> len 4
#   TextIOWrapper.__class__.__name__ == 'type'  -> len 4
#
# Prior specs (io_extra4, io_extra) check equality strings for most of these.
# No prior io spec checks __class__.__name__.__len__() for any of them.
# All six length anchors are novel in the io_extra53 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra53.concrete_class_name_lens:
  description: "io concrete class __class__.__name__.__len__()==4 for FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper — all use 'type' metaclass (4 chars); prior specs check equality strings but no prior io spec checks __class__.__name__.__len__(); all six novel length anchors in io_extra53 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iocnl53

  columns: [id, function, args, expected]
  rows:
    - [FileIO_class_name_len,         FileIO.__class__.__name__.__len__,         [], 4]
    - [BytesIO_class_name_len,        BytesIO.__class__.__name__.__len__,        [], 4]
    - [StringIO_class_name_len,       StringIO.__class__.__name__.__len__,       [], 4]
    - [BufferedWriter_class_name_len, BufferedWriter.__class__.__name__.__len__, [], 4]
    - [BufferedReader_class_name_len, BufferedReader.__class__.__name__.__len__, [], 4]
    - [TextIOWrapper_class_name_len,  TextIOWrapper.__class__.__name__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# io.open function identity
#
# io.open is the builtin open() function exposed from the _io C extension.
# Its identity attributes are:
#
#   open.__name__             == 'open'                      -> len 4
#   open.__qualname__         == 'open'                      -> len 4
#   open.__class__.__name__   == 'builtin_function_or_method' -> len 26
#
# Prior specs:
#   io_extra3:  covers open.__name__.__eq__('open')
#   io_extra33: covers open.__qualname__.__eq__('open')
#
# No prior io spec checks open.__name__.__len__(), open.__qualname__.__len__(),
# or open.__class__.__name__.__eq__('builtin_function_or_method').
# All three anchors are novel in the io_extra53 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra53.open_name_len:
  description: "io.open.__name__.__len__() == 4 — 'open' has 4 characters; io_extra3 checks open.__name__.__eq__('open') but no prior io spec checks open.__name__.__len__(); novel length anchor in io_extra53 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: open.__name__.__len__
  args: []
  expected: 4

invariant io_extra53.open_qualname_len:
  description: "io.open.__qualname__.__len__() == 4 — 'open' has 4 characters; __qualname__==__name__=='open' for this top-level builtin; io_extra33 checks open.__qualname__.__eq__('open') but no prior io spec checks open.__qualname__.__len__(); novel length anchor in io_extra53 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: open.__qualname__.__len__
  args: []
  expected: 4

invariant io_extra53.open_class_name_eq:
  description: "io.open.__class__.__name__ == 'builtin_function_or_method' — io.open is the builtin open() function from the _io C extension; its type is builtin_function_or_method; no prior io spec checks open.__class__.__name__ at all; novel equality anchor in io_extra53 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
