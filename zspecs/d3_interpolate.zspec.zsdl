spec: d3_interpolate
version: ">=3.0.0"
backend: node(d3-interpolate)

docs: https://d3js.org/d3-interpolate

provenance:
  derived_from:
    - "d3-interpolate docs — https://d3js.org/d3-interpolate"
    - "Test vectors verified with d3-interpolate via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "d3-interpolate source"
  notes:
    - "Smooth interpolation between values — numbers, strings, colors, dates, arrays, objects."
    - "Install: npm install d3-interpolate"
    - "v3 ESM only; named exports interpolate / interpolateNumber / interpolateRgb / interpolateHsl / etc."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factories; never throw on valid inputs."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant d3_interpolate.number_midpoint:
  description: "interpolateNumber(0,100)(0.5) is 50"
  category: number
  kind: node_chain_eq
  entry: named
  function: interpolateNumber
  entry_args: [0, 100]
  chain:
    - {call: [0.5]}
  expected: 50

invariant d3_interpolate.number_quarter:
  description: "interpolateNumber(0,100)(0.25) is 25"
  category: number
  kind: node_chain_eq
  entry: named
  function: interpolateNumber
  entry_args: [0, 100]
  chain:
    - {call: [0.25]}
  expected: 25

invariant d3_interpolate.number_endpoint_zero:
  description: "interpolateNumber(0,100)(0) is 0"
  category: number
  kind: node_chain_eq
  entry: named
  function: interpolateNumber
  entry_args: [0, 100]
  chain:
    - {call: [0]}
  expected: 0

invariant d3_interpolate.number_endpoint_one:
  description: "interpolateNumber(0,100)(1) is 100"
  category: number
  kind: node_chain_eq
  entry: named
  function: interpolateNumber
  entry_args: [0, 100]
  chain:
    - {call: [1]}
  expected: 100

invariant d3_interpolate.number_negative_range:
  description: "interpolateNumber(-10, 10)(0.5) is 0"
  category: number
  kind: node_chain_eq
  entry: named
  function: interpolateNumber
  entry_args: [-10, 10]
  chain:
    - {call: [0.5]}
  expected: 0

invariant d3_interpolate.rgb_grayscale_midpoint:
  description: "interpolateRgb('#000','#fff')(0.5) is 'rgb(128, 128, 128)'"
  category: rgb
  kind: node_chain_eq
  entry: named
  function: interpolateRgb
  entry_args: ["#000", "#fff"]
  chain:
    - {call: [0.5]}
  expected: "rgb(128, 128, 128)"

invariant d3_interpolate.rgb_endpoint_black:
  description: "interpolateRgb('#000','#fff')(0) is black"
  category: rgb
  kind: node_chain_eq
  entry: named
  function: interpolateRgb
  entry_args: ["#000", "#fff"]
  chain:
    - {call: [0]}
  expected: "rgb(0, 0, 0)"

invariant d3_interpolate.rgb_endpoint_white:
  description: "interpolateRgb('#000','#fff')(1) is white"
  category: rgb
  kind: node_chain_eq
  entry: named
  function: interpolateRgb
  entry_args: ["#000", "#fff"]
  chain:
    - {call: [1]}
  expected: "rgb(255, 255, 255)"

invariant d3_interpolate.interpolate_export_present:
  description: "interpolate (generic) is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "interpolate.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T16:52:37Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
