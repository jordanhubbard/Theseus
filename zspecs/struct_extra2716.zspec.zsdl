spec: struct_extra2716
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 628 theme: __neg__, __pos__, and __abs__ dict-presence checks (unary minus, unary plus, absolute value)."
    - "struct.Struct is a compiled struct object class; it does not implement unary arithmetic protocols."
    - "struct.error is an exception subclass (inherits from Exception); it does not define __neg__, __pos__, or __abs__ in its own __dict__."
    - "None of the struct public classes define __neg__, __pos__, or __abs__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — absent from all struct classes
# ---------------------------------------------------------------------------

table struct_extra2716.neg_protocol:
  description: "__neg__ is absent from all struct class __dict__s — none implement unary minus"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2716

  columns: [id, function, args, expected]
  rows:
    - ["st2716001", "struct.Struct.__dict__.__contains__", ["__neg__"], false]
    - ["st2716002", "struct.error.__dict__.__contains__",  ["__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — absent from all struct classes
# ---------------------------------------------------------------------------

table struct_extra2716.pos_protocol:
  description: "__pos__ is absent from all struct class __dict__s — none implement unary plus"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2716

  columns: [id, function, args, expected]
  rows:
    - ["st2716003", "struct.Struct.__dict__.__contains__", ["__pos__"], false]
    - ["st2716004", "struct.error.__dict__.__contains__",  ["__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — absent from all struct classes
# ---------------------------------------------------------------------------

table struct_extra2716.abs_protocol:
  description: "__abs__ is absent from all struct class __dict__s — none implement absolute value"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2716

  columns: [id, function, args, expected]
  rows:
    - ["st2716005", "struct.Struct.__dict__.__contains__", ["__abs__"], false]
    - ["st2716006", "struct.error.__dict__.__contains__",  ["__abs__"], false]

# ---------------------------------------------------------------------------
# Combined view — Struct and error vs. all three protocols
# ---------------------------------------------------------------------------

table struct_extra2716.struct_unary_combined:
  description: "struct.Struct and struct.error define none of __neg__, __pos__, __abs__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2716

  columns: [id, function, args, expected]
  rows:
    - ["st2716007", "struct.Struct.__dict__.__contains__", ["__neg__"], false]
    - ["st2716008", "struct.Struct.__dict__.__contains__", ["__pos__"], false]
    - ["st2716009", "struct.Struct.__dict__.__contains__", ["__abs__"], false]
    - ["st2716010", "struct.error.__dict__.__contains__",  ["__neg__"], false]
    - ["st2716011", "struct.error.__dict__.__contains__",  ["__pos__"], false]
    - ["st2716012", "struct.error.__dict__.__contains__",  ["__abs__"], false]
