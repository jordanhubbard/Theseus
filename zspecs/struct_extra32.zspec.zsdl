spec: struct_extra32
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra31.zspec.zsdl — covers iter_unpack result __class__.__name__.__len__()==15; Struct.__new__/__sizeof__ __qualname__.__len__(); Struct.__class__.__name__.__len__()==4."
    - "struct_extra30.zspec.zsdl — covers calcsize('10s'/'?'/'e'); Struct('4B').size; Struct('4B').format.__len__()==2."
    - "struct_extra27.zspec.zsdl — covers Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack."
    - "struct_extra23.zspec.zsdl — covers __module__.__len__() for pack_into/unpack_from/iter_unpack; Struct.__new__/__sizeof__.__qualname__.__eq__."
    - "struct_extra21.zspec.zsdl — covers Struct.__init__/__repr__ __qualname__.__eq__ and __qualname__.__len__(); Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__()."
    - "struct_extra16.zspec.zsdl — covers MODULE-LEVEL pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __name__.__len__()."
    - "struct_extra9.zspec.zsdl — covers Struct METHOD pack/unpack/pack_into/unpack_from/iter_unpack __name__.__eq__ (string equality)."
  notes:
    - "This spec extends struct through struct_extra31; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: module-level function __name__.__len__() for pack/unpack/calcsize/pack_into/unpack_from/iter_unpack (extra16); Struct METHOD __name__.__eq__('pack') etc. via __eq__ (extra9); Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (extra21/extra27)."
    - "This spec covers: Struct METHOD __name__.__len__() table (NOVEL — extra9 checks Struct method __name__ via __eq__; extra16 checks MODULE-LEVEL function __name__.__len__(); no prior spec calls __name__.__len__() on the Struct bound-method descriptors pack/unpack/pack_into/unpack_from/iter_unpack; these are method_descriptor objects on the Struct type; their __name__ lengths are 4/6/9/11/11 respectively); Struct('>I').pack(255) behavioral invariant (NOVEL — extra30 covers Struct('4B').size and format; no prior spec checks the big-endian unsigned-int pack of 255 producing b'\\x00\\x00\\x00\\xff')."
    - "struct.Struct.pack.__name__ == 'pack' (len 4). extra9 checks Struct.pack.__name__.__eq__('pack') via __eq__; extra16 checks the MODULE-LEVEL struct.pack.__name__.__len__()==4 but that is a different object (the module-level function, not the Struct method descriptor). No prior spec calls __name__.__len__() on struct.Struct.pack (the method_descriptor). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__name__ == 'unpack' (len 6). Same gap: extra9 __eq__, extra16 module-level function. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__name__ == 'pack_into' (len 9). Same gap. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__name__ == 'unpack_from' (len 11). Same gap. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack' (len 11). Same gap. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct('>I').pack(255) == b'\\x00\\x00\\x00\\xff'. Big-endian format '>I' encodes 255 as a 4-byte big-endian unsigned integer. 255 == 0xff, so the encoding is 0x00 0x00 0x00 0xff. No prior struct spec checks this specific pack output. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Struct METHOD __name__.__len__() — distinct from module-level function lens
#
# struct.Struct.pack, .unpack, .pack_into, .unpack_from, .iter_unpack are
# method_descriptor objects on the Struct type. They have a __name__ attribute.
#
# struct_extra9 checks Struct.pack.__name__.__eq__('pack') etc. via __eq__.
# struct_extra16 checks MODULE-LEVEL struct.pack.__name__.__len__()==4 etc.
#   but that is the module-level function object, not the Struct method descriptor.
# struct_extra21/extra27 check __qualname__.__len__() for these, not __name__.__len__().
# No prior spec calls __name__.__len__() on the Struct type method descriptors.
#
# Method descriptor __name__ values and lengths:
#   Struct.pack          -> 'pack'          -> 4
#   Struct.unpack        -> 'unpack'        -> 6
#   Struct.pack_into     -> 'pack_into'     -> 9
#   Struct.unpack_from   -> 'unpack_from'   -> 11
#   Struct.iter_unpack   -> 'iter_unpack'   -> 11
# ---------------------------------------------------------------------------

table struct_extra32.Struct_method_name_lens:
  description: "struct.Struct METHOD __name__.__len__() — novel __len__() axis on Struct method descriptors; extra9 covers __eq__; extra16 covers MODULE-LEVEL function __name__.__len__(); extra21/27 cover __qualname__.__len__()"
  kind: python_call_eq
  category: method_identity
  id_prefix: smnl32

  columns: [id, function, args, expected]
  rows:
    - [pack_name_len,        Struct.pack.__name__.__len__,        [], 4]
    - [unpack_name_len,      Struct.unpack.__name__.__len__,      [], 6]
    - [pack_into_name_len,   Struct.pack_into.__name__.__len__,   [], 9]
    - [unpack_from_name_len, Struct.unpack_from.__name__.__len__, [], 11]
    - [iter_unpack_name_len, Struct.iter_unpack.__name__.__len__, [], 11]

# ---------------------------------------------------------------------------
# Struct('>I').pack(255) behavioral invariant
#
# struct.Struct('>I') creates a Struct for big-endian unsigned 4-byte integer.
# Packing 255 (0xff) gives b'\x00\x00\x00\xff'.
#
# No prior struct spec checks this specific combination of big-endian format
# and value 255. struct_extra30 covers Struct('4B').size and format.__len__();
# no prior spec verifies a pack() output for a Struct instance via method chain.
# ---------------------------------------------------------------------------

invariant struct_extra32.Struct_bigendian_pack_255:
  description: "struct.Struct('>I').pack(255) == b'\\x00\\x00\\x00\\xff' — big-endian unsigned int; 255==0xff in 4-byte big-endian; novel: no prior spec checks Struct instance pack output for this value"
  category: behavioral
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: pack
  method_args: [255]
  expected: !hex 000000ff
