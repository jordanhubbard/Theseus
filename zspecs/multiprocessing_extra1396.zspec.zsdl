spec: multiprocessing_extra1396
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing: Process-based parallelism"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool class documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method presence and type checks."
    - "multiprocessing.Process and multiprocessing.pool.Pool do NOT have __class_getitem__ in their own __dict__."
    - "multiprocessing.queues.Queue and multiprocessing.queues.SimpleQueue have __class_getitem__ in their __dict__ — type is 'method'."
    - "multiprocessing.queues.JoinableQueue does NOT have __class_getitem__ in its own __dict__ (inherited from Queue)."
    - "multiprocessing.pool.AsyncResult has __class_getitem__ in its own __dict__ — type is 'method'."
    - "multiprocessing.synchronize.Lock, Event, Semaphore, Barrier do NOT have __class_getitem__ in their __dict__."
    - "All multiprocessing classes have __init_subclass__ as builtin_function_or_method, inherited from object."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1396.queues_class_getitem_checks:
  description: "multiprocessing.queues.Queue and SimpleQueue have __class_getitem__ in __dict__ as 'method'; JoinableQueue does not"
  kind: python_call_eq
  category: class_getitem_check
  id_prefix: mp1396qc
  columns: [id, function, args, expected]
  rows:
    - [mp1396qc001, multiprocessing.queues.Queue.__dict__.__contains__,                      ["__class_getitem__"], true]
    - [mp1396qc002, multiprocessing.queues.Queue.__class_getitem__.__class__.__name__.__eq__, ["method"],            true]
    - [mp1396qc003, multiprocessing.queues.SimpleQueue.__dict__.__contains__,                 ["__class_getitem__"], true]
    - [mp1396qc004, multiprocessing.queues.SimpleQueue.__class_getitem__.__class__.__name__.__eq__, ["method"],      true]
    - [mp1396qc005, multiprocessing.queues.JoinableQueue.__dict__.__contains__,               ["__class_getitem__"], false]
    - [mp1396qc006, multiprocessing.pool.AsyncResult.__dict__.__contains__,                   ["__class_getitem__"], true]
    - [mp1396qc007, multiprocessing.pool.AsyncResult.__class_getitem__.__class__.__name__.__eq__, ["method"],        true]

table multiprocessing_extra1396.process_pool_class_getitem_absent:
  description: "multiprocessing.Process and pool.Pool do NOT have __class_getitem__ in their own __dict__; synchronize primitives also absent"
  kind: python_call_eq
  category: class_getitem_dict_absent
  id_prefix: mp1396pa
  columns: [id, function, args, expected]
  rows:
    - [mp1396pa001, multiprocessing.Process.__dict__.__contains__,              ["__class_getitem__"], false]
    - [mp1396pa002, multiprocessing.pool.Pool.__dict__.__contains__,            ["__class_getitem__"], false]
    - [mp1396pa003, multiprocessing.synchronize.Lock.__dict__.__contains__,     ["__class_getitem__"], false]
    - [mp1396pa004, multiprocessing.synchronize.Event.__dict__.__contains__,    ["__class_getitem__"], false]
    - [mp1396pa005, multiprocessing.synchronize.Semaphore.__dict__.__contains__, ["__class_getitem__"], false]
    - [mp1396pa006, multiprocessing.synchronize.Barrier.__dict__.__contains__,  ["__class_getitem__"], false]

table multiprocessing_extra1396.init_subclass_type_checks:
  description: "All multiprocessing classes have __init_subclass__ as builtin_function_or_method, not in own __dict__"
  kind: python_call_eq
  category: init_subclass_check
  id_prefix: mp1396is
  columns: [id, function, args, expected]
  rows:
    - [mp1396is001, multiprocessing.Process.__init_subclass__.__class__.__name__.__eq__,              ["builtin_function_or_method"], true]
    - [mp1396is002, multiprocessing.pool.Pool.__init_subclass__.__class__.__name__.__eq__,            ["builtin_function_or_method"], true]
    - [mp1396is003, multiprocessing.queues.Queue.__init_subclass__.__class__.__name__.__eq__,         ["builtin_function_or_method"], true]
    - [mp1396is004, multiprocessing.queues.SimpleQueue.__init_subclass__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [mp1396is005, multiprocessing.synchronize.Lock.__init_subclass__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [mp1396is006, multiprocessing.synchronize.Barrier.__init_subclass__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [mp1396is007, multiprocessing.Process.__dict__.__contains__,                                     ["__init_subclass__"],           false]
    - [mp1396is008, multiprocessing.pool.Pool.__dict__.__contains__,                                   ["__init_subclass__"],           false]
