spec: decimal_extra1126
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module __name__, __spec__.name, __doc__.__class__.__name__, Decimal.__doc__.__class__.__name__, Context.__doc__.__class__.__name__, and rounding constant string value and class checks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.__name__, decimal.__spec__.name, decimal.__doc__.__class__.__name__, decimal.Decimal.__doc__.__class__.__name__, decimal.Context.__doc__.__class__.__name__, ROUND_HALF_DOWN/ROUND_HALF_UP/ROUND_CEILING/ROUND_FLOOR string values; decimal.__name__ and __spec__.name not covered in _extra1096 or _extra1111; __doc__ class names of module/Decimal/Context not previously covered"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1126.module_identity:
  description: "decimal module __name__, __spec__.name, and __doc__.__class__.__name__ checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc1126mi
  columns: [id, function, args, expected]
  rows:
    - [dc1126mi001, decimal.__name__.__eq__,                        ["decimal"],  true]
    - [dc1126mi002, decimal.__spec__.name.__eq__,                   ["decimal"],  true]
    - [dc1126mi003, decimal.__doc__.__class__.__name__.__eq__,      ["str"],      true]
    - [dc1126mi004, decimal.__name__.__eq__,                        ["_decimal"], false]
    - [dc1126mi005, decimal.__spec__.name.__eq__,                   ["_decimal"], false]
    - [dc1126mi006, decimal.__doc__.__class__.__name__.__eq__,      ["bytes"],    false]
    - [dc1126mi007, decimal.__name__.__class__.__name__.__eq__,     ["str"],      true]

table decimal_extra1126.decimal_and_context_doc_class_names:
  description: "decimal.Decimal and decimal.Context __doc__.__class__.__name__ checks"
  kind: python_call_eq
  category: decimal_and_context_doc_class_names
  id_prefix: dc1126dc
  columns: [id, function, args, expected]
  rows:
    - [dc1126dc001, decimal.Decimal.__doc__.__class__.__name__.__eq__,  ["str"],      true]
    - [dc1126dc002, decimal.Context.__doc__.__class__.__name__.__eq__,  ["str"],      true]
    - [dc1126dc003, decimal.Decimal.__doc__.__class__.__name__.__eq__,  ["bytes"],    false]
    - [dc1126dc004, decimal.Context.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [dc1126dc005, decimal.DecimalException.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [dc1126dc006, decimal.InvalidOperation.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [dc1126dc007, decimal.DivisionByZero.__doc__.__class__.__name__.__eq__,  ["str"], true]

table decimal_extra1126.rounding_constant_string_values:
  description: "decimal rounding constant exact string value checks for ROUND_HALF_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_05UP"
  kind: python_call_eq
  category: rounding_constant_string_values
  id_prefix: dc1126rv
  columns: [id, function, args, expected]
  rows:
    - [dc1126rv001, decimal.ROUND_HALF_DOWN.__eq__,  ["ROUND_HALF_DOWN"],  true]
    - [dc1126rv002, decimal.ROUND_CEILING.__eq__,    ["ROUND_CEILING"],    true]
    - [dc1126rv003, decimal.ROUND_FLOOR.__eq__,      ["ROUND_FLOOR"],      true]
    - [dc1126rv004, decimal.ROUND_05UP.__eq__,       ["ROUND_05UP"],       true]
    - [dc1126rv005, decimal.ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"],  true]
    - [dc1126rv006, decimal.ROUND_UP.__eq__,         ["ROUND_UP"],         true]
    - [dc1126rv007, decimal.ROUND_HALF_DOWN.__eq__,  ["ROUND_HALF_UP"],    false]
    - [dc1126rv008, decimal.ROUND_CEILING.__eq__,    ["ROUND_FLOOR"],      false]
    - [dc1126rv009, decimal.ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"], true]
