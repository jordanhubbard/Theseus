spec: functools_extra256
version: ">=3.8"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.lru_cache, functools.cache, and functools.cached_property function/class identity behavioral contracts."
    - "functools.lru_cache.__name__ == 'lru_cache' — lru_cache is a pure-Python decorator function; __name__ is 'lru_cache'. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' — lru_cache is defined in the functools module; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache' — cache is a pure-Python decorator function (added in 3.9); __name__ is 'cache'. Verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools' — cache is defined in the functools module; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.cache.__class__.__name__ == 'function' — cache is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "functools.cached_property.__name__ == 'cached_property' — cached_property is a class; its __name__ is 'cached_property'. Verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools' — cached_property is defined in the functools module; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object; its first base class __name__ is 'object'. Verified with Python 3.14.3."
    - "functools.cached_property.__class__.__name__ == 'type' — cached_property is a class (metaclass is type); __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache function identity
#
# functools.lru_cache.__name__ == 'lru_cache'
# functools.lru_cache.__module__ == 'functools'
# functools.lru_cache.__class__.__name__ == 'function'
#
# lru_cache is a pure-Python memoizing decorator defined in functools.
# New to extra256.
# ---------------------------------------------------------------------------

table functools_extra256.lru_cache_identity:
  description: "functools.lru_cache __name__, __module__, __class__.__name__ identity contracts; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: lrucache256

  columns: [id, function, args, expected, description]
  rows:
    - [lrucache_name_eq,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache is a pure-Python memoizing decorator; __name__ is 'lru_cache'; new to extra256"]
    - [lrucache_module_eq,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in the functools module; __module__ is 'functools'; new to extra256"]
    - [lrucache_class_name_eq,
       lru_cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a plain Python function; __class__.__name__ is 'function'; new to extra256"]
    - [lrucache_name_len_9,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters; new to extra256"]
    - [lrucache_module_len_9,
       lru_cache.__module__.__len__,
       [],
       9,
       "functools.lru_cache.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra256"]

# ---------------------------------------------------------------------------
# Table 2: functools.cache function identity
#
# functools.cache.__name__ == 'cache'
# functools.cache.__module__ == 'functools'
# functools.cache.__class__.__name__ == 'function'
#
# cache is a pure-Python unbounded memoizing decorator added in Python 3.9.
# New to extra256.
# ---------------------------------------------------------------------------

table functools_extra256.cache_identity:
  description: "functools.cache __name__, __module__, __class__.__name__ identity contracts; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: cache256

  columns: [id, function, args, expected, description]
  rows:
    - [cache_name_eq,
       cache.__name__.__eq__,
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — cache is a pure-Python unbounded memoizing decorator (added 3.9); __name__ is 'cache'; new to extra256"]
    - [cache_module_eq,
       cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is defined in the functools module; __module__ is 'functools'; new to extra256"]
    - [cache_class_name_eq,
       cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.cache.__class__.__name__.__eq__('function') == True — cache is a plain Python function; __class__.__name__ is 'function'; new to extra256"]
    - [cache_name_len_5,
       cache.__name__.__len__,
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — 'cache' has 5 characters; new to extra256"]
    - [cache_module_len_9,
       cache.__module__.__len__,
       [],
       9,
       "functools.cache.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra256"]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property class identity
#
# functools.cached_property.__name__ == 'cached_property'
# functools.cached_property.__module__ == 'functools'
# functools.cached_property.__bases__[0].__name__ == 'object'
# functools.cached_property.__class__.__name__ == 'type'
#
# cached_property is a class (not a function) that caches instance attribute
# results. Its base class is object and its metaclass is type.
# New to extra256.
# ---------------------------------------------------------------------------

table functools_extra256.cached_property_identity:
  description: "functools.cached_property __name__, __module__, __bases__[0].__name__, __class__.__name__ identity contracts; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: cachedprop256

  columns: [id, function, args, expected, description]
  rows:
    - [cachedprop_name_eq,
       cached_property.__name__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is a class; __name__ is 'cached_property'; new to extra256"]
    - [cachedprop_module_eq,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in the functools module; __module__ is 'functools'; new to extra256"]
    - ["cachedprop_base0_name_eq",
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property inherits directly from object; first base __name__ is 'object'; new to extra256"]
    - [cachedprop_class_name_eq,
       cached_property.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a class whose metaclass is type; __class__.__name__ is 'type'; new to extra256"]
    - [cachedprop_name_len_15,
       cached_property.__name__.__len__,
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has 15 characters; new to extra256"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra256
# ---------------------------------------------------------------------------

invariant functools_extra256.lru_cache.name_eq:
  description: "functools.lru_cache.__name__ == 'lru_cache' — pure-Python memoizing decorator; new to extra256"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra256.lru_cache.module_eq:
  description: "functools.lru_cache.__module__ == 'functools' — defined in the functools module; new to extra256"
  category: identity
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra256.lru_cache.class_is_function:
  description: "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a plain Python function; new to extra256"
  category: identity
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra256.lru_cache.name_len_9:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters; new to extra256"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9

invariant functools_extra256.cache.name_eq:
  description: "functools.cache.__name__ == 'cache' — pure-Python unbounded memoizing decorator; new to extra256"
  category: identity
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra256.cache.module_eq:
  description: "functools.cache.__module__ == 'functools' — defined in the functools module; new to extra256"
  category: identity
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra256.cache.class_is_function:
  description: "functools.cache.__class__.__name__ == 'function' — cache is a plain Python function; new to extra256"
  category: identity
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra256.cache.name_len_5:
  description: "functools.cache.__name__.__len__() == 5 — 'cache' has 5 characters; new to extra256"
  category: identity
  kind: python_call_eq
  function: cache.__name__.__len__
  args: []
  expected: 5

invariant functools_extra256.cached_property.name_eq:
  description: "functools.cached_property.__name__ == 'cached_property' — class for caching instance attribute results; new to extra256"
  category: identity
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra256.cached_property.module_eq:
  description: "functools.cached_property.__module__ == 'functools' — defined in the functools module; new to extra256"
  category: identity
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra256.cached_property.class_is_type:
  description: "functools.cached_property.__class__.__name__ == 'type' — cached_property is a class whose metaclass is type; new to extra256"
  category: identity
  kind: python_call_eq
  function: cached_property.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra256.cached_property.name_len_15:
  description: "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has 15 characters; new to extra256"
  category: identity
  kind: python_call_eq
  function: cached_property.__name__.__len__
  args: []
  expected: 15
