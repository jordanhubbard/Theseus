spec: functools_extra2746
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 630 theme: __round__, __divmod__, and __pow__ dict-presence checks (numeric arithmetic protocol — used by round(), divmod(), and the ** operator)."
    - "functools.partial is a callable wrapper; it does not implement numeric arithmetic protocols."
    - "functools.partialmethod is a descriptor; it similarly defines none of __round__, __divmod__, or __pow__."
    - "functools.cached_property is a data descriptor (defines __get__, __set__, __delete__) but not __round__, __divmod__, or __pow__."
    - "functools.singledispatchmethod is a descriptor wrapper; it does not define __round__, __divmod__, or __pow__."
    - "None of the functools public classes define __round__, __divmod__, or __pow__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2746.round_protocol:
  description: "__round__ is absent from all functools class __dict__s — none implement the round() numeric protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2746

  columns: [id, function, args, expected]
  rows:
    - ["ft2746001", "functools.partial.__dict__.__contains__",              ["__round__"], false]
    - ["ft2746002", "functools.partialmethod.__dict__.__contains__",        ["__round__"], false]
    - ["ft2746003", "functools.cached_property.__dict__.__contains__",      ["__round__"], false]
    - ["ft2746004", "functools.singledispatchmethod.__dict__.__contains__",  ["__round__"], false]

# ---------------------------------------------------------------------------
