# ---------------------------------------------------------------------------

table functools_extra2746.divmod_protocol:
  description: "__divmod__ is absent from all functools class __dict__s — none implement the divmod() numeric protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2746

  columns: [id, function, args, expected]
  rows:
    - ["ft2746005", "functools.partial.__dict__.__contains__",              ["__divmod__"], false]
    - ["ft2746006", "functools.partialmethod.__dict__.__contains__",        ["__divmod__"], false]
    - ["ft2746007", "functools.cached_property.__dict__.__contains__",      ["__divmod__"], false]
    - ["ft2746008", "functools.singledispatchmethod.__dict__.__contains__",  ["__divmod__"], false]

# ---------------------------------------------------------------------------
# __pow__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2746.pow_protocol:
  description: "__pow__ is absent from all functools class __dict__s — none implement the ** exponentiation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2746

  columns: [id, function, args, expected]
  rows:
    - ["ft2746009",  "functools.partial.__dict__.__contains__",              ["__pow__"], false]
    - ["ft2746010",  "functools.partialmethod.__dict__.__contains__",        ["__pow__"], false]
    - ["ft2746011",  "functools.cached_property.__dict__.__contains__",      ["__pow__"], false]
    - ["ft2746012",  "functools.singledispatchmethod.__dict__.__contains__",  ["__pow__"], false]

# ---------------------------------------------------------------------------
# Combined view — partial and partialmethod vs. all three arithmetic protocols
# ---------------------------------------------------------------------------

table functools_extra2746.partial_arithmetic_combined:
  description: "functools.partial and functools.partialmethod define none of __round__, __divmod__, __pow__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2746

  columns: [id, function, args, expected]
  rows:
    - ["ft2746013", "functools.partial.__dict__.__contains__",       ["__round__"],  false]
    - ["ft2746014", "functools.partial.__dict__.__contains__",       ["__divmod__"], false]
    - ["ft2746015", "functools.partial.__dict__.__contains__",       ["__pow__"],    false]
    - ["ft2746016", "functools.partialmethod.__dict__.__contains__", ["__round__"],  false]
    - ["ft2746017", "functools.partialmethod.__dict__.__contains__", ["__divmod__"], false]
    - ["ft2746018", "functools.partialmethod.__dict__.__contains__", ["__pow__"],    false]
