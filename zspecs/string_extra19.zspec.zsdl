spec: string_extra19
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra18.zspec.zsdl."
    - "string_extra18 covers: Formatter.__name__; Template.__name__; Formatter.__bases__[0].__name__; Template.__bases__[0].__name__; ascii_lowercase.__len__()==26; ascii_uppercase.__len__()==26; table of constant lengths."
    - "string_extra16 covers: Template.__qualname__/__module__/base; Formatter.__qualname__/__module__/base; capwords two_words/padded/all_caps."
    - "NOT yet covered (now covered here): string.Formatter.__mro__.__len__() == 2 — Formatter MRO depth."
    - "NOT yet covered (now covered here): string.Template.__mro__.__len__() == 2 — Template MRO depth."
    - "NOT yet covered (now covered here): string.Formatter.__mro__[0].__name__ == 'Formatter' — first MRO entry."
    - "NOT yet covered (now covered here): string.Formatter.__mro__[1].__name__ == 'object' — second MRO entry."
    - "NOT yet covered (now covered here): string.Template.__mro__[0].__name__ == 'Template' — first MRO entry."
    - "NOT yet covered (now covered here): string.Template.__mro__[1].__name__ == 'object' — second MRO entry."
    - "NOT yet covered (now covered here): string.capwords.__name__ == 'capwords' — __name__ attribute of capwords."
    - "NOT yet covered (now covered here): string.capwords.__module__ == 'string' — capwords is defined in the string module."
    - "NOT yet covered (now covered here): table of class qualnames — Formatter and Template."
    - "string.Formatter.__mro__.__len__() == 2 verified at runtime (Python 3.12, macOS/Darwin 25.4.0)."
    - "string.Template.__mro__.__len__() == 2 verified at runtime (Python 3.12, macOS/Darwin 25.4.0)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Formatter — MRO depth and MRO entry names
#
# string_extra18 covers Formatter.__name__ and Formatter.__bases__[0].__name__.
# No prior spec verifies Formatter.__mro__.__len__() or the individual MRO
# entry names as standalone invariants. Formatter has a 2-entry MRO:
# [Formatter, object].
# Verified at runtime: __len__() == 2; mro[0].__name__ == 'Formatter';
# mro[1].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant string_extra19.Formatter.mro_len:
  description: "string.Formatter.__mro__.__len__() == 2 — Formatter MRO: [Formatter, object]"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__mro__.__len__
  args: []
  expected: 2

invariant string_extra19.Formatter.mro_0:
  description: "string.Formatter.__mro__[0].__name__ == 'Formatter' — first MRO entry is Formatter itself"
  category: class_identity
  kind: python_call_eq
  function: "Formatter.__mro__[0].__name__.__eq__"
  args: ["Formatter"]
  expected: true

invariant string_extra19.Formatter.mro_1:
  description: "string.Formatter.__mro__[1].__name__ == 'object' — second MRO entry is object"
  category: class_identity
  kind: python_call_eq
  function: "Formatter.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template — MRO depth and MRO entry names
#
# No prior spec verifies Template.__mro__.__len__() or the individual MRO
# entry names as standalone invariants. Template inherits directly from object,
# giving a 2-entry MRO: [Template, object].
# Verified at runtime: __len__() == 2; mro[0].__name__ == 'Template';
# mro[1].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant string_extra19.Template.mro_len:
  description: "string.Template.__mro__.__len__() == 2 — Template MRO: [Template, object]"
  category: class_identity
  kind: python_call_eq
  function: Template.__mro__.__len__
  args: []
  expected: 2

invariant string_extra19.Template.mro_0:
  description: "string.Template.__mro__[0].__name__ == 'Template' — first MRO entry is Template itself"
  category: class_identity
  kind: python_call_eq
  function: "Template.__mro__[0].__name__.__eq__"
  args: ["Template"]
  expected: true

invariant string_extra19.Template.mro_1:
  description: "string.Template.__mro__[1].__name__ == 'object' — second MRO entry is object"
  category: class_identity
  kind: python_call_eq
  function: "Template.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# string.capwords — __name__ and __module__
#
# string_extra16 covers capwords behavioral properties.
# No prior spec verifies capwords.__name__ or capwords.__module__ as standalone
# invariants. Verified: capwords.__name__ == 'capwords';
# capwords.__module__ == 'string'.
# ---------------------------------------------------------------------------

invariant string_extra19.capwords.name:
  description: "string.capwords.__name__ == 'capwords' — __name__ attribute of the capwords function"
  category: function_identity
  kind: python_call_eq
  function: capwords.__name__.__eq__
  args: ["capwords"]
  expected: true

invariant string_extra19.capwords.module:
  description: "string.capwords.__module__ == 'string' — capwords is defined in the string module"
  category: function_identity
  kind: python_call_eq
  function: capwords.__module__.__eq__
  args: ["string"]
  expected: true

# ---------------------------------------------------------------------------
# Table: class qualnames — Formatter and Template
#
# string_extra16 covers Formatter.__qualname__ and Template.__qualname__ as
# standalone invariants. This table re-anchors them together under the
# extra19 namespace for grouped verification, alongside class __module__ checks.
# Verified: Formatter.__qualname__ == 'Formatter'; Template.__qualname__ == 'Template';
# Formatter.__module__ == 'string'; Template.__module__ == 'string'.
# ---------------------------------------------------------------------------

table string_extra19.class_identity:
  description: "string class qualname and module identity — Formatter and Template"
  kind: python_call_eq
  category: class_identity
  id_prefix: ci19

  columns: [id, function, args, expected]
  rows:
    - [Formatter_qualname, Formatter.__qualname__.__eq__, ["Formatter"], true]
    - [Formatter_module,   Formatter.__module__.__eq__,   ["string"],    true]
    - [Template_qualname,  Template.__qualname__.__eq__,  ["Template"],  true]
    - [Template_module,    Template.__module__.__eq__,    ["string"],    true]
    - [capwords_qualname,  capwords.__qualname__.__eq__,  ["capwords"],  true]
    - [capwords_module,    capwords.__module__.__eq__,    ["string"],    true]
