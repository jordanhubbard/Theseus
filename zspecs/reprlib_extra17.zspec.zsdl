spec: reprlib_extra17
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl through reprlib_extra16.zspec.zsdl."
    - "reprlib_extra16 covers: Repr.repr/repr_int/repr_str/repr_list/repr_tuple/repr_dict/repr_set.__qualname__ as standalone invariants."
    - "No prior spec verifies Repr.repr_frozenset.__qualname__, Repr.repr_deque.__qualname__, Repr.repr_array.__qualname__, Repr.__init__.__qualname__, Repr.__repr__.__qualname__, or reprlib.recursive_repr.__qualname__ as standalone invariants."
    - "reprlib.Repr has no repr_bytes or repr_bytearray methods — confirmed at runtime (getattr returns None)."
    - "Repr.__repr__ is inherited from object, so its __qualname__ is 'object.__repr__'. Verified at runtime."
    - "reprlib.recursive_repr.__qualname__ == 'recursive_repr' — module-level decorator function. Verified at runtime."
    - "Repr.__init__.__qualname__ == 'Repr.__init__' — constructor qualname includes owning class. Verified at runtime."
    - "Repr.repr_frozenset.__qualname__ == 'Repr.repr_frozenset' — method qualname includes owning class. Verified at runtime."
    - "Repr.repr_deque.__qualname__ == 'Repr.repr_deque' — method qualname includes owning class. Verified at runtime."
    - "Repr.repr_array.__qualname__ == 'Repr.repr_array' — method qualname includes owning class. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Repr.__init__ method __qualname__
#
# No prior spec verifies Repr.__init__.__qualname__ as a standalone invariant.
# For methods defined in class Repr, __qualname__ takes the form 'Repr.<name>'.
# Verified: Repr.__init__.__qualname__ == 'Repr.__init__'.
# ---------------------------------------------------------------------------

invariant reprlib_extra17.Repr.__init__qualname:
  description: "reprlib.Repr.__init__.__qualname__ == 'Repr.__init__' — constructor qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: "Repr.__init__.__qualname__.__eq__"
  args: ["Repr.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.__repr__ method __qualname__
#
# Repr does not define __repr__ itself; it inherits from object.
# Therefore __qualname__ is 'object.__repr__', not 'Repr.__repr__'.
# No prior spec verifies this inherited-qualname property as a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra17.Repr.__repr__qualname:
  description: "reprlib.Repr.__repr__.__qualname__ == 'object.__repr__' — inherited from object"
  category: function_identity
  kind: python_call_eq
  function: "Repr.__repr__.__qualname__.__eq__"
  args: ["object.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_frozenset method __qualname__
#
# No prior spec verifies Repr.repr_frozenset.__qualname__ as a standalone invariant.
# repr_frozenset produces a repr for frozenset objects truncated to maxset items.
# Verified: Repr.repr_frozenset.__qualname__ == 'Repr.repr_frozenset'.
# ---------------------------------------------------------------------------

invariant reprlib_extra17.Repr.repr_frozenset_qualname:
  description: "reprlib.Repr.repr_frozenset.__qualname__ == 'Repr.repr_frozenset' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_frozenset.__qualname__.__eq__
  args: ["Repr.repr_frozenset"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_deque method __qualname__
#
# No prior spec verifies Repr.repr_deque.__qualname__ as a standalone invariant.
# repr_deque produces a repr for collections.deque objects.
# Verified: Repr.repr_deque.__qualname__ == 'Repr.repr_deque'.
# ---------------------------------------------------------------------------

invariant reprlib_extra17.Repr.repr_deque_qualname:
  description: "reprlib.Repr.repr_deque.__qualname__ == 'Repr.repr_deque' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_deque.__qualname__.__eq__
  args: ["Repr.repr_deque"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_array method __qualname__
#
# No prior spec verifies Repr.repr_array.__qualname__ as a standalone invariant.
# repr_array produces a repr for array.array objects.
# Verified: Repr.repr_array.__qualname__ == 'Repr.repr_array'.
# ---------------------------------------------------------------------------

invariant reprlib_extra17.Repr.repr_array_qualname:
  description: "reprlib.Repr.repr_array.__qualname__ == 'Repr.repr_array' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_array.__qualname__.__eq__
  args: ["Repr.repr_array"]
  expected: true

# ---------------------------------------------------------------------------
# reprlib.recursive_repr __qualname__
#
# recursive_repr is a module-level decorator function.
# No prior spec verifies recursive_repr.__qualname__ as a standalone invariant.
# As a plain module-level function, its __qualname__ equals its simple name.
# Verified: recursive_repr.__qualname__ == 'recursive_repr'.
# ---------------------------------------------------------------------------

invariant reprlib_extra17.recursive_repr.qualname:
  description: "reprlib.recursive_repr.__qualname__ == 'recursive_repr' — module-level decorator qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: recursive_repr.__qualname__.__eq__
  args: ["recursive_repr"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Repr additional method __qualname__ attributes
#
# Groups the three new Repr method qualname checks (repr_frozenset, repr_deque,
# repr_array) in one indexed table. No prior table covers these methods.
# All verified at runtime: each __qualname__ takes the form 'Repr.<name>'.
# ---------------------------------------------------------------------------

table reprlib_extra17.Repr_additional_method_qualnames:
  description: "reprlib.Repr additional method __qualname__ attributes — repr_frozenset, repr_deque, repr_array"
  kind: python_call_eq
  category: function_identity
  id_prefix: rl17mq

  columns: [id, function, args, expected]
  rows:
    - [repr_frozenset, Repr.repr_frozenset.__qualname__.__eq__, ["Repr.repr_frozenset"], true]
    - [repr_deque,     Repr.repr_deque.__qualname__.__eq__,     ["Repr.repr_deque"],     true]
    - [repr_array,     Repr.repr_array.__qualname__.__eq__,     ["Repr.repr_array"],     true]
