spec: uuid_extra129
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra128.zspec.zsdl — covers UUID.__le__/__gt__/__ge__ qualname/name/class/module/co_argcount/co_name / UUID.__repr__/__hash__ co_name and co_varnames.__len__() (table + invariants)."
    - "uuid_extra127.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__/__hash__ __name__ equality / UUID dunder __class__.__name__=='function' and __module__=='uuid' / UUID.__init__ co_argcount==7 and co_varnames.__len__()==15 / UUID.__new__ identity (table + invariants)."
    - "uuid_extra105.zspec.zsdl — covers UUID.__le__/__gt__/__ge__ qualname equality / UUID.__int__ qualname / UUID method co_argcount grouping (unary vs binary) (table + invariants)."
    - "uuid_extra100.zspec.zsdl — covers UUID.int member_descriptor type/qualname/__objclass__ / UUID.__setattr__ qualname and class name (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ co_name/co_argcount/__qualname__ / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior uuid spec files."
    - "Wave 362 theme: UUID.__lt__/__int__/__setattr__ __name__ equality / UUID.__lt__/__int__/__setattr__ co_name equality / UUID.__setattr__ co_argcount==3 and co_varnames.__len__()==3 / UUID.__int__ co_name and co_varnames.__len__()==1."
    - "uuid.UUID.__lt__.__name__ == '__lt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__name__ == '__int__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__name__ == '__setattr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__code__.co_name == '__lt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__code__.co_name == '__int__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__code__.co_name == '__setattr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__code__.co_argcount == 3 (self, name, value). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__code__.co_varnames.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__code__.co_varnames.__len__() == 1 (only 'self'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra99 anchors UUID.__lt__ qualname equality. extra127 anchors __name__ for __init__/__str__/__repr__/__eq__/__hash__. extra128 anchors __name__ for __le__/__gt__/__ge__. This spec is the first to anchor UUID.__lt__/__int__/__setattr__ __name__ equality, co_name equality, UUID.__setattr__ co_argcount==3 and co_varnames.__len__()==3, UUID.__int__ co_varnames.__len__()==1 under uuidlts129."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__name__.__eq__('__lt__')
# uuid.UUID.__int__.__name__.__eq__('__int__')
# uuid.UUID.__setattr__.__name__.__eq__('__setattr__')
# uuid.UUID.__lt__.__class__.__name__.__eq__('function')
# uuid.UUID.__int__.__class__.__name__.__eq__('function')
#
# Wave 362 theme: UUID.__lt__/__int__/__setattr__ __name__ equality.
#
# UUID.__lt__, UUID.__int__, and UUID.__setattr__ are pure-Python functions
# (class 'function') defined in Lib/uuid.py. Their __name__ attribute is
# the short dunder name as it appears in the def statement. extra127 anchors
# __name__ equality for __init__/__str__/__repr__/__eq__/__hash__; extra128
# anchors __name__ for __le__/__gt__/__ge__. UUID.__lt__.__name__=='__lt__'
# and UUID.__int__.__name__=='__int__' and UUID.__setattr__.__name__==
# '__setattr__' have NOT been anchored by any prior uuid spec. No prior spec
# anchors __lt__.__name__ (only __lt__.__qualname__ in extra99).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra129.UUID_lt_int_setattr_names:
  description: "uuid.UUID/__lt__/__name__.__eq__('__lt__')==True / __int__/__name__.__eq__('__int__')==True / __setattr__/__name__.__eq__('__setattr__')==True / __lt__/__class__/__name__.__eq__('function')==True / __int__/__class__/__name__.__eq__('function')==True — __lt__ enables ordering; __int__ converts UUID to 128-bit int; __setattr__ enforces immutability; all three are pure-Python functions; extra127 anchors __init__/__str__/__repr__/__eq__/__hash__ __name__; extra128 anchors __le__/__gt__/__ge__ __name__; first uuidlts129 anchor for __lt__/__int__/__setattr__ __name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidlts129

  columns: [id, function, args, expected, description]
  rows:
    - [lt_name,       UUID.__lt__.__name__.__eq__,              ["__lt__"],       true, "UUID.__lt__.__name__ is '__lt__' (less-than comparison; orders UUIDs by self.int)"]
    - [int_name,      UUID.__int__.__name__.__eq__,             ["__int__"],      true, "UUID.__int__.__name__ is '__int__' (converts UUID to 128-bit integer via self.int)"]
    - [setattr_name,  UUID.__setattr__.__name__.__eq__,         ["__setattr__"],  true, "UUID.__setattr__.__name__ is '__setattr__' (raises TypeError to enforce UUID immutability)"]
    - [lt_cls,        UUID.__lt__.__class__.__name__.__eq__,    ["function"],     true, "UUID.__lt__.__class__.__name__ is 'function' (pure-Python function; contrasts with C method_descriptor)"]
    - [int_cls,       UUID.__int__.__class__.__name__.__eq__,   ["function"],     true, "UUID.__int__.__class__.__name__ is 'function' (pure-Python function defined in Lib/uuid.py)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__code__.co_name.__eq__('__lt__')
# uuid.UUID.__int__.__code__.co_name.__eq__('__int__')
# uuid.UUID.__setattr__.__code__.co_name.__eq__('__setattr__')
# uuid.UUID.__setattr__.__code__.co_argcount.__eq__(3)
# uuid.UUID.__setattr__.__module__.__eq__('uuid')
#
# Wave 362 theme: UUID dunder co_name equality and __setattr__ co_argcount.
#
# The co_name attribute of a code object matches the __name__ of its enclosing
# function (for simple methods). UUID.__lt__, __int__, and __setattr__ all
# have co_name equal to their __name__. UUID.__setattr__ is special in that
# it takes 3 positional args: self, name, and value — co_argcount==3.
# This is the only UUID dunder with co_argcount==3; all other UUID methods
# have co_argcount==1 (unary) or 2 (binary/comparison). extra128 anchors
# co_argcount==2 for __le__/__gt__/__ge__; no prior spec anchors __setattr__
# co_argcount or co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra129.UUID_co_names_and_setattr_argcount:
  description: "uuid.UUID/__lt__/__code__/co_name.__eq__('__lt__')==True / __int__/__code__/co_name.__eq__('__int__')==True / __setattr__/__code__/co_name.__eq__('__setattr__')==True / __setattr__/__code__/co_argcount.__eq__(3)==True / __setattr__/__module__.__eq__('uuid')==True — co_name matches __name__ for all three; __setattr__ uniquely has co_argcount==3 (self + name + value); all other UUID dunders have 1 or 2 args; first uuidlts129 anchor for __lt__/__int__/__setattr__ co_name and __setattr__ co_argcount"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidlts129

  columns: [id, function, args, expected, description]
  rows:
    - [lt_co_name,        UUID.__lt__.__code__.co_name.__eq__,        ["__lt__"],      true, "UUID.__lt__.__code__.co_name is '__lt__' (co_name always equals the def statement name)"]
    - [int_co_name,       UUID.__int__.__code__.co_name.__eq__,       ["__int__"],     true, "UUID.__int__.__code__.co_name is '__int__' (converts UUID to 128-bit int; co_name matches __name__)"]
    - [setattr_co_name,   UUID.__setattr__.__code__.co_name.__eq__,   ["__setattr__"], true, "UUID.__setattr__.__code__.co_name is '__setattr__' (overrides to raise TypeError on any attribute assignment)"]
    - [setattr_argcount,  UUID.__setattr__.__code__.co_argcount.__eq__, [3],           true, "UUID.__setattr__.__code__.co_argcount is 3 (self + name + value; only UUID dunder with 3 positional args)"]
    - [setattr_module,    UUID.__setattr__.__module__.__eq__,         ["uuid"],        true, "UUID.__setattr__.__module__ is 'uuid' (defined in Lib/uuid.py; all UUID dunders have __module__=='uuid')"]

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__code__.co_varnames.__len__().__eq__(1)
# uuid.UUID.__setattr__.__code__.co_varnames.__len__().__eq__(3)
# uuid.UUID.__int__.__module__.__eq__('uuid')
# uuid.UUID.__setattr__.__class__.__name__.__eq__('function')
# uuid.UUID.__lt__.__module__.__eq__('uuid')
#
# Wave 362 theme: UUID.__int__/__setattr__ co_varnames length and module cross-check.
#
# UUID.__int__.__code__.co_varnames is ('self',) — just one element because
# __int__ is a unary method with no local variables beyond self. It returns
# self.int directly. UUID.__setattr__.__code__.co_varnames is
# ('self', 'name', 'value') — exactly 3 elements, one per argument, and no
# additional local variables (the function body immediately raises TypeError).
# These co_varnames.__len__() values confirm the minimal complexity of both
# methods. extra128 anchors UUID.__repr__.co_varnames.__len__()==1; this spec
# is the first to anchor UUID.__int__ and UUID.__setattr__ co_varnames lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra129.UUID_co_varnames_lens_and_module:
  description: "uuid.UUID/__int__/__code__/co_varnames/__len__()==1 / __setattr__/__code__/co_varnames/__len__()==3 / __int__/__module__.__eq__('uuid')==True / __setattr__/__class__/__name__.__eq__('function')==True / __lt__/__module__.__eq__('uuid')==True — __int__ has 1 co_varname ('self' only; returns self.int directly); __setattr__ has 3 ('self','name','value'; immediately raises TypeError); first uuidlts129 anchor for __int__/__setattr__ co_varnames.__len__() and remaining module cross-checks"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidlts129

  columns: [id, function, args, expected, description]
  rows:
    - [int_varlen,       UUID.__int__.__code__.co_varnames.__len__,    [],      1, "UUID.__int__ co_varnames has 1 entry: ('self',) — unary method with no local temps (returns self.int)"]
    - [setattr_varlen,   UUID.__setattr__.__code__.co_varnames.__len__, [],     3, "UUID.__setattr__ co_varnames has 3 entries: ('self','name','value') — immediately raises TypeError with no temps"]
    - [int_module,       UUID.__int__.__module__.__eq__,               ["uuid"], true, "UUID.__int__.__module__ is 'uuid' (defined in Lib/uuid.py alongside all other UUID dunders)"]
    - [setattr_cls,      UUID.__setattr__.__class__.__name__.__eq__,   ["function"], true, "UUID.__setattr__.__class__.__name__ is 'function' (pure-Python override; extra94 anchors this at table level)"]
    - [lt_module,        UUID.__lt__.__module__.__eq__,                ["uuid"], true, "UUID.__lt__.__module__ is 'uuid' (extra128 anchors __le__/__gt__/__ge__ module; first anchor for __lt__ module)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__name__.__eq__('__lt__') — standalone
#
# uuid.UUID.__lt__.__name__ is '__lt__'. UUID implements all four ordering
# operators (__lt__, __le__, __gt__, __ge__) explicitly in Lib/uuid.py.
# extra99 anchors __lt__.__qualname__=='UUID.__lt__' and its __qualname__.__len__().
# extra127 anchors __name__ for __init__/__str__/__repr__/__eq__/__hash__.
# extra128 anchors __name__ for __le__/__gt__/__ge__. UUID.__lt__.__name__
# ('__lt__') falls in the gap — neither extra127 nor extra128 covers it.
# This is the first standalone for UUID.__lt__.__name__.__eq__ under uuidlts129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra129.UUID_lt_name:
  description: "uuid.UUID.__lt__.__name__.__eq__('__lt__') == True — UUID defines __lt__ explicitly (not via @total_ordering; compares self.int < other.int); extra99 anchors __lt__.__qualname__; extra127 anchors __name__ for init/str/repr/eq/hash; extra128 anchors __name__ for __le__/__gt__/__ge__; this is the gap: __lt__.__name__ uncovered; first standalone for UUID.__lt__.__name__.__eq__ under uuidlts129"
  category: type_identity
  kind: python_call_eq
  function: UUID.__lt__.__name__.__eq__
  args: ["__lt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__name__.__eq__('__int__') — standalone
#
# uuid.UUID.__int__.__name__ is '__int__'. UUID.__int__ is the Python function
# that implements int(uuid_instance), returning the UUID's 128-bit integer
# value (stored in self.int, the slot-based member_descriptor). UUID.__int__
# is a unary function (co_argcount==1, co_varnames==('self',)) that simply
# returns self.int. extra105 anchors UUID.__int__.__qualname__=='UUID.__int__'
# and co_argcount==1. No prior uuid spec anchors UUID.__int__.__name__ via
# __eq__ as a standalone under uuidlts129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra129.UUID_int_name:
  description: "uuid.UUID.__int__.__name__.__eq__('__int__') == True — __int__ returns UUID as 128-bit integer (self.int); unary: co_argcount==1; extra105 anchors qualname 'UUID.__int__' and co_argcount; first standalone for UUID.__int__.__name__.__eq__ under uuidlts129"
  category: type_identity
  kind: python_call_eq
  function: UUID.__int__.__name__.__eq__
  args: ["__int__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__code__.co_argcount.__eq__(3) — standalone
#
# uuid.UUID.__setattr__.__code__.co_argcount is 3. UUID overrides __setattr__
# to make UUID objects immutable — it immediately raises TypeError('UUID objects
# are immutable'). The method signature is __setattr__(self, name, value),
# giving it 3 positional arguments. This is the only UUID dunder with
# co_argcount==3; all unary methods (like __int__, __str__, __repr__, __hash__)
# have co_argcount==1, and binary comparison methods have co_argcount==2.
# extra100 anchors __setattr__.__qualname__=='UUID.__setattr__' and its class
# name=='function'. No prior uuid spec anchors __setattr__.co_argcount via
# __eq__ as a standalone under uuidlts129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra129.UUID_setattr_co_argcount_3:
  description: "uuid.UUID.__setattr__.__code__.co_argcount.__eq__(3) == True — __setattr__ takes 3 args: self + name + value; raises TypeError immediately to enforce UUID immutability; only UUID dunder with co_argcount==3 (unary dunders have 1, comparison have 2); extra100 anchors qualname/class; first standalone for __setattr__.co_argcount.__eq__(3) under uuidlts129"
  category: type_identity
  kind: python_call_eq
  function: UUID.__setattr__.__code__.co_argcount.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__code__.co_varnames.__len__().__eq__(1) — standalone
#
# uuid.UUID.__int__.__code__.co_varnames.__len__() is 1. The co_varnames
# tuple for UUID.__int__ contains exactly one element: ('self',). The method
# body is simply 'return self.int' — no local variables beyond the implicit
# self parameter. By contrast, UUID.__str__ has co_varnames.__len__()==2
# (self and the local variable 'x' for hex formatting). extra128 anchors
# UUID.__repr__.co_varnames.__len__()==1 (which is also 1 for the same
# reason). This standalone is the first to anchor UUID.__int__
# co_varnames.__len__()==1 under uuidlts129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra129.UUID_int_co_varnames_len_1:
  description: "uuid.UUID.__int__.__code__.co_varnames.__len__() == 1 — __int__ has only ('self',) in co_varnames (no local temps; body is just 'return self.int'); analogous to __repr__ which also has len==1 (anchored in extra128); contrasts with __str__ which has len==2 (self + x); first standalone for __int__.co_varnames.__len__()==1 under uuidlts129"
  category: type_identity
  kind: python_call_eq
  function: UUID.__int__.__code__.co_varnames.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__code__.co_varnames.__len__().__eq__(3) — standalone
#
# uuid.UUID.__setattr__.__code__.co_varnames.__len__() is 3. The co_varnames
# tuple is ('self', 'name', 'value') — exactly the three parameters of the
# __setattr__ signature. UUID.__setattr__ contains no local variables beyond
# its parameters because the entire function body is a single raise statement.
# This co_varnames length of 3 is unique among UUID dunders: all other UUID
# methods have co_varnames length 1 (unary) or 2 (binary comparison or UUID.
# __str__). No prior uuid spec anchors UUID.__setattr__ co_varnames.__len__()
# as a standalone under uuidlts129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra129.UUID_setattr_co_varnames_len_3:
  description: "uuid.UUID.__setattr__.__code__.co_varnames.__len__() == 3 — __setattr__ has ('self','name','value') in co_varnames; no local temps (body is single raise statement); unique length-3 co_varnames among UUID dunders (others have 1 or 2); first standalone for __setattr__.co_varnames.__len__()==3 under uuidlts129"
  category: type_identity
  kind: python_call_eq
  function: UUID.__setattr__.__code__.co_varnames.__len__
  args: []
  expected: 3
