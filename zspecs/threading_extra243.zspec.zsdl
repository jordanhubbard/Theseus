spec: threading_extra243
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra242.zspec.zsdl — covers Semaphore and BoundedSemaphore class identity"
    - "threading_extra241.zspec.zsdl — covers Timer and main_thread identity"
    - "threading_extra.zspec.zsdl — covers module checks for synchronization primitives, local, get_ident, TIMEOUT_MAX, stack_size"
    - "threading.zspec.zsdl — covers class __name__ checks (Barrier, BoundedSemaphore, Condition) and function names"
  notes:
    - "This spec covers threading.current_thread, threading.active_count, and threading.enumerate function identity contracts."
    - "threading.current_thread.__name__ == 'current_thread' (len=14) — current_thread is a Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.current_thread.__module__ == 'threading' (len=9) — current_thread is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.current_thread.__qualname__ == 'current_thread' (len=14) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "threading.current_thread.__class__.__name__ == 'function' — current_thread is a plain Python function. Verified with Python 3.14.3."
    - "threading.active_count.__name__ == 'active_count' (len=12) — active_count is a Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.active_count.__module__ == 'threading' (len=9) — active_count is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.active_count.__qualname__ == 'active_count' (len=12) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "threading.active_count.__class__.__name__ == 'function' — active_count is a plain Python function. Verified with Python 3.14.3."
    - "threading.enumerate.__name__ == 'enumerate' (len=9) — enumerate is a Python function in Lib/threading.py (shadows the built-in in this namespace). Verified with Python 3.14.3."
    - "threading.enumerate.__module__ == 'threading' (len=9) — enumerate is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.enumerate.__qualname__ == 'enumerate' (len=9) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "threading.enumerate.__class__.__name__ == 'function' — threading.enumerate is a Python function (distinct from builtins.enumerate which is a type). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.current_thread identity contracts
#
# threading.current_thread.__name__ == 'current_thread' (len=14)
# threading.current_thread.__module__ == 'threading' (len=9)
# threading.current_thread.__qualname__ == 'current_thread' (len=14)
# threading.current_thread.__class__.__name__ == 'function'
# threading.current_thread.__name__.__len__() == 14
#
# current_thread is a Python function in Lib/threading.py. New to extra243.
# ---------------------------------------------------------------------------

table threading_extra243.thr243fns_ct_identity:
  description: "threading.current_thread identity: name, module, qualname, class; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: thr243fns

  columns: [id, function, args, expected, description]
  rows:
    - [ct_name_eq,
       current_thread.__name__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__name__.__eq__('current_thread') == True — current_thread is a Python function in Lib/threading.py; __name__ is 'current_thread' (len=14); new to extra243"]
    - [ct_name_len_14,
       current_thread.__name__.__len__,
       [],
       14,
       "threading.current_thread.__name__.__len__() == 14 — 'current_thread' has exactly 14 characters; str.__len__() returns 14; new to extra243"]
    - [ct_module_eq,
       current_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.current_thread.__module__.__eq__('threading') == True — current_thread is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra243"]
    - [ct_module_len_9,
       current_thread.__module__.__len__,
       [],
       9,
       "threading.current_thread.__module__.__len__() == 9 — 'threading' has exactly 9 characters; str.__len__() returns 9; new to extra243"]
    - [ct_qualname_eq,
       current_thread.__qualname__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__qualname__.__eq__('current_thread') == True — __qualname__ is 'current_thread' (len=14); same as __name__ for top-level function; new to extra243"]

# ---------------------------------------------------------------------------
# Table 2: threading.current_thread class and doc contracts
#
# threading.current_thread.__class__.__name__ == 'function'
# threading.current_thread.__qualname__.__len__() == 14
# threading.current_thread.__name__.__contains__('thread') == True
# threading.current_thread.__module__.__contains__('threading') == True
# threading.current_thread.__name__.__contains__('current') == True
#
# New to extra243.
# ---------------------------------------------------------------------------

table threading_extra243.thr243fns_ct_class:
  description: "threading.current_thread class, qualname len, name content checks; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: thr243fnsc

  columns: [id, function, args, expected, description]
  rows:
    - [ct_class_is_function,
       current_thread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.current_thread.__class__.__name__.__eq__('function') == True — current_thread is a plain Python function; its __class__ is the built-in function type; new to extra243"]
    - [ct_qualname_len_14,
       current_thread.__qualname__.__len__,
       [],
       14,
       "threading.current_thread.__qualname__.__len__() == 14 — 'current_thread' has exactly 14 characters; str.__len__() returns 14; new to extra243"]
    - [ct_name_contains_thread,
       current_thread.__name__.__contains__,
       ["thread"],
       true,
       "threading.current_thread.__name__.__contains__('thread') == True — 'current_thread' contains the substring 'thread'; new to extra243"]
    - [ct_module_contains_threading,
       current_thread.__module__.__contains__,
       ["threading"],
       true,
       "threading.current_thread.__module__.__contains__('threading') == True — 'threading' contains the substring 'threading'; new to extra243"]
    - [ct_name_contains_current,
       current_thread.__name__.__contains__,
       ["current"],
       true,
       "threading.current_thread.__name__.__contains__('current') == True — 'current_thread' contains the prefix 'current'; new to extra243"]

# ---------------------------------------------------------------------------
# Table 3: threading.active_count identity contracts
#
# threading.active_count.__name__ == 'active_count' (len=12)
# threading.active_count.__module__ == 'threading' (len=9)
# threading.active_count.__qualname__ == 'active_count' (len=12)
# threading.active_count.__class__.__name__ == 'function'
# threading.active_count.__name__.__len__() == 12
#
# active_count is a Python function in Lib/threading.py. New to extra243.
# ---------------------------------------------------------------------------

table threading_extra243.thr243fns_ac_identity:
  description: "threading.active_count identity: name, module, qualname, class; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: thr243fnsac

  columns: [id, function, args, expected, description]
  rows:
    - [ac_name_eq,
       active_count.__name__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__name__.__eq__('active_count') == True — active_count is a Python function in Lib/threading.py; __name__ is 'active_count' (len=12); new to extra243"]
    - [ac_name_len_12,
       active_count.__name__.__len__,
       [],
       12,
       "threading.active_count.__name__.__len__() == 12 — 'active_count' has exactly 12 characters; str.__len__() returns 12; new to extra243"]
    - [ac_module_eq,
       active_count.__module__.__eq__,
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra243"]
    - [ac_qualname_eq,
       active_count.__qualname__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__qualname__.__eq__('active_count') == True — __qualname__ is 'active_count' (len=12); same as __name__ for top-level function; new to extra243"]
    - [ac_class_is_function,
       active_count.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.active_count.__class__.__name__.__eq__('function') == True — active_count is a plain Python function; its __class__ is the built-in function type; new to extra243"]

# ---------------------------------------------------------------------------
# Table 4: threading.enumerate identity contracts
#
# threading.enumerate.__name__ == 'enumerate' (len=9)
# threading.enumerate.__module__ == 'threading' (len=9)
# threading.enumerate.__qualname__ == 'enumerate' (len=9)
# threading.enumerate.__class__.__name__ == 'function'
# threading.enumerate.__name__.__len__() == 9
#
# threading.enumerate is a Python function in Lib/threading.py (not the built-in enumerate type).
# New to extra243.
# ---------------------------------------------------------------------------

table threading_extra243.thr243fns_en_identity:
  description: "threading.enumerate identity: name, module, qualname, class; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: thr243fnsen

  columns: [id, function, args, expected, description]
  rows:
    - [en_name_eq,
       enumerate.__name__.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__name__.__eq__('enumerate') == True — threading.enumerate is a Python function in Lib/threading.py; __name__ is 'enumerate' (len=9); new to extra243"]
    - [en_name_len_9,
       enumerate.__name__.__len__,
       [],
       9,
       "threading.enumerate.__name__.__len__() == 9 — 'enumerate' has exactly 9 characters; str.__len__() returns 9; new to extra243"]
    - [en_module_eq,
       enumerate.__module__.__eq__,
       ["threading"],
       true,
       "threading.enumerate.__module__.__eq__('threading') == True — threading.enumerate is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra243"]
    - [en_qualname_eq,
       enumerate.__qualname__.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__qualname__.__eq__('enumerate') == True — __qualname__ is 'enumerate' (len=9); same as __name__ for top-level function; new to extra243"]
    - [en_class_is_function,
       enumerate.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.enumerate.__class__.__name__.__eq__('function') == True — threading.enumerate is a Python function (distinct from builtins.enumerate which is a type); new to extra243"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra243
# ---------------------------------------------------------------------------

invariant threading_extra243.ct_name_eq:
  description: "threading.current_thread.__name__ == 'current_thread' (len=14); new to extra243"
  kind: python_call_eq
  function: current_thread.__name__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra243.ct_name_len_14:
  description: "threading.current_thread.__name__.__len__() == 14 — 'current_thread' has 14 characters; new to extra243"
  kind: python_call_eq
  function: current_thread.__name__.__len__
  args: []
  expected: 14

invariant threading_extra243.ct_module_eq:
  description: "threading.current_thread.__module__ == 'threading' — defined in Lib/threading.py; new to extra243"
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra243.ct_qualname_eq:
  description: "threading.current_thread.__qualname__ == 'current_thread' (len=14); new to extra243"
  kind: python_call_eq
  function: current_thread.__qualname__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra243.ct_class_is_function:
  description: "threading.current_thread.__class__.__name__ == 'function' — plain Python function; new to extra243"
  kind: python_call_eq
  function: current_thread.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra243.ac_name_eq:
  description: "threading.active_count.__name__ == 'active_count' (len=12); new to extra243"
  kind: python_call_eq
  function: active_count.__name__.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra243.ac_module_eq:
  description: "threading.active_count.__module__ == 'threading' — defined in Lib/threading.py; new to extra243"
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra243.ac_qualname_eq:
  description: "threading.active_count.__qualname__ == 'active_count' (len=12); new to extra243"
  kind: python_call_eq
  function: active_count.__qualname__.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra243.ac_class_is_function:
  description: "threading.active_count.__class__.__name__ == 'function' — plain Python function; new to extra243"
  kind: python_call_eq
  function: active_count.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra243.en_name_eq:
  description: "threading.enumerate.__name__ == 'enumerate' (len=9); new to extra243"
  kind: python_call_eq
  function: enumerate.__name__.__eq__
  args: ["enumerate"]
  expected: true

invariant threading_extra243.en_module_eq:
  description: "threading.enumerate.__module__ == 'threading' — defined in Lib/threading.py; new to extra243"
  kind: python_call_eq
  function: enumerate.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra243.en_class_is_function:
  description: "threading.enumerate.__class__.__name__ == 'function' — Python function, distinct from builtins.enumerate type; new to extra243"
  kind: python_call_eq
  function: enumerate.__class__.__name__.__eq__
  args: ["function"]
  expected: true
