spec: io3241
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 663 (io3241): __rtruediv__, __rfloordiv__, __rmod__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __rtruediv__, __rfloordiv__, __rmod__ dict-presence (reflected division/modulo)."
    - "No io class defines __rtruediv__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not numeric types, and do not implement reflected true division."
    - "No io class defines __rfloordiv__ in its own __dict__: stream I/O classes do not implement reflected floor division."
    - "No io class defines __rmod__ in its own __dict__: stream I/O classes do not implement reflected modulo."
    - "Key finding: decimal.Decimal defines all 3 reflected operators — consistent with wave 662 (__radd__/__rsub__/__rmul__ all true)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rtruediv__ dict-presence — operator.contains(Cls.__dict__, '__rtruediv__')
#
# No io class defines __rtruediv__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types,
# and do not implement the reflected true division operator.
# ---------------------------------------------------------------------------

table io3241.rtruediv:
  description: "io types __rtruediv__ dict-presence checks; wave 663"
