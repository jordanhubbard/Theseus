spec: gettext
version: ">=3.x"
backend: python_module(gettext)

docs: https://docs.python.org/3/library/gettext.html

provenance:
  derived_from:
    - "Python gettext documentation — https://docs.python.org/3/library/gettext.html"
    - "GNU gettext manual — https://www.gnu.org/software/gettext/manual/gettext.html"
    - "Test vectors verified by running Python 3.12 gettext module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gettext.py"
  notes:
    - "gettext provides GNU gettext-compatible internationalization (i18n) and localization (l10n) services."
    - "When no translation catalog is installed, gettext.gettext(msg) returns msg unchanged (passthrough)."
    - "ngettext(singular, plural, n) returns singular when n==1, otherwise plural — for untranslated strings."
    - "gettext.Catalog is an alias for GNUTranslations; both names refer to the same class."
    - "GNUTranslations inherits directly from NullTranslations."
    - "NullTranslations implements the base translation object; methods return the input string unchanged."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table gettext.func_names:
  kind: python_call_eq
  category: functions
  id_prefix: func_name

  columns: [id, function, args, expected]
  rows:
    - [gettext,        "gettext.__name__.__eq__",        ["gettext"],        true]
    - [ngettext,       "ngettext.__name__.__eq__",       ["ngettext"],       true]
    - [dgettext,       "dgettext.__name__.__eq__",       ["dgettext"],       true]
    - [dngettext,      "dngettext.__name__.__eq__",      ["dngettext"],      true]
    - [bindtextdomain, "bindtextdomain.__name__.__eq__", ["bindtextdomain"], true]
    - [textdomain,     "textdomain.__name__.__eq__",     ["textdomain"],     true]
    - [find,           "find.__name__.__eq__",           ["find"],           true]
    - [translation,    "translation.__name__.__eq__",    ["translation"],    true]
    - [install,        "install.__name__.__eq__",        ["install"],        true]

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant gettext.NullTranslations.class_name:
  description: "gettext.NullTranslations.__name__ == 'NullTranslations'"
  category: classnames
  kind: python_call_eq
  function: NullTranslations.__name__.__eq__
  args: ["NullTranslations"]
  expected: true

invariant gettext.GNUTranslations.class_name:
  description: "gettext.GNUTranslations.__name__ == 'GNUTranslations'"
  category: classnames
  kind: python_call_eq
  function: GNUTranslations.__name__.__eq__
  args: ["GNUTranslations"]
  expected: true

invariant gettext.Catalog.class_name:
  description: "gettext.Catalog.__name__ == 'GNUTranslations' — Catalog is an alias for GNUTranslations"
  category: classnames
  kind: python_call_eq
  function: Catalog.__name__.__eq__
  args: ["GNUTranslations"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — GNUTranslations extends NullTranslations
# ---------------------------------------------------------------------------

invariant gettext.GNUTranslations.base_class:
  description: "gettext.GNUTranslations.__bases__[0].__name__ == 'NullTranslations'"
  category: hierarchy
  kind: python_call_eq
  function: GNUTranslations.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "NullTranslations"

# ---------------------------------------------------------------------------
# Behavioral checks — passthrough when no catalog is installed
# ---------------------------------------------------------------------------

invariant gettext.gettext.passthrough:
  description: "gettext.gettext('hello') == 'hello' — untranslated string is returned unchanged"
  category: behavior
  kind: python_call_eq
  function: gettext
  args: ["hello"]
  expected: "hello"

invariant gettext.ngettext.singular:
  description: "gettext.ngettext('apple', 'apples', 1) == 'apple' — singular form when n == 1"
  category: behavior
  kind: python_call_eq
  function: ngettext
  args: ["apple", "apples", 1]
  expected: "apple"

invariant gettext.ngettext.plural:
  description: "gettext.ngettext('apple', 'apples', 2) == 'apples' — plural form when n != 1"
  category: behavior
  kind: python_call_eq
  function: ngettext
  args: ["apple", "apples", 2]
  expected: "apples"
