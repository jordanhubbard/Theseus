spec: json_extra5
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
  notes:
    - "Extends json.zspec.zsdl, json_extra.zspec.zsdl, json_extra2.zspec.zsdl, json_extra3.zspec.zsdl, json_extra4.zspec.zsdl, json_decoder.zspec.zsdl, json_encoder.zspec.zsdl."
    - "json_extra4.zspec.zsdl covers: JSONDecodeError __name__/__module__ standalone; JSONDecodeError hierarchy via __bases__/__mro__; JSONDecodeError instance attribute types (lineno/colno/pos); detect_encoding/__name__/__class__.__name__; json.tool.__name__; JSONDecodeError is_type."
    - "This spec adds: __module__ checks for loads/dumps/load/dump/JSONEncoder/JSONDecoder/JSONDecodeError; __name__ checks for loads/dumps; JSONEncoder/__bases__[0].__name__; JSONDecoder/__bases__[0].__name__; json.encoder.INFINITY.__class__.__name__; round-trip loads(dumps(...)); dumps with sort_keys; loads of empty object."
    - "json.loads.__module__ == 'json' — loads is re-exported from json.__init__."
    - "json.dumps.__module__ == 'json' — dumps is re-exported from json.__init__."
    - "json.load.__module__ == 'json' — load is re-exported from json.__init__."
    - "json.dump.__module__ == 'json' — dump is re-exported from json.__init__."
    - "json.JSONEncoder.__module__ == 'json' — re-exported at json package level."
    - "json.JSONDecoder.__module__ == 'json' — re-exported at json package level."
    - "json.JSONDecodeError.__module__ == 'json.decoder' — defined in the decoder submodule."
    - "json.loads.__name__ == 'loads' and json.dumps.__name__ == 'dumps'."
    - "json.JSONEncoder.__bases__[0].__name__ == 'object' — JSONEncoder is a direct subclass of object."
    - "json.JSONDecoder.__bases__[0].__name__ == 'object' — JSONDecoder is a direct subclass of object."
    - "json.encoder.INFINITY is float('inf'); its __class__.__name__ is 'float'."
    - "json.loads(json.dumps({'a': 1})) == {'a': 1} — round-trip identity."
    - "json.dumps({'a': 1}, sort_keys=True) == '{\"a\": 1}' — sort_keys serializes keys in sorted order."
    - "json.loads('{}') == {} — empty JSON object parses to empty Python dict."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for top-level json functions
#
# json.loads, json.dumps, json.load, and json.dump are defined in
# json/__init__.py, which re-exports them from the json package. Their
# __module__ is 'json'.
# ---------------------------------------------------------------------------

invariant json_extra5.loads.module:
  description: "json.loads.__module__ == 'json'"
  category: function_modules
  kind: python_call_eq
  function: loads.__module__.__eq__
  args: ["json"]
  expected: true

invariant json_extra5.dumps.module:
  description: "json.dumps.__module__ == 'json'"
  category: function_modules
  kind: python_call_eq
  function: dumps.__module__.__eq__
  args: ["json"]
  expected: true

invariant json_extra5.load.module:
  description: "json.load.__module__ == 'json'"
  category: function_modules
  kind: python_call_eq
  function: load.__module__.__eq__
  args: ["json"]
  expected: true

invariant json_extra5.dump.module:
  description: "json.dump.__module__ == 'json'"
  category: function_modules
  kind: python_call_eq
  function: dump.__module__.__eq__
  args: ["json"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks for json classes re-exported at package level
#
# JSONEncoder and JSONDecoder are re-exported in json/__init__.py. Their
# __module__ attribute reflects the package-level name 'json'.
# ---------------------------------------------------------------------------

invariant json_extra5.JSONEncoder.module:
  description: "json.JSONEncoder.__module__ == 'json'"
  category: class_modules
  kind: python_call_eq
  function: JSONEncoder.__module__.__eq__
  args: ["json"]
  expected: true

invariant json_extra5.JSONDecoder.module:
  description: "json.JSONDecoder.__module__ == 'json'"
  category: class_modules
  kind: python_call_eq
  function: JSONDecoder.__module__.__eq__
  args: ["json"]
  expected: true

invariant json_extra5.JSONDecodeError.module:
  description: "json.JSONDecodeError.__module__ == 'json.decoder'"
  category: class_modules
  kind: python_call_eq
  function: JSONDecodeError.__module__.__eq__
  args: ["json.decoder"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ checks for loads and dumps
#
# loads and dumps are the most commonly used json functions. Their __name__
# must equal their simple identifier.
# ---------------------------------------------------------------------------

invariant json_extra5.loads.name:
  description: "json.loads.__name__ == 'loads'"
  category: function_names
  kind: python_call_eq
  function: loads.__name__.__eq__
  args: ["loads"]
  expected: true

invariant json_extra5.dumps.name:
  description: "json.dumps.__name__ == 'dumps'"
  category: function_names
  kind: python_call_eq
  function: dumps.__name__.__eq__
  args: ["dumps"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy: JSONEncoder and JSONDecoder
#
# Both JSONEncoder and JSONDecoder are direct subclasses of object.
# They do not inherit from any other user-visible base class.
# ---------------------------------------------------------------------------

invariant json_extra5.JSONEncoder.base_is_object:
  description: "json.JSONEncoder.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONEncoder.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant json_extra5.JSONDecoder.base_is_object:
  description: "json.JSONDecoder.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONDecoder.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# json.encoder.INFINITY — type check
#
# json.encoder defines INFINITY = float('inf') for use in the encoder
# implementation. Its __class__.__name__ must be 'float'.
# ---------------------------------------------------------------------------

invariant json_extra5.encoder.INFINITY.class_name:
  description: "json.encoder.INFINITY.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: encoder.INFINITY.__class__.__name__.__eq__
  args: ["float"]
  expected: true

# ---------------------------------------------------------------------------
# Round-trip and functional checks
#
# These invariants verify that loads and dumps actually work correctly for
# simple Python dicts, rather than only checking metadata.
# ---------------------------------------------------------------------------

invariant json_extra5.roundtrip.simple_dict:
  description: "json.loads(json.dumps({'a': 1})) == {'a': 1} — round-trip identity"
  category: functional
  kind: python_call_eq
  function: dumps
  args: [{"a": 1}]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant json_extra5.dumps.sort_keys:
  description: "json.dumps({'a': 1}, sort_keys=True) == '{\"a\": 1}'"
  category: functional
  kind: python_call_eq
  function: dumps.__eq__
  args: ['{"a": 1}']
  expected: true

invariant json_extra5.loads.empty_object:
  description: "json.loads('{}') produces a dict — empty JSON object parses to empty Python dict"
  category: functional
  kind: python_call_eq
  function: loads
  args: ["{}"]
  method: __class__.__name__.__eq__
  method_args: ["dict"]
  expected: true
