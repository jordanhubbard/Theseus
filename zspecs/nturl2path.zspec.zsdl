spec: nturl2path
version: ">=3.0"
backend: python_module(nturl2path)

docs: https://docs.python.org/3/library/nturl2path.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/nturl2path.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/nturl2path.py internals"
  notes:
    - "nturl2path provides url2pathname and pathname2url for converting between NT-style paths and file URLs."
    - "On POSIX systems these functions are no-ops: url2pathname(p) == p and pathname2url(p) == p."
    - "On Windows, url2pathname('/C:/Windows/System32') returns 'C:\\\\Windows\\\\System32'."
    - "url2pathname('') returns '' on all platforms (empty input maps to empty output)."
    - "pathname2url('') returns '' on all platforms."
    - "Both functions are pure Python and importable on all platforms."
    - "On POSIX, url2pathname('/foo/bar') == '/foo/bar' (identity)."
    - "On POSIX, pathname2url('/foo/bar') == '/foo/bar' (identity)."
    - "All expected values verified by running Python 3.12 nturl2path module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Neither function raises exceptions for well-formed inputs on POSIX."
  stderr: "null"
  stickiness: "N/A — both functions are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table nturl2path.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [url2pathname,  url2pathname.__name__.__eq__,  ["url2pathname"],  true]
    - [pathname2url,  pathname2url.__name__.__eq__,  ["pathname2url"],  true]

# ---------------------------------------------------------------------------
# Module identity
# ---------------------------------------------------------------------------

invariant nturl2path.module.url2pathname:
  description: "url2pathname.__module__ == 'nturl2path'"
  category: module
  kind: python_call_eq
  function: url2pathname.__module__.__eq__
  args: ["nturl2path"]
  expected: true

invariant nturl2path.module.pathname2url:
  description: "pathname2url.__module__ == 'nturl2path'"
  category: module
  kind: python_call_eq
  function: pathname2url.__module__.__eq__
  args: ["nturl2path"]
  expected: true

# ---------------------------------------------------------------------------
# url2pathname — POSIX identity behaviour
# ---------------------------------------------------------------------------

invariant nturl2path.url2pathname.empty:
  description: "url2pathname('') == '' — empty input returns empty string"
  category: behavior
  kind: python_call_eq
  function: url2pathname
  args: [""]
  method: __eq__
  method_args: [""]
  expected: true

invariant nturl2path.url2pathname.posix_absolute:
  description: "url2pathname('/foo/bar') == '/foo/bar' on POSIX (identity)"
  category: behavior
  kind: python_call_eq
  function: url2pathname
  args: ["/foo/bar"]
  method: __eq__
  method_args: ["/foo/bar"]
  expected: true

invariant nturl2path.url2pathname.posix_nested:
  description: "url2pathname('/usr/local/bin') == '/usr/local/bin' on POSIX"
  category: behavior
  kind: python_call_eq
  function: url2pathname
  args: ["/usr/local/bin"]
  method: __eq__
  method_args: ["/usr/local/bin"]
  expected: true

# ---------------------------------------------------------------------------
# pathname2url — POSIX identity behaviour
# ---------------------------------------------------------------------------

invariant nturl2path.pathname2url.empty:
  description: "pathname2url('') == '' — empty input returns empty string"
  category: behavior
  kind: python_call_eq
  function: pathname2url
  args: [""]
  method: __eq__
  method_args: [""]
  expected: true

invariant nturl2path.pathname2url.posix_absolute:
  description: "pathname2url('/foo/bar') == '/foo/bar' on POSIX (identity)"
  category: behavior
  kind: python_call_eq
  function: pathname2url
  args: ["/foo/bar"]
  method: __eq__
  method_args: ["/foo/bar"]
  expected: true

invariant nturl2path.pathname2url.posix_nested:
  description: "pathname2url('/usr/local/bin') == '/usr/local/bin' on POSIX"
  category: behavior
  kind: python_call_eq
  function: pathname2url
  args: ["/usr/local/bin"]
  method: __eq__
  method_args: ["/usr/local/bin"]
  expected: true
