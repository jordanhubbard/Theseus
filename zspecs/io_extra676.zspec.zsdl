table io_extra676.buffered_reader_method_names:
  description: "io.BufferedReader method __name__ identity checks"
  kind: python_call_eq
  category: method_identity
  id_prefix: io676br
  columns: [id, function, args, expected]
  rows:
    - [io676br001, io.BufferedReader.read.__name__.__eq__, ["read"], true]
    - [io676br002, io.BufferedReader.read1.__name__.__eq__, ["read1"], true]
    - [io676br003, io.BufferedReader.peek.__name__.__eq__, ["peek"], true]
    - [io676br004, io.BufferedReader.readinto.__name__.__eq__, ["readinto"], true]
    - [io676br005, io.BufferedReader.readinto1.__name__.__eq__, ["readinto1"], true]

