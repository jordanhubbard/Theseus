spec: decimal_extra342
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal — power, logarithm, sqrt, and exp operations
# All string representations verified with Python 3.14.3 default context (prec=28)
# ---------------------------------------------------------------------------

invariant decimal.Decimal.ln.contains_value:
  description: "Decimal('2').ln().__str__() contains '0.6931' — natural log of 2"
  category: logarithm
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: ln
  method_chain: __str__
  method_chain_method: __contains__
  method_chain_args: ["0.6931"]
  expected: true

invariant decimal.Decimal.log10.of_ten:
  description: "Decimal('10').log10().__str__() == '1' — log base 10 of 10 is exactly 1"
  category: logarithm
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: log10
  method_chain: __str__
  method_chain_method: __eq__
  method_chain_args: ["1"]
  expected: true

invariant decimal.Decimal.pow.two_to_ten:
  description: "Decimal('2').__pow__(Decimal('10')).__str__() == '1024'"
  category: power
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: __pow__
  method_args: [["10"]]
  method_chain: __str__
  method_chain_method: __eq__
  method_chain_args: ["1024"]
  expected: true

invariant decimal.Decimal.pow.two_to_zero:
  description: "Decimal('2').__pow__(Decimal('0')).__str__() == '1' — any number to the zero power is 1"
  category: power
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: __pow__
  method_args: [["0"]]
  method_chain: __str__
  method_chain_method: __eq__
  method_chain_args: ["1"]
  expected: true

invariant decimal.Decimal.sqrt.hundred:
  description: "Decimal('100').sqrt().__str__() == '10' — square root of 100 is exactly 10"
  category: sqrt
  kind: python_call_eq
  function: Decimal
  args: ["100"]
  method: sqrt
  method_chain: __str__
  method_chain_method: __eq__
  method_chain_args: ["10"]
  expected: true

invariant decimal.Decimal.sqrt.two.contains_value:
  description: "Decimal('2').sqrt().__str__() contains '1.4142' — square root of 2"
  category: sqrt
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: sqrt
  method_chain: __str__
  method_chain_method: __contains__
  method_chain_args: ["1.4142"]
  expected: true

invariant decimal.Decimal.exp.one.contains_value:
  description: "Decimal('1').exp().__str__() contains '2.7182' — e^1 approximates Euler's number"
  category: exp
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: exp
  method_chain: __str__
  method_chain_method: __contains__
  method_chain_args: ["2.7182"]
  expected: true
