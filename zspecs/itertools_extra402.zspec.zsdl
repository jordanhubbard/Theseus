spec: itertools_extra402
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.accumulate.__qualname__ == 'accumulate' — accumulate is a C type; __qualname__ equals __name__ == 'accumulate'. Verified with Python 3.14.4."
    - "itertools.groupby.__qualname__ == 'groupby' — groupby is a C type; __qualname__ equals __name__ == 'groupby'. Verified with Python 3.14.4."
    - "itertools.count.__qualname__ == 'count' — count is a C type; __qualname__ equals __name__ == 'count'. Verified with Python 3.14.4."
    - "itertools.pairwise.__qualname__ == 'pairwise' — pairwise is a C type (added in 3.10); __qualname__ equals __name__ == 'pairwise'. Verified with Python 3.14.4."
    - "itertools.batched.__qualname__ == 'batched' — batched is a C type (added in 3.12); __qualname__ equals __name__ == 'batched'. Verified with Python 3.14.4."
    - "itertools.accumulate.__doc__.__class__.__name__ == 'str' — accumulate carries a plain string docstring. Verified with Python 3.14.4."
    - "itertools.groupby.__doc__.__class__.__name__ == 'str' — groupby carries a plain string docstring. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C type __qualname__ identity
#
# All iterator types in itertools are implemented as C types. For C types,
# __qualname__ equals __name__ — there is no outer class scope to prefix.
# This table covers accumulate, groupby, count, pairwise, and batched.
# ---------------------------------------------------------------------------

table itertools_extra402.type_qualname:
  description: "itertools C type __qualname__ values — equals __name__ for all C types; new to extra402"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsqn402

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_qualname_eq,
       "accumulate.__qualname__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__.__eq__('accumulate') == True — accumulate is a C type; __qualname__ equals __name__ == 'accumulate'; str.__eq__('accumulate') returns True; new to extra402"]
    - [groupby_qualname_eq,
       "groupby.__qualname__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__qualname__.__eq__('groupby') == True — groupby is a C type; __qualname__ equals __name__ == 'groupby'; str.__eq__('groupby') returns True; new to extra402"]
    - [count_qualname_eq,
       "count.__qualname__.__eq__",
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a C type; __qualname__ equals __name__ == 'count'; str.__eq__('count') returns True; new to extra402"]
    - [pairwise_qualname_eq,
       "pairwise.__qualname__.__eq__",
       ["pairwise"],
       true,
       "itertools.pairwise.__qualname__.__eq__('pairwise') == True — pairwise is a C type added in Python 3.10; __qualname__ equals __name__ == 'pairwise'; str.__eq__('pairwise') returns True; new to extra402"]
    - [batched_qualname_eq,
       "batched.__qualname__.__eq__",
       ["batched"],
       true,
       "itertools.batched.__qualname__.__eq__('batched') == True — batched is a C type added in Python 3.12; __qualname__ equals __name__ == 'batched'; str.__eq__('batched') returns True; new to extra402"]

# ---------------------------------------------------------------------------
# Table 2: itertools C type __doc__.__class__.__name__
#
# itertools.accumulate and itertools.groupby each carry a plain string
# docstring embedded in the C source. __doc__.__class__.__name__ is 'str'.
# ---------------------------------------------------------------------------

table itertools_extra402.type_doc_class_name:
  description: "itertools.accumulate and groupby __doc__.__class__.__name__ — plain string docstrings on C types; new to extra402"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdc402

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_doc_class_name_eq,
       "accumulate.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.accumulate.__doc__.__class__.__name__.__eq__('str') == True — accumulate carries a plain string docstring in C; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra402"]
    - [groupby_doc_class_name_eq,
       "groupby.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — groupby carries a plain string docstring in C; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra402"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra402
# ---------------------------------------------------------------------------

invariant itertools_extra402.accumulate_qualname:
  description: "itertools.accumulate.__qualname__ == 'accumulate' — C type; __qualname__ equals __name__; new to extra402"
  kind: python_call_eq
  function: accumulate.__qualname__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra402.groupby_qualname:
  description: "itertools.groupby.__qualname__ == 'groupby' — C type; __qualname__ equals __name__; new to extra402"
  kind: python_call_eq
  function: groupby.__qualname__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra402.count_qualname:
  description: "itertools.count.__qualname__ == 'count' — C type; __qualname__ equals __name__; new to extra402"
  kind: python_call_eq
  function: count.__qualname__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra402.pairwise_qualname:
  description: "itertools.pairwise.__qualname__ == 'pairwise' — C type added in Python 3.10; __qualname__ equals __name__; new to extra402"
  kind: python_call_eq
  function: pairwise.__qualname__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra402.batched_qualname:
  description: "itertools.batched.__qualname__ == 'batched' — C type added in Python 3.12; __qualname__ equals __name__; new to extra402"
  kind: python_call_eq
  function: batched.__qualname__.__eq__
  args: ["batched"]
  expected: true

invariant itertools_extra402.accumulate_doc_class_name:
  description: "itertools.accumulate.__doc__.__class__.__name__ == 'str' — plain string docstring on C type; new to extra402"
  kind: python_call_eq
  function: accumulate.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra402.groupby_doc_class_name:
  description: "itertools.groupby.__doc__.__class__.__name__ == 'str' — plain string docstring on C type; new to extra402"
  kind: python_call_eq
  function: groupby.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
