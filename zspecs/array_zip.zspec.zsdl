spec: array_zip
version: ">=1.0.0"
backend: node(array-zip)

docs: https://www.npmjs.com/package/array-zip

provenance:
  derived_from:
    - "array-zip README — https://www.npmjs.com/package/array-zip"
    - "Test vectors verified with array-zip via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-zip source"
  notes:
    - "array-zip is an npm package. Install: npm install array-zip"
    - "Zips two arrays together into an array of pairs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of [a, b] pairs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_zip.zip:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: azip

  columns: [id, args, expected]
  rows:
    - [numbers,  [[1, 2], [3, 4]],           [[1, 3], [2, 4]]]
    - [three,    [[1, 2, 3], [4, 5, 6]],     [[1, 4], [2, 5], [3, 6]]]
    - [mixed,    [["a", "b"], [1, 2]],        [["a", 1], ["b", 2]]]
