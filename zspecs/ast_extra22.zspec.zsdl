spec: ast_extra22
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "ast_extra21.zspec.zsdl — covers AST/__qualname__ and lengths for get_docstring/copy_location/increment_lineno/unparse/fix_missing_locations/walk"
    - "ast_extra20.zspec.zsdl — covers stmt-subclass and expr-subclass node __qualname__ tables; parse/dump/literal_eval __qualname__.__len__() via ast_extra21"
    - "ast_extra19.zspec.zsdl — covers walk/fix_missing_locations/copy_location/increment_lineno/get_docstring __qualname__.__eq__"
    - "ast_extra18.zspec.zsdl — covers parse/__qualname__.__eq__, dump/__qualname__.__eq__, literal_eval/__qualname__.__eq__"
    - "ast_extra16.zspec.zsdl — covers NodeVisitor/__qualname__.__eq__; NodeTransformer/__qualname__.__eq__"
  notes:
    - "This spec extends ast_extra21.zspec.zsdl."
    - "Focus: __qualname__ for ast.NodeVisitor.visit and ast.NodeTransformer.generic_visit (method __qualname__ includes class prefix); qualname lengths for parse/dump/literal_eval and these two methods."
    - "ast.NodeVisitor.visit.__qualname__ == 'NodeVisitor.visit' — no prior ast spec covers this method-level __qualname__ as a standalone __eq__ invariant."
    - "ast.NodeTransformer.generic_visit.__qualname__ == 'NodeTransformer.generic_visit' — no prior ast spec covers this method-level __qualname__."
    - "ast.parse.__qualname__.__len__() == 5 — no prior ast spec covers parse.__qualname__.__len__() as a standalone invariant."
    - "ast.dump.__qualname__.__len__() == 4 — no prior ast spec covers dump.__qualname__.__len__() as a standalone invariant."
    - "ast.literal_eval.__qualname__.__len__() == 12 — no prior ast spec covers literal_eval.__qualname__.__len__() as a standalone invariant."
    - "ast.NodeVisitor.visit.__qualname__.__len__() == 17 — 'NodeVisitor.visit' has 17 characters."
    - "ast.NodeTransformer.generic_visit.__qualname__.__len__() == 29 — 'NodeTransformer.generic_visit' has 29 characters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Method __qualname__ — NodeVisitor.visit, NodeTransformer.generic_visit
# (ast_extra22 namespace)
#
# ast_extra16 covers NodeVisitor/__qualname__ and NodeTransformer/__qualname__
# (class-level). Method-level qualnames (NodeVisitor.visit and
# NodeTransformer.generic_visit) include the class prefix and are not covered
# in any prior ast spec as standalone __eq__ invariants.
# ---------------------------------------------------------------------------

invariant ast_extra22.NodeVisitor_visit.qualname:
  description: "ast.NodeVisitor.visit.__qualname__ == 'NodeVisitor.visit'"
  category: method_qualnames
  kind: python_call_eq
  function: NodeVisitor.visit.__qualname__.__eq__
  args: ["NodeVisitor.visit"]
  expected: true

invariant ast_extra22.NodeTransformer_generic_visit.qualname:
  description: "ast.NodeTransformer.generic_visit.__qualname__ == 'NodeTransformer.generic_visit'"
  category: method_qualnames
  kind: python_call_eq
  function: NodeTransformer.generic_visit.__qualname__.__eq__
  args: ["NodeTransformer.generic_visit"]
  expected: true

# ---------------------------------------------------------------------------
# Method __qualname__.__len__() — NodeVisitor.visit, NodeTransformer.generic_visit
# (ast_extra22 namespace)
#
# No prior ast spec covers __qualname__.__len__() for these method objects.
# 'NodeVisitor.visit' has 17 characters; 'NodeTransformer.generic_visit' has 29.
# ---------------------------------------------------------------------------

invariant ast_extra22.NodeVisitor_visit.qualname_len:
  description: "ast.NodeVisitor.visit.__qualname__.__len__() == 17 — 'NodeVisitor.visit' has 17 characters"
  category: method_qualname_lengths
  kind: python_call_eq
  function: NodeVisitor.visit.__qualname__.__len__
  args: []
  expected: 17

invariant ast_extra22.NodeTransformer_generic_visit.qualname_len:
  description: "ast.NodeTransformer.generic_visit.__qualname__.__len__() == 29 — 'NodeTransformer.generic_visit' has 29 characters"
  category: method_qualname_lengths
  kind: python_call_eq
  function: NodeTransformer.generic_visit.__qualname__.__len__
  args: []
  expected: 29

# ---------------------------------------------------------------------------
# Function __qualname__.__len__() — parse, dump, literal_eval
# (ast_extra22 namespace)
#
# ast_extra18 covers parse/__qualname__.__eq__, dump/__qualname__.__eq__, and
# literal_eval/__qualname__.__eq__ in the ast_extra18 namespace.
# ast_extra21 covers __qualname__.__len__() for get_docstring/copy_location/
# increment_lineno/unparse/fix_missing_locations/walk — not for parse/dump/
# literal_eval. These lengths are new in the ast_extra22 namespace.
# ---------------------------------------------------------------------------

table ast_extra22.core_function_qualname_lens:
  description: "__qualname__.__len__() for core ast module functions"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: corefqlen

  columns: [id, function, args, expected]
  rows:
    - [parse,        parse.__qualname__.__len__,        [], 5]
    - [dump,         dump.__qualname__.__len__,          [], 4]
    - [literal_eval, literal_eval.__qualname__.__len__,  [], 12]
