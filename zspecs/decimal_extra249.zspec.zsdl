spec: decimal_extra249
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers decimal.Context attribute descriptor identity and decimal module limit constants."
    - "decimal.Context is a C class (_decimal extension); its instance attributes prec, rounding, Emax, Emin, capitals, clamp are all getset_descriptor objects on the class."
    - "type(decimal.Context.prec).__name__ == 'getset_descriptor' for all six C-backed attributes."
    - "decimal.Context does not expose 'traps' or 'flags' as class-level descriptors; these are instance-level SignalDict objects only."
    - "decimal.MAX_PREC == 999999999999999999 — the platform maximum precision for the _decimal C extension."
    - "decimal.MAX_EMAX == 999999999999999999 — the platform maximum value for Emax."
    - "decimal.MIN_EMIN == -999999999999999999 — the platform minimum value for Emin."
    - "decimal.MIN_ETINY == -1999999999999999997 — the minimum value of Etiny (= Emin - prec + 1 at maximum precision)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Context attribute descriptor __class__.__name__ identity
#
# prec, rounding, Emax, Emin, capitals, clamp are all getset_descriptor
# objects on the C Context class, providing getter/setter access to
# C struct fields. They are NOT member_descriptor (which uses direct
# struct offsets) — they use explicit getter/setter functions.
# ---------------------------------------------------------------------------

table decimal_extra249.context_attr_descriptor_class_names:
  description: "decimal.Context attribute descriptor __class__.__name__ — prec, rounding, Emax, Emin, capitals, clamp are 'getset_descriptor'; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: decxcadn249

  columns: [id, function, args, expected, description]
  rows:
    - [prec_class,
       "Context.prec.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "decimal.Context.prec.__class__.__name__.__eq__('getset_descriptor') == True — Context.prec is a C-level getset_descriptor providing getter/setter access to the precision field; its __class__.__name__ is 'getset_descriptor'; str.__eq__('getset_descriptor') returns True; new to extra249"]
    - [rounding_class,
       "Context.rounding.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "decimal.Context.rounding.__class__.__name__.__eq__('getset_descriptor') == True — Context.rounding is a C-level getset_descriptor providing getter/setter access to the rounding mode; its __class__.__name__ is 'getset_descriptor'; str.__eq__('getset_descriptor') returns True; new to extra249"]
    - [Emax_class,
       "Context.Emax.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "decimal.Context.Emax.__class__.__name__.__eq__('getset_descriptor') == True — Context.Emax is a C-level getset_descriptor providing getter/setter access to the maximum exponent; its __class__.__name__ is 'getset_descriptor'; str.__eq__('getset_descriptor') returns True; new to extra249"]
    - [Emin_class,
       "Context.Emin.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "decimal.Context.Emin.__class__.__name__.__eq__('getset_descriptor') == True — Context.Emin is a C-level getset_descriptor providing getter/setter access to the minimum exponent; its __class__.__name__ is 'getset_descriptor'; str.__eq__('getset_descriptor') returns True; new to extra249"]
    - [capitals_class,
       "Context.capitals.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "decimal.Context.capitals.__class__.__name__.__eq__('getset_descriptor') == True — Context.capitals is a C-level getset_descriptor controlling whether 'E' is uppercase in engineering notation; its __class__.__name__ is 'getset_descriptor'; str.__eq__('getset_descriptor') returns True; new to extra249"]
    - [clamp_class,
       "Context.clamp.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "decimal.Context.clamp.__class__.__name__.__eq__('getset_descriptor') == True — Context.clamp is a C-level getset_descriptor controlling clamped exponent behavior; its __class__.__name__ is 'getset_descriptor'; str.__eq__('getset_descriptor') returns True; new to extra249"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Context attribute descriptor __name__ identity
#
# Each getset_descriptor has a __name__ equal to the attribute name.
# ---------------------------------------------------------------------------

table decimal_extra249.context_attr_descriptor_names:
  description: "decimal.Context attribute descriptor __name__ identity — prec, rounding, Emax, Emin, capitals, clamp; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: decxcadn2_249

  columns: [id, function, args, expected, description]
  rows:
    - [prec_name,
       "Context.prec.__name__.__eq__",
       ["prec"],
       true,
       "decimal.Context.prec.__name__.__eq__('prec') == True — the getset_descriptor for the precision attribute is named 'prec'; str.__eq__('prec') returns True; new to extra249"]
    - [rounding_name,
       "Context.rounding.__name__.__eq__",
       ["rounding"],
       true,
       "decimal.Context.rounding.__name__.__eq__('rounding') == True — the getset_descriptor for the rounding mode attribute is named 'rounding'; str.__eq__('rounding') returns True; new to extra249"]
    - [Emax_name,
       "Context.Emax.__name__.__eq__",
       ["Emax"],
       true,
       "decimal.Context.Emax.__name__.__eq__('Emax') == True — the getset_descriptor for the maximum exponent attribute is named 'Emax'; str.__eq__('Emax') returns True; new to extra249"]
    - [Emin_name,
       "Context.Emin.__name__.__eq__",
       ["Emin"],
       true,
       "decimal.Context.Emin.__name__.__eq__('Emin') == True — the getset_descriptor for the minimum exponent attribute is named 'Emin'; str.__eq__('Emin') returns True; new to extra249"]
    - [capitals_name,
       "Context.capitals.__name__.__eq__",
       ["capitals"],
       true,
       "decimal.Context.capitals.__name__.__eq__('capitals') == True — the getset_descriptor for the capitals flag is named 'capitals'; str.__eq__('capitals') returns True; new to extra249"]
    - [clamp_name,
       "Context.clamp.__name__.__eq__",
       ["clamp"],
       true,
       "decimal.Context.clamp.__name__.__eq__('clamp') == True — the getset_descriptor for the clamp flag is named 'clamp'; str.__eq__('clamp') returns True; new to extra249"]

# ---------------------------------------------------------------------------
# Table 3: decimal module limit constants
#
# MAX_PREC, MAX_EMAX, MIN_EMIN, MIN_ETINY are platform-dependent integer
# constants representing the implementation limits of the _decimal C extension.
# On 64-bit platforms these are large integers as shown below.
# ---------------------------------------------------------------------------

table decimal_extra249.module_limit_constants:
  description: "decimal module limit constants — MAX_PREC, MAX_EMAX, MIN_EMIN, MIN_ETINY values on 64-bit; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: decxmlc249

  columns: [id, function, args, expected, description]
  rows:
    - [max_prec_eq,
       "MAX_PREC.__eq__",
       [999999999999999999],
       true,
       "decimal.MAX_PREC.__eq__(999999999999999999) == True — MAX_PREC is the platform maximum precision for the _decimal C extension; on 64-bit systems this is 999999999999999999; int.__eq__(999999999999999999) returns True; new to extra249"]
    - [max_emax_eq,
       "MAX_EMAX.__eq__",
       [999999999999999999],
       true,
       "decimal.MAX_EMAX.__eq__(999999999999999999) == True — MAX_EMAX is the maximum allowed value for Context.Emax on 64-bit systems; int.__eq__(999999999999999999) returns True; new to extra249"]
    - [min_emin_eq,
       "MIN_EMIN.__eq__",
       [-999999999999999999],
       true,
       "decimal.MIN_EMIN.__eq__(-999999999999999999) == True — MIN_EMIN is the minimum allowed value for Context.Emin on 64-bit systems; int.__eq__(-999999999999999999) returns True; new to extra249"]
    - [min_etiny_eq,
       "MIN_ETINY.__eq__",
       [-1999999999999999997],
       true,
       "decimal.MIN_ETINY.__eq__(-1999999999999999997) == True — MIN_ETINY is the minimum value of Etiny (= Emin - prec + 1 at maximum precision); on 64-bit this is -1999999999999999997; int.__eq__(-1999999999999999997) returns True; new to extra249"]
    - [max_prec_class,
       "MAX_PREC.__class__.__name__.__eq__",
       ["int"],
       true,
       "decimal.MAX_PREC.__class__.__name__.__eq__('int') == True — MAX_PREC is a Python int object, not a C-level descriptor; its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra249"]
    - [max_emax_class,
       "MAX_EMAX.__class__.__name__.__eq__",
       ["int"],
       true,
       "decimal.MAX_EMAX.__class__.__name__.__eq__('int') == True — MAX_EMAX is a Python int constant in the decimal module; its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra249"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra249
# ---------------------------------------------------------------------------

invariant decimal_extra249.context_prec_is_getset_descriptor:
  description: "decimal.Context.prec.__class__.__name__ == 'getset_descriptor' — Context.prec uses C getter/setter functions, not a struct member offset; new to extra249"
  kind: python_call_eq
  function: Context.prec.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant decimal_extra249.context_rounding_is_getset_descriptor:
  description: "decimal.Context.rounding.__class__.__name__ == 'getset_descriptor' — Context.rounding controls how results are rounded; new to extra249"
  kind: python_call_eq
  function: Context.rounding.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant decimal_extra249.context_emax_is_getset_descriptor:
  description: "decimal.Context.Emax.__class__.__name__ == 'getset_descriptor' — Context.Emax controls the maximum exponent for normal numbers; new to extra249"
  kind: python_call_eq
  function: Context.Emax.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant decimal_extra249.context_emin_is_getset_descriptor:
  description: "decimal.Context.Emin.__class__.__name__ == 'getset_descriptor' — Context.Emin controls the minimum exponent for normal numbers; new to extra249"
  kind: python_call_eq
  function: Context.Emin.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant decimal_extra249.context_capitals_is_getset_descriptor:
  description: "decimal.Context.capitals.__class__.__name__ == 'getset_descriptor' — Context.capitals controls whether 'E' is uppercased in engineering-notation output; new to extra249"
  kind: python_call_eq
  function: Context.capitals.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant decimal_extra249.context_clamp_is_getset_descriptor:
  description: "decimal.Context.clamp.__class__.__name__ == 'getset_descriptor' — Context.clamp enables IEEE 754-2008 clamped exponent mode; new to extra249"
  kind: python_call_eq
  function: Context.clamp.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant decimal_extra249.context_prec_name:
  description: "decimal.Context.prec.__name__ == 'prec' — the getset_descriptor for precision is named 'prec'; new to extra249"
  kind: python_call_eq
  function: Context.prec.__name__.__eq__
  args: ["prec"]
  expected: true

invariant decimal_extra249.max_prec_value:
  description: "decimal.MAX_PREC == 999999999999999999 — platform maximum precision for _decimal C extension on 64-bit systems; new to extra249"
  kind: python_call_eq
  function: MAX_PREC.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra249.max_emax_value:
  description: "decimal.MAX_EMAX == 999999999999999999 — platform maximum value for Context.Emax on 64-bit systems; new to extra249"
  kind: python_call_eq
  function: MAX_EMAX.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra249.min_emin_value:
  description: "decimal.MIN_EMIN == -999999999999999999 — platform minimum value for Context.Emin on 64-bit systems; new to extra249"
  kind: python_call_eq
  function: MIN_EMIN.__eq__
  args: [-999999999999999999]
  expected: true

invariant decimal_extra249.min_etiny_value:
  description: "decimal.MIN_ETINY == -1999999999999999997 — minimum Etiny value at maximum precision on 64-bit systems; new to extra249"
  kind: python_call_eq
  function: MIN_ETINY.__eq__
  args: [-1999999999999999997]
  expected: true
