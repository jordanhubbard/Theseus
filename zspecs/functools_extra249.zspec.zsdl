spec: functools_extra249
version: ">=3.8"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra248.zspec.zsdl — covers partialmethod and WRAPPER_UPDATES identity"
    - "functools_extra247.zspec.zsdl — covers cmp_to_key and WRAPPER_ASSIGNMENTS identity"
    - "functools_extra246.zspec.zsdl — covers wraps and update_wrapper identity"
    - "functools_extra.zspec.zsdl — covers reduce/partial/cached_property/cmp_to_key/total_ordering/singledispatch names and modules"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, and callable type checks"
  notes:
    - "This spec covers functools.singledispatchmethod class identity and functools.cache function identity."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' (len=20) — singledispatchmethod is a Python class in Lib/functools.py added in Python 3.8. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools' (len=9) — singledispatchmethod is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' (len=20) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__class__.__name__ == 'type' — singledispatchmethod is a class; its metaclass is type. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod inherits directly from object. Verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache' (len=5) — cache is a plain Python function in Lib/functools.py added in Python 3.9. Verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools' (len=9) — cache is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cache.__class__.__name__ == 'function' — cache is a plain function, not a class or descriptor. Verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache' (len=5) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatchmethod class identity contracts
#
# functools.singledispatchmethod.__name__ == 'singledispatchmethod' (len=20)
# functools.singledispatchmethod.__module__ == 'functools' (len=9)
# functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' (len=20)
# functools.singledispatchmethod.__class__.__name__ == 'type'
# functools.singledispatchmethod.__name__.__len__() == 20
#
# singledispatchmethod is a Python class in Lib/functools.py (added Python 3.8). New to extra249.
# ---------------------------------------------------------------------------

table functools_extra249.sdmeth249_identity:
  description: "functools.singledispatchmethod class identity: name, module, qualname, class; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: sdmeth249

  columns: [id, function, args, expected, description]
  rows:
    - [sdm_name_eq,
       singledispatchmethod.__name__.__eq__,
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True — singledispatchmethod is a Python class in Lib/functools.py; __name__ is 'singledispatchmethod' (len=20); new to extra249"]
    - [sdm_name_len_20,
       singledispatchmethod.__name__.__len__,
       [],
       20,
       "functools.singledispatchmethod.__name__.__len__() == 20 — 'singledispatchmethod' has exactly 20 characters; str.__len__() returns 20; new to extra249"]
    - [sdm_module_eq,
       singledispatchmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__.__eq__('functools') == True — singledispatchmethod is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra249"]
    - [sdm_module_len_9,
       singledispatchmethod.__module__.__len__,
       [],
       9,
       "functools.singledispatchmethod.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra249"]
    - [sdm_qualname_eq,
       singledispatchmethod.__qualname__.__eq__,
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__qualname__.__eq__('singledispatchmethod') == True — __qualname__ is 'singledispatchmethod' (len=20); same as __name__ for top-level class; new to extra249"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatchmethod bases and class type contracts
#
# functools.singledispatchmethod.__bases__[0].__name__ == 'object'
# functools.singledispatchmethod.__class__.__name__ == 'type'
# functools.singledispatchmethod.__qualname__.__len__() == 20
# functools.singledispatchmethod.__module__.__contains__('functools') == True
# functools.singledispatchmethod.__name__.__contains__('dispatch') == True
#
# New to extra249.
# ---------------------------------------------------------------------------

table functools_extra249.sdmeth249_bases:
  description: "functools.singledispatchmethod bases, class type, qualname len, content checks; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: sdmeth249b

  columns: [id, function, args, expected, description]
  rows:
    - [sdm_bases_0_is_object,
       "singledispatchmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.singledispatchmethod.__bases__[0].__name__.__eq__('object') == True — singledispatchmethod inherits directly from object; __bases__[0] is object; new to extra249"]
    - [sdm_class_is_type,
       singledispatchmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.singledispatchmethod.__class__.__name__.__eq__('type') == True — singledispatchmethod is a class; its metaclass is the built-in type; new to extra249"]
    - [sdm_qualname_len_20,
       singledispatchmethod.__qualname__.__len__,
       [],
       20,
       "functools.singledispatchmethod.__qualname__.__len__() == 20 — 'singledispatchmethod' has exactly 20 characters; str.__len__() returns 20; new to extra249"]
    - [sdm_module_contains_functools,
       singledispatchmethod.__module__.__contains__,
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__.__contains__('functools') == True — 'functools' contains the substring 'functools'; new to extra249"]
    - [sdm_name_contains_dispatch,
       singledispatchmethod.__name__.__contains__,
       ["dispatch"],
       true,
       "functools.singledispatchmethod.__name__.__contains__('dispatch') == True — 'singledispatchmethod' contains 'dispatch'; new to extra249"]

# ---------------------------------------------------------------------------
# Table 3: functools.cache function identity contracts
#
# functools.cache.__name__ == 'cache' (len=5)
# functools.cache.__module__ == 'functools' (len=9)
# functools.cache.__class__.__name__ == 'function'
# functools.cache.__qualname__ == 'cache' (len=5)
# functools.cache.__name__.__len__() == 5
#
# cache is a plain Python function in Lib/functools.py (added Python 3.9). New to extra249.
# ---------------------------------------------------------------------------

table functools_extra249.cache249_identity:
  description: "functools.cache function identity: name, module, class, qualname; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: cache249

  columns: [id, function, args, expected, description]
  rows:
    - [cache_name_eq,
       cache.__name__.__eq__,
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — cache is a plain Python function in Lib/functools.py; __name__ is 'cache' (len=5); new to extra249"]
    - [cache_name_len_5,
       cache.__name__.__len__,
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — 'cache' has exactly 5 characters; str.__len__() returns 5; new to extra249"]
    - [cache_module_eq,
       cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra249"]
    - [cache_module_len_9,
       cache.__module__.__len__,
       [],
       9,
       "functools.cache.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra249"]
    - [cache_class_is_function,
       cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.cache.__class__.__name__.__eq__('function') == True — cache is a plain function, not a class; __class__.__name__ is 'function' (len=8); new to extra249"]

# ---------------------------------------------------------------------------
# Table 4: functools.cache qualname and content checks
#
# functools.cache.__qualname__ == 'cache' (len=5)
# functools.cache.__class__.__name__.__len__() == 8
# functools.cache.__class__.__module__ == 'builtins'
# functools.singledispatchmethod.__bases__[0].__name__.__len__() == 6
# functools.singledispatchmethod.__class__.__name__.__len__() == 4
#
# New to extra249.
# ---------------------------------------------------------------------------

table functools_extra249.cache249_extra:
  description: "functools.cache qualname, class module; singledispatchmethod base len checks; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: cache249x

  columns: [id, function, args, expected, description]
  rows:
    - [cache_qualname_eq,
       cache.__qualname__.__eq__,
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — __qualname__ is 'cache' (len=5); same as __name__ for top-level function; new to extra249"]
    - [cache_class_name_len_8,
       cache.__class__.__name__.__len__,
       [],
       8,
       "functools.cache.__class__.__name__.__len__() == 8 — 'function' has exactly 8 characters; str.__len__() returns 8; new to extra249"]
    - [cache_class_module_builtins,
       cache.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.cache.__class__.__module__.__eq__('builtins') == True — function type is defined in the builtins module; new to extra249"]
    - [sdm_bases_0_len_6,
       "singledispatchmethod.__bases__[0].__name__.__len__",
       [],
       6,
       "functools.singledispatchmethod.__bases__[0].__name__.__len__() == 6 — 'object' has exactly 6 characters; new to extra249"]
    - [sdm_class_name_len_4,
       singledispatchmethod.__class__.__name__.__len__,
       [],
       4,
       "functools.singledispatchmethod.__class__.__name__.__len__() == 4 — 'type' has exactly 4 characters; str.__len__() returns 4; new to extra249"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra249
# ---------------------------------------------------------------------------

invariant functools_extra249.sdm_name_eq:
  description: "functools.singledispatchmethod.__name__ == 'singledispatchmethod' (len=20); new to extra249"
  kind: python_call_eq
  function: singledispatchmethod.__name__.__eq__
  args: ["singledispatchmethod"]
  expected: true

invariant functools_extra249.sdm_module_eq:
  description: "functools.singledispatchmethod.__module__ == 'functools' — defined in Lib/functools.py; new to extra249"
  kind: python_call_eq
  function: singledispatchmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra249.sdm_bases_0_is_object:
  description: "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — inherits from object; new to extra249"
  kind: python_call_eq
  function: "singledispatchmethod.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra249.sdm_class_is_type:
  description: "functools.singledispatchmethod.__class__.__name__ == 'type' — singledispatchmethod is a class; new to extra249"
  kind: python_call_eq
  function: singledispatchmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra249.sdm_qualname_eq:
  description: "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' (len=20); new to extra249"
  kind: python_call_eq
  function: singledispatchmethod.__qualname__.__eq__
  args: ["singledispatchmethod"]
  expected: true

invariant functools_extra249.sdm_name_len_20:
  description: "functools.singledispatchmethod.__name__.__len__() == 20; new to extra249"
  kind: python_call_eq
  function: singledispatchmethod.__name__.__len__
  args: []
  expected: 20

invariant functools_extra249.cache_name_eq:
  description: "functools.cache.__name__ == 'cache' (len=5); new to extra249"
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra249.cache_module_eq:
  description: "functools.cache.__module__ == 'functools' — defined in Lib/functools.py; new to extra249"
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra249.cache_class_is_function:
  description: "functools.cache.__class__.__name__ == 'function' — cache is a plain Python function, not a class; new to extra249"
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra249.cache_qualname_eq:
  description: "functools.cache.__qualname__ == 'cache' (len=5); new to extra249"
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra249.cache_name_len_5:
  description: "functools.cache.__name__.__len__() == 5; new to extra249"
  kind: python_call_eq
  function: cache.__name__.__len__
  args: []
  expected: 5

invariant functools_extra249.sdm_name_contains_dispatch:
  description: "functools.singledispatchmethod.__name__ contains 'dispatch'; new to extra249"
  kind: python_call_eq
  function: singledispatchmethod.__name__.__contains__
  args: ["dispatch"]
  expected: true
