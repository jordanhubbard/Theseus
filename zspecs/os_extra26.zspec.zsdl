spec: os_extra26
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os_extra25.zspec.zsdl — covers prior os module attributes"
  notes:
    - "This spec extends os.zspec.zsdl and all prior os_extra specs through os_extra25.zspec.zsdl."
    - "os.error is a direct alias for the built-in OSError; os.error is OSError evaluates True."
    - "os.error.__name__ == 'OSError' — the alias exposes the canonical class name; verified at runtime."
    - "os.error.__bases__[0].__name__ == 'Exception' — OSError inherits directly from Exception; verified at runtime."
    - "os.stat_result, os.terminal_size, os.times_result, os.uname_result all inherit from tuple; verified at runtime."
    - "os.stat_result.__bases__[0].__name__ == 'tuple' — stat_result is a named tuple subtype; verified at runtime."
    - "os.terminal_size.__bases__[0].__name__ == 'tuple' — terminal_size is a named tuple subtype; verified at runtime."
    - "os.times_result.__bases__[0].__name__ == 'tuple' — times_result is a named tuple subtype; verified at runtime."
    - "os.uname_result.__bases__[0].__name__ == 'tuple' — uname_result is a named tuple subtype; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Base class names for os result/error types
#
# The four os result structs (stat_result, terminal_size, times_result,
# uname_result) all inherit from tuple — they are C-level named-tuple
# subtypes. os.error is an alias for the built-in OSError, which inherits
# from Exception. This table captures all five in a single grouped check.
# ---------------------------------------------------------------------------

table os_extra26.result_class_bases:
  description: "__bases__[0].__name__ for os result classes and os.error"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: osbase26

  columns: [id, function, args, expected]
  rows:
    - [error,        "error.__bases__[0].__name__.__eq__",        ["Exception"], true]
    - [stat_result,  "stat_result.__bases__[0].__name__.__eq__",  ["tuple"],     true]
    - [terminal_size,"terminal_size.__bases__[0].__name__.__eq__",["tuple"],     true]
    - [times_result, "times_result.__bases__[0].__name__.__eq__", ["tuple"],     true]
    - [uname_result, "uname_result.__bases__[0].__name__.__eq__", ["tuple"],     true]

# ---------------------------------------------------------------------------
# Standalone invariants — os.error alias and result class __name__ checks
#
# os.error is a well-known alias for OSError; verifying __name__ confirms
# the alias points to the canonical class. The result-class __name__ checks
# confirm each C-level type is registered under its expected Python name.
# ---------------------------------------------------------------------------

invariant os_extra26.error.name:
  description: "os.error.__name__ == 'OSError' — os.error is an alias for the built-in OSError"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant os_extra26.stat_result.name:
  description: "os.stat_result.__name__ == 'stat_result' — C-level struct exposed as a named-tuple subtype"
  category: class_identity
  kind: python_call_eq
  function: stat_result.__name__.__eq__
  args: ["stat_result"]
  expected: true

invariant os_extra26.terminal_size.name:
  description: "os.terminal_size.__name__ == 'terminal_size' — named-tuple subtype for terminal dimensions"
  category: class_identity
  kind: python_call_eq
  function: terminal_size.__name__.__eq__
  args: ["terminal_size"]
  expected: true

invariant os_extra26.times_result.name:
  description: "os.times_result.__name__ == 'times_result' — named-tuple subtype for os.times() output"
  category: class_identity
  kind: python_call_eq
  function: times_result.__name__.__eq__
  args: ["times_result"]
  expected: true

invariant os_extra26.uname_result.name:
  description: "os.uname_result.__name__ == 'uname_result' — named-tuple subtype for os.uname() output"
  category: class_identity
  kind: python_call_eq
  function: uname_result.__name__.__eq__
  args: ["uname_result"]
  expected: true
