spec: asyncio_extra2506
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __add__, __sub__, __mul__ arithmetic operator dict-presence checks."
    - "asyncio.Queue, asyncio.Task, asyncio.Future, asyncio.Lock, asyncio.Event define no arithmetic operators."
    - "__dict__.__contains__ returns False for __add__, __sub__, __mul__ on all five classes."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue — arithmetic operator dict-presence
# ---------------------------------------------------------------------------

table asyncio_extra2506.queue_arith_ops:
  description: "asyncio.Queue.__dict__ contains no arithmetic operators (__add__, __sub__, __mul__); all __dict__.__contains__ calls return False; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2506

  columns: [id, function, args, expected]
  rows:
    - ["as2506001", asyncio.Queue.__dict__.__contains__, ["__add__"], false]
    - ["as2506002", asyncio.Queue.__dict__.__contains__, ["__sub__"], false]
    - ["as2506003", asyncio.Queue.__dict__.__contains__, ["__mul__"], false]

