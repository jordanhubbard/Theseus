spec: operator_extra13
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra12.zspec.zsdl."
    - "operator_extra12 covers: methodcaller with extra positional args; itemgetter with multiple indices; attrgetter with dotted path; __name__ for xor/floordiv/mod/setitem/delitem."
    - "operator_extra9 covers: gt/__name__; le/__name__; ge/__name__; and_/__name__; or_/__name__ as standalone __eq__ invariants."
    - "NOT yet covered as __qualname__ invariants: add/sub/mul/truediv/pow/neg/pos/abs/eq/ne/lt/gt."
    - "operator.add.__qualname__ == 'add' — qualname matches unqualified name for module-level C builtins."
    - "operator.sub.__qualname__ == 'sub'; operator.mul.__qualname__ == 'mul'; operator.truediv.__qualname__ == 'truediv'."
    - "operator.pow.__qualname__ == 'pow'; operator.neg.__qualname__ == 'neg'; operator.pos.__qualname__ == 'pos'."
    - "operator.abs.__qualname__ == 'abs'; operator.eq.__qualname__ == 'eq'; operator.ne.__qualname__ == 'ne'."
    - "operator.lt.__qualname__ == 'lt'; operator.gt.__qualname__ == 'gt'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for arithmetic operators: add, sub, mul, truediv, pow
#
# operator_extra9 and earlier specs check __name__ for selected operators.
# No prior spec records __qualname__ for these arithmetic functions.
# For C-implemented module-level functions __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant operator_extra13.add.qualname:
  description: "operator.add.__qualname__ == 'add'"
  category: function_qualnames
  kind: python_call_eq
  function: add.__qualname__.__eq__
  args: ["add"]
  expected: true

invariant operator_extra13.sub.qualname:
  description: "operator.sub.__qualname__ == 'sub'"
  category: function_qualnames
  kind: python_call_eq
  function: sub.__qualname__.__eq__
  args: ["sub"]
  expected: true

invariant operator_extra13.mul.qualname:
  description: "operator.mul.__qualname__ == 'mul'"
  category: function_qualnames
  kind: python_call_eq
  function: mul.__qualname__.__eq__
  args: ["mul"]
  expected: true

invariant operator_extra13.truediv.qualname:
  description: "operator.truediv.__qualname__ == 'truediv'"
  category: function_qualnames
  kind: python_call_eq
  function: truediv.__qualname__.__eq__
  args: ["truediv"]
  expected: true

invariant operator_extra13.pow.qualname:
  description: "operator.pow.__qualname__ == 'pow'"
  category: function_qualnames
  kind: python_call_eq
  function: pow.__qualname__.__eq__
  args: ["pow"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for unary operators: neg, pos, abs
#
# No prior spec records __qualname__ for neg, pos, or abs as standalone
# __eq__ invariants.
# ---------------------------------------------------------------------------

invariant operator_extra13.neg.qualname:
  description: "operator.neg.__qualname__ == 'neg'"
  category: function_qualnames
  kind: python_call_eq
  function: neg.__qualname__.__eq__
  args: ["neg"]
  expected: true

invariant operator_extra13.pos.qualname:
  description: "operator.pos.__qualname__ == 'pos'"
  category: function_qualnames
  kind: python_call_eq
  function: pos.__qualname__.__eq__
  args: ["pos"]
  expected: true

invariant operator_extra13.abs.qualname:
  description: "operator.abs.__qualname__ == 'abs'"
  category: function_qualnames
  kind: python_call_eq
  function: abs.__qualname__.__eq__
  args: ["abs"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for comparison operators: eq, ne, lt, gt
#
# operator_extra9 covers gt/__name__, and no prior spec records __qualname__
# for the comparison functions eq, ne, lt, or gt.
# ---------------------------------------------------------------------------

invariant operator_extra13.eq.qualname:
  description: "operator.eq.__qualname__ == 'eq'"
  category: function_qualnames
  kind: python_call_eq
  function: eq.__qualname__.__eq__
  args: ["eq"]
  expected: true

invariant operator_extra13.ne.qualname:
  description: "operator.ne.__qualname__ == 'ne'"
  category: function_qualnames
  kind: python_call_eq
  function: ne.__qualname__.__eq__
  args: ["ne"]
  expected: true

invariant operator_extra13.lt.qualname:
  description: "operator.lt.__qualname__ == 'lt'"
  category: function_qualnames
  kind: python_call_eq
  function: lt.__qualname__.__eq__
  args: ["lt"]
  expected: true

invariant operator_extra13.gt.qualname:
  description: "operator.gt.__qualname__ == 'gt'"
  category: function_qualnames
  kind: python_call_eq
  function: gt.__qualname__.__eq__
  args: ["gt"]
  expected: true
