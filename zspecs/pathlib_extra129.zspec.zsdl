spec: pathlib_extra129
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePosixPath and pathlib.PureWindowsPath class identity attributes not yet covered."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (len=13)."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (len=15)."
    - "pathlib.PurePosixPath.__module__ == 'pathlib' (len=7)."
    - "pathlib.PureWindowsPath.__module__ == 'pathlib' (len=7)."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (len=8)."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (len=8)."
    - "pathlib.PurePosixPath.__mro__.__len__() == 3 (PurePosixPath, PurePath, object)."
    - "pathlib.PureWindowsPath.__mro__.__len__() == 3 (PureWindowsPath, PurePath, object)."
    - "pathlib.PurePosixPath.__mro__[1].__name__ == 'PurePath' and __mro__[2].__name__ == 'object'."
    - "pathlib.PureWindowsPath.__mro__[1].__name__ == 'PurePath' and __mro__[2].__name__ == 'object'."
    - "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath' (qualname equals __name__ for top-level classes)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath class identity: __name__, __module__, __qualname__
# PurePosixPath is a pure POSIX path (forward slashes). It is a direct
# subclass of PurePath only — single inheritance, shallow MRO of length 3.
# __name__ == 'PurePosixPath' (13 chars), __module__ == 'pathlib' (7 chars).
# __qualname__ == __name__ because PurePosixPath is a top-level class.
# ---------------------------------------------------------------------------

table pathlib_extra129.PurePosixPath_name_module_qualname:
  description: "pathlib.PurePosixPath class identity: __name__=='PurePosixPath'(13), __module__=='pathlib'(7), __qualname__=='PurePosixPath'(13)"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibppx129a

  columns: [id, function, args, expected, description]
  rows:
    - [ppx_name_eq,      PurePosixPath.__name__.__eq__,        ["PurePosixPath"], true,  "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (13 chars; PurePosixPath is the platform-independent POSIX path class; it uses forward-slash separators regardless of OS)"]
    - [ppx_name_len,     PurePosixPath.__name__.__len__,       [],                13,    "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath': 'Pure'(4)+'Posix'(5)+'Path'(4)==13)"]
    - [ppx_mod_eq,       PurePosixPath.__module__.__eq__,      ["pathlib"],       true,  "pathlib.PurePosixPath.__module__ == 'pathlib' (7 chars; PurePosixPath is defined in the pathlib module)"]
    - [ppx_mod_len,      PurePosixPath.__module__.__len__,     [],                7,     "pathlib.PurePosixPath.__module__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [ppx_qn_eq,        PurePosixPath.__qualname__.__eq__,    ["PurePosixPath"], true,  "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath' (13 chars; for a top-level class, __qualname__ equals __name__ — there is no enclosing class or function scope)"]
    - [ppx_name_has_posix, PurePosixPath.__name__.__contains__, ["Posix"],        true,  "pathlib.PurePosixPath.__name__.__contains__('Posix') == True ('PurePosixPath' contains the substring 'Posix' identifying it as the POSIX-specific pure path class)"]
    - [ppx_name_has_pure, PurePosixPath.__name__.__contains__, ["Pure"],          true,  "pathlib.PurePosixPath.__name__.__contains__('Pure') == True ('PurePosixPath' starts with 'Pure' identifying it as a pure path class that does not touch the filesystem)"]
    - [ppx_mod_ne_pathlib2, PurePosixPath.__module__.__eq__,  ["pathlib2"],      false, "pathlib.PurePosixPath.__module__ != 'pathlib2' (module is 'pathlib', not 'pathlib2' which is the backport package for Python 2)"]

# ---------------------------------------------------------------------------
# pathlib.PureWindowsPath class identity: __name__, __module__, __qualname__
# PureWindowsPath is a pure Windows path (backslash separators, drive letters).
# Also a direct subclass of PurePath only — single inheritance, MRO length 3.
# __name__ == 'PureWindowsPath' (15 chars), __module__ == 'pathlib' (7 chars).
# PureWindowsPath name is 2 chars longer than PurePosixPath: 'Windows'(7) vs 'Posix'(5).
# ---------------------------------------------------------------------------

table pathlib_extra129.PureWindowsPath_name_module_qualname:
  description: "pathlib.PureWindowsPath class identity: __name__=='PureWindowsPath'(15), __module__=='pathlib'(7), __qualname__=='PureWindowsPath'(15)"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibppx129b

  columns: [id, function, args, expected, description]
  rows:
    - [pwp_name_eq,      PureWindowsPath.__name__.__eq__,       ["PureWindowsPath"], true,  "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (15 chars; PureWindowsPath is the platform-independent Windows path class using backslash separators and drive letter support)"]
    - [pwp_name_len,     PureWindowsPath.__name__.__len__,      [],                  15,    "pathlib.PureWindowsPath.__name__.__len__() == 15 ('Pure'(4)+'Windows'(7)+'Path'(4)==15; 2 chars longer than PurePosixPath at 13 because 'Windows'(7) > 'Posix'(5))"]
    - [pwp_mod_eq,       PureWindowsPath.__module__.__eq__,     ["pathlib"],         true,  "pathlib.PureWindowsPath.__module__ == 'pathlib' (7 chars; PureWindowsPath is defined in the pathlib module; same __module__ as PurePosixPath)"]
    - [pwp_mod_len,      PureWindowsPath.__module__.__len__,    [],                  7,     "pathlib.PureWindowsPath.__module__.__len__() == 7 ('pathlib' has 7 characters; same as PurePosixPath.__module__.__len__)"]
    - [pwp_qn_eq,        PureWindowsPath.__qualname__.__eq__,   ["PureWindowsPath"], true,  "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath' (15 chars; for a top-level class, __qualname__ equals __name__)"]
    - [pwp_name_has_win, PureWindowsPath.__name__.__contains__, ["Windows"],         true,  "pathlib.PureWindowsPath.__name__.__contains__('Windows') == True ('PureWindowsPath' contains the substring 'Windows' identifying it as the Windows-specific pure path class)"]
    - [pwp_name_ne_ppx,  PureWindowsPath.__name__.__eq__,       ["PurePosixPath"],  false, "pathlib.PureWindowsPath.__name__ != 'PurePosixPath' (the two pure path classes have distinct names: 'PureWindowsPath' vs 'PurePosixPath')"]
    - [pwp_name_gt_ppx,  PureWindowsPath.__name__.__len__.__gt__, [13],             true,  "len('PureWindowsPath') > len('PurePosixPath') (15 > 13; PureWindowsPath name is 2 chars longer because 'Windows'(7) > 'Posix'(5))"]

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath and PureWindowsPath MRO and __bases__ structure
# Both have identical MRO structure: [Subclass, PurePath, object] (length 3).
# Both have exactly one direct base: PurePath.
# __bases__[0].__name__ == 'PurePath' (8 chars) for both.
# MRO[1].__name__ == 'PurePath', MRO[2].__name__ == 'object' for both.
# ---------------------------------------------------------------------------

table pathlib_extra129.PurePosixPath_PureWindowsPath_mro_bases:
  description: "pathlib.PurePosixPath and PureWindowsPath MRO and __bases__ structure: both have __mro__.__len__()==3, __bases__.__len__()==1, __bases__[0].__name__=='PurePath'(8); MRO[1]=='PurePath', MRO[2]=='object'"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibppx129c

  columns: [id, function, args, expected, description]
  rows:
    - [ppx_mro_len,      PurePosixPath.__mro__.__len__,               [],           3,     "pathlib.PurePosixPath.__mro__.__len__() == 3 (MRO: [PurePosixPath, PurePath, object]; single inheritance means the MRO has exactly 3 entries)"]
    - [ppx_bases_len,    PurePosixPath.__bases__.__len__,             [],           1,     "pathlib.PurePosixPath.__bases__.__len__() == 1 (PurePosixPath has exactly one direct base: PurePath; it uses single inheritance)"]
    - [ppx_base0_eq,     "PurePosixPath.__bases__[0].__name__.__eq__",  ["PurePath"], true,  "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (8 chars; PurePath is the sole direct base of PurePosixPath; it provides the platform-agnostic pure path operations)"]
    - [ppx_mro1_eq,      "PurePosixPath.__mro__[1].__name__.__eq__",    ["PurePath"], true,  "pathlib.PurePosixPath.__mro__[1].__name__ == 'PurePath' (8 chars; MRO position 1 is PurePath, the direct superclass)"]
    - [ppx_mro2_eq,      "PurePosixPath.__mro__[2].__name__.__eq__",    ["object"],   true,  "pathlib.PurePosixPath.__mro__[2].__name__ == 'object' (6 chars; MRO position 2 is object, the ultimate Python base class)"]
    - [pwp_mro_len,      PureWindowsPath.__mro__.__len__,             [],           3,     "pathlib.PureWindowsPath.__mro__.__len__() == 3 (identical MRO length to PurePosixPath; both are single-inheritance subclasses of PurePath)"]
    - [pwp_bases_len,    PureWindowsPath.__bases__.__len__,           [],           1,     "pathlib.PureWindowsPath.__bases__.__len__() == 1 (PureWindowsPath also has exactly one direct base: PurePath)"]
    - [pwp_base0_eq,     "PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"], true, "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (8 chars; PurePath is the sole direct base of PureWindowsPath, same as PurePosixPath)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra129.PurePosixPath.name_eq:
  description: "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (13 chars; 'Pure'(4)+'Posix'(5)+'Path'(4)==13; PurePosixPath provides pure POSIX path manipulation without accessing the filesystem; it can be used on any OS to work with POSIX-style paths; no prior pathlib spec asserts PurePosixPath.__name__ equality); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra129.PureWindowsPath.name_eq:
  description: "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (15 chars; 'Pure'(4)+'Windows'(7)+'Path'(4)==15; PureWindowsPath provides pure Windows path manipulation without accessing the filesystem; it handles backslash separators and drive letters; no prior pathlib spec asserts PureWindowsPath.__name__ equality); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__name__.__eq__
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra129.PurePosixPath.module_eq_pathlib:
  description: "pathlib.PurePosixPath.__module__ == 'pathlib' (7 chars; PurePosixPath is defined in the pathlib module; __module__ identifies the module where the class is defined; no prior pathlib spec asserts PurePosixPath.__module__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra129.PurePosixPath.mro_len_3:
  description: "pathlib.PurePosixPath.__mro__.__len__() == 3 (MRO is [PurePosixPath, PurePath, object]; PurePosixPath uses single inheritance from PurePath, which itself inherits only from object; this gives a minimal MRO of length 3; no prior pathlib spec asserts PurePosixPath.__mro__.__len__()); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra129.PureWindowsPath.base0_is_PurePath:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (8 chars; PureWindowsPath inherits from exactly one class: PurePath; __bases__ has length 1 and __bases__[0] is PurePath; PurePath provides all the pure path operations that PureWindowsPath inherits; no prior pathlib spec asserts PureWindowsPath.__bases__[0].__name__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__bases__[0].__name__.__eq__
  args: ["PurePath"]
  expected: true
