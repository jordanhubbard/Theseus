spec: itertools_extra75
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra74.zspec.zsdl."
    - "This spec covers: itertools __mro__.__len__() == 2 for all C types (Wave 241)."
    - "All itertools C types inherit directly from object, so __mro__ is [type, object] with length 2."
    - "chain.__mro__.__len__() == 2 — chain is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "islice.__mro__.__len__() == 2 — islice is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "product.__mro__.__len__() == 2 — product is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "combinations.__mro__.__len__() == 2 — combinations is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "permutations.__mro__.__len__() == 2 — permutations is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "accumulate.__mro__.__len__() == 2 — accumulate is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "cycle.__mro__.__len__() == 2 — cycle is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "groupby.__mro__.__len__() == 2 — groupby is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "repeat.__mro__.__len__() == 2 — repeat is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "starmap.__mro__.__len__() == 2 — starmap is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "compress.__mro__.__len__() == 2 — compress is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "dropwhile.__mro__.__len__() == 2 — dropwhile is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "takewhile.__mro__.__len__() == 2 — takewhile is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "zip_longest.__mro__.__len__() == 2 — zip_longest is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "filterfalse.__mro__.__len__() == 2 — filterfalse is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "count.__mro__.__len__() == 2 — count is a C extension type inheriting from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain/islice/product/combinations MRO length — extra75
#
# Wave 241 theme: all itertools C types have __mro__.__len__() == 2.
#
# itertools.chain.__mro__.__len__()        == 2
# itertools.islice.__mro__.__len__()       == 2
# itertools.product.__mro__.__len__()      == 2
# itertools.combinations.__mro__.__len__() == 2
#
# No prior itertools spec checks these types' __mro__.__len__ via itertmore75. New to extra75.
# ---------------------------------------------------------------------------

table itertools_extra75.chain_islice_product_combinations_mro:
  description: "chain/islice/product/combinations __mro__.__len__()==2; wave 241 itertools C type MRO lengths; new to extra75"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertmore75

  columns: [id, function, args, expected, description]
  rows:
    - [chain_mro_len_eq_2,
       chain.__mro__.__len__,
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — chain is a C extension type defined in Modules/itertoolsmodule.c that chains multiple iterables into a single sequence; it inherits directly from object; its MRO is [chain, object] with exactly 2 entries; tuple.__len__() returns 2; no prior itertools spec checks chain.__mro__.__len__ via itertmore75; new to extra75"]
    - [islice_mro_len_eq_2,
       islice.__mro__.__len__,
       [],
       2,
       "itertools.islice.__mro__.__len__() == 2 — islice is a C extension type defined in Modules/itertoolsmodule.c that makes an iterator returning selected elements; it inherits directly from object; its MRO is [islice, object] with exactly 2 entries; tuple.__len__() returns 2; no prior itertools spec checks islice.__mro__.__len__ via itertmore75; new to extra75"]
    - [product_mro_len_eq_2,
       product.__mro__.__len__,
       [],
       2,
       "itertools.product.__mro__.__len__() == 2 — product is a C extension type defined in Modules/itertoolsmodule.c that computes Cartesian products; it inherits directly from object; its MRO is [product, object] with exactly 2 entries; tuple.__len__() returns 2; no prior itertools spec checks product.__mro__.__len__ via itertmore75; new to extra75"]
    - [combinations_mro_len_eq_2,
       combinations.__mro__.__len__,
       [],
       2,
       "itertools.combinations.__mro__.__len__() == 2 — combinations is a C extension type defined in Modules/itertoolsmodule.c that returns successive r-length combinations; it inherits directly from object; its MRO is [combinations, object] with exactly 2 entries; tuple.__len__() returns 2; no prior itertools spec checks combinations.__mro__.__len__ via itertmore75; new to extra75"]

