spec: asyncio_extra1051
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio queue classes documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.LifoQueue, asyncio.PriorityQueue, asyncio.QueueEmpty, asyncio.QueueFull module/qualname/name identity and weakref descriptor types"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1051.lifoqueue_identity:
  description: "asyncio.LifoQueue module, qualname, and name identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: as1051lq
  columns: [id, function, args, expected]
  rows:
    - [as1051lq001, asyncio.LifoQueue.__module__.__eq__,    ["asyncio.queues"], true]
    - [as1051lq002, asyncio.LifoQueue.__qualname__.__eq__,  ["LifoQueue"],      true]
    - [as1051lq003, asyncio.LifoQueue.__name__.__eq__,      ["LifoQueue"],      true]
    - [as1051lq004, asyncio.LifoQueue.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [as1051lq005, asyncio.LifoQueue.__class__.__name__.__eq__, ["type"], true]

