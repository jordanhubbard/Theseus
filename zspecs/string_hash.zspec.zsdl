spec: string_hash
version: ">=1.1.0"
backend: node(string-hash)

docs: https://www.npmjs.com/package/string-hash

provenance:
  derived_from:
    - "string-hash README — https://www.npmjs.com/package/string-hash"
    - "Test vectors verified with string-hash via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "string-hash source"
  notes:
    - "string-hash is an npm package. Install: npm install string-hash"
    - "hash(str) returns a deterministic unsigned 32-bit integer derived from the string."
    - "Uses a djb2-style XOR hash. Empty string returns the seed value 5381."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns unsigned 32-bit integer hash."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_hash.hash:
  kind: node_module_call_eq
  function: ~
  category: hash
  id_prefix: sh

  columns: [id, args, expected]
  rows:
    - [empty,  [""],        5381]
    - [hello,  ["hello"],   181380007]
    - [world,  ["world"],   164394279]
    - [foo,    ["foo"],     193420387]
