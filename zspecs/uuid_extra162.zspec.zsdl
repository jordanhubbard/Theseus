#
# uuid.UUID.__dict__.__contains__('__repr__') is True. UUID.__repr__ returns a string
# of the form UUID('xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'). '__repr__' (8 chars) =
# '__'=2 + 'repr'=4 + '__'=2. uuid_extra156 anchors __repr__ membership via 'in' syntax;
# this standalone anchors via __contains__ method under uuiddict162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra162.UUID_dict_contains_repr:
  description: "uuid.UUID.__dict__.__contains__('__repr__') == True — '__repr__' (8 chars = '__'=2 + 'repr'=4 + '__'=2; UUID.__repr__ returns 'UUID(repr-str)' where repr-str is the canonical 36-char hyphenated UUID string; '__repr__'(8)=='__init__'(8)=='__hash__'(8) — three 8-char dunders in UUID.__dict__; uuid_extra156 anchors __repr__ via 'in' syntax; this standalone anchors via __contains__ under uuiddict162; UUID.__dict__.__len__()==37; first uuiddict162 standalone for UUID.__dict__.__contains__('__repr__') via __contains__ method"
  category: identity
  kind: python_call_eq
