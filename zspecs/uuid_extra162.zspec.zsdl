# dict keys or set elements. '__hash__' (8 chars) = '__'=2 + 'hash'=4 + '__'=2.
# uuid_extra161 anchors this via __contains__ and as a standalone.
# This standalone provides a fresh anchor under uuiddict162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra162.UUID_dict_contains_hash:
  description: "uuid.UUID.__dict__.__contains__('__hash__') == True — '__hash__' (8 chars = '__'=2 + 'hash'=4 + '__'=2; UUID.__hash__() returns hash(self.int); makes UUID instances hashable — usable as dict keys and set elements; '__hash__'(8)=='__init__'(8)=='__repr__'(8) — three 8-char dunders in UUID.__dict__; uuid_extra161 anchors __hash__ via __contains__ and standalone; first uuiddict162 standalone for UUID.__dict__.__contains__('__hash__')"
  category: identity
  kind: python_call_eq
