# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__init__') — standalone
#
# uuid.UUID.__dict__.__contains__('__init__') is True. UUID.__init__ is the primary
# constructor logic for uuid.UUID. It accepts keyword arguments: hex (32-char string),
# bytes (16-byte big-endian), bytes_le (16-byte little-endian), fields (6-tuple), int
# (128-bit integer), version (1-5), and is_safe (SafeUUID). Exactly one of hex/bytes/
# bytes_le/fields/int must be provided. '__init__' (8 chars) = '__'=2 + 'init'=4 + '__'=2.
# Novel anchor: uuid_extra161 does not anchor '__init__' membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra162.UUID_dict_contains_init:
  description: "uuid.UUID.__dict__.__contains__('__init__') == True — '__init__' (8 chars = '__'=2 + 'init'=4 + '__'=2; UUID.__init__ accepts keyword args: hex/bytes/bytes_le/fields/int/version/is_safe; exactly one of hex/bytes/bytes_le/fields/int must be provided; '__init__'(8)=='__repr__'(8)=='__hash__'(8) — three-way tie at 8 chars; uuid_extra161 anchors __int__/__str__/__hash__/__eq__ but NOT '__init__' — novel anchor; uuid_extra156 does not anchor '__init__' membership; UUID.__dict__.__len__()==37; first uuiddict162 standalone for UUID.__dict__.__contains__('__init__')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__new__')==False — standalone
#
# uuid.UUID.__dict__.__contains__('__new__') is False. UUID does NOT define __new__ —
# instance creation uses __init__ alone. '__new__' is inherited from object but not
# redefined in uuid.UUID.__dict__. This contrasts with struct.Struct which defines
# both __new__ and __init__ in its __dict__. '__new__' (7 chars) = '__'=2 + 'new'=3 + '__'=2.
# Novel anchor: no prior uuid spec anchors UUID.__dict__.__contains__('__new__') == False.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra162.UUID_dict_not_contains_new:
  description: "uuid.UUID.__dict__.__contains__('__new__') == False — '__new__' (7 chars = '__'=2 + 'new'=3 + '__'=2; UUID does NOT define __new__ in its own __dict__; UUID uses __init__ for all construction logic; __new__ is inherited from object (not redefined); this contrasts with struct.Struct where '__new__' IS in Struct.__dict__ (struct_extra165 anchors); '__new__'(7) < '__init__'(8) by 1 char: 'new'(3) < 'init'(4) by 1; UUID.__dict__.__len__()==37 (37 keys, none named '__new__'); novel False anchor — no prior uuid spec anchors this; first uuiddict162 standalone for UUID.__dict__.__contains__('__new__')==False"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__new__"]
  expected: false

# ---------------------------------------------------------------------------
