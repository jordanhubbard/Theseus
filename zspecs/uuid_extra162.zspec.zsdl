# uuid.UUID.__dict__.__contains__('__new__')
# uuid.UUID.__dict__.__contains__('__repr__')
# uuid.UUID.__dict__.__len__()==37
#
# Wave 352 theme: UUID.__dict__ dunder membership — __init__ (True), __new__ (False), __repr__ (True).
#
# UUID.__dict__.__contains__('__init__') == True (UUID defines __init__; novel anchor).
# UUID.__dict__.__contains__('__new__') == False (UUID does NOT define __new__; novel anchor).
# UUID.__dict__.__contains__('__repr__') == True (UUID defines __repr__; fresh anchor).
# UUID.__dict__.__len__() == 37 (total dict size; confirmed).
# uuid_extra161 anchors __str__/__hash__/__eq__/__int__ via __contains__;
# this spec adds __init__ (True), __new__ (False), and __repr__ (True) as new dunder anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra162.UUID_dict_init_new_repr:
  description: "uuid.UUID.__dict__.__contains__('__init__')==True / UUID.__dict__.__contains__('__new__')==False / UUID.__dict__.__contains__('__repr__')==True / UUID.__dict__.__len__()==37 — UUID.__dict__.__contains__('__init__') is True ('__init__' is a key in uuid.UUID.__dict__; UUID.__init__ is the instance initialization method that accepts keyword arguments: hex, bytes, bytes_le, fields, int, version, is_safe; exactly one of these must be provided; '__init__'(8 chars) = '__'=2 + 'init'=4 + '__'=2; novel anchor: uuid_extra161 anchors __int__/__str__/__hash__/__eq__ but NOT '__init__'; uuid_extra156 does not anchor '__init__' either); UUID.__dict__.__contains__('__new__') is False ('__new__' is NOT a key in uuid.UUID.__dict__; UUID does not define __new__ — it uses __init__ for instance setup; this contrasts with struct.Struct which has '__new__' in its dict (struct_extra165 anchors); UUID.__new__ is inherited from object but not redefined in UUID.__dict__; '__new__'(7 chars) is absent from UUID.__dict__; novel False anchor); UUID.__dict__.__contains__('__repr__') is True ('__repr__' is a key in uuid.UUID.__dict__; UUID.__repr__ returns 'UUID(repr)' where repr is the canonical hyphenated UUID string; '__repr__'(8 chars) = '__'=2 + 'repr'=4 + '__'=2; uuid_extra156 anchors __repr__ via 'in' syntax; confirmed via __contains__ here; '__repr__'(8)=='__init__'(8) — tied dunder name length); UUID.__dict__.__len__() is 37 (confirmed; 37 total keys in UUID.__dict__; uuid_extra156 anchors __len__()==37; first uuiddict162 anchor for __init__/__new__/__repr__ dunder membership)"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict162

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_init,    "UUID.__dict__.__contains__", ["__init__"], true,  "uuid.UUID.__dict__.__contains__('__init__') == True ('__init__'=8 chars; UUID.__init__ accepts hex/bytes/int/fields/version/is_safe kwargs; novel anchor)"]
    - [dict_no_new,      "UUID.__dict__.__contains__", ["__new__"],  false, "uuid.UUID.__dict__.__contains__('__new__') == False ('__new__' NOT in UUID.__dict__; UUID uses __init__ not __new__; novel False anchor)"]
    - [dict_has_repr,    "UUID.__dict__.__contains__", ["__repr__"], true,  "uuid.UUID.__dict__.__contains__('__repr__') == True ('__repr__'=8 chars; UUID.__repr__ returns 'UUID(repr)'; uuid_extra156 anchors via 'in'; confirmed via __contains__)"]
    - [dict_len_37,      "UUID.__dict__.__len__",      [],           37,    "uuid.UUID.__dict__.__len__() is 37 (37 total keys: 18 dunders + _from_int + 18 non-dunder properties; uuid_extra156 anchors __len__()==37; confirmed here)"]

