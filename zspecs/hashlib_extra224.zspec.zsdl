spec: hashlib_extra224
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.md5().__class__.__qualname__ == 'HASH' (4 chars) — OpenSSL-backed HASH object."
    - "hashlib.sha256().__class__.__qualname__ == 'HASH' (4 chars) — same C-level HASH type."
    - "hashlib.md5().update.__qualname__ == 'HASH.update' (11 chars) — method on C-level HASH object."
    - "hashlib.md5().hexdigest.__qualname__ == 'HASH.hexdigest' (14 chars)."
    - "hashlib.md5().digest.__qualname__ == 'HASH.digest' (11 chars)."
    - "hashlib.md5().copy.__qualname__ == 'HASH.copy' (9 chars)."
    - "hashlib.new.__qualname__ == '__hash_new' (10 chars) — internal hash dispatch function."
    - "hashlib.md5.__qualname__ == 'openssl_md5' (11 chars) — C-level function has 'openssl_' prefix."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256' (14 chars) — C-level function has 'openssl_' prefix."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib HASH object method __qualname__.__len__() checks
#
# hashlib.md5().update.__qualname__.__len__()    == 11  ('HASH.update')
# hashlib.md5().hexdigest.__qualname__.__len__() == 14  ('HASH.hexdigest')
# hashlib.md5().digest.__qualname__.__len__()    == 11  ('HASH.digest')
# hashlib.md5().copy.__qualname__.__len__()      == 9   ('HASH.copy')
# hashlib.md5().__class__.__qualname__.__len__() == 4   ('HASH')
# ---------------------------------------------------------------------------

table hashlib_extra224.hash_method_qualname_lengths:
  description: "hashlib HASH object method __qualname__.__len__() checks in hashlib224 namespace — wave 224 theme: HASH class qualname is 4 chars; HASH.update is 11 chars; HASH.hexdigest is 14 chars; HASH.digest is 11 chars; HASH.copy is 9 chars; all HASH methods carry the 'HASH.' prefix (5 chars) from the OpenSSL-backed C-level HASH type; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlib224

  columns: [id, function, args, expected, description]
  rows:
    - [hash_class_qualname_len,     hashlib.md5().__class__.__qualname__.__len__,                [], 4,  "hashlib.md5().__class__.__qualname__.__len__() == 4 — HASH class qualname 'HASH' is 4 characters"]
    - [hash_update_qn_len,          hashlib.md5().update.__qualname__.__len__,                   [], 11, "hashlib.md5().update.__qualname__.__len__() == 11 — 'HASH.update' is 11 characters"]
    - [hash_hexdigest_qn_len,       hashlib.md5().hexdigest.__qualname__.__len__,                [], 14, "hashlib.md5().hexdigest.__qualname__.__len__() == 14 — 'HASH.hexdigest' is 14 characters"]
    - [hash_digest_qn_len,          hashlib.md5().digest.__qualname__.__len__,                   [], 11, "hashlib.md5().digest.__qualname__.__len__() == 11 — 'HASH.digest' is 11 characters"]
    - [hash_copy_qn_len,            hashlib.md5().copy.__qualname__.__len__,                     [], 9,  "hashlib.md5().copy.__qualname__.__len__() == 9 — 'HASH.copy' is 9 characters"]

# ---------------------------------------------------------------------------
# hashlib module-level function __qualname__.__len__() checks
#
# hashlib.new.__qualname__.__len__()    == 10  ('__hash_new')
# hashlib.md5.__qualname__.__len__()    == 11  ('openssl_md5')
# hashlib.sha256.__qualname__.__len__() == 14  ('openssl_sha256')
# ---------------------------------------------------------------------------

table hashlib_extra224.module_func_qualname_lengths:
  description: "hashlib module-level function __qualname__.__len__() checks in hashlib224a namespace — wave 224 theme: hashlib.new qualname is '__hash_new' (10 chars); hashlib.md5 qualname is 'openssl_md5' (11 chars); hashlib.sha256 qualname is 'openssl_sha256' (14 chars); C-level functions have unusual qualnames matching their __name__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlib224a

  columns: [id, function, args, expected, description]
  rows:
    - [new_qualname_len,    hashlib.new.__qualname__.__len__,    [], 10, "hashlib.new.__qualname__.__len__() == 10 — qualname '__hash_new' is 10 characters"]
    - [md5_qualname_len,    hashlib.md5.__qualname__.__len__,    [], 11, "hashlib.md5.__qualname__.__len__() == 11 — qualname 'openssl_md5' is 11 characters"]
    - [sha256_qualname_len, hashlib.sha256.__qualname__.__len__, [], 14, "hashlib.sha256.__qualname__.__len__() == 14 — qualname 'openssl_sha256' is 14 characters"]

# ---------------------------------------------------------------------------
# hashlib HASH object __qualname__ equality checks
#
# hashlib.md5().__class__.__qualname__.__eq__('HASH')   == True
# hashlib.sha256().__class__.__qualname__.__eq__('HASH') == True
# hashlib.md5().update.__qualname__.__eq__('HASH.update') == True
# hashlib.md5().hexdigest.__qualname__.__eq__('HASH.hexdigest') == True
# ---------------------------------------------------------------------------

invariant hashlib_extra224.md5_class_qualname_eq:
  description: "hashlib.md5().__class__.__qualname__.__eq__('HASH') == True — md5() returns a C-level HASH object; its class qualname is 'HASH'; OpenSSL-backed type from _hashlib extension; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.md5().__class__.__qualname__.__eq__"
  args: ["HASH"]
  expected: true

invariant hashlib_extra224.sha256_class_qualname_eq:
  description: "hashlib.sha256().__class__.__qualname__.__eq__('HASH') == True — sha256() returns the same C-level HASH type as md5(); class qualname is 'HASH'; OpenSSL-backed type; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.sha256().__class__.__qualname__.__eq__"
  args: ["HASH"]
  expected: true

invariant hashlib_extra224.hash_update_qualname_eq:
  description: "hashlib.md5().update.__qualname__.__eq__('HASH.update') == True — HASH.update is the qualified name of the update method on the C-level HASH object; prefix 'HASH.' indicates the class; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "hashlib.md5().update.__qualname__.__eq__"
  args: ["HASH.update"]
  expected: true

invariant hashlib_extra224.hash_hexdigest_qualname_eq:
  description: "hashlib.md5().hexdigest.__qualname__.__eq__('HASH.hexdigest') == True — HASH.hexdigest is the qualified name of the hexdigest method; returns hex-encoded digest string; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "hashlib.md5().hexdigest.__qualname__.__eq__"
  args: ["HASH.hexdigest"]
  expected: true

invariant hashlib_extra224.new_qualname_eq:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') == True — hashlib.new is an internal dispatch function; its qualname is '__hash_new' (with double underscore prefix); C-level implementation; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "hashlib.new.__qualname__.__eq__"
  args: ["__hash_new"]
  expected: true
