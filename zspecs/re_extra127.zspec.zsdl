spec: re_extra127
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module function __code__.co_varnames — first parameter and total co_varnames length."
    - "All re module public functions except purge have co_varnames[0] == 'pattern' (the first arg is always the pattern string)."
    - "re.compile.__code__.co_varnames = ('pattern', 'flags'), len = 2."
    - "re.search.__code__.co_varnames[0] = 'pattern', len(co_varnames) = 3."
    - "re.match.__code__.co_varnames[0] = 'pattern', len(co_varnames) = 3."
    - "re.fullmatch.__code__.co_varnames[0] = 'pattern', len(co_varnames) = 3."
    - "re.findall.__code__.co_varnames[0] = 'pattern', len(co_varnames) = 3."
    - "re.finditer.__code__.co_varnames[0] = 'pattern', len(co_varnames) = 3."
    - "re.sub.__code__.co_varnames[0] = 'pattern', len(co_varnames) = 7 (has extra 'args' and 'warnings' locals for deprecation handling)."
    - "re.split.__code__.co_varnames[0] = 'pattern', len(co_varnames) = 6 (has 'args' and 'warnings' locals)."
    - "re.escape.__code__.co_varnames[0] = 'pattern', len(co_varnames) = 1 (only 'pattern', no other params)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function co_varnames[0] — all public re functions with a 'pattern'
# first parameter. co_varnames[0] == 'pattern' for compile, search, match,
# fullmatch, sub, subn, split, findall, finditer, escape.
# ---------------------------------------------------------------------------

table re_extra127.function_co_varnames_first_param:
  description: "re module function __code__.co_varnames[0] == 'pattern' for compile, search, match, fullmatch, findall, finditer, escape"
  kind: python_call_eq
  category: code_attrs
  id_prefix: recodevars127

  columns: [id, function, args, expected, description]
  rows:
    - [compile_vars0,   compile.__code__.co_varnames.__getitem__,   [0], "pattern", "re.compile.__code__.co_varnames[0] == 'pattern'"]
    - [search_vars0,    search.__code__.co_varnames.__getitem__,    [0], "pattern", "re.search.__code__.co_varnames[0] == 'pattern'"]
    - [match_vars0,     match.__code__.co_varnames.__getitem__,     [0], "pattern", "re.match.__code__.co_varnames[0] == 'pattern'"]
    - [fullmatch_vars0, fullmatch.__code__.co_varnames.__getitem__, [0], "pattern", "re.fullmatch.__code__.co_varnames[0] == 'pattern'"]
    - [findall_vars0,   findall.__code__.co_varnames.__getitem__,   [0], "pattern", "re.findall.__code__.co_varnames[0] == 'pattern'"]
    - [finditer_vars0,  finditer.__code__.co_varnames.__getitem__,  [0], "pattern", "re.finditer.__code__.co_varnames[0] == 'pattern'"]
    - [escape_vars0,    escape.__code__.co_varnames.__getitem__,    [0], "pattern", "re.escape.__code__.co_varnames[0] == 'pattern'"]
    - [sub_vars0,       sub.__code__.co_varnames.__getitem__,       [0], "pattern", "re.sub.__code__.co_varnames[0] == 'pattern'"]
    - [split_vars0,     split.__code__.co_varnames.__getitem__,     [0], "pattern", "re.split.__code__.co_varnames[0] == 'pattern'"]

# ---------------------------------------------------------------------------
# re module function len(co_varnames) — total number of local variables
# compile=2, search=match=fullmatch=findall=finditer=3, sub=subn=7, split=6,
# escape=1 (only 'pattern').
# ---------------------------------------------------------------------------

table re_extra127.function_co_varnames_length:
  description: "re module function len(__code__.co_varnames): compile=2, search/match/fullmatch/findall/finditer=3, escape=1, sub/subn=7, split=6"
  kind: python_call_eq
  category: code_attrs
  id_prefix: recodevars127

  columns: [id, function, args, expected, description]
  rows:
    - [compile_vars_len,   compile.__code__.co_varnames.__len__,   [], 2, "re.compile co_varnames len 2: ('pattern', 'flags')"]
    - [search_vars_len,    search.__code__.co_varnames.__len__,    [], 3, "re.search co_varnames len 3: ('pattern', 'string', 'flags')"]
    - [match_vars_len,     match.__code__.co_varnames.__len__,     [], 3, "re.match co_varnames len 3: ('pattern', 'string', 'flags')"]
    - [fullmatch_vars_len, fullmatch.__code__.co_varnames.__len__, [], 3, "re.fullmatch co_varnames len 3: ('pattern', 'string', 'flags')"]
    - [findall_vars_len,   findall.__code__.co_varnames.__len__,   [], 3, "re.findall co_varnames len 3: ('pattern', 'string', 'flags')"]
    - [finditer_vars_len,  finditer.__code__.co_varnames.__len__,  [], 3, "re.finditer co_varnames len 3: ('pattern', 'string', 'flags')"]
    - [escape_vars_len,    escape.__code__.co_varnames.__len__,    [], 1, "re.escape co_varnames len 1: only ('pattern',)"]
    - [sub_vars_len,       sub.__code__.co_varnames.__len__,       [], 7, "re.sub co_varnames len 7: includes 'args' and 'warnings' deprecation locals"]
    - [split_vars_len,     split.__code__.co_varnames.__len__,     [], 6, "re.split co_varnames len 6: includes 'args' and 'warnings' deprecation locals"]
    - [compile_not_len3,   compile.__code__.co_varnames.__len__,   [], 3, false]

# ---------------------------------------------------------------------------
# re module function co_varnames second parameter (index 1) where applicable
# search/match/fullmatch/findall/finditer have co_varnames[1] == 'string'.
# sub has co_varnames[1] == 'repl'.
# split has co_varnames[1] == 'string'.
# compile has co_varnames[1] == 'flags'.
# ---------------------------------------------------------------------------

table re_extra127.function_co_varnames_second_param:
  description: "re module function __code__.co_varnames[1]: compile='flags', search/match/fullmatch/findall/finditer/split='string', sub='repl'"
  kind: python_call_eq
  category: code_attrs
  id_prefix: recodevars127

  columns: [id, function, args, expected, description]
  rows:
    - [compile_vars1,   compile.__code__.co_varnames.__getitem__,   [1], "flags",  "re.compile.__code__.co_varnames[1] == 'flags'"]
    - [search_vars1,    search.__code__.co_varnames.__getitem__,    [1], "string", "re.search.__code__.co_varnames[1] == 'string'"]
    - [match_vars1,     match.__code__.co_varnames.__getitem__,     [1], "string", "re.match.__code__.co_varnames[1] == 'string'"]
    - [fullmatch_vars1, fullmatch.__code__.co_varnames.__getitem__, [1], "string", "re.fullmatch.__code__.co_varnames[1] == 'string'"]
    - [findall_vars1,   findall.__code__.co_varnames.__getitem__,   [1], "string", "re.findall.__code__.co_varnames[1] == 'string'"]
    - [split_vars1,     split.__code__.co_varnames.__getitem__,     [1], "string", "re.split.__code__.co_varnames[1] == 'string'"]
    - [sub_vars1,       sub.__code__.co_varnames.__getitem__,       [1], "repl",   "re.sub.__code__.co_varnames[1] == 'repl' (replace-with argument)"]
    - [compile_v1_not_string, compile.__code__.co_varnames.__getitem__, [1], "string", false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra127.compile.co_varnames_0_is_pattern:
  description: "re.compile.__code__.co_varnames[0] == 'pattern' (the first and primary argument to all re functions is the regex pattern string)"
  category: code_attrs
  kind: python_call_eq
  function: compile.__code__.co_varnames.__getitem__
  args: [0]
  expected: "pattern"

invariant re_extra127.escape.co_varnames_len_1:
  description: "re.escape.__code__.co_varnames.__len__() == 1 (re.escape takes only 'pattern'; it is the simplest re function with no flags or string argument)"
  category: code_attrs
  kind: python_call_eq
  function: escape.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant re_extra127.sub.co_varnames_len_7:
  description: "re.sub.__code__.co_varnames.__len__() == 7 (re.sub has 'pattern', 'repl', 'string', 'count', 'flags' plus 'args' and 'warnings' locals for deprecation warning handling)"
  category: code_attrs
  kind: python_call_eq
  function: sub.__code__.co_varnames.__len__
  args: []
  expected: 7

invariant re_extra127.compile.co_varnames_1_is_flags:
  description: "re.compile.__code__.co_varnames[1] == 'flags' (the second parameter of re.compile is the optional flags bitmask)"
  category: code_attrs
  kind: python_call_eq
  function: compile.__code__.co_varnames.__getitem__
  args: [1]
  expected: "flags"

invariant re_extra127.sub.co_varnames_1_is_repl:
  description: "re.sub.__code__.co_varnames[1] == 'repl' (the second parameter of re.sub is the replacement string or callable)"
  category: code_attrs
  kind: python_call_eq
  function: sub.__code__.co_varnames.__getitem__
  args: [1]
  expected: "repl"
