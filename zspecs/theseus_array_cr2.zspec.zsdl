spec: theseus_array_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_array_cr2)
blocks: array

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html"
  notes:
    - "Clean-room extended array module. Do NOT import array."
    - "array(typecode, initializer=[]): typed sequence of values."
    - "Supported typecodes: 'b' (signed byte), 'B' (unsigned byte), 'i' (int), 'f' (float), 'd' (double), 'u' (unicode, deprecated)."
    - "array.append(x): add element to end."
    - "array.extend(iterable): extend with iterable."
    - "array.tobytes(): return bytes representation."
    - "array.frombytes(b): load values from bytes."
    - "array2_append(): a=array('i',[1,2]); a.append(3); a[2] == 3."
    - "array2_tobytes(): array('B',[1,2,3]).tobytes() == b'\\x01\\x02\\x03'."
    - "array2_frombytes(): a=array('B',[]); a.frombytes(b'\\x01\\x02'); len(a) == 2."
    - "Export: array, typecodes."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_array_cr2.append:
  description: "array('i',[1,2]).append(3); a[2] == 3"
  category: array
  kind: python_call_eq
  function: array2_append
  args: []
  expected: 3

invariant theseus_array_cr2.tobytes:
  description: "array('B',[1,2,3]).tobytes() == b'\\x01\\x02\\x03'"
  category: array
  kind: python_call_eq
  function: array2_tobytes
  args: []
  expected: true

invariant theseus_array_cr2.frombytes:
  description: "array('B',[]).frombytes(b'\\x01\\x02'); len(a) == 2"
  category: array
  kind: python_call_eq
  function: array2_frombytes
  args: []
  expected: 2
