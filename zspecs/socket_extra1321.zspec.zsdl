spec: socket_extra1321
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c and Lib/socket.py"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ method class checks for socket types."
    - "socket.socket defines __repr__ as a pure-Python function in Lib/socket.py."
    - "socket.socket.__repr__.__qualname__ == 'socket.__repr__' and __class__.__name__ == 'function'."
    - "socket.socket.__str__ inherits from object: __qualname__ == 'object.__str__', class 'wrapper_descriptor'."
    - "socket.error is an alias for OSError; its __repr__ inherits from BaseException."
    - "socket.error.__repr__.__class__.__name__ == 'wrapper_descriptor' (inherited C-level slot)."
    - "socket.error.__repr__.__qualname__ == 'BaseException.__repr__' (inherited from BaseException)."
    - "socket.timeout is a subclass of OSError; same inheritance pattern for __repr__."
    - "socket.timeout.__repr__.__qualname__ == 'BaseException.__repr__' (inherited C-level slot)."
    - "socket.AddressFamily is an Enum subclass; __repr__ inherited from Enum (Python function)."
    - "repr(socket.socket).__class__.__name__ == 'str' — repr of class object always returns str."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra1321.socket_repr_qualnames:
  description: "socket.socket __repr__ is a Python function; __str__ inherits from object: qualname and class checks"
  kind: python_call_eq
  category: identity
  id_prefix: sk1321rq
  columns: [id, function, args, expected]
  rows:
    - [sk1321rq001, socket.socket.__repr__.__qualname__.__eq__,       ["socket.__repr__"],  true]
    - [sk1321rq002, socket.socket.__repr__.__class__.__name__.__eq__, ["function"],         true]
    - [sk1321rq003, socket.socket.__str__.__qualname__.__eq__,        ["object.__str__"],   true]
    - [sk1321rq004, socket.socket.__str__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [sk1321rq005, socket.socket.__repr__.__qualname__.__eq__,       ["socket.__repr__"],  true]
    - [sk1321rq006, socket.socket.__repr__.__class__.__name__.__eq__, ["function"],         true]

table socket_extra1321.exception_repr_inheritance:
  description: "socket.error and socket.timeout __repr__ and __str__ inherited from BaseException: wrapper_descriptor checks"
  kind: python_call_eq
  category: identity
  id_prefix: sk1321er
  columns: [id, function, args, expected]
  rows:
    - [sk1321er001, socket.error.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"],     true]
    - [sk1321er002, socket.error.__repr__.__qualname__.__eq__,         ["BaseException.__repr__"], true]
    - [sk1321er003, socket.error.__str__.__class__.__name__.__eq__,    ["wrapper_descriptor"],     true]
    - [sk1321er004, socket.timeout.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"],     true]
    - [sk1321er005, socket.timeout.__repr__.__qualname__.__eq__,       ["BaseException.__repr__"], true]
    - [sk1321er006, socket.timeout.__str__.__class__.__name__.__eq__,  ["wrapper_descriptor"],     true]

table socket_extra1321.repr_of_class_objects_returns_str:
  description: "repr() called on socket class objects always returns a str instance; AddressFamily Enum __repr__ check"
  kind: python_call_eq
  category: identity
  id_prefix: sk1321ro
  columns: [id, function, args, expected]
  rows:
    - [sk1321ro001, repr(socket.socket).__class__.__name__.__eq__,              ["str"],      true]
    - [sk1321ro002, repr(socket.error).__class__.__name__.__eq__,               ["str"],      true]
    - [sk1321ro003, repr(socket.timeout).__class__.__name__.__eq__,             ["str"],      true]
    - [sk1321ro004, socket.AddressFamily.__repr__.__class__.__name__.__eq__,    ["function"], true]
    - [sk1321ro005, socket.AddressFamily.__repr__.__qualname__.__eq__,          ["Enum.__repr__"], true]
    - [sk1321ro006, repr(socket.AddressFamily).__class__.__name__.__eq__,       ["str"],      true]
