spec: statistics_extra27
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra26.zspec.zsdl."
    - "Prior specs covered: mean/median/mode/stdev/variance/pstdev/pvariance qualnames and module lengths, NormalDist method qualname lengths for pdf/cdf/inv_cdf/overlap/quantiles/zscore/samples/from_samples, __name__/__module__ lengths for StatisticsError and all major functions."
    - "This spec covers: NormalDist.__mro__.__len__() and StatisticsError.__mro__.__len__(); NormalDist.__bases__[0].__name__ and StatisticsError.__bases__[0].__name__; NormalDist.__init__.__qualname__.__len__() and __module__.__len__(); __qualname__.__len__() for module-level functions (mean/median/mode/stdev/variance/pstdev/pvariance/fmean/geometric_mean/harmonic_mean/StatisticsError)."
    - "NormalDist.__mro__ == [NormalDist, object] — length 2; NormalDist does not extend any statistics ABC."
    - "StatisticsError.__mro__ == [StatisticsError, ValueError, Exception, BaseException, object] — length 5."
    - "NormalDist.__bases__[0].__name__ == 'object'; StatisticsError.__bases__[0].__name__ == 'ValueError'."
    - "NormalDist.__init__.__qualname__ == 'NormalDist.__init__' (19 chars)."
    - "geometric_mean.__qualname__ == 'geometric_mean' (14 chars) — longest function qualname; harmonic_mean is 13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for NormalDist and StatisticsError
#
# NormalDist is a plain Python class with no numeric ABC parents; its MRO
# contains only itself and object (length 2). StatisticsError inherits from
# ValueError → Exception → BaseException → object, giving MRO length 5.
# No prior statistics spec records __mro__.__len__() for either of these.
# ---------------------------------------------------------------------------

table statistics_extra27.mro_lengths:
  description: "__mro__.__len__() for NormalDist and StatisticsError"
  kind: python_call_eq
  category: class_identity
  id_prefix: mro_len

  columns: [id, function, args, expected, description]
  rows:
    - [NormalDist,
       NormalDist.__mro__.__len__,
       [],
       2,
       "len(NormalDist.__mro__) == 2 — [NormalDist, object]"]
    - [StatisticsError,
       StatisticsError.__mro__.__len__,
       [],
       5,
       "len(StatisticsError.__mro__) == 5 — [StatisticsError, ValueError, Exception, BaseException, object]"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for module-level statistics functions
#
# For top-level module functions, __qualname__ equals __name__. This table
# records __qualname__.__len__() for all major statistics functions and
# StatisticsError. geometric_mean (14 chars) and harmonic_mean (13 chars) are
# the longest; mean and mode share the shortest (4 chars). No prior statistics
# spec records __qualname__.__len__() for these objects in a combined table.
# ---------------------------------------------------------------------------

table statistics_extra27.function_qualname_lens:
  description: "__qualname__.__len__() for statistics module-level functions and StatisticsError"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [mean,          mean.__qualname__.__len__,          [], 4]
    - [mode,          mode.__qualname__.__len__,          [], 4]
    - [median,        median.__qualname__.__len__,        [], 6]
    - [stdev,         stdev.__qualname__.__len__,         [], 5]
    - [fmean,         fmean.__qualname__.__len__,         [], 5]
    - [variance,      variance.__qualname__.__len__,      [], 8]
    - [pstdev,        pstdev.__qualname__.__len__,        [], 6]
    - [pvariance,     pvariance.__qualname__.__len__,     [], 9]
    - [harmonic_mean, harmonic_mean.__qualname__.__len__, [], 13]
    - [geometric_mean, geometric_mean.__qualname__.__len__, [], 14]
    - [StatisticsError, StatisticsError.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# NormalDist.__mro__.__len__() == 2 — standalone
#
# NormalDist is a plain class with object as its only base. Its MRO has exactly
# two entries: NormalDist itself and object. This minimal depth contrasts with
# StatisticsError (depth 5) and reflects that NormalDist is a self-contained
# utility class, not part of any inheritance hierarchy.
# ---------------------------------------------------------------------------

invariant statistics_extra27.NormalDist.mro_len:
  description: "len(statistics.NormalDist.__mro__) == 2 — NormalDist inherits only from object"
  category: class_identity
  kind: python_call_eq
  function: NormalDist.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# StatisticsError.__mro__.__len__() == 5 — standalone
#
# statistics.StatisticsError inherits from ValueError, which itself inherits
# from Exception → BaseException → object. This gives a full MRO depth of 5,
# reflecting the standard Python exception hierarchy. No prior statistics spec
# records this as a standalone invariant.
# ---------------------------------------------------------------------------

invariant statistics_extra27.StatisticsError.mro_len:
  description: "len(statistics.StatisticsError.__mro__) == 5 — [StatisticsError, ValueError, Exception, BaseException, object]"
  category: class_identity
  kind: python_call_eq
  function: StatisticsError.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# NormalDist.__bases__[0].__name__ == 'object' — standalone
#
# NormalDist has a single base class, object. This confirms that NormalDist
# does not extend any numeric ABC or other statistics class; it is a
# self-contained implementation. No prior statistics spec records this value.
# ---------------------------------------------------------------------------

invariant statistics_extra27.NormalDist.bases0_name:
  description: "statistics.NormalDist.__bases__[0].__name__ == 'object'"
  category: class_identity
  kind: python_call_eq
  function: "NormalDist.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# StatisticsError.__bases__[0].__name__ == 'ValueError' — standalone
#
# StatisticsError directly inherits from ValueError, making it a subclass of
# the standard exception hierarchy appropriate for invalid input conditions.
# No prior statistics spec records this base class name check.
# ---------------------------------------------------------------------------

invariant statistics_extra27.StatisticsError.bases0_name:
  description: "statistics.StatisticsError.__bases__[0].__name__ == 'ValueError'"
  category: class_identity
  kind: python_call_eq
  function: "StatisticsError.__bases__[0].__name__.__eq__"
  args: ["ValueError"]
  expected: true

# ---------------------------------------------------------------------------
# NormalDist.__init__.__qualname__.__len__() == 19 — standalone
#
# NormalDist.__init__.__qualname__ == 'NormalDist.__init__' (19 chars).
# The 11-char 'NormalDist.' prefix plus the 8-char '__init__' method name
# gives 19. This is the same length structure as other 'NormalDist.method'
# qualnames but __init__ is the initializer. No prior statistics spec records
# this value as a standalone invariant.
# ---------------------------------------------------------------------------

invariant statistics_extra27.NormalDist.init_qualname_len:
  description: "len(statistics.NormalDist.__init__.__qualname__) == 19 — 'NormalDist.__init__' is 19 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: NormalDist.__init__.__qualname__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# NormalDist.__init__.__module__.__len__() == 10 — standalone
#
# NormalDist.__init__.__module__ == 'statistics' (10 chars). This is
# consistent with all other statistics module objects: every function and
# class in the module reports __module__ == 'statistics'. No prior statistics
# spec records __module__.__len__() specifically for NormalDist.__init__.
# ---------------------------------------------------------------------------

invariant statistics_extra27.NormalDist.init_module_len:
  description: "len(statistics.NormalDist.__init__.__module__) == 10 — 'statistics' is 10 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: NormalDist.__init__.__module__.__len__
  args: []
  expected: 10
