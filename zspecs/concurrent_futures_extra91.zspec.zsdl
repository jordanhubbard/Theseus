table concurrent_futures_extra91.spec_and_loader_class_names:
  description: "concurrent.futures __spec__ and __loader__ class name checks in cfmoduleexc91 namespace — wave 254 theme: concurrent.futures module identity; __spec__.__class__.__name__.__eq__('ModuleSpec')==True; __loader__.__class__.__name__.__eq__('SourceFileLoader')==True (source package); __doc__.__class__.__name__.__eq__('str')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmoduleexc91a

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name,   "__spec__.__class__.__name__.__eq__",   ["ModuleSpec"],       true, "__spec__.__class__.__name__ == 'ModuleSpec' — module spec is a ModuleSpec instance; verified with Python 3.14.3"]
    - [loader_class_name, "__loader__.__class__.__name__.__eq__", ["SourceFileLoader"], true, "__loader__.__class__.__name__ == 'SourceFileLoader' — concurrent.futures is a Python source package; verified with Python 3.14.3"]
    - [doc_class_name,    "__doc__.__class__.__name__.__eq__",    ["str"],              true, "__doc__.__class__.__name__ == 'str' — module docstring is a str; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures exception __name__ and __module__ equality — extra91
#
# InvalidStateError.__name__ == 'InvalidStateError'
# InvalidStateError.__module__ == 'concurrent.futures._base'
# BrokenExecutor.__name__ == 'BrokenExecutor'
# BrokenExecutor.__module__ == 'concurrent.futures._base'
# CancelledError.__name__ == 'CancelledError'
# CancelledError.__module__ == 'concurrent.futures._base'
