spec: concurrent_futures_extra91
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra90

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra90.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures module identity (__name__, __package__, __loader__, __spec__) + InvalidStateError, BrokenExecutor, and CancelledError class hierarchy. NEW in extra91: cf.__name__=='concurrent.futures'; cf.__package__=='concurrent.futures'; cf.__loader__.__class__.__name__=='SourceFileLoader'; cf.__spec__.__class__.__name__=='ModuleSpec'; InvalidStateError.__name__=='InvalidStateError'; InvalidStateError.__module__=='concurrent.futures._base'; InvalidStateError.__bases__[0].__name__=='Error'; InvalidStateError.__mro__.__len__()==5; BrokenExecutor.__name__=='BrokenExecutor'; BrokenExecutor.__module__=='concurrent.futures._base'; BrokenExecutor.__bases__[0].__name__=='RuntimeError'; BrokenExecutor.__mro__.__len__()==5; CancelledError.__module__=='concurrent.futures._base'; CancelledError.__bases__[0].__name__=='Error'; CancelledError.__mro__.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__name__ == 'concurrent.futures'. The module name includes the package prefix. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__package__ == 'concurrent.futures'. The module is a package. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'. The package is loaded as a Python source package. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec'. The module spec is a ModuleSpec instance. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'. InvalidStateError is defined in Lib/concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error'. InvalidStateError inherits from concurrent.futures._base.Error. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__mro__.__len__() == 5. MRO is [InvalidStateError, Error, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'. BrokenExecutor is defined in Lib/concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'. BrokenExecutor inherits from RuntimeError (not from Error). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5. MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'. This is the cf-specific CancelledError (not to be confused with asyncio.CancelledError). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__bases__[0].__name__ == 'Error'. CancelledError inherits from concurrent.futures._base.Error. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures module string identity — extra91
#
# Wave 254 theme: concurrent.futures module identity + exception hierarchy.
#
# concurrent.futures.__name__ == 'concurrent.futures'
# concurrent.futures.__package__ == 'concurrent.futures'
# ---------------------------------------------------------------------------

table concurrent_futures_extra91.module_string_identity:
  description: "concurrent.futures module string identity checks in cfmoduleexc91 namespace — wave 254 theme: concurrent.futures module identity and exception classes; __name__.__eq__('concurrent.futures')==True; __package__.__eq__('concurrent.futures')==True; concurrent.futures is a package with a dotted name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmoduleexc91

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name,    __name__.__eq__,    ["concurrent.futures"], true, "__name__ == 'concurrent.futures' — module name includes package prefix; verified with Python 3.14.3"]
    - [mod_package, __package__.__eq__, ["concurrent.futures"], true, "__package__ == 'concurrent.futures' — module is a package; verified with Python 3.14.3"]

