table concurrent_futures_extra91.exception_bases_and_mro:
  description: "concurrent.futures exception __bases__[0].__name__ and __mro__.__len__() checks in cfmoduleexc91 namespace — wave 254 theme: concurrent.futures exception classes; InvalidStateError.__bases__[0].__name__.__eq__('Error')==True (inherits from cf Error base); InvalidStateError.__mro__.__len__()==5; BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError')==True (inherits from RuntimeError, not Error); BrokenExecutor.__mro__.__len__()==5; CancelledError.__bases__[0].__name__.__eq__('Error')==True; CancelledError.__mro__.__len__()==5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmoduleexc91c

  columns: [id, function, args, expected, description]
  rows:
    - [invalid_bases0,    "InvalidStateError.__bases__[0].__name__.__eq__",  ["Error"],         true, "InvalidStateError.__bases__[0].__name__ == 'Error' — inherits from concurrent.futures._base.Error; verified with Python 3.14.3"]
    - [invalid_mro_len,   InvalidStateError.__mro__.__len__,                 [],                5,    "InvalidStateError.__mro__.__len__() == 5 — MRO is [InvalidStateError, Error, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [broken_bases0,     "BrokenExecutor.__bases__[0].__name__.__eq__",     ["RuntimeError"],  true, "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — inherits from RuntimeError (not Error); verified with Python 3.14.3"]
    - [broken_mro_len,    BrokenExecutor.__mro__.__len__,                    [],                5,    "BrokenExecutor.__mro__.__len__() == 5 — MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [cancelled_bases0,  "CancelledError.__bases__[0].__name__.__eq__",     ["Error"],         true, "CancelledError.__bases__[0].__name__ == 'Error' — inherits from concurrent.futures._base.Error; verified with Python 3.14.3"]
    - [cancelled_mro_len, CancelledError.__mro__.__len__,                    [],                5,    "CancelledError.__mro__.__len__() == 5 — MRO is [CancelledError, Error, Exception, BaseException, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra91
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra91.module_name_is_dotted:
  description: "concurrent.futures.__name__.__eq__('concurrent.futures') returns True — the module's __name__ is the full dotted package name 'concurrent.futures'; this contrasts with simple module names like 'asyncio' or 'abc'; the dotted name reflects the two-level package hierarchy (concurrent is a namespace package, futures is a subpackage); NEW in extra91: first standalone __name__ invariant for concurrent.futures in cfmoduleexc91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra91.loader_is_SourceFileLoader:
  description: "concurrent.futures.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — concurrent.futures is a Python source package loaded by importlib.machinery.SourceFileLoader; this is the same loader type as asyncio; NEW in extra91: first standalone __loader__ class name invariant for concurrent.futures in cfmoduleexc91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__eq__"
  args: ["SourceFileLoader"]
  expected: true

invariant concurrent_futures_extra91.InvalidStateError_base_is_Error:
  description: "concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__('Error') returns True — InvalidStateError inherits from concurrent.futures._base.Error (not from RuntimeError); this is the cf-specific Error base class; InvalidStateError represents an illegal state transition on a Future; NEW in extra91: first standalone __bases__ invariant for InvalidStateError in cfmoduleexc91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "InvalidStateError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

invariant concurrent_futures_extra91.BrokenExecutor_base_is_RuntimeError:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') returns True — BrokenExecutor inherits from RuntimeError (not from the cf-specific Error class); this contrasts with InvalidStateError and CancelledError which both inherit from Error; BrokenExecutor is raised when a worker pool becomes unexpectedly broken; NEW in extra91: first standalone __bases__ invariant for BrokenExecutor in cfmoduleexc91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

invariant concurrent_futures_extra91.CancelledError_mro_len_five:
  description: "concurrent.futures.CancelledError.__mro__.__len__() == 5 — CancelledError's MRO is [CancelledError, Error, Exception, BaseException, object]; the length of 5 reflects the hierarchy through the cf-specific Error base class; this is the concurrent.futures.CancelledError (distinct from asyncio.CancelledError which has mro length 3); NEW in extra91: first standalone __mro__.__len__ invariant for CancelledError in cfmoduleexc91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: CancelledError.__mro__.__len__
  args: []
  expected: 5
