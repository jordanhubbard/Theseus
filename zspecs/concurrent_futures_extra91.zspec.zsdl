table concurrent_futures_extra91.exception_name_and_module:
  description: "concurrent.futures exception __name__ and __module__ equality checks in cfmoduleexc91 namespace — wave 254 theme: concurrent.futures exception classes; InvalidStateError.__name__.__eq__('InvalidStateError')==True; InvalidStateError.__module__.__eq__('concurrent.futures._base')==True; BrokenExecutor.__name__.__eq__('BrokenExecutor')==True; BrokenExecutor.__module__.__eq__('concurrent.futures._base')==True; CancelledError.__name__.__eq__('CancelledError')==True; CancelledError.__module__.__eq__('concurrent.futures._base')==True; all three exceptions are defined in _base.py; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmoduleexc91b

  columns: [id, function, args, expected, description]
  rows:
    - [invalid_name,    InvalidStateError.__name__.__eq__,   ["InvalidStateError"],             true, "InvalidStateError.__name__ == 'InvalidStateError' — exception class name; verified with Python 3.14.3"]
    - [invalid_module,  InvalidStateError.__module__.__eq__, ["concurrent.futures._base"],      true, "InvalidStateError.__module__ == 'concurrent.futures._base' — defined in Lib/concurrent/futures/_base.py; verified with Python 3.14.3"]
    - [broken_name,     BrokenExecutor.__name__.__eq__,      ["BrokenExecutor"],                true, "BrokenExecutor.__name__ == 'BrokenExecutor' — exception class name; verified with Python 3.14.3"]
    - [broken_module,   BrokenExecutor.__module__.__eq__,    ["concurrent.futures._base"],      true, "BrokenExecutor.__module__ == 'concurrent.futures._base' — defined in Lib/concurrent/futures/_base.py; verified with Python 3.14.3"]
    - [cancelled_name,  CancelledError.__name__.__eq__,      ["CancelledError"],                true, "CancelledError.__name__ == 'CancelledError' — cf-specific CancelledError class name; verified with Python 3.14.3"]
    - [cancelled_module, CancelledError.__module__.__eq__,   ["concurrent.futures._base"],      true, "CancelledError.__module__ == 'concurrent.futures._base' — defined in Lib/concurrent/futures/_base.py; verified with Python 3.14.3"]

