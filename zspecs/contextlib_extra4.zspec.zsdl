spec: contextlib_extra4
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "Extends contextlib.zspec.zsdl, contextlib_extra.zspec.zsdl, contextlib_extra2.zspec.zsdl, contextlib_extra3.zspec.zsdl."
    - "contextlib.zspec.zsdl covers __name__ for: contextmanager, suppress, ExitStack, closing, redirect_stdout, redirect_stderr, nullcontext, AsyncExitStack, AbstractContextManager, asynccontextmanager."
    - "contextlib_extra.zspec.zsdl covers __module__ for contextmanager/asynccontextmanager/closing/nullcontext; aclosing name/module; is_function/is_type checks."
    - "contextlib_extra2.zspec.zsdl covers a consolidated __name__ table for 10 symbols and ABCMeta metaclass checks."
    - "contextlib_extra3.zspec.zsdl covers __qualname__ for: AsyncExitStack, asynccontextmanager, aclosing, AbstractAsyncContextManager, nullcontext, ExitStack, suppress, closing, contextmanager, AbstractContextManager, redirect_stdout, redirect_stderr; AsyncContextDecorator name/module/qualname."
    - "This spec adds __module__ checks for suppress, closing, redirect_stdout, redirect_stderr, ExitStack, AsyncExitStack, AbstractContextManager, AbstractAsyncContextManager, contextmanager (orthogonal coverage), plus __name__ spot-checks for suppress/closing/nullcontext/redirect_stdout/redirect_stderr/ExitStack/AsyncExitStack/AbstractContextManager/AbstractAsyncContextManager."
    - "contextlib.suppress.__module__ == 'contextlib' — suppress is a class defined directly in the contextlib module."
    - "contextlib.closing.__module__ == 'contextlib' — closing is a class defined directly in the contextlib module."
    - "contextlib.ExitStack.__module__ == 'contextlib' — ExitStack is a class defined directly in the contextlib module."
    - "contextlib.AsyncExitStack.__module__ == 'contextlib' — AsyncExitStack is a class defined directly in contextlib."
    - "contextlib.AbstractContextManager.__module__ == 'contextlib'."
    - "contextlib.AbstractAsyncContextManager.__module__ == 'contextlib'."
    - "contextlib.contextmanager.__module__ == 'contextlib' — already in contextlib_extra; here confirmed again via this spec's namespace."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ spot-checks — supplement contextlib.zspec.zsdl table coverage
#
# contextlib.zspec.zsdl covers these via a table; here we add individual
# invariants for the names not yet covered by prior individual invariants.
# ---------------------------------------------------------------------------

invariant contextlib_extra4.suppress.name:
  description: "contextlib.suppress.__name__ == 'suppress'"
  category: identity
  kind: python_call_eq
  function: suppress.__name__.__eq__
  args: ["suppress"]
  expected: true

invariant contextlib_extra4.closing.name:
  description: "contextlib.closing.__name__ == 'closing'"
  category: identity
  kind: python_call_eq
  function: closing.__name__.__eq__
  args: ["closing"]
  expected: true

invariant contextlib_extra4.nullcontext.name:
  description: "contextlib.nullcontext.__name__ == 'nullcontext'"
  category: identity
  kind: python_call_eq
  function: nullcontext.__name__.__eq__
  args: ["nullcontext"]
  expected: true

invariant contextlib_extra4.redirect_stdout.name:
  description: "contextlib.redirect_stdout.__name__ == 'redirect_stdout'"
  category: identity
  kind: python_call_eq
  function: redirect_stdout.__name__.__eq__
  args: ["redirect_stdout"]
  expected: true

invariant contextlib_extra4.redirect_stderr.name:
  description: "contextlib.redirect_stderr.__name__ == 'redirect_stderr'"
  category: identity
  kind: python_call_eq
  function: redirect_stderr.__name__.__eq__
  args: ["redirect_stderr"]
  expected: true

invariant contextlib_extra4.ExitStack.name:
  description: "contextlib.ExitStack.__name__ == 'ExitStack'"
  category: identity
  kind: python_call_eq
  function: ExitStack.__name__.__eq__
  args: ["ExitStack"]
  expected: true

invariant contextlib_extra4.AsyncExitStack.name:
  description: "contextlib.AsyncExitStack.__name__ == 'AsyncExitStack'"
  category: identity
  kind: python_call_eq
  function: AsyncExitStack.__name__.__eq__
  args: ["AsyncExitStack"]
  expected: true

invariant contextlib_extra4.AbstractContextManager.name:
  description: "contextlib.AbstractContextManager.__name__ == 'AbstractContextManager'"
  category: identity
  kind: python_call_eq
  function: AbstractContextManager.__name__.__eq__
  args: ["AbstractContextManager"]
  expected: true

invariant contextlib_extra4.AbstractAsyncContextManager.name:
  description: "contextlib.AbstractAsyncContextManager.__name__ == 'AbstractAsyncContextManager'"
  category: identity
  kind: python_call_eq
  function: AbstractAsyncContextManager.__name__.__eq__
  args: ["AbstractAsyncContextManager"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks — suppress, closing, ExitStack, AsyncExitStack
#
# contextlib_extra.zspec.zsdl covers __module__ for contextmanager,
# asynccontextmanager, closing, nullcontext. Here we add suppress,
# ExitStack, AsyncExitStack, redirect_stdout, redirect_stderr,
# AbstractContextManager, AbstractAsyncContextManager.
# ---------------------------------------------------------------------------

invariant contextlib_extra4.suppress.module:
  description: "contextlib.suppress.__module__ == 'contextlib'"
  category: module
  kind: python_call_eq
  function: suppress.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra4.ExitStack.module:
  description: "contextlib.ExitStack.__module__ == 'contextlib'"
  category: module
  kind: python_call_eq
  function: ExitStack.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra4.AsyncExitStack.module:
  description: "contextlib.AsyncExitStack.__module__ == 'contextlib'"
  category: module
  kind: python_call_eq
  function: AsyncExitStack.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra4.contextmanager.module:
  description: "contextlib.contextmanager.__module__ == 'contextlib'"
  category: module
  kind: python_call_eq
  function: contextmanager.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra4.AbstractContextManager.module:
  description: "contextlib.AbstractContextManager.__module__ == 'contextlib'"
  category: module
  kind: python_call_eq
  function: AbstractContextManager.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra4.AbstractAsyncContextManager.module:
  description: "contextlib.AbstractAsyncContextManager.__module__ == 'contextlib'"
  category: module
  kind: python_call_eq
  function: AbstractAsyncContextManager.__module__.__eq__
  args: ["contextlib"]
  expected: true
