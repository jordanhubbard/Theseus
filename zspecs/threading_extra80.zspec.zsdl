spec: threading_extra80
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra79.zspec.zsdl."
    - "This spec covers: threading Semaphore.acquire/release + Event.set/clear/wait + Condition.wait/notify/notify_all code attributes (Wave 244)."
    - "Lock is a factory function (threading.Lock() returns a _thread.lock C type); Lock itself has __class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "Semaphore is a pure-Python class; Semaphore.acquire/__code__ is accessible. Verified with Python 3.14.3."
    - "Semaphore.acquire.__code__.co_name == 'acquire' — code object name matches method name. Verified with Python 3.14.3."
    - "Semaphore.acquire.__code__.co_argcount == 3 — self, blocking=True, timeout=None. Verified with Python 3.14.3."
    - "Semaphore.release.__code__.co_name == 'release' — code object name matches method name. Verified with Python 3.14.3."
    - "Semaphore.release.__code__.co_argcount == 2 — self, n=1. Verified with Python 3.14.3."
    - "Event is a pure-Python class; Event.set/__code__ is accessible. Verified with Python 3.14.3."
    - "Event.set.__code__.co_name == 'set' — code object name matches method name. Verified with Python 3.14.3."
    - "Event.set.__code__.co_argcount == 1 — self only. Verified with Python 3.14.3."
    - "Event.clear.__code__.co_name == 'clear' — code object name matches method name. Verified with Python 3.14.3."
    - "Event.clear.__code__.co_argcount == 1 — self only. Verified with Python 3.14.3."
    - "Event.wait.__code__.co_name == 'wait' — code object name matches method name. Verified with Python 3.14.3."
    - "Event.wait.__code__.co_argcount == 2 — self, timeout=None. Verified with Python 3.14.3."
    - "Condition.wait.__code__.co_name == 'wait' — code object name matches method name. Verified with Python 3.14.3."
    - "Condition.wait.__code__.co_argcount == 2 — self, timeout=None. Verified with Python 3.14.3."
    - "Condition.notify.__code__.co_name == 'notify' — code object name matches method name. Verified with Python 3.14.3."
    - "Condition.notify.__code__.co_argcount == 2 — self, n=1. Verified with Python 3.14.3."
    - "Condition.notify_all.__code__.co_name == 'notify_all' — code object name matches method name. Verified with Python 3.14.3."
    - "Condition.notify_all.__code__.co_argcount == 1 — self only. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Semaphore.acquire and Semaphore.release code objects — extra80
#
# Wave 244 theme: Semaphore is a pure-Python class; acquire/release have code objects.
#
# threading.Semaphore.acquire.__code__.co_name     == 'acquire'
# threading.Semaphore.acquire.__code__.co_argcount == 3
# threading.Semaphore.release.__code__.co_name     == 'release'
# threading.Semaphore.release.__code__.co_argcount == 2
#
# No prior threading spec checks Semaphore.acquire/release code objects via threadingextra80. New to extra80.
# ---------------------------------------------------------------------------

table threading_extra80.Semaphore_acquire_release_code:
  description: "Semaphore.acquire.__code__.co_name=='acquire', co_argcount==3; release co_name=='release', co_argcount==2; wave 244 Semaphore acquire/release code attrs; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra80

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_acquire_code_co_name_eq_acquire,
       Semaphore.acquire.__code__.co_name.__eq__,
       ["acquire"],
       true,
       "threading.Semaphore.acquire.__code__.co_name.__eq__('acquire') == True — Semaphore is a pure-Python class defined in Lib/threading.py; its acquire method's code object co_name records the method name 'acquire' (7 chars); str.__eq__('acquire') returns True; no prior threading spec checks Semaphore.acquire.__code__.co_name via threadingextra80; new to extra80"]
    - [Semaphore_acquire_code_co_argcount_eq_3,
       Semaphore.acquire.__code__.co_argcount.__eq__,
       [3],
       true,
       "threading.Semaphore.acquire.__code__.co_argcount.__eq__(3) == True — Semaphore.acquire(self, blocking=True, timeout=None) takes three positional-or-keyword arguments: self, blocking (default True), and timeout (default None); the code object's co_argcount is 3; int.__eq__(3) returns True; no prior threading spec checks Semaphore.acquire.__code__.co_argcount via threadingextra80; new to extra80"]
    - [Semaphore_release_code_co_name_eq_release,
       Semaphore.release.__code__.co_name.__eq__,
       ["release"],
       true,
       "threading.Semaphore.release.__code__.co_name.__eq__('release') == True — Semaphore is a pure-Python class defined in Lib/threading.py; its release method's code object co_name records the method name 'release' (7 chars); str.__eq__('release') returns True; no prior threading spec checks Semaphore.release.__code__.co_name via threadingextra80; new to extra80"]
    - [Semaphore_release_code_co_argcount_eq_2,
       Semaphore.release.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Semaphore.release.__code__.co_argcount.__eq__(2) == True — Semaphore.release(self, n=1) takes two positional-or-keyword arguments: self and n (n has a default of 1 but co_argcount still counts it); the code object's co_argcount is 2; int.__eq__(2) returns True; no prior threading spec checks Semaphore.release.__code__.co_argcount via threadingextra80; new to extra80"]

# ---------------------------------------------------------------------------
# Event.set, Event.clear, and Event.wait code objects — extra80
#
# Wave 244 theme: Event is a pure-Python class; set/clear/wait have code objects.
#
# threading.Event.set.__code__.co_name    == 'set'
# threading.Event.set.__code__.co_argcount == 1
# threading.Event.clear.__code__.co_name  == 'clear'
# threading.Event.clear.__code__.co_argcount == 1
# threading.Event.wait.__code__.co_name   == 'wait'
# threading.Event.wait.__code__.co_argcount == 2
#
# No prior threading spec checks Event.set/clear/wait code objects via threadingextra80. New to extra80.
# ---------------------------------------------------------------------------

table threading_extra80.Event_set_clear_wait_code:
  description: "Event.set.__code__.co_name=='set', co_argcount==1; clear co_name=='clear', co_argcount==1; wait co_name=='wait', co_argcount==2; wave 244 Event set/clear/wait code attrs; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra80

  columns: [id, function, args, expected, description]
  rows:
    - [Event_set_code_co_name_eq_set,
       Event.set.__code__.co_name.__eq__,
       ["set"],
       true,
       "threading.Event.set.__code__.co_name.__eq__('set') == True — Event is a pure-Python class defined in Lib/threading.py; its set method's code object co_name records the method name 'set' (3 chars); str.__eq__('set') returns True; no prior threading spec checks Event.set.__code__.co_name via threadingextra80; new to extra80"]
    - [Event_set_code_co_argcount_eq_1,
       Event.set.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Event.set.__code__.co_argcount.__eq__(1) == True — Event.set(self) takes exactly one positional argument, self; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior threading spec checks Event.set.__code__.co_argcount via threadingextra80; new to extra80"]
    - [Event_clear_code_co_name_eq_clear,
       Event.clear.__code__.co_name.__eq__,
       ["clear"],
       true,
       "threading.Event.clear.__code__.co_name.__eq__('clear') == True — Event is a pure-Python class defined in Lib/threading.py; its clear method's code object co_name records the method name 'clear' (5 chars); str.__eq__('clear') returns True; no prior threading spec checks Event.clear.__code__.co_name via threadingextra80; new to extra80"]
    - [Event_clear_code_co_argcount_eq_1,
       Event.clear.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Event.clear.__code__.co_argcount.__eq__(1) == True — Event.clear(self) takes exactly one positional argument, self; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior threading spec checks Event.clear.__code__.co_argcount via threadingextra80; new to extra80"]
    - [Event_wait_code_co_name_eq_wait,
       Event.wait.__code__.co_name.__eq__,
       ["wait"],
       true,
       "threading.Event.wait.__code__.co_name.__eq__('wait') == True — Event is a pure-Python class defined in Lib/threading.py; its wait method's code object co_name records the method name 'wait' (4 chars); str.__eq__('wait') returns True; no prior threading spec checks Event.wait.__code__.co_name via threadingextra80; new to extra80"]
    - [Event_wait_code_co_argcount_eq_2,
       Event.wait.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Event.wait.__code__.co_argcount.__eq__(2) == True — Event.wait(self, timeout=None) takes two positional-or-keyword arguments: self and timeout (timeout has a default of None but co_argcount still counts it); the code object's co_argcount is 2; int.__eq__(2) returns True; no prior threading spec checks Event.wait.__code__.co_argcount via threadingextra80; new to extra80"]

# ---------------------------------------------------------------------------
# Condition.wait code object — extra80
#
# Wave 244 theme: Condition.wait code attrs (distinct from Condition.__init__ in extra79).
#
# threading.Condition.wait.__code__.co_name     == 'wait'
# threading.Condition.wait.__code__.co_argcount == 2
#
# No prior threading spec checks Condition.wait code objects via threadingextra80. New to extra80.
# ---------------------------------------------------------------------------

table threading_extra80.Condition_wait_code:
  description: "Condition.wait.__code__.co_name=='wait', co_argcount==2; wave 244 Condition.wait code attrs; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra80

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_wait_code_co_name_eq_wait,
       Condition.wait.__code__.co_name.__eq__,
       ["wait"],
       true,
       "threading.Condition.wait.__code__.co_name.__eq__('wait') == True — Condition is a pure-Python class defined in Lib/threading.py; its wait method's code object co_name records the method name 'wait' (4 chars); str.__eq__('wait') returns True; no prior threading spec checks Condition.wait.__code__.co_name via threadingextra80; new to extra80"]
    - [Condition_wait_code_co_argcount_eq_2,
       Condition.wait.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Condition.wait.__code__.co_argcount.__eq__(2) == True — Condition.wait(self, timeout=None) takes two positional-or-keyword arguments: self and timeout (timeout has a default of None but co_argcount still counts it); the code object's co_argcount is 2; int.__eq__(2) returns True; no prior threading spec checks Condition.wait.__code__.co_argcount via threadingextra80; new to extra80"]

# ---------------------------------------------------------------------------
# Condition.notify and Condition.notify_all code objects — extra80
#
# Wave 244 theme: Condition.notify/notify_all code object attributes.
#
# threading.Condition.notify.__code__.co_name        == 'notify'
# threading.Condition.notify.__code__.co_argcount    == 2
# threading.Condition.notify_all.__code__.co_name    == 'notify_all'
# threading.Condition.notify_all.__code__.co_argcount == 1
#
# No prior threading spec checks Condition.notify/notify_all code objects via threadingextra80. New to extra80.
# ---------------------------------------------------------------------------

table threading_extra80.Condition_notify_notify_all_code:
  description: "Condition.notify.__code__.co_name=='notify', co_argcount==2; notify_all co_name=='notify_all', co_argcount==1; wave 244 Condition notify/notify_all code attrs; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra80

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_notify_code_co_name_eq_notify,
       Condition.notify.__code__.co_name.__eq__,
       ["notify"],
       true,
       "threading.Condition.notify.__code__.co_name.__eq__('notify') == True — Condition is a pure-Python class defined in Lib/threading.py; its notify method's code object co_name records the method name 'notify' (6 chars); str.__eq__('notify') returns True; no prior threading spec checks Condition.notify.__code__.co_name via threadingextra80; new to extra80"]
    - [Condition_notify_code_co_argcount_eq_2,
       Condition.notify.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Condition.notify.__code__.co_argcount.__eq__(2) == True — Condition.notify(self, n=1) takes two positional-or-keyword arguments: self and n (n has a default of 1 but co_argcount still counts it); the code object's co_argcount is 2; int.__eq__(2) returns True; no prior threading spec checks Condition.notify.__code__.co_argcount via threadingextra80; new to extra80"]
    - [Condition_notify_all_code_co_name_eq_notify_all,
       Condition.notify_all.__code__.co_name.__eq__,
       ["notify_all"],
       true,
       "threading.Condition.notify_all.__code__.co_name.__eq__('notify_all') == True — Condition is a pure-Python class defined in Lib/threading.py; its notify_all method's code object co_name records the method name 'notify_all' (10 chars); str.__eq__('notify_all') returns True; no prior threading spec checks Condition.notify_all.__code__.co_name via threadingextra80; new to extra80"]
    - [Condition_notify_all_code_co_argcount_eq_1,
       Condition.notify_all.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Condition.notify_all.__code__.co_argcount.__eq__(1) == True — Condition.notify_all(self) takes exactly one positional argument, self; it wakes all threads waiting on the condition by calling notify(n) with the number of waiters; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior threading spec checks Condition.notify_all.__code__.co_argcount via threadingextra80; new to extra80"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra80
# ---------------------------------------------------------------------------

invariant threading_extra80.Semaphore_acquire_code_co_name:
  description: "threading.Semaphore.acquire.__code__.co_name.__eq__('acquire') == True — Semaphore.acquire code object name is 'acquire'; wave 244 Semaphore.acquire code attrs; new to extra80"
  kind: python_call_eq
  function: Semaphore.acquire.__code__.co_name.__eq__
  args: ["acquire"]
  expected: true

invariant threading_extra80.Semaphore_acquire_code_co_argcount:
  description: "threading.Semaphore.acquire.__code__.co_argcount.__eq__(3) == True — Semaphore.acquire(self, blocking=True, timeout=None) has 3 positional-or-keyword args; wave 244 Semaphore.acquire code attrs; new to extra80"
  kind: python_call_eq
  function: Semaphore.acquire.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant threading_extra80.Event_set_code_co_argcount:
  description: "threading.Event.set.__code__.co_argcount.__eq__(1) == True — Event.set(self) has 1 positional arg; wave 244 Event.set code attrs; new to extra80"
  kind: python_call_eq
  function: Event.set.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra80.Condition_notify_code_co_argcount:
  description: "threading.Condition.notify.__code__.co_argcount.__eq__(2) == True — Condition.notify(self, n=1) has 2 positional-or-keyword args; wave 244 Condition.notify code attrs; new to extra80"
  kind: python_call_eq
  function: Condition.notify.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra80.Condition_notify_all_code_co_name:
  description: "threading.Condition.notify_all.__code__.co_name.__eq__('notify_all') == True — Condition.notify_all code object name is 'notify_all'; wave 244 Condition.notify_all code attrs; new to extra80"
  kind: python_call_eq
  function: Condition.notify_all.__code__.co_name.__eq__
  args: ["notify_all"]
  expected: true
