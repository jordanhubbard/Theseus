spec: re_extra1021
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module Pattern, Match, and error documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.Pattern, re.Match, re.error __weakref__ descriptors and module-level metadata types"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1021.class_weakref:
  description: "re.Pattern, re.Match, and re.error __weakref__ descriptor identity"
  kind: python_call_eq
  category: weakref_descriptor
  id_prefix: re1021x
  columns: [id, function, args, expected]
  rows:
    - [re1021x001, re.Pattern.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true]
    - [re1021x002, re.Match.__weakref__.__class__.__name__.__eq__,    ["getset_descriptor"], true]
    - [re1021x003, re.error.__weakref__.__class__.__name__.__eq__,    ["getset_descriptor"], true]

table re_extra1021.module_meta:
  description: "re module-level metadata type checks"
  kind: python_call_eq
  category: module_meta
  id_prefix: re1021m
  columns: [id, function, args, expected]
  rows:
    - [re1021m001, re.__all__.__class__.__name__.__eq__,      ["list"], true]
    - [re1021m002, re.__cached__.__class__.__name__.__eq__,   ["str"],  true]
    - [re1021m003, re.__file__.__class__.__name__.__eq__,     ["str"],  true]
    - [re1021m004, re.__name__.__class__.__name__.__eq__,     ["str"],  true]
    - [re1021m005, re.__package__.__class__.__name__.__eq__,  ["str"],  true]
    - [re1021m006, re.__spec__.__class__.__name__.__eq__,     ["ModuleSpec"], true]

table re_extra1021.class_module:
  description: "re class __module__ and __name__ identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: re1021c
  columns: [id, function, args, expected]
  rows:
    - [re1021c001, re.Pattern.__name__.__eq__,        ["Pattern"], true]
    - [re1021c002, re.Match.__name__.__eq__,          ["Match"],   true]
    - [re1021c003, re.error.__name__.__eq__,          ["error"],   true]
    - [re1021c004, re.error.__module__.__eq__,        ["re"],      true]
    - [re1021c005, re.Pattern.__module__.__eq__,      ["re"],      true]
    - [re1021c006, re.Match.__module__.__eq__,        ["re"],      true]
    - [re1021c007, re.error.__class__.__name__.__eq__, ["type"],   true]
