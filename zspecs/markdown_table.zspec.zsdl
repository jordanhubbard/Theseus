spec: markdown_table
version: ">=3.0.0"
backend: node(markdown-table)

docs: https://github.com/wooorm/markdown-table#readme

provenance:
  derived_from:
    - "markdown-table README — https://github.com/wooorm/markdown-table#readme"
    - "GitHub Flavored Markdown table specification — https://github.github.com/gfm/#tables-extension-"
    - "Test vectors verified with markdown-table via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "markdown-table source"
  notes:
    - "markdown-table generates GitHub-Flavored-Markdown tables from a 2D array."
    - "Install: npm install markdown-table"
    - "The package exports {markdownTable: function}; use entry:named function:markdownTable."
    - "Output is column-aligned with each cell padded to the widest entry in its column."
    - "First row is treated as the header; a separator row '| - | - |' is inserted after it."
    - "Trailing newline is NOT included; the result ends at the last data row."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function — never throws on a valid 2D array input."
  stderr: "null"
  stickiness: "N/A — each call is independent."
  codes: {}

table markdown_table.format:
  kind: node_chain_eq
  category: format
  entry: named
  function: markdownTable
  id_prefix: tbl

  columns: [id, entry_args, chain, expected]
  rows:
    - [two_columns_two_rows,
       [[["a", "b"], ["1", "2"]]],
       [],
       "| a | b |\n| - | - |\n| 1 | 2 |"]

    - [name_age_aligned,
       [[["Name", "Age"], ["Alice", "30"], ["Bob", "25"]]],
       [],
       "| Name  | Age |\n| ----- | --- |\n| Alice | 30  |\n| Bob   | 25  |"]

    - [single_column_header_only,
       [[["x"]]],
       [],
       "| x |\n| - |"]

    - [single_row_no_data,
       [[["col1", "col2"]]],
       [],
       "| col1 | col2 |\n| ---- | ---- |"]
