spec: threading_extra418
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.__name__ == 'threading' — the module's __name__ attribute is the string 'threading'. Verified with Python 3.14.0."
    - "threading.__package__ == '' — threading is a top-level module; its __package__ is the empty string. Verified with Python 3.14.0."
    - "threading.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec object is an instance of importlib.machinery.ModuleSpec. Verified with Python 3.14.0."
    - "threading.Condition.wait.__name__ == 'wait' — Condition.wait is a Python function defined in Lib/threading.py; __name__ is 'wait'. Verified with Python 3.14.0."
    - "threading.Condition.notify.__name__ == 'notify' — Condition.notify is a Python function defined in Lib/threading.py; __name__ is 'notify'. Verified with Python 3.14.0."
    - "threading.Condition.notify_all.__name__ == 'notify_all' — Condition.notify_all is a Python function defined in Lib/threading.py; __name__ is 'notify_all'. Verified with Python 3.14.0."
    - "threading.Condition.acquire and threading.Condition.release are NOT direct attributes of the Condition class; they are delegated to the underlying lock at instance creation time and are not present in Condition.__dict__. Verified with Python 3.14.0."
    - "All expected values verified by running Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading module identity attributes
#
# threading is a pure-Python module (Lib/threading.py). Its __name__,
# __package__, and __spec__.__class__.__name__ reflect its identity as a
# top-level standard-library module. All values verified with Python 3.14.0.
# ---------------------------------------------------------------------------

table threading_extra418.module_identity:
  description: "threading module identity attribute values — __name__, __package__, __spec__ class; new to extra418"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmi418

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       "__name__.__eq__",
       ["threading"],
       true,
       "threading.__name__.__eq__('threading') == True — the module's __name__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra418"]
    - [module_package_eq,
       "__package__.__eq__",
       [""],
       true,
       "threading.__package__.__eq__('') == True — threading is a top-level module with empty __package__; str.__eq__('') returns True; new to extra418"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is an importlib.machinery.ModuleSpec instance; str.__eq__('ModuleSpec') returns True; new to extra418"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition method __name__ values
#
# threading.Condition is a plain Python class defined in Lib/threading.py.
# Its wait, notify, and notify_all methods are Python functions; their
# __name__ attribute equals the bare method name string. Note: acquire and
# release are not present on the Condition class directly — they are
# delegated to the underlying lock at instance creation time.
# ---------------------------------------------------------------------------

table threading_extra418.condition_method_name:
  description: "threading.Condition method __name__ values — wait, notify, notify_all defined in Lib/threading.py; new to extra418"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcm418

  columns: [id, function, args, expected, description]
  rows:
    - [condition_wait_name_eq,
       "Condition.wait.__name__.__eq__",
       ["wait"],
       true,
       "threading.Condition.wait.__name__.__eq__('wait') == True — wait is a Python method on Condition defined in Lib/threading.py; __name__ is 'wait'; str.__eq__('wait') returns True; new to extra418"]
    - [condition_notify_name_eq,
       "Condition.notify.__name__.__eq__",
       ["notify"],
       true,
       "threading.Condition.notify.__name__.__eq__('notify') == True — notify is a Python method on Condition defined in Lib/threading.py; __name__ is 'notify'; str.__eq__('notify') returns True; new to extra418"]
    - [condition_notify_all_name_eq,
       "Condition.notify_all.__name__.__eq__",
       ["notify_all"],
       true,
       "threading.Condition.notify_all.__name__.__eq__('notify_all') == True — notify_all is a Python method on Condition defined in Lib/threading.py; __name__ is 'notify_all'; str.__eq__('notify_all') returns True; new to extra418"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra418
# ---------------------------------------------------------------------------

invariant threading_extra418.module_name:
  description: "threading.__name__ == 'threading' — module's __name__ attribute is 'threading'; new to extra418"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra418.module_package:
  description: "threading.__package__ == '' — top-level module has empty __package__; new to extra418"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant threading_extra418.spec_class_name:
  description: "threading.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec instance; new to extra418"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant threading_extra418.condition_wait_name:
  description: "threading.Condition.wait.__name__ == 'wait' — Python method on Condition; new to extra418"
  kind: python_call_eq
  function: Condition.wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant threading_extra418.condition_notify_name:
  description: "threading.Condition.notify.__name__ == 'notify' — Python method on Condition; new to extra418"
  kind: python_call_eq
  function: Condition.notify.__name__.__eq__
  args: ["notify"]
  expected: true

invariant threading_extra418.condition_notify_all_name:
  description: "threading.Condition.notify_all.__name__ == 'notify_all' — Python method on Condition; new to extra418"
  kind: python_call_eq
  function: Condition.notify_all.__name__.__eq__
  args: ["notify_all"]
  expected: true
