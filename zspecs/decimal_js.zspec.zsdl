spec: decimal_js
version: ">=10.0.0"
backend: node(decimal.js)

docs: https://www.npmjs.com/package/decimal.js

provenance:
  derived_from:
    - "decimal.js README — https://www.npmjs.com/package/decimal.js"
    - "Test vectors verified with decimal.js via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "decimal.js source"
  notes:
    - "decimal.js is an npm package. Install: npm install decimal.js"
    - "Decimal(val) constructs a high-precision decimal; callable with or without new."
    - "Provides toString(), toNumber(), isInteger() and arithmetic operations."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns precise decimal value or boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table decimal_js.toString:
  kind: node_factory_call_eq
  factory: Decimal
  method: toString
  category: format
  id_prefix: decjstr

  columns: [id, factory_args, expected]
  rows:
    - [pi,    ["3.14"],                  "3.14"]
    - [large, ["12345678901234567890"],  "12345678901234567890"]
    - [small, ["0.0001"],               "0.0001"]

table decimal_js.toNumber:
  kind: node_factory_call_eq
  factory: Decimal
  method: toNumber
  category: convert
  id_prefix: decjnum

  columns: [id, factory_args, expected]
  rows:
    - [pi,  ["3.14"], 3.14]
    - [neg, ["-5"],   -5]

table decimal_js.isInteger:
  kind: node_factory_call_eq
  factory: Decimal
  method: isInteger
  category: predicate
  id_prefix: decjint

  columns: [id, factory_args, expected]
  rows:
    - [integer,   ["3"],   true]
    - [not_int,   ["3.5"], false]
