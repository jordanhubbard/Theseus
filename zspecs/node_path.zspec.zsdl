spec: node_path
version: ">=12.0.0"
backend: node(path)

docs: https://nodejs.org/api/path.html

provenance:
  derived_from:
    - "Node.js path module documentation — https://nodejs.org/api/path.html"
    - "Test vectors verified with Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "Node.js source"
  notes:
    - "path is a Node.js built-in module. No npm install required."
    - "All path operations use POSIX semantics on Linux/macOS."
    - "path.parse returns an object with root, dir, base, ext, name fields."
    - "path.join normalizes separators; path.normalize collapses redundant slashes and .."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns strings or objects. No errors for valid string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table node_path.join:
  kind: node_module_call_eq
  function: join
  category: join
  id_prefix: pathjoin

  columns: [id, args, expected]
  rows:
    - [simple,    ["foo", "bar", "baz"],     "foo/bar/baz"]
    - [absolute,  ["/foo", "bar"],            "/foo/bar"]
    - [dotdot,    ["/foo/bar", "../baz"],     "/foo/baz"]
    - [trailing,  ["foo/", "bar"],            "foo/bar"]

table node_path.dirname:
  kind: node_module_call_eq
  function: dirname
  category: dirname
  id_prefix: pathdir

  columns: [id, args, expected]
  rows:
    - [file,      ["/foo/bar/baz.txt"],  "/foo/bar"]
    - [dir,       ["/foo/bar"],          "/foo"]
    - [root,      ["/foo"],              "/"]
    - [relative,  ["foo/bar/baz.txt"],   "foo/bar"]

table node_path.basename:
  kind: node_module_call_eq
  function: basename
  category: basename
  id_prefix: pathbase

  columns: [id, args, expected]
  rows:
    - [with_ext,    ["/foo/bar/baz.txt"],          "baz.txt"]
    - [strip_ext,   ["/foo/bar/baz.txt", ".txt"],  "baz"]
    - [no_ext,      ["/foo/bar/baz"],              "baz"]

table node_path.extname:
  kind: node_module_call_eq
  function: extname
  category: extname
  id_prefix: pathext

  columns: [id, args, expected]
  rows:
    - [txt,      ["/foo/bar/baz.txt"],  ".txt"]
    - [js,       ["/foo/bar/index.js"], ".js"]
    - [no_ext,   ["/foo/bar/baz"],      ""]
    - [hidden,   ["/foo/.bashrc"],      ""]

table node_path.normalize:
  kind: node_module_call_eq
  function: normalize
  category: normalize
  id_prefix: pathnorm

  columns: [id, args, expected]
  rows:
    - [double_slash,  ["/foo//bar"],           "/foo/bar"]
    - [dotdot,        ["/foo/bar/../baz"],      "/foo/baz"]
    - [dot,           ["/foo/./bar"],           "/foo/bar"]

table node_path.isAbsolute:
  kind: node_module_call_eq
  function: isAbsolute
  category: isAbsolute
  id_prefix: pathabs

  columns: [id, args, expected]
  rows:
    - [abs,       ["/foo/bar"],   true]
    - [rel,       ["foo/bar"],    false]
    - [dot_rel,   ["./foo"],      false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:00:05Z
  iterations: 1
  pass_count: 21
  fail_count: 0
  total_invariants: 21
  notes: Synthesis succeeded in 1 iteration(s). 21 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
