spec: lodash_upperfirst
version: ">=4.0.0"
backend: node(lodash.upperfirst)

docs: https://lodash.com/docs/#upperFirst

provenance:
  derived_from:
    - "lodash.upperfirst README — https://www.npmjs.com/package/lodash.upperfirst"
    - "Test vectors verified with lodash.upperfirst@4.3.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.upperfirst exports the _.upperFirst function directly as module.exports."
    - "upperFirst(string) converts the first character to upper case."
    - "Only the first character is changed; the rest is left as-is."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string with first character uppercased."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_upperfirst.upperfirst:
  kind: node_module_call_eq
  function: ~
  category: upperfirst
  id_prefix: lupf

  columns: [id, args, expected]
  rows:
    - [lower,    ["hello"],    "Hello"]
    - [upper,    ["Hello"],    "Hello"]
    - [all_low,  ["foo bar"],  "Foo bar"]
    - [empty,    [""],         ""]
