spec: buffer_from
version: ">=1.1.2"
backend: node(buffer-from)

docs: https://www.npmjs.com/package/buffer-from

provenance:
  derived_from:
    - "buffer-from README — https://www.npmjs.com/package/buffer-from"
    - "Test vectors verified with buffer-from via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "buffer-from source"
  notes:
    - "buffer-from is an npm package. Install: npm install buffer-from"
    - "Creates a Buffer from a string, array, or ArrayBuffer."
    - "JSON-serializes as {type: 'Buffer', data: [...bytes]}."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a Buffer object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table buffer_from.bufferFrom:
  kind: node_module_call_eq
  function: ~
  category: convert
  id_prefix: buffrom

  columns: [id, args, expected]
  rows:
    - [string, ["hello"],
       {"type": "Buffer", "data": [104, 101, 108, 108, 111]}]
    - [array,  [[72, 105]],
       {"type": "Buffer", "data": [72, 105]}]

