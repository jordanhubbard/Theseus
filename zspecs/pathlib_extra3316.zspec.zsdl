spec: pp3316
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (pp3316): __ipow__, __ilshift__, __irshift__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __ipow__, __ilshift__, __irshift__ dict-presence (in-place **=, <<=, >>=)."
    - "No pathlib class defines __ipow__ in its own __dict__: path objects are filesystem path abstractions, not numeric types; in-place exponentiation has no meaning for paths."
    - "No pathlib class defines __ilshift__ in its own __dict__: path objects do not implement in-place left-shift; bitwise operators have no meaning for filesystem paths."
    - "No pathlib class defines __irshift__ in its own __dict__: path objects do not implement in-place right-shift; augmented bitwise assignment operators are not part of the path protocol."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with waves 666/667 pattern: all in-place arithmetic/bitwise operators absent from pathlib class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — operator.contains(Cls.__dict__, '__ipow__')
#
# No pathlib class defines __ipow__ in its own __dict__; all false.
# pathlib path objects are filesystem path abstractions, not numeric types;
# the **= operator has no semantic meaning for path objects.
# ---------------------------------------------------------------------------

table pp3316.ipow:
  description: "pathlib types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3316

  columns: [id, function, args, expected]
  rows:
    - ["pp3316001", operator.contains, [pathlib.PurePath.__dict__,         "__ipow__"], false]
    - ["pp3316002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__ipow__"], false]
    - ["pp3316003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__ipow__"], false]
    - ["pp3316004", operator.contains, [pathlib.Path.__dict__,             "__ipow__"], false]
    - ["pp3316005", operator.contains, [pathlib.PosixPath.__dict__,        "__ipow__"], false]

