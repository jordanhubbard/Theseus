spec: hashlib_extra2056
version: ">=3.9"
backend: python_module(_hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_hashopenssl.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "_hashlib.HASH is a cryptographic digest C type; it defines none of the sequence/mapping or attribute access protocol methods in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2056.getitem_protocol:
  description: "_hashlib.HASH __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2056

  columns: [id, function, args, expected]
  rows:
    - ["hl2056001", "_hashlib.HASH.__dict__.__contains__", ["__getitem__"], false]
    - ["hl2056002", "_hashlib.HASH.__dict__.__contains__", ["__setitem__"], false]
    - ["hl2056003", "_hashlib.HASH.__dict__.__contains__", ["__delitem__"], false]

