spec: yargs_parser
version: ">=22.0.0"
backend: node(yargs-parser)

docs: https://www.npmjs.com/package/yargs-parser

provenance:
  derived_from:
    - "yargs-parser README — https://www.npmjs.com/package/yargs-parser"
    - "Test vectors verified with yargs-parser via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "yargs-parser source"
  notes:
    - "yargs-parser is an npm package. Install: npm install yargs-parser"
    - "Parses argv arrays into an object. Returns {_: positional_args, ...flags}."
    - "Module exports a function directly (not via default)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a parsed arguments object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table yargs_parser.parse:
  kind: node_module_call_eq
  function: ~
  category: parse
  id_prefix: yargsparse

  columns: [id, args, expected]
  rows:
    - [named_string, [["--foo", "bar"]],          {"_": [], "foo": "bar"}]
    - [named_int,    [["--a", "1"]],               {"_": [], "a": 1}]
    - [short_flag,   [["-b"]],                     {"_": [], "b": true}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:42:20Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
