spec: socket_extra76
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra75.zspec.zsdl — covers socket.socket.__dict__.__contains__ close/detach/dup/sendfile/get_inheritable/set_inheritable / gethostname/gethostbyname/getnameinfo/setdefaulttimeout/__qualname__ (table + invariants)."
    - "socket_extra69.zspec.zsdl — covers socket.socket.__dict__.__contains__ accept/makefile/setblocking/settimeout (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra75; it does NOT duplicate invariants present in those files."
    - "Wave 243 theme: socket.socket class __dict__ content (context manager and repr methods) + AddressFamily/SocketKind identity."
    - "NOTE: connect/bind/listen/recv/send/fileno/settimeout/gettimeout/setblocking are NOT in socket.socket.__dict__ — they are inherited from the C extension _socket.socket and not overridden in the Python socket.socket class. socket_extra69 checks accept/makefile/setblocking/settimeout — which despite being listed in socket.py ARE in __dict__; fileno is NOT."
    - "socket.socket.__dict__.__contains__('__enter__') == True — __enter__ is defined on socket.socket in socket.py as a context manager method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__exit__') == True — __exit__ is defined on socket.socket in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__repr__') == True — __repr__ is defined on socket.socket in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('family') == True — family is defined as a property descriptor on socket.socket in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('type') == True — type is defined as a property descriptor on socket.socket in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__class__.__name__ == 'EnumType' — AddressFamily is an IntFlag enum whose metaclass is EnumType. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__class__.__name__ == 'EnumType' — SocketKind is an IntEnum whose metaclass is EnumType. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__module__ == 'socket' — AddressFamily is defined in the socket module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__module__ == 'socket' — SocketKind is defined in the socket module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__ for __enter__ and __exit__
#
# Wave 243 theme: socket.socket class __dict__ context manager methods.
#
# socket.socket defines __enter__ and __exit__ as Python methods in socket.py
# enabling use as a context manager. socket_extra69 covers accept/makefile/
# setblocking/settimeout; socket_extra75 covers close/detach/dup/sendfile/
# get_inheritable/set_inheritable. No prior socket spec checks __enter__ or
# __exit__ in socket.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra76.socket_dict_contains_enter_exit:
  description: "socket.socket/__dict__.__contains__('__enter__')==True / __contains__('__exit__')==True — __enter__ and __exit__ are Python methods defined in socket.py enabling context manager use; socket_extra69/extra75 cover other Python methods; no prior socket spec checks __enter__ or __exit__ in socket.__dict__; first context manager dict contains anchor for socket.socket"
  kind: python_call_eq
  category: class_dict
  id_prefix: socketmore76

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_contains_enter, socket.__dict__.__contains__, ["__enter__"], true]
    - [socket_dict_contains_exit,  socket.__dict__.__contains__, ["__exit__"],  true]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__ for __repr__, family, and type
#
# Wave 243 theme: socket.socket class __dict__ repr and property methods.
#
# socket.socket defines __repr__, family, and type in socket.py. No prior
# socket spec checks __repr__, family, or type in socket.__dict__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra76.socket_dict_contains_repr_family_type:
  description: "socket.socket/__dict__.__contains__('__repr__')==True / __contains__('family')==True / __contains__('type')==True — __repr__/family/type are defined in socket.py on socket.socket; no prior socket spec checks __repr__/family/type in socket.__dict__; first repr and property dict contains anchor for socket.socket"
  kind: python_call_eq
  category: class_dict
  id_prefix: socketmore76

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_contains_repr,   socket.__dict__.__contains__, ["__repr__"], true]
    - [socket_dict_contains_family, socket.__dict__.__contains__, ["family"],   true]
    - [socket_dict_contains_type,   socket.__dict__.__contains__, ["type"],     true]

# ---------------------------------------------------------------------------
# socket.AddressFamily and SocketKind __class__.__name__ == 'EnumType'
#
# Wave 243 theme: AddressFamily/SocketKind enum metaclass identity.
#
# socket.AddressFamily is an IntFlag enum; socket.SocketKind is an IntEnum.
# Both are enum classes whose metaclass is EnumType. No prior socket spec
# checks AddressFamily.__class__.__name__ or SocketKind.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra76.AddressFamily_SocketKind_class_name:
  description: "socket.AddressFamily/__class__/__name__.__eq__('EnumType')==True / SocketKind/__class__/__name__.__eq__('EnumType')==True — AddressFamily is an IntFlag enum and SocketKind is an IntEnum; both have EnumType as their metaclass; no prior socket spec checks AddressFamily.__class__.__name__ or SocketKind.__class__.__name__; first EnumType metaclass anchor for AddressFamily and SocketKind"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketmore76

  columns: [id, function, args, expected]
  rows:
    - [AddressFamily_class_EnumType, AddressFamily.__class__.__name__.__eq__, ["EnumType"], true]
    - [SocketKind_class_EnumType,    SocketKind.__class__.__name__.__eq__,    ["EnumType"], true]

# ---------------------------------------------------------------------------
# socket.AddressFamily and SocketKind __module__ == 'socket'
#
# Wave 243 theme: AddressFamily/SocketKind module identity.
#
# socket.AddressFamily and socket.SocketKind are defined in the socket module.
# Their __module__ is 'socket'. No prior socket spec checks AddressFamily.__module__
# or SocketKind.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra76.AddressFamily_SocketKind_module:
  description: "socket.AddressFamily/__module__.__eq__('socket')==True / SocketKind/__module__.__eq__('socket')==True — AddressFamily and SocketKind are defined in the socket module; their __module__ is 'socket'; no prior socket spec checks AddressFamily.__module__ or SocketKind.__module__; first __module__ anchor for AddressFamily and SocketKind"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketmore76

  columns: [id, function, args, expected]
  rows:
    - [AddressFamily_module_socket, AddressFamily.__module__.__eq__, ["socket"], true]
    - [SocketKind_module_socket,    SocketKind.__module__.__eq__,    ["socket"], true]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('__enter__') — standalone
#
# socket.socket defines __enter__ in its __dict__. No prior socket spec checks
# __enter__ in socket.__dict__ as a standalone. First __enter__ dict contains
# standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra76.socket_dict_contains_enter:
  description: "socket.socket.__dict__.__contains__('__enter__') == True — __enter__ is a Python method defined in socket.py; no prior socket spec checks __enter__ in socket.__dict__ as a standalone; first __enter__ dict contains standalone"
  category: class_dict
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["__enter__"]
  expected: true

