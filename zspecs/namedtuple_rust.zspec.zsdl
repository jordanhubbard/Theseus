spec: namedtuple_rust
version: ">=3.9"
backend: rust_module(namedtuple_rust)

docs: https://docs.python.org/3/library/collections.html#collections.namedtuple

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html#collections.namedtuple — Python namedtuple documentation"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
  notes:
    - "Clean-room Rust reimplementation of Python collections.namedtuple, exposed via PyO3."
    - "namedtuple(typename, field_names) creates a new named tuple class."
    - "Point = namedtuple('Point', ['x', 'y']) creates a 2-field named tuple class."
    - "Point._fields == ('x', 'y') — tuple of field names."
    - "Point(1, 2).__len__() == 2 — length equals number of fields."
    - "Point(1, 2)._asdict() == {'x': 1, 'y': 2} — ordered dict of field names to values."
    - "Color = namedtuple('Color', ['r', 'g', 'b']) — 3-field named tuple."
    - "Color._fields == ('r', 'g', 'b')."
    - "Color(255, 0, 0).__len__() == 3."
    - "All test vectors verified against Python 3.14.3 collections.namedtuple."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# namedtuple — _fields class attribute (field name tuple)
invariant namedtuple_rust.Point._fields:
  description: "namedtuple('Point', ['x', 'y'])._fields == ('x', 'y')"
  category: namedtuple
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: _fields
  expected: ["x", "y"]

invariant namedtuple_rust.Color._fields:
  description: "namedtuple('Color', ['r', 'g', 'b'])._fields == ('r', 'g', 'b')"
  category: namedtuple
  kind: python_call_eq
  function: namedtuple
  args: ["Color", ["r", "g", "b"]]
  method: _fields
  expected: ["r", "g", "b"]

# namedtuple — instance length via __call__ + method_chain
invariant namedtuple_rust.Point.len:
  description: "namedtuple('Point', ['x', 'y'])(1, 2).__len__() == 2"
  category: namedtuple
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: __call__
  method_args: [1, 2]
  method_chain: __len__
  expected: 2

invariant namedtuple_rust.Color.len:
  description: "namedtuple('Color', ['r', 'g', 'b'])(255, 0, 0).__len__() == 3"
  category: namedtuple
  kind: python_call_eq
  function: namedtuple
  args: ["Color", ["r", "g", "b"]]
  method: __call__
  method_args: [255, 0, 0]
  method_chain: __len__
  expected: 3

# namedtuple — _asdict() returns ordered dict of fields
invariant namedtuple_rust.Point._asdict:
  description: "namedtuple('Point', ['x', 'y'])(1, 2)._asdict() == {'x': 1, 'y': 2}"
  category: namedtuple
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: __call__
  method_args: [1, 2]
  method_chain: _asdict
  expected: {x: 1, y: 2}

invariant namedtuple_rust.Color._asdict:
  description: "namedtuple('Color', ['r', 'g', 'b'])(255, 0, 0)._asdict() == {'r': 255, 'g': 0, 'b': 0}"
  category: namedtuple
  kind: python_call_eq
  function: namedtuple
  args: ["Color", ["r", "g", "b"]]
  method: __call__
  method_args: [255, 0, 0]
  method_chain: _asdict
  expected: {r: 255, g: 0, b: 0}

