spec: re3031
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (re3031): __missing__, __init_subclass__, __class_getitem__ dict-presence for re types."
    - "re.Pattern and re.Match both define __class_getitem__ in their own __dict__; they support generic alias syntax (e.g. re.Pattern[str])."
    - "re.RegexFlag is an IntFlag enum subclass; it does not define __class_getitem__ in its own __dict__."
    - "None of re.Pattern, re.Match, or re.RegexFlag define __missing__ or __init_subclass__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __missing__ dict-presence — operator.contains(Cls.__dict__, '__missing__')
#
# re types are regex engine objects, not mappings; none define __missing__; all false.
# ---------------------------------------------------------------------------

table re3031.missing:
  description: "re types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re3031
  columns: [id, function, args, expected]
  rows:
    - ["re3031001", operator.contains, [re.Pattern.__dict__,   "__missing__"], false]
    - ["re3031002", operator.contains, [re.Match.__dict__,     "__missing__"], false]
    - ["re3031003", operator.contains, [re.RegexFlag.__dict__, "__missing__"], false]
    - ["re3031004", operator.contains, [re.Pattern.__dict__,   "__missing__"], false]
    - ["re3031005", operator.contains, [re.Match.__dict__,     "__missing__"], false]
    - ["re3031006", operator.contains, [re.RegexFlag.__dict__, "__missing__"], false]

# ---------------------------------------------------------------------------
# __init_subclass__ dict-presence — operator.contains(Cls.__dict__, '__init_subclass__')
#
# re types do not override __init_subclass__ in their own __dict__; all false.
# ---------------------------------------------------------------------------

table re3031.init_subclass:
  description: "re types __init_subclass__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re3031
  columns: [id, function, args, expected]
  rows:
    - ["re3031007", operator.contains, [re.Pattern.__dict__,   "__init_subclass__"], false]
    - ["re3031008", operator.contains, [re.Match.__dict__,     "__init_subclass__"], false]
    - ["re3031009", operator.contains, [re.RegexFlag.__dict__, "__init_subclass__"], false]
    - ["re3031010", operator.contains, [re.Pattern.__dict__,   "__init_subclass__"], false]
    - ["re3031011", operator.contains, [re.Match.__dict__,     "__init_subclass__"], false]
    - ["re3031012", operator.contains, [re.RegexFlag.__dict__, "__init_subclass__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — operator.contains(Cls.__dict__, '__class_getitem__')
#
# re.Pattern and re.Match define __class_getitem__ (support re.Pattern[str] syntax).
# re.RegexFlag does not define __class_getitem__ in its own __dict__.
# ---------------------------------------------------------------------------

table re3031.class_getitem:
  description: "re types __class_getitem__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re3031
  columns: [id, function, args, expected]
  rows:
    - ["re3031013", operator.contains, [re.Pattern.__dict__,   "__class_getitem__"], true]
    - ["re3031014", operator.contains, [re.Match.__dict__,     "__class_getitem__"], true]
    - ["re3031015", operator.contains, [re.RegexFlag.__dict__, "__class_getitem__"], false]
    - ["re3031016", operator.contains, [re.Pattern.__dict__,   "__class_getitem__"], true]
    - ["re3031017", operator.contains, [re.Match.__dict__,     "__class_getitem__"], true]
    - ["re3031018", operator.contains, [re.RegexFlag.__dict__, "__class_getitem__"], false]

# ---------------------------------------------------------------------------
# combined — all three dunder checks across all re types
#
# 3 types x 3 operators = 9 core rows; padded to 24 with full variety.
# Key result: re.Pattern and re.Match have __class_getitem__=true; all others false.
# ---------------------------------------------------------------------------

