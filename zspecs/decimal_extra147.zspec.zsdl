spec: decimal_extra147
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.__dict__.__len__()==49 and decimal.__dict__.__class__.__name__=='dict' (the public decimal module namespace). Also covers _decimal.__dict__.__len__()==47 and _decimal.__dict__.__class__.__name__=='dict' (the private C extension). Unlike the io vs _io comparison (37 vs 25), the decimal vs _decimal sizes are very close (49 vs 47) — the C extension nearly equals the public module because decimal is mostly implemented in C."
    - "decimal.__dict__.__len__() == 49; _decimal.__dict__.__len__() == 47. The 2-entry difference: decimal adds '__builtins__' and '__cached__' which are module-level attributes added by Python's import machinery for pure-Python modules; _decimal as a C extension does not have these."
    - "_decimal has entries NOT in decimal (by name): none — all _decimal names are also present in decimal under the same name. Decimal and Context in _decimal.__dict__ have __module__ == 'decimal' (not '_decimal')."
    - "_decimal has __version__ == '1.70' and __libmpdec_version__ == '4.0.1' — version attributes unique to the C extension that are not re-exported by the public decimal module."
    - "_decimal has HAVE_CONTEXTVAR, HAVE_THREADS, IEEE_CONTEXT_MAX_BITS, MAX_EMAX, MAX_PREC, MIN_EMIN, MIN_ETINY — C implementation constants exposed by _decimal but not all re-exported by decimal."
    - "decimal.MAX_PREC == 999999999999999999 (the maximum precision for the C decimal implementation; 18 nines; a very large value reflecting that _decimal uses 64-bit integers for the coefficient)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.__dict__ vs _decimal.__dict__ namespace size comparison
# decimal.__dict__.__len__() == 49 (public Python module wrapper).
# _decimal.__dict__.__len__() == 47 (private C extension — nearly the same).
# Both are plain dicts.
# The 2-entry difference: decimal has __builtins__ and __cached__ (added by
# Python's import machinery for pure-Python modules); _decimal does not.
# ---------------------------------------------------------------------------

table decimal_extra147.module_namespace_sizes:
  description: "decimal.__dict__.__len__()==49; _decimal.__dict__.__len__()==47; both are plain dicts; the 2-entry gap reflects __builtins__ and __cached__ in the Python wrapper module"
  kind: python_call_eq
  category: identity
  id_prefix: decnames147

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_dict_len,   __dict__.__len__,                   [], 49,   "decimal.__dict__.__len__() == 49 (the public decimal module exports 49 names; 2 more than _decimal.__dict__.__len__() (47) due to __builtins__ and __cached__ which Python's import machinery adds to pure-Python module dicts)"]
    - [decimal_dict_cls,   __dict__.__class__.__name__.__eq__, ["dict"], true, "decimal.__dict__.__class__.__name__ == 'dict' (the public decimal module __dict__ is a plain mutable Python dict; same as _decimal even though _decimal is a C extension — both C and Python module __dict__ attributes are plain dicts, not mappingproxy)"]

# ---------------------------------------------------------------------------
# _decimal C extension: unique attributes not re-exported by decimal
# _decimal has __version__, __libmpdec_version__, HAVE_CONTEXTVAR,
# HAVE_THREADS, IEEE_CONTEXT_MAX_BITS, MAX_EMAX, MIN_EMIN, MIN_ETINY,
# IEEEContext, BasicContext, DefaultContext, ExtendedContext.
# ---------------------------------------------------------------------------

table decimal_extra147._decimal_unique_membership:
  description: "_decimal.__dict__: has __version__=='1.70', __libmpdec_version__, IEEEContext, BasicContext, DefaultContext, ExtendedContext, HAVE_CONTEXTVAR, HAVE_THREADS, IEEE_CONTEXT_MAX_BITS"
  kind: python_call_eq
  category: identity
  id_prefix: decnames147

  columns: [id, function, args, expected, description]
  rows:
    - [dec_module_eq,       Decimal.__module__.__eq__,  ["decimal"], true, "decimal.Decimal.__module__ == 'decimal' (Decimal's __module__ is the public 'decimal' module, not '_decimal'; the C extension sets __module__ to 'decimal' so that type annotations and repr reference the public module)"]
    - [ctx_module_eq,       Context.__module__.__eq__,  ["decimal"], true, "decimal.Context.__module__ == 'decimal' (same as Decimal; the C extension sets Context.__module__ to the public module name; this ensures repr(decimal.getcontext()) shows 'decimal.Context' not '_decimal.Context')"]
    - [dec_name_eq,         Decimal.__name__.__eq__,    ["Decimal"], true, "decimal.Decimal.__name__ == 'Decimal' (len=7; the class name without module prefix; same length as 'Context' (7), 'Pattern' (7 in re), and 'decimal' (7, the module name itself))"]
    - [dec_name_len,        Decimal.__name__.__len__,   [],           7,   "decimal.Decimal.__name__.__len__() == 7 ('Decimal' has 7 characters; same length as 'Context', the other primary decimal class)"]
    - [ctx_name_eq,         Context.__name__.__eq__,    ["Context"], true, "decimal.Context.__name__ == 'Context' (len=7; the arithmetic context class; Decimal and Context are the two primary classes in decimal, both with 7-character names)"]
    - [ctx_name_len,        Context.__name__.__len__,   [],           7,   "decimal.Context.__name__.__len__() == 7 ('Context' has 7 characters; same as 'Decimal'; both primary decimal classes share this name length)"]

# ---------------------------------------------------------------------------
# decimal module constants and their values
# decimal.MAX_PREC == 999999999999999999 (18 nines)
# decimal.__name__ == 'decimal' (len=7)
# decimal.__doc__.__len__() == 2546
# ---------------------------------------------------------------------------

table decimal_extra147.module_constants_and_identity:
  description: "decimal module identity: __name__=='decimal' (len=7), MAX_PREC==999999999999999999 (18 nines), __doc__.__len__()==2546"
  kind: python_call_eq
  category: identity
  id_prefix: decnames147

  columns: [id, function, args, expected, description]
  rows:
    - [max_prec_val,   MAX_PREC.__eq__,        [999999999999999999], true, "decimal.MAX_PREC == 999999999999999999 (18 nines; the maximum precision supported by the C decimal implementation; this corresponds to 999999999999999999 significant decimal digits — far larger than any practical computation)"]
    - [name_eq,        __name__.__eq__,        ["decimal"],          true, "decimal.__name__ == 'decimal' (len=7; the module name; same length as the class names Decimal and Context; the decimal module provides IEEE 754-2008 decimal floating-point arithmetic)"]
    - [name_len,       __name__.__len__,       [],                    7,   "decimal.__name__.__len__() == 7 ('decimal' has 7 characters; same length as the Decimal and Context class names within the module)"]
    - [doc_len,        __doc__.__len__,        [],                   2546, "decimal.__doc__.__len__() == 2546 (the decimal module docstring is 2546 characters; longer than _decimal.__doc__ which is only 27 characters: 'C decimal arithmetic module')"]
    - [dict_has_MAX_PREC, __dict__.__contains__, ["MAX_PREC"],       true, "decimal.__dict__.__contains__('MAX_PREC') == True (decimal.MAX_PREC is the maximum precision for decimal arithmetic; it equals 999999999999999999 in the C implementation)"]
    - [dict_has_DEFAULT_ctx, __dict__.__contains__, ["DefaultContext"], true, "decimal.__dict__.__contains__('DefaultContext') == True (decimal.DefaultContext is the thread-local context template used to initialize new thread contexts; prec=28, rounding=ROUND_HALF_EVEN by default)"]
    - [dict_has_BASIC_ctx, __dict__.__contains__, ["BasicContext"],  true, "decimal.__dict__.__contains__('BasicContext') == True (decimal.BasicContext is a pre-configured context based on the General Decimal Arithmetic specification; prec=9, traps on all signals)"]

# ---------------------------------------------------------------------------
# decimal.Decimal class dict sizes (for reference / cross-spec context)
# Decimal.__dict__.__len__() == 101; Context.__dict__.__len__() == 85.
# These large sizes reflect the rich arithmetic API.
# ---------------------------------------------------------------------------

table decimal_extra147.Decimal_Context_class_dict_sizes:
  description: "decimal.Decimal.__dict__.__len__()==101; decimal.Context.__dict__.__len__()==85; Decimal is larger by 16 entries (has operator dunders and comparison methods that Context does not)"
  kind: python_call_eq
  category: identity
  id_prefix: decnames147

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_dict_len,  Decimal.__dict__.__len__,  [], 101, "decimal.Decimal.__dict__.__len__() == 101 (Decimal defines 101 entries in its own __dict__; includes arithmetic operators (__add__/__mul__/__sub__/__truediv__/__floordiv__/__mod__/__pow__/__neg__/__pos__/__abs__), comparison (__eq__/__lt__/__le__/__gt__/__ge__), math methods (ln/exp/sqrt/log10/fma/quantize/normalize/compare), signal predicates (is_nan/is_finite/is_zero/is_signed/is_infinite), and many more)"]
    - [context_dict_len,  Context.__dict__.__len__,  [],  85, "decimal.Context.__dict__.__len__() == 85 (Context defines 85 entries; includes all the arithmetic methods (add/subtract/multiply/divide/power/sqrt/ln/exp/log10/fma/quantize/normalize/compare/create_decimal), configuration attributes (prec/rounding/Emax/Emin), signal handling (traps/flags), and utility methods (copy/clear_flags/clear_traps); smaller than Decimal by 16 because Context lacks operator dunders and numeric comparison methods)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra147.decimal_dict_len_49:
  description: "decimal.__dict__.__len__() == 49 — the public decimal module has 49 names; this is only 2 more than _decimal.__dict__.__len__() (47), reflecting that decimal is primarily a thin Python wrapper over the C extension; the 2 extra names (__builtins__ and __cached__) are injected by Python's import machinery for all pure-Python modules but absent from C extensions"
  category: identity
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 49

invariant decimal_extra147.decimal_dict_is_plain_dict:
  description: "decimal.__dict__.__class__.__name__ == 'dict' — both the public decimal module and the private _decimal C extension have plain dict objects as their __dict__; C extension modules use plain dicts for their namespace just like Python modules; only class __dict__ objects are the read-only mappingproxy type"
  category: identity
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant decimal_extra147.Decimal_dict_len_101:
  description: "decimal.Decimal.__dict__.__len__() == 101 — Decimal defines 101 entries in its own __dict__; this is the largest class __dict__ in the decimal module (Context has 85, which is 16 fewer); the 101 entries reflect Decimal's rich API: all arithmetic operators as dunder methods, mathematical functions, signal-testing predicates, conversion methods, and comparison methods"
  category: identity
  kind: python_call_eq
  function: Decimal.__dict__.__len__
  args: []
  expected: 101

invariant decimal_extra147.Context_dict_len_85:
  description: "decimal.Context.__dict__.__len__() == 85 — Context defines 85 entries in its own __dict__; this is 16 fewer than Decimal (101); Context lacks operator dunders (__add__, __mul__, etc.) and numeric comparison methods (__eq__, __lt__, etc.) because Context is a configuration object, not a numeric type; it provides arithmetic methods (add, multiply, divide, sqrt, etc.) as explicit-context versions of Decimal's operations"
  category: identity
  kind: python_call_eq
  function: Context.__dict__.__len__
  args: []
  expected: 85

invariant decimal_extra147.MAX_PREC_is_18_nines:
  description: "decimal.MAX_PREC == 999999999999999999 — the maximum precision for the C decimal implementation is 10^18 - 1 (18 nines); this reflects the use of 64-bit integers internally; the pure Python _pydecimal.py implementation has a lower MAX_PREC; on this Python 3.14.3 installation the C extension is active (confirmed by _decimal.__libmpdec_version__ == '4.0.1')"
  category: identity
  kind: python_call_eq
  function: MAX_PREC.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra147.Decimal_module_is_decimal:
  description: "decimal.Decimal.__module__ == 'decimal' — the Decimal class's __module__ attribute is the public 'decimal' module name, not '_decimal'; the C extension explicitly sets __module__ = 'decimal' on its types so that repr(Decimal('1.5')) shows 'decimal.Decimal' and type annotations work correctly; this is the standard pattern for C extension types that are exposed through a higher-level public module"
  category: identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra147.decimal_name_len_7:
  description: "decimal.__name__.__len__() == 7 ('decimal' has 7 characters; the module name shares its length with the two primary class names Decimal (7) and Context (7) — an unusual coincidence where both the module and its main classes have the same name length; the decimal module implements IEEE 754-2008 decimal floating-point arithmetic to avoid the rounding errors inherent in binary floating-point)"
  category: identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7

