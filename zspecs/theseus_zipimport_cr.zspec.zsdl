spec: theseus_zipimport_cr
version: ">=3.0"
backend: python_cleanroom(theseus_zipimport_cr)
blocks: zipimport

docs: https://docs.python.org/3/library/zipimport.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zipimport.html"
  not_derived_from:
    - "CPython source: Lib/zipimport.py (frozen)"
  notes:
    - "Clean-room zipimport module. Do NOT import zipimport."

error_model: python_exceptions

invariant theseus_zipimport_cr.zipimport2_error:
  description: "ZipImportError exists as ImportError subclass"
  category: behavior
  kind: python_call_eq
  function: zipimport2_error
  args: []
  expected: true

invariant theseus_zipimport_cr.zipimport2_importer:
  description: "zipimporter class exists"
  category: behavior
  kind: python_call_eq
  function: zipimport2_importer
  args: []
  expected: true

invariant theseus_zipimport_cr.zipimport2_find:
  description: "zipimporter.find_spec() returns None for non-existent archive"
  category: behavior
  kind: python_call_eq
  function: zipimport2_find
  args: []
  expected: true
