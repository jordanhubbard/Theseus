  columns: [id, function, args, expected, description]
  rows:
    - [round_ceiling_class,    decimal.ROUND_CEILING.__class__.__name__,    [],  "str",  "decimal.ROUND_CEILING.__class__.__name__ == 'str'; ROUND_CEILING is a plain Python str constant; confirmed Python 3.14.3 macOS"]
    - [round_floor_class,      decimal.ROUND_FLOOR.__class__.__name__,      [],  "str",  "decimal.ROUND_FLOOR.__class__.__name__ == 'str'; ROUND_FLOOR is a plain Python str constant; confirmed Python 3.14.3 macOS"]
