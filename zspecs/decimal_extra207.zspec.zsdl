spec: decimal_extra207
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers decimal module constants, context, and Decimal class metadata"
    - "decimal_extra206.zspec.zsdl — covers decimal.Decimal.__dict__ comparison/conversion methods"
  notes:
    - "decimal rounding constants are plain Python str values, not enum members."
    - "decimal.ROUND_HALF_UP.__class__.__name__ == 'str'; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_DOWN.__class__.__name__ == 'str'; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_UP.__class__.__name__ == 'str'; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str'; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_CEILING.__class__.__name__ == 'str'; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_FLOOR.__class__.__name__ == 'str'; confirmed Python 3.14.3 macOS."
    - "Each rounding constant has the same string value as its name: ROUND_HALF_UP == 'ROUND_HALF_UP'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal rounding constants class name — ROUND_HALF_UP, ROUND_DOWN, ROUND_UP
# All rounding constants are plain str values; type(decimal.ROUND_HALF_UP).__name__ == 'str'
# ---------------------------------------------------------------------------

table decimal_extra207.rounding_constants_class_name_group1:
  description: "decimal rounding constants ROUND_HALF_UP, ROUND_DOWN, ROUND_UP are plain str values"
  kind: python_call_eq
  category: constant_metadata
  id_prefix: decimalrounding207

  columns: [id, function, args, expected, description]
  rows:
    - [round_half_up_class,  decimal.ROUND_HALF_UP.__class__.__name__,   [],  "str",  "decimal.ROUND_HALF_UP.__class__.__name__ == 'str'; ROUND_HALF_UP is a plain Python str constant; confirmed Python 3.14.3 macOS"]
    - [round_down_class,     decimal.ROUND_DOWN.__class__.__name__,      [],  "str",  "decimal.ROUND_DOWN.__class__.__name__ == 'str'; ROUND_DOWN is a plain Python str constant; confirmed Python 3.14.3 macOS"]
    - [round_up_class,       decimal.ROUND_UP.__class__.__name__,        [],  "str",  "decimal.ROUND_UP.__class__.__name__ == 'str'; ROUND_UP is a plain Python str constant; confirmed Python 3.14.3 macOS"]
    - [round_half_even_class, decimal.ROUND_HALF_EVEN.__class__.__name__, [], "str",  "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str'; ROUND_HALF_EVEN is a plain Python str constant; confirmed Python 3.14.3 macOS"]

