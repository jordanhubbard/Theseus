spec: inspect_extra1861
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra.zspec.zsdl — covers module checks and core inspect type dunders"
    - "inspect_extra10.zspec.zsdl — covers Parameter/Signature/BoundArguments attribute membership"
  notes:
    - "Wave 571 theme: bitwise operators (__or__/__and__/__xor__) and in-place operators (__iadd__/__imul__/__ior__/__iand__) for inspect types."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments are pure Python classes defined in inspect.py."
    - "None of these classes define bitwise or in-place operator dunder methods in their own __dict__."
    - "inspect.__dict__ contains all the is* predicate functions (ismodule, isclass, ismethod, etc.)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: bitwise operators for inspect types
#
# inspect.Parameter, inspect.Signature, and inspect.BoundArguments are pure
# Python classes. None define bitwise dunder methods in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra1861.bitwise_operators:
  description: "Bitwise operator dunder methods absent from inspect type own __dict__"
  kind: python_call_eq
  category: bitwise_operators
  id_prefix: in1861

  columns: [id, function, args, expected]
  rows:
    - ["in1861001", inspect.Parameter.__dict__.__contains__,      ["__or__"],  false]
    - ["in1861002", inspect.Parameter.__dict__.__contains__,      ["__and__"], false]
    - ["in1861003", inspect.Parameter.__dict__.__contains__,      ["__xor__"], false]
    - ["in1861004", inspect.Signature.__dict__.__contains__,      ["__or__"],  false]
    - ["in1861005", inspect.Signature.__dict__.__contains__,      ["__and__"], false]
    - ["in1861006", inspect.BoundArguments.__dict__.__contains__,  ["__or__"],  false]
    - ["in1861007", inspect.BoundArguments.__dict__.__contains__,  ["__and__"], false]
    - ["in1861008", inspect.BoundArguments.__dict__.__contains__,  ["__xor__"], false]

# ---------------------------------------------------------------------------
# Table 2: in-place operators for inspect types
#
# None of the inspect types define in-place operator dunder methods in
# their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra1861.inplace_operators:
  description: "In-place operator dunder methods absent from inspect type own __dict__"
  kind: python_call_eq
  category: inplace_operators
  id_prefix: in1861

  columns: [id, function, args, expected]
  rows:
    - ["in1861009", inspect.Parameter.__dict__.__contains__,      ["__iadd__"], false]
    - ["in1861010", inspect.Parameter.__dict__.__contains__,      ["__ior__"],  false]
    - ["in1861011", inspect.Signature.__dict__.__contains__,      ["__iadd__"], false]
    - ["in1861012", inspect.Signature.__dict__.__contains__,      ["__ior__"],  false]
    - ["in1861013", inspect.BoundArguments.__dict__.__contains__,  ["__iadd__"], false]
    - ["in1861014", inspect.BoundArguments.__dict__.__contains__,  ["__ior__"],  false]
    - ["in1861015", inspect.Parameter.__dict__.__contains__,      ["__imul__"], false]
    - ["in1861016", inspect.Signature.__dict__.__contains__,      ["__imul__"], false]

# ---------------------------------------------------------------------------
# Table 3: inspect.is* predicate functions in inspect.__dict__
#
# The inspect module exposes a rich set of is* predicate functions for
# classifying Python objects. All are present in inspect.__dict__.
# ---------------------------------------------------------------------------

table inspect_extra1861.inspect_isX_functions:
  description: "inspect.is* predicate functions present in inspect.__dict__"
  kind: python_call_eq
  category: inspect_isX_functions
  id_prefix: in1861

  columns: [id, function, args, expected]
  rows:
    - ["in1861017", inspect.__dict__.__contains__,  ["ismodule"],             true]
    - ["in1861018", inspect.__dict__.__contains__,  ["isclass"],              true]
    - ["in1861019", inspect.__dict__.__contains__,  ["ismethod"],             true]
    - ["in1861020", inspect.__dict__.__contains__,  ["isfunction"],           true]
    - ["in1861021", inspect.__dict__.__contains__,  ["isgeneratorfunction"],  true]
    - ["in1861022", inspect.__dict__.__contains__,  ["isgenerator"],          true]
    - ["in1861023", inspect.__dict__.__contains__,  ["iscoroutinefunction"],  true]
    - ["in1861024", inspect.__dict__.__contains__,  ["iscoroutine"],          true]
    - ["in1861025", inspect.__dict__.__contains__,  ["isasyncgenfunction"],   true]
    - ["in1861026", inspect.__dict__.__contains__,  ["isasyncgen"],           true]
