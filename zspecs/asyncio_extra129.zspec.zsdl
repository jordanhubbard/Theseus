spec: asyncio_extra129
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/taskgroups.py"
  notes:
    - "This spec covers: wave 255 theme — asyncio.BoundedSemaphore and asyncio.TaskGroup class identity. NEW in extra129: asyncio.BoundedSemaphore.__name__=='BoundedSemaphore' (len=16); asyncio.BoundedSemaphore.__module__=='asyncio.locks'; asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore'; asyncio.BoundedSemaphore.__mro__.__len__()==5 (MRO=[BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]); asyncio.TaskGroup.__name__=='TaskGroup' (len=9); asyncio.TaskGroup.__module__=='asyncio.taskgroups'; asyncio.TaskGroup.__bases__[0].__name__=='object'; asyncio.TaskGroup.__mro__.__len__()==2 (MRO=[TaskGroup, object]); asyncio.BoundedSemaphore.__class__.__name__=='type'; asyncio.TaskGroup.__class__.__name__=='type'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BoundedSemaphore.__mro__.__len__() == 5. MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] — BoundedSemaphore inherits from Semaphore which extends the lock mixin chain; depth-5 is the deepest MRO in the asyncio.locks hierarchy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups'. TaskGroup is defined in Lib/asyncio/taskgroups.py (added in Python 3.11) and re-exported through the asyncio public namespace. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.TaskGroup.__mro__.__len__() == 2. TaskGroup inherits directly from object (MRO=[TaskGroup, object]), the minimal depth-2 chain; unlike Semaphore/Lock/BoundedSemaphore which use mixin inheritance, TaskGroup has no base classes other than object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'. BoundedSemaphore directly extends Semaphore, adding an upper bound on the semaphore count; this single-base inheritance results in the 5-element MRO chain. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.BoundedSemaphore class identity — extra129
#
# Wave 255 theme: asyncio.BoundedSemaphore class identity.
#
# asyncio.BoundedSemaphore.__name__           == 'BoundedSemaphore'  (len=16)
# asyncio.BoundedSemaphore.__module__         == 'asyncio.locks'
# asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# asyncio.BoundedSemaphore.__mro__.__len__()  == 5
# asyncio.BoundedSemaphore.__class__.__name__ == 'type'
# asyncio.BoundedSemaphore.__qualname__       == 'BoundedSemaphore'  (len=16)
# ---------------------------------------------------------------------------

table asyncio_extra129.asyncio_boundedsemaphore_identity:
  description: "asyncio.BoundedSemaphore class identity checks in asynciobsemident129 namespace — wave 255 theme: asyncio.BoundedSemaphore is a pure-Python class defined in Lib/asyncio/locks.py; it inherits from asyncio.Semaphore (which itself inherits from _ContextManagerMixin -> _LoopBoundMixin -> object) producing a depth-5 MRO chain — the deepest in the asyncio locks hierarchy; BoundedSemaphore.__name__.__eq__('BoundedSemaphore')==True (len=16: 'Bounded'=7 + 'Semaphore'=9); BoundedSemaphore.__module__.__eq__('asyncio.locks')==True (defined in Lib/asyncio/locks.py, submodule 'asyncio.locks'); BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore')==True (single base class Semaphore); BoundedSemaphore.__mro__.__len__()==5 (MRO=[BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]); BoundedSemaphore.__class__.__name__.__eq__('type')==True (it is a class, metaclass is type); BoundedSemaphore.__qualname__.__eq__('BoundedSemaphore')==True (module-level class, qualname equals name, len=16); BoundedSemaphore adds a bound check on top of Semaphore preventing release() from raising the count beyond the initial value; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciobsemident129

  columns: [id, function, args, expected, description]
  rows:
    - [bsem_name,      asyncio.BoundedSemaphore.__name__.__eq__,                      ["BoundedSemaphore"], true, "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16); verified with Python 3.14.3"]
    - [bsem_namelen,   asyncio.BoundedSemaphore.__name__.__len__,                     [],                  16,   "asyncio.BoundedSemaphore.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [bsem_module,    asyncio.BoundedSemaphore.__module__.__eq__,                    ["asyncio.locks"],   true, "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [bsem_base0,     "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__",       ["Semaphore"],       true, "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [bsem_mro_len,   asyncio.BoundedSemaphore.__mro__.__len__,                      [],                  5,    "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [bsem_class_nm,  asyncio.BoundedSemaphore.__class__.__name__.__eq__,            ["type"],            true, "asyncio.BoundedSemaphore.__class__.__name__ == 'type' — genuine Python class; verified with Python 3.14.3"]
    - [bsem_qn_eq,     asyncio.BoundedSemaphore.__qualname__.__eq__,                  ["BoundedSemaphore"], true, "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' (len=16, module-level so qualname equals name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.TaskGroup class identity — extra129
#
# Wave 255 theme: asyncio.TaskGroup class identity.
#
# asyncio.TaskGroup.__name__           == 'TaskGroup'          (len=9)
# asyncio.TaskGroup.__module__         == 'asyncio.taskgroups'
# asyncio.TaskGroup.__bases__[0].__name__ == 'object'
# asyncio.TaskGroup.__mro__.__len__()  == 2
# asyncio.TaskGroup.__class__.__name__ == 'type'
# asyncio.TaskGroup.__qualname__       == 'TaskGroup'          (len=9)
# ---------------------------------------------------------------------------

table asyncio_extra129.asyncio_taskgroup_identity:
  description: "asyncio.TaskGroup class identity checks in asynciobsemident129 namespace — wave 255 theme: asyncio.TaskGroup is a pure-Python class defined in Lib/asyncio/taskgroups.py (added in Python 3.11 as part of structured concurrency support); TaskGroup.__name__.__eq__('TaskGroup')==True (len=9: 'Task'=4 + 'Group'=5); TaskGroup.__module__.__eq__('asyncio.taskgroups')==True (defined in the taskgroups submodule, re-exported via asyncio/__init__.py); TaskGroup.__bases__[0].__name__.__eq__('object')==True (TaskGroup inherits directly from object — unlike the lock classes which use mixin chains, TaskGroup has no intermediate base classes); TaskGroup.__mro__.__len__()==2 (MRO=[TaskGroup, object], the minimal depth-2 chain — same depth as asyncio.Future and concurrent.futures.Future); TaskGroup.__class__.__name__.__eq__('type')==True; TaskGroup.__qualname__.__eq__('TaskGroup')==True (len=9, module-level class so qualname equals name); TaskGroup is used as an async context manager to concurrently run multiple tasks and wait for them all; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciobsemident129a

  columns: [id, function, args, expected, description]
  rows:
    - [tg_name,      asyncio.TaskGroup.__name__.__eq__,                   ["TaskGroup"],         true, "asyncio.TaskGroup.__name__ == 'TaskGroup' (len=9); verified with Python 3.14.3"]
    - [tg_namelen,   asyncio.TaskGroup.__name__.__len__,                  [],                    9,    "asyncio.TaskGroup.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [tg_module,    asyncio.TaskGroup.__module__.__eq__,                 ["asyncio.taskgroups"], true, "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups'; verified with Python 3.14.3"]
    - [tg_base0,     "asyncio.TaskGroup.__bases__[0].__name__.__eq__",    ["object"],            true, "asyncio.TaskGroup.__bases__[0].__name__ == 'object' — inherits directly from object; verified with Python 3.14.3"]
    - [tg_mro_len,   asyncio.TaskGroup.__mro__.__len__,                   [],                    2,    "asyncio.TaskGroup.__mro__.__len__() == 2 — MRO=[TaskGroup, object], minimal depth-2 chain; verified with Python 3.14.3"]
    - [tg_class_nm,  asyncio.TaskGroup.__class__.__name__.__eq__,         ["type"],              true, "asyncio.TaskGroup.__class__.__name__ == 'type' — genuine Python class; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BoundedSemaphore vs TaskGroup MRO comparison — extra129
#
# Wave 255 theme: contrasting the two classes by MRO depth.
#
# BoundedSemaphore.__mro__.__len__() == 5  (deepest in asyncio locks)
# TaskGroup.__mro__.__len__() == 2         (minimal, no mixin chain)
# ---------------------------------------------------------------------------

table asyncio_extra129.asyncio_mro_comparison:
  description: "asyncio.BoundedSemaphore vs asyncio.TaskGroup MRO depth comparison in asynciobsemident129 namespace — wave 255 theme: the two classes represent opposite extremes in asyncio MRO depth; BoundedSemaphore.__mro__.__len__()==5 (the deepest in asyncio.locks: BoundedSemaphore->Semaphore->_ContextManagerMixin->_LoopBoundMixin->object) while TaskGroup.__mro__.__len__()==2 (the minimal possible depth: TaskGroup->object); the difference in MRO depth reflects their design: lock classes share mixin code for context-manager support and event-loop binding via the 4-level mixin chain, while TaskGroup manages its own lifecycle without shared mixins; BoundedSemaphore.__name__.__len__()==16 is the longest asyncio lock class name; TaskGroup.__name__.__len__()==9 reflects the compound 'Task+Group' name; both classes have __class__.__name__=='type'; BoundedSemaphore.__module__=='asyncio.locks'; TaskGroup.__module__=='asyncio.taskgroups'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciobsemident129b

  columns: [id, function, args, expected, description]
  rows:
    - [bsem_mro5,  asyncio.BoundedSemaphore.__mro__.__len__,  [], 5, "asyncio.BoundedSemaphore.__mro__.__len__() == 5, deepest in asyncio locks; verified with Python 3.14.3"]
    - [tg_mro2,    asyncio.TaskGroup.__mro__.__len__,          [], 2, "asyncio.TaskGroup.__mro__.__len__() == 2, minimal depth (TaskGroup->object); verified with Python 3.14.3"]
    - [bsem_nm16,  asyncio.BoundedSemaphore.__name__.__len__,  [], 16, "asyncio.BoundedSemaphore.__name__.__len__() == 16, longest asyncio lock class name; verified with Python 3.14.3"]
    - [tg_nm9,     asyncio.TaskGroup.__name__.__len__,          [], 9,  "asyncio.TaskGroup.__name__.__len__() == 9 ('Task'=4+'Group'=5); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra129
# ---------------------------------------------------------------------------

invariant asyncio_extra129.BoundedSemaphore_name_eq:
  description: "asyncio.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') returns True — BoundedSemaphore.__name__ is 'BoundedSemaphore' (len=16: 'Bounded'=7 + 'Semaphore'=9); BoundedSemaphore is a subclass of asyncio.Semaphore that adds an upper bound check — calling release() when the count would exceed the initial value raises a ValueError; BoundedSemaphore.__module__ is 'asyncio.locks'; BoundedSemaphore.__bases__[0].__name__ is 'Semaphore' (its direct parent); BoundedSemaphore.__mro__.__len__() is 5 (the deepest MRO in asyncio locks); BoundedSemaphore.__class__.__name__ is 'type'; NEW in extra129: first standalone BoundedSemaphore name invariant in asynciobsemident129 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant asyncio_extra129.BoundedSemaphore_mro_len_is_5:
  description: "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — BoundedSemaphore's MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=5); this is the deepest MRO among the asyncio lock classes: Event has depth 3 (via _LoopBoundMixin only), Semaphore and Lock each have depth 4 (via _ContextManagerMixin -> _LoopBoundMixin), and BoundedSemaphore adds one more level (depth 5) because it inherits from Semaphore; BoundedSemaphore.__bases__[0].__name__ is 'Semaphore'; BoundedSemaphore.__module__ is 'asyncio.locks'; the 5-element chain reflects BoundedSemaphore's position as the most derived class in the asyncio locks hierarchy; NEW in extra129: first standalone BoundedSemaphore MRO length invariant in asynciobsemident129 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__mro__.__len__
  args: []
  expected: 5

invariant asyncio_extra129.TaskGroup_module_eq:
  description: "asyncio.TaskGroup.__module__.__eq__('asyncio.taskgroups') returns True — TaskGroup.__module__ is 'asyncio.taskgroups' (len=19: 'asyncio.taskgroups' has 18 chars); TaskGroup is defined in Lib/asyncio/taskgroups.py which was added in Python 3.11 to support structured concurrency (PEP 654); the module name 'asyncio.taskgroups' reflects the taskgroups.py submodule; unlike the coroutine functions (sleep, gather, wait) which are all in 'asyncio.tasks', TaskGroup has its own dedicated submodule; TaskGroup.__bases__[0].__name__ is 'object'; TaskGroup.__mro__.__len__() is 2; TaskGroup is used as 'async with asyncio.TaskGroup() as tg:' to spawn and await multiple tasks in a structured scope; NEW in extra129: first standalone TaskGroup module invariant in asynciobsemident129 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.TaskGroup.__module__.__eq__
  args: ["asyncio.taskgroups"]
  expected: true

invariant asyncio_extra129.TaskGroup_mro_len_is_2:
  description: "asyncio.TaskGroup.__mro__.__len__() == 2 — TaskGroup's MRO is [TaskGroup, object] (length=2); this minimal depth-2 chain contrasts sharply with BoundedSemaphore's depth-5 MRO; TaskGroup inherits directly from object with no mixin classes for event-loop binding or context-manager support — it implements its async context manager protocol (__aenter__, __aexit__) directly in its own class body; this is the same minimal MRO depth as asyncio.Future, concurrent.futures.Future, and multiprocessing.pool.Pool (all depth=2, direct object subclasses); TaskGroup.__module__ is 'asyncio.taskgroups'; TaskGroup.__name__ is 'TaskGroup'; NEW in extra129: first standalone TaskGroup MRO length invariant in asynciobsemident129 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.TaskGroup.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra129.BoundedSemaphore_base_is_Semaphore:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') returns True — BoundedSemaphore inherits from Semaphore as its single direct base class; this single-base inheritance means BoundedSemaphore picks up Semaphore's full MRO chain ([Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]) and adds itself at the front to produce the 5-element MRO; BoundedSemaphore modifies Semaphore by overriding release() to raise ValueError if the internal counter would exceed the initial bound; BoundedSemaphore.__bases__[0].__name__.__len__() is 9 (same as asyncio.TaskGroup.__name__.__len__()==9); BoundedSemaphore.__module__ is 'asyncio.locks'; NEW in extra129: first standalone BoundedSemaphore base class invariant in asynciobsemident129 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

