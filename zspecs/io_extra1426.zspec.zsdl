spec: io_extra1426
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers __format__ and __dir__ method type/presence for io module classes. All io classes in this batch (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, UnsupportedOperation) have __format__.__class__.__name__=='method_descriptor' (inherited from object via the C-level _IOBase or BaseException chain). None of the io classes in this batch define '__format__' in their own __dict__. Similarly, all classes have __dir__.__class__.__name__=='method_descriptor' and none define '__dir__' in their own __dict__. All verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.IOBase.__format__.__class__.__name__=='method_descriptor' and '__format__' not in io.IOBase.__dict__ — IOBase inherits __format__ from object (via _IOBase C type). io.UnsupportedOperation.__format__.__class__.__name__=='method_descriptor' — UnsupportedOperation inherits from OSError->ValueError->Exception->BaseException->object chain. io.BytesIO.__dict__.__contains__('__format__')==False — BytesIO does not define __format__ in its own dict even though it defines __sizeof__. All verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __format__ type and dict presence checks — extra1426
#
# io.IOBase.__format__.__class__.__name__                   == 'method_descriptor'
# io.IOBase.__dict__.__contains__('__format__')            == False
# io.BytesIO.__format__.__class__.__name__                  == 'method_descriptor'
# io.BytesIO.__dict__.__contains__('__format__')           == False
# io.UnsupportedOperation.__format__.__class__.__name__     == 'method_descriptor'
# io.UnsupportedOperation.__dict__.__contains__('__format__') == False
# ---------------------------------------------------------------------------

table io_extra1426.io_format_type:
  description: "io class __format__ method type and __dict__ presence checks — wave 542 extra1426 theme. io.IOBase.__format__.__class__.__name__=='method_descriptor' (IOBase inherits __format__ from object via the C-level _IOBase type; the method_descriptor type is the descriptor object for C-implemented instance methods). None of the io classes in this batch (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, UnsupportedOperation) define '__format__' in their own __dict__ — all inherit it. io.UnsupportedOperation.__format__.__class__.__name__=='method_descriptor' (inherits from OSError->ValueError->Exception->BaseException->object chain; MRO len=6). io.BytesIO.__dict__.__contains__('__format__')==False (BytesIO defines __sizeof__ in its own dict but not __format__). All verified with Python 3.14.4."
  kind: python_call_eq
  category: format_introspection
  id_prefix: io1426fm

  columns: [id, function, args, expected, description]
  rows:
    - [io1426fm001, io.IOBase.__format__.__class__.__name__.__eq__,              ["method_descriptor"], true,  "io.IOBase.__format__.__class__.__name__ == 'method_descriptor' (inherited from object via _IOBase C type); verified with Python 3.14.4"]
    - [io1426fm002, io.IOBase.__dict__.__contains__,                             ["__format__"],         false, "io.IOBase.__dict__.__contains__('__format__') == False (IOBase does not define __format__ in its own dict); verified with Python 3.14.4"]
    - [io1426fm003, io.RawIOBase.__format__.__class__.__name__.__eq__,           ["method_descriptor"], true,  "io.RawIOBase.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426fm004, io.RawIOBase.__dict__.__contains__,                          ["__format__"],         false, "io.RawIOBase.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [io1426fm005, io.BufferedIOBase.__format__.__class__.__name__.__eq__,      ["method_descriptor"], true,  "io.BufferedIOBase.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426fm006, io.BufferedIOBase.__dict__.__contains__,                     ["__format__"],         false, "io.BufferedIOBase.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [io1426fm007, io.TextIOBase.__format__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "io.TextIOBase.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426fm008, io.TextIOBase.__dict__.__contains__,                         ["__format__"],         false, "io.TextIOBase.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [io1426fm009, io.BytesIO.__format__.__class__.__name__.__eq__,             ["method_descriptor"], true,  "io.BytesIO.__format__.__class__.__name__ == 'method_descriptor' (BytesIO defines __sizeof__ in own dict but not __format__); verified with Python 3.14.4"]
    - [io1426fm010, io.BytesIO.__dict__.__contains__,                            ["__format__"],         false, "io.BytesIO.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [io1426fm011, io.StringIO.__format__.__class__.__name__.__eq__,            ["method_descriptor"], true,  "io.StringIO.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426fm012, io.StringIO.__dict__.__contains__,                           ["__format__"],         false, "io.StringIO.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [io1426fm013, io.UnsupportedOperation.__format__.__class__.__name__.__eq__, ["method_descriptor"], true, "io.UnsupportedOperation.__format__.__class__.__name__ == 'method_descriptor' (inherits from BaseException chain; MRO len=6); verified with Python 3.14.4"]
    - [io1426fm014, io.UnsupportedOperation.__dict__.__contains__,               ["__format__"],         false, "io.UnsupportedOperation.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# io class __dir__ type and dict presence checks — extra1426
#
# io.IOBase.__dir__.__class__.__name__                   == 'method_descriptor'
# io.IOBase.__dict__.__contains__('__dir__')            == False
# io.BytesIO.__dir__.__class__.__name__                  == 'method_descriptor'
# io.BytesIO.__dict__.__contains__('__dir__')           == False
# io.UnsupportedOperation.__dir__.__class__.__name__     == 'method_descriptor'
# io.StringIO.__dict__.__contains__('__dir__')          == False
# ---------------------------------------------------------------------------

table io_extra1426.io_dir_type:
  description: "io class __dir__ method type and __dict__ presence checks — wave 542 extra1426 theme. io.IOBase.__dir__.__class__.__name__=='method_descriptor' (IOBase inherits __dir__ from object via _IOBase C type; none of the io classes define '__dir__' in their own __dict__). io.UnsupportedOperation.__dir__.__class__.__name__=='method_descriptor' (inherits from BaseException chain). io.BytesIO.__dict__.__contains__('__dir__')==False (BytesIO, despite defining __sizeof__ in own dict, does not define __dir__). io.StringIO.__dict__.__contains__('__dir__')==False. All verified with Python 3.14.4."
  kind: python_call_eq
  category: dir_introspection
  id_prefix: io1426dr

  columns: [id, function, args, expected, description]
  rows:
    - [io1426dr001, io.IOBase.__dir__.__class__.__name__.__eq__,              ["method_descriptor"], true,  "io.IOBase.__dir__.__class__.__name__ == 'method_descriptor' (inherited from object via _IOBase C type); verified with Python 3.14.4"]
    - [io1426dr002, io.IOBase.__dict__.__contains__,                          ["__dir__"],            false, "io.IOBase.__dict__.__contains__('__dir__') == False (not defined in own dict); verified with Python 3.14.4"]
    - [io1426dr003, io.RawIOBase.__dir__.__class__.__name__.__eq__,           ["method_descriptor"], true,  "io.RawIOBase.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426dr004, io.RawIOBase.__dict__.__contains__,                       ["__dir__"],            false, "io.RawIOBase.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [io1426dr005, io.BufferedIOBase.__dir__.__class__.__name__.__eq__,      ["method_descriptor"], true,  "io.BufferedIOBase.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426dr006, io.BufferedIOBase.__dict__.__contains__,                  ["__dir__"],            false, "io.BufferedIOBase.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [io1426dr007, io.TextIOBase.__dir__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "io.TextIOBase.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426dr008, io.TextIOBase.__dict__.__contains__,                      ["__dir__"],            false, "io.TextIOBase.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [io1426dr009, io.BytesIO.__dir__.__class__.__name__.__eq__,             ["method_descriptor"], true,  "io.BytesIO.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426dr010, io.BytesIO.__dict__.__contains__,                         ["__dir__"],            false, "io.BytesIO.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [io1426dr011, io.StringIO.__dir__.__class__.__name__.__eq__,            ["method_descriptor"], true,  "io.StringIO.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426dr012, io.StringIO.__dict__.__contains__,                        ["__dir__"],            false, "io.StringIO.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [io1426dr013, io.UnsupportedOperation.__dir__.__class__.__name__.__eq__, ["method_descriptor"], true, "io.UnsupportedOperation.__dir__.__class__.__name__ == 'method_descriptor' (inherits from BaseException chain; MRO len=6); verified with Python 3.14.4"]
    - [io1426dr014, io.UnsupportedOperation.__dict__.__contains__,            ["__dir__"],            false, "io.UnsupportedOperation.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# io class __format__ and __dir__ cross-checks — extra1426
#
# Confirms both __format__ and __dir__ behave identically across all io classes:
# neither is ever found in a class's own __dict__; both are always method_descriptor.
# ---------------------------------------------------------------------------

table io_extra1426.io_format_dir_cross:
  description: "io class __format__ and __dir__ cross-checks — wave 542 extra1426. Confirms that across all seven io classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, UnsupportedOperation), both __format__ and __dir__ are always 'method_descriptor' and are never present in the class's own __dict__. This uniform pattern holds for both the ABC-style io wrappers (IOBase and subclasses) and the concrete implementations (BytesIO, StringIO) as well as the exception class (UnsupportedOperation). Verified with Python 3.14.4."
  kind: python_call_eq
  category: format_dir_cross
  id_prefix: io1426cx

  columns: [id, function, args, expected, description]
  rows:
    - [io1426cx001, io.IOBase.__format__.__class__.__name__.__eq__,            ["method_descriptor"], true,  "io.IOBase both __format__ and __dir__ are method_descriptor and absent from own __dict__; __format__ check; verified with Python 3.14.4"]
    - [io1426cx002, io.IOBase.__dir__.__class__.__name__.__eq__,               ["method_descriptor"], true,  "io.IOBase.__dir__ is also method_descriptor; verified with Python 3.14.4"]
    - [io1426cx003, io.BytesIO.__format__.__class__.__name__.__eq__,           ["method_descriptor"], true,  "io.BytesIO.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx004, io.BytesIO.__dir__.__class__.__name__.__eq__,              ["method_descriptor"], true,  "io.BytesIO.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx005, io.StringIO.__format__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "io.StringIO.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx006, io.StringIO.__dir__.__class__.__name__.__eq__,             ["method_descriptor"], true,  "io.StringIO.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx007, io.UnsupportedOperation.__format__.__class__.__name__.__eq__, ["method_descriptor"], true, "io.UnsupportedOperation.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx008, io.UnsupportedOperation.__dir__.__class__.__name__.__eq__, ["method_descriptor"], true,  "io.UnsupportedOperation.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx009, io.RawIOBase.__format__.__class__.__name__.__eq__,         ["method_descriptor"], true,  "io.RawIOBase.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx010, io.RawIOBase.__dir__.__class__.__name__.__eq__,            ["method_descriptor"], true,  "io.RawIOBase.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx011, io.BufferedIOBase.__format__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "io.BufferedIOBase.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx012, io.BufferedIOBase.__dir__.__class__.__name__.__eq__,       ["method_descriptor"], true,  "io.BufferedIOBase.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx013, io.TextIOBase.__format__.__class__.__name__.__eq__,        ["method_descriptor"], true,  "io.TextIOBase.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [io1426cx014, io.TextIOBase.__dir__.__class__.__name__.__eq__,           ["method_descriptor"], true,  "io.TextIOBase.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
