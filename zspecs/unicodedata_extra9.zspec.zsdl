spec: unicodedata_extra9
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl through unicodedata_extra8.zspec.zsdl."
    - "unicodedata_extra (base extra) covers: __name__ value for all major functions (lookup/name/decimal/digit/numeric/category/bidirectional/combining/east_asian_width/mirrored/decomposition/normalize/is_normalized); unidata_version.__class__.__name__; name('A'); category('A')."
    - "unicodedata_extra2 covers: __module__ for normalize/decomposition/bidirectional/east_asian_width/combining/category/lookup/name; is_normalized __name__/__module__; unidata_version len>=3 and contains '.'."
    - "unicodedata_extra3 covers: __module__ for decimal/numeric/digit/mirrored; ucd_3_2_0.__class__.__name__=='UCD'."
    - "unicodedata_extra4 covers: __name__ table for lookup/category/bidirectional/combining/east_asian_width/mirrored/decomposition/normalize/is_normalized; unidata_version type; category A/a/0; bidirectional A; combining A; east_asian_width A; mirrored '('."
    - "unicodedata_extra5 to extra8 cover: lookup/name/category/bidirectional/east_asian_width/mirrored/decimal/digit/numeric/decomposition vectors; is_normalized; ucd_3_2_0 behavioral; function __module__ table."
    - "Focus: new axes — the TYPE of lookup/__name__/name/__name__/category/__name__ (str); unidata_version length >= 5 (tighter bound); new category vectors for '{' and '@'; digit('A') raises ValueError; name for U+00E9; combining(' ') == 0."
    - "unicodedata.lookup.__name__.__class__.__name__ == 'str' — the __name__ attribute of a built-in function is always a str. This is a type-of-attribute check, distinct from the value check in prior specs."
    - "unicodedata.name.__name__.__class__.__name__ == 'str' — same rationale."
    - "unicodedata.category.__name__.__class__.__name__ == 'str' — same rationale."
    - "unicodedata.unidata_version.__len__() >= 5 — unicodedata_extra2 asserts >= 3; actual versions like '15.0.0' (6 chars) justify >= 5 as a tighter, still-portable lower bound."
    - "unicodedata.category('{') == 'Ps' — left curly bracket is open punctuation. Not covered in any prior spec."
    - "unicodedata.category('@') == 'Po' — commercial at is other punctuation. Base spec covers '!' -> 'Po' but not '@'. New character vector."
    - "unicodedata.digit('A') raises ValueError — digit() raises for non-digit characters. Prior specs cover decimal('A') raises but not digit('A') raises."
    - "unicodedata.name('\\u00e9') == 'LATIN SMALL LETTER E WITH ACUTE' — prior specs cover name for 'A', 'a', '0', '€', 'Z', '9', '!', ' '. This accented character is new."
    - "unicodedata.combining(' ') == 0 — space has combining class 0 (non-combining). Prior specs cover combining('A') and combining('0') but not space."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attribute TYPE checks for lookup, name, and category
#
# unicodedata_extra and unicodedata_extra4 confirm the VALUE of __name__
# (e.g., lookup.__name__ == 'lookup'). No prior spec checks the TYPE of the
# __name__ attribute itself. For built-in C-extension functions, __name__
# is always a str.
# ---------------------------------------------------------------------------

table unicodedata_extra9.function_name_types:
  kind: python_call_eq
  category: function_identity
  id_prefix: nametype

  columns: [id, function, args, expected]
  rows:
    - [lookup,   lookup.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [name,     name.__name__.__class__.__name__.__eq__,     ["str"], true]
    - [category, category.__name__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# unidata_version — tighter length lower bound
#
# unicodedata_extra2 asserts unidata_version.__len__() >= 3 (minimum 'X.Y').
# Actual Unicode data version strings have the form 'X.Y.Z' (e.g. '15.0.0'),
# which is at least 5 characters ('5.0.0'). A >= 5 lower bound is tighter
# and still portable across all CPython 3.9+ deployments.
# Not covered in any prior spec (extra2 only asserts >= 3).
# ---------------------------------------------------------------------------

invariant unicodedata_extra9.unidata_version.len_ge_5:
  description: "unicodedata.unidata_version.__len__() >= 5 — version 'X.Y.Z' is at least 5 chars"
  category: module_constants
  kind: python_call_eq
  function: unidata_version.__len__
  args: []
  method: __ge__
  method_args: [5]
  expected: true

# ---------------------------------------------------------------------------
# category() — new character vectors
#
# Base spec covers: 'A'->Lu, 'a'->Ll, '0'->Nd, '!'->Po, ' '->Zs.
# extra4/5/6/7 add: 'a'->Ll, '0'->Nd, '\t'->Cc, '+'->Sm, '€'->Sc, '\n'->Cc, 'Z'->Lu, 'z'->Ll.
# '{' -> 'Ps' (punctuation, open) and '@' -> 'Po' are not covered anywhere.
# ---------------------------------------------------------------------------

invariant unicodedata_extra9.category.open_curly:
  description: "unicodedata.category('{') == 'Ps' — left curly bracket is open punctuation"
  category: category
  kind: python_call_eq
  function: category
  args: ["{"]
  expected: "Ps"

invariant unicodedata_extra9.category.commercial_at:
  description: "unicodedata.category('@') == 'Po' — commercial at is other punctuation"
  category: category
  kind: python_call_eq
  function: category
  args: ["@"]
  expected: "Po"

# ---------------------------------------------------------------------------
# digit() — raises ValueError for non-digit characters
#
# unicodedata.zspec.zsdl covers decimal('A') raises ValueError.
# unicodedata_extra5 covers digit() value vectors (0/7/9).
# No prior spec covers digit('A') raises ValueError.
# digit() is documented to raise ValueError for characters that are not digits.
# ---------------------------------------------------------------------------

invariant unicodedata_extra9.digit.letter_raises:
  description: "unicodedata.digit('A') raises ValueError — 'A' is not a digit character"
  category: digit
  kind: python_call_raises
  function: digit
  args: ["A"]
  expected_exception: ValueError

# ---------------------------------------------------------------------------
# name() — new character vector
#
# Base spec covers: 'A', 'a', '0', '€'.
# extra6 covers: 'Z', '9'.
# extra7 covers: '!', ' '.
# U+00E9 LATIN SMALL LETTER E WITH ACUTE is a common accented character not yet covered.
# ---------------------------------------------------------------------------

invariant unicodedata_extra9.name.e_acute:
  description: "unicodedata.name('\\u00e9') == 'LATIN SMALL LETTER E WITH ACUTE'"
  category: name
  kind: python_call_eq
  function: name
  args: ["\u00e9"]
  expected: "LATIN SMALL LETTER E WITH ACUTE"

# ---------------------------------------------------------------------------
# combining() — space has combining class 0
#
# unicodedata (base) covers combining('A') == 0 and combining('0') == 0.
# unicodedata_extra4 covers combining('A') == 0.
# unicodedata_extra5 covers combining(U+0301) == 230.
# Space (' ') also has combining class 0 — not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant unicodedata_extra9.combining.space:
  description: "unicodedata.combining(' ') == 0 — space has no combining class"
  category: combining
  kind: python_call_eq
  function: combining
  args: [" "]
  expected: 0
