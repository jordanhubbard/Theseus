spec: strip_final_newline
version: ">=4.0.0"
backend: node(strip-final-newline)

docs: https://github.com/sindresorhus/strip-final-newline#readme

provenance:
  derived_from:
    - "strip-final-newline README — https://github.com/sindresorhus/strip-final-newline#readme"
    - "Test vectors verified with strip-final-newline via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "strip-final-newline source"
  notes:
    - "Removes the final newline character (\\n or \\r\\n) from a string or Buffer — exactly one occurrence."
    - "Install: npm install strip-final-newline"
    - "v4 is ESM with a CJS shim; default export is the function."
    - "Multiple trailing newlines: only ONE is stripped (e.g. 'x\\n\\n' → 'x\\n')."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table strip_final_newline.strip:
  kind: node_chain_eq
  category: strip
  entry: named
  function: default
  id_prefix: strip

  columns: [id, entry_args, chain, expected]
  rows:
    - [trailing_lf,        ["hello\n"],         [], "hello"]
    - [trailing_crlf,      ["hello\r\n"],       [], "hello"]
    - [no_trailing,        ["hello"],            [], "hello"]
    - [empty_input,        [""],                 [], ""]
    - [only_lf,            ["\n"],               [], ""]
    - [only_crlf,          ["\r\n"],             [], ""]
    - [multiple_lf_strips_one,  ["hello\n\n"],   [], "hello\n"]
    - [trailing_then_text, ["a\nb"],             [], "a\nb"]
    - [embedded_lf_kept,   ["a\nb\n"],           [], "a\nb"]
