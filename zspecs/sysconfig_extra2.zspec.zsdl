spec: sysconfig_extra2
version: ">=3.9"
backend: python_module(sysconfig)

docs: https://docs.python.org/3/library/sysconfig.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sysconfig.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sysconfig.py"
  notes:
    - "This spec extends sysconfig.zspec.zsdl and sysconfig_extra.zspec.zsdl with new vectors."
    - "sysconfig.zspec.zsdl: function names table (get_python_version/get_config_vars/get_config_var/get_platform/get_paths/get_path/get_scheme_names/get_path_names/is_python_build/parse_config_h); return types for get_python_version/get_scheme_names/get_path_names/get_platform; get_scheme_names len==7; get_path_names contains stdlib/platlib."
    - "sysconfig_extra.zspec.zsdl: function names table (same set); return types for get_python_version/get_platform/get_scheme_names/get_path_names via method/method_chain."
    - "This spec adds: get_config_vars() returns a dict; get_config_vars() is non-empty; get_paths() returns a dict; get_paths() is non-empty; get_path_names() len >= 1; get_scheme_names() contains 'posix_prefix'; get_python_version() contains '.'; get_path_names() contains 'scripts'; get_path_names() contains 'data'."
    - "get_config_vars() returns a dict mapping Makefile variable names to their values; it is always non-empty on a working CPython install."
    - "get_paths() returns a dict mapping all path category names to their resolved filesystem paths; always non-empty."
    - "get_scheme_names() includes 'posix_prefix' on all POSIX platforms (Linux, macOS, FreeBSD)."
    - "get_path_names() always contains 'scripts' and 'data' in addition to 'stdlib' and 'platlib'."
    - "get_python_version() always contains a '.' separator (e.g. '3.12', '3.9')."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# get_config_vars() — return type and non-emptiness
# Not covered in sysconfig.zspec.zsdl or sysconfig_extra.zspec.zsdl
# (those specs only check function name and return types of other functions)
# ---------------------------------------------------------------------------

invariant sysconfig_extra2.get_config_vars.returns_dict:
  description: "sysconfig.get_config_vars().__class__.__name__ == 'dict' — returns a dict of Makefile variables"
  category: runtime
  kind: python_call_eq
  function: get_config_vars
  args: []
  method: __class__
  method_chain: __name__
  expected: "dict"

invariant sysconfig_extra2.get_config_vars.nonempty:
  description: "len(sysconfig.get_config_vars()) >= 1 — config_vars dict is non-empty on any CPython install"
  category: runtime
  kind: python_call_eq
  function: get_config_vars
  args: []
  method: __len__
  method_args: []
  method_chain: __ge__
  method_chain_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# get_paths() — return type and non-emptiness
# Not covered in sysconfig.zspec.zsdl or sysconfig_extra.zspec.zsdl
# ---------------------------------------------------------------------------

invariant sysconfig_extra2.get_paths.returns_dict:
  description: "sysconfig.get_paths().__class__.__name__ == 'dict' — returns a dict of path category to path strings"
  category: runtime
  kind: python_call_eq
  function: get_paths
  args: []
  method: __class__
  method_chain: __name__
  expected: "dict"

invariant sysconfig_extra2.get_paths.nonempty:
  description: "len(sysconfig.get_paths()) >= 1 — paths dict is non-empty on any CPython install"
  category: runtime
  kind: python_call_eq
  function: get_paths
  args: []
  method: __len__
  method_args: []
  method_chain: __ge__
  method_chain_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# get_scheme_names() — content checks beyond what prior specs cover
# sysconfig.zspec.zsdl: len == 7, no content checks
# sysconfig_extra.zspec.zsdl: no content checks
# New here: 'posix_prefix' membership (POSIX-only; guaranteed on macOS, Linux, FreeBSD)
# ---------------------------------------------------------------------------

invariant sysconfig_extra2.get_scheme_names.posix_prefix:
  description: "sysconfig.get_scheme_names().__contains__('posix_prefix') — posix_prefix scheme is always present on POSIX platforms"
  category: runtime
  kind: python_call_eq
  function: get_scheme_names
  args: []
  method: __contains__
  method_args: ["posix_prefix"]
  expected: true

# ---------------------------------------------------------------------------
# get_path_names() — length and additional membership checks
# sysconfig.zspec.zsdl: contains 'stdlib', contains 'platlib'
# New here: len >= 1, contains 'scripts', contains 'data'
# ---------------------------------------------------------------------------

invariant sysconfig_extra2.get_path_names.nonempty:
  description: "len(sysconfig.get_path_names()) >= 1 — path_names tuple is always non-empty"
  category: runtime
  kind: python_call_eq
  function: get_path_names
  args: []
  method: __len__
  method_args: []
  method_chain: __ge__
  method_chain_args: [1]
  expected: true

invariant sysconfig_extra2.get_path_names.scripts_present:
  description: "sysconfig.get_path_names().__contains__('scripts') — 'scripts' is always in path_names"
  category: runtime
  kind: python_call_eq
  function: get_path_names
  args: []
  method: __contains__
  method_args: ["scripts"]
  expected: true

invariant sysconfig_extra2.get_path_names.data_present:
  description: "sysconfig.get_path_names().__contains__('data') — 'data' is always in path_names"
  category: runtime
  kind: python_call_eq
  function: get_path_names
  args: []
  method: __contains__
  method_args: ["data"]
  expected: true

# ---------------------------------------------------------------------------
# get_python_version() — version string always contains a '.' separator
# sysconfig.zspec.zsdl and sysconfig_extra.zspec.zsdl only check return type (str)
# New here: '.' membership (e.g. '3.12' always has at least one dot)
# ---------------------------------------------------------------------------

invariant sysconfig_extra2.get_python_version.contains_dot:
  description: "sysconfig.get_python_version().__contains__('.') — version string always contains a '.' separator"
  category: runtime
  kind: python_call_eq
  function: get_python_version
  args: []
  method: __contains__
  method_args: ["."]
  expected: true

invariant sysconfig_extra2.get_python_version.nonempty:
  description: "len(sysconfig.get_python_version()) >= 3 — version string is at least 3 chars (e.g. '3.9')"
  category: runtime
  kind: python_call_eq
  function: get_python_version
  args: []
  method: __len__
  method_args: []
  method_chain: __ge__
  method_chain_args: [3]
  expected: true
