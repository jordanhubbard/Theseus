spec: re_extra1771
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class names, flag constants, match/search/sub/split/findall"
  notes:
    - "Wave 565, theme: async protocol. All five async dunder methods are absent from re types."
    - "re.compile returns a re.Pattern object; re.match/re.search return re.Match objects."
    - "re.compile.__class__.__name__ == 'function' — compile is a plain Python function."
    - "re.match.__class__.__name__ == 'function' — match is a plain Python function."
    - "re.search.__class__.__name__ == 'function' — search is a plain Python function."
    - "re.sub.__class__.__name__ == 'function' — sub is a plain Python function."
    - "re.error defines a custom __init__ (accepting msg, pattern, pos); __init__ is in re.error.__dict__."
    - "re.NOFLAG exists in Python 3.11+; its __class__.__name__ == 'RegexFlag'."
    - "All expected values verified by running Python 3.14 re module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Async protocol — re types do NOT define any async dunder in their own __dict__
# Wave 565 theme: __aenter__, __aexit__, __aiter__, __anext__, __await__
# ---------------------------------------------------------------------------

table re_extra1771.async_protocol:
  kind: python_call_eq
  category: async_protocol
  id_prefix: re1771

  columns: [id, function, args, expected]
  rows:
    - ["re1771001", error.__dict__.__contains__,   ["__aenter__"], false]
    - ["re1771002", error.__dict__.__contains__,   ["__aexit__"],  false]
    - ["re1771003", error.__dict__.__contains__,   ["__aiter__"],  false]
    - ["re1771004", error.__dict__.__contains__,   ["__anext__"],  false]
    - ["re1771005", error.__dict__.__contains__,   ["__await__"],  false]
    - ["re1771006", Pattern.__dict__.__contains__, ["__aenter__"], false]
    - ["re1771007", Pattern.__dict__.__contains__, ["__aexit__"],  false]
    - ["re1771008", Pattern.__dict__.__contains__, ["__aiter__"],  false]
    - ["re1771009", Pattern.__dict__.__contains__, ["__anext__"],  false]
    - ["re1771010", Pattern.__dict__.__contains__, ["__await__"],  false]

# ---------------------------------------------------------------------------
# Complementary: function class names — compile, match, search, sub
# ---------------------------------------------------------------------------

table re_extra1771.function_class_names:
  kind: python_call_eq
  category: function_types
  id_prefix: re1771

  columns: [id, function, args, expected]
  rows:
    - ["re1771011", compile.__class__.__name__.__eq__, ["function"], true]
    - ["re1771012", match.__class__.__name__.__eq__,   ["function"], true]
    - ["re1771013", search.__class__.__name__.__eq__,  ["function"], true]
    - ["re1771014", sub.__class__.__name__.__eq__,     ["function"], true]

# ---------------------------------------------------------------------------
# Complementary: re.error.__dict__ contains __init__ (custom constructor)
# ---------------------------------------------------------------------------

invariant re_extra1771.error.has_init:
  description: "re.error.__dict__.__contains__('__init__') == True — re.error defines a custom __init__"
  category: dict_membership
  kind: python_call_eq
  function: error.__dict__.__contains__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Complementary: re.NOFLAG — exists in Python 3.11+, class is RegexFlag
# ---------------------------------------------------------------------------

invariant re_extra1771.NOFLAG.class_name:
  description: "re.NOFLAG.__class__.__name__ == 'RegexFlag'"
  category: flags
  kind: python_call_eq
  function: NOFLAG.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra1771.NOFLAG.value_zero:
  description: "re.NOFLAG == 0 — NOFLAG has integer value 0"
  category: flags
  kind: python_call_eq
  function: NOFLAG.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Complementary: Pattern class metadata — Pattern and Match are in re.__dict__
# ---------------------------------------------------------------------------

invariant re_extra1771.Pattern.class_name:
  description: "re.Pattern.__name__ == 'Pattern'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra1771.Match.class_name:
  description: "re.Match.__name__ == 'Match'"
  category: class_metadata
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra1771.error.class_name:
  description: "re.error.__name__ == 'error'"
  category: class_metadata
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true
