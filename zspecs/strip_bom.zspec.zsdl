spec: strip_bom
version: ">=5.0.0"
backend: node(strip-bom)

docs: https://github.com/sindresorhus/strip-bom#readme

provenance:
  derived_from:
    - "strip-bom README — https://github.com/sindresorhus/strip-bom#readme"
    - "Unicode UTF-8 BOM (U+FEFF)"
    - "Test vectors verified with strip-bom via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "strip-bom source"
  notes:
    - "Strips the leading UTF-8 byte-order mark (U+FEFF) from a string, if present."
    - "Install: npm install strip-bom"
    - "v5 is ESM with a CJS shim; default export is the function."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table strip_bom.strip:
  kind: node_chain_eq
  category: strip
  entry: named
  function: default
  id_prefix: strip

  columns: [id, entry_args, chain, expected]
  rows:
    - [with_bom,         ["﻿hello"],     [], "hello"]
    - [no_bom_passthrough, ["hello"],         [], "hello"]
    - [empty_string,     [""],                  [], ""]
    - [bom_only,         ["﻿"],            [], ""]
    - [bom_then_unicode, ["﻿Café"],        [], "Café"]
    - [embedded_not_at_start, ["a﻿b"],     [], "a﻿b"]
    - [bom_then_newline, ["﻿\nhello"],    [], "\nhello"]

# Length contract — BOM-stripped string is 1 char shorter
invariant strip_bom.length_decreases_by_one_when_bom_present:
  description: "Stripping a BOM-prefixed string decreases length by 1"
  category: length
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["﻿hello"]
  chain:
    - {get: length}
  expected: 5
