spec: socket_extra1081
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket __init__/__repr__/__enter__/__exit__ qualnames, socket.getfqdn/gethostname/getaddrinfo qualname and module"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1081.socket_lifecycle_qualnames:
  description: "socket.socket __init__, __repr__, __enter__, __exit__ qualname identity"
  kind: python_call_eq
  category: socket_lifecycle_qualnames
  id_prefix: sk1081lq
  columns: [id, function, args, expected]
  rows:
    - [sk1081lq001, socket.socket.__init__.__qualname__.__eq__,   ["socket.__init__"],  true]
    - [sk1081lq002, socket.socket.__repr__.__qualname__.__eq__,   ["socket.__repr__"],  true]
    - [sk1081lq003, socket.socket.__enter__.__qualname__.__eq__,  ["socket.__enter__"], true]
    - [sk1081lq004, socket.socket.__exit__.__qualname__.__eq__,   ["socket.__exit__"],  true]
    - [sk1081lq005, socket.socket.__init__.__qualname__.__class__.__name__.__eq__,  ["str"], true]
    - [sk1081lq006, socket.socket.__repr__.__qualname__.__class__.__name__.__eq__,  ["str"], true]
    - [sk1081lq007, socket.socket.__enter__.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [sk1081lq008, socket.socket.__exit__.__qualname__.__class__.__name__.__eq__,  ["str"], true]

table socket_extra1081.socket_lifecycle_class_names:
