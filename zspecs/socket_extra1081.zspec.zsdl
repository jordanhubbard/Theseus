    - [sk1081lc004, socket.socket.__exit__.__class__.__name__.__eq__,   ["slot_wrapper"], true]

table socket_extra1081.module_function_qualname_and_module:
  description: "socket.getfqdn, socket.gethostname, socket.getaddrinfo qualname and module identity"
  kind: python_call_eq
  category: module_function_qualname_module
  id_prefix: sk1081mf
  columns: [id, function, args, expected]
  rows:
    - [sk1081mf001, socket.getfqdn.__qualname__.__eq__,                      ["getfqdn"],     true]
    - [sk1081mf002, socket.gethostname.__qualname__.__eq__,                  ["gethostname"], true]
