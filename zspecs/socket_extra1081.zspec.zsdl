    - [sk1081mf004, socket.getfqdn.__module__.__eq__,                        ["socket"],      true]
    - [sk1081mf005, socket.gethostname.__module__.__eq__,                    ["socket"],      true]
    - [sk1081mf006, socket.getaddrinfo.__module__.__eq__,                    ["socket"],      true]
    - [sk1081mf007, socket.getfqdn.__qualname__.__class__.__name__.__eq__,   ["str"],         true]
    - [sk1081mf008, socket.gethostname.__qualname__.__class__.__name__.__eq__, ["str"],       true]
    - [sk1081mf009, socket.getaddrinfo.__qualname__.__class__.__name__.__eq__, ["str"],       true]
    - [sk1081mf010, socket.getfqdn.__class__.__name__.__eq__,                ["function"],    true]
    - [sk1081mf011, socket.gethostname.__class__.__name__.__eq__,            ["builtin_function_or_method"], true]
