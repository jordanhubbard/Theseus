spec: mp3091
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 653 (mp3091): __hash__, __eq__, __bool__ dict-presence for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.pool.AsyncResult, multiprocessing.pool.MapResult, multiprocessing.managers.SyncManager, multiprocessing.managers.BaseListProxy, multiprocessing.managers._BaseDictProxy, multiprocessing.managers._BaseSetProxy."
    - "All 8 multiprocessing classes return false for __hash__, __eq__, and __bool__ in their own __dict__."
    - "multiprocessing.Process is the primary process-spawning class; it uses identity-based equality and hashing from object."
    - "Pool and AsyncResult/MapResult are work-distribution primitives; no custom comparison semantics are defined."
    - "The manager proxy classes (BaseListProxy, _BaseDictProxy, _BaseSetProxy) delegate operations to the managed object in the server process but do not define custom __hash__, __eq__, or __bool__ in their own __dict__."
    - "SyncManager is a multiprocessing.managers.BaseManager subclass providing managed synchronization objects; it defines no custom hash, equality, or bool."
    - "__bool__ is false for all 8 classes — none define truthiness semantics; they always evaluate as truthy via the object default."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# All 8 multiprocessing classes return false for __hash__.
# None define __hash__ in their own __dict__; they inherit identity-based
# hashing from object. Proxy classes mirror operations to the server process
# but do not redefine object identity or hashing on the client side.
# ---------------------------------------------------------------------------

table mp3091.hash:
  description: "multiprocessing types __hash__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3091

  columns: [id, function, args, expected]
  rows:
    - ["mp3091001", operator.contains, [multiprocessing.Process.__dict__,                  "__hash__"], false]
    - ["mp3091002", operator.contains, [multiprocessing.pool.Pool.__dict__,                "__hash__"], false]
    - ["mp3091003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__hash__"], false]
    - ["mp3091004", operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__hash__"], false]
    - ["mp3091005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__hash__"], false]
    - ["mp3091006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__hash__"], false]
    - ["mp3091007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__hash__"], false]
    - ["mp3091008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ dict-presence — operator.contains(Cls.__dict__, '__eq__')
#
# All 8 multiprocessing classes return false for __eq__.
# None define custom equality; they rely on identity comparison from object.
# Proxy objects represent distinct handles to managed state — two proxies
# pointing to the same managed object are still distinct Python objects.
# ---------------------------------------------------------------------------

