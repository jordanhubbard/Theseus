# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# All 8 multiprocessing classes return false for __bool__.
# No class defines custom boolean coercion; they always evaluate as truthy
# by inheriting the default from object.
# Pool and Process objects don't expose running/stopped state via __bool__;
# proxy objects don't reflect the managed container's emptiness.
# ---------------------------------------------------------------------------

