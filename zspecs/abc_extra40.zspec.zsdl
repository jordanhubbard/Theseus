spec: abc_extra40
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra39.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token/update_abstractmethods, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), ABCMeta/__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC/__abstractmethods__/__class__/__name__.__len__()==9, ABC/__name__.__len__()==3, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name/qualname lengths, ABC/__subclasshook__/__qualname__.__len__()==20, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABCMeta/__prepare__/__qualname__.__len__()==19, ABCMeta/__init__/__qualname__.__len__()==13, ABCMeta/__getattribute__/__qualname__.__len__()==21, ABCMeta/__call__/__repr__/__qualname__.__len__()==13, ABCMeta/__setattr__/__delattr__/__qualname__.__len__()==16, abstractmethod/__code__/__class__/__name__.__len__()==4, ABC/__init_subclass__/__qualname__/__len__()==21, metaclass chain tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4, get_cache_token/__class__/__name__.__len__()==26, ABCMeta/__bases__[0]/__module__/__qualname__.__len__(), ABC/__bases__[0]/__module__/__qualname__.__len__(), abstractmethod/__class__/__module__.__len__()==8, abc/__spec__/__class__/__name__.__len__()==10, ABCMeta MRO __module__/__qualname__.__len__() tables, abstractmethod/__name__=='abstractmethod' (extra34), get_cache_token/__module__=='_abc' (extra34), ABC/__name__=='ABC' (extra34), ABC/__bases__[0].__name__=='object' (extra34), ABCMeta/__name__=='ABCMeta'/__module__=='abc'/__bases__[0].__name__=='type' (extra35), ABCMeta.register/__qualname__.__len__()==16 (extra35), ABCMeta/__mro__.__len__()==3, ABC/__mro__.__len__()==2, ABC/__mro__[1].__name__=='object' (extra35), ABCMeta MRO entries [0]/'ABCMeta', [1]/'type', [2]/'object', ABC/__mro__[0].__name__=='ABC', abstractmethod/__qualname__.__len__()==14, abstractproperty/__name__=='abstractproperty'/__module__=='abc', abstractclassmethod/__name__=='abstractclassmethod'/__module__=='abc' (extra36), abstractproperty/__qualname__=='abstractproperty', abstractproperty/__qualname__.__len__()==16, abstractproperty/__bases__[0].__name__=='property', abstractclassmethod/__bases__[0].__name__=='classmethod', abstractstaticmethod/__name__=='abstractstaticmethod', abstractstaticmethod/__bases__[0].__name__=='staticmethod', ABC/__qualname__=='ABC', ABC/__qualname__.__len__()==3 (extra37), abstractmethod/__qualname__=='abstractmethod', abstractclassmethod/__qualname__=='abstractclassmethod', abstractstaticmethod/__qualname__=='abstractstaticmethod', ABCMeta.register/__qualname__=='ABCMeta.register', ABC/__abstractmethods__/__class__/__name__=='frozenset', ABC/__abstractmethods__/__len__()==0, ABCMeta/__call__/__qualname__=='type.__call__' (extra38), ABCMeta/__qualname__=='ABCMeta', ABCMeta/__qualname__.__len__()==7, ABC/__qualname__.__len__()==3, abstractmethod/__qualname__.__len__()==14, abstractproperty/__qualname__.__len__()==16, abstractclassmethod/__qualname__.__len__()==19, abstractstaticmethod/__qualname__.__len__()==20, get_cache_token/__qualname__=='get_cache_token', get_cache_token/__qualname__.__len__()==15 (extra39)."
    - "This spec covers: abstractproperty/__mro__.__len__()==3; abstractclassmethod/__mro__.__len__()==3; abstractstaticmethod/__mro__.__len__()==3; abstractmethod/__class__.__name__=='function'; abstractproperty/__class__.__name__=='type'; ABC/__class__.__name__=='ABCMeta'; abstractproperty/__bases__[0].__name__.__len__()==8; abstractclassmethod/__bases__[0].__name__.__len__()==11; abstractstaticmethod/__bases__[0].__name__.__len__()==12."
    - "abc.abstractproperty.__mro__.__len__() == 3. abstractproperty.__mro__ == (abstractproperty, property, object). It subclasses property and has one intermediate base. ABCMeta and ABC MRO depths were covered in extra35; extra40 extends to the three deprecated abstract decorator classes. Verified with Python 3.14.3."
    - "abc.abstractclassmethod.__mro__.__len__() == 3. abstractclassmethod.__mro__ == (abstractclassmethod, classmethod, object). It subclasses classmethod with depth 3. Shares MRO depth 3 with abstractproperty and abstractstaticmethod. Verified with Python 3.14.3."
    - "abc.abstractstaticmethod.__mro__.__len__() == 3. abstractstaticmethod.__mro__ == (abstractstaticmethod, staticmethod, object). It subclasses staticmethod with depth 3. All three deprecated abstract decorators share MRO depth 3. Verified with Python 3.14.3."
    - "abc.abstractmethod.__class__.__name__ == 'function'. abstractmethod is a plain Python function (not a class), so its __class__ is 'function'. This contrasts with abstractproperty which is a class (type). len('function') == 8. Verified with Python 3.14.3."
    - "abc.abstractproperty.__class__.__name__ == 'type'. abstractproperty is a class (a subclass of property) so its metaclass instance is 'type'. This contrasts with abstractmethod which is a function. len('type') == 4. Verified with Python 3.14.3."
    - "abc.ABC.__class__.__name__ == 'ABCMeta'. ABC is an instance of ABCMeta (its metaclass); ABC.__class__ == ABCMeta. This demonstrates that ABCMeta is the metaclass for ABC. len('ABCMeta') == 7. Verified with Python 3.14.3."
    - "abc.abstractproperty.__bases__[0].__name__.__len__() == 8. abstractproperty.__bases__[0].__name__ == 'property'; len('property') == 8. Extends prior coverage of __bases__[0].__name__ equality (extra36) to include the length. Verified with Python 3.14.3."
    - "abc.abstractclassmethod.__bases__[0].__name__.__len__() == 11. abstractclassmethod.__bases__[0].__name__ == 'classmethod'; len('classmethod') == 11. Verified with Python 3.14.3."
    - "abc.abstractstaticmethod.__bases__[0].__name__.__len__() == 12. abstractstaticmethod.__bases__[0].__name__ == 'staticmethod'; len('staticmethod') == 12. Note: the three deprecated abstract decorator base names increase in length: property(8) < classmethod(11) < staticmethod(12). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc deprecated abstract decorator class MRO depths — extra40 namespace
#
# ABCMeta.__mro__.__len__()==3 and ABC.__mro__.__len__()==2 were covered in
# extra35. Extra40 covers the three deprecated abstract decorator classes:
#   abstractproperty.__mro__.__len__()    == 3  (abstractproperty, property, object)
#   abstractclassmethod.__mro__.__len__() == 3  (abstractclassmethod, classmethod, object)
#   abstractstaticmethod.__mro__.__len__() == 3 (abstractstaticmethod, staticmethod, object)
# All three share MRO depth 3; each has a different stdlib metaclass as parent.
# ---------------------------------------------------------------------------

table abc_extra40.deprecated_abstract_mro_depths:
  description: "abc deprecated abstract decorator class __mro__.__len__() in extra40 namespace — abstractproperty, abstractclassmethod, abstractstaticmethod"
  kind: python_call_eq
  category: class_names
  id_prefix: abcdepabsmrodepth40

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty,    abstractproperty.__mro__.__len__,    [], 3, "abstractproperty.__mro__.__len__() == 3 — abstractproperty -> property -> object"]
    - [abstractclassmethod, abstractclassmethod.__mro__.__len__, [], 3, "abstractclassmethod.__mro__.__len__() == 3 — abstractclassmethod -> classmethod -> object"]
    - [abstractstaticmethod, abstractstaticmethod.__mro__.__len__, [], 3, "abstractstaticmethod.__mro__.__len__() == 3 — abstractstaticmethod -> staticmethod -> object"]

# ---------------------------------------------------------------------------
# abc class identity (__class__.__name__) — extra40 namespace
#
# Three key identity facts about abc objects:
#   abstractmethod.__class__.__name__ == 'function'  — it is a plain function
#   abstractproperty.__class__.__name__ == 'type'    — it is a class (type instance)
#   ABC.__class__.__name__ == 'ABCMeta'              — ABC's metaclass is ABCMeta
# These capture the nature of each abc export:
# - abstractmethod is decorated with @abc.abstractmethod as a function wrapper
# - abstractproperty (deprecated) is a class that subclasses property
# - ABC is a class whose metaclass is ABCMeta
# Prior spec extra34 captured abstractmethod/__class__/__name__.__len__()==8
# (via __len__); extra40 captures the string equality directly.
# ---------------------------------------------------------------------------

table abc_extra40.class_identity:
  description: "abc object identity via __class__.__name__ string equality in extra40 namespace — abstractmethod, abstractproperty, ABC"
  kind: python_call_eq
  category: class_names
  id_prefix: abcclsidentity40

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_class,  abstractmethod.__class__.__name__.__eq__,  ["function"], true, "abstractmethod.__class__.__name__ == 'function' — abstractmethod is a plain Python function, not a class"]
    - [abstractproperty_class, abstractproperty.__class__.__name__.__eq__, ["type"],   true, "abstractproperty.__class__.__name__ == 'type' — abstractproperty is a class (subclasses property); its metaclass is 'type'"]
    - [ABC_class,             ABC.__class__.__name__.__eq__,             ["ABCMeta"],  true, "ABC.__class__.__name__ == 'ABCMeta' — ABC is an instance of ABCMeta; its metaclass is ABCMeta"]

# ---------------------------------------------------------------------------
# abc deprecated abstract decorator __bases__[0].__name__ lengths — extra40
#
# Extra36 captured __bases__[0].__name__ string equality for the three
# deprecated abstract decorators. Extra40 adds the __len__() measurements:
#   abstractproperty.__bases__[0].__name__.__len__()    == 8   ('property')
#   abstractclassmethod.__bases__[0].__name__.__len__() == 11  ('classmethod')
#   abstractstaticmethod.__bases__[0].__name__.__len__()== 12  ('staticmethod')
# The three base names increase in length: property < classmethod < staticmethod.
# ---------------------------------------------------------------------------

table abc_extra40.deprecated_abstract_bases_name_lengths:
  description: "abc deprecated abstract decorator __bases__[0].__name__.__len__() in extra40 namespace — property, classmethod, staticmethod"
  kind: python_call_eq
  category: class_names
  id_prefix: abcdepabsbasesnamelen40

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty,    "abstractproperty.__bases__[0].__name__.__len__",    [],  8, "abstractproperty.__bases__[0].__name__.__len__() == 8 — base 'property' has 8 characters"]
    - [abstractclassmethod, "abstractclassmethod.__bases__[0].__name__.__len__", [], 11, "abstractclassmethod.__bases__[0].__name__.__len__() == 11 — base 'classmethod' has 11 characters"]
    - [abstractstaticmethod, "abstractstaticmethod.__bases__[0].__name__.__len__", [], 12, "abstractstaticmethod.__bases__[0].__name__.__len__() == 12 — base 'staticmethod' has 12 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra40
# ---------------------------------------------------------------------------

invariant abc_extra40.abstractproperty_mro_len:
  description: "abc.abstractproperty.__mro__.__len__() == 3 — abstractproperty -> property -> object"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra40.abstractclassmethod_mro_len:
  description: "abc.abstractclassmethod.__mro__.__len__() == 3 — abstractclassmethod -> classmethod -> object"
  category: class_names
  kind: python_call_eq
  function: abstractclassmethod.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra40.abstractstaticmethod_mro_len:
  description: "abc.abstractstaticmethod.__mro__.__len__() == 3 — abstractstaticmethod -> staticmethod -> object"
  category: class_names
  kind: python_call_eq
  function: abstractstaticmethod.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra40.abstractmethod_class_name_eq:
  description: "abc.abstractmethod.__class__.__name__ == 'function' — abstractmethod is a plain Python function (not a class)"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra40.abstractproperty_class_name_eq:
  description: "abc.abstractproperty.__class__.__name__ == 'type' — abstractproperty is a class; its metaclass is type"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra40.ABC_class_name_eq:
  description: "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC is an instance of ABCMeta; its metaclass is ABCMeta"
  category: class_names
  kind: python_call_eq
  function: ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra40.abstractproperty_bases_name_len:
  description: "abc.abstractproperty.__bases__[0].__name__.__len__() == 8 — base class 'property' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: "abstractproperty.__bases__[0].__name__.__len__"
  args: []
  expected: 8

invariant abc_extra40.abstractclassmethod_bases_name_len:
  description: "abc.abstractclassmethod.__bases__[0].__name__.__len__() == 11 — base class 'classmethod' has 11 characters"
  category: class_names
  kind: python_call_eq
  function: "abstractclassmethod.__bases__[0].__name__.__len__"
  args: []
  expected: 11

invariant abc_extra40.abstractstaticmethod_bases_name_len:
  description: "abc.abstractstaticmethod.__bases__[0].__name__.__len__() == 12 — base class 'staticmethod' has 12 characters"
  category: class_names
  kind: python_call_eq
  function: "abstractstaticmethod.__bases__[0].__name__.__len__"
  args: []
  expected: 12
