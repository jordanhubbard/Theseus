provenance:
  derived_from:
    - "https://www.python-httpx.org/ — HTTPX library"
  notes:
    - "httpx is a fully featured HTTP client."
    - "httpx.Client is a class."
    - "httpx.AsyncClient is a class."
    - "httpx.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant httpx_extra_rust.has_client:
  description: "httpx.Client is a class"
  category: presence
  kind: python_call_eq
  function: httpx_has_client
  args: []
