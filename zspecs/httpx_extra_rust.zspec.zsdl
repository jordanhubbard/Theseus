invariant httpx_extra_rust.has_async_client:
  description: "httpx.AsyncClient is a class"
  category: presence
  kind: python_call_eq
  function: httpx_has_async_client
  args: []
  expected: true

invariant httpx_extra_rust.version_nonempty:
  description: "httpx.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: httpx_extra_version_nonempty
  args: []
  expected: true

