spec: uuid_extra1696
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "https://docs.python.org/3/library/pickle.html — Python pickle protocol documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 560 (_extra1696): pickling protocol dict-presence checks."
    - "uuid.UUID uses __slots__ = ('int', 'is_safe', '__weakref__') and therefore relies on __getstate__ and __setstate__ for pickling instead of the default instance __dict__ mechanism."
    - "uuid.UUID defines __getstate__ and __setstate__ in its own __dict__ but does NOT define __reduce__, __getnewargs__, or __getnewargs_ex__."
    - "uuid.UUID is picklable in Python — pickle.loads(pickle.dumps(uuid.UUID(...))) produces an equal object."
    - "uuid.SafeUUID is an Enum subclass; it defines neither pickle dunders nor copy dunders in its own __dict__."
    - "uuid.UUID does not define __copy__ or __deepcopy__ in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Pickling protocol methods on uuid.UUID.__dict__
#
# uuid.UUID uses __slots__, so the default pickling mechanism (which relies on
# __dict__) does not work.  uuid.UUID therefore defines __getstate__ and
# __setstate__ to support pickle.  It does not define __reduce__, __getnewargs__,
# or __getnewargs_ex__.
# ---------------------------------------------------------------------------

table uuid_extra1696.pickling_protocol:
  description: "uuid.UUID pickling protocol dict-presence checks — __getstate__ and __setstate__ present; __reduce__ and getnewargs variants absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1696

  columns: [id, function, args, expected]
  rows:
    - ["uu1696001", "uuid.UUID.__dict__.__contains__", ["__reduce__"],        false]
    - ["uu1696002", "uuid.UUID.__dict__.__contains__", ["__getstate__"],      true]
    - ["uu1696003", "uuid.UUID.__dict__.__contains__", ["__setstate__"],      true]
    - ["uu1696004", "uuid.UUID.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["uu1696005", "uuid.UUID.__dict__.__contains__", ["__getnewargs_ex__"], false]

# ---------------------------------------------------------------------------
# Table 2: Copy protocol and slots dict-presence checks on uuid.UUID
#
# uuid.UUID does not define __copy__ or __deepcopy__ in its own __dict__.
# The __slots__ key is present in uuid.UUID.__dict__ (as a class-level tuple).
# ---------------------------------------------------------------------------

table uuid_extra1696.copy_and_slots:
  description: "uuid.UUID copy protocol and __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1696

  columns: [id, function, args, expected]
  rows:
    - ["uu1696006", "uuid.UUID.__dict__.__contains__", ["__copy__"],     false]
    - ["uu1696007", "uuid.UUID.__dict__.__contains__", ["__deepcopy__"], false]
    - ["uu1696008", "uuid.UUID.__dict__.__contains__", ["__slots__"],    true]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID comparison and conversion API dict-presence checks
#
# uuid.UUID defines a full set of rich comparison and conversion methods in
# its own __dict__: __hash__, __eq__, __lt__, __le__, __gt__, __ge__,
# __str__, __repr__, __int__, and the properties bytes, hex, int, and __init__.
# ---------------------------------------------------------------------------

table uuid_extra1696.comparison_and_api:
  description: "uuid.UUID comparison, hashing, and conversion API dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1696

  columns: [id, function, args, expected]
  rows:
    - ["uu1696009", "uuid.UUID.__dict__.__contains__", ["__hash__"],  true]
    - ["uu1696010", "uuid.UUID.__dict__.__contains__", ["__eq__"],    true]
    - ["uu1696011", "uuid.UUID.__dict__.__contains__", ["__lt__"],    true]
    - ["uu1696012", "uuid.UUID.__dict__.__contains__", ["__le__"],    true]
    - ["uu1696013", "uuid.UUID.__dict__.__contains__", ["__gt__"],    true]
    - ["uu1696014", "uuid.UUID.__dict__.__contains__", ["__ge__"],    true]
    - ["uu1696015", "uuid.UUID.__dict__.__contains__", ["__str__"],   true]
    - ["uu1696016", "uuid.UUID.__dict__.__contains__", ["__repr__"],  true]
    - ["uu1696017", "uuid.UUID.__dict__.__contains__", ["__int__"],   true]
    - ["uu1696018", "uuid.UUID.__dict__.__contains__", ["__init__"],  true]
    - ["uu1696019", "uuid.UUID.__dict__.__contains__", ["bytes"],     true]
    - ["uu1696020", "uuid.UUID.__dict__.__contains__", ["hex"],       true]
    - ["uu1696021", "uuid.UUID.__dict__.__contains__", ["int"],       true]

# ---------------------------------------------------------------------------
# Table 4: uuid.SafeUUID pickling protocol dict-presence checks
#
# uuid.SafeUUID is an Enum subclass.  It defines neither pickle dunders
# (__reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__)
# nor copy dunders (__copy__, __deepcopy__) in its own __dict__.
# ---------------------------------------------------------------------------

table uuid_extra1696.safeuuid_pickling_protocol:
  description: "uuid.SafeUUID pickling and copy protocol dict-presence checks — no pickle or copy dunders in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1696

  columns: [id, function, args, expected]
  rows:
    - ["uu1696022", "uuid.SafeUUID.__dict__.__contains__", ["__reduce__"],        false]
    - ["uu1696023", "uuid.SafeUUID.__dict__.__contains__", ["__getstate__"],      false]
    - ["uu1696024", "uuid.SafeUUID.__dict__.__contains__", ["__setstate__"],      false]
    - ["uu1696025", "uuid.SafeUUID.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["uu1696026", "uuid.SafeUUID.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["uu1696027", "uuid.SafeUUID.__dict__.__contains__", ["__copy__"],          false]
    - ["uu1696028", "uuid.SafeUUID.__dict__.__contains__", ["__deepcopy__"],      false]
