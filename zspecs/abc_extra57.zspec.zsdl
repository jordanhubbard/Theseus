spec: abc_extra57
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#annotations — Python __annotations__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra56.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables, ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8), ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ (extra49), abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__.__eq__('mappingproxy') (extra49), abc module __dict__.__class__.__name__/__qualname__ (extra49), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41-extra43), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins' (extra42), abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper' (extra50), __class__.__module__.__len__() cross-checks (extra50), __repr__.__class__.__name__ for all abc objects (extra51), __weakref__.__class__.__name__ for abstractproperty/abstractclassmethod/abstractstaticmethod (extra51), ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function') (extra52), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra52), abc.__package__.__eq__('') (extra53), ABC/ABCMeta/abstractmethod/get_cache_token __doc__.__class__.__name__.__eq__('str') (extra53), ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') (extra53), __loader__.__class__.__name__.__eq__('type') (extra54), __loader__.__name__.__eq__('FrozenImporter') (extra54), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra54), __file__.__class__.__name__.__eq__('str') (extra54), ABCMeta.__instancecheck__.__qualname__.__len__()==25 (extra54), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__name__.__len__() (extra55), ABCMeta.register/__instancecheck__/__subclasscheck__/update_abstractmethods __qualname__.__eq__ (extra56), abstractproperty.__init__.__qualname__.__eq__('property.__init__') (extra56)."
    - "This spec covers (abcann57 namespace): wave 228 theme — __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks. NEW in extra57: abstractmethod/__annotations__.__class__.__name__.__eq__('dict') — prior specs covered abstractmethod.__annotations__ content (empty dict, len==0) but NOT the __class__.__name__ via __eq__; abstractmethod/__globals__.__class__.__name__.__eq__('dict') — no prior abc spec has checked the __globals__ dict class name via __eq__; abstractmethod/__globals__.__contains__('abstractmethod') — no prior abc spec has used __contains__ on abstractmethod.__globals__; ABCMeta/__doc__.__contains__('Abstract') — ABCMeta.__doc__ starts 'Metaclass for defining Abstract Base Classes (ABCs).' and contains 'Abstract' but NOT 'ABCMeta' (verified); get_cache_token is a builtin function (builtin_function_or_method) — it has NO __annotations__ attribute; the task requesting annotations checks for get_cache_token is inapplicable; this spec instead verifies get_cache_token.__class__.__name__ to distinguish it from pure-Python abstractmethod."
    - "abc.abstractmethod.__annotations__.__class__.__name__ == 'dict'. abstractmethod is a pure-Python function defined in Lib/abc.py. Its __annotations__ attribute is an empty dict ({}). The __class__.__name__ of that dict is 'dict'. Prior specs captured abstractmethod.__annotations__ content (empty dict) but did NOT verify __class__.__name__ via __eq__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__globals__.__class__.__name__ == 'dict'. The __globals__ of any pure-Python function is the module-level namespace dict of its defining module (Lib/abc.py). The type of that namespace is dict, so __class__.__name__ is 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__globals__.__contains__('abstractmethod') returns True. 'abstractmethod' is a key in abstractmethod's module globals (Lib/abc.py) because abstractmethod is defined at module level in that file. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__doc__.__contains__('Abstract') returns True. ABCMeta.__doc__ is 'Metaclass for defining Abstract Base Classes (ABCs).' followed by additional text. The word 'Abstract' appears in the docstring. NOTE: ABCMeta.__doc__ does NOT contain 'ABCMeta' (verified — the docstring uses 'ABC' abbreviation, not the full class name). 'Abstract' is the correct content check substring that returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token is a builtin_function_or_method (defined in Modules/_abc.c). It has NO __annotations__ attribute — accessing get_cache_token.__annotations__ raises AttributeError. The task description requesting __annotations__ checks for get_cache_token is inapplicable to this builtin. This spec instead verifies get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') to document the type distinction from pure-Python abstractmethod. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc abstractmethod __annotations__ class identity — extra57
#
# Wave 228 theme: __annotations__ class identity checks.
#
# abstractmethod is a pure-Python function defined in Lib/abc.py. Its
# __annotations__ attribute is an empty dict ({}). The __class__.__name__
# of that dict is 'dict'.
#
# NEW: prior specs captured abstractmethod.__annotations__ content but NOT
# the __class__.__name__ via __eq__.
# ---------------------------------------------------------------------------

table abc_extra57.abstractmethod_annotations_class_name:
  description: "abc abstractmethod.__annotations__.__class__.__name__.__eq__('dict') check in abcann57 namespace — wave 228 theme: __annotations__ class identity; abstractmethod is a pure-Python function (Lib/abc.py); its __annotations__ attribute is an empty dict ({}); __class__.__name__ of that dict is 'dict'; prior specs covered the annotations content (empty dict) but NOT __class__.__name__ via __eq__; NEW in extra57: first __annotations__.__class__.__name__.__eq__ check for abstractmethod in any abc spec; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: abcann57

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_ann_class, abstractmethod.__annotations__.__class__.__name__.__eq__, ["dict"], true, "abstractmethod.__annotations__.__class__.__name__ == 'dict' — abstractmethod is a pure-Python function defined in Lib/abc.py; its __annotations__ attribute is an empty dict ({}); the type of any dict is dict itself, so __class__.__name__ is 'dict'; prior specs captured the empty dict content but NOT the __class__.__name__ via __eq__; NEW in extra57: first __annotations__.__class__.__name__.__eq__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc abstractmethod.__globals__ class identity and key membership — extra57
#
# Wave 228 theme: __globals__ dict keys.
#
# abstractmethod.__globals__ is the module-level namespace dict of Lib/abc.py.
# Its type is dict. 'abstractmethod' is a key in that dict because abstractmethod
# is defined at module level in Lib/abc.py.
# ---------------------------------------------------------------------------

table abc_extra57.abstractmethod_globals_class_and_contains:
  description: "abc abstractmethod.__globals__ class identity and key membership checks in abcann57 namespace — wave 228 theme: __globals__ dict keys; abstractmethod.__globals__ is the module-level namespace dict of Lib/abc.py; its __class__.__name__ is 'dict' and it contains 'abstractmethod' as a key since abstractmethod is defined at module level; NEW in extra57: no prior abc spec has checked abstractmethod.__globals__.__class__.__name__ via __eq__ or used __contains__ on abstractmethod.__globals__; verified with Python 3.14.3"
  kind: python_call_eq
  category: globals
  id_prefix: abcann57g

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_globals_class,    abstractmethod.__globals__.__class__.__name__.__eq__, ["dict"],           true, "abstractmethod.__globals__.__class__.__name__ == 'dict' — the __globals__ of any pure-Python function is the module-level namespace dict of its defining module (Lib/abc.py); the type of that namespace is dict, so __class__.__name__ is 'dict'; NEW in extra57: first __globals__.__class__.__name__.__eq__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [abstractmethod_globals_contains, abstractmethod.__globals__.__contains__,               ["abstractmethod"], true, "abstractmethod.__globals__.__contains__('abstractmethod') returns True — 'abstractmethod' is a key in abstractmethod's module globals (Lib/abc.py) since abstractmethod is defined at module level in that file; dict.__contains__ checks key membership; NEW in extra57: first __globals__.__contains__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta.__doc__ content check — extra57
#
# Wave 228 theme: __doc__.__contains__ content checks.
#
# ABCMeta.__doc__ == 'Metaclass for defining Abstract Base Classes (ABCs).\n...'
# NOTE: This docstring does NOT contain 'ABCMeta'. It does contain 'Abstract'.
# The task requested checking for 'ABCMeta' — but that substring is absent.
# This spec uses 'Abstract' as the verified-True content check.
# ---------------------------------------------------------------------------

table abc_extra57.abcmeta_doc_contains:
  description: "abc ABCMeta.__doc__.__contains__ content check in abcann57 namespace — wave 228 theme: __doc__.__contains__ content checks; ABCMeta.__doc__ starts 'Metaclass for defining Abstract Base Classes (ABCs).' and contains 'Abstract' throughout; NOTE: ABCMeta.__doc__ does NOT contain 'ABCMeta' (verified — the docstring uses the abbreviation 'ABC', not the full class name); 'Abstract' is the correct content check that returns True; NEW in extra57: no prior abc spec has used __contains__ to test ABCMeta.__doc__ content; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: abcann57d

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_doc_contains_abstract, ABCMeta.__doc__.__contains__, ["Abstract"], true, "ABCMeta.__doc__.__contains__('Abstract') returns True — abc.ABCMeta.__doc__ is 'Metaclass for defining Abstract Base Classes (ABCs).' followed by additional text about registering virtual subclasses; the word 'Abstract' appears in the docstring; NOTE: 'ABCMeta' does NOT appear in this docstring (verified with Python 3.14.3); 'Abstract' is the correct content check substring; str.__contains__ returns True when the substring is present; NEW in extra57: first __doc__.__contains__ content check for ABCMeta in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc get_cache_token __class__.__name__ identity — extra57
#
# Wave 228 theme: class identity checks.
#
# get_cache_token is a builtin_function_or_method defined in Modules/_abc.c.
# It has NO __annotations__ attribute (accessing it raises AttributeError).
# This spec verifies get_cache_token.__class__.__name__ to document the type
# distinction from pure-Python abstractmethod (which is a 'function').
#
# NOTE: The task description requested __annotations__ checks for get_cache_token
# but this is inapplicable — get_cache_token is a C builtin with no __annotations__.
# ---------------------------------------------------------------------------

table abc_extra57.get_cache_token_class_name:
  description: "abc get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') check in abcann57 namespace — wave 228 theme: class identity; get_cache_token is a C builtin (builtin_function_or_method) defined in Modules/_abc.c; it has NO __annotations__ attribute (accessing raises AttributeError); this check documents the type distinction from pure-Python abstractmethod (which is a 'function'); NOTE: the task description requested __annotations__ checks for get_cache_token but those are inapplicable to C builtins; __class__.__name__ is verified instead; NEW in extra57: first __class__.__name__.__eq__('builtin_function_or_method') check for get_cache_token via __eq__ in this wave (extra40 captured __class__.__name__=='function' for abstractmethod; get_cache_token as builtin documented here); verified with Python 3.14.3"
  kind: python_call_eq
  category: type
  id_prefix: abcann57gct

  columns: [id, function, args, expected, description]
  rows:
    - [gct_class_name, get_cache_token.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "get_cache_token.__class__.__name__ == 'builtin_function_or_method' — get_cache_token is a C builtin defined in Modules/_abc.c; its __class__.__name__ is 'builtin_function_or_method'; it has NO __annotations__ attribute (accessing raises AttributeError); contrast with abstractmethod which is a pure-Python 'function'; NEW in extra57: first __class__.__name__.__eq__('builtin_function_or_method') check for get_cache_token via __eq__ in wave 228; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra57
# ---------------------------------------------------------------------------

invariant abc_extra57.abstractmethod_annotations_class_name_eq:
  description: "abc.abstractmethod.__annotations__.__class__.__name__.__eq__('dict') returns True — abstractmethod is a pure-Python function defined in Lib/abc.py; its __annotations__ attribute is an empty dict ({}); the __class__.__name__ of that dict is 'dict'; prior specs captured the empty annotations content but NOT the __class__.__name__ via __eq__; NEW in extra57: wave 228 first __annotations__ class identity invariant for abstractmethod in any abc spec; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: abstractmethod.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra57.abstractmethod_globals_class_name_eq:
  description: "abc.abstractmethod.__globals__.__class__.__name__.__eq__('dict') returns True — abstractmethod.__globals__ is the module-level namespace dict of Lib/abc.py; the type of any module namespace is dict, so __class__.__name__ is 'dict'; NEW in extra57: no prior abc spec has checked abstractmethod.__globals__.__class__.__name__ via __eq__; wave 228 first __globals__ class identity invariant for abstractmethod in any abc spec; verified with Python 3.14.3"
  category: globals
  kind: python_call_eq
  function: abstractmethod.__globals__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra57.abstractmethod_globals_contains_abstractmethod:
  description: "abc.abstractmethod.__globals__.__contains__('abstractmethod') returns True — 'abstractmethod' is a key in the module-level namespace dict of Lib/abc.py where abstractmethod is defined at module level; dict.__contains__ checks for key membership; NEW in extra57: no prior abc spec has used __contains__ on abstractmethod.__globals__; wave 228 first __globals__.__contains__ invariant for abstractmethod; verified with Python 3.14.3"
  category: globals
  kind: python_call_eq
  function: abstractmethod.__globals__.__contains__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra57.abcmeta_doc_contains_abstract:
  description: "abc.ABCMeta.__doc__.__contains__('Abstract') returns True — ABCMeta.__doc__ is 'Metaclass for defining Abstract Base Classes (ABCs).' followed by additional detail; the word 'Abstract' appears in the docstring; str.__contains__ returns True; NOTE: 'ABCMeta' does NOT appear in this docstring (verified); 'Abstract' is the correct content check; NEW in extra57: no prior abc spec has used __contains__ on ABCMeta.__doc__; wave 228 first __doc__.__contains__ content invariant for ABCMeta; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: ABCMeta.__doc__.__contains__
  args: ["Abstract"]
  expected: true

invariant abc_extra57.get_cache_token_class_name_eq:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — get_cache_token is a C builtin defined in Modules/_abc.c; its type is builtin_function_or_method; it has NO __annotations__ attribute (accessing raises AttributeError); contrast with pure-Python abstractmethod whose __class__.__name__ is 'function'; NEW in extra57: wave 228 class identity invariant for get_cache_token documenting its C builtin nature; verified with Python 3.14.3"
  category: type
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
