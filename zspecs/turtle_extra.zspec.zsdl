spec: turtle_extra
version: ">=3.9"
backend: python_module(turtle)

docs: https://docs.python.org/3/library/turtle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/turtle.html — Python turtle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/turtle.py"
  notes:
    - "Extends turtle.zspec.zsdl with class name, module, and function name invariants."
    - "turtle.Turtle.__name__ == 'Turtle' and __module__ == 'turtle'."
    - "turtle.Screen is a singleton class that manages the drawing canvas; its __name__ == 'Screen'."
    - "turtle.Pen is an alias for turtle.Turtle; Pen.__name__ == 'Pen'."
    - "Module-level functions forward, backward, bgcolor, and done delegate to a default Turtle instance."
    - "Function __name__ attributes are inspectable without a display or Tk instance."
    - "turtle.bgcolor.__name__ == 'bgcolor' — sets or returns the background color of the drawing canvas."
    - "turtle.done.__name__ == 'done' — starts the Tk event loop; alias for mainloop()."
    - "All expected values verified with Python 3.12 turtle on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Turtle — class name and module
# ---------------------------------------------------------------------------

invariant turtle_extra.Turtle.name:
  description: "turtle.Turtle.__name__ == 'Turtle'"
  category: class_names
  kind: python_call_eq
  function: Turtle.__name__.__eq__
  args: ["Turtle"]
  expected: true

invariant turtle_extra.Turtle.module:
  description: "turtle.Turtle.__module__ == 'turtle'"
  category: class_modules
  kind: python_call_eq
  function: Turtle.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# Screen — singleton canvas class name
# ---------------------------------------------------------------------------

invariant turtle_extra.Screen.name:
  description: "turtle.Screen.__name__ == 'Screen'"
  category: class_names
  kind: python_call_eq
  function: Screen.__name__.__eq__
  args: ["Screen"]
  expected: true

invariant turtle_extra.Screen.module:
  description: "turtle.Screen.__module__ == 'turtle'"
  category: class_modules
  kind: python_call_eq
  function: Screen.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# Pen — alias for Turtle
# ---------------------------------------------------------------------------

invariant turtle_extra.Pen.name:
  description: "turtle.Pen.__name__ == 'Pen'"
  category: class_names
  kind: python_call_eq
  function: Pen.__name__.__eq__
  args: ["Pen"]
  expected: true

invariant turtle_extra.Pen.module:
  description: "turtle.Pen.__module__ == 'turtle'"
  category: class_modules
  kind: python_call_eq
  function: Pen.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __name__ checks
# ---------------------------------------------------------------------------

invariant turtle_extra.forward.name:
  description: "turtle.forward.__name__ == 'forward'"
  category: functions
  kind: python_call_eq
  function: forward.__name__.__eq__
  args: ["forward"]
  expected: true

invariant turtle_extra.backward.name:
  description: "turtle.backward.__name__ == 'backward'"
  category: functions
  kind: python_call_eq
  function: backward.__name__.__eq__
  args: ["backward"]
  expected: true

invariant turtle_extra.bgcolor.name:
  description: "turtle.bgcolor.__name__ == 'bgcolor'"
  category: functions
  kind: python_call_eq
  function: bgcolor.__name__.__eq__
  args: ["bgcolor"]
  expected: true

invariant turtle_extra.done.name:
  description: "turtle.done.__name__ == 'done'"
  category: functions
  kind: python_call_eq
  function: done.__name__.__eq__
  args: ["done"]
  expected: true

# ---------------------------------------------------------------------------
# Function type checks — module-level names are callable (function objects)
# ---------------------------------------------------------------------------

table turtle_extra.function_type_checks:
  kind: python_call_eq
  category: types
  id_prefix: ftype

  columns: [id, function, args, expected]
  rows:
    - [forward_is_function,  forward.__class__.__name__.__eq__,  ["function"],  true]
    - [backward_is_function, backward.__class__.__name__.__eq__, ["function"],  true]
    - [bgcolor_is_function,  bgcolor.__class__.__name__.__eq__,  ["function"],  true]
    - [done_is_function,     done.__class__.__name__.__eq__,     ["function"],  true]
