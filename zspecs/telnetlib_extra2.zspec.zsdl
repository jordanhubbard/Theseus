spec: telnetlib_extra2
version: ">=3.9,<3.13"
backend: python_module(telnetlib)

docs: https://docs.python.org/3.12/library/telnetlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/telnetlib.html — Python telnetlib module documentation"
    - "RFC 854 — TELNET PROTOCOL SPECIFICATION"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/telnetlib.py internal socket handling"
  notes:
    - "This spec extends telnetlib.zspec.zsdl and telnetlib_extra.zspec.zsdl."
    - "telnetlib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "telnetlib.zspec.zsdl covers: Telnet.__name__, Telnet.__module__, TELNET_PORT==23, IAC/DO/DONT/WILL/WONT/SB/SE values, method names."
    - "telnetlib_extra.zspec.zsdl covers: Telnet.__name__, Telnet.__module__, DEBUGLEVEL type/value, method names."
    - "This spec adds: Telnet.__bases__[0].__name__=='object', Telnet.__qualname__, TELNET_PORT type check, type checks for IAC/WILL/WONT/DO/DONT as 'bytes'."
    - "telnetlib byte constants (IAC, WILL, WONT, DO, DONT) are bytes objects of length 1."
    - "Telnet inherits directly from object (it has no intermediate base class)."
    - "TELNET_PORT is a plain int module-level constant; its type was not verified in prior specs."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Telnet.__bases__[0].__name__ == 'object'
# Not covered in telnetlib.zspec.zsdl or telnetlib_extra.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant telnetlib_extra2.Telnet.base_is_object:
  description: "telnetlib.Telnet.__bases__[0].__name__ == 'object' — Telnet has no intermediate base"
  category: hierarchy
  kind: python_call_eq
  function: Telnet.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Telnet.__qualname__ — not covered in any prior telnetlib spec
# ---------------------------------------------------------------------------

invariant telnetlib_extra2.Telnet.qualname:
  description: "telnetlib.Telnet.__qualname__ == 'Telnet'"
  category: class_attributes
  kind: python_call_eq
  function: Telnet.__qualname__.__eq__
  args: ["Telnet"]
  expected: true

# ---------------------------------------------------------------------------
# TELNET_PORT type check — value==23 is in telnetlib.zspec.zsdl; type is new
# ---------------------------------------------------------------------------

invariant telnetlib_extra2.TELNET_PORT.type_is_int:
  description: "telnetlib.TELNET_PORT.__class__.__name__ == 'int' — TELNET_PORT is a plain integer"
  category: constants
  kind: python_call_eq
  function: TELNET_PORT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# DEBUGLEVEL type and value — already in telnetlib_extra; not repeated here.
#
# IAC, WILL, WONT, DO, DONT — type checks (class is 'bytes')
# telnetlib.zspec.zsdl checks the integer values via __eq__; type is new.
# ---------------------------------------------------------------------------

table telnetlib_extra2.protocol_byte_types:
  kind: python_call_eq
  category: constants
  id_prefix: byteclass

  columns: [id, function, args, expected]
  rows:
    - [IAC,  IAC.__class__.__name__.__eq__,  ["bytes"], true]
    - [WILL, WILL.__class__.__name__.__eq__, ["bytes"], true]
    - [WONT, WONT.__class__.__name__.__eq__, ["bytes"], true]
    - [DO,   DO.__class__.__name__.__eq__,   ["bytes"], true]
    - [DONT, DONT.__class__.__name__.__eq__, ["bytes"], true]
