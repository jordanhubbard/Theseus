# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra248.BufferedReader.name_eq:
  description: "io.BufferedReader.__name__ == 'BufferedReader' — the class name string; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra248.BufferedReader.module_is_underscore_io:
  description: "io.BufferedReader.__module__ == '_io' — BufferedReader is a C extension type defined in _io, not the pure Python ABC; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra248.BufferedReader.module_not_io:
  description: "io.BufferedReader.__module__ != 'io' — unlike the IOBase ABC, BufferedReader is defined in _io (C extension), not 'io'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["io"]
  expected: false

invariant io_extra248.BufferedReader.base_name_eq:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — BufferedReader directly extends the C type _BufferedIOBase; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "BufferedReader.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra248.BufferedReader.class_is_type:
  description: "io.BufferedReader.__class__.__name__ == 'type' — BufferedReader is a C extension type with plain metaclass type, not ABCMeta; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra248.BufferedReader.name_len:
  description: "len(io.BufferedReader.__name__) == 14 — 'BufferedReader' has 14 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__name__.__len__
  args: []
  expected: 14

