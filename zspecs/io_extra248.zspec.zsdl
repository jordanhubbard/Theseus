spec: io_extra248
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bufferedio.c"
    - "CPython source: Lib/io.py"
    - "io_extra247.zspec.zsdl — covers io.IOBase and io.RawIOBase class identity"
    - "_io_extra.zspec.zsdl — covers _io-backend types"
  notes:
    - "This spec covers: io.BufferedReader and io.BufferedWriter class identity — __name__, __module__, __bases__[0].__name__."
    - "io.BufferedReader.__module__ == '_io' — BufferedReader is a C extension type, not an ABC wrapper; verified Python 3.14.3 macOS."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — BufferedReader directly extends the C type _BufferedIOBase; verified Python 3.14.3 macOS."
    - "io.BufferedReader.__class__.__name__ == 'type' — BufferedReader is a plain C type, not an ABC; metaclass is type, not ABCMeta; verified Python 3.14.3 macOS."
    - "io.BufferedWriter.__module__ == '_io' — BufferedWriter is also a C extension type; verified Python 3.14.3 macOS."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter also extends _BufferedIOBase; verified Python 3.14.3 macOS."
    - "io.BufferedWriter.__class__.__name__ == 'type' — BufferedWriter metaclass is type, not ABCMeta; verified Python 3.14.3 macOS."
    - "BufferedReader.__name__ == 'BufferedReader' — length 14; verified Python 3.14.3 macOS."
    - "BufferedReader.__module__ == '_io' — length 3; verified Python 3.14.3 macOS."
    - "BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — length 15; verified Python 3.14.3 macOS."
    - "BufferedWriter.__name__ == 'BufferedWriter' — length 14; verified Python 3.14.3 macOS."
    - "BufferedWriter.__module__ == '_io' — length 3; verified Python 3.14.3 macOS."
    - "BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — length 15; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader class identity — __name__, __module__, __qualname__
# BufferedReader is a C extension type in _io; __module__ == '_io', not 'io'.
# Its metaclass is plain type (not ABCMeta).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra248.BufferedReader_name_module_qualname:
  description: "io.BufferedReader class identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobuffr248

  columns: [id, function, args, expected]
  rows:
    - [buffr_name_eq,      BufferedReader.__name__.__eq__,      ["BufferedReader"], true]
    - [buffr_name_not_bw,  BufferedReader.__name__.__eq__,      ["BufferedWriter"], false]
    - [buffr_module_eq,    BufferedReader.__module__.__eq__,    ["_io"],            true]
    - [buffr_module_not,   BufferedReader.__module__.__eq__,    ["io"],             false]
    - [buffr_qualname_eq,  BufferedReader.__qualname__.__eq__,  ["BufferedReader"], true]

# ---------------------------------------------------------------------------
# io.BufferedReader __name__, __module__, __bases__[0].__name__ string lengths
# __name__='BufferedReader' len=14, __module__='_io' len=3,
# __bases__[0].__name__='_BufferedIOBase' len=15.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra248.BufferedReader_name_module_lengths:
  description: "io.BufferedReader string lengths: __name__=14, __module__=3, __bases__[0].__name__=15; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobuffr248

  columns: [id, function, args, expected]
  rows:
    - [buffr_name_len,     BufferedReader.__name__.__len__,     [], 14]
    - [buffr_module_len,   BufferedReader.__module__.__len__,   [], 3]
    - [buffr_qualname_len, BufferedReader.__qualname__.__len__, [], 14]

