spec: functools_extra255
version: ">=3.4"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.reduce, functools.total_ordering, and functools.cmp_to_key function identity behavioral contracts."
    - "functools.reduce.__name__ == 'reduce' — reduce is a built-in function implemented in C (_functools); its __name__ is 'reduce'. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce is implemented in the C extension _functools; __module__ reflects the C-level module. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C-level built-in; its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.total_ordering.__name__ == 'total_ordering' — total_ordering is a pure-Python decorator function; its __name__ is 'total_ordering'. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' — total_ordering is defined in the functools module; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function; its __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__ == 'Class decorator that fills in missing ordering methods' — full docstring. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' — cmp_to_key is a C-level built-in; its __name__ is 'cmp_to_key'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in the C extension _functools. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C-level built-in. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce function identity
#
# functools.reduce.__name__ == 'reduce'
# functools.reduce.__module__ == '_functools'
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
#
# functools.reduce is a C-level built-in exposed through functools. Its
# __module__ is '_functools' (the underlying C extension), not 'functools'.
# New to extra255.
# ---------------------------------------------------------------------------

table functools_extra255.reduce_identity:
  description: "functools.reduce __name__, __module__, __class__.__name__ identity contracts; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: reduce255

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — reduce is the C-level reduce built-in; its __name__ is 'reduce'; str.__eq__('reduce') returns True; new to extra255"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in the _functools C extension; __module__ is '_functools'; str.__eq__('_functools') returns True; new to extra255"]
    - [reduce_class_name_eq,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C-level built-in; __class__.__name__ is 'builtin_function_or_method'; new to extra255"]
    - [reduce_name_len_6,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters; new to extra255"]
    - [reduce_module_len_10,
       reduce.__module__.__len__,
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — '_functools' has 10 characters; new to extra255"]

# ---------------------------------------------------------------------------
# Table 2: functools.total_ordering function identity
#
# functools.total_ordering.__name__ == 'total_ordering'
# functools.total_ordering.__module__ == 'functools'
# functools.total_ordering.__class__.__name__ == 'function'
# functools.total_ordering.__doc__ == 'Class decorator that fills in missing ordering methods'
#
# total_ordering is a pure-Python class decorator defined in functools.
# New to extra255.
# ---------------------------------------------------------------------------

table functools_extra255.total_ordering_identity:
  description: "functools.total_ordering __name__, __module__, __class__.__name__, __doc__ identity contracts; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: totalord255

  columns: [id, function, args, expected, description]
  rows:
    - [totalord_name_eq,
       total_ordering.__name__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — total_ordering is a pure-Python class decorator; __name__ is 'total_ordering'; new to extra255"]
    - [totalord_module_eq,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in the functools module; __module__ is 'functools'; new to extra255"]
    - [totalord_class_name_eq,
       total_ordering.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a plain Python function; __class__.__name__ is 'function'; new to extra255"]
    - [totalord_doc_contains_ordering,
       total_ordering.__doc__.__contains__,
       ["ordering"],
       true,
       "functools.total_ordering.__doc__.__contains__('ordering') == True — the docstring says 'fills in missing ordering methods'; contains 'ordering'; new to extra255"]
    - [totalord_doc_len_54,
       total_ordering.__doc__.__len__,
       [],
       54,
       "functools.total_ordering.__doc__.__len__() == 54 — 'Class decorator that fills in missing ordering methods' has 54 characters; new to extra255"]

# ---------------------------------------------------------------------------
# Table 3: functools.cmp_to_key function identity
#
# functools.cmp_to_key.__name__ == 'cmp_to_key'
# functools.cmp_to_key.__module__ == '_functools'
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
#
# cmp_to_key is a C-level built-in exposed through functools, like reduce.
# New to extra255.
# ---------------------------------------------------------------------------

table functools_extra255.cmp_to_key_identity:
  description: "functools.cmp_to_key __name__, __module__, __class__.__name__ identity contracts; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: cmpkey255

  columns: [id, function, args, expected, description]
  rows:
    - [cmpkey_name_eq,
       cmp_to_key.__name__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__name__.__eq__('cmp_to_key') == True — cmp_to_key is the C-level key-from-comparator built-in; __name__ is 'cmp_to_key'; new to extra255"]
    - [cmpkey_module_eq,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in the _functools C extension; __module__ is '_functools'; new to extra255"]
    - [cmpkey_class_name_eq,
       cmp_to_key.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is a C-level built-in; __class__.__name__ is 'builtin_function_or_method'; new to extra255"]
    - [cmpkey_name_len_10,
       cmp_to_key.__name__.__len__,
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' has 10 characters; new to extra255"]
    - [cmpkey_module_len_10,
       cmp_to_key.__module__.__len__,
       [],
       10,
       "functools.cmp_to_key.__module__.__len__() == 10 — '_functools' has 10 characters; new to extra255"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra255
# ---------------------------------------------------------------------------

invariant functools_extra255.reduce.name_eq:
  description: "functools.reduce.__name__ == 'reduce' — reduce is the C-level reduce built-in; new to extra255"
  category: identity
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra255.reduce.module_eq:
  description: "functools.reduce.__module__ == '_functools' — reduce is in the _functools C extension; new to extra255"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra255.reduce.class_is_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C-level built-in; new to extra255"
  category: identity
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra255.reduce.name_len_6:
  description: "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters; new to extra255"
  category: identity
  kind: python_call_eq
  function: reduce.__name__.__len__
  args: []
  expected: 6

invariant functools_extra255.total_ordering.name_eq:
  description: "functools.total_ordering.__name__ == 'total_ordering' — pure-Python class decorator; new to extra255"
  category: identity
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra255.total_ordering.module_eq:
  description: "functools.total_ordering.__module__ == 'functools' — defined in the functools module; new to extra255"
  category: identity
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra255.total_ordering.class_is_function:
  description: "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function; new to extra255"
  category: identity
  kind: python_call_eq
  function: total_ordering.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra255.total_ordering.doc_contains_ordering:
  description: "functools.total_ordering.__doc__.__contains__('ordering') == True — docstring describes filling in ordering methods; new to extra255"
  category: doc_checks
  kind: python_call_eq
  function: total_ordering.__doc__.__contains__
  args: ["ordering"]
  expected: true

invariant functools_extra255.total_ordering.doc_len_54:
  description: "functools.total_ordering.__doc__.__len__() == 54 — docstring has 54 characters on Python 3.14.3; new to extra255"
  category: doc_checks
  kind: python_call_eq
  function: total_ordering.__doc__.__len__
  args: []
  expected: 54

invariant functools_extra255.cmp_to_key.name_eq:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key' — C-level key-from-comparator built-in; new to extra255"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__name__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra255.cmp_to_key.module_eq:
  description: "functools.cmp_to_key.__module__ == '_functools' — implemented in the _functools C extension; new to extra255"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra255.cmp_to_key.class_is_builtin:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C-level built-in; new to extra255"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra255.cmp_to_key.name_len_10:
  description: "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' has 10 characters; new to extra255"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__name__.__len__
  args: []
  expected: 10
