spec: pathlib_extra503
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib class hierarchy and attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers pathlib class __qualname__ and selected __bases__ name checks"
    - "Path __bases__ check omitted as it is platform-dependent (PosixPath vs WindowsPath)"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra503.class_qualnames:
  description: "pathlib class __qualname__ identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: plqn

  columns: [id, function, args, expected]
  rows:
    - [plqn001, pathlib.Path.__qualname__.__eq__, ["Path"], true]
    - [plqn002, pathlib.PurePath.__qualname__.__eq__, ["PurePath"], true]
    - [plqn003, pathlib.PurePosixPath.__qualname__.__eq__, ["PurePosixPath"], true]
    - [plqn004, pathlib.PureWindowsPath.__qualname__.__eq__, ["PureWindowsPath"], true]
    - [plqn005, pathlib.PosixPath.__qualname__.__eq__, ["PosixPath"], true]
    - [plqn006, pathlib.WindowsPath.__qualname__.__eq__, ["WindowsPath"], true]

table pathlib_extra503.base_class_names:
  description: "pathlib class __bases__ first element __name__ checks"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: plbc

  columns: [id, function, args, expected]
  rows:
    - [plbc001, "pathlib.PurePath.__bases__[0].__name__.__eq__", ["object"], true]
    - [plbc002, "pathlib.PurePosixPath.__bases__[0].__name__.__eq__", ["PurePath"], true]
    - [plbc003, "pathlib.PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"], true]
