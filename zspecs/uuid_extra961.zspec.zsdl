spec: uuid_extra961
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.UUID and uuid.SafeUUID class dict, bases, slots, and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra961.class_dict_types:
  description: "uuid class __dict__ type identity"
  kind: python_call_eq
  category: class_dict_types
  id_prefix: uu961dt
  columns: [id, function, args, expected]
  rows:
    - [uu961dt001, uuid.UUID.__dict__.__class__.__name__.__eq__,     ["mappingproxy"], true]
    - [uu961dt002, uuid.SafeUUID.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [uu961dt003, uuid.UUID.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [uu961dt004, uuid.SafeUUID.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [uu961dt005, uuid.UUID.__dict__.__class__.__module__.__eq__, ["builtins"], true]

table uuid_extra961.class_bases_types:
  description: "uuid class __bases__ type identity"
  kind: python_call_eq
  category: class_bases_types
  id_prefix: uu961bt
  columns: [id, function, args, expected]
  rows:
    - [uu961bt001, uuid.UUID.__bases__.__class__.__name__.__eq__,     ["tuple"], true]
    - [uu961bt002, uuid.SafeUUID.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [uu961bt003, uuid.UUID.__bases__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [uu961bt004, uuid.SafeUUID.__bases__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [uu961bt005, uuid.UUID.__class__.__name__.__eq__, ["type"], true]
    - [uu961bt006, uuid.SafeUUID.__class__.__name__.__eq__, ["EnumType"], true]

table uuid_extra961.module_and_slots_identity:
  description: "uuid module identity and UUID __slots__ type"
  kind: python_call_eq
  category: module_and_slots_identity
  id_prefix: uu961ms
  columns: [id, function, args, expected]
  rows:
    - [uu961ms001, uuid.__name__.__eq__,                        ["uuid"],  true]
    - [uu961ms002, uuid.__spec__.name.__eq__,                   ["uuid"],  true]
    - [uu961ms003, uuid.UUID.__slots__.__class__.__name__.__eq__, ["tuple"], true]
    - [uu961ms004, uuid.__name__.__class__.__name__.__eq__,     ["str"],   true]
    - [uu961ms005, uuid.__spec__.name.__class__.__name__.__eq__, ["str"],   true]
    - [uu961ms006, uuid.__spec__.__class__.__name__.__eq__,     ["ModuleSpec"], true]
