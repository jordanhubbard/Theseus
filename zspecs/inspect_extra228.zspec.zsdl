spec: inspect_extra228
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect behavioral output contracts: isbuiltin/isroutine/isclass/isfunction predicate results for builtins (len), classes (int, str), and lambda functions."
    - "inspect.isbuiltin(len) == True — len is a built-in function implemented in C; isbuiltin returns True. Verified with Python 3.14.3."
    - "inspect.isroutine(len) == True — len is callable as a routine (builtin); isroutine returns True. Verified with Python 3.14.3."
    - "inspect.isclass(int) == True — int is a type/class; isclass returns True. Verified with Python 3.14.3."
    - "inspect.isclass(len) == False — len is a builtin function, not a class; isclass returns False. Verified with Python 3.14.3."
    - "inspect.isfunction(lambda x: x) == True — lambda creates a FunctionType object; isfunction returns True. Verified with Python 3.14.3."
    - "inspect.isbuiltin(lambda x: x) == False — lambda creates a Python FunctionType, not a BuiltinFunctionType; isbuiltin returns False. Verified with Python 3.14.3."
    - "inspect.isroutine(lambda x: x) == True — lambda is a callable routine (FunctionType); isroutine returns True. Verified with Python 3.14.3."
    - "inspect.isclass(str) == True — str is a built-in type/class; isclass returns True. Verified with Python 3.14.3."
    - "inspect.ismodule(inspect) == True — the inspect module is a module object; ismodule returns True. Verified with Python 3.14.3."
    - "inspect.getmembers([]) returns a list — getmembers always returns a list of (name, value) pairs. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect is* predicates return True for builtins
#
# inspect.isbuiltin(len) == True
# inspect.isroutine(len) == True
# inspect.isclass(int) == True
# inspect.isclass(str) == True
# inspect.isclass(list) == True
#
# Built-in functions are BuiltinFunctionType; classes are type instances.
# New to extra228.
# ---------------------------------------------------------------------------

table inspect_extra228.is_predicates_true_builtins:
  description: "inspect isbuiltin/isroutine/isclass return True for len, int, str, list; new to extra228"
  kind: python_call_eq
  category: behavioral
  id_prefix: inspectextra228istruebuiltin

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_len_true,
       isbuiltin,
       ["__builtins__.len"],
       true,
       "inspect.isbuiltin(len) == True — len is a C builtin function (BuiltinFunctionType); isbuiltin checks isinstance(object, types.BuiltinFunctionType); len qualifies; isbuiltin(len) returns True; new to extra228"]
    - [isroutine_len_true,
       isroutine,
       ["__builtins__.len"],
       true,
       "inspect.isroutine(len) == True — len is a builtin callable routine; isroutine returns True for builtins, functions, methods, and lambdas; isroutine(len) returns True; new to extra228"]
    - [isclass_int_true,
       isclass,
       ["__builtins__.int"],
       true,
       "inspect.isclass(int) == True — int is a built-in type; isclass checks isinstance(object, type); int is an instance of type; isclass(int) returns True; new to extra228"]
    - [isclass_str_true,
       isclass,
       ["__builtins__.str"],
       true,
       "inspect.isclass(str) == True — str is a built-in type; isinstance(str, type) is True; isclass(str) returns True; new to extra228"]
    - [isclass_list_true,
       isclass,
       ["__builtins__.list"],
       true,
       "inspect.isclass(list) == True — list is a built-in type; isinstance(list, type) is True; isclass(list) returns True; new to extra228"]

# ---------------------------------------------------------------------------
# Table 2: inspect is* predicates return False for builtins in wrong category
#
# inspect.isclass(len) == False
# inspect.isfunction(len) == False
# inspect.isbuiltin(int) == False
# inspect.isfunction(int) == False
# inspect.ismodule(len) == False
#
# New to extra228.
# ---------------------------------------------------------------------------

table inspect_extra228.is_predicates_false_cross:
  description: "inspect isclass(len)/isfunction(len)/isbuiltin(int)/isfunction(int)/ismodule(len) all False; new to extra228"
  kind: python_call_eq
  category: behavioral
  id_prefix: inspectextra228isfalsecrss

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_name_len,
       isbuiltin.__name__.__len__,
       [],
       9,
       "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has exactly 9 characters (i-s-b-u-i-l-t-i-n); __len__() returns 9; new to extra228"]
    - [isroutine_name_len,
       isroutine.__name__.__len__,
       [],
       9,
       "inspect.isroutine.__name__.__len__() == 9 — 'isroutine' has exactly 9 characters (i-s-r-o-u-t-i-n-e); __len__() returns 9; new to extra228"]
    - [isclass_name_len,
       isclass.__name__.__len__,
       [],
       7,
       "inspect.isclass.__name__.__len__() == 7 — 'isclass' has exactly 7 characters (i-s-c-l-a-s-s); __len__() returns 7; new to extra228"]
    - [isfunction_name_len,
       isfunction.__name__.__len__,
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has exactly 10 characters (i-s-f-u-n-c-t-i-o-n); __len__() returns 10; new to extra228"]
    - [ismodule_name_len,
       ismodule.__name__.__len__,
       [],
       8,
       "inspect.ismodule.__name__.__len__() == 8 — 'ismodule' has exactly 8 characters (i-s-m-o-d-u-l-e); __len__() returns 8; new to extra228"]

# ---------------------------------------------------------------------------
# Table 3: inspect is* predicate qualname contracts
#
# inspect.isbuiltin.__qualname__ == 'isbuiltin'
# inspect.isroutine.__qualname__ == 'isroutine'
# inspect.isclass.__qualname__ == 'isclass'
# inspect.isfunction.__qualname__ == 'isfunction'
# inspect.ismodule.__qualname__ == 'ismodule'
#
# New to extra228.
# ---------------------------------------------------------------------------

table inspect_extra228.is_predicate_qualnames:
  description: "inspect isbuiltin/isroutine/isclass/isfunction/ismodule qualname contracts; new to extra228"
  kind: python_call_eq
  category: behavioral
  id_prefix: inspectextra228isqualname

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_qualname,
       isbuiltin.__qualname__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__qualname__ == 'isbuiltin' — isbuiltin is a top-level function with unqualified qualname; __qualname__.__eq__('isbuiltin') returns True; new to extra228"]
    - [isroutine_qualname,
       isroutine.__qualname__.__eq__,
       ["isroutine"],
       true,
       "inspect.isroutine.__qualname__ == 'isroutine' — isroutine is a top-level function with unqualified qualname; __qualname__.__eq__('isroutine') returns True; new to extra228"]
    - [isclass_qualname,
       isclass.__qualname__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__qualname__ == 'isclass' — isclass is a top-level function with unqualified qualname; __qualname__.__eq__('isclass') returns True; new to extra228"]
    - [isfunction_qualname,
       isfunction.__qualname__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__qualname__ == 'isfunction' — isfunction is a top-level function with unqualified qualname; __qualname__.__eq__('isfunction') returns True; new to extra228"]
    - [ismodule_qualname,
       ismodule.__qualname__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__qualname__ == 'ismodule' — ismodule is a top-level function with unqualified qualname; __qualname__.__eq__('ismodule') returns True; new to extra228"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra228
# ---------------------------------------------------------------------------

invariant inspect_extra228.isbuiltin_name_len_9:
  description: "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has 9 characters; new to extra228"
  kind: python_call_eq
  function: isbuiltin.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra228.isroutine_name_len_9:
  description: "inspect.isroutine.__name__.__len__() == 9 — 'isroutine' has 9 characters; new to extra228"
  kind: python_call_eq
  function: isroutine.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra228.isclass_name_len_7:
  description: "inspect.isclass.__name__.__len__() == 7 — 'isclass' has 7 characters; new to extra228"
  kind: python_call_eq
  function: isclass.__name__.__len__
  args: []
  expected: 7

invariant inspect_extra228.isfunction_name_len_10:
  description: "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters; new to extra228"
  kind: python_call_eq
  function: isfunction.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra228.ismodule_name_len_8:
  description: "inspect.ismodule.__name__.__len__() == 8 — 'ismodule' has 8 characters; new to extra228"
  kind: python_call_eq
  function: ismodule.__name__.__len__
  args: []
  expected: 8

invariant inspect_extra228.isbuiltin_qualname:
  description: "inspect.isbuiltin.__qualname__ == 'isbuiltin'; new to extra228"
  kind: python_call_eq
  function: isbuiltin.__qualname__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra228.isroutine_qualname:
  description: "inspect.isroutine.__qualname__ == 'isroutine'; new to extra228"
  kind: python_call_eq
  function: isroutine.__qualname__.__eq__
  args: ["isroutine"]
  expected: true

invariant inspect_extra228.isclass_qualname:
  description: "inspect.isclass.__qualname__ == 'isclass'; new to extra228"
  kind: python_call_eq
  function: isclass.__qualname__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra228.isfunction_qualname:
  description: "inspect.isfunction.__qualname__ == 'isfunction'; new to extra228"
  kind: python_call_eq
  function: isfunction.__qualname__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra228.ismodule_qualname:
  description: "inspect.ismodule.__qualname__ == 'ismodule'; new to extra228"
  kind: python_call_eq
  function: ismodule.__qualname__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra228.isbuiltin_module_eq:
  description: "inspect.isbuiltin.__module__ == 'inspect'; new to extra228"
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra228.isclass_module_eq:
  description: "inspect.isclass.__module__ == 'inspect'; new to extra228"
  kind: python_call_eq
  function: isclass.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra228.isroutine_module_eq:
  description: "inspect.isroutine.__module__ == 'inspect'; new to extra228"
  kind: python_call_eq
  function: isroutine.__module__.__eq__
  args: ["inspect"]
  expected: true
