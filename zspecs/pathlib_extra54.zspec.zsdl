spec: pathlib_extra54
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra53.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __class__.__name__.__eq__('type') and __class__.__name__.__len__()==4; Path.cwd/__class__.__name__.__eq__('method'); Path.home/__class__.__name__.__eq__('method')."
    - "pathlib_extra50.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__len__(); Path.cwd/__qualname__.__len__()==8; Path.home/__qualname__.__len__()==9."
    - "pathlib_extra49.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__eq__(); Path.cwd/__qualname__.__eq__('Path.cwd'); Path.home/__qualname__.__eq__('Path.home')."
    - "pathlib_extra37.zspec.zsdl — covers Path.__dict__.__class__.__name__.__len__()==13; PurePath.__dict__.__class__.__name__.__len__()==13."
  notes:
    - "This spec extends pathlib_extra53.zspec.zsdl."
    - "Prior specs collectively covered: all six pathlib class __qualname__.__eq__() and __qualname__.__len__() (pathlib_extra49/pathlib_extra50); all six class __class__.__name__.__eq__('type') and __class__.__name__.__len__()==4 (pathlib_extra53); Path.cwd and Path.home __class__.__name__.__eq__('method') (pathlib_extra53); Path.cwd and Path.home __qualname__ equality and length (pathlib_extra49/pathlib_extra50). NO prior pathlib spec checks __class__.__qualname__ for any pathlib class. NO prior pathlib spec checks __class__.__module__ for any pathlib class. NO prior pathlib spec checks Path.cwd.__class__.__qualname__ or Path.home.__class__.__qualname__."
    - "This spec covers: pathlib.Path.__class__.__qualname__.__eq__('type') (NOVEL — pathlib_extra53 anchors Path.__class__.__name__=='type' via __name__ path; no prior pathlib spec accesses __class__.__qualname__ for any pathlib class; novel __qualname__ path anchor); pathlib.PurePath.__class__.__qualname__.__eq__('type') (NOVEL); pathlib.PurePosixPath.__class__.__qualname__.__eq__('type') (NOVEL); pathlib.PureWindowsPath.__class__.__qualname__.__eq__('type') (NOVEL); pathlib.Path.cwd.__class__.__qualname__.__eq__('method') (NOVEL — pathlib_extra53 anchors Path.cwd.__class__.__name__=='method' via __name__; no prior pathlib spec checks Path.cwd.__class__.__qualname__; novel); pathlib.Path.home.__class__.__qualname__.__eq__('method') (NOVEL); pathlib.Path.__class__.__module__.__eq__('builtins') (NOVEL — the 'type' metaclass is defined in the builtins module; __class__.__module__ for a regular class's metaclass is 'builtins'; no prior pathlib spec checks __class__.__module__ for any pathlib class; novel); pathlib.PurePath.__class__.__module__.__eq__('builtins') (NOVEL)."
    - "pathlib.Path.__class__.__qualname__ == 'type'. Path is a regular Python class with the standard 'type' metaclass. For top-level builtin types, __qualname__==__name__=='type'. pathlib_extra53 anchors __class__.__name__ via the __name__ path; no prior pathlib spec accesses __class__.__qualname__. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePosixPath.__class__.__qualname__ == 'type'. Same reasoning as Path. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__class__.__qualname__ == 'type'. Same reasoning. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.cwd.__class__.__qualname__ == 'method'. When accessed as a class attribute, Path.cwd is a bound method object. Its type's __qualname__ is 'method'. pathlib_extra53 anchors Path.cwd.__class__.__name__=='method' via __name__ path; no prior pathlib spec checks Path.cwd.__class__.__qualname__. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.__class__.__module__ == 'builtins'. The 'type' metaclass is a C-level builtin type; its __module__ is 'builtins'. Since Path.__class__ is type, Path.__class__.__module__ is 'builtins'. No prior pathlib spec checks __class__.__module__ for any pathlib class. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__class__.__module__ == 'builtins'. Same reasoning as Path. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __class__.__qualname__ equality
#
# All pathlib classes are regular Python classes with the standard 'type'
# metaclass. For top-level builtin types, __qualname__==__name__:
#
#   Path.__class__.__qualname__            == 'type'
#   PurePath.__class__.__qualname__        == 'type'
#   PurePosixPath.__class__.__qualname__   == 'type'
#   PureWindowsPath.__class__.__qualname__ == 'type'
#
# pathlib_extra53 covers the corresponding __class__.__name__ equality via
# the __name__ path. No prior pathlib spec checks __class__.__qualname__
# for any pathlib class. All four anchors are novel in the pathlib_extra54
# namespace. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra54.class_metaclass_qualname_eq:
  description: "pathlib class __class__.__qualname__.__eq__('type') for Path/PurePath/PurePosixPath/PureWindowsPath — all use 'type' metaclass; for top-level builtin types __qualname__==__name__=='type'; pathlib_extra53 covers via __name__ path; no prior pathlib spec checks __class__.__qualname__ for any pathlib class; all four novel __qualname__ path anchors in pathlib_extra54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibclsqual54

  columns: [id, function, args, expected]
  rows:
    - [Path_class_qualname,            Path.__class__.__qualname__.__eq__,            ["type"], true]
    - [PurePath_class_qualname,        PurePath.__class__.__qualname__.__eq__,        ["type"], true]
    - [PurePosixPath_class_qualname,   PurePosixPath.__class__.__qualname__.__eq__,   ["type"], true]
    - [PureWindowsPath_class_qualname, PureWindowsPath.__class__.__qualname__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# pathlib.Path.cwd and Path.home __class__.__qualname__
#
# When accessed as class attributes, Path.cwd and Path.home are bound method
# objects. Their type's __qualname__ is 'method':
#
#   Path.cwd.__class__.__qualname__  == 'method'
#   Path.home.__class__.__qualname__ == 'method'
#
# pathlib_extra53 anchors these via the __class__.__name__ path (__name__).
# No prior pathlib spec checks __class__.__qualname__ for Path.cwd or
# Path.home. Both anchors are novel in the pathlib_extra54 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra54.Path_cwd_class_qualname_eq:
  description: "pathlib.Path.cwd.__class__.__qualname__ == 'method' — when accessed as a class attribute, Path.cwd is a bound method; its type's __qualname__ is 'method'; pathlib_extra53 anchors Path.cwd.__class__.__name__=='method' via __name__ path; no prior pathlib spec checks Path.cwd.__class__.__qualname__; novel __qualname__ path anchor in pathlib_extra54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Path.cwd.__class__.__qualname__.__eq__
  args: ["method"]
  expected: true

invariant pathlib_extra54.Path_home_class_qualname_eq:
  description: "pathlib.Path.home.__class__.__qualname__ == 'method' — when accessed as a class attribute, Path.home is a bound method; its type's __qualname__ is 'method'; pathlib_extra53 anchors Path.home.__class__.__name__=='method' via __name__ path; no prior pathlib spec checks Path.home.__class__.__qualname__; novel __qualname__ path anchor in pathlib_extra54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Path.home.__class__.__qualname__.__eq__
  args: ["method"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib class __class__.__module__ equality
#
# The 'type' metaclass is a C-level builtin type whose module is 'builtins'.
# Therefore for any class whose metaclass is type:
#
#   Path.__class__.__module__     == 'builtins'
#   PurePath.__class__.__module__ == 'builtins'
#
# No prior pathlib spec checks __class__.__module__ for any pathlib class.
# Both anchors are novel in the pathlib_extra54 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra54.Path_class_module_eq:
  description: "pathlib.Path.__class__.__module__ == 'builtins' — Path.__class__ is the 'type' metaclass; type is a C-level builtin whose __module__ is 'builtins'; no prior pathlib spec checks __class__.__module__ for any pathlib class; novel anchor in pathlib_extra54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Path.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant pathlib_extra54.PurePath_class_module_eq:
  description: "pathlib.PurePath.__class__.__module__ == 'builtins' — PurePath.__class__ is the 'type' metaclass; type is a C-level builtin whose __module__ is 'builtins'; no prior pathlib spec checks __class__.__module__ for any pathlib class; novel anchor in pathlib_extra54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
