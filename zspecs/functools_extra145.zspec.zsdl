spec: functools_extra145
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.reduce (C builtin), functools.partial (C type), functools.wraps (Python function), functools.lru_cache (Python function), and functools.__spec__ (ModuleSpec) — doc string class, __name__, __module__, __qualname__, co_argcount, MRO (Wave 268)."
    - "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce is a C builtin; its docstring is a plain str. Verified with Python 3.14.3."
    - "len(functools.reduce.__doc__) == 389 — the reduce docstring has 389 characters. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce lives in the C extension _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — partial is a C type; its docstring is a plain str. Verified with Python 3.14.3."
    - "len(functools.partial.__doc__) == 83 — the partial docstring has 83 characters. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial' (len 7). Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' (len 9). Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial directly inherits object. Verified with Python 3.14.3."
    - "len(functools.partial.__mro__) == 2 — MRO is [partial, object]. Verified with Python 3.14.3."
    - "functools.wraps.__doc__.__class__.__name__ == 'str' — wraps is a Python function; its docstring is a plain str. Verified with Python 3.14.3."
    - "len(functools.wraps.__doc__) == 356 — the wraps docstring has 356 characters. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' (len 5). Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_argcount == 3 (wrapped, assigned, updated). Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__class__.__name__ == 'str' — lru_cache is a Python function; its docstring is a plain str. Verified with Python 3.14.3."
    - "len(functools.lru_cache.__doc__) == 743 — the lru_cache docstring has 743 characters. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_argcount == 2 (maxsize, typed). Verified with Python 3.14.3."
    - "functools.__spec__.__class__.__name__ == 'ModuleSpec' — the import spec is a ModuleSpec from _frozen_importlib. Verified with Python 3.14.3."
    - "functools.__spec__.name == 'functools' (len 9). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce — C builtin doc string and module
#
# Wave 268 theme: functools.reduce — a C builtin_function_or_method.
#
# functools.reduce.__doc__.__class__.__name__ == 'str'
# len(functools.reduce.__doc__) == 389
# functools.reduce.__qualname__ == 'reduce' (len 6)
# functools.reduce.__module__ == '_functools' (len 10)
#
# reduce lives in _functoolsmodule.c (imported as _functools) and is
# exposed in functools as a re-export. New to extra145.
# ---------------------------------------------------------------------------

table functools_extra145.reduce_doc_and_module:
  description: "functools.reduce: C builtin, __doc__ is str len 389, __qualname__ len 6, __module__ '_functools' len 10; wave 268; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsreduce145

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_class_eq_str,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce is a C builtin; its docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra145"]
    - [reduce_doc_len_eq_389,
       "reduce.__doc__.__len__",
       [],
       389,
       "functools.reduce.__doc__.__len__() == 389 — the reduce docstring has 389 characters; len(__doc__) == 389; verified with Python 3.14.3; new to extra145"]
    - [reduce_qualname_eq,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — the C builtin's __qualname__ is 'reduce'; str.__eq__('reduce') returns True; new to extra145"]
    - [reduce_qualname_len_eq_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — __qualname__ is 'reduce' which has 6 characters; len('reduce') == 6; new to extra145"]
    - [reduce_module_eq__functools,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is defined in _functoolsmodule.c; its __module__ is '_functools' (the C extension); str.__eq__('_functools') returns True; new to extra145"]
    - [reduce_module_len_eq_10,
       "reduce.__module__.__len__",
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — __module__ is '_functools' which has 10 characters; len('_functools') == 10; new to extra145"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial — C type doc string, name, module, MRO
#
# Wave 268 theme: functools.partial — C extension type.
#
# functools.partial.__doc__.__class__.__name__ == 'str'
# len(functools.partial.__doc__) == 83
# functools.partial.__name__ == 'partial' (len 7)
# functools.partial.__module__ == 'functools' (len 9)
# functools.partial.__bases__[0].__name__ == 'object'
# len(functools.partial.__mro__) == 2
#
# partial is a C extension type but its __module__ is set to 'functools'
# (not '_functools') by the extension. New to extra145.
# ---------------------------------------------------------------------------

table functools_extra145.partial_class_identity:
  description: "functools.partial: C type, __doc__ str len 83, __name__ len 7, __module__ 'functools' len 9, MRO len 2; wave 268; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartial145

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_class_eq_str,
       "partial.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial is a C type; its docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra145"]
    - [partial_doc_len_eq_83,
       "partial.__doc__.__len__",
       [],
       83,
       "functools.partial.__doc__.__len__() == 83 — the partial docstring has 83 characters; len(__doc__) == 83; verified with Python 3.14.3; new to extra145"]
    - [partial_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — the C type's __name__ is 'partial'; str.__eq__('partial') returns True; new to extra145"]
    - [partial_name_len_eq_7,
       "partial.__name__.__len__",
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — __name__ is 'partial' which has 7 characters; len('partial') == 7; new to extra145"]
    - [partial_module_eq_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial.__module__ is 'functools' (the C extension sets this); str.__eq__('functools') returns True; new to extra145"]
    - [partial_module_len_eq_9,
       "partial.__module__.__len__",
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — __module__ is 'functools' which has 9 characters; len('functools') == 9; new to extra145"]
    - [partial_bases_0_eq_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial directly inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra145"]
    - [partial_mro_len_eq_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial's MRO is [partial, object]; len(__mro__) is 2; new to extra145"]

