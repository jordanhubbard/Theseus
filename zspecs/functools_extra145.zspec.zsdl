       ["_frozen_importlib"],
       true,
       "functools.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec is defined in _frozen_importlib; __class__.__module__ is '_frozen_importlib'; str.__eq__('_frozen_importlib') returns True; new to extra145"]
    - [spec_class_module_len_eq_17,
       "__spec__.__class__.__module__.__len__",
       [],
       17,
