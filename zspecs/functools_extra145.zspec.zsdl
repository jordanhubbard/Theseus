    - [spec_name_eq_functools,
       "__spec__.name.__eq__",
       ["functools"],
       true,
       "functools.__spec__.name.__eq__('functools') == True — the ModuleSpec .name attribute is 'functools'; str.__eq__('functools') returns True; new to extra145"]
    - [spec_name_len_eq_9,
       "__spec__.name.__len__",
       [],
       9,
       "functools.__spec__.name.__len__() == 9 — .name is 'functools' which has 9 characters; len('functools') == 9; new to extra145"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra145
# ---------------------------------------------------------------------------

invariant functools_extra145.reduce_doc_is_str:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — the reduce docstring is a plain Python str; wave 268; new to extra145"
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra145.reduce_doc_len:
  description: "len(functools.reduce.__doc__) == 389 — the reduce docstring has 389 characters; wave 268; new to extra145"
  kind: python_call_eq
  function: reduce.__doc__.__len__
  args: []
  expected: 389

invariant functools_extra145.reduce_module_is__functools:
  description: "functools.reduce.__module__ == '_functools' — reduce is defined in the _functools C extension; wave 268; new to extra145"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra145.partial_doc_len:
  description: "len(functools.partial.__doc__) == 83 — the partial docstring has 83 characters; wave 268; new to extra145"
  kind: python_call_eq
  function: partial.__doc__.__len__
  args: []
  expected: 83

invariant functools_extra145.partial_mro_len:
  description: "len(functools.partial.__mro__) == 2 — partial's MRO is [partial, object]; wave 268; new to extra145"
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra145.wraps_doc_len:
  description: "len(functools.wraps.__doc__) == 356 — the wraps docstring has 356 characters; wave 268; new to extra145"
  kind: python_call_eq
  function: wraps.__doc__.__len__
  args: []
  expected: 356

invariant functools_extra145.wraps_co_argcount:
  description: "functools.wraps.__code__.co_argcount == 3 — wraps takes wrapped, assigned, updated; wave 268; new to extra145"
  kind: python_call_eq
  function: wraps.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant functools_extra145.lru_cache_doc_len:
  description: "len(functools.lru_cache.__doc__) == 743 — the lru_cache docstring has 743 characters; wave 268; new to extra145"
  kind: python_call_eq
  function: lru_cache.__doc__.__len__
  args: []
  expected: 743

invariant functools_extra145.spec_name_eq_functools:
  description: "functools.__spec__.name == 'functools' — the module spec name is 'functools'; wave 268; new to extra145"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["functools"]
  expected: true
