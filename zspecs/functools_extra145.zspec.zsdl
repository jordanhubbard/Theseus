    - [spec_class_eq_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the module spec is an instance of ModuleSpec from _frozen_importlib; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra145"]
