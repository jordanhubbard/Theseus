# ---------------------------------------------------------------------------
# Table 5: functools.__spec__ — ModuleSpec identity
#
# Wave 268 theme: functools.__spec__ — the module's import spec.
#
# functools.__spec__.__class__.__name__ == 'ModuleSpec' (len 10)
# functools.__spec__.__class__.__module__ == '_frozen_importlib' (len 17)
# functools.__spec__.name == 'functools' (len 9)
#
# functools is a pure Python module (Lib/functools.py), so its __spec__.origin
# is a filesystem path (not 'built-in'). New to extra145.
# ---------------------------------------------------------------------------

table functools_extra145.spec_attrs:
  description: "functools.__spec__: class ModuleSpec len 10, __class__.__module__ '_frozen_importlib' len 17, name 'functools' len 9; wave 268; new to extra145"
