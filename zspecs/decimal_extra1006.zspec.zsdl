spec: decimal_extra1006
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal.Context and decimal.Decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.Context and decimal.Decimal method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1006.context_qualnames:
  description: "decimal.Context method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: dc1006c
  columns: [id, function, args, expected]
  rows:
    - [dc1006c001, decimal.Context.clear_flags.__qualname__.__eq__,              ["Context.clear_flags"],              true]
    - [dc1006c002, decimal.Context.clear_traps.__qualname__.__eq__,              ["Context.clear_traps"],              true]
    - [dc1006c003, decimal.Context.copy.__qualname__.__eq__,                     ["Context.copy"],                     true]
    - [dc1006c004, decimal.Context.create_decimal.__qualname__.__eq__,           ["Context.create_decimal"],           true]
    - [dc1006c005, decimal.Context.create_decimal_from_float.__qualname__.__eq__, ["Context.create_decimal_from_float"], true]
    - [dc1006c006, decimal.Context.__repr__.__qualname__.__eq__,                 ["Context.__repr__"],                 true]
    - [dc1006c007, decimal.Context.__copy__.__qualname__.__eq__,                 ["Context.__copy__"],                 true]

table decimal_extra1006.decimal_qualnames:
  description: "decimal.Decimal method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: dc1006d
  columns: [id, function, args, expected]
  rows:
    - [dc1006d001, decimal.Decimal.as_tuple.__qualname__.__eq__,         ["Decimal.as_tuple"],         true]
    - [dc1006d002, decimal.Decimal.as_integer_ratio.__qualname__.__eq__, ["Decimal.as_integer_ratio"], true]
    - [dc1006d003, decimal.Decimal.sqrt.__qualname__.__eq__,             ["Decimal.sqrt"],             true]
    - [dc1006d004, decimal.Decimal.normalize.__qualname__.__eq__,        ["Decimal.normalize"],        true]
    - [dc1006d005, decimal.Decimal.__repr__.__qualname__.__eq__,         ["Decimal.__repr__"],         true]
    - [dc1006d006, decimal.Decimal.__str__.__qualname__.__eq__,          ["Decimal.__str__"],          true]
    - [dc1006d007, decimal.Decimal.__abs__.__qualname__.__eq__,          ["Decimal.__abs__"],          true]

table decimal_extra1006.decimal_numeric_qualnames:
  description: "decimal.Decimal numeric operation method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: dc1006n
  columns: [id, function, args, expected]
  rows:
    - [dc1006n001, decimal.Decimal.__add__.__qualname__.__eq__,     ["Decimal.__add__"],     true]
    - [dc1006n002, decimal.Decimal.__sub__.__qualname__.__eq__,     ["Decimal.__sub__"],     true]
    - [dc1006n003, decimal.Decimal.__mul__.__qualname__.__eq__,     ["Decimal.__mul__"],     true]
    - [dc1006n004, decimal.Decimal.__truediv__.__qualname__.__eq__, ["Decimal.__truediv__"], true]
    - [dc1006n005, decimal.Decimal.__eq__.__qualname__.__eq__,      ["Decimal.__eq__"],      true]
