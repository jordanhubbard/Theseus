spec: theseus_weakref_cr
version: ">=3.8"
backend: python_cleanroom(theseus_weakref_cr)
blocks: weakref

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/weakref.html"
  not_derived_from:
    - "CPython source: Lib/weakref.py (internal implementation)"
  notes:
    - "Clean-room weakref module. Do NOT import weakref."

error_model: python_exceptions

invariant theseus_weakref_cr.weakref2_ref:
  description: "weakref.ref(obj)() returns the object while alive"
  category: ref
  kind: python_call_eq
  function: weakref2_ref
  args: []
  expected: true

invariant theseus_weakref_cr.weakref2_dead:
  description: "weakref returns None after object is deleted"
  category: ref
  kind: python_call_eq
  function: weakref2_dead
  args: []
  expected: true

invariant theseus_weakref_cr.weakref2_proxy:
  description: "weakproxy allows attribute access while object alive"
  category: proxy
  kind: python_call_eq
  function: weakref2_proxy
  args: []
  expected: 42
