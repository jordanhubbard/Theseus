table asyncio_extra92.two_arg_functions:
  description: "asyncio two-argument top-level function co_argcount checks in asynciofnargcount92 namespace — wave 252 theme: asyncio top-level coroutine function __code__.co_argcount values; sleep.__code__.co_argcount==2 (delay and result arguments); wait_for.__code__.co_argcount==2 (aw and timeout arguments); verified with Python 3.14.3"
  kind: python_call_eq
  category: function_attrs
  id_prefix: asynciofnargcount92a

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_argcount,    sleep.__code__.co_argcount.__eq__,    [2], true, "sleep.__code__.co_argcount == 2 — takes delay and result arguments; verified with Python 3.14.3"]
    - [wait_for_argcount, wait_for.__code__.co_argcount.__eq__, [2], true, "wait_for.__code__.co_argcount == 2 — takes aw and timeout arguments; verified with Python 3.14.3"]

