# ---------------------------------------------------------------------------
# Standalone invariants — extra92
# ---------------------------------------------------------------------------

invariant asyncio_extra92.gather_argcount_zero:
  description: "asyncio.gather.__code__.co_argcount.__eq__(0) returns True — gather uses *coros_or_futures variadic positional args so co_argcount is 0; this is the only top-level asyncio function with variadic args giving co_argcount==0; NEW in extra92: first standalone co_argcount invariant for gather in asynciofnargcount92 namespace; wave 252; verified with Python 3.14.3"
  category: function_attrs
  kind: python_call_eq
  function: "gather.__code__.co_argcount.__eq__"
  args: [0]
  expected: true

invariant asyncio_extra92.sleep_argcount_two:
  description: "asyncio.sleep.__code__.co_argcount.__eq__(2) returns True — sleep takes delay and result as its two positional arguments; result has a default value of None; NEW in extra92: first standalone co_argcount invariant for sleep in asynciofnargcount92 namespace; wave 252; verified with Python 3.14.3"
  category: function_attrs
  kind: python_call_eq
  function: sleep.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra92.run_argcount_one:
  description: "asyncio.run.__code__.co_argcount.__eq__(1) returns True — run takes main (the top-level coroutine) as its single positional argument; NEW in extra92: first standalone co_argcount invariant for run in asynciofnargcount92 namespace; wave 252; verified with Python 3.14.3"
  category: function_attrs
  kind: python_call_eq
  function: run.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant asyncio_extra92.create_task_argcount_one:
  description: "asyncio.create_task.__code__.co_argcount.__eq__(1) returns True — create_task takes coro as its single positional argument; NEW in extra92: first standalone co_argcount invariant for create_task in asynciofnargcount92 namespace; wave 252; verified with Python 3.14.3"
  category: function_attrs
  kind: python_call_eq
  function: create_task.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant asyncio_extra92.new_event_loop_argcount_zero:
  description: "asyncio.new_event_loop.__code__.co_argcount.__eq__(0) returns True — new_event_loop takes no positional arguments; NEW in extra92: first standalone co_argcount invariant for new_event_loop in asynciofnargcount92 namespace; wave 252; verified with Python 3.14.3"
  category: function_attrs
  kind: python_call_eq
  function: new_event_loop.__code__.co_argcount.__eq__
  args: [0]
  expected: true
