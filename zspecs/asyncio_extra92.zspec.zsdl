spec: asyncio_extra92
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra91

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec extends asyncio_extra91.zspec.zsdl."
    - "This spec covers: wave 252 theme — asyncio top-level coroutine function __code__.co_argcount values. NEW in extra92: gather.__code__.co_argcount==0; new_event_loop.__code__.co_argcount==0; get_event_loop_policy.__code__.co_argcount==0; sleep.__code__.co_argcount==2; wait_for.__code__.co_argcount==2; wait.__code__.co_argcount==1; shield.__code__.co_argcount==1; timeout.__code__.co_argcount==1; run.__code__.co_argcount==1; create_task.__code__.co_argcount==1; ensure_future.__code__.co_argcount==1; wrap_future.__code__.co_argcount==1; set_event_loop.__code__.co_argcount==1; set_event_loop_policy.__code__.co_argcount==1; get_event_loop is a builtin_function_or_method (no __code__); get_running_loop is a builtin_function_or_method (no __code__). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__code__.co_argcount == 0. gather uses *coros_or_futures variadic args so co_argcount is 0. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.new_event_loop.__code__.co_argcount == 0. new_event_loop takes no arguments. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.get_event_loop_policy.__code__.co_argcount == 0. get_event_loop_policy takes no arguments. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__code__.co_argcount == 2. sleep takes delay and result arguments. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wait_for.__code__.co_argcount == 2. wait_for takes aw and timeout arguments. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wait.__code__.co_argcount == 1. wait takes fs as its positional argument. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.shield.__code__.co_argcount == 1. shield takes aw as its positional argument. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.timeout.__code__.co_argcount == 1. timeout takes delay as its positional argument. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__code__.co_argcount == 1. run takes main as its positional argument. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.create_task.__code__.co_argcount == 1. create_task takes coro as its positional argument. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.ensure_future.__code__.co_argcount == 1. ensure_future takes coro_or_future as its positional argument. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wrap_future.__code__.co_argcount == 1. wrap_future takes future as its positional argument. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.set_event_loop.__code__.co_argcount == 1. set_event_loop takes loop as its positional argument. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.set_event_loop_policy.__code__.co_argcount == 1. set_event_loop_policy takes policy as its positional argument. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.get_event_loop is a builtin_function_or_method (no __code__). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.get_running_loop is a builtin_function_or_method (no __code__). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio zero-argument coroutine functions — extra92
#
# Wave 252 theme: asyncio top-level coroutine function co_argcount values.
#
# gather.__code__.co_argcount == 0  (variadic *coros_or_futures)
# new_event_loop.__code__.co_argcount == 0
# get_event_loop_policy.__code__.co_argcount == 0
# ---------------------------------------------------------------------------

table asyncio_extra92.zero_arg_functions:
  description: "asyncio zero-argument top-level function co_argcount checks in asynciofnargcount92 namespace — wave 252 theme: asyncio top-level coroutine function __code__.co_argcount values; gather.__code__.co_argcount==0 (variadic *coros_or_futures so co_argcount is 0); new_event_loop.__code__.co_argcount==0; get_event_loop_policy.__code__.co_argcount==0; all verified with Python 3.14.3"
  kind: python_call_eq
  category: function_attrs
  id_prefix: asynciofnargcount92

  columns: [id, function, args, expected, description]
  rows:
    - [gather_argcount,           "gather.__code__.co_argcount.__eq__",           [0], true, "gather.__code__.co_argcount == 0 — variadic *coros_or_futures; co_argcount is 0; verified with Python 3.14.3"]
    - [new_event_loop_argcount,   new_event_loop.__code__.co_argcount.__eq__,     [0], true, "new_event_loop.__code__.co_argcount == 0 — takes no arguments; verified with Python 3.14.3"]
    - [get_event_loop_pol_argcount, get_event_loop_policy.__code__.co_argcount.__eq__, [0], true, "get_event_loop_policy.__code__.co_argcount == 0 — takes no arguments; verified with Python 3.14.3"]

