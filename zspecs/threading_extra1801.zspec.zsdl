spec: threading_extra1801
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value and container/context-manager protocol dict-presence checks for threading types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra1801.truth_protocol:
  description: "threading types __bool__ and __len__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1801

  columns: [id, function, args, expected]
  rows:
    - ["th1801001", "threading.Thread.__dict__.__contains__", ["__bool__"], false]
    - ["th1801002", "threading.Thread.__dict__.__contains__", ["__len__"], false]
    - ["th1801003", "threading.Lock.__class__.__dict__.__contains__", ["__bool__"], false]
    - ["th1801004", "threading.Event.__dict__.__contains__", ["__bool__"], false]
    - ["th1801005", "threading.Condition.__dict__.__contains__", ["__bool__"], false]
    - ["th1801006", "threading.Semaphore.__dict__.__contains__", ["__bool__"], false]
    - ["th1801007", "threading.Timer.__dict__.__contains__", ["__bool__"], false]
    - ["th1801008", "threading.Barrier.__dict__.__contains__", ["__bool__"], false]

table threading_extra1801.lock_protocol:
  description: "threading types context manager protocol __enter__/__exit__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1801

  columns: [id, function, args, expected]
  rows:
    - ["th1801101", "threading.Lock.__class__.__dict__.__contains__", ["__enter__"], true]
    - ["th1801102", "threading.Lock.__class__.__dict__.__contains__", ["__exit__"], true]
    - ["th1801103", "threading.Condition.__dict__.__contains__", ["__enter__"], true]
    - ["th1801104", "threading.Condition.__dict__.__contains__", ["__exit__"], true]
    - ["th1801105", "threading.Semaphore.__dict__.__contains__", ["__enter__"], true]
    - ["th1801106", "threading.Semaphore.__dict__.__contains__", ["__exit__"], true]
    - ["th1801107", "threading.Thread.__dict__.__contains__", ["__enter__"], false]
    - ["th1801108", "threading.Thread.__dict__.__contains__", ["__exit__"], false]

table threading_extra1801.event_barrier_attrs:
  description: "threading.Event and threading.Barrier specific method and property dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1801

  columns: [id, function, args, expected]
  rows:
    - ["th1801201", "threading.Event.__dict__.__contains__", ["is_set"], true]
    - ["th1801202", "threading.Event.__dict__.__contains__", ["set"], true]
    - ["th1801203", "threading.Event.__dict__.__contains__", ["clear"], true]
    - ["th1801204", "threading.Event.__dict__.__contains__", ["wait"], true]
    - ["th1801205", "threading.Barrier.__dict__.__contains__", ["wait"], true]
    - ["th1801206", "threading.Barrier.__dict__.__contains__", ["reset"], true]
    - ["th1801207", "threading.Barrier.__dict__.__contains__", ["abort"], true]
    - ["th1801208", "threading.Barrier.__dict__.__contains__", ["parties"], true]
    - ["th1801209", "threading.Barrier.__dict__.__contains__", ["n_waiting"], true]
    - ["th1801210", "threading.Barrier.__dict__.__contains__", ["broken"], true]
