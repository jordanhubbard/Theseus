spec: urllib_request_extra3
version: ">=3.0"
backend: python_module(urllib.request)

docs: https://docs.python.org/3/library/urllib.request.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.request.html — Python urllib.request module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/request.py"
  notes:
    - "This spec extends urllib_request.zspec.zsdl, urllib_request_extra.zspec.zsdl, and urllib_request_extra2.zspec.zsdl."
    - "urllib_request.zspec.zsdl covers: class_names table (Request/OpenerDirector/BaseHandler/HTTPDefaultErrorHandler/HTTPRedirectHandler/URLError/HTTPError/HTTPHandler/FileHandler), function_names table (urlopen/build_opener/install_opener/pathname2url), Request construction (type/host/full_url/get_method), pathname2url absolute path, URLError reason, HTTPError code/msg."
    - "urllib_request_extra.zspec.zsdl covers: urlretrieve/url2pathname/pathname2url/urlopen __name__; Request/HTTPError/URLError __name__; Request/__module__; URLError/HTTPError __module__ (== 'urllib.error'); HTTPError __bases__[0].__name__ == 'URLError'."
    - "urllib_request_extra2.zspec.zsdl covers: urlopen/build_opener/install_opener/urlretrieve __qualname__; Request/BaseHandler/HTTPHandler/FileHandler/OpenerDirector __qualname__; urlopen/urlretrieve/build_opener __module__."
    - "Focus: __qualname__ for HTTPDefaultErrorHandler and HTTPRedirectHandler (not covered in extra2); __module__ for HTTPDefaultErrorHandler/HTTPRedirectHandler/HTTPHandler/FileHandler/BaseHandler/OpenerDirector/install_opener; url2pathname and pathname2url __qualname__; HTTPRedirectHandler base class; Request.selector attribute; url2pathname round-trip."
    - "HTTPDefaultErrorHandler.__qualname__ == 'HTTPDefaultErrorHandler' — top-level class."
    - "HTTPRedirectHandler.__qualname__ == 'HTTPRedirectHandler' — top-level class."
    - "url2pathname.__qualname__ == 'url2pathname' — top-level function."
    - "pathname2url.__qualname__ == 'pathname2url' — top-level function."
    - "HTTPRedirectHandler.__bases__[0].__name__ == 'BaseHandler' — HTTPRedirectHandler inherits from BaseHandler."
    - "Request('http://example.com/path?q=1').selector == '/path?q=1' — the URL path+query component."
    - "url2pathname('///etc/hosts') == '/etc/hosts' on macOS/Darwin — inverse of pathname2url."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — classes not covered in urllib_request_extra2
# extra2 covers Request/BaseHandler/HTTPHandler/FileHandler/OpenerDirector.
# HTTPDefaultErrorHandler and HTTPRedirectHandler are new.
# url2pathname and pathname2url function qualnames are also new.
# ---------------------------------------------------------------------------

table urllib_request_extra3.class_qualnames_extended:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [HTTPDefaultErrorHandler, HTTPDefaultErrorHandler.__qualname__.__eq__, ["HTTPDefaultErrorHandler"], true]
    - [HTTPRedirectHandler,     HTTPRedirectHandler.__qualname__.__eq__,     ["HTTPRedirectHandler"],     true]

table urllib_request_extra3.function_qualnames_extended:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [url2pathname,  url2pathname.__qualname__.__eq__,  ["url2pathname"],  true]
    - [pathname2url,  pathname2url.__qualname__.__eq__,  ["pathname2url"],  true]

# ---------------------------------------------------------------------------
# __module__ checks — symbols not covered as standalone invariants in prior specs
# extra2 covers urlopen/urlretrieve/build_opener __module__.
# extra covers Request/URLError/HTTPError __module__.
# HTTPDefaultErrorHandler/HTTPRedirectHandler/HTTPHandler/FileHandler/BaseHandler/
# OpenerDirector/install_opener __module__ are new.
# ---------------------------------------------------------------------------

table urllib_request_extra3.class_modules:
  kind: python_call_eq
  category: modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [HTTPDefaultErrorHandler, HTTPDefaultErrorHandler.__module__.__eq__, ["urllib.request"], true]
    - [HTTPRedirectHandler,     HTTPRedirectHandler.__module__.__eq__,     ["urllib.request"], true]
    - [HTTPHandler,             HTTPHandler.__module__.__eq__,             ["urllib.request"], true]
    - [FileHandler,             FileHandler.__module__.__eq__,             ["urllib.request"], true]
    - [BaseHandler,             BaseHandler.__module__.__eq__,             ["urllib.request"], true]
    - [OpenerDirector,          OpenerDirector.__module__.__eq__,          ["urllib.request"], true]

invariant urllib_request_extra3.install_opener.module:
  description: "urllib.request.install_opener.__module__ == 'urllib.request'"
  category: modules
  kind: python_call_eq
  function: install_opener.__module__.__eq__
  args: ["urllib.request"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPRedirectHandler inheritance — not checked in any prior spec
# HTTPRedirectHandler inherits from BaseHandler.
# ---------------------------------------------------------------------------

invariant urllib_request_extra3.HTTPRedirectHandler.base:
  description: "urllib.request.HTTPRedirectHandler.__bases__[0].__name__ == 'BaseHandler'"
  category: hierarchy
  kind: python_call_eq
  function: HTTPRedirectHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseHandler"

# ---------------------------------------------------------------------------
# Request.selector attribute — URL path+query component
# urllib_request.zspec.zsdl covers type, host, full_url, get_method.
# The selector attribute has not been verified in any prior spec.
# ---------------------------------------------------------------------------

invariant urllib_request_extra3.req_selector:
  description: "Request('http://example.com/path?q=1').selector == '/path?q=1'"
  category: Request
  kind: python_call_eq
  function: Request
  args: ["http://example.com/path?q=1"]
  method: selector
  expected: "/path?q=1"

invariant urllib_request_extra3.req_selector_root:
  description: "Request('http://example.com').selector == '' or '/'"
  category: Request
  kind: python_call_eq
  function: Request
  args: ["http://example.com"]
  method: selector
  expected: ""

# ---------------------------------------------------------------------------
# url2pathname — round-trip inverse of pathname2url on macOS/Darwin
# urllib_request.zspec.zsdl covers pathname2url('/etc/hosts') == '///etc/hosts'.
# url2pathname('///etc/hosts') == '/etc/hosts' is the inverse; not yet checked.
# ---------------------------------------------------------------------------

invariant urllib_request_extra3.url2pathname_absolute:
  description: "url2pathname('///etc/hosts') == '/etc/hosts' on macOS/Darwin (POSIX file URI triple-slash)"
  category: url2pathname
  kind: python_call_eq
  function: url2pathname
  args: ["///etc/hosts"]
  expected: "/etc/hosts"
