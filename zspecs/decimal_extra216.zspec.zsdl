spec: decimal_extra216
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers: Decimal comparison (__gt__, __eq__), string representation (__str__ preserving trailing zeros), addition exactness, special values (NaN, Infinity, -Infinity), is_finite(), is_nan()."
    - "Decimal('1.5').__gt__(Decimal('1.4')) == True — decimal comparison is exact; verified with Python 3.14.3."
    - "Decimal('1.0').__eq__(Decimal('1')) == True — numeric equality ignores trailing zeros in comparison; verified with Python 3.14.3."
    - "Decimal('1.0').__str__() == '1.0' — __str__ preserves trailing zero from construction; verified with Python 3.14.3."
    - "Decimal('1').__str__() == '1' — no spurious zeros added; verified with Python 3.14.3."
    - "Decimal('1.50').__str__() == '1.50' — two trailing zeros preserved from construction string; verified with Python 3.14.3."
    - "Decimal('0.1') + Decimal('0.2') — result __str__() == '0.3' — decimal arithmetic is exact, unlike float; verified with Python 3.14.3."
    - "Decimal('NaN').__str__() == 'NaN'; Decimal('Infinity').__str__() == 'Infinity'; Decimal('-Infinity').__str__() == '-Infinity'; verified with Python 3.14.3."
    - "Decimal('1.0').is_finite() == True; Decimal('Infinity').is_finite() == False; Decimal('NaN').is_nan() == True; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal comparison — __gt__ and __eq__
# Decimal uses exact arithmetic; comparisons are mathematically precise.
# ---------------------------------------------------------------------------

invariant decimal_extra216.Decimal.gt.1_5_vs_1_4:
  description: "Decimal('1.5').__gt__(Decimal('1.4')) == True — exact decimal comparison; 1.5 > 1.4; verified with Python 3.14.3"
  category: comparison
  kind: python_call_eq
  function: "Decimal('1.5').__gt__"
  args: ["1.4"]
  expected: true

invariant decimal_extra216.Decimal.eq.1_0_vs_1:
  description: "Decimal('1.0').__eq__(Decimal('1')) == True — numeric equality: 1.0 and 1 are equal even though their string representations differ; verified with Python 3.14.3"
  category: comparison
  kind: python_call_eq
  function: "Decimal('1.0').__eq__"
  args: ["1"]
  expected: true

# ---------------------------------------------------------------------------
# Decimal.__str__() — preserves trailing zeros from construction
# Decimal preserves the exact coefficient and exponent from the input string.
# ---------------------------------------------------------------------------

table decimal_extra216.str_representations:
  description: "Decimal.__str__() preserves trailing zeros from construction string; NaN, Infinity, -Infinity have fixed string forms; verified with Python 3.14.3"
  kind: python_call_eq
  category: string_repr
  id_prefix: decstrrepr216

  columns: [id, function, args, expected]
  rows:
    - [str_1_0,        "Decimal('1.0').__str__",          [],  "1.0"]
    - [str_1,          "Decimal('1').__str__",            [],  "1"]
    - [str_1_50,       "Decimal('1.50').__str__",         [],  "1.50"]
    - [str_nan,        "Decimal('NaN').__str__",          [],  "NaN"]
    - [str_inf,        "Decimal('Infinity').__str__",     [],  "Infinity"]
    - [str_neginf,     "Decimal('-Infinity').__str__",    [],  "-Infinity"]

# ---------------------------------------------------------------------------
# Decimal addition — exact arithmetic
# Decimal('0.1') + Decimal('0.2') == Decimal('0.3') exactly.
# float 0.1 + 0.2 != 0.3 due to binary representation; Decimal is exact.
# ---------------------------------------------------------------------------

invariant decimal_extra216.Decimal.add.0_1_plus_0_2:
  description: "Decimal('0.1') + Decimal('0.2') __str__() == '0.3' — decimal arithmetic is exact; contrast float where 0.1+0.2 != 0.3; verified with Python 3.14.3"
  category: arithmetic
  kind: python_call_eq
  function: "Decimal('0.1').__add__(Decimal('0.2')).__str__"
  args: []
  expected: "0.3"

# ---------------------------------------------------------------------------
# Decimal special value predicates — is_finite(), is_nan()
# is_finite() returns True for finite numbers, False for Infinity/NaN.
# is_nan() returns True for NaN, False otherwise.
# ---------------------------------------------------------------------------

table decimal_extra216.special_value_predicates:
  description: "Decimal.is_finite() and is_nan() predicates for finite, Infinity, and NaN values; verified with Python 3.14.3"
  kind: python_call_eq
  category: predicates
  id_prefix: decspecpred216

  columns: [id, function, args, expected]
  rows:
    - [finite_is_finite,   "Decimal('1.0').is_finite",      [],  true]
    - [inf_is_finite,      "Decimal('Infinity').is_finite",  [],  false]
    - [nan_is_nan,         "Decimal('NaN').is_nan",         [],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra216.Decimal.str.1_0:
  description: "Decimal('1.0').__str__() == '1.0' — trailing zero preserved; Decimal stores coefficient and exponent; verified with Python 3.14.3"
  category: string_repr
  kind: python_call_eq
  function: "Decimal('1.0').__str__"
  args: []
  expected: "1.0"

invariant decimal_extra216.Decimal.str.1_50:
  description: "Decimal('1.50').__str__() == '1.50' — two trailing zeros preserved from input '1.50'; verified with Python 3.14.3"
  category: string_repr
  kind: python_call_eq
  function: "Decimal('1.50').__str__"
  args: []
  expected: "1.50"

invariant decimal_extra216.Decimal.str.nan:
  description: "Decimal('NaN').__str__() == 'NaN' — canonical string representation of not-a-number; verified with Python 3.14.3"
  category: string_repr
  kind: python_call_eq
  function: "Decimal('NaN').__str__"
  args: []
  expected: "NaN"

invariant decimal_extra216.Decimal.str.infinity:
  description: "Decimal('Infinity').__str__() == 'Infinity' — canonical string for positive infinity; verified with Python 3.14.3"
  category: string_repr
  kind: python_call_eq
  function: "Decimal('Infinity').__str__"
  args: []
  expected: "Infinity"

invariant decimal_extra216.Decimal.str.neg_infinity:
  description: "Decimal('-Infinity').__str__() == '-Infinity' — canonical string for negative infinity; verified with Python 3.14.3"
  category: string_repr
  kind: python_call_eq
  function: "Decimal('-Infinity').__str__"
  args: []
  expected: "-Infinity"

invariant decimal_extra216.Decimal.is_finite.true:
  description: "Decimal('1.0').is_finite() == True — a finite decimal number; verified with Python 3.14.3"
  category: predicates
  kind: python_call_eq
  function: "Decimal('1.0').is_finite"
  args: []
  expected: true

invariant decimal_extra216.Decimal.is_finite.false:
  description: "Decimal('Infinity').is_finite() == False — infinity is not finite; verified with Python 3.14.3"
  category: predicates
  kind: python_call_eq
  function: "Decimal('Infinity').is_finite"
  args: []
  expected: false

invariant decimal_extra216.Decimal.is_nan.true:
  description: "Decimal('NaN').is_nan() == True — NaN is not-a-number; verified with Python 3.14.3"
  category: predicates
  kind: python_call_eq
  function: "Decimal('NaN').is_nan"
  args: []
  expected: true

