spec: fs_jetpack
version: ">=5.0.0"
backend: node(fs-jetpack)

docs: https://github.com/szwacz/fs-jetpack#readme

provenance:
  derived_from:
    - "fs-jetpack README — https://github.com/szwacz/fs-jetpack#readme"
    - "Test vectors verified with fs-jetpack via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "fs-jetpack source"
  notes:
    - "Higher-level fs API — chainable cwd-bound operations, copy/move/list/find with sensible defaults."
    - "Install: npm install fs-jetpack"
    - "v5 CJS; default export is a jetpack instance bound to process.cwd(); each helper has a sync and async (Async-suffixed) variant."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws on missing files (non-list operations); list() returns undefined for missing dirs."
  stderr: "null"
  stickiness: "cwd() returns the current bound directory."
  codes: {}

invariant fs_jetpack.has_read:
  description: "read() (sync) is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "read.constructor.name"}
  expected: "Function"

invariant fs_jetpack.has_write:
  description: "write() (sync) is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "write.constructor.name"}
  expected: "Function"

invariant fs_jetpack.has_exists:
  description: "exists() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "exists.constructor.name"}
  expected: "Function"

invariant fs_jetpack.has_list:
  description: "list() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "list.constructor.name"}
  expected: "Function"

invariant fs_jetpack.has_copy:
  description: "copy() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "copy.constructor.name"}
  expected: "Function"

invariant fs_jetpack.has_remove:
  description: "remove() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "remove.constructor.name"}
  expected: "Function"

invariant fs_jetpack.has_cwd:
  description: "cwd() returns current bound directory"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "cwd.constructor.name"}
  expected: "Function"

invariant fs_jetpack.has_async_read:
  description: "readAsync (Promise variant) is exported as a Function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "readAsync.constructor.name"}
  expected: "Function"

invariant fs_jetpack.has_dir:
  description: "dir() (mkdir) is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "dir.constructor.name"}
  expected: "Function"

invariant fs_jetpack.has_find:
  description: "find() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "find.constructor.name"}
  expected: "Function"

