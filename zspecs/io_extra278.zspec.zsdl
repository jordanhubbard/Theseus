spec: io_extra278
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io is a frozen module (origin == 'frozen') that wraps the _io C extension."
    - "io.__loader__ is the FrozenImporter class itself (not an instance); io.__loader__.__name__ == 'FrozenImporter'."
    - "io.__loader__.__class__.__name__ == 'type' because FrozenImporter is a class object."
    - "io.__spec__.origin == 'frozen' — the io module is embedded in the CPython interpreter."
    - "_io.__loader__ is the BuiltinImporter class; _io.__loader__.__name__ == 'BuiltinImporter'."
    - "_io.__spec__.origin == 'built-in' — the _io C extension is a built-in module."
    - "io.UnsupportedOperation has two bases: OSError and ValueError (in that order)."
    - "io.UnsupportedOperation.__module__ == 'io' — the class is defined in the io wrapper module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: io module __spec__ and loader identity
# ---------------------------------------------------------------------------

table io_extra278.io_module_spec_identity:
  description: "io module __name__, __package__, __spec__.name, __spec__.__class__.__name__, __loader__.__name__, and __spec__.origin identity"
  kind: python_call_eq
  category: identity
  id_prefix: msi

  columns: [id, function, args, expected, description]
  rows:
    - [io_name,         __name__.__eq__,                    ["io"],            true, "io.__name__ == 'io'"]
    - [io_package,      __package__.__eq__,                 [""],              true, "io.__package__ == ''"]
    - [spec_name,       __spec__.name.__eq__,               ["io"],            true, "io.__spec__.name == 'io'"]
    - [spec_class,      __spec__.__class__.__name__.__eq__, ["ModuleSpec"],    true, "io.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [loader_name,     __loader__.__name__.__eq__,         ["FrozenImporter"], true, "io.__loader__.__name__ == 'FrozenImporter' — loader IS the class"]
    - [loader_class,    __loader__.__class__.__name__.__eq__, ["type"],         true, "io.__loader__.__class__.__name__ == 'type' — FrozenImporter is a class object"]
    - [origin_val,      __spec__.origin.__eq__,             ["frozen"],        true, "io.__spec__.origin == 'frozen' — io is a frozen module"]

# ---------------------------------------------------------------------------
# Table: io.UnsupportedOperation exception class identity
# ---------------------------------------------------------------------------

table io_extra278.unsupported_operation_identity:
  description: "io.UnsupportedOperation __name__, __module__, and base class names"
  kind: python_call_eq
  category: identity
  id_prefix: uoi

  columns: [id, function, args, expected, description]
  rows:
    - [exc_name,   UnsupportedOperation.__name__.__eq__,               ["UnsupportedOperation"], true, "io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"]
    - [exc_module, UnsupportedOperation.__module__.__eq__,             ["io"],                   true, "io.UnsupportedOperation.__module__ == 'io'"]
    - [exc_base0,  "UnsupportedOperation.__bases__[0].__name__.__eq__", ["OSError"],              true, "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError'"]
    - [exc_base1,  "UnsupportedOperation.__bases__[1].__name__.__eq__", ["ValueError"],           true, "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError'"]

# ---------------------------------------------------------------------------
# Standalone invariants: io spec and _io loader identity
# ---------------------------------------------------------------------------

invariant io_extra278.io.__spec__.name:
  description: "io.__spec__.name == 'io'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["io"]
  expected: true

invariant io_extra278.io.__spec__.origin:
  description: "io.__spec__.origin == 'frozen' — io is embedded in the interpreter"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["frozen"]
  expected: true

invariant io_extra278.io.__loader__.__name__:
  description: "io.__loader__.__name__ == 'FrozenImporter' — the loader object is the class itself"
  category: identity
  kind: python_call_eq
  function: __loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant io_extra278.io.UnsupportedOperation.name:
  description: "io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"
  category: identity
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra278.io.UnsupportedOperation.module:
  description: "io.UnsupportedOperation.__module__ == 'io'"
  category: identity
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra278.io.UnsupportedOperation.base0:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError'"
  category: identity
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant io_extra278.io.UnsupportedOperation.base1:
  description: "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError'"
  category: identity
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[1].__name__.__eq__"
  args: ["ValueError"]
  expected: true
