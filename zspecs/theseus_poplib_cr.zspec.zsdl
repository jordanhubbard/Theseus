spec: theseus_poplib_cr
version: ">=3.8"
backend: python_cleanroom(theseus_poplib_cr)
blocks: poplib

docs: https://docs.python.org/3/library/poplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/poplib.html"
  not_derived_from:
    - "CPython source: Lib/poplib.py"
  notes:
    - "Clean-room poplib module. Do NOT import poplib."
    - "POP3 client with exception classes."

error_model: python_exceptions

invariant theseus_poplib_cr.poplib2_exceptions:
  description: "poplib exception classes exist and inherit from Exception"
  category: exceptions
  kind: python_call_eq
  function: poplib2_exceptions
  args: []
  expected: true

invariant theseus_poplib_cr.poplib2_constants:
  description: "POP3_PORT and POP3_SSL_PORT have expected values"
  category: constants
  kind: python_call_eq
  function: poplib2_constants
  args: []
  expected: true

invariant theseus_poplib_cr.poplib2_parse_response:
  description: "POP3 response line parsed correctly"
  category: parsing
  kind: python_call_eq
  function: poplib2_parse_response
  args: []
  expected: true
