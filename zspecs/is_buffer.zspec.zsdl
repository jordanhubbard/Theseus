spec: is_buffer
version: ">=2.0.0"
backend: node(is-buffer)

docs: https://github.com/feross/is-buffer#readme

provenance:
  derived_from:
    - "is-buffer README — https://github.com/feross/is-buffer#readme"
    - "Node.js Buffer.isBuffer docs — https://nodejs.org/api/buffer.html"
    - "Test vectors verified with is-buffer via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "is-buffer source"
  notes:
    - "Predicate that returns true for Node Buffers without requiring Buffer to be globally available."
    - "Install: npm install is-buffer"
    - "v2 CJS; module export IS the function. Returns false for any non-Buffer value (including objects, null, primitives)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on any input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant is_buffer.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant is_buffer.module_arity:
  description: "Module function declared length is 1"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant is_buffer.module_name:
  description: "Module function .name is 'isBuffer'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: name}
  expected: "isBuffer"

invariant is_buffer.empty_object_false:
  description: "Empty object is not a Buffer"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{}]
  chain: []
  expected: false

invariant is_buffer.null_false:
  description: "null is not a Buffer"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [null]
  chain: []
  expected: false

invariant is_buffer.string_false:
  description: "Strings are not Buffers"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: ["hello"]
  chain: []
  expected: false

invariant is_buffer.number_false:
  description: "Numbers are not Buffers"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [42]
  chain: []
  expected: false

invariant is_buffer.array_false:
  description: "Arrays are not Buffers"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [[1, 2, 3]]
  chain: []
  expected: false
