spec: bdb_extra2
version: ">=3.9"
backend: python_module(bdb)

docs: https://docs.python.org/3/library/bdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bdb.html — Python bdb module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bdb.py"
  notes:
    - "Extends bdb.zspec.zsdl and bdb_extra.zspec.zsdl; does NOT duplicate invariants already present there."
    - "bdb.zspec.zsdl covers: Bdb.__name__, Bdb.__module__, Breakpoint.__name__, BdbQuit.__name__, BdbQuit.__bases__[0].__name__, BdbQuit.__module__; set_trace/set_break/clear_break/clear_all_breaks/get_breaks/run/runcall/runeval/set_continue/set_quit method names."
    - "bdb_extra.zspec.zsdl covers: Bdb.__name__, Bdb.__module__, Breakpoint.__name__, Breakpoint.__module__, BdbQuit.__name__, BdbQuit.__module__, BdbQuit.__bases__[0].__name__, BdbQuit.__bases__.__len__; set_trace/set_step/set_next/set_return/set_quit/set_break/run/runcall/runeval/set_continue/clear_break method names."
    - "This spec adds: Bdb.__bases__[0].__name__, Breakpoint.__module__ already in bdb_extra — using checkfuncname and effective module-level functions, which are NEW."
    - "bdb.checkfuncname is a module-level function that checks whether execution should stop at a breakpoint given the current function."
    - "bdb.effective is a module-level function that checks whether a breakpoint is effective at a given location."
    - "bdb.Bdb.__bases__[0].__name__ == 'object' — Bdb inherits directly from object (no intermediate debugger base)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Bdb — base class hierarchy (not in bdb.zspec or bdb_extra.zspec)
# ---------------------------------------------------------------------------

invariant bdb_extra2.Bdb.base_is_object:
  description: "bdb.Bdb.__bases__[0].__name__ == 'object' — Bdb inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Bdb.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# module-level functions — checkfuncname and effective
# (not covered in bdb.zspec or bdb_extra.zspec)
# ---------------------------------------------------------------------------

invariant bdb_extra2.checkfuncname.name:
  description: "bdb.checkfuncname.__name__ == 'checkfuncname'"
  category: module_functions
  kind: python_call_eq
  function: checkfuncname.__name__.__eq__
  args: ["checkfuncname"]
  expected: true

invariant bdb_extra2.effective.name:
  description: "bdb.effective.__name__ == 'effective'"
  category: module_functions
  kind: python_call_eq
  function: effective.__name__.__eq__
  args: ["effective"]
  expected: true

invariant bdb_extra2.checkfuncname.module:
  description: "bdb.checkfuncname.__module__ == 'bdb'"
  category: module_functions
  kind: python_call_eq
  function: checkfuncname.__module__.__eq__
  args: ["bdb"]
  expected: true

invariant bdb_extra2.effective.module:
  description: "bdb.effective.__module__ == 'bdb'"
  category: module_functions
  kind: python_call_eq
  function: effective.__module__.__eq__
  args: ["bdb"]
  expected: true

# ---------------------------------------------------------------------------
# class names table — Bdb, Breakpoint, BdbQuit (compact form for cross-check)
# This table uses __qualname__ which is distinct from the __name__ tables
# already in bdb.zspec.zsdl and bdb_extra.zspec.zsdl.
# ---------------------------------------------------------------------------

table bdb_extra2.class_qualnames:
  kind: python_call_eq
  category: class_names
  id_prefix: qualname
  columns: [id, function, args, expected]
  rows:
    - [Bdb,        Bdb.__qualname__.__eq__,        ["Bdb"],        true]
    - [Breakpoint, Breakpoint.__qualname__.__eq__, ["Breakpoint"], true]
    - [BdbQuit,    BdbQuit.__qualname__.__eq__,    ["BdbQuit"],    true]
