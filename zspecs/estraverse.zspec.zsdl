spec: estraverse
version: ">=5.0.0"
backend: node(estraverse)

docs: https://github.com/estools/estraverse#readme

provenance:
  derived_from:
    - "estraverse README — https://github.com/estools/estraverse#readme"
    - "ESTree specification — https://github.com/estree/estree"
    - "Test vectors verified with estraverse via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "estraverse source"
  notes:
    - "estraverse is the ESTree visitor utility — used by escope, escodegen, and most AST tooling that doesn't ship its own traversal."
    - "Install: npm install estraverse"
    - "Most invariants test the static metadata exports (Syntax, VisitorKeys, VisitorOption); traverse/replace are higher-order callbacks not directly chain-testable."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; visitor callbacks may throw to abort traversal but exposed APIs don't."
  stderr: "null"
  stickiness: "N/A — pure metadata."
  codes: {}

# Syntax — node-type registry
invariant estraverse.syntax_program:
  description: "Syntax.Program == 'Program'"
  category: syntax_registry
  kind: node_property_eq
  entry: bare
  property: Syntax.Program
  expected: "Program"

invariant estraverse.syntax_binary_expression:
  description: "Syntax.BinaryExpression == 'BinaryExpression'"
  category: syntax_registry
  kind: node_property_eq
  entry: bare
  property: Syntax.BinaryExpression
  expected: "BinaryExpression"

invariant estraverse.syntax_function_declaration:
  description: "Syntax.FunctionDeclaration == 'FunctionDeclaration'"
  category: syntax_registry
  kind: node_property_eq
  entry: bare
  property: Syntax.FunctionDeclaration
  expected: "FunctionDeclaration"

invariant estraverse.syntax_call_expression:
  description: "Syntax.CallExpression == 'CallExpression'"
  category: syntax_registry
  kind: node_property_eq
  entry: bare
  property: Syntax.CallExpression
  expected: "CallExpression"

# VisitorKeys — child-property registry per node type
invariant estraverse.visitor_keys_program:
  description: "VisitorKeys.Program == ['body']"
  category: visitor_keys
  kind: node_property_eq
  entry: bare
  property: VisitorKeys.Program
  expected: ["body"]

invariant estraverse.visitor_keys_binary_expression:
  description: "VisitorKeys.BinaryExpression includes 'left' and 'right'"
  category: visitor_keys
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: VisitorKeys}
    - {get: BinaryExpression}
    - {method: includes, args: ["left"]}
  expected: true

invariant estraverse.visitor_keys_binary_right:
  description: "VisitorKeys.BinaryExpression includes 'right'"
  category: visitor_keys
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: VisitorKeys}
    - {get: BinaryExpression}
    - {method: includes, args: ["right"]}
  expected: true

# VisitorOption — control-flow sentinels (opaque object identities)
invariant estraverse.visitor_option_break_is_object:
  description: "VisitorOption.Break is an opaque sentinel object (truthy)"
  category: visitor_option
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: VisitorOption}
    - {get: Break}
    - {get: constructor}
    - {get: name}
  expected: "Object"

invariant estraverse.visitor_option_skip_distinct_from_break:
  description: "VisitorOption.Skip is a separate sentinel object"
  category: visitor_option
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: VisitorOption}
    - {get: Skip}
    - {get: constructor}
    - {get: name}
  expected: "Object"

# Identity — top-level functions exist as expected
invariant estraverse.has_traverse_function:
  description: "estraverse.traverse is a function"
  category: api_surface
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: traverse}
    - {get: name}
  expected: "traverse"

invariant estraverse.has_replace_function:
  description: "estraverse.replace is a function"
  category: api_surface
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: replace}
    - {get: name}
  expected: "replace"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:44:57Z
  iterations: 1
  pass_count: 11
  fail_count: 0
  total_invariants: 11
  notes: Synthesis succeeded in 1 iteration(s). 11 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
