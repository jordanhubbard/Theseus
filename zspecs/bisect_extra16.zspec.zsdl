spec: bisect_extra16
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl through bisect_extra15.zspec.zsdl."
    - "Prior specs cover: __name__/__module__/__qualname__ for all 6 callables; behavioral vectors."
    - "Prior specs cover: __name__/__module__/__qualname__ for bisect_left/bisect_right/insort_left/insort_right/bisect/insort; behavioral vectors on many sorted lists."
    - "bisect_extra15 covers all 6 qualnames and all 6 __module__ in a unified table."
    - "No prior spec covers __text_signature__ for any bisect function."
    - "No prior spec covers bisect.__package__ == ''."
    - "No prior spec uses [10,20,30,40,50,60,70] as a behavioral input."
    - "bisect_left.__text_signature__ == '($module, /, a, x, lo=0, hi=None, *, key=None)' — C builtin text signature."
    - "bisect.__package__ == '' — top-level module has empty package string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# bisect module __package__ attribute
#
# No prior spec checks bisect.__package__. bisect is a top-level module so
# its __package__ is the empty string. This is distinct from __name__ which
# is 'bisect' (covered in bisect_extra4).
# ---------------------------------------------------------------------------

invariant bisect_extra16.module.package:
  description: "bisect.__package__ == '' — top-level module has empty package string"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# bisect function __text_signature__ table
#
# C-extension builtins expose their call signature as __text_signature__.
# No prior spec checks this attribute for any bisect function. All six
# bisect callables share the same signature string because bisect and insort
# are aliases for bisect_right and insort_right respectively, and the
# remaining four all accept (a, x, lo=0, hi=None, *, key=None).
# ---------------------------------------------------------------------------

table bisect_extra16.text_signatures:
  description: "__text_signature__ for all 6 bisect callables — C builtin parameter signature"
  kind: python_call_eq
  category: function_metadata
  id_prefix: bsig

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__text_signature__.__eq__,  ["($module, /, a, x, lo=0, hi=None, *, key=None)"], true]
    - [bisect_right, bisect_right.__text_signature__.__eq__, ["($module, /, a, x, lo=0, hi=None, *, key=None)"], true]
    - [insort_left,  insort_left.__text_signature__.__eq__,  ["($module, /, a, x, lo=0, hi=None, *, key=None)"], true]
    - [insort_right, insort_right.__text_signature__.__eq__, ["($module, /, a, x, lo=0, hi=None, *, key=None)"], true]
    - [bisect,       bisect.__text_signature__.__eq__,       ["($module, /, a, x, lo=0, hi=None, *, key=None)"], true]
    - [insort,       insort.__text_signature__.__eq__,       ["($module, /, a, x, lo=0, hi=None, *, key=None)"], true]

# ---------------------------------------------------------------------------
# Behavioral vectors on [10, 20, 30, 40, 50, 60, 70]
#
# No prior spec uses this 7-element list. It provides distinct boundary cases:
# search at list endpoints (10, 70), a present interior element (30), and
# absent interior values (25, 65). bisect_left and bisect_right differ when
# the target is present; they agree when the target is absent.
# ---------------------------------------------------------------------------

table bisect_extra16.vectors_10_70:
  description: "bisect_left/bisect_right on [10,20,30,40,50,60,70] — endpoints, present, and absent values"
  kind: python_call_eq
  category: behavioral
  id_prefix: bv70

  columns: [id, function, args, expected]
  rows:
    - [left_10,  bisect_left,  [[10, 20, 30, 40, 50, 60, 70], 10], 0]
    - [right_10, bisect_right, [[10, 20, 30, 40, 50, 60, 70], 10], 1]
    - [left_25,  bisect_left,  [[10, 20, 30, 40, 50, 60, 70], 25], 2]
    - [right_25, bisect_right, [[10, 20, 30, 40, 50, 60, 70], 25], 2]
    - [left_30,  bisect_left,  [[10, 20, 30, 40, 50, 60, 70], 30], 2]
    - [right_30, bisect_right, [[10, 20, 30, 40, 50, 60, 70], 30], 3]
    - [left_65,  bisect_left,  [[10, 20, 30, 40, 50, 60, 70], 65], 6]
    - [right_65, bisect_right, [[10, 20, 30, 40, 50, 60, 70], 65], 6]
    - [left_70,  bisect_left,  [[10, 20, 30, 40, 50, 60, 70], 70], 6]
    - [right_70, bisect_right, [[10, 20, 30, 40, 50, 60, 70], 70], 7]
