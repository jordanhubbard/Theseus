spec: types_extra30
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends types_extra29.zspec.zsdl."
    - "Prior specs covered: FunctionType/LambdaType/MethodType/GeneratorType/CodeType/ModuleType/__name__/__module__/__qualname__, SimpleNamespace/__name__/__module__/__qualname__, MappingProxyType/__name__, DynamicClassAttribute/__name__, GenericAlias/__name__, UnionType/__name__, various __bases__[0].__name__ checks, NoneType/EllipsisType/NotImplementedType, __module__.__len__() and __name__.__len__() for many types, __qualname__.__len__() for SimpleNamespace methods and ModuleType methods, __mro__.__len__() for MappingProxyType/NoneType/EllipsisType and six more core types (all 2), types.__all__.__len__() (33), __dict__.__class__.__name__.__len__() for seven classes (all 12), CodeType qualname/dict/mro/bases0 lens, types.__name__.__len__() (5)."
    - "This spec covers: CellType.__name__.__len__()==4 ('cell'); CellType.__qualname__.__len__()==4; CellType.__mro__.__len__()==2; CellType.__bases__[0].__name__.__len__()==6 ('object'); AsyncGeneratorType.__name__.__len__()==15 ('async_generator'); AsyncGeneratorType.__qualname__.__len__()==15; AsyncGeneratorType.__mro__.__len__()==2; BuiltinFunctionType.__name__.__len__()==26 ('builtin_function_or_method'); BuiltinFunctionType.__mro__.__len__()==2; WrapperDescriptorType.__name__.__len__()==18 ('wrapper_descriptor'); WrapperDescriptorType.__qualname__.__len__()==18; WrapperDescriptorType.__mro__.__len__()==2; MethodWrapperType.__name__.__len__()==14 ('method-wrapper'); MethodWrapperType.__qualname__.__len__()==14; MethodWrapperType.__mro__.__len__()==2."
    - "CellType.__name__ == CellType.__qualname__ == 'cell' (4 chars) — the C internal short name for closure cells."
    - "AsyncGeneratorType.__name__ == 'async_generator' (15 chars) — note the underscore; differs from Python class name 'AsyncGeneratorType' (18 chars)."
    - "BuiltinFunctionType.__name__ == 'builtin_function_or_method' (26 chars) — the longest C type name in this spec; BuiltinMethodType is the same object."
    - "WrapperDescriptorType.__name__ == 'wrapper_descriptor' (18 chars); MethodWrapperType.__name__ == 'method-wrapper' (14 chars, note the hyphen)."
    - "All C types (CellType, AsyncGeneratorType, BuiltinFunctionType, WrapperDescriptorType, MethodWrapperType) have __mro__ length 2 — each directly subclasses object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CellType introspection — __name__, __qualname__, __mro__, __bases__[0]
#
# types.CellType is the C type for closure cell objects. Its internal C name
# is 'cell' (length 4), much shorter than the Python attribute name 'CellType'
# (8). __qualname__ also equals 'cell' (4). __mro__ has length 2 (cell,
# object). __bases__[0].__name__ == 'object' (length 6). No prior types spec
# records CellType introspection in a grouped table.
# ---------------------------------------------------------------------------

table types_extra30.CellType_attrs:
  description: "CellType __name__/__qualname__/__mro__ lengths and __bases__[0].__name__.__len__()"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: cell_attr

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,
       CellType.__name__.__len__,
       [],
       4,
       "types.CellType.__name__ == 'cell' (length 4) — C internal short name"]
    - [qualname_len,
       CellType.__qualname__.__len__,
       [],
       4,
       "types.CellType.__qualname__ == 'cell' (length 4) — equals __name__ for C type"]
    - [mro_len,
       CellType.__mro__.__len__,
       [],
       2,
       "len(types.CellType.__mro__) == 2 — (cell, object); direct object subclass"]
    - [bases0_name_len,
       "CellType.__bases__[0].__name__.__len__",
       [],
       6,
       "types.CellType.__bases__[0].__name__ == 'object' (length 6)"]

# ---------------------------------------------------------------------------
# AsyncGeneratorType introspection — __name__, __qualname__, __mro__
#
# types.AsyncGeneratorType is the C type for async generator objects. Its
# internal C name is 'async_generator' (15 chars) — note the underscore
# separator, contrasting with the CamelCase Python attribute 'AsyncGeneratorType'
# (18 chars). __qualname__ also equals 'async_generator' (15). __mro__ has
# length 2 (async_generator, object). No prior types spec records these
# AsyncGeneratorType attribute lengths.
# ---------------------------------------------------------------------------

table types_extra30.AsyncGeneratorType_attrs:
  description: "AsyncGeneratorType __name__/__qualname__/__mro__ lengths"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: asyncgen_attr

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,
       AsyncGeneratorType.__name__.__len__,
       [],
       15,
       "types.AsyncGeneratorType.__name__ == 'async_generator' (length 15) — C name uses underscore"]
    - [qualname_len,
       AsyncGeneratorType.__qualname__.__len__,
       [],
       15,
       "types.AsyncGeneratorType.__qualname__ == 'async_generator' (length 15) — equals __name__"]
    - [mro_len,
       AsyncGeneratorType.__mro__.__len__,
       [],
       2,
       "len(types.AsyncGeneratorType.__mro__) == 2 — (async_generator, object)"]

# ---------------------------------------------------------------------------
# WrapperDescriptorType and MethodWrapperType introspection — __name__,
# __qualname__, __mro__
#
# types.WrapperDescriptorType.__name__ == 'wrapper_descriptor' (18 chars).
# types.MethodWrapperType.__name__ == 'method-wrapper' (14 chars) — note the
# hyphen, which is unusual for Python C type names. Both __qualname__ values
# equal the corresponding __name__. Both have __mro__ length 2. No prior types
# spec records these two types' attribute lengths.
# ---------------------------------------------------------------------------

table types_extra30.wrapper_type_attrs:
  description: "WrapperDescriptorType and MethodWrapperType __name__/__qualname__/__mro__ lengths"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: wrapper_attr

  columns: [id, function, args, expected, description]
  rows:
    - [WDT_name_len,
       WrapperDescriptorType.__name__.__len__,
       [],
       18,
       "types.WrapperDescriptorType.__name__ == 'wrapper_descriptor' (length 18)"]
    - [WDT_qualname_len,
       WrapperDescriptorType.__qualname__.__len__,
       [],
       18,
       "types.WrapperDescriptorType.__qualname__ == 'wrapper_descriptor' (length 18)"]
    - [WDT_mro_len,
       WrapperDescriptorType.__mro__.__len__,
       [],
       2,
       "len(types.WrapperDescriptorType.__mro__) == 2 — (wrapper_descriptor, object)"]
    - [MWT_name_len,
       MethodWrapperType.__name__.__len__,
       [],
       14,
       "types.MethodWrapperType.__name__ == 'method-wrapper' (length 14) — hyphen in name"]
    - [MWT_qualname_len,
       MethodWrapperType.__qualname__.__len__,
       [],
       14,
       "types.MethodWrapperType.__qualname__ == 'method-wrapper' (length 14)"]
    - [MWT_mro_len,
       MethodWrapperType.__mro__.__len__,
       [],
       2,
       "len(types.MethodWrapperType.__mro__) == 2 — (method-wrapper, object)"]

# ---------------------------------------------------------------------------
# BuiltinFunctionType.__name__.__len__() == 26 — standalone invariant
#
# types.BuiltinFunctionType.__name__ == 'builtin_function_or_method' (26
# chars). This is the longest C type name recorded in this spec series for
# the types module. BuiltinMethodType is the same object as BuiltinFunctionType
# (types.BuiltinMethodType is types.BuiltinFunctionType evaluates to True),
# so both attribute names resolve to the same __name__. No prior types spec
# records BuiltinFunctionType.__name__.__len__() as a standalone.
# ---------------------------------------------------------------------------

invariant types_extra30.BuiltinFunctionType.name_len:
  description: "types.BuiltinFunctionType.__name__.__len__() == 26 — C name 'builtin_function_or_method' (26 chars); BuiltinMethodType is the same object"
  category: class_name_attrs
  kind: python_call_eq
  function: BuiltinFunctionType.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# BuiltinFunctionType.__mro__.__len__() == 2 — standalone invariant
#
# types.BuiltinFunctionType.__mro__ == (builtin_function_or_method, object) —
# length 2. Despite its long C name, it is a direct object subclass with a
# flat MRO, consistent with all other C types in this spec. Recorded
# standalone as it was not covered in any prior types spec.
# ---------------------------------------------------------------------------

invariant types_extra30.BuiltinFunctionType.mro_len:
  description: "types.BuiltinFunctionType.__mro__.__len__() == 2 — (builtin_function_or_method, object); flat MRO despite long C name"
  category: mro_lengths
  kind: python_call_eq
  function: BuiltinFunctionType.__mro__.__len__
  args: []
  expected: 2
