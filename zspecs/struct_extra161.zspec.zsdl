spec: struct_extra161
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra160.zspec.zsdl — covers struct.Struct.__dict__ membership (pack/unpack/pack_into/unpack_from/iter_unpack/size/format) and meta-attributes (__len__()==16/__class__.__name__=='mappingproxy') (table + invariants)."
    - "struct_extra159.zspec.zsdl — covers struct.__spec__.origin type and content / submodule_search_locations NoneType / spec attribute lengths (table + invariants)."
    - "struct_extra158.zspec.zsdl — covers struct.Struct.__new__/__str__ qualnames; struct.error class identity / error.__bases__[0].__name__=='Exception' (table + invariants)."
    - "struct_extra157.zspec.zsdl — covers struct.Struct.__repr__/__sizeof__ qualnames / Struct.__name__/__module__ (table + invariants)."
    - "struct_extra155.zspec.zsdl — covers struct.Struct.size/__format__ getset_descriptor qualnames (table + invariants)."
    - "struct_extra154.zspec.zsdl — covers struct.Struct.pack/__unpack/__pack_into qualnames (table + invariants)."
    - "struct_extra153.zspec.zsdl — covers struct.Struct.__init__.__qualname__ / Struct.__doc__.__len__()==40 / error.__doc__ NoneType (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra160."
    - "Wave 347 theme: struct class identity — struct.error.__name__=='error' / error.__module__=='struct' / error.__bases__[0].__name__=='Exception' / struct.Struct.__name__=='Struct' / Struct.__module__=='_struct' / Struct.__bases__[0].__name__=='object'. struct_extra158 anchors error.__bases__[0].__name__=='Exception' as a table row and struct.error class identity; struct_extra157 anchors Struct.__name__ and Struct.__module__ as table rows. This spec anchors these values alongside their lengths and Struct.__bases__ as the primary novel content."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.error.__name__ == 'error' (5 chars). struct.error is the exception class raised by struct operations when a format string or data is invalid. It is defined in the _struct C extension (Modules/_struct.c) as a subclass of Exception. Its __name__ is 'error' (5 chars, lowercase) following the old Python convention for exception names (before PEP 8 required CapWords for exception classes). struct.error.__module__ == 'struct' (6 chars; despite being implemented in _struct.c, the error class's __module__ is 'struct' the public module name)."
    - "Note: struct.Struct.__name__ == 'Struct' (6 chars). The Struct class is a C extension type defined in Modules/_struct.c. Its __name__ is 'Struct' (6 chars, CapWords following modern Python convention). struct_extra157 anchors Struct.__name__ and Struct.__module__ as table rows. struct.Struct.__module__ == '_struct' (7 chars = '_'=1 + 'struct'=6). The private C extension '_struct' uses the underscore prefix convention."
    - "Note: struct.Struct.__bases__[0].__name__ == 'object' (6 chars). Struct is a C extension type that directly inherits from object (it has no intermediate Python base class). This is typical for C extension types. 'object' (6 chars) == 'Struct' (6 chars) in length — an interesting equality where the class name and its base class name have the same character count."
    - "Note: struct.error.__bases__[0].__name__ == 'Exception' (9 chars). struct.error inherits from Python's built-in Exception class. struct_extra158 anchors this as a table row. 'Exception' (9 chars) is the most common base for user-visible exception classes. 'Exception'(9) > 'error'(5) in length by 4 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.error.__bases__[0].__name__.__eq__('Exception')
# struct.error.__name__.__len__()==5
#
# Wave 347 theme: struct.error class identity metadata.
#
# error.__name__ == 'error' (5 chars; lowercase; old Python exception naming convention).
# error.__module__ == 'struct' (6 chars; public module name despite C extension origin).
# error.__bases__[0].__name__ == 'Exception' (9 chars; single base is Exception).
# error.__name__.__len__() == 5 ('error' = 5 chars).
# struct_extra158 anchors error.__bases__[0].__name__=='Exception' and error class identity
# as table rows; this spec anchors error.__name__ and error.__module__ as the primary novel
# content alongside lengths. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra161.error_class_identity:
  description: "struct.error.__name__.__eq__('error')==True / error.__module__.__eq__('struct')==True / error.__bases__[0].__name__.__eq__('Exception')==True / error.__name__.__len__()==5 — error.__name__ is 'error' (5 chars; the exception class name; lowercase following old Python exception naming convention predating PEP 8 CapWords requirement; struct.error is the public alias for the C-level exception; its __name__ is the bare string 'error' not 'struct.error'); error.__module__ is 'struct' (6 chars; despite being implemented in Modules/_struct.c, the error class's __module__ is 'struct' (the public module) not '_struct' (the C extension); this is because the error class is re-exported through Lib/struct.py); error.__bases__[0].__name__ is 'Exception' (9 chars; struct.error inherits from Exception; struct_extra158 anchors this as a table row; confirmed here alongside __name__ and __module__; 'Exception'=9 chars > 'error'=5 chars by 4); error.__name__.__len__() is 5 ('error' = 'e'+'r'+'r'+'o'+'r' = 5 chars; first structclass161 anchor for error.__name__ and error.__module__)"
  kind: python_call_eq
  category: identity
  id_prefix: structclass161

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_error,       "error.__name__.__eq__",               ["error"],     true, "struct.error.__name__ == 'error' (5 chars; lowercase; old exception naming convention; bare name without module prefix)"]
    - [error_module_struct,    "error.__module__.__eq__",             ["struct"],    true, "struct.error.__module__ == 'struct' (6 chars; public module name; re-exported through Lib/struct.py despite C implementation)"]
    - [error_bases_exception,  "error.__bases__[0].__name__.__eq__",  ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception' (9 chars; inherits from Exception; struct_extra158 anchors; confirmed)"]
    - [error_name_len_5,       "error.__name__.__len__",              [], 5,          "struct.error.__name__.__len__() is 5 ('error' = 5 chars; lowercase 5-char exception name)"]

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct')
# struct.Struct.__module__.__eq__('_struct')
# struct.Struct.__bases__[0].__name__.__eq__('object')
# struct.Struct.__name__.__len__()==6
#
# Wave 347 theme: struct.Struct class identity metadata.
#
# Struct.__name__ == 'Struct' (6 chars; CapWords; modern naming convention).
# Struct.__module__ == '_struct' (7 chars; private C extension).
# Struct.__bases__[0].__name__ == 'object' (6 chars; single base; C extension type).
# Struct.__name__.__len__() == 6 ('Struct' = 6 chars).
# struct_extra157 anchors Struct.__name__ and Struct.__module__ as table rows; this spec
# anchors Struct.__bases__ as the primary novel content. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra161.Struct_class_identity:
  description: "struct.Struct.__name__.__eq__('Struct')==True / Struct.__module__.__eq__('_struct')==True / Struct.__bases__[0].__name__.__eq__('object')==True / Struct.__name__.__len__()==6 — Struct.__name__ is 'Struct' (6 chars; CapWords following modern Python naming convention for class names; the C extension type name; struct_extra157 anchors this as a table row; confirmed here alongside __bases__); Struct.__module__ is '_struct' (7 chars = '_'=1 + 'struct'=6; private C extension module containing the Struct type implementation; underscore prefix marks private; 'struct'(6) vs '_struct'(7): 1 char longer due to underscore; struct_extra157 anchors this as a table row; confirmed); Struct.__bases__[0].__name__ is 'object' (6 chars; Struct is a C extension type that directly inherits from Python's built-in object; no intermediate Python base class; C extension types commonly inherit directly from object; 'object'(6) == 'Struct'(6) in length — same 6 chars; first structclass161 anchor for Struct.__bases__); Struct.__name__.__len__() is 6 ('Struct' = 6 chars; same length as 'object'=6 chars; 'Struct'(6) < '_struct'(7) by 1 char)"
  kind: python_call_eq
  category: identity
  id_prefix: structclass161

  columns: [id, function, args, expected, description]
  rows:
    - [struct_class_name,     "Struct.__name__.__eq__",               ["Struct"],  true, "struct.Struct.__name__ == 'Struct' (6 chars; CapWords naming; C extension type; struct_extra157 anchors as row; confirmed)"]
    - [struct_class_module,   "Struct.__module__.__eq__",             ["_struct"], true, "struct.Struct.__module__ == '_struct' (7 chars; private C extension; '_'=1 + 'struct'=6; struct_extra157 anchors as row; confirmed)"]
    - [struct_bases_object,   "Struct.__bases__[0].__name__.__eq__",  ["object"],  true, "struct.Struct.__bases__[0].__name__ == 'object' (6 chars; C extension type inherits from object; first structclass161 anchor for Struct.__bases__)"]
    - [struct_name_len_6,     "Struct.__name__.__len__",              [], 6,        "struct.Struct.__name__.__len__() is 6 ('Struct' = 6 chars; same length as 'object'=6; shorter than '_struct'=7 by 1)"]

# ---------------------------------------------------------------------------
# struct.error and Struct module string lengths
#
# Wave 347 theme: class module attribute lengths.
#
# error.__module__.__len__() == 6 ('struct' = 6 chars).
# Struct.__module__.__len__() == 7 ('_struct' = 7 chars).
# error.__bases__[0].__name__.__len__() == 9 ('Exception' = 9 chars).
# Struct.__bases__[0].__name__.__len__() == 6 ('object' = 6 chars).
# No prior struct spec anchors these module lengths as a table under structclass161.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra161.class_module_and_base_lengths:
  description: "struct.error.__module__.__len__()==6 / Struct.__module__.__len__()==7 / error.__bases__[0].__name__.__len__()==9 / Struct.__bases__[0].__name__.__len__()==6 — error.__module__.__len__() is 6 ('struct' = 6 chars; the public module name; same length as 'Struct'=6 and 'object'=6; note 'struct'(6) < '_struct'(7) by 1 char); Struct.__module__.__len__() is 7 ('_struct' = '_'=1 + 'struct'=6 = 7 chars; private C extension; 1 char longer than 'struct'=6 due to underscore prefix; Struct.__module__.__len__()(7) > error.__module__.__len__()(6) by 1 char); error.__bases__[0].__name__.__len__() is 9 ('Exception' = 9 chars; Exception is the longest name in this spec: 'Exception'(9) > '_struct'(7) > 'struct'/'Struct'/'object'(6) > 'error'(5)); Struct.__bases__[0].__name__.__len__() is 6 ('object' = 6 chars; same as 'Struct'=6 and 'struct'=6 in length; interesting three-way length tie: 'struct'/'Struct'/'object' all 6 chars); length ordering: 'error'(5) < 'struct'/'Struct'/'object'(6) < '_struct'(7) < 'Exception'(9); first structclass161 anchor for module and base name lengths as a table"
  kind: python_call_eq
  category: identity
  id_prefix: structclass161

  columns: [id, function, args, expected, description]
  rows:
    - [error_module_len_6,      "error.__module__.__len__",               [], 6, "struct.error.__module__.__len__() is 6 ('struct' = 6 chars; public module name; same length as 'Struct'=6 and 'object'=6)"]
    - [struct_module_len_7,     "Struct.__module__.__len__",              [], 7, "struct.Struct.__module__.__len__() is 7 ('_struct' = '_'=1 + 'struct'=6 = 7; 1 char longer than 'struct'=6 due to underscore)"]
    - [error_base_name_len_9,   "error.__bases__[0].__name__.__len__",   [], 9, "struct.error.__bases__[0].__name__.__len__() is 9 ('Exception' = 9 chars; longest name in this spec; 4 chars longer than 'error'=5)"]
    - [struct_base_name_len_6,  "Struct.__bases__[0].__name__.__len__",  [], 6, "struct.Struct.__bases__[0].__name__.__len__() is 6 ('object' = 6 chars; same length as 'Struct'=6 and 'struct'=6; three-way tie)"]

# ---------------------------------------------------------------------------
# struct.error and Struct name confirmation and comparison
#
# Wave 347 theme: error and Struct names side by side.
#
# error.__name__.__eq__('error') (confirmed).
# Struct.__name__.__eq__('Struct') (confirmed).
# error.__module__.__eq__('struct') (confirmed).
# Struct.__bases__[0].__name__.__eq__('object') (confirmed).
# No prior struct spec anchors this combination as a table under structclass161.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra161.error_and_Struct_name_comparison:
  description: "struct.error.__name__.__eq__('error')==True / Struct.__name__.__eq__('Struct')==True / error.__module__.__eq__('struct')==True / Struct.__bases__[0].__name__.__eq__('object')==True — error.__name__ is 'error' (confirmed; 5 chars; lowercase; old naming convention; contrast with Struct.__name__=='Struct' which uses CapWords modern naming); Struct.__name__ is 'Struct' (confirmed; 6 chars; CapWords modern naming; 1 char longer than 'error'=5; naming convention difference reflects historical Python evolution: error predates CapWords requirement); error.__module__ is 'struct' (confirmed; 6 chars; public module name; note that error.__module__=='struct'(6) != Struct.__module__=='_struct'(7) — error goes through the public module but Struct is directly from the C extension); Struct.__bases__[0].__name__ is 'object' (confirmed; 6 chars; C extension inherits from object); length comparison: 'error'(5) < 'object'/'Struct'/'struct'(6) < '_struct'(7); first structclass161 anchor for this cross-class comparison table"
  kind: python_call_eq
  category: identity
  id_prefix: structclass161

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_b,          "error.__name__.__eq__",               ["error"],  true, "struct.error.__name__ == 'error' (confirmed; 5 chars; lowercase old naming vs 'Struct' CapWords modern naming; 'error'<'Struct' in length by 1)"]
    - [struct_name_b,         "Struct.__name__.__eq__",              ["Struct"], true, "struct.Struct.__name__ == 'Struct' (confirmed; 6 chars; CapWords; 1 char longer than 'error'=5; struct_extra157 anchors as row)"]
    - [error_module_b,        "error.__module__.__eq__",             ["struct"], true, "struct.error.__module__ == 'struct' (confirmed; 6 chars; public module; differs from Struct.__module__=='_struct'(7) by underscore)"]
    - [struct_bases_object_b, "Struct.__bases__[0].__name__.__eq__", ["object"], true, "struct.Struct.__bases__[0].__name__ == 'object' (confirmed; 6 chars; C extension type inherits from object)"]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error.__name__ is 'error' (5 chars). struct.error is the exception class raised when
# the format string or data is invalid in struct operations. Its __name__ is 'error' (lowercase)
# following the old Python convention for exception classes that predated PEP 8's requirement
# for CapWords exception names. struct.error is defined in Modules/_struct.c but is accessible
# as struct.error (via Lib/struct.py re-export). The lowercase 'error' name is a historical
# artifact that remains for backward compatibility. struct_extra158 anchors the error class
# identity but not error.__name__ as a standalone. No prior struct spec anchors error.__name__
# as a standalone under structclass161. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra161.error_name_eq_error:
  description: "struct.error.__name__.__eq__('error') == True — 'error' (5 chars; lowercase; old Python exception naming convention predating PEP 8 CapWords requirement; kept for backward compatibility); struct.error is raised by struct pack/unpack when format or data is invalid; error.__module__=='struct' (6 chars; public module name); error.__bases__[0].__name__=='Exception' (9 chars; struct_extra158 anchors); 'error'(5) < 'struct'(6) < 'Exception'(9) in length; first structclass161 standalone for error.__name__"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error.__module__ is 'struct' (6 chars). Despite the error class being implemented
# in the _struct C extension (Modules/_struct.c), its __module__ attribute is 'struct' (the
# public module name, not '_struct'). This is because Lib/struct.py imports error from _struct
# and re-exports it, setting the class's __module__ in the process. This contrasts with
# struct.Struct.__module__ == '_struct' (7 chars) — Struct's __module__ reflects the C
# extension directly. 'struct' (6 chars) vs '_struct' (7 chars): differ by 1 char (underscore).
# No prior struct spec anchors error.__module__ as a standalone under structclass161.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra161.error_module_eq_struct:
  description: "struct.error.__module__.__eq__('struct') == True — 'struct' (6 chars; public module name); error's __module__ is 'struct' not '_struct' because Lib/struct.py re-exports it from _struct; contrasts with Struct.__module__=='_struct'(7 chars): 'struct'(6) vs '_struct'(7) differ by 1 char (the leading underscore); error.__name__=='error'(5 chars); error.__bases__[0].__name__=='Exception'(9); length ordering: 'error'(5) < 'struct'(6) < '_struct'(7) < 'Exception'(9); first structclass161 standalone for error.__module__"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception' (9 chars). struct.error inherits from
# Python's built-in Exception class (not from OSError or any other more specific exception).
# 'Exception' is the conventional base class for application-level errors that should be
# caught with try/except. struct_extra158 anchors error.__bases__[0].__name__=='Exception'
# as a table row; this standalone provides a dedicated invariant under structclass161.
# 'Exception' (9 chars) is the longest name in this spec: 'error'(5) < 'struct'(6) < 'Struct'(6) < 'object'(6) < '_struct'(7) < 'Exception'(9).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra161.error_bases_Exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — 'Exception' (9 chars; longest name in this spec); struct.error inherits from Python's built-in Exception class; 'Exception' is the conventional base for application-level errors; struct_extra158 anchors this as a table row; confirmed here as standalone under structclass161; error.__name__=='error'(5) / error.__module__=='struct'(6); length ordering: 'error'(5) < 'struct'/'Struct'/'object'(6) < '_struct'(7) < 'Exception'(9); first structclass161 standalone for error.__bases__[0].__name__"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct') — standalone
#
# struct.Struct.__name__ is 'Struct' (6 chars). The Struct class is a C extension type
# defined in Modules/_struct.c. Its __name__ is 'Struct' (6 chars, CapWords) following
# the modern Python naming convention for classes (PEP 8: CapWords for class names).
# struct_extra157 anchors Struct.__name__ as a table row; this standalone provides a
# dedicated invariant under structclass161. Struct.__name__ (6 chars) == 'struct' (6 chars)
# == 'object' (6 chars) in length — all three share the same character count.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra161.Struct_name_eq_Struct:
  description: "struct.Struct.__name__.__eq__('Struct') == True — 'Struct' (6 chars; CapWords class name; C extension type in Modules/_struct.c; modern PEP 8 naming unlike 'error'=5 chars lowercase); struct_extra157 anchors as table row; Struct.__module__=='_struct'(7 chars); Struct.__bases__[0].__name__=='object'(6 chars); interesting three-way tie: 'Struct'(6)=='struct'(6)=='object'(6) in length; first structclass161 standalone for Struct.__name__"
  category: identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct') — standalone
#
# struct.Struct.__module__ is '_struct' (7 chars). The Struct class is a C extension type
# from Modules/_struct.c, and its __module__ reflects the C extension module name '_struct'
# directly (unlike struct.error, whose __module__ is the public 'struct' via re-export).
# '_struct' (7 chars) = '_'=1 + 'struct'=6. The leading underscore marks a private C
# extension not intended for direct user import. struct_extra157 anchors Struct.__module__
# as a table row; this standalone provides a dedicated invariant under structclass161.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra161.Struct_module_eq_struct_private:
  description: "struct.Struct.__module__.__eq__('_struct') == True — '_struct' (7 chars = '_'=1 + 'struct'=6; private C extension module; Modules/_struct.c); leading underscore marks private; Struct.__module__=='_struct'(7) vs error.__module__=='struct'(6): Struct's module is the C extension directly, error's is the public module (re-exported via Lib/struct.py); Struct.__name__=='Struct'(6 chars); struct_extra157 anchors as table row; '_struct'(7) > 'struct'(6) by 1 char (the leading underscore); first structclass161 standalone for Struct.__module__"
  category: identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__bases__[0].__name__.__eq__('object') — standalone
#
# struct.Struct.__bases__[0].__name__ is 'object' (6 chars). Struct is a C extension type
# (defined in Modules/_struct.c as PyTypeObject) that inherits directly from Python's
# built-in object class. C extension types commonly inherit directly from object without
# any intermediate Python-level base class. Struct.__bases__ is a 1-tuple containing only
# object. 'object' (6 chars) == 'Struct' (6 chars) — the class and its base class share
# the same name length. This contrasts with struct.error.__bases__[0].__name__=='Exception'
# (9 chars, a much longer base class name). No prior struct spec anchors Struct.__bases__
# as a standalone under structclass161. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra161.Struct_bases_object:
  description: "struct.Struct.__bases__[0].__name__.__eq__('object') == True — 'object' (6 chars; Python built-in ultimate base class; C extension types commonly inherit from object directly); Struct.__bases__ is a 1-tuple (single base class; no multiple inheritance); 'object'(6) == 'Struct'(6) in length — interesting equality; contrasts with error.__bases__[0].__name__=='Exception'(9 chars); Struct.__name__=='Struct'(6); Struct.__module__=='_struct'(7); first structclass161 standalone for Struct.__bases__[0].__name__"
  category: identity
  kind: python_call_eq
  function: "Struct.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
