spec: socket_extra1621
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "socket.socket is a pure Python wrapper class (Lib/socket.py) with __slots__ = ['__weakref__', '_io_refs', '_closed']"
    - "Because '__weakref__' is explicitly listed in __slots__, socket.socket.__dict__.__contains__('__weakref__') is True"
    - "The __weakref__ descriptor in socket.socket.__dict__ is a getset_descriptor"
    - "_io_refs and _closed are member_descriptor in socket.socket.__dict__"
    - "socket.error is OSError (same object); socket.timeout is TimeoutError (Python 3.3+)"
    - "socket.herror and socket.gaierror are pure Python classes inheriting from OSError without __slots__; their __dict__ DOES contain '__weakref__'"
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; enum metaclass does NOT add '__weakref__' to their own class __dict__"
    - "socket.socket instances DO support weak references via the explicit __weakref__ slot"
    - "socket.socket.__slots__ is a list (not a tuple) with exactly 3 entries"
  created_at: "2026-04-12"
error_model: python_exceptions

table socket_extra1621.socket_has_weakref_slot:
  description: "socket.socket explicitly includes '__weakref__' in its __slots__; socket.socket.__dict__ therefore contains '__weakref__' as a getset_descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1621hw

  columns: [id, function, args, expected]
  rows:
    - ["sk1621hw001", "socket.socket.__dict__.__contains__",                   ["__weakref__"],  true]
    - ["sk1621hw002", "socket.socket.__dict__.__contains__",                   ["__slots__"],    true]
    - ["sk1621hw003", "socket.socket.__dict__.__contains__",                   ["__dict__"],     false]
    - ["sk1621hw004", "socket.socket.__dict__.__contains__",                   ["_io_refs"],     true]
    - ["sk1621hw005", "socket.socket.__dict__.__contains__",                   ["_closed"],      true]
    - ["sk1621hw006", "type(socket.socket.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["sk1621hw007", "type(socket.socket.__dict__['_io_refs']).__name__.__eq__",    ["member_descriptor"], true]
    - ["sk1621hw008", "type(socket.socket.__dict__['_closed']).__name__.__eq__",     ["member_descriptor"], true]
    - ["sk1621hw009", "type(socket.socket.__dict__['__slots__']).__name__.__eq__",   ["list"],    true]
    - ["sk1621hw010", "socket.socket.__name__.__eq__",                         ["socket"],       true]
    - ["sk1621hw011", "socket.socket.__module__.__eq__",                       ["socket"],       true]
    - ["sk1621hw012", "socket.socket.__class__.__name__.__eq__",               ["type"],         true]
    - ["sk1621hw013", "socket.socket.__dict__.__class__.__name__.__eq__",      ["mappingproxy"], true]
    - ["sk1621hw014", "socket.socket.__dict__.__contains__",                   ["accept"],       true]
    - ["sk1621hw015", "socket.socket.__dict__.__contains__",                   ["close"],        true]
    - ["sk1621hw016", "socket.socket.__dict__.__contains__",                   ["detach"],       true]
    - ["sk1621hw017", "socket.socket.__dict__.__contains__",                   ["dup"],          true]
    - ["sk1621hw018", "socket.socket.__dict__.__contains__",                   ["makefile"],     true]
    - ["sk1621hw019", "socket.socket.__dict__.__contains__",                   ["family"],       true]
    - ["sk1621hw020", "socket.socket.__dict__.__contains__",                   ["type"],         true]
    - ["sk1621hw021", "type(socket.socket.__dict__['family']).__name__.__eq__", ["property"],   true]
    - ["sk1621hw022", "type(socket.socket.__dict__['type']).__name__.__eq__",   ["property"],   true]
    - ["sk1621hw023", "type(socket.socket.__dict__['accept']).__name__.__eq__", ["function"],   true]
    - ["sk1621hw024", "type(socket.socket.__dict__['close']).__name__.__eq__",  ["function"],   true]
    - ["sk1621hw025", "socket.socket.__dict__.__contains__",                   ["__init__"],     true]

table socket_extra1621.socket_slots_content:
  description: "socket.socket.__slots__ is a list with exactly 3 entries: '__weakref__', '_io_refs', '_closed'"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1621sl

  columns: [id, function, args, expected]
  rows:
    - ["sk1621sl001", "socket.socket.__slots__.__contains__",                  ["__weakref__"],  true]
    - ["sk1621sl002", "socket.socket.__slots__.__contains__",                  ["_io_refs"],     true]
    - ["sk1621sl003", "socket.socket.__slots__.__contains__",                  ["_closed"],      true]
    - ["sk1621sl004", "len(socket.socket.__slots__).__eq__",                   [3],              true]
    - ["sk1621sl005", "socket.socket.__slots__.__len__",                       [],               3]
    - ["sk1621sl006", "socket.socket.__slots__.__contains__",                  ["__dict__"],     false]
    - ["sk1621sl007", "socket.socket.__slots__.__contains__",                  ["family"],       false]
    - ["sk1621sl008", "socket.socket.__slots__.__contains__",                  ["type"],         false]
    - ["sk1621sl009", "socket.socket.__slots__.__contains__",                  ["accept"],       false]
    - ["sk1621sl010", "socket.socket.__dict__.__contains__",                   ["__weakref__"],  true]
    - ["sk1621sl011", "socket.socket.__dict__.__contains__",                   ["_io_refs"],     true]
    - ["sk1621sl012", "socket.socket.__dict__.__contains__",                   ["_closed"],      true]
    - ["sk1621sl013", "type(socket.socket.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["sk1621sl014", "type(socket.socket.__dict__['_io_refs']).__name__.__eq__",    ["member_descriptor"], true]
    - ["sk1621sl015", "type(socket.socket.__dict__['_closed']).__name__.__eq__",     ["member_descriptor"], true]
    - ["sk1621sl016", "socket.socket.__dict__.__contains__",                   ["__getstate__"], true]
    - ["sk1621sl017", "type(socket.socket.__dict__['__getstate__']).__name__.__eq__", ["function"], true]
    - ["sk1621sl018", "socket.socket.__dict__.__contains__",                   ["__enter__"],   true]
    - ["sk1621sl019", "socket.socket.__dict__.__contains__",                   ["__exit__"],    true]
    - ["sk1621sl020", "type(socket.socket.__dict__['__enter__']).__name__.__eq__", ["function"], true]
    - ["sk1621sl021", "socket.socket.__dict__.__contains__",                   ["sendfile"],     true]
    - ["sk1621sl022", "type(socket.socket.__dict__['sendfile']).__name__.__eq__", ["function"],  true]
    - ["sk1621sl023", "socket.socket.__dict__.__contains__",                   ["get_inheritable"], true]
    - ["sk1621sl024", "socket.socket.__dict__.__contains__",                   ["set_inheritable"], true]
    - ["sk1621sl025", "socket.socket.__bases__.__len__",                       [],               1]

table socket_extra1621.socket_exceptions_weakref:
  description: "socket.herror and socket.gaierror are pure Python OSError subclasses without __slots__; their __dict__ contains '__weakref__'; AddressFamily and SocketKind do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1621ex

  columns: [id, function, args, expected]
  rows:
    - ["sk1621ex001", "socket.herror.__dict__.__contains__",                   ["__weakref__"],  true]
    - ["sk1621ex002", "socket.gaierror.__dict__.__contains__",                 ["__weakref__"],  true]
    - ["sk1621ex003", "socket.herror.__dict__.__contains__",                   ["__slots__"],    false]
    - ["sk1621ex004", "socket.gaierror.__dict__.__contains__",                 ["__slots__"],    false]
    - ["sk1621ex005", "type(socket.herror.__dict__['__weakref__']).__name__.__eq__",  ["getset_descriptor"], true]
    - ["sk1621ex006", "type(socket.gaierror.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["sk1621ex007", "socket.herror.__dict__.__contains__",                   ["__doc__"],      true]
    - ["sk1621ex008", "socket.gaierror.__dict__.__contains__",                 ["__doc__"],      true]
    - ["sk1621ex009", "socket.herror.__dict__.__contains__",                   ["__module__"],   true]
    - ["sk1621ex010", "socket.gaierror.__dict__.__contains__",                 ["__module__"],   true]
    - ["sk1621ex011", "issubclass(socket.herror, OSError).__eq__",             [true],           true]
    - ["sk1621ex012", "issubclass(socket.gaierror, OSError).__eq__",           [true],           true]
    - ["sk1621ex013", "socket.herror.__name__.__eq__",                         ["herror"],       true]
    - ["sk1621ex014", "socket.gaierror.__name__.__eq__",                       ["gaierror"],     true]
    - ["sk1621ex015", "socket.herror.__module__.__eq__",                       ["socket"],       true]
    - ["sk1621ex016", "socket.gaierror.__module__.__eq__",                     ["socket"],       true]
    - ["sk1621ex017", "socket.herror.__bases__.__len__",                       [],               1]
    - ["sk1621ex018", "socket.gaierror.__bases__.__len__",                     [],               1]
    - ["sk1621ex019", "socket.herror.__dict__.__contains__",                   ["__dict__"],     false]
    - ["sk1621ex020", "socket.gaierror.__dict__.__contains__",                 ["__dict__"],     false]
    - ["sk1621ex021", "socket.AddressFamily.__dict__.__contains__",            ["__weakref__"],  false]
    - ["sk1621ex022", "socket.SocketKind.__dict__.__contains__",               ["__weakref__"],  false]
    - ["sk1621ex023", "socket.AddressFamily.__dict__.__contains__",            ["__slots__"],    false]
    - ["sk1621ex024", "socket.SocketKind.__dict__.__contains__",               ["__slots__"],    false]
    - ["sk1621ex025", "socket.socket.__dict__.__contains__",                   ["__weakref__"],  true]
