spec: struct_extra181
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.__name__ == 'struct' — len=6; module identity."
    - "struct.Struct.pack.__name__ == 'pack' — len=4; shortest Struct method name."
    - "struct.Struct.unpack.__name__ == 'unpack' — len=6; matches struct module name length."
    - "struct.Struct.pack_into.__name__ == 'pack_into' — len=9; underscore-separated compound name."
    - "struct.Struct.unpack_from.__name__ == 'unpack_from' — len=11; longest alongside iter_unpack."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack' — len=11; same length as unpack_from."
    - "struct.Struct.__init__.__name__ == '__init__' — len=8; dunder name including underscores."
    - "Name length ordering: pack(4) < unpack(6) < pack_into(9) < unpack_from(11) == iter_unpack(11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct module __name__ identity and length
#
# struct.__name__ == 'struct' (len=6)
#
# The module __name__ attribute equals its canonical name.
# ---------------------------------------------------------------------------

table struct_extra181.struct_module_name:
  description: "struct module __name__ identity and length; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: structmethods181

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,
       struct.__name__.__eq__,
       ["struct"],
       true,
       "struct.__name__.__eq__('struct') == True — module is named 'struct'; len=6; new to extra181"]
    - [name_len,
       struct.__name__.__len__,
       [],
       6,
       "struct.__name__.__len__() == 6 — 'struct' has 6 characters; new to extra181"]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct pack/unpack method __name__ values and lengths
#
# struct.Struct.pack.__name__        == 'pack'        (len=4)
# struct.Struct.unpack.__name__      == 'unpack'      (len=6)
# struct.Struct.pack_into.__name__   == 'pack_into'   (len=9)
# struct.Struct.unpack_from.__name__ == 'unpack_from' (len=11)
# struct.Struct.iter_unpack.__name__ == 'iter_unpack' (len=11)
#
# Name lengths strictly increase: pack(4) < unpack(6) < pack_into(9),
# then unpack_from and iter_unpack are tied at 11.
# ---------------------------------------------------------------------------

table struct_extra181.struct_method_names:
  description: "struct.Struct pack/unpack method __name__ values and lengths; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: structmethods181

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_eq,
       struct.Struct.pack.__name__.__eq__,
       ["pack"],
       true,
       "struct.Struct.pack.__name__.__eq__('pack') == True — pack method is named 'pack'; len=4; new to extra181"]
    - [pack_name_len,
       struct.Struct.pack.__name__.__len__,
       [],
       4,
       "struct.Struct.pack.__name__.__len__() == 4 — 'pack' has 4 characters; new to extra181"]
    - [unpack_name_eq,
       struct.Struct.unpack.__name__.__eq__,
       ["unpack"],
       true,
       "struct.Struct.unpack.__name__.__eq__('unpack') == True — unpack method is named 'unpack'; len=6; new to extra181"]
    - [unpack_name_len,
       struct.Struct.unpack.__name__.__len__,
       [],
       6,
       "struct.Struct.unpack.__name__.__len__() == 6 — 'unpack' has 6 characters; new to extra181"]
    - [pack_into_name_eq,
       struct.Struct.pack_into.__name__.__eq__,
       ["pack_into"],
       true,
       "struct.Struct.pack_into.__name__.__eq__('pack_into') == True — pack_into method is named 'pack_into'; len=9; new to extra181"]
    - [pack_into_name_len,
       struct.Struct.pack_into.__name__.__len__,
       [],
       9,
       "struct.Struct.pack_into.__name__.__len__() == 9 — 'pack_into' has 9 characters; new to extra181"]
    - [unpack_from_name_eq,
       struct.Struct.unpack_from.__name__.__eq__,
       ["unpack_from"],
       true,
       "struct.Struct.unpack_from.__name__.__eq__('unpack_from') == True — unpack_from method is named 'unpack_from'; len=11; new to extra181"]
    - [unpack_from_name_len,
       struct.Struct.unpack_from.__name__.__len__,
       [],
       11,
       "struct.Struct.unpack_from.__name__.__len__() == 11 — 'unpack_from' has 11 characters; new to extra181"]
    - [iter_unpack_name_eq,
       struct.Struct.iter_unpack.__name__.__eq__,
       ["iter_unpack"],
       true,
       "struct.Struct.iter_unpack.__name__.__eq__('iter_unpack') == True — iter_unpack method is named 'iter_unpack'; len=11; new to extra181"]
    - [iter_unpack_name_len,
       struct.Struct.iter_unpack.__name__.__len__,
       [],
       11,
       "struct.Struct.iter_unpack.__name__.__len__() == 11 — 'iter_unpack' has 11 characters; new to extra181"]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct.__init__ __name__ value and length
#
# struct.Struct.__init__.__name__ == '__init__' (len=8)
#
# The __init__ dunder method name includes four underscores; total length 8.
# ---------------------------------------------------------------------------

table struct_extra181.struct_init_name:
  description: "struct.Struct.__init__ __name__ value and length; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: structmethods181

  columns: [id, function, args, expected, description]
  rows:
    - [init_name_eq,
       struct.Struct.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "struct.Struct.__init__.__name__.__eq__('__init__') == True — __init__ dunder name; len=8; new to extra181"]
    - [init_name_len,
       struct.Struct.__init__.__name__.__len__,
       [],
       8,
       "struct.Struct.__init__.__name__.__len__() == 8 — '__init__' has 8 characters including underscores; new to extra181"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra181
# ---------------------------------------------------------------------------

invariant struct_extra181.module_name_is_struct:
  description: "struct.__name__ == 'struct' — module identity; len=6; new to extra181"
  category: identity
  kind: python_call_eq
  function: struct.__name__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra181.module_name_len_is_6:
  description: "struct.__name__.__len__() == 6 — 'struct' has 6 characters; new to extra181"
  category: identity
  kind: python_call_eq
  function: struct.__name__.__len__
  args: []
  expected: 6

invariant struct_extra181.pack_name_is_pack:
  description: "struct.Struct.pack.__name__ == 'pack' — pack method name; len=4; new to extra181"
  category: identity
  kind: python_call_eq
  function: struct.Struct.pack.__name__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra181.unpack_name_is_unpack:
  description: "struct.Struct.unpack.__name__ == 'unpack' — unpack method name; len=6; new to extra181"
  category: identity
  kind: python_call_eq
  function: struct.Struct.unpack.__name__.__eq__
  args: ["unpack"]
  expected: true

invariant struct_extra181.pack_into_name_is_pack_into:
  description: "struct.Struct.pack_into.__name__ == 'pack_into' — pack_into method name; len=9; new to extra181"
  category: identity
  kind: python_call_eq
  function: struct.Struct.pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true

invariant struct_extra181.unpack_from_name_is_unpack_from:
  description: "struct.Struct.unpack_from.__name__ == 'unpack_from' — unpack_from method name; len=11; new to extra181"
  category: identity
  kind: python_call_eq
  function: struct.Struct.unpack_from.__name__.__eq__
  args: ["unpack_from"]
  expected: true

invariant struct_extra181.iter_unpack_name_is_iter_unpack:
  description: "struct.Struct.iter_unpack.__name__ == 'iter_unpack' — iter_unpack method name; len=11; new to extra181"
  category: identity
  kind: python_call_eq
  function: struct.Struct.iter_unpack.__name__.__eq__
  args: ["iter_unpack"]
  expected: true

invariant struct_extra181.init_name_is_init:
  description: "struct.Struct.__init__.__name__ == '__init__' — __init__ dunder name; len=8; new to extra181"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true
