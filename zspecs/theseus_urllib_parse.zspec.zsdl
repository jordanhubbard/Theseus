spec: theseus_urllib_parse
version: ">=3.9"
backend: python_cleanroom(theseus_urllib_parse)
blocks: urllib

docs: https://www.rfc-editor.org/rfc/rfc3986

provenance:
  derived_from:
    - "https://www.rfc-editor.org/rfc/rfc3986 — URI RFC"
  notes:
    - "Clean-room URL parsing. Do NOT import urllib, urllib.parse, or any URL library."
    - "Implement URL parsing using only Python string operations."
    - "urlparse_scheme: parse 'https://example.com/path?q=1' and return the scheme 'https'."
    - "urlencode_basic: urlencode({'a': '1', 'b': '2'}) returns a string containing 'a=1'."
    - "quote_space: quote(' hello') returns '%20hello' or 'hello' with space encoded."
    - "Export: urlparse(url) -> dict with keys scheme/netloc/path/query, urlencode(params) -> str, quote(s) -> str."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_urllib_parse.scheme:
  description: "urlparse('https://example.com/path')['scheme'] == 'https'"
  category: urlparse
  kind: python_call_eq
  function: urlparse_scheme
  args: []
  expected: "https"

invariant theseus_urllib_parse.urlencode:
  description: "urlencode({'a': '1'}) contains 'a=1'"
  category: urlencode
  kind: python_call_eq
  function: urlencode_has_a1
  args: []
  expected: true

invariant theseus_urllib_parse.quote:
  description: "quote('hello world') encodes the space"
  category: quote
  kind: python_call_eq
  function: quote_space_encoded
  args: []
  expected: true
