spec: os_extra16
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra15.zspec.zsdl."
    - "os_extra7 covers get_terminal_size.__name__; os_extra13 covers cpu_count.__module__."
    - "No prior spec covers os.get_terminal_size.__module__ or os.get_terminal_size.__qualname__."
    - "os_extra14 covers times_result.__name__ and times_result.__module__."
    - "No prior spec covers os.times_result.__qualname__ or os.times_result.__bases__[0].__name__."
    - "No prior spec covers os.times_result.__mro__ length (3: times_result, tuple, object)."
    - "No prior spec covers os.O_NONBLOCK, os.O_NOCTTY, os.O_DIRECTORY, os.O_NOFOLLOW flag types."
    - "os_extra12 covers os.O_RDONLY/O_WRONLY/O_RDWR/O_CREAT/O_EXCL/O_APPEND/O_TRUNC; not O_NONBLOCK/O_NOCTTY/O_DIRECTORY/O_NOFOLLOW."
    - "os.get_terminal_size is implemented in the posix C extension; __module__ == 'posix'."
    - "os.times_result.__qualname__ == 'times_result' — top-level C struct_sequence type."
    - "os.times_result.__bases__[0].__name__ == 'tuple' — times_result is a tuple subclass (struct_sequence)."
    - "os.times_result.__mro__ has length 3: [times_result, tuple, object]."
    - "os.O_NONBLOCK, os.O_NOCTTY, os.O_DIRECTORY, os.O_NOFOLLOW are int constants (macOS values: 4, 131072, 1048576, 256)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.get_terminal_size — __module__ and __qualname__
#
# os_extra7 covers get_terminal_size.__name__ == 'get_terminal_size'.
# No prior spec checks get_terminal_size.__module__ or __qualname__.
# get_terminal_size is implemented in the posix C extension.
# ---------------------------------------------------------------------------

invariant os_extra16.get_terminal_size.module:
  description: "os.get_terminal_size.__module__ == 'posix' — implemented in the posix C extension"
  category: function_modules
  kind: python_call_eq
  function: get_terminal_size.__module__.__eq__
  args: ["posix"]
  expected: true

invariant os_extra16.get_terminal_size.qualname:
  description: "os.get_terminal_size.__qualname__ == 'get_terminal_size' — top-level C function; qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: get_terminal_size.__qualname__.__eq__
  args: ["get_terminal_size"]
  expected: true

# ---------------------------------------------------------------------------
# os.times_result — __qualname__, __bases__, and MRO length
#
# os_extra14 covers times_result.__name__ and times_result.__module__.
# No prior spec covers times_result.__qualname__, its tuple base class, or its
# MRO length. times_result is a C struct_sequence type that subclasses tuple.
# MRO is [times_result, tuple, object] — length 3.
# ---------------------------------------------------------------------------

invariant os_extra16.times_result.qualname:
  description: "os.times_result.__qualname__ == 'times_result' — top-level C struct_sequence type; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: times_result.__qualname__.__eq__
  args: ["times_result"]
  expected: true

invariant os_extra16.times_result.base_is_tuple:
  description: "os.times_result.__bases__[0].__name__ == 'tuple' — times_result is a tuple subclass (struct_sequence)"
  category: class_hierarchy
  kind: python_call_eq
  function: times_result.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "tuple"

invariant os_extra16.times_result.mro_length:
  description: "len(os.times_result.__mro__) == 3 — MRO is [times_result, tuple, object]"
  category: mro_lengths
  kind: python_call_eq
  function: times_result.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# os.O_NONBLOCK, os.O_NOCTTY, os.O_DIRECTORY, os.O_NOFOLLOW — type checks
#
# os_extra12 covers O_RDONLY/O_WRONLY/O_RDWR/O_CREAT/O_EXCL/O_APPEND/O_TRUNC.
# No prior spec covers O_NONBLOCK, O_NOCTTY, O_DIRECTORY, or O_NOFOLLOW.
# All are POSIX open(2) flag constants; all are plain Python ints.
# Exact values are macOS-specific (4, 131072, 1048576, 256) but type is portable.
# ---------------------------------------------------------------------------

table os_extra16.extra_open_flags_type:
  kind: python_call_eq
  category: constants
  id_prefix: flagtype

  columns: [id, function, args, expected]
  rows:
    - [O_NONBLOCK,  O_NONBLOCK.__class__.__name__.__eq__,  ["int"], true]
    - [O_NOCTTY,    O_NOCTTY.__class__.__name__.__eq__,    ["int"], true]
    - [O_DIRECTORY, O_DIRECTORY.__class__.__name__.__eq__, ["int"], true]
    - [O_NOFOLLOW,  O_NOFOLLOW.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# os.O_NONBLOCK, os.O_NOCTTY, os.O_DIRECTORY, os.O_NOFOLLOW — positivity
#
# All four constants are positive integers (no flag has value 0 other than
# O_RDONLY which is already covered). Verified on macOS: 4, 131072, 1048576, 256.
# ---------------------------------------------------------------------------

table os_extra16.extra_open_flags_positive:
  kind: python_call_eq
  category: constants
  id_prefix: flagpos

  columns: [id, function, args, expected]
  rows:
    - [O_NONBLOCK,  O_NONBLOCK.__gt__,  [0], true]
    - [O_NOCTTY,    O_NOCTTY.__gt__,    [0], true]
    - [O_DIRECTORY, O_DIRECTORY.__gt__, [0], true]
    - [O_NOFOLLOW,  O_NOFOLLOW.__gt__,  [0], true]
