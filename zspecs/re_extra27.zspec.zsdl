spec: re_extra27
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra26.zspec.zsdl."
    - "re_extra25 covers: compile/match/search/findall/finditer/sub/subn/split/fullmatch/escape function __qualname__ standalone invariants."
    - "re_extra26 covers: Pattern.match/search/findall/finditer/sub/split/fullmatch and Match.group/groups/start/end method __qualname__ standalone invariants."
    - "Focus: __module__ attributes for Pattern, Match, RegexFlag types; RegexFlag base class name; re.error class identity (PatternError); IGNORECASE/MULTILINE flag class qualname and module; re.compile __module__."
    - "re.Pattern.__qualname__ == 'Pattern' and re.Pattern.__module__ == 're' — Pattern is a C-extension type exported from the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.Match.__qualname__ == 'Match' and re.Match.__module__ == 're' — Match is a C-extension type exported from the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.RegexFlag.__qualname__ == 'RegexFlag' and re.RegexFlag.__module__ == 're' — RegexFlag is an IntFlag subclass. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.error.__qualname__ == 'PatternError' — re.error is an alias for re.PatternError; the underlying class name is PatternError. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.error.__bases__[0].__name__ == 'Exception' — PatternError inherits directly from Exception. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.IGNORECASE.__class__.__qualname__ == 'RegexFlag' — flag instances are of type RegexFlag. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.IGNORECASE.__class__.__module__ == 're' — RegexFlag type is defined in the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.compile.__module__ == 're' — module-level function; __module__ equals the module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern.__module__
#
# re_extra26 records Pattern method __qualname__ values. No prior re spec
# records re.Pattern.__module__. Pattern is a C-extension type; its __module__
# is 're'.
# ---------------------------------------------------------------------------

invariant re_extra27.Pattern.module:
  description: "re.Pattern.__module__ == 're' — Pattern is a C-extension type exported from the re module"
  category: class_module
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.Match.__module__
#
# re_extra26 records Match method __qualname__ values. No prior re spec
# records re.Match.__module__. Match is a C-extension type; its __module__
# is 're'.
# ---------------------------------------------------------------------------

invariant re_extra27.Match.module:
  description: "re.Match.__module__ == 're' — Match is a C-extension type exported from the re module"
  category: class_module
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.RegexFlag.__module__ and base class
#
# RegexFlag is an IntFlag subclass. No prior re spec records
# re.RegexFlag.__module__ or its base class name.
# re.RegexFlag.__qualname__ == 'RegexFlag' (covered here for cross-anchoring).
# re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — direct base.
# ---------------------------------------------------------------------------

invariant re_extra27.RegexFlag.module:
  description: "re.RegexFlag.__module__ == 're' — RegexFlag IntFlag subclass defined in the re module"
  category: class_module
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra27.RegexFlag.base_name:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits directly from IntFlag"
  category: class_hierarchy
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

# ---------------------------------------------------------------------------
# re.error / re.PatternError identity
#
# re.error is an alias for re.PatternError. The underlying class __qualname__
# is 'PatternError' (not 'error'). Its direct base is Exception.
# No prior re spec records re.error.__qualname__ or re.error.__bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant re_extra27.error.qualname:
  description: "re.error.__qualname__ == 'PatternError' — re.error is an alias for re.PatternError"
  category: class_qualname
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra27.error.base_name:
  description: "re.error.__bases__[0].__name__ == 'Exception' — PatternError inherits directly from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# re.IGNORECASE flag class identity
#
# re.IGNORECASE is a RegexFlag instance. Its __class__.__qualname__ == 'RegexFlag'
# and __class__.__module__ == 're'. No prior re spec records these.
# re.MULTILINE is also a RegexFlag instance with the same class qualname.
# ---------------------------------------------------------------------------

invariant re_extra27.IGNORECASE.class_qualname:
  description: "re.IGNORECASE.__class__.__qualname__ == 'RegexFlag' — flag instances are of type RegexFlag"
  category: module_attrs
  kind: python_call_eq
  function: IGNORECASE.__class__.__qualname__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra27.IGNORECASE.class_module:
  description: "re.IGNORECASE.__class__.__module__ == 're' — RegexFlag type is defined in the re module"
  category: module_attrs
  kind: python_call_eq
  function: IGNORECASE.__class__.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra27.MULTILINE.class_qualname:
  description: "re.MULTILINE.__class__.__qualname__ == 'RegexFlag' — MULTILINE flag instance is also of type RegexFlag"
  category: module_attrs
  kind: python_call_eq
  function: MULTILINE.__class__.__qualname__.__eq__
  args: ["RegexFlag"]
  expected: true

# ---------------------------------------------------------------------------
# re.compile.__module__
#
# re_extra25 records re.compile.__qualname__ == 'compile'. No prior re spec
# records re.compile.__module__. As a module-level function, __module__ is 're'.
# ---------------------------------------------------------------------------

invariant re_extra27.compile.module:
  description: "re.compile.__module__ == 're' — module-level function defined in the re module"
  category: function_module
  kind: python_call_eq
  function: compile.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all ten checks
#
# Covers Pattern/Match/RegexFlag __module__ (3), RegexFlag base class (1),
# error/__qualname__ and base (2), IGNORECASE class qualname and module (2),
# MULTILINE class qualname (1), and compile __module__ (1).
# ---------------------------------------------------------------------------

table re_extra27.module_and_hierarchy_checks:
  description: "__module__, base class, flag type, and error qualname checks for re types"
  kind: python_call_eq
  category: class_module

  columns: [id, function, args, expected]
  rows:
    - [Pattern_module,           Pattern.__module__.__eq__,                    ["re"],           true]
    - [Match_module,             Match.__module__.__eq__,                      ["re"],           true]
    - [RegexFlag_module,         RegexFlag.__module__.__eq__,                  ["re"],           true]
    - [RegexFlag_base,           "RegexFlag.__bases__[0].__name__.__eq__",     ["IntFlag"],      true]
    - [error_qualname,           error.__qualname__.__eq__,                    ["PatternError"], true]
    - [error_base,               "error.__bases__[0].__name__.__eq__",         ["Exception"],    true]
    - [IGNORECASE_class_qualname, IGNORECASE.__class__.__qualname__.__eq__,    ["RegexFlag"],    true]
    - [IGNORECASE_class_module,  IGNORECASE.__class__.__module__.__eq__,       ["re"],           true]
    - [MULTILINE_class_qualname, MULTILINE.__class__.__qualname__.__eq__,      ["RegexFlag"],    true]
    - [compile_module,           compile.__module__.__eq__,                    ["re"],           true]
