spec: is_even
version: ">=1.0.0"
backend: node(is-even)

docs: https://www.npmjs.com/package/is-even

provenance:
  derived_from:
    - "is-even README — https://www.npmjs.com/package/is-even"
    - "Test vectors verified with is-even via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-even source"
  notes:
    - "is-even is an npm package. Install: npm install is-even"
    - "Returns true if the number is even."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_even.isEven:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: iseven

  columns: [id, args, expected]
  rows:
    - [even_4,  [4],  true]
    - [odd_3,   [3],  false]
    - [zero,    [0],  true]
