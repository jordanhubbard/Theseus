spec: unicodedata_extra16
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl and prior extras through unicodedata_extra15.zspec.zsdl."
    - "unicodedata_extra15 covers: unidata_version.__class__.__name__=='str'; unidata_version.__len__()==6; lookup/__name__/normalize/category/bidirectional __module__ standalones; function_modules table."
    - "unicodedata_extra13 covers: lookup/name/normalize/category/bidirectional/combining/east_asian_width __name__ attributes."
    - "No prior spec verifies __qualname__ for any unicodedata built-in function as a standalone invariant."
    - "This spec covers: lookup/__qualname__=='lookup'; name/__qualname__=='name'; decimal/__qualname__=='decimal'; digit/__qualname__=='digit'; numeric/__qualname__=='numeric'; category/__qualname__=='category'; normalize/__qualname__=='normalize'; bidirectional/__qualname__=='bidirectional'."
    - "unicodedata built-in functions are C-level builtins; their __qualname__ equals their simple name (no owning class prefix). Verified at runtime."
    - "unicodedata.lookup.__qualname__ == 'lookup' — C builtin qualname is flat. Verified at runtime."
    - "unicodedata.name.__qualname__ == 'name' — C builtin qualname. Verified at runtime."
    - "unicodedata.decimal.__qualname__ == 'decimal' — C builtin qualname. Verified at runtime."
    - "unicodedata.digit.__qualname__ == 'digit' — C builtin qualname. Verified at runtime."
    - "unicodedata.numeric.__qualname__ == 'numeric' — C builtin qualname. Verified at runtime."
    - "unicodedata.category.__qualname__ == 'category' — C builtin qualname. Verified at runtime."
    - "unicodedata.normalize.__qualname__ == 'normalize' — C builtin qualname. Verified at runtime."
    - "unicodedata.bidirectional.__qualname__ == 'bidirectional' — C builtin qualname. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# unicodedata built-in function __qualname__ — lookup and name
#
# unicodedata_extra13 covers __name__ and unicodedata_extra15 covers __module__
# for these functions. No prior spec verifies __qualname__ for any unicodedata
# function as a standalone invariant. C-level built-in functions have a flat
# __qualname__ equal to their simple name.
# Verified: lookup.__qualname__ == 'lookup', name.__qualname__ == 'name'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra16.lookup.qualname:
  description: "unicodedata.lookup.__qualname__ == 'lookup' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: lookup.__qualname__.__eq__
  args: ["lookup"]
  expected: true

invariant unicodedata_extra16.name.qualname:
  description: "unicodedata.name.__qualname__ == 'name' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: name.__qualname__.__eq__
  args: ["name"]
  expected: true

# ---------------------------------------------------------------------------
# unicodedata built-in function __qualname__ — decimal, digit, numeric
#
# These three functions convert a Unicode character to its numeric value.
# No prior spec verifies their __qualname__ attributes.
# Verified: decimal.__qualname__=='decimal', digit.__qualname__=='digit',
#           numeric.__qualname__=='numeric'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra16.decimal.qualname:
  description: "unicodedata.decimal.__qualname__ == 'decimal' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: decimal.__qualname__.__eq__
  args: ["decimal"]
  expected: true

invariant unicodedata_extra16.digit.qualname:
  description: "unicodedata.digit.__qualname__ == 'digit' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: digit.__qualname__.__eq__
  args: ["digit"]
  expected: true

invariant unicodedata_extra16.numeric.qualname:
  description: "unicodedata.numeric.__qualname__ == 'numeric' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: numeric.__qualname__.__eq__
  args: ["numeric"]
  expected: true

# ---------------------------------------------------------------------------
# unicodedata built-in function __qualname__ — category, normalize, bidirectional
#
# These three functions query character properties.
# No prior spec verifies their __qualname__ attributes.
# Verified: category.__qualname__=='category', normalize.__qualname__=='normalize',
#           bidirectional.__qualname__=='bidirectional'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra16.category.qualname:
  description: "unicodedata.category.__qualname__ == 'category' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: category.__qualname__.__eq__
  args: ["category"]
  expected: true

invariant unicodedata_extra16.normalize.qualname:
  description: "unicodedata.normalize.__qualname__ == 'normalize' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: normalize.__qualname__.__eq__
  args: ["normalize"]
  expected: true

invariant unicodedata_extra16.bidirectional.qualname:
  description: "unicodedata.bidirectional.__qualname__ == 'bidirectional' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: bidirectional.__qualname__.__eq__
  args: ["bidirectional"]
  expected: true

# ---------------------------------------------------------------------------
# Table: unicodedata built-in function __qualname__ attributes
#
# Groups all __qualname__ checks for unicodedata built-in functions.
# No prior table covers unicodedata function __qualname__ attributes.
# All verified at runtime: each __qualname__ equals the function's simple name.
# ---------------------------------------------------------------------------

table unicodedata_extra16.function_qualnames:
  description: "unicodedata built-in function __qualname__ attributes — all equal simple function names"
  kind: python_call_eq
  category: function_identity
  id_prefix: ud16fq

  columns: [id, function, args, expected]
  rows:
    - [lookup,        lookup.__qualname__.__eq__,        ["lookup"],        true]
    - [name,          name.__qualname__.__eq__,          ["name"],          true]
    - [decimal,       decimal.__qualname__.__eq__,       ["decimal"],       true]
    - [digit,         digit.__qualname__.__eq__,         ["digit"],         true]
    - [numeric,       numeric.__qualname__.__eq__,       ["numeric"],       true]
    - [category,      category.__qualname__.__eq__,      ["category"],      true]
    - [normalize,     normalize.__qualname__.__eq__,     ["normalize"],     true]
    - [bidirectional, bidirectional.__qualname__.__eq__, ["bidirectional"], true]
