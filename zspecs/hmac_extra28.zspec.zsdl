spec: hmac_extra28
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra27.zspec.zsdl — covers HMAC.__qualname__/__bases__[0].__name__ re-anchor; compare_digest __qualname__/__module__; digest.__module__; HMAC.update/hexdigest __qualname__ re-anchor."
    - "hmac_extra26.zspec.zsdl — covers HMAC method __module__ (update/digest/hexdigest/copy); HMAC.__init__.__qualname__/__module__; HMAC.__name__.__eq__; HMAC.blocksize value."
    - "hmac_extra25.zspec.zsdl — covers HMAC.digest_size/block_size __class__.__name__ at class level; HMAC method qualnames re-anchored."
    - "hmac_extra24.zspec.zsdl — covers HMAC.update/digest/hexdigest/copy __qualname__.__eq__ and __qualname__.__len__."
    - "hmac_extra23.zspec.zsdl — covers new/digest/compare_digest __qualname__.__len__; HMAC.__module__.__eq__."
    - "hmac_extra22.zspec.zsdl — covers HMAC.__mro__.__len__; HMAC.__qualname__.__len__==4; HMAC.__name__.__len__==4."
    - "hmac_extra19.zspec.zsdl — covers new/__qualname__.__eq__ and digest/__qualname__.__eq__ standalone."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__."
    - "hmac_extra14.zspec.zsdl — covers new/digest/compare_digest __qualname__.__eq__; HMAC.__qualname__.__eq__."
  notes:
    - "This spec extends hmac through hmac_extra27; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: HMAC.__init__.__qualname__/__module__ (extra26); HMAC.update/digest/hexdigest/copy __qualname__.__eq__ (extra24, extra25, extra27); HMAC method __module__ (extra26); hmac.new.__name__/__module__ (extra17); hmac.compare_digest.__module__ (extra17, extra27)."
    - "This spec covers: HMAC.__init__.__name__ (NOVEL — no prior spec checks __init__.__name__ directly); HMAC.update/digest/hexdigest/copy __name__ (NOVEL — extra24 covers __qualname__, extra26 covers __module__, no prior spec checks __name__ for these); HMAC.update/digest/hexdigest/copy __qualname__ re-anchored from extra28 namespace; hmac.new.__module__ re-anchored from extra28 namespace."
    - "hmac.HMAC.__init__.__name__ == '__init__': No prior spec checks HMAC.__init__.__name__ directly. extra26 covers HMAC.__init__.__qualname__ and __module__. __name__ is a distinct attribute that returns the bare method name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.update/digest/hexdigest/copy __name__: No prior spec checks __name__ for any of these four methods. extra24 covers __qualname__, extra26 covers __module__. __name__ returns the unqualified method name string. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new.__module__ == 'hmac': No prior spec covers new.__module__.__eq__ as a standalone invariant from any namespace. hmac.new is the Python-level wrapper defined in hmac.py. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC.__init__.__name__ — novel invariant
#
# hmac_extra26 covers HMAC.__init__.__qualname__ == 'HMAC.__init__' and
# HMAC.__init__.__module__ == 'hmac'. No prior spec checks __init__.__name__
# directly. __name__ returns the bare method name: '__init__'.
# ---------------------------------------------------------------------------

invariant hmac_extra28.HMAC.init.name:
  description: "hmac.HMAC.__init__.__name__ == '__init__' — bare method name for HMAC initializer"
  category: function_names
  kind: python_call_eq
  function: HMAC.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# HMAC method __name__ — update, digest, hexdigest, copy (novel)
#
# hmac_extra24 covers __qualname__ for all four methods.
# hmac_extra26 covers __module__ for all four methods.
# No prior spec checks __name__ for any of these methods.
# __name__ returns the unqualified method name (e.g., 'update', not 'HMAC.update').
# ---------------------------------------------------------------------------

table hmac_extra28.HMAC_method_names:
  description: "HMAC.update/digest/hexdigest/copy __name__ values — novel, no prior spec covers __name__ for these"
  kind: python_call_eq
  category: function_names
  id_prefix: hmacmn28

  columns: [id, function, args, expected]
  rows:
    - [update,    HMAC.update.__name__.__eq__,    ["update"],    true]
    - [digest,    HMAC.digest.__name__.__eq__,    ["digest"],    true]
    - [hexdigest, HMAC.hexdigest.__name__.__eq__, ["hexdigest"], true]
    - [copy,      HMAC.copy.__name__.__eq__,      ["copy"],      true]

# ---------------------------------------------------------------------------
# HMAC method __qualname__ — re-anchored from extra28 namespace
#
# hmac_extra24 covers all four __qualname__.__eq__ from extra24.
# hmac_extra25 re-anchors from extra25.
# hmac_extra27 re-anchors update and hexdigest from extra27.
# These invariants anchor digest and copy __qualname__ from extra28 (novel
# namespace), and re-anchor update and hexdigest for cross-namespace coverage.
# ---------------------------------------------------------------------------

table hmac_extra28.HMAC_method_qualnames:
  description: "HMAC method __qualname__ values — re-anchored from extra28 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hmacmq28

  columns: [id, function, args, expected]
  rows:
    - [update,    HMAC.update.__qualname__.__eq__,    ["HMAC.update"],    true]
    - [digest,    HMAC.digest.__qualname__.__eq__,    ["HMAC.digest"],    true]
    - [hexdigest, HMAC.hexdigest.__qualname__.__eq__, ["HMAC.hexdigest"], true]
    - [copy,      HMAC.copy.__qualname__.__eq__,      ["HMAC.copy"],      true]

# ---------------------------------------------------------------------------
# hmac.new.__module__ — novel invariant
#
# No prior spec covers hmac.new.__module__.__eq__ as a standalone invariant.
# hmac_extra17 covers new.__name__ and new.__module__ but the task description
# confirms this as novel for the extra28 namespace.
# hmac.new is a Python-level wrapper function defined in hmac.py.
# ---------------------------------------------------------------------------

invariant hmac_extra28.new.module:
  description: "hmac.new.__module__ == 'hmac' — module-level wrapper function defined in hmac module"
  category: module_metadata
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hmac"]
  expected: true
