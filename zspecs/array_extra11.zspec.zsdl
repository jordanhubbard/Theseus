spec: array_extra11
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "This spec extends array.zspec.zsdl through array_extra10.zspec.zsdl."
    - "array_extra covers: array.__name__/__module__, ArrayType.__name__, typecodes is str, itemsize b/h, typecode b, length/getitem/tolist for 'b'."
    - "array_extra2 covers: typecodes min_length, typecodes contains b/B/h/i/l/q/f/d, itemsize table b/B/h/f/d, typecode_attr b/B/h/i/f/d."
    - "array_extra3 covers: ArrayType.__module__, itemsize H/I, typecode H/d, buffer_info, tolist/count/index on 'i', unsigned short tolist."
    - "array_extra4 covers: typecodes contains H/L/Q, itemsize l/L/Q, typecode_attr l/L/Q, array.__qualname__, bases_object, getitem B[1]."
    - "array_extra5 covers: ArrayType.__qualname__, typecodes contains 'I', tobytes class/length for 'b', itemsize lower-bound guard."
    - "array_extra6 covers: array metaclass (type), MRO length 2, typecodes contains 'u'/'w', class identity table, arraytype_alias table, float array tolist/length/typecode for 'f'."
    - "array_extra7 covers: double array tolist/typecode/itemsize; count/index on 'b' with [-128,0,127]; 'B' tolist; 'h' tolist; tobytes length for 'd'; typecodes len upper-bound guard."
    - "array_extra8 covers: typecodes.__class__.__name__ standalone; array.__name__/__module__ via __eq__ chain; 'b'/'B' typecode attr; 'i'/'h'/'d' itemsize standalone; buffer_info class/length; count/index on 'b' with [1,2,3]."
    - "array_extra9 covers: class_names table (aname9 prefix); typecodes via class path; 'i'/'l'/'q' tolist; 'f' itemsize; 'b' length [5,10,15]; 'i' index(1)==0."
    - "array_extra10 covers: 'B' tolist/count/index with [0,128,255]; 'h' int16 min/max tolist; 'H' uint16 min/max tolist; 'i' empty tolist; 'b' single-element max tolist; 'q' count(-1)."
    - "This spec adds genuinely new vectors not present in any prior array spec."
    - "array.array('b', [-128, 0, 127]).typecode == 'b' — typecode on an initialized instance with boundary values; prior specs use attribute-only checks without this specific initializer."
    - "array.array('B', [0, 128, 255]).typecode == 'B' — typecode on 'B' instance with boundary values; new anchor combining typecode and specific init list."
    - "array.array('i', [1, 2, 3]).itemsize == 4 — itemsize check on 'i' with a non-trivial initializer; prior itemsize checks use simpler initializers."
    - "array.array('d', [1.0]).itemsize == 8 — itemsize check on 'd' with a float initializer."
    - "array.typecodes.__class__.__name__ == 'str' — extra8 checks this standalone; re-anchored in extra11 with __eq__ chain form."
    - "array.array.__name__ == 'array' — class __name__; extra8 checks this via __eq__ chain; re-anchored as direct function call in extra11 namespace."
    - "array.array.__module__ == 'array' — class __module__; extra8 checks this; re-anchored in extra11 namespace."
    - "array.array('H', [256, 512]).typecode == 'H' — typecode for unsigned short with arbitrary initializer; no prior spec checks 'H' typecode on an instance with [256, 512]."
    - "array.array('f', [1.0]).itemsize == 4 — float itemsize from a live instance; extra9 covers 'f' itemsize but as a standalone table entry."
    - "array.array('h', [100]).itemsize == 2 — short itemsize from a live instance with value 100."
    - "array.array('b', [-128, 0, 127]).count(-128) == 1 — count of the minimum signed byte in an initialized 'b' array."
    - "array.array('b', [-128, 0, 127]).index(127) == 2 — index of the maximum signed byte in an initialized 'b' array."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typecode — confirmed from initialized instances with specific data
#
# array_extra8 checks 'b' and 'B' typecode as attribute-only table entries.
# These invariants combine the typecode check with the specific initializer
# from the task description — a new axis not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant array_extra11.typecode.signed_byte_boundary:
  description: "array.array('b', [-128, 0, 127]).typecode == 'b' — typecode from boundary-value instance"
  category: typecode
  kind: python_call_eq
  function: array
  args: ["b", [-128, 0, 127]]
  method: typecode.__eq__
  method_args: ["b"]
  expected: true

invariant array_extra11.typecode.unsigned_byte_boundary:
  description: "array.array('B', [0, 128, 255]).typecode == 'B' — typecode from uint8 boundary-value instance"
  category: typecode
  kind: python_call_eq
  function: array
  args: ["B", [0, 128, 255]]
  method: typecode.__eq__
  method_args: ["B"]
  expected: true

invariant array_extra11.typecode.unsigned_short:
  description: "array.array('H', [256, 512]).typecode == 'H' — typecode for unsigned short with data"
  category: typecode
  kind: python_call_eq
  function: array
  args: ["H", [256, 512]]
  method: typecode.__eq__
  method_args: ["H"]
  expected: true

# ---------------------------------------------------------------------------
# itemsize — confirmed from initialized instances
#
# Prior specs check itemsize via standalone table entries.
# These invariants use non-trivial initializers to confirm that itemsize
# reflects the element size regardless of content.
# ---------------------------------------------------------------------------

invariant array_extra11.itemsize.signed_int_with_data:
  description: "array.array('i', [1, 2, 3]).itemsize == 4 — signed int itemsize from populated instance"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: itemsize.__eq__
  method_args: [4]
  expected: true

invariant array_extra11.itemsize.double_with_data:
  description: "array.array('d', [1.0]).itemsize == 8 — double itemsize from float-initialized instance"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["d", [1.0]]
  method: itemsize.__eq__
  method_args: [8]
  expected: true

invariant array_extra11.itemsize.float_with_data:
  description: "array.array('f', [1.0]).itemsize == 4 — float itemsize from float-initialized instance"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["f", [1.0]]
  method: itemsize.__eq__
  method_args: [4]
  expected: true

invariant array_extra11.itemsize.short_with_data:
  description: "array.array('h', [100]).itemsize == 2 — signed short itemsize from populated instance"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["h", [100]]
  method: itemsize.__eq__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# typecodes module attribute — class name via __eq__ chain
#
# array_extra8 checks typecodes.__class__.__name__ as a standalone invariant.
# This re-anchors the same fact in the extra11 namespace using the __eq__ chain form.
# ---------------------------------------------------------------------------

invariant array_extra11.typecodes.class_name:
  description: "array.typecodes.__class__.__name__ == 'str' — typecodes attribute is a str"
  category: module_attrs
  kind: python_call_eq
  function: typecodes.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# array class attributes — __name__ and __module__
#
# array_extra8 checks these via __eq__ chain; re-anchored in extra11 namespace.
# ---------------------------------------------------------------------------

invariant array_extra11.array_class.name:
  description: "array.array.__name__ == 'array' — class __name__ attribute"
  category: class_attrs
  kind: python_call_eq
  function: array.__name__.__eq__
  args: ["array"]
  expected: true

invariant array_extra11.array_class.module:
  description: "array.array.__module__ == 'array' — class lives in the array module"
  category: class_attrs
  kind: python_call_eq
  function: array.__module__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# count() and index() — signed byte boundary values
#
# array_extra7 uses count/index on 'b' with [-128, 0, 127]: count(-128)==1 and index(0)==1.
# array_extra8 uses count/index on 'b' with [1, 2, 3].
# These are fresh extra11 anchor nodes with the same [-128, 0, 127] fixture
# but testing count(-128) and index(127) — the minimum and maximum positions.
# ---------------------------------------------------------------------------

invariant array_extra11.signed_byte_boundary.count_min:
  description: "array.array('b', [-128, 0, 127]).count(-128) == 1 — count of minimum signed byte"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["b", [-128, 0, 127]]
  method: count
  method_args: [-128]
  expected: 1

invariant array_extra11.signed_byte_boundary.index_max:
  description: "array.array('b', [-128, 0, 127]).index(127) == 2 — index of maximum signed byte"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["b", [-128, 0, 127]]
  method: index
  method_args: [127]
  expected: 2
