# Theseus configuration — example / reference file.
#
# Two-layer config scheme:
#   config.yaml       — generic defaults; checked into git (no secrets)
#   config.site.yaml  — site-specific overrides (API keys, IPs, local paths);
#                       gitignored, never committed
#
# To configure a new site: copy this file to config.site.yaml and fill in
# your values.  config.yaml is already committed with safe defaults.

ai:
  # provider controls which AI backend is used for synthesis.
  #
  # 'auto'       Try CLI agents in order (claude → codex → droid), then openai endpoint.
  # 'claude'     Claude CLI  — install from https://claude.ai/code
  #              Invoked as: claude --print -  (prompt via stdin)
  # 'codex'      OpenAI Codex CLI  — install from https://github.com/openai/codex
  #              Invoked as: codex --quiet -  (prompt via stdin)
  # 'droid'      Droid CLI  — set cli_agent_command = "droid" and use 'cli_agent'
  # 'openai'     Any OpenAI-compatible HTTP endpoint: Ollama, LM Studio, OpenRouter,
  #              real OpenAI API, or any local server.  Set openai_base_url + model.
  # 'cli_agent'  Generic: any CLI agent that reads a prompt from stdin and prints
  #              the response to stdout.  Set cli_agent_command.
  provider: auto

  # OpenAI-compatible endpoint (used when provider is 'openai' or 'auto' fallback).
  # Examples:
  #   Ollama local:   http://localhost:11434/v1
  #   LM Studio:      http://localhost:1234/v1
  #   OpenRouter:     https://openrouter.ai/api/v1
  #   Real OpenAI:    https://api.openai.com/v1
  openai_base_url: "http://localhost:11434/v1"
  openai_api_key: ""          # required for OpenRouter / real OpenAI
  openai_model: "gpt-4o"      # model name for the openai provider

  # Generic CLI agent (used when provider is 'cli_agent').
  # cli_agent_command: "droid"
  # cli_agent_args: ["-"]     # args passed before the prompt; "-" = read stdin

artifact_store:
  # Base URL for storing built artifacts.
  # Must be writable. Examples:
  #   s3://theseus-artifacts          (MinIO, see endpoint_url below)
  #   s3://my-aws-bucket/theseus      (real AWS S3, no endpoint_url needed)
  #   file:///Users/me/theseus-artifacts
  url: "s3://theseus-artifacts"
  # MinIO (or other S3-compatible) endpoint — omit for real AWS S3
  endpoint_url: "http://ubumeh.local:9000"
  access_key: "theseus"
  secret_key: ""   # fill in your MinIO root password

  # Cache generated source files (Makefile+distinfo for FreeBSD, default.nix
  # for Nix) to the artifact store in addition to built binaries.
  # Off by default — enable in your local config.yaml if you want to inspect
  # generated sources. Not committed to the repo.
  cache_generated_sources: false

targets:
  # Build workers — freebsd_ports driver jobs go to freebsd.local,
  # nixpkgs driver jobs go to ubuntu.local.
  - name: macos-local
    os: darwin
    arch: arm64
    local: true
  - name: freebsd.local
    os: freebsd
    arch: amd64
    host: freebsd.local
    user: jkh
    driver: freebsd_ports
  - name: ubuntu.local
    os: linux
    arch: amd64
    host: ubuntu.local
    user: jkh
    driver: nixpkgs
    nix_via_docker: true
